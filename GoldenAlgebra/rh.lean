    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 γ : ℝ}
    (Hstarts : DzeroStartsAfter Dzero γ)
    (hT0_pos : 0 < T0)
    (hT0_le_2pi : T0 ≤ 2 * Real.pi) :
