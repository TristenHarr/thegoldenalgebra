    (f : ℂ → ℂ) (s : ℂ) (k : ℤ) : Prop :=
  ∃ g : ℂ → ℂ,
    ContinuousAt g s ∧
      logDeriv f =ᶠ[𝓝[≠] s]
        (fun z : ℂ => (k : ℂ) / (z - s) + g z)

