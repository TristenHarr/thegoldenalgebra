    (fun z _ => xiModelError_zeros100ceil_decomp z)
    (perWindowGlobalErrorControl_of_low_mid_high
      H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ Global `XiPullbackAntiHerglotzTarget`** from the
canonical-error global control target.

Since the local package covers all of `тДВ` (region = `True`), its
`implies_regionAntiHerglotz` gives `(╬Ы[XiPullback] z).im тЙд 0` for all
`z` with `0 < z.im` тАФ exactly `XiPullbackAntiHerglotzTarget`. -/
theorem xiPullbackAntiHerglotzTarget_of_xiModelErrorGlobalControl
    (H : XiModelErrorGlobalControlTarget) :
    XiPullbackAntiHerglotzTarget := by
  intro z hz
  -- Inline the local package's anti-Herglotz on z directly via the
  -- model-Anti + finite-band error margin chain (sidesteps the
  -- `P.region z = (fun _ => True) z` definitional-reduction issue).
  rw [xiModelError_zeros100ceil_decomp z, Complex.add_im]
  have h_model_im :
      (xiCloudDensityModel_zeros100ceil.model z).im тЙд 0 :=
    xiCloudDensityModel_zeros100ceil_modelAnti z hz
  obtain тЯиT, hT2pi, hregTтЯй := exists_admissible_T z
  have h_err_margin :
      |(xiModelError_zeros100ceil z).im|
        тЙд -(xiCloudDensityModel_zeros100ceil.model z).im :=
    errorMargin_of_globalErrorControl
      (M := xiCloudDensityModel_zeros100ceil)
      (error := xiModelError_zeros100ceil)
      xiCloudDensityModel_zeros100ceil_zeros
      (perWindowGlobalErrorControl_of_low_mid_high
        H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)
      hT2pi hz hregT
  have h_err_le :
      (xiModelError_zeros100ceil z).im
        тЙд |(xiModelError_zeros100ceil z).im| :=
    le_abs_self _
  linarith

-- =====================================================================
-- CLXXXVI: Phase 1.1 тАФ localized fluctuation measures (Mathlib measure objects)
-- =====================================================================
-- The ┬з16.1 `FluctuationMeasureData` records `S = N тИТ NтВА` at the
-- function level. This section lifts the same data to actual Mathlib
-- `Measure тДЭ` objects:
--   `dN = ╬г_{j<n} (mult j) тАв dirac (Z j)`     (Phase 1.1 discrete part)
--   `dNтВА = volume.withDensity ╧Б`              (Phase 1.1 smooth part)
-- and their localized restrictions to a window `[T, X]`. We do NOT yet
-- subtract them as a `SignedMeasure тДЭ` on the whole real line тАФ
-- `dNтВА` is infinite globally, so that is the trap. Localized first,
-- whole-line later via `X тЖТ тИЮ`.

namespace Phase1Measure

open MeasureTheory
open scoped ENNReal

/-- **Discrete zero-counting measure:**
  `dN = ╬г_{j<n} (mult j) тАв dirac (Z j)`.
The atomic measure supported on the zero ordinates `{Z 0, тАж, Z (n-1)}`
with weight `mult j` at each. -/
noncomputable def discreteZeroMeasure
    (D : FluctuationMeasureData) : Measure тДЭ :=
  (Finset.range D.n).sum fun j =>
    ((D.mult j : тДЭтЙе0тИЮ)) тАв Measure.dirac (D.Z j)

/-- **Smooth zero-counting measure:**
  `dNтВА = volume.withDensity (ENNReal.ofReal тИШ ╧Б)`,
where `╧Б = zeroDensityRho = (1/(2╧А))┬╖log(u/(2╧А))`. Infinite on `тДЭ`
globally; finite when restricted to a bounded window. -/
noncomputable def smoothZeroCountingMeasure : Measure тДЭ :=
  (MeasureTheory.volume : Measure тДЭ).withDensity
    (fun u : тДЭ => ENNReal.ofReal (zeroDensityRho u))

/-- **Localized discrete measure** on `[T, X]`. -/
noncomputable def discreteZeroMeasureOn
    (D : FluctuationMeasureData) (T X : тДЭ) : Measure тДЭ :=
  (discreteZeroMeasure D).restrict (Set.Icc T X)

/-- **Localized smooth measure** on `[T, X]`. Finite on any bounded
interval because `╧Б` is bounded there. -/
noncomputable def smoothZeroCountingMeasureOn
    (T X : тДЭ) : Measure тДЭ :=
  smoothZeroCountingMeasure.restrict (Set.Icc T X)

end Phase1Measure

-- =====================================================================
-- CLXXXVII: Bridge тАФ concrete smooth Stieltjes partial via intervalIntegral
-- =====================================================================
-- The ┬з16.2-A `StieltjesPartialSplit` keeps `smoothPart : тДЭ тЖТ тДЭ` abstract.
-- This section pins it down to the explicit interval integral
--   `smoothStieltjesPartial f T X := тИл u in T..X, f u ┬╖ ╧Б(u) du`
-- and constructs `FluctuationMeasureData.toStieltjesPartialSplit` from
-- any `FluctuationMeasureData D` and integrand `f`, with the discrete
-- ╬г-of-Diracs side defaulting to `discreteStieltjesPartial D.Z D.mult D.n`.

namespace Phase1Measure

open MeasureTheory
open intervalIntegral

/-- **Smooth Stieltjes partial integral** for a real integrand `f`:
  `тИл_T^X f(u) ┬╖ ╧Б(u) du`. -/
noncomputable def smoothStieltjesPartial
    (f : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДЭ :=
  тИл u in T..X, f u * zeroDensityRho u

/-- **Concrete total finite Stieltjes partial** for `f`:
  `╬г_{T тЙд Z j тЙд X} mult j ┬╖ f(Z j) тИТ тИл_T^X f(u)┬╖╧Б(u) du`.
The function-level realization of `тИл_T^X f dS = тИл_T^X f d(N тИТ NтВА)`. -/
noncomputable def concreteStieltjesPartial
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДЭ :=
  discreteStieltjesPartial D.Z D.mult D.n f T X
    - smoothStieltjesPartial f T X

/-- тнР **PROVED тАФ `FluctuationMeasureData` projects to `StieltjesPartialSplit`.**
The discrete side is the canonical `discreteStieltjesPartial`; the smooth
side is the concrete `smoothStieltjesPartial`; the `total` field is the
difference and `total_eq` is `rfl`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toStieltjesPartialSplit
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T : тДЭ) :
    StieltjesPartialSplit where
  Z          := D.Z
  mult       := D.mult
  n          := D.n
  f          := f
  T          := T
  smoothPart := fun X => smoothStieltjesPartial f T X
  total      := fun X => concreteStieltjesPartial D f T X
  total_eq   := fun _ => rfl

/-- тнР **PROVED тАФ specialization to the imaginary paired-Cauchy kernel.**
Plugs `f := pairedCauchyImKernel x y` into the generic
`toStieltjesPartialSplit`. This is the integrand that appears on the
imaginary side of `тИл K_u(z) dS(u)`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toKernelStieltjesPartialSplit
    (D : FluctuationMeasureData) (x y T : тДЭ) :
    StieltjesPartialSplit :=
  D.toStieltjesPartialSplit
    (fun u : тДЭ => pairedCauchyImKernel x y u) T

end Phase1Measure

-- =====================================================================
-- CLXXXVIII: Phase 1.3 тАФ finite + improper kernel IBP scaffolds
-- =====================================================================
-- The integration-by-parts identity
--   `тИл_T^X k_z(u) dS(u)
--      = k_z(X)┬╖S(X) тИТ k_z(T)┬╖S(T) тИТ тИл_T^X S(u)┬╖k_z'(u) du`
-- packaged as named data. `FiniteKernelStieltjesIBP` carries the finite
-- identity per `X`; `ImproperKernelStieltjesIBP` adds the three limits
-- needed to pass `X тЖТ тИЮ`:
--   (i)  partial X тЖТ L
--   (ii) k_z(X)┬╖S(X) тЖТ 0  (boundary at тИЮ)
--   (iii) тИл_T^X S k' тЖТ J
-- From these, the improper IBP identity reads `L = тИТk_z(T)┬╖S(T) тИТ J`
-- and the bound `|L| тЙд |k_z(T)|┬╖B(T) + тИл_T^тИЮ B(u)┬╖|k_z'(u)| du` follows
-- from `|S u| тЙд B u` and the kernel decay envelopes
-- (`abs_pairedCauchyImKernelDeriv_le_adaptive_18`).

namespace Phase1IBP

open Filter Topology
open intervalIntegral

/-- **IBP boundary term** for the imaginary paired-Cauchy kernel:
  `k_z(X)┬╖S(X) тИТ k_z(T)┬╖S(T)`. -/
noncomputable def kernelBoundaryTerm
    (S : тДЭ тЖТ тДЭ) (x y T X : тДЭ) : тДЭ :=
  pairedCauchyImKernel x y X * S X
    - pairedCauchyImKernel x y T * S T

/-- **IBP derivative-side integral**:
  `тИл_T^X S(u) ┬╖ k_z'(u) du`. -/
noncomputable def kernelIBPDerivativeIntegral
    (S : тДЭ тЖТ тДЭ) (x y T X : тДЭ) : тДЭ :=
  тИл u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Finite Stieltjes IBP identity for the imaginary kernel.**
Packages the per-`X` identity
  `partial X = k_z(X)┬╖S(X) тИТ k_z(T)┬╖S(T) тИТ тИл_T^X S k'`.
The `partial` field is the running finite Stieltjes integral
  `тИл_T^X k_z(u) dS(u)`
(realized in practice via `concreteStieltjesPartial`). -/
structure FiniteKernelStieltjesIBP where
  S          : тДЭ тЖТ тДЭ
  partialF   : тДЭ тЖТ тДЭ
  x          : тДЭ
  y          : тДЭ
  T          : тДЭ
  finite_ibp :
    тИА X : тДЭ,
      partialF X =
        kernelBoundaryTerm S x y T X
          - kernelIBPDerivativeIntegral S x y T X

/-- **Improper Stieltjes IBP for the imaginary kernel.** Extends the
finite identity with three limits that let us pass `X тЖТ тИЮ`:

* `partial_tendsto`            тАФ `partial X тЖТ L`
* `boundary_atTop`             тАФ `k_z(X)┬╖S(X) тЖТ 0`
* `derivative_integral_tendsto` тАФ `тИл_T^X S k' тЖТ J`

The improper IBP identity that follows: `L = тИТk_z(T)┬╖S(T) тИТ J`. -/
structure ImproperKernelStieltjesIBP where
  S          : тДЭ тЖТ тДЭ
  partialF   : тДЭ тЖТ тДЭ
  x          : тДЭ
  y          : тДЭ
  T          : тДЭ
  L          : тДЭ
  finiteIBP  : FiniteKernelStieltjesIBP
  finiteIBP_S_eq        : finiteIBP.S = S
  finiteIBP_partial_eq  : finiteIBP.partialF = partialF
  finiteIBP_x_eq        : finiteIBP.x = x
  finiteIBP_y_eq        : finiteIBP.y = y
  finiteIBP_T_eq        : finiteIBP.T = T
  partialF_tendsto :
    Tendsto partialF atTop (ЁЭУЭ L)
  boundary_atTop :
    Tendsto
      (fun X : тДЭ => pairedCauchyImKernel x y X * S X)
      atTop
      (ЁЭУЭ 0)
  derivative_integral_tendsto :
    тИГ J : тДЭ,
      Tendsto
        (fun X : тДЭ => kernelIBPDerivativeIntegral S x y T X)
        atTop
        (ЁЭУЭ J)

/-- тнР **PROVED тАФ improper IBP identity: `L = тИТk_z(T)┬╖S(T) тИТ J`.**
The three limits combined with the per-`X` finite identity force the
limiting value of the partial integral to be the boundary term at `T`
plus the (negated) derivative-side integral at infinity. -/
theorem ImproperKernelStieltjesIBP.improper_identity
    (I : ImproperKernelStieltjesIBP) :
    тИГ J : тДЭ,
      Tendsto
        (fun X : тДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (ЁЭУЭ J) тИз
      I.L = - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J := by
  obtain тЯиJ, hJтЯй := I.derivative_integral_tendsto
  refine тЯиJ, hJ, ?_тЯй
  -- partial X = k(X)┬╖S(X) тИТ k(T)┬╖S(T) тИТ тИл_T^X S k'
  have h_finite_X :
      тИА X : тДЭ,
        I.partialF X =
          pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X := by
    intro X
    have h := I.finiteIBP.finite_ibp X
    -- rewrite finiteIBP fields тЖТ I fields via the *_eq hypotheses
    rw [I.finiteIBP_partial_eq] at h
    unfold kernelBoundaryTerm at h
    rw [I.finiteIBP_S_eq, I.finiteIBP_x_eq, I.finiteIBP_y_eq, I.finiteIBP_T_eq] at h
    exact h
  -- Pass to the limit `X тЖТ тИЮ`.
  have h_const :
      Tendsto
        (fun _ : тДЭ => pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (ЁЭУЭ (pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    tendsto_const_nhds
  have h_diff :
      Tendsto
        (fun X : тДЭ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (ЁЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    I.boundary_atTop.sub h_const
  have h_rhs :
      Tendsto
        (fun X : тДЭ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T
            - kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (ЁЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) :=
    h_diff.sub hJ
  -- partial = RHS as functions, so the limit of partial is the same.
  have h_partial_rhs :
      (fun X : тДЭ => I.partialF X) =
      (fun X : тДЭ =>
        pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X) :=
    funext h_finite_X
  have h_partial_lim :
      Tendsto (fun X : тДЭ => I.partialF X) atTop
        (ЁЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) := by
    rw [h_partial_rhs]; exact h_rhs
  -- Unique limit of `partial` тЯ╣ `L = 0 тИТ k(T)┬╖S(T) тИТ J`.
  have h_unique :
      I.L = 0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J :=
    tendsto_nhds_unique I.partialF_tendsto h_partial_lim
  linarith

/-- тнР **PROVED тАФ improper IBP wrapper.** Extract the `ImproperStieltjesIntegralData`
of ┬з16.2 from an `ImproperKernelStieltjesIBP`. -/
noncomputable def ImproperKernelStieltjesIBP.toImproperData
    (I : ImproperKernelStieltjesIBP) :
    ImproperStieltjesIntegralData where
  F        := I.partialF
  T        := I.T
  L        := I.L
  converges := I.partialF_tendsto

-- ---------------------------------------------------------------------
-- CLXXXIX: IBP-side bound on |L|
-- ---------------------------------------------------------------------
-- With `|S(u)| тЙд B(u)` on `[T, тИЮ)` and the derivative-side integral
-- bounded in absolute value by тИл_T^тИЮ B(u)┬╖|k_z'(u)| du, the improper
-- identity `L = тИТk_z(T)┬╖S(T) тИТ J` gives
--   |L|  тЙд  |k_z(T)|┬╖B(T) + |J|
--         тЙд  |k_z(T)|┬╖B(T) + тИл_T^тИЮ B(u)┬╖|k_z'(u)| du.
-- The first inequality is triangle; the second is the hypothesis on
-- the derivative-side integral.

/-- тнР **PROVED тАФ triangle bound on the improper IBP value.**
`|L| тЙд |k_z(T)┬╖S(T)| + |J|`. Pure arithmetic from the improper IBP
identity. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_triangle
    (I : ImproperKernelStieltjesIBP) :
    тИГ J : тДЭ,
      Tendsto
        (fun X : тДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (ЁЭУЭ J) тИз
      |I.L| тЙд |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
  obtain тЯиJ, hJ, hLтЯй := I.improper_identity
  refine тЯиJ, hJ, ?_тЯй
  -- L = -k(T)┬╖S(T) - J, so |L| = |-k┬╖S - J| тЙд |k┬╖S| + |J|.
  rw [hL]
  calc |(- pairedCauchyImKernel I.x I.y I.T * I.S I.T) - J|
      тЙд |- pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := abs_sub _ _
    _ = |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
        rw [neg_mul, abs_neg]

/-- тнР **PROVED тАФ `|L|` bound via `|S(T)| тЙд B(T)` and a derivative-integral
envelope.** Given:
- `|S(u)| тЙд B(u)` on `[T, тИЮ)`;
- the derivative-side integral has limit `J` with `|J| тЙд Jbound`;
the improper IBP value satisfies
  `|L|  тЙд  |k_z(T)|┬╖B(T)  +  Jbound`.

The shape matches the `ibpMargin` field of `ImaginaryStieltjesTailIBPBound`
(┬з13, CXLIV): `|k_z(T)|┬╖B(T) + integralBound тЙд modelMargin`. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_of_S_and_J_bound
    (I : ImproperKernelStieltjesIBP)
    (B : тДЭ тЖТ тДЭ)
    (hS_bound : тИА u : тДЭ, I.T тЙд u тЖТ |I.S u| тЙд B u)
    (Jbound : тДЭ)
    (hJ_bound :
      тИА J : тДЭ,
        Tendsto
          (fun X : тДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
          atTop
          (ЁЭУЭ J) тЖТ |J| тЙд Jbound) :
    |I.L| тЙд |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound := by
  obtain тЯиJ, hJ, hLtriтЯй := I.abs_L_le_triangle
  have hJ_le : |J| тЙд Jbound := hJ_bound J hJ
  have hS_T : |I.S I.T| тЙд B I.T := hS_bound I.T le_rfl
  have h_kS : |pairedCauchyImKernel I.x I.y I.T * I.S I.T|
              тЙд |pairedCauchyImKernel I.x I.y I.T| * B I.T := by
    rw [abs_mul]
    exact mul_le_mul_of_nonneg_left hS_T (abs_nonneg _)
  linarith [hLtri, hJ_le, h_kS]

end Phase1IBP

-- =====================================================================
-- CXC: Closed-form discharge of `ImaginaryStieltjesTailIBPBound`
-- =====================================================================
-- Threads `Phase1IBP.ImproperKernelStieltjesIBP` into the existing
-- ┬з13 `ImaginaryStieltjesTailIBPBound`. The discharge requires:
--   тАв the improper IBP package (which we just defined);
--   тАв a bound function `B : тДЭ тЖТ тДЭ` for the fluctuation;
--   тАв a closed-form bound `Jbound` for the derivative-side improper
--     integral (the analytic content that produces the `18y/u┬│` decay
--     envelope, currently a hypothesis until the next-pass IBP grind
--     produces it from `abs_pairedCauchyImKernelDeriv_le_adaptive_18`).
-- The output is an `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
-- is exactly the IBP-side bound the ┬з13 chain consumes.

namespace Phase1IBP

open Filter Topology

/-- тнР **PROVED тАФ `ImproperKernelStieltjesIBP` discharges
`ImaginaryStieltjesTailIBPBound`.** Given:

* the improper IBP package `I`;
* the bound function `B` for `|S|` on `[T, тИЮ)`;
* a closed-form envelope `Jbound` for the derivative-side integral;
* and the margin hypothesis `|k_z(T)|┬╖B(T) + Jbound тЙд modelMargin`
  (already certified by the ┬з13/┬зCLXXXIII slab bundle in the form
  `closedFormSErrorBoundCD C D y T тЙд -(model z).im`),

construct the ┬з13 `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
field is the headline inequality. -/
noncomputable def ImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : ImproperKernelStieltjesIBP)
    (B : тДЭ тЖТ тДЭ)
    (hS_bound : тИА u : тДЭ, I.T тЙд u тЖТ |I.S u| тЙд B u)
    (Jbound : тДЭ)
    (modelMargin : тДЭ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound тЙд modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

end Phase1IBP

-- =====================================================================
-- ┬зCXCI. Smooth finite-window kernel IBP (Phase 1.3 grind, smooth side)
-- =====================================================================
-- The first concrete piece of the IBP chain. For a closed window
-- `[T, X]` with `0 < T тЙд X`, the integration-by-parts identity
--   `тИл_T^X k_z(u)┬╖╧Б(u) du
--      = k_z(X)┬╖S(X) тИТ k_z(T)┬╖S(T) тИТ тИл_T^X S(u)┬╖k_z'(u) du`
-- where `S(u) := тИл_T^u ╧Б(v) dv = smoothCountingPrimitive T u`.
-- This is the *smooth* half of `FiniteKernelStieltjesIBP`; the discrete
-- Abel summation against the zero Diracs is ┬зCXCII (next).
-- Built on Mathlib's:
--   тАв `intervalIntegral.integral_hasDerivAt_right` (FTC, upper endpoint)
--   тАв `intervalIntegral.integral_mul_deriv_eq_deriv_mul` (IBP)
--   тАв `Real.continuousAt_log` (continuity of `log` away from 0).

namespace Phase1IBP

open MeasureTheory Filter Topology

/-- **Smooth counting primitive** for the zero-counting density:
  `S(X) = тИл_T^X ╧Б(u) du`. -/
noncomputable def smoothCountingPrimitive (T X : тДЭ) : тДЭ :=
  тИл u in T..X, zeroDensityRho u

/-- тнР **PROVED тАФ `S(T) = 0`**. Trivial via `integral_same`. -/
lemma smoothCountingPrimitive_self (T : тДЭ) :
    smoothCountingPrimitive T T = 0 := by
  unfold smoothCountingPrimitive
  exact intervalIntegral.integral_same

/-- тнР **PROVED тАФ `zeroDensityRho` is continuous at any `X > 0`.**
`╧Б(u) = (1/(2╧А))┬╖log(u/(2╧А))`; `log` is continuous away from `0`. -/
lemma zeroDensityRho_continuousAt {X : тДЭ} (hX : 0 < X) :
    ContinuousAt zeroDensityRho X := by
  unfold zeroDensityRho
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h_div_pos : 0 < X / (2 * Real.pi) := div_pos hX h2pi_pos
  have h_div_ne : X / (2 * Real.pi) тЙа 0 := ne_of_gt h_div_pos
  have h_inner : ContinuousAt (fun u : тДЭ => u / (2 * Real.pi)) X :=
    (continuous_id.div_const _).continuousAt
  -- Use `ContinuousAt.log` which composes cleanly (avoids the
  -- `HDiv.hDiv` unification trap that bites `Real.continuousAt_log.comp`).
  have h_log : ContinuousAt (fun u : тДЭ => Real.log (u / (2 * Real.pi))) X :=
    h_inner.log h_div_ne
  exact continuousAt_const.mul h_log

/-- тнР **PROVED тАФ `zeroDensityRho` is continuous on `Set.Ioi 0`.** -/
lemma zeroDensityRho_continuousOn_Ioi :
    ContinuousOn zeroDensityRho (Set.Ioi 0) :=
  fun _ hu => (zeroDensityRho_continuousAt hu).continuousWithinAt

/-- тнР **PROVED тАФ `zeroDensityRho` is `IntervalIntegrable` on `[T, X]`
when `0 < T тЙд X`.** Continuity on the compact `[T, X] тКВ (0, тИЮ)` gives
integrability. -/
lemma zeroDensityRho_intervalIntegrable
    {T X : тДЭ} (hT : 0 < T) (hTX : T тЙд X) :
    IntervalIntegrable zeroDensityRho MeasureTheory.volume T X := by
  refine ContinuousOn.intervalIntegrable_of_Icc hTX ?_
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  exact (zeroDensityRho_continuousAt hu_pos).continuousWithinAt

/-- тнР **PROVED тАФ FTC: `smoothCountingPrimitive T` is differentiable on
`(0, тИЮ)` and its derivative is `zeroDensityRho`.** -/
lemma smoothCountingPrimitive_hasDerivAt
    {T X : тДЭ} (hT : 0 < T) (hTX : T тЙд X) :
    HasDerivAt (fun u : тДЭ => smoothCountingPrimitive T u)
      (zeroDensityRho X) X := by
  have hX : 0 < X := lt_of_lt_of_le hT hTX
  have hX_cont : ContinuousAt zeroDensityRho X := zeroDensityRho_continuousAt hX
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  -- StronglyMeasurableAtFilter via a continuity neighborhood: on `Ioi 0`,
  -- `╧Б` is continuous, hence AE-strongly-measurable.
  have h_Ioi_mem : Set.Ioi (0 : тДЭ) тИИ ЁЭУЭ X := Ioi_mem_nhds hX
  have h_smaf : StronglyMeasurableAtFilter zeroDensityRho (ЁЭУЭ X) MeasureTheory.volume :=
    тЯиSet.Ioi 0, h_Ioi_mem,
     zeroDensityRho_continuousOn_Ioi.aestronglyMeasurable measurableSet_IoiтЯй
  exact intervalIntegral.integral_hasDerivAt_right h_int h_smaf hX_cont

/-- тнР **PROVED тАФ `pairedCauchyImKernel x y` is differentiable at every `u`
for `y > 0`, with `HasDerivAt`-form derivative `pairedCauchyImKernelDeriv`.**
Lifts the `deriv` form (CXLV `deriv_pairedCauchyImKernel`) to the
`HasDerivAt` form by composing `DifferentiableAt` combinators and
substituting the proven derivative value. -/
lemma pairedCauchyImKernel_hasDerivAt
    {y : тДЭ} (hy : 0 < y) (x u : тДЭ) :
    HasDerivAt (fun v : тДЭ => pairedCauchyImKernel x y v)
      (pairedCauchyImKernelDeriv x y u) u := by
  have hd1_pos : (0 : тДЭ) < (x - u)^2 + y^2 := by positivity
  have hd2_pos : (0 : тДЭ) < (x + u)^2 + y^2 := by positivity
  have h_diff : DifferentiableAt тДЭ (fun v : тДЭ => pairedCauchyImKernel x y v) u := by
    unfold pairedCauchyImKernel
    have h1 : DifferentiableAt тДЭ (fun v : тДЭ => (x - v)^2 + y^2) u :=
      (((differentiableAt_const x).sub differentiableAt_id).pow 2).add_const _
    have h2 : DifferentiableAt тДЭ (fun v : тДЭ => (x + v)^2 + y^2) u :=
      (((differentiableAt_const x).add differentiableAt_id).pow 2).add_const _
    have hi1 : DifferentiableAt тДЭ (fun v : тДЭ => 1 / ((x - v)^2 + y^2)) u :=
      (differentiableAt_const _).div h1 (ne_of_gt hd1_pos)
    have hi2 : DifferentiableAt тДЭ (fun v : тДЭ => 1 / ((x + v)^2 + y^2)) u :=
      (differentiableAt_const _).div h2 (ne_of_gt hd2_pos)
    exact (differentiableAt_const (-y)).mul (hi1.add hi2)
  have h_value : deriv (fun v : тДЭ => pairedCauchyImKernel x y v) u
                  = pairedCauchyImKernelDeriv x y u :=
    deriv_pairedCauchyImKernel x y u hy
  rw [тЖР h_value]
  exact h_diff.hasDerivAt

/-- тнР **PROVED тАФ `pairedCauchyImKernelDeriv x y` is continuous on `тДЭ`
for `y > 0`.** Used to discharge the integrability hypothesis of IBP. -/
lemma pairedCauchyImKernelDeriv_continuous
    {y : тДЭ} (hy : 0 < y) (x : тДЭ) :
    Continuous (fun u : тДЭ => pairedCauchyImKernelDeriv x y u) := by
  unfold pairedCauchyImKernelDeriv
  have h_plus_sq : Continuous (fun u : тДЭ => ((x + u)^2 + y^2)^2) := by
    have h : Continuous (fun u : тДЭ => (x + u)^2 + y^2) :=
      ((continuous_const.add continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have h_minus_sq : Continuous (fun u : тДЭ => ((x - u)^2 + y^2)^2) := by
    have h : Continuous (fun u : тДЭ => (x - u)^2 + y^2) :=
      ((continuous_const.sub continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have hne_plus : тИА u : тДЭ, ((x + u)^2 + y^2)^2 тЙа 0 := fun u => by
    have : 0 < ((x + u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have hne_minus : тИА u : тДЭ, ((x - u)^2 + y^2)^2 тЙа 0 := fun u => by
    have : 0 < ((x - u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have h_div_plus : Continuous (fun u : тДЭ => (x + u) / ((x + u)^2 + y^2)^2) :=
    (continuous_const.add continuous_id).div h_plus_sq hne_plus
  have h_div_minus : Continuous (fun u : тДЭ => (x - u) / ((x - u)^2 + y^2)^2) :=
    (continuous_const.sub continuous_id).div h_minus_sq hne_minus
  exact continuous_const.mul (h_div_plus.sub h_div_minus)

/-- тнР **PROVED тАФ `pairedCauchyImKernelDeriv` is `IntervalIntegrable`** on
any window. Direct from continuity. -/
lemma pairedCauchyImKernelDeriv_intervalIntegrable
    {y : тДЭ} (hy : 0 < y) (x T X : тДЭ) :
    IntervalIntegrable (fun u : тДЭ => pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
  (pairedCauchyImKernelDeriv_continuous hy x).intervalIntegrable T X

/-- ЁЯМЯ **PROVED тАФ SMOOTH FINITE-WINDOW IBP IDENTITY** for the imaginary
paired-Cauchy kernel against the zero-counting density:

  `тИл_T^X k_z(u)┬╖╧Б(u) du
     = k_z(X)┬╖S(X) тИТ k_z(T)┬╖S(T) тИТ тИл_T^X S(u)┬╖k_z'(u) du`

where `S(u) := smoothCountingPrimitive T u`. The smooth half of the
finite Stieltjes IBP тАФ combined with the discrete Abel summation
(next), this yields the first concrete inhabitant of
`FiniteKernelStieltjesIBP`. -/
theorem smooth_zeroDensity_kernel_ibp
    {y : тДЭ} (hy : 0 < y) (x T X : тДЭ)
    (hT : 0 < T) (hTX : T тЙд X) :
    (тИл u in T..X, pairedCauchyImKernel x y u * zeroDensityRho u) =
      pairedCauchyImKernel x y X * smoothCountingPrimitive T X
        - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
        - тИл u in T..X,
            smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
  have hu_deriv :
      тИА u тИИ Set.uIcc T X,
        HasDerivAt (fun v : тДЭ => pairedCauchyImKernel x y v)
          (pairedCauchyImKernelDeriv x y u) u :=
    fun u _ => pairedCauchyImKernel_hasDerivAt hy x u
  have hv_deriv :
      тИА u тИИ Set.uIcc T X,
        HasDerivAt (fun v : тДЭ => smoothCountingPrimitive T v)
          (zeroDensityRho u) u := by
    intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    exact smoothCountingPrimitive_hasDerivAt hT hu.1
  have hu'_int :
      IntervalIntegrable (fun u : тДЭ => pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    pairedCauchyImKernelDeriv_intervalIntegrable hy x T X
  have hv'_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  have h_ibp :=
    intervalIntegral.integral_mul_deriv_eq_deriv_mul
      hu_deriv hv_deriv hu'_int hv'_int
  -- h_ibp :  тИл k * ╧Б = k(X)┬╖S(X) тИТ k(T)┬╖S(T) тИТ тИл k' * S
  -- target:  тИл k * ╧Б = k(X)┬╖S(X) тИТ k(T)┬╖S(T) тИТ тИл S * k'
  have h_swap :
      (тИл u in T..X,
         pairedCauchyImKernelDeriv x y u * smoothCountingPrimitive T u) =
      (тИл u in T..X,
         smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u) := by
    refine intervalIntegral.integral_congr ?_
    intro u _; exact mul_comm _ _
  linarith [h_ibp, h_swap]

end Phase1IBP

-- =====================================================================
-- ┬зCXCII-A. Ordered discrete Abel summation (Phase 1.3 grind, discrete side)
-- =====================================================================
-- The discrete half of `FiniteKernelStieltjesIBP`. The safe path:
-- prove the pure algebraic summation-by-parts identity over
-- `Finset.range (n + 1)` first, then instantiate with clipped zero
-- weights against the imaginary kernel.
--
-- Pure algebra:
--   `тИС_{j тЙд n} a_j ┬╖ b_j
--      = (тИС_{j тЙд n} a_j) ┬╖ b_n
--        тИТ тИС_{j < n} (тИС_{i тЙд j} a_i) ┬╖ (b_{j+1} тИТ b_j)`
--
-- Clipped instantiation:
--   `a_j := if T тЙд Z_j тЙд X then mult_j else 0`
--   `b_j := f (Z_j)`.

namespace Phase1IBP

open BigOperators

/-- тнР **PROVED тАФ pure algebraic Abel/summation-by-parts identity over
`Finset.range (n + 1)`.** -/
lemma fin_sum_mul_eq_boundary_sub_sum_succ
    (n : тДХ) (a b : тДХ тЖТ тДЭ) :
    (тИС j тИИ Finset.range (n + 1), a j * b j)
      =
    (тИС j тИИ Finset.range (n + 1), a j) * b n
      -
    тИС j тИИ Finset.range n,
      (тИС i тИИ Finset.range (j + 1), a i) * (b (j + 1) - b j) := by
  induction n with
  | zero => simp
  | succ n ih =>
    rw [Finset.sum_range_succ (fun j => a j * b j) (n + 1), ih,
        Finset.sum_range_succ (fun j => a j) (n + 1),
        Finset.sum_range_succ
          (fun j => (тИС i тИИ Finset.range (j + 1), a i) * (b (j + 1) - b j)) n]
    ring

/-- **Discrete counting primitive** for the zero list, clipped to `[T, X]`:
  `N_{T,X}(D) = ╬г_{j < n : T тЙд Z_j тЙд X} mult_j`. -/
noncomputable def discreteCountingPrimitive
    (D : FluctuationMeasureData) (T X : тДЭ) : тДЭ :=
  тИС j тИИ Finset.range D.n,
    if T тЙд D.Z j тИз D.Z j тЙд X then (D.mult j : тДЭ) else 0

/-- **Discrete kernel partial** for an arbitrary integrand `f`:
  `╬г_{j < n : T тЙд Z_j тЙд X} mult_j ┬╖ f(Z_j)`. -/
noncomputable def discreteKernelPartial
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДЭ :=
  тИС j тИИ Finset.range D.n,
    if T тЙд D.Z j тИз D.Z j тЙд X then (D.mult j : тДЭ) * f (D.Z j) else 0

/-- тнР **PROVED тАФ counting primitive at `X = T`.** Only ordinates
exactly at `T` contribute. -/
lemma discreteCountingPrimitive_left
    (D : FluctuationMeasureData) (T : тДЭ) :
    discreteCountingPrimitive D T T
      =
    тИС j тИИ Finset.range D.n,
      if D.Z j = T then (D.mult j : тДЭ) else 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : D.Z j = T
  ┬╖ have hpair : T тЙд D.Z j тИз D.Z j тЙд T := тЯиh.ge, h.leтЯй
    simp [h, hpair]
  ┬╖ have hnot : ┬м (T тЙд D.Z j тИз D.Z j тЙд T) := by
      intro hpair
      exact h (le_antisymm hpair.2 hpair.1)
    simp [h, hnot]

/-- тнР **PROVED тАФ counting primitive is monotone in the upper cutoff.** -/
lemma discreteCountingPrimitive_mono
    (D : FluctuationMeasureData) (T : тДЭ) :
    Monotone (fun X => discreteCountingPrimitive D T X) := by
  classical
  intro X Y hXY
  unfold discreteCountingPrimitive
  apply Finset.sum_le_sum
  intro j _
  have hmult_nn : (0 : тДЭ) тЙд (D.mult j : тДЭ) := Nat.cast_nonneg _
  by_cases hTX : T тЙд D.Z j
  ┬╖ by_cases hZX : D.Z j тЙд X
    ┬╖ have hZY : D.Z j тЙд Y := le_trans hZX hXY
      have hX_pair : T тЙд D.Z j тИз D.Z j тЙд X := тЯиhTX, hZXтЯй
      have hY_pair : T тЙд D.Z j тИз D.Z j тЙд Y := тЯиhTX, hZYтЯй
      rw [if_pos hX_pair, if_pos hY_pair]
    ┬╖ by_cases hZY : D.Z j тЙд Y
      ┬╖ have hY_pair : T тЙд D.Z j тИз D.Z j тЙд Y := тЯиhTX, hZYтЯй
        have hX_nopair : ┬м (T тЙд D.Z j тИз D.Z j тЙд X) := fun тЯи_, hтЯй => hZX h
        rw [if_neg hX_nopair, if_pos hY_pair]
        exact hmult_nn
      ┬╖ have hX_nopair : ┬м (T тЙд D.Z j тИз D.Z j тЙд X) := fun тЯи_, hтЯй => hZX h
        have hY_nopair : ┬м (T тЙд D.Z j тИз D.Z j тЙд Y) := fun тЯи_, hтЯй => hZY h
        rw [if_neg hX_nopair, if_neg hY_nopair]
  ┬╖ have hX_nopair : ┬м (T тЙд D.Z j тИз D.Z j тЙд X) := fun тЯиh, _тЯй => hTX h
    have hY_nopair : ┬м (T тЙд D.Z j тИз D.Z j тЙд Y) := fun тЯиh, _тЯй => hTX h
    rw [if_neg hX_nopair, if_neg hY_nopair]

/-- **Ordered-zero-list fluctuation data.** Extends `FluctuationMeasureData`
with monotonicity of the ordinate sequence тАФ the discrete Abel summation
needs the ordinates in order. -/
structure OrderedFluctuationMeasureData extends FluctuationMeasureData where
  mono_Z : Monotone Z

/-- **Clipped weight**: `a_j = mult_j` if `T тЙд Z_j тЙд X`, else `0`. -/
noncomputable def clippedWeight
    (D : FluctuationMeasureData) (T X : тДЭ) : тДХ тЖТ тДЭ :=
  fun j => if T тЙд D.Z j тИз D.Z j тЙд X then (D.mult j : тДЭ) else 0

/-- тнР **PROVED тАФ `discreteKernelPartial` rewritten as a clipped pure sum.**
The clipped weight absorbs the indicator so the partial collapses to
`тИС a_j ┬╖ b_j` for `a_j = clippedWeight`, `b_j = f (Z_j)`. -/
lemma discreteKernelPartial_eq_clippedSum
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) :
    discreteKernelPartial D f T X
      =
    тИС j тИИ Finset.range D.n,
      clippedWeight D T X j * f (D.Z j) := by
  unfold discreteKernelPartial clippedWeight
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : T тЙд D.Z j тИз D.Z j тЙд X
  ┬╖ rw [if_pos h, if_pos h]
  ┬╖ rw [if_neg h, if_neg h, zero_mul]

/-- тнР **PROVED тАФ `discreteCountingPrimitive` is the sum of `clippedWeight`.** -/
lemma discreteCountingPrimitive_eq_clippedSum
    (D : FluctuationMeasureData) (T X : тДЭ) :
    discreteCountingPrimitive D T X
      = тИС j тИИ Finset.range D.n, clippedWeight D T X j := rfl

/-- ЁЯМЯ **PROVED тАФ RAW ABEL IDENTITY** for the ordered discrete kernel
partial over `Finset.range (m + 1)`, with `D.n = m + 1`.

  `discreteKernelPartial D f T X
     = (тИС clippedWeight) ┬╖ f (Z m)
       тИТ тИС_{j < m} (cumulative clippedWeight up to j) ┬╖ (f (Z_{j+1}) тИТ f (Z_j))`

The discrete-side analogue of `smooth_zeroDensity_kernel_ibp` (┬зCXCI),
generic in the integrand. -/
theorem ordered_discrete_kernel_abel_clipped
    (D : OrderedFluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) {m : тДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (тИС j тИИ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) * f (D.Z m)
      -
    тИС j тИИ Finset.range m,
      (тИС i тИИ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (f (D.Z (j + 1)) - f (D.Z j)) := by
  rw [discreteKernelPartial_eq_clippedSum, hn]
  exact fin_sum_mul_eq_boundary_sub_sum_succ m
    (fun j => clippedWeight D.toFluctuationMeasureData T X j)
    (fun j => f (D.Z j))

/-- ЁЯМЯ **PROVED тАФ paired-Cauchy-imaginary kernel Abel identity.**
Specializes `ordered_discrete_kernel_abel_clipped` to
`f := pairedCauchyImKernel x y`. This is the discrete-side companion
to `smooth_zeroDensity_kernel_ibp` (┬зCXCI). -/
theorem ordered_discrete_pairedCauchyIm_abel_clipped
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    (тИС j тИИ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) *
          pairedCauchyImKernel x y (D.Z m)
      -
    тИС j тИИ Finset.range m,
      (тИС i тИИ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (pairedCauchyImKernel x y (D.Z (j + 1))
          - pairedCauchyImKernel x y (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- ┬зCXCII-B. Named primitives, Abel remainder, finite fluctuation
-- =====================================================================
-- Wraps the Abel identity in readable named forms:
--   тАв `clippedCumulativeWeight`: the prefix-sum primitive appearing on
--     the Abel RHS (this is `discreteCountingPrimitive` restricted to
--     `Finset.range (j + 1)`);
--   тАв `discreteAbelRemainder f`: the sum of cumulative ├Ч kernel-difference
--     terms (the discrete analogue of `тИл S┬╖k'`);
--   тАв `discreteKernelAbelRemainder`: paired-Cauchy specialization;
--   тАв `ordered_discrete_kernel_ibp_raw`: the compact discrete IBP.

/-- **Cumulative clipped weight** through index `j`:
  `╬г_{i тЙд j} clippedWeight i = ╬г_{i тЙд j, T тЙд Z i тЙд X} mult i`. -/
noncomputable def clippedCumulativeWeight
    (D : OrderedFluctuationMeasureData) (T X : тДЭ) (j : тДХ) : тДЭ :=
  тИС i тИИ Finset.range (j + 1), clippedWeight D.toFluctuationMeasureData T X i

/-- тнР **PROVED тАФ `clippedCumulativeWeight` unfolds to the discrete
counting prefix sum (rfl).** -/
lemma clippedCumulativeWeight_eq_discreteCountingPrefix
    (D : OrderedFluctuationMeasureData) (T X : тДЭ) (j : тДХ) :
    clippedCumulativeWeight D T X j
      =
    тИС i тИИ Finset.range (j + 1),
      if T тЙд D.Z i тИз D.Z i тЙд X then (D.mult i : тДЭ) else 0 := rfl

/-- тнР **PROVED тАФ Abel identity with the named primitives.** Rewrites
`ordered_discrete_kernel_abel_clipped` using `discreteCountingPrimitive`
and `clippedCumulativeWeight`. Pure renaming; defeq through both. -/
theorem ordered_discrete_kernel_abel_clipped_named
    (D : OrderedFluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) {m : тДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (discreteCountingPrimitive D.toFluctuationMeasureData T X) * f (D.Z m)
      -
    тИС j тИИ Finset.range m,
      clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D f T X hn

/-- **Discrete Abel remainder** for an arbitrary integrand `f`:
the sum of cumulative weights ├Ч kernel differences. Discrete analogue
of `тИл_T^X S(u)┬╖f'(u) du`. -/
noncomputable def discreteAbelRemainder
    (D : OrderedFluctuationMeasureData) (f : тДЭ тЖТ тДЭ)
    (T X : тДЭ) (m : тДХ) : тДЭ :=
  тИС j тИИ Finset.range m,
    clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j))

/-- **Discrete Abel remainder** specialized to the imaginary
paired-Cauchy kernel. -/
noncomputable def discreteKernelAbelRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) (m : тДХ) : тДЭ :=
  discreteAbelRemainder D (fun u => pairedCauchyImKernel x y u) T X m

/-- ЁЯМЯ **PROVED тАФ RAW DISCRETE IBP** for the imaginary paired-Cauchy
kernel against the clipped zero counts, in named-primitive form:

  `discreteKernelPartial D k T X
     = discreteCountingPrimitive D T X ┬╖ k(Z_m)
       тИТ discreteKernelAbelRemainder D x y T X m`.

The compact discrete-side companion to `smooth_zeroDensity_kernel_ibp`. -/
theorem ordered_discrete_kernel_ibp_raw
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m := by
  unfold discreteKernelAbelRemainder discreteAbelRemainder
  exact ordered_discrete_kernel_abel_clipped_named D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- ┬зCXCIII. Finite fluctuation primitive + raw combined IBP
-- =====================================================================
-- Now combine the smooth (┬зCXCI) and discrete (┬зCXCII) halves into the
-- finite-window fluctuation IBP identity.
--
--   `S_total(u) := S_discrete(u) тИТ S_smooth(u)`
--   `F(T, X)   := тИл_T^X k dS_total = discreteKernelPartial тИТ тИл k┬╖╧Б`
--
-- The raw identity reads
--
--   `F(T, X) = N(X)┬╖k(Z_m) тИТ R_discrete
--             тИТ (k(X)┬╖S_smooth(X) тИТ k(T)┬╖S_smooth(T) тИТ тИл S_smooth ┬╖ k')`
--
-- Note: the boundary on the discrete side is at `k(Z_m)`, not yet at
-- `k(X)`. The endpoint correction is ┬зCXCIV (next patch).

/-- **Finite fluctuation primitive**:
  `S(T, X) := N(X) тИТ S_smooth(X)` (discrete count minus smooth integral). -/
noncomputable def finiteFluctuationPrimitive
    (D : OrderedFluctuationMeasureData) (T X : тДЭ) : тДЭ :=
  discreteCountingPrimitive D.toFluctuationMeasureData T X
    - smoothCountingPrimitive T X

/-- тнР **PROVED тАФ finite fluctuation primitive at the left endpoint.**
`S_smooth(T) = 0`, so `S(T, T) = N(T, T)`. -/
lemma finiteFluctuationPrimitive_left
    (D : OrderedFluctuationMeasureData) (T : тДЭ) :
    finiteFluctuationPrimitive D T T
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T T := by
  simp [finiteFluctuationPrimitive, smoothCountingPrimitive_self]

/-- тнР **PROVED тАФ when there is no zero atom at `T`, the discrete count
at `X = T` vanishes.** Optional convention; keeps boundary atoms
visible by being separately stated rather than baked into the
primitive. -/
lemma discreteCountingPrimitive_left_zero_of_no_atom
    (D : FluctuationMeasureData) (T : тДЭ)
    (hno : тИА j тИИ Finset.range D.n, D.Z j тЙа T) :
    discreteCountingPrimitive D T T = 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j hj
  have hnot : ┬м (T тЙд D.Z j тИз D.Z j тЙд T) := by
    intro h
    exact hno j hj (le_antisymm h.2 h.1)
  simp [hnot]

/-- **Finite fluctuation kernel partial** for the imaginary paired-Cauchy
kernel:
  `F(T, X) := ╬г_clipped mult┬╖k(Z) тИТ тИл_T^X k┬╖╧Б`. -/
noncomputable def finiteFluctuationKernelPartial
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) : тДЭ :=
  discreteKernelPartial D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X
    -
  тИл u in T..X,
      pairedCauchyImKernel x y u * zeroDensityRho u

/-- **Raw mixed remainder** combining the discrete Abel remainder and
the smooth integral `тИл S_smooth ┬╖ k'`. The first ingredient of the
finite fluctuation IBP body. -/
noncomputable def finiteFluctuationRawRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) (m : тДХ) : тДЭ :=
  discreteKernelAbelRemainder D x y T X m
    -
  тИл u in T..X,
      smoothCountingPrimitive T u *
        pairedCauchyImKernelDeriv x y u

/-- ЁЯМЯЁЯМЯ **PROVED тАФ RAW FINITE FLUCTUATION IBP IDENTITY.**

Combines `ordered_discrete_kernel_ibp_raw` (┬зCXCII) and
`smooth_zeroDensity_kernel_ibp` (┬зCXCI) into

  `finiteFluctuationKernelPartial D x y T X
     = N(X)┬╖k(Z_m) тИТ R_discrete
       тИТ (k(X)┬╖S_smooth(X) тИТ k(T)┬╖S_smooth(T) тИТ тИл S_smooth┬╖k')`.

The boundary on the discrete side is at `k(Z_m)` (the last ordinate of
the indexed finite list), NOT yet at `k(X)`. Bringing the boundary to
`k(X)` requires the endpoint correction `k(X) тИТ k(Z_m)`, which is
┬зCXCIV. This raw form is the honest output of summation-by-parts plus
FTC IBP. -/
theorem finiteFluctuationKernelPartial_raw_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T тЙд X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m
      -
    (pairedCauchyImKernel x y X * smoothCountingPrimitive T X
      - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
      - тИл u in T..X,
          smoothCountingPrimitive T u *
            pairedCauchyImKernelDeriv x y u) := by
  unfold finiteFluctuationKernelPartial
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn,
      smooth_zeroDensity_kernel_ibp hy x T X hT hTX]

-- =====================================================================
-- ┬зCXCIV. Endpoint correction тАФ shift boundary from k(Z_m) to k(X)
-- =====================================================================
-- The raw discrete IBP boundary is `N ┬╖ k(Z_m)`. Analytic estimates want
-- the boundary at the cutoff `k(X)`. The difference is the endpoint
-- correction `N ┬╖ (k(X) - k(Z_m))`. Subtracting it gives the
-- analytically clean IBP identity.

/-- **Generic discrete Abel endpoint correction**: the boundary delta
between `f(X)` and `f(D.Z m)` scaled by the discrete count primitive. -/
noncomputable def discreteAbelEndpointCorrection
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) (m : тДХ) : тДЭ :=
  discreteCountingPrimitive D T X * (f X - f (D.Z m))

/-- тнР **PROVED тАФ Endpoint-corrected discrete IBP (paired Cauchy
kernel).** Rearranges `ordered_discrete_kernel_ibp_raw` so the boundary
uses `pairedCauchyImKernel x y X` instead of `pairedCauchyImKernel x y (D.Z m)`,
introducing the endpoint correction term explicitly. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteAbelEndpointCorrection D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X m := by
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn]
  unfold discreteAbelEndpointCorrection
  ring

/-- **Paired-Cauchy specialization** of the discrete Abel endpoint
correction. -/
noncomputable def discreteKernelEndpointCorrection
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ) : тДЭ :=
  discreteAbelEndpointCorrection D.toFluctuationMeasureData
    (fun u => pairedCauchyImKernel x y u) T X m

/-- тнР **PROVED тАФ Endpoint-corrected discrete IBP**, paired-kernel form
using the specialized `discreteKernelEndpointCorrection`. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected_paired
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteKernelEndpointCorrection D x y T X m := by
  unfold discreteKernelEndpointCorrection
  exact ordered_discrete_kernel_ibp_endpoint_corrected D x y T X hn

/-- **Combined endpoint correction** for the finite fluctuation IBP.
Same data as the discrete endpoint correction (the smooth side has its
boundary at `k(X) ┬╖ S_smooth(X)` already, so no smooth correction). -/
noncomputable def finiteFluctuationEndpointCorrection
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) (m : тДХ) : тДЭ :=
  discreteKernelEndpointCorrection D x y T X m

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ Endpoint-corrected finite fluctuation IBP.**
The analytically clean shape:

  `finiteFluctuationKernelPartial D x y T X
     = finiteFluctuationPrimitive D T X ┬╖ k(X)
       тИТ finiteFluctuationRawRemainder D x y T X m
       тИТ finiteFluctuationEndpointCorrection D x y T X m`.

Both boundaries now align at `k(X)`. Uses `smoothCountingPrimitive_self`
to discharge `S_smooth(T) = 0` (so the `k(T) ┬╖ S_smooth(T)` term in the
raw IBP vanishes). -/
theorem finiteFluctuationKernelPartial_endpoint_corrected_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T тЙд X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    finiteFluctuationPrimitive D T X
      * pairedCauchyImKernel x y X
      -
    finiteFluctuationRawRemainder D x y T X m
      -
    finiteFluctuationEndpointCorrection D x y T X m := by
  rw [finiteFluctuationKernelPartial_raw_ibp D x y T X hn hT hTX hy]
  unfold finiteFluctuationPrimitive finiteFluctuationRawRemainder
        finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection
        discreteAbelEndpointCorrection
  rw [smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- ┬зCXCIV-bounds: Endpoint correction zero case + absolute bounds
-- =====================================================================
-- Makes the endpoint correction harmless: it vanishes when X is chosen
-- AT an atom (X = D.Z m), and is bounded by `count ┬╖ |k(X)-k(D.Z m)|`
-- otherwise. Then a Lipschitz-style wrapper lets future kernel-derivative
-- bounds slot in. Finally `..._abs_le_of_parts` combines raw remainder +
-- endpoint correction bounds via the triangle inequality.

/-- тнР **PROVED тАФ Generic endpoint correction vanishes** when `X = D.Z m`. -/
theorem discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) (m : тДХ)
    (hX : X = D.Z m) :
    discreteAbelEndpointCorrection D f T X m = 0 := by
  unfold discreteAbelEndpointCorrection
  rw [hX]
  ring

/-- тнР **PROVED тАФ Paired-Cauchy endpoint correction vanishes** at `X = D.Z m`. -/
theorem discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ)
    (hX : X = D.Z m) :
    discreteKernelEndpointCorrection D x y T X m = 0 := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m hX

/-- тнР **PROVED тАФ Combined endpoint correction vanishes** at `X = D.Z m`. -/
theorem finiteFluctuationEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ)
    (hX : X = D.Z m) :
    finiteFluctuationEndpointCorrection D x y T X m = 0 := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z D x y T X m hX

/-- тнР **PROVED тАФ Generic endpoint correction absolute bound.** -/
theorem discreteAbelEndpointCorrection_abs_le
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) (m : тДХ) :
    |discreteAbelEndpointCorrection D f T X m|
      тЙд |discreteCountingPrimitive D T X|
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul]

/-- тнР **PROVED тАФ Cleaner bound** when the count primitive is nonneg. -/
theorem discreteAbelEndpointCorrection_abs_le_count
    (D : FluctuationMeasureData) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) (m : тДХ)
    (hN : 0 тЙд discreteCountingPrimitive D T X) :
    |discreteAbelEndpointCorrection D f T X m|
      тЙд discreteCountingPrimitive D T X
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul, abs_of_nonneg hN]

/-- тнР **PROVED тАФ Paired-Cauchy endpoint absolute bound.** -/
theorem discreteKernelEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ) :
    |discreteKernelEndpointCorrection D x y T X m|
      тЙд |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_abs_le
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m

/-- тнР **PROVED тАФ Combined finite-fluctuation endpoint absolute bound.** -/
theorem finiteFluctuationEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ) :
    |finiteFluctuationEndpointCorrection D x y T X m|
      тЙд |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_abs_le D x y T X m

/-- тнР **PROVED тАФ Lipschitz-hypothesis wrapper.**
Given an externally-supplied kernel-difference bound `K ┬╖ |X тИТ D.Z m|`,
yields `count ┬╖ K ┬╖ |X тИТ D.Z m|`. Future kernel-derivative work can plug
the Lipschitz `K` here without re-proving the structural bound. -/
theorem discreteKernelEndpointCorrection_abs_le_deriv_bound
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ) (K : тДЭ)
    (hN : 0 тЙд discreteCountingPrimitive D.toFluctuationMeasureData T X)
    (hLip :
      |pairedCauchyImKernel x y X
        - pairedCauchyImKernel x y (D.Z m)|
        тЙд K * |X - D.Z m|) :
    |discreteKernelEndpointCorrection D x y T X m|
      тЙд discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by
  have h0 :
      |discreteKernelEndpointCorrection D x y T X m|
        тЙд |discreteCountingPrimitive D.toFluctuationMeasureData T X|
            * |pairedCauchyImKernel x y X
                - pairedCauchyImKernel x y (D.Z m)| :=
    discreteKernelEndpointCorrection_abs_le D x y T X m
  rw [abs_of_nonneg hN] at h0
  have h_step :
      discreteCountingPrimitive D.toFluctuationMeasureData T X
        * |pairedCauchyImKernel x y X
            - pairedCauchyImKernel x y (D.Z m)|
        тЙд discreteCountingPrimitive D.toFluctuationMeasureData T X
            * (K * |X - D.Z m|) :=
    mul_le_mul_of_nonneg_left hLip hN
  calc |discreteKernelEndpointCorrection D x y T X m|
      тЙд discreteCountingPrimitive D.toFluctuationMeasureData T X
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := h0
    _ тЙд discreteCountingPrimitive D.toFluctuationMeasureData T X
          * (K * |X - D.Z m|) := h_step
    _ = discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by ring

/-- **Per-piece IBP-correction bound predicate.**
The IBP body has two analytic terms to bound: the raw remainder and the
endpoint correction. This predicate names both budgets simultaneously. -/
def finiteFluctuationRemainderControlled
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ)
    (Braw Bend : тДЭ) : Prop :=
  |finiteFluctuationRawRemainder D x y T X m| тЙд Braw тИз
  |finiteFluctuationEndpointCorrection D x y T X m| тЙд Bend

/-- тнР **PROVED тАФ Triangle inequality combines raw + endpoint bounds.**
The full IBP correction (raw remainder + endpoint correction) is bounded
by the sum of the individual bounds. The abstract building block that
turns piece-wise IBP estimates into a single error budget. -/
theorem finiteFluctuationCorrection_abs_le_of_parts
    {D : OrderedFluctuationMeasureData} {x y T X : тДЭ} {m : тДХ}
    {Braw Bend : тДЭ}
    (hraw : |finiteFluctuationRawRemainder D x y T X m| тЙд Braw)
    (hend : |finiteFluctuationEndpointCorrection D x y T X m| тЙд Bend) :
    |finiteFluctuationRawRemainder D x y T X m
      + finiteFluctuationEndpointCorrection D x y T X m|
      тЙд Braw + Bend := by
  calc |finiteFluctuationRawRemainder D x y T X m
        + finiteFluctuationEndpointCorrection D x y T X m|
      тЙд |finiteFluctuationRawRemainder D x y T X m|
        + |finiteFluctuationEndpointCorrection D x y T X m| := abs_add _ _
    _ тЙд Braw + Bend := add_le_add hraw hend

-- =====================================================================
-- ┬зCXCV. FTC bridge тАФ Abel sums тЖТ interval integrals of N ┬╖ k'
-- =====================================================================
-- Goal:
--   `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
--      = тИл_T^X N(u) ┬╖ k'(u) du`
-- under clean window assumptions (`OrderedWindow`): all indexed
-- ordinates lie in `[T, X]` and are strictly increasing.
--
-- Strategy (Option A тАФ Window):
--   1. Express the clipped weights as raw `mult` (clipping is trivial
--      since every `Z_j тИИ [T, X]`).
--   2. Rewrite the cumulative weights as the unclipped partial sums.
--   3. Decompose `N(u)` as `тИС_i mult_i ┬╖ [Z_i тЙд u]` on `[T, X]`.
--   4. By linearity + a per-`i` FTC identity
--        `тИл_T^X [Z_i тЙд u] ┬╖ k'(u) du = k(X) тИТ k(Z_i)`
--      the integral equals `тИС_i mult_i ┬╖ (k(X) тИТ k(Z_i))`.
--   5. This matches `R + EC` via the endpoint-corrected discrete IBP.
--
-- Steps 1тАУ3 and 5 are pure algebra and land here. Step 4 тАФ the
-- indicator-against-`k'` FTC integral тАФ is the genuine analytic
-- content; it lives as a Prop hypothesis on the headline theorem,
-- matching the file's "capstone consumes Prop hypotheses" pattern.

/-- **Ordered-window data**: every indexed ordinate lies inside
`[T, X]` and the ordinates are strictly increasing. The clean
hypothesis package that lets the Abel/FTC bridge land without
juggling boundary atoms or duplicate ordinates. -/
structure OrderedWindow
    (D : OrderedFluctuationMeasureData) (T X : тДЭ) (m : тДХ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T тЙд D.Z 0
  hlast_le_X  : D.Z m тЙд X
  hstrict     : тИА j, j < m тЖТ D.Z j < D.Z (j + 1)

/-- тнР **PROVED тАФ under `OrderedWindow`, every indexed ordinate
`Z_j` lies in `[T, X]`.** Monotonicity from `D.mono_Z` together with
`T тЙд Z_0` and `Z_m тЙд X` does the job. -/
lemma OrderedWindow.Z_mem_window
    {D : OrderedFluctuationMeasureData} {T X : тДЭ} {m j : тДХ}
    (W : OrderedWindow D T X m) (hj : j тЙд m) :
    T тЙд D.Z j тИз D.Z j тЙд X := by
  refine тЯи?_, ?_тЯй
  ┬╖ exact le_trans W.hT_le_first (D.mono_Z (Nat.zero_le j))
  ┬╖ exact le_trans (D.mono_Z hj) W.hlast_le_X

/-- тнР **PROVED тАФ under `OrderedWindow`, the clipped weight equals the
raw multiplicity for every `j тЙд m`.** -/
lemma clippedWeight_eq_mult_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : тДЭ} {m j : тДХ}
    (W : OrderedWindow D T X m) (hj : j тЙд m) :
    clippedWeight D.toFluctuationMeasureData T X j = (D.mult j : тДЭ) := by
  unfold clippedWeight
  rw [if_pos (W.Z_mem_window hj)]

/-- тнР **PROVED тАФ under `OrderedWindow`, the clipped cumulative weight
through index `j тЙд m` equals the unclipped partial sum
`тИС_{i тЙд j} mult_i`.** -/
lemma clippedCumulativeWeight_eq_partialSum_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : тДЭ} {m j : тДХ}
    (W : OrderedWindow D T X m) (hj : j тЙд m) :
    clippedCumulativeWeight D T X j
      = тИС i тИИ Finset.range (j + 1), (D.mult i : тДЭ) := by
  unfold clippedCumulativeWeight
  apply Finset.sum_congr rfl
  intro i hi
  have hi_le_m : i тЙд m := by
    have hi_lt : i < j + 1 := Finset.mem_range.mp hi
    omega
  exact clippedWeight_eq_mult_of_orderedWindow W hi_le_m

/-- тнР **PROVED тАФ under `OrderedWindow`, the full clipped sum
(= `discreteCountingPrimitive D T X` = `N(X)`) equals the total
multiplicity.** -/
lemma discreteCountingPrimitive_full_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : тДЭ} {m : тДХ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      = тИС i тИИ Finset.range D.n, (D.mult i : тДЭ) := by
  rw [discreteCountingPrimitive_eq_clippedSum, W.hn]
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < m + 1 := Finset.mem_range.mp hi
  exact clippedWeight_eq_mult_of_orderedWindow W (by omega)

/-- **Per-`i` FTC integrand identity (analytic hypothesis).** For each
ordinate `Z_i` in the window, the indicator-against-kernel-derivative
integral equals the kernel boundary difference:

  `тИл_T^X [Z_i тЙд u] ┬╖ k'(u) du = k(X) тИТ k(Z_i)`.

This is the genuine analytic content of the ┬зCXCV bridge тАФ it
encapsulates an interval split at `Z_i` plus FTC on `[Z_i, X]` for
`pairedCauchyImKernel` (the indicator vanishes on `[T, Z_i)`).
Packaged as a Prop so the bridge theorem itself stays algebraic. -/
def IndicatorKernelFTCHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (m : тДХ) : Prop :=
  тИА i тИИ Finset.range D.n, i тЙд m тЖТ
    (тИл u in T..X,
        (if D.Z i тЙд u then (1 : тДЭ) else 0) * pairedCauchyImKernelDeriv x y u)
      = pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)

/-- **Linearity hypothesis**: pulling the finite sum over `i тИИ range n`
out of the kernel-derivative integral. Mathlib's
`intervalIntegral.integral_finset_sum` discharges this given pointwise
integrability of each summand; packaged as a Prop to keep the algebraic
core focused. -/
def IntegralSumLinearityHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) : Prop :=
  (тИл u in T..X,
      (тИС i тИИ Finset.range D.n,
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0))
        * pairedCauchyImKernelDeriv x y u)
    =
  тИС i тИИ Finset.range D.n,
    (D.mult i : тДЭ) *
      тИл u in T..X,
        (if D.Z i тЙд u then (1 : тДЭ) else 0) * pairedCauchyImKernelDeriv x y u

/-- **N(u) decomposition hypothesis**: under `OrderedWindow`, the
clipped counting primitive at any inner `u тИИ [T, X]` agrees with the
unclipped indicator sum `тИС_i mult_i ┬╖ [Z_i тЙд u]`. Packaged as an
integrand-level equality so the integral can be congruenced. -/
def NDecompositionIntegrandHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) : Prop :=
  (тИл u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
    =
  тИл u in T..X,
    (тИС i тИИ Finset.range D.n,
      (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0))
      * pairedCauchyImKernelDeriv x y u

/-- тнР **PROVED тАФ algebraic Abel-sum closed form** for `R + EC` under
`OrderedWindow`:

  `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
     = тИС_{i тЙд m} mult_i ┬╖ (k(X) тИТ k(Z_i))`.

Derivation: invoke the endpoint-corrected discrete IBP to convert the
LHS to `N(X) ┬╖ k(X) тИТ discreteKernelPartial`; expand both via
`OrderedWindow` and rearrange. -/
theorem discrete_remainder_plus_correction_eq_explicit_sum
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    тИС i тИИ Finset.range D.n,
      (D.mult i : тДЭ) *
        (pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)) := by
  -- Endpoint-corrected discrete IBP: partial = N┬╖k(X) тИТ R тИТ EC.
  have h_ibp :=
    ordered_discrete_kernel_ibp_endpoint_corrected D x y T X W.hn
  -- Solve for R + EC: R + EC = N┬╖k(X) тИТ partial.
  have h_RE :
      discreteKernelAbelRemainder D x y T X m
        + discreteAbelEndpointCorrection D.toFluctuationMeasureData
            (fun u => pairedCauchyImKernel x y u) T X m
        = discreteCountingPrimitive D.toFluctuationMeasureData T X
            * pairedCauchyImKernel x y X
          - discreteKernelPartial D.toFluctuationMeasureData
              (fun u => pairedCauchyImKernel x y u) T X := by
    linarith [h_ibp]
  rw [h_RE]
  -- Now expand `partial` under OrderedWindow: clipping vanishes.
  have h_partial :
      discreteKernelPartial D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X
        = тИС i тИИ Finset.range D.n,
            (D.mult i : тДЭ) * pairedCauchyImKernel x y (D.Z i) := by
    unfold discreteKernelPartial
    rw [W.hn]
    apply Finset.sum_congr rfl
    intro i hi
    have hi_lt : i < m + 1 := Finset.mem_range.mp hi
    have hi_le_m : i тЙд m := by omega
    rw [if_pos (W.Z_mem_window hi_le_m)]
  rw [h_partial, discreteCountingPrimitive_full_of_orderedWindow W]
  -- N(X) ┬╖ k(X) тИТ тИС mult_i ┬╖ k(Z_i) = тИС mult_i ┬╖ (k(X) тИТ k(Z_i))
  rw [Finset.sum_mul, тЖР Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro i _
  ring

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ FTC BRIDGE: discrete Abel + endpoint correction
= integral of `N ┬╖ k'`** (under OrderedWindow + analytic hypotheses).

Identifies the discrete Abel remainder plus the endpoint correction
with the interval integral

  `тИл_T^X N(u) ┬╖ k'(u) du`,

routing the genuine analytic content through three Prop hypotheses:
the N-decomposition integrand rewrite, the integral-linearity swap,
and the per-`i` indicator-FTC identity. With all three discharged
(future work via Mathlib's `intervalIntegral.integral_finset_sum`,
`integral_congr`, and `integral_eq_sub_of_hasDerivAt`), this is the
first finite-window FTC bridge from Abel sums to step-function
integrals. -/
theorem discrete_corrected_remainder_eq_intervalIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m)
    (h_decomp : NDecompositionIntegrandHypothesis D x y T X)
    (h_linear : IntegralSumLinearityHypothesis D x y T X)
    (h_ftc : IndicatorKernelFTCHypothesis D x y T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    тИл u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
  -- Algebraic side: R + EC = тИС mult_i ┬╖ (k(X) тИТ k(Z_i)).
  rw [discrete_remainder_plus_correction_eq_explicit_sum D x y T X W]
  -- Analytic side: rewrite the integral through the three hypotheses.
  rw [h_decomp, h_linear]
  -- Now the integral side is тИС mult_i ┬╖ (тИл indicator ┬╖ k').
  -- Discharge each per-`i` via the FTC hypothesis.
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i тЙд m := by rw [W.hn] at hi_lt; omega
  rw [h_ftc i hi hi_le_m]

-- =====================================================================
-- ┬зCXCVI-A. Discharge `NDecompositionIntegrandHypothesis`
-- =====================================================================
-- Under `OrderedWindow`, the clipping condition `T тЙд Z_i тИз Z_i тЙд u`
-- collapses to `Z_i тЙд u` (the `T тЙд Z_i` part is automatic). The
-- counting primitive then equals `тИС_i mult_i ┬╖ [Z_i тЙд u]` pointwise
-- (for every `u`, not just `u тИИ [T, X]`), so the integrand rewrite
-- discharges via `intervalIntegral.integral_congr`.

/-- тнР **PROVED тАФ pointwise decomposition of `N(u)`** under `OrderedWindow`:
  `discreteCountingPrimitive D T u
     = тИС_i mult_i ┬╖ [Z_i тЙд u]`.
Holds for every `u : тДЭ` because the `T тЙд Z_i` half of the clipping
condition is automatic from `OrderedWindow`. -/
lemma discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (T X u : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T u
      =
    тИС i тИИ Finset.range D.n,
      (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0) := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i тЙд m := by rw [W.hn] at hi_lt; omega
  have hT_Zi : T тЙд D.Z i := (W.Z_mem_window hi_le_m).1
  by_cases hZi_u : D.Z i тЙд u
  ┬╖ have hclip : T тЙд D.Z i тИз D.Z i тЙд u := тЯиhT_Zi, hZi_uтЯй
    rw [if_pos hclip, if_pos hZi_u, mul_one]
  ┬╖ have hclip : ┬м (T тЙд D.Z i тИз D.Z i тЙд u) := fun h => hZi_u h.2
    rw [if_neg hclip, if_neg hZi_u, mul_zero]

/-- ЁЯМЯ **PROVED тАФ `NDecompositionIntegrandHypothesis` discharged**
under `OrderedWindow`. The pointwise lemma plus
`intervalIntegral.integral_congr` does the work. -/
theorem nDecompositionIntegrand_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) :
    NDecompositionIntegrandHypothesis D x y T X := by
  unfold NDecompositionIntegrandHypothesis
  refine intervalIntegral.integral_congr ?_
  intro u _
  show discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      = (тИС i тИИ Finset.range D.n, (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0))
          * pairedCauchyImKernelDeriv x y u
  rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W]

-- =====================================================================
-- ┬зCXCVI-B-prep. FTC for the paired-Cauchy imaginary kernel derivative
-- =====================================================================
-- Pure FTC: `тИл_a^b k'(u) du = k(b) тИТ k(a)`. Independent of indicators.
-- Becomes the engine for `IndicatorKernelFTCHypothesis` once the
-- indicator split lemma lands (next patch).

/-- ЁЯМЯ **PROVED тАФ FTC for `pairedCauchyImKernel`**:
  `тИл_a^b k'(u) du = k(b) тИТ k(a)`.
Direct application of `intervalIntegral.integral_eq_sub_of_hasDerivAt`
with the per-point derivative `pairedCauchyImKernel_hasDerivAt` and
the continuity-based integrability `pairedCauchyImKernelDeriv_intervalIntegrable`. -/
theorem pairedCauchyImKernelDeriv_integral_eq_sub
    {y : тДЭ} (hy : 0 < y) (x a b : тДЭ) :
    (тИл u in a..b, pairedCauchyImKernelDeriv x y u)
      =
    pairedCauchyImKernel x y b - pairedCauchyImKernel x y a := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ┬╖ intro u _
    exact pairedCauchyImKernel_hasDerivAt hy x u
  ┬╖ exact pairedCauchyImKernelDeriv_intervalIntegrable hy x a b

-- =====================================================================
-- ┬зCXCVI-B. Indicator splitting + `IndicatorKernelFTCHypothesis`
-- =====================================================================
-- Key analytic step: for `T тЙд a тЙд X`,
--   `тИл_T^X [a тЙд u] ┬╖ k'(u) du = тИл_a^X k'(u) du`.
-- Mathlib has `intervalIntegral.integral_indicator` for `Set.Ioi`; we
-- recast `[a тЙд u]` (i.e. `Set.Ici a`) to `Set.Ioi a` via an a.e.
-- equality (they differ only at the single point `{a}`, measure 0)
-- and then invoke Mathlib's lemma directly.

-- Strategy that AVOIDS `intervalIntegral.integral_indicator` entirely.
-- That theorem's general type drives the `whnf` budget to zero on the
-- explicit `pairedCauchyImKernelDeriv` rational body. The route below
-- closes the cutoff identity via:
--   1. closed cutoff `[a тЙд u]` = strict cutoff `[a < u]` (one AE step)
--   2. split `тИл_T^X = тИл_T^a + тИл_a^X` (adjacent intervals)
--   3. left piece: pointwise zero  (no AE needed under strict cutoff)
--   4. right piece: AE-equal to `g`
--   5. assemble via calc.

/-- тнР **PROVED тАФ a.e. on `volume`, every point differs from a fixed `a`.**
Volume-singleton triviality, packaged for use with `filter_upwards`. -/
lemma ae_ne_real (a : тДЭ) :
    тИАс╡Р u : тДЭ тИВMeasureTheory.volume, u тЙа a := by
  refine MeasureTheory.ae_iff.mpr ?_
  have h_eq : {u : тДЭ | ┬м u тЙа a} = {a} := by
    ext u
    simp [Set.mem_setOf_eq, Set.mem_singleton_iff, not_not]
  rw [h_eq]
  exact Real.volume_singleton

/-- тнР **PROVED тАФ closed cutoff equals strict cutoff in the
interval integral.** Single AE step using `ae_ne_real`. -/
lemma integral_if_le_eq_integral_if_lt
    (g : тДЭ тЖТ тДЭ) (a T X : тДЭ) :
    (тИл u in T..X, (if a тЙд u then (1 : тДЭ) else 0) * g u)
      =
    тИл u in T..X, (if a < u then (1 : тДЭ) else 0) * g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne _
  by_cases hle : a тЙд u
  ┬╖ have hlt : a < u := lt_of_le_of_ne hle (Ne.symm hu_ne)
    rw [if_pos hle, if_pos hlt]
  ┬╖ have hnlt : ┬м a < u := fun h => hle (le_of_lt h)
    rw [if_neg hle, if_neg hnlt]

/-- тнР **PROVED тАФ strict cutoff left piece is zero** on `[T, a]`.
Pointwise: every `u тИИ [T, a]` has `a < u` false (since `u тЙд a`). -/
lemma integral_if_lt_left_zero
    (g : тДЭ тЖТ тДЭ) (T a : тДЭ) (hTa : T тЙд a) :
    (тИл u in T..a, (if a < u then (1 : тДЭ) else 0) * g u) = 0 := by
  have h_eq : тИА u тИИ Set.uIcc T a,
      (if a < u then (1 : тДЭ) else 0) * g u = 0 := by
    intro u hu
    rw [Set.uIcc_of_le hTa] at hu
    have hua : u тЙд a := hu.2
    have hnlt : ┬м a < u := not_lt.mpr hua
    rw [if_neg hnlt, zero_mul]
  calc (тИл u in T..a, (if a < u then (1 : тДЭ) else 0) * g u)
      = тИл _ in T..a, (0 : тДЭ) := intervalIntegral.integral_congr h_eq
    _ = 0 := intervalIntegral.integral_zero

/-- тнР **PROVED тАФ strict cutoff right piece equals `g`** on `[a, X]`.
Single AE step (since `a < u` fails only at `u = a`). -/
lemma integral_if_lt_right_eq
    (g : тДЭ тЖТ тДЭ) (a X : тДЭ) (haX : a тЙд X) :
    (тИл u in a..X, (if a < u then (1 : тДЭ) else 0) * g u)
      =
    тИл u in a..X, g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne hu_mem
  rw [Set.uIoc_of_le haX] at hu_mem
  have hau_lt : a < u := hu_mem.1
  rw [if_pos hau_lt, one_mul]

/-- тнР **PROVED тАФ strict cutoff ├Ч `g`** is interval-integrable on the
left sub-interval `[T, a]`. Integrand is pointwise zero on `(T, a]`
(since `u тЙд a тЖТ ┬м(a < u)`); congruence with the constant-zero
integrable function discharges. -/
lemma intervalIntegrable_if_lt_mul_left
    (g : тДЭ тЖТ тДЭ) (a T : тДЭ) (hTa : T тЙд a) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : тДЭ) else 0) * g u)
      MeasureTheory.volume T a := by
  refine (intervalIntegrable_const (c := (0 : тДЭ))).congr ?_
  rw [Set.uIoc_of_le hTa]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hua : u тЙд a := hu.2
  have hnlt : ┬м a < u := not_lt.mpr hua
  show (0 : тДЭ) = (if a < u then (1 : тДЭ) else 0) * g u
  rw [if_neg hnlt, zero_mul]

/-- тнР **PROVED тАФ strict cutoff ├Ч `g`** is interval-integrable on the
right sub-interval `[a, X]` when `g` is. Integrand equals `g` for
`a < u`; congruence with `g` discharges. -/
lemma intervalIntegrable_if_lt_mul_right
    (g : тДЭ тЖТ тДЭ) (a X : тДЭ) (haX : a тЙд X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume a X) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : тДЭ) else 0) * g u)
      MeasureTheory.volume a X := by
  refine hg_int.congr ?_
  rw [Set.uIoc_of_le haX]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hau : a < u := hu.1
  show g u = (if a < u then (1 : тДЭ) else 0) * g u
  rw [if_pos hau, one_mul]

/-- тнР **PROVED тАФ strict cutoff splits cleanly at `a`**:
  `тИл_T^X [a < u] ┬╖ g(u) du = тИл_a^X g(u) du`.
Uses adjacent-interval splitting, left zero, right `g`. No
`integral_indicator` invocation. -/
lemma integral_if_lt_eq_integral_from_cut
    (g : тДЭ тЖТ тДЭ) (T a X : тДЭ)
    (hTa : T тЙд a) (haX : a тЙд X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (тИл u in T..X, (if a < u then (1 : тДЭ) else 0) * g u)
      =
    тИл u in a..X, g u := by
  -- split `g`'s integrability to the right sub-interval
  have hTX : T тЙд X := le_trans hTa haX
  have h_sub_right : Set.uIcc a X тКЖ Set.uIcc T X := by
    rw [Set.uIcc_of_le haX, Set.uIcc_of_le hTX]
    exact Set.Icc_subset_Icc_left hTa
  have hg_right : IntervalIntegrable g MeasureTheory.volume a X :=
    hg_int.mono_set h_sub_right
  -- indicator-product integrability on each sub-interval
  have h_int_left := intervalIntegrable_if_lt_mul_left g a T hTa
  have h_int_right := intervalIntegrable_if_lt_mul_right g a X haX hg_right
  calc
    (тИл u in T..X, (if a < u then (1 : тДЭ) else 0) * g u)
        =
      (тИл u in T..a, (if a < u then (1 : тДЭ) else 0) * g u)
        + тИл u in a..X, (if a < u then (1 : тДЭ) else 0) * g u :=
        (intervalIntegral.integral_add_adjacent_intervals
          h_int_left h_int_right).symm
    _ = 0 + тИл u in a..X, g u := by
          rw [integral_if_lt_left_zero g T a hTa,
              integral_if_lt_right_eq g a X haX]
    _ = тИл u in a..X, g u := zero_add _

/-- ЁЯМЯ **PROVED тАФ generic indicator cutoff identity**:
  `тИл_T^X [a тЙд u] ┬╖ g(u) du = тИл_a^X g(u) du`   for `T тЙд a тЙд X`.

Routes through strict cutoff to bypass `intervalIntegral.integral_indicator`. -/
theorem indicator_Ici_integral_eq_integral_from_cut
    (g : тДЭ тЖТ тДЭ) (T a X : тДЭ)
    (hTa : T тЙд a) (haX : a тЙд X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (тИл u in T..X, (if a тЙд u then (1 : тДЭ) else 0) * g u)
      =
    тИл u in a..X, g u := by
  rw [integral_if_le_eq_integral_if_lt g a T X,
      integral_if_lt_eq_integral_from_cut g T a X hTa haX hg_int]

/-- тнР **PROVED тАФ kernel-specific indicator cutoff identity**, by
direct specialization of `indicator_Ici_integral_eq_integral_from_cut`.
The kernel-derivative is interval-integrable from continuity for any
`y > 0` (via `pairedCauchyImKernelDeriv_intervalIntegrable`). -/
theorem pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
    (x y T a X : тДЭ) (hTa : T тЙд a) (haX : a тЙд X) (hy : 0 < y) :
    (тИл u in T..X,
        (if a тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      =
    тИл u in a..X, pairedCauchyImKernelDeriv x y u :=
  indicator_Ici_integral_eq_integral_from_cut
    (pairedCauchyImKernelDeriv x y) T a X hTa haX
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X)

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `IndicatorKernelFTCHypothesis` discharged**
under `OrderedWindow`. Combines the indicator cutoff lemma with the
pure FTC for the kernel derivative. -/
theorem indicatorKernelFTC_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IndicatorKernelFTCHypothesis D x y T X m := by
  intro i hi hi_le_m
  have hZi := W.Z_mem_window hi_le_m
  rw [pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
        x y T (D.Z i) X hZi.1 hZi.2 hy]
  exact pairedCauchyImKernelDeriv_integral_eq_sub hy x (D.Z i) X

-- =====================================================================
-- ┬зCXCVI-C. Discharge `IntegralSumLinearityHypothesis`
-- =====================================================================
-- The indicator ├Ч kernel-derivative term is interval-integrable
-- (it equals `Set.indicator (Set.Ici Z_i) (mult_i ┬╖ k')`, where the
-- argument is continuous, hence integrable). Then
-- `intervalIntegral.integral_finset_sum` discharges the sum-linearity.

/-- тнР **PROVED тАФ interval integrability of each indicator ├Ч kernel
derivative term.** -/
lemma indicator_kernel_deriv_term_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) (i : тДХ)
    (hy : 0 < y) :
    IntervalIntegrable
      (fun u : тДЭ =>
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- The term equals `Set.indicator (Set.Ici (D.Z i)) (mult_i ┬╖ k')`.
  have h_eq :
      (fun u : тДЭ =>
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = Set.indicator (Set.Ici (D.Z i))
          (fun u : тДЭ => (D.mult i : тДЭ) * pairedCauchyImKernelDeriv x y u) := by
    funext u
    by_cases h : D.Z i тЙд u
    ┬╖ have hmem : u тИИ Set.Ici (D.Z i) := h
      rw [if_pos h, mul_one, Set.indicator_of_mem hmem]
    ┬╖ have hnmem : u тИЙ Set.Ici (D.Z i) := h
      rw [if_neg h, mul_zero, zero_mul, Set.indicator_of_notMem hnmem]
  rw [h_eq]
  -- `IntervalIntegrable.indicator` isn't in Mathlib; build manually
  -- from the two `IntegrableOn` components.
  have h_const_mul : IntervalIntegrable
      (fun u : тДЭ => (D.mult i : тДЭ) * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X).const_mul (D.mult i : тДЭ)
  exact тЯиh_const_mul.1.indicator measurableSet_Ici,
         h_const_mul.2.indicator measurableSet_IciтЯй

/-- ЁЯМЯ **PROVED тАФ `IntegralSumLinearityHypothesis` discharged** under
`OrderedWindow` (well, just needs `hy : 0 < y` for the term
integrability). Three-step proof: pointwise distribute `(тИС) ┬╖ k'` to
`тИС ((┬╖) ┬╖ k')`; apply `intervalIntegral.integral_finset_sum`; pull
each `mult_i` constant out of the per-`i` integral. -/
theorem integralSumLinearity_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ)
    (hy : 0 < y) :
    IntegralSumLinearityHypothesis D x y T X := by
  unfold IntegralSumLinearityHypothesis
  -- Step 1: pointwise distribute the sum over k'(u).
  have h_distrib : тИА u : тДЭ,
      (тИС i тИИ Finset.range D.n,
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0))
        * pairedCauchyImKernelDeriv x y u
      =
      тИС i тИИ Finset.range D.n,
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
    intro u
    rw [Finset.sum_mul]
  -- Step 2: rewrite the LHS integral using the pointwise distribution.
  have h_rewrite :
      (тИл u in T..X,
        (тИС i тИИ Finset.range D.n,
          (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0))
          * pairedCauchyImKernelDeriv x y u)
      =
      тИл u in T..X,
        тИС i тИИ Finset.range D.n,
          (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u := by
    refine intervalIntegral.integral_congr ?_
    intro u _
    exact h_distrib u
  rw [h_rewrite]
  -- Step 3: pull the finite sum out of the integral.
  have h_int : тИА i тИИ Finset.range D.n,
      IntervalIntegrable
        (fun u : тДЭ =>
          (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    fun i _ => indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  rw [intervalIntegral.integral_finset_sum h_int]
  -- Step 4: per-i, pull constant `mult_i` out of `тИл`.
  apply Finset.sum_congr rfl
  intro i _
  have h_term :
      (fun u : тДЭ =>
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = (fun u : тДЭ =>
          (D.mult i : тДЭ) *
            ((if D.Z i тЙд u then (1 : тДЭ) else 0) * pairedCauchyImKernelDeriv x y u)) := by
    funext u; ring
  rw [h_term, intervalIntegral.integral_const_mul]

-- =====================================================================
-- ┬зCXCVII. Unconditional FTC bridge + finite-window true IBP
-- =====================================================================
-- All three Prop hypotheses are now discharged. The FTC bridge and the
-- full finite-window IBP normal form become unconditional theorems.

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ UNCONDITIONAL FTC BRIDGE** under `OrderedWindow`.
Combines the three discharged hypotheses with the algebraic bridge
`discrete_corrected_remainder_eq_intervalIntegral`. -/
theorem discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    тИл u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u :=
  discrete_corrected_remainder_eq_intervalIntegral D x y T X W
    (nDecompositionIntegrand_of_orderedWindow D x y T X W)
    (integralSumLinearity_of_orderedWindow D x y T X hy)
    (indicatorKernelFTC_of_orderedWindow D x y T X W hy)

-- =====================================================================
-- ┬зCXCVIII. True finite-window fluctuation IBP (no analytic hypotheses)
-- =====================================================================
-- Combines the unconditional FTC bridge `discrete_corrected_remainder_eq_
-- intervalIntegral_of_orderedWindow` with the endpoint-corrected
-- finite-fluctuation IBP into the clean finite-window Stieltjes IBP:
--
--   `finiteFluctuationKernelPartial = k(X) ┬╖ S(T,X) тИТ тИл_T^X S(T,u) ┬╖ k'(u) du`
--
-- where `S(T, ┬╖) = finiteFluctuationPrimitive D T`. No Prop hypotheses.

/-- **Per-`i` indicator-kernel-derivative term**, top-level definition
to keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteKernelDerivIndicatorTerm
    (D : OrderedFluctuationMeasureData) (x y : тДЭ) (i : тДХ) : тДЭ тЖТ тДЭ :=
  fun u =>
    (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- тнР **PROVED тАФ `N(u) ┬╖ k'(u)` is interval-integrable** on `[T, X]`
under `OrderedWindow`. Uses the indicator decomposition: `N` equals
`тИС_i mult_i ┬╖ [Z_i тЙд u]` (pointwise everywhere), and each term in the
sum is interval-integrable. The integrability of the sum is stated
as a **sum of functions**, not a `fun u => тИС ... u`, to avoid the
function-vs-sum unification timeout. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IntervalIntegrable
      (fun u => discreteCountingPrimitive D.toFluctuationMeasureData T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun_int :
      IntervalIntegrable
        (тИС i тИИ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (by
      intro i _
      unfold discreteKernelDerivIndicatorTerm
      exact indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy)
  refine h_sum_fun_int.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (тИС i, term i) u = тИС i, term i u  (Finset.sum_apply)
  -- = (тИС i, mult_i * indicator_i) * k'(u)  (Finset.sum_mul reverse)
  -- = N(u) * k'(u)  (decomposition lemma)
  calc
    (тИС i тИИ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i) u
        =
      тИС i тИИ Finset.range D.n,
        (D.mult i : тДЭ) * (if D.Z i тЙд u then (1 : тДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
          simp only [Finset.sum_apply, discreteKernelDerivIndicatorTerm]
    _ =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
          symm
          rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W,
              Finset.sum_mul]

/-- тнР **PROVED тАФ `S_smooth(u) ┬╖ k'(u)` is interval-integrable** on
`[T, X]` for `0 < T тЙд X` and `0 < y`. Both factors are continuous on
`[T, X]`: `S_smooth` via the existing `HasDerivAt` (differentiable тЗТ
continuous), and `k'` via `pairedCauchyImKernelDeriv_continuous`. -/
lemma smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    {T X : тДЭ} (hT : 0 < T) (hTX : T тЙд X) (x : тДЭ) {y : тДЭ} (hy : 0 < y) :
    IntervalIntegrable
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- S_smooth is continuous on [T, X] via HasDerivAt тЖТ differentiableAt тЖТ continuousAt
  have h_S_cont : ContinuousOn (fun u => smoothCountingPrimitive T u)
      (Set.Icc T X) := by
    intro u hu
    have h_diff : DifferentiableAt тДЭ (fun v => smoothCountingPrimitive T v) u :=
      (smoothCountingPrimitive_hasDerivAt hT hu.1).differentiableAt
    exact h_diff.continuousAt.continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    (pairedCauchyImKernelDeriv_continuous hy x).continuousOn
  have h_prod_cont : ContinuousOn
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    h_S_cont.mul h_k_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- **True derivative-side integral** for the finite fluctuation IBP:
  `тИл_T^X S(T,u) ┬╖ k'(u) du`  where `S(T, ┬╖) = finiteFluctuationPrimitive D T`. -/
noncomputable def finiteFluctuationDerivativeIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) : тДЭ :=
  тИл u in T..X,
    finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u

/-- тнР **PROVED тАФ derivative-side integral splits as difference of two
integrals**:
  `finiteFluctuationDerivativeIntegral = (тИл N┬╖k') тИТ (тИл S_smooth┬╖k')`.
Uses `intervalIntegral.integral_sub` with the two integrability
helpers above. -/
lemma finiteFluctuationDerivativeIntegral_expand
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m) (hT : 0 < T) (hTX : T тЙд X) (hy : 0 < y) :
    finiteFluctuationDerivativeIntegral D x y T X
      =
    (тИл u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
      -
    тИл u in T..X,
      smoothCountingPrimitive T u
        * pairedCauchyImKernelDeriv x y u := by
  unfold finiteFluctuationDerivativeIntegral finiteFluctuationPrimitive
  have h_pointwise : тИА u : тДЭ,
      (discreteCountingPrimitive D.toFluctuationMeasureData T u
        - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u
      =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
    intro u; ring
  rw [show (fun u : тДЭ =>
        (discreteCountingPrimitive D.toFluctuationMeasureData T u
          - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u)
      = (fun u : тДЭ =>
        discreteCountingPrimitive D.toFluctuationMeasureData T u
          * pairedCauchyImKernelDeriv x y u
        - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u)
      from funext h_pointwise]
  exact intervalIntegral.integral_sub
    (discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable D x y T X W hy)
    (smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable hT hTX x hy)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ TRUE FINITE-WINDOW FLUCTUATION IBP**
(no analytic Prop hypotheses):

  `finiteFluctuationKernelPartial D x y T X
     = k(X) ┬╖ S(T,X) тИТ тИл_T^X S(T,u) ┬╖ k'(u) du`

where `S(T, ┬╖) = finiteFluctuationPrimitive D T`.

This is the first unconditional finite-window Stieltjes IBP for the
xi fluctuation against the imaginary paired-Cauchy kernel. Combines:
* the endpoint-corrected fluctuation IBP (┬зCXCIV);
* the unconditional FTC bridge (┬зCXCVII);
* the derivative-integral expansion (above).

All three were unconditional, so this is too. -/
theorem finiteFluctuationKernelPartial_true_ibp
    (D : OrderedFluctuationMeasureData) (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T тЙд X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
      -
    finiteFluctuationDerivativeIntegral D x y T X := by
  -- Step 1: invoke the endpoint-corrected IBP
  rw [finiteFluctuationKernelPartial_endpoint_corrected_ibp
        D x y T X W.hn hT hTX hy]
  -- Step 2: unfold rawRemainder + endpointCorrection
  unfold finiteFluctuationRawRemainder finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection discreteAbelEndpointCorrection
  -- Step 3: bridge `R + EC = тИлN┬╖k'`
  have h_bridge :=
    discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow D x y T X W hy
  -- Step 4: derivative-side expansion
  have h_expand :=
    finiteFluctuationDerivativeIntegral_expand D x y T X W hT hTX hy
  -- Step 5: name abbreviations to dodge integral atoms inside `ring`.
  set N := discreteCountingPrimitive D.toFluctuationMeasureData T X with hN
  set ffP := finiteFluctuationPrimitive D T X with hffP
  set kX := pairedCauchyImKernel x y X with hkX
  set ffDI := finiteFluctuationDerivativeIntegral D x y T X with hffDI
  set R := discreteKernelAbelRemainder D x y T X m with hR
  set SI := тИл u in T..X,
              smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u
    with hSI
  set NI := тИл u in T..X,
              discreteCountingPrimitive D.toFluctuationMeasureData T u
                * pairedCauchyImKernelDeriv x y u
    with hNI
  -- `set ... with ...` already replaced occurrences in `h_bridge` and
  -- `h_expand`. We still need to unfold `discreteAbelEndpointCorrection`
  -- in `h_bridge` so it exposes `N * (kX - k(D.Z m))`.
  unfold discreteAbelEndpointCorrection at h_bridge
  show ffP * kX - (R - SI) - N * (kX - pairedCauchyImKernel x y (D.Z m))
       = kX * ffP - ffDI
  linarith

/-- тнР **PROVED тАФ `finiteFluctuationPrimitive D T T = 0` when no zero
ordinate sits exactly at `T`.** Combines
`discreteCountingPrimitive_left_zero_of_no_atom` with
`smoothCountingPrimitive_self`. -/
lemma finiteFluctuationPrimitive_left_zero_of_no_atom
    (D : OrderedFluctuationMeasureData) (T : тДЭ)
    (hnoT : тИА j тИИ Finset.range D.n, D.Z j тЙа T) :
    finiteFluctuationPrimitive D T T = 0 := by
  unfold finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_left_zero_of_no_atom D.toFluctuationMeasureData T hnoT,
      smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- ┬зCXCIX. Finite-window IBP packaging + tail-window eventual data
-- =====================================================================
-- (A) `FiniteWindowKernelStieltjesIBP`: a one-endpoint package recording
-- the finite-window Stieltjes IBP identity at a specific `X`. Makes
-- `finiteFluctuationKernelPartial_true_ibp` reusable by downstream
-- improper-limit records without reopening the Abel machinery.
-- (B) `OrderedTailWindowData` + `orderedWindow_eventually_atTop`: data
-- that's stable as `X тЖТ тИЮ`, with the eventual-window lemma that says
-- `OrderedWindow D T X m` holds for all sufficiently large `X`. This is
-- the bridge for building improper IBP packages from finite-window ones.

/-- **One-endpoint finite-window Stieltjes IBP record.** Records the
finite IBP identity at a specific cutoff `X`:

  `partialAtX = k(X)┬╖S(X) тИТ k(T)┬╖S(T) тИТ тИл_T^X S(u)┬╖k'(u) du`.

Different from the global `FiniteKernelStieltjesIBP` (┬зCLXXXVIII), which
quantifies the identity over **all** `X`. This record is the natural
finite-window output of `finiteFluctuationKernelPartial_true_ibp`. -/
structure FiniteWindowKernelStieltjesIBP where
  S : тДЭ тЖТ тДЭ
  partialAtX : тДЭ
  x : тДЭ
  y : тДЭ
  T : тДЭ
  X : тДЭ
  finite_ibp_at_X :
    partialAtX =
      pairedCauchyImKernel x y X * S X
        - pairedCauchyImKernel x y T * S T
        - тИл u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- ЁЯМЯ **PROVED тАФ package `finiteFluctuationKernelPartial_true_ibp` as
a `FiniteWindowKernelStieltjesIBP`.** Requires `OrderedWindow` and the
no-atom-at-`T` convention (so the `k(T)┬╖S(T)` term is correctly zero).
The output is the canonical finite-window IBP record. -/
noncomputable def orderedWindowFiniteWindowKernelStieltjesIBP
    (D : OrderedFluctuationMeasureData)
    (x y T X : тДЭ) {m : тДХ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T тЙд X) (hy : 0 < y)
    (hnoT : тИА j тИИ Finset.range D.n, D.Z j тЙа T) :
    FiniteWindowKernelStieltjesIBP where
  S := fun U => finiteFluctuationPrimitive D T U
  partialAtX := finiteFluctuationKernelPartial D x y T X
  x := x
  y := y
  T := T
  X := X
  finite_ibp_at_X := by
    have hmain :=
      finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
    have hleft :
        finiteFluctuationPrimitive D T T = 0 :=
      finiteFluctuationPrimitive_left_zero_of_no_atom D T hnoT
    rw [hmain, hleft]
    unfold finiteFluctuationDerivativeIntegral
    ring

/-- **Tail-window data** for the eventual-`X` form. Holds the
window-invariant pieces (`D.n = m + 1`, `T тЙд Z_0`, strict ordinates)
without committing to a specific upper cutoff `X`. Once `X` is large
enough тАФ specifically, `X тЙе Z_m` тАФ this lifts to a full
`OrderedWindow D T X m`. -/
structure OrderedTailWindowData
    (D : OrderedFluctuationMeasureData) (T : тДЭ) (m : тДХ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T тЙд D.Z 0
  hstrict     : тИА j, j < m тЖТ D.Z j < D.Z (j + 1)

/-- ЁЯМЯ **PROVED тАФ `OrderedWindow D T X m` holds eventually as `X тЖТ тИЮ`.**
The discrete zero list `{Z_0, тАж, Z_m}` is fixed; once `X тЙе Z_m`, the
window inclusion `Z_m тЙд X` holds. Combined with the
window-invariant data in `OrderedTailWindowData`, this gives the
full `OrderedWindow` predicate for all sufficiently large `X`.

This is the key "finite windows become valid eventually" lemma,
enabling improper-limit packages to consume the finite IBP theorem. -/
lemma orderedWindow_eventually_atTop
    (D : OrderedFluctuationMeasureData) (T : тДЭ) {m : тДХ}
    (Wtail : OrderedTailWindowData D T m) :
    тИАс╢а X in Filter.atTop, OrderedWindow D T X m := by
  filter_upwards [Filter.eventually_ge_atTop (D.Z m)] with X hXm
  exact
    { hn := Wtail.hn
      hT_le_first := Wtail.hT_le_first
      hlast_le_X := hXm
      hstrict := Wtail.hstrict }

-- =====================================================================
-- ┬зCC. Base paired-Cauchy kernel decay
-- =====================================================================
-- Pure algebraic decay bound for the boundary term `pairedCauchyImKernel x y X`
-- in the regime `|x| < X`:
--
--   `|k(X)| тЙд 2y / (X тИТ |x|)┬▓`.
--
-- Built in tiny algebraic pieces (positivity, denominator comparisons,
-- per-term Cauchy bounds) so each step has a small local goal. No
-- filter, no kernel-body unfolding in a single step.

/-- тнР **PROVED тАФ positive tail gap** `X тИТ |x| > 0` when `|x| < X`. -/
lemma tailGap_pos_of_abs_lt (x X : тДЭ) (hX : |x| < X) :
    0 < X - |x| := by linarith

/-- тнР **PROVED тАФ positive tail-gap square**. -/
lemma tailGap_sq_pos_of_abs_lt (x X : тДЭ) (hX : |x| < X) :
    0 < (X - |x|)^2 := by
  have h : 0 < X - |x| := tailGap_pos_of_abs_lt x X hX
  positivity

/-- тнР **PROVED тАФ `(X тИТ |x|)┬▓ тЙд (X тИТ x)┬▓`.** Case split on sign of `x`. -/
lemma tailGap_sq_le_sub_sq (x X : тДЭ) (hX : |x| < X) :
    (X - |x|)^2 тЙд (X - x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 тЙд x
  ┬╖ rw [abs_of_nonneg hx]
  ┬╖ have hxle : x тЙд 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle]
    -- goal: (X - -x)^2 тЙд (X - x)^2, i.e., (X + x)^2 тЙд (X - x)^2 when x тЙд 0
    have hXx_nonpos : X * x тЙд 0 :=
      mul_nonpos_of_nonneg_of_nonpos hX_pos.le hxle
    nlinarith [hXx_nonpos]

/-- тнР **PROVED тАФ `(X тИТ |x|)┬▓ тЙд (X + x)┬▓`.** Same by_cases pattern. -/
lemma tailGap_sq_le_add_sq (x X : тДЭ) (hX : |x| < X) :
    (X - |x|)^2 тЙд (X + x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 тЙд x
  ┬╖ rw [abs_of_nonneg hx]
    -- goal: (X - x)^2 тЙд (X + x)^2 when x тЙе 0
    have hXx_nonneg : 0 тЙд X * x := mul_nonneg hX_pos.le hx
    nlinarith [hXx_nonneg]
  ┬╖ have hxle : x тЙд 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle, sub_neg_eq_add]

/-- тнР **PROVED тАФ denominator lower bound** with the `+ y┬▓` term:
  `(X тИТ |x|)┬▓ тЙд (X тИТ x)┬▓ + y┬▓`. -/
lemma tailGap_sq_le_sub_den (x y X : тДЭ) (hX : |x| < X) :
    (X - |x|)^2 тЙд (X - x)^2 + y^2 := by
  have h1 := tailGap_sq_le_sub_sq x X hX
  have h2 : 0 тЙд y^2 := sq_nonneg y
  linarith

/-- тнР **PROVED тАФ denominator lower bound** with the `+ y┬▓` term, plus form. -/
lemma tailGap_sq_le_add_den (x y X : тДЭ) (hX : |x| < X) :
    (X - |x|)^2 тЙд (X + x)^2 + y^2 := by
  have h1 := tailGap_sq_le_add_sq x X hX
  have h2 : 0 тЙд y^2 := sq_nonneg y
  linarith

/-- тнР **PROVED тАФ bound on the `-` Cauchy term** (kernel uses `(x-X)`,
which squares to `(X-x)`, hence equivalent). -/
lemma cauchy_sub_term_le_tail
    (x y X : тДЭ) (hy : 0 тЙд y) (hX : |x| < X) :
    y / ((x - X)^2 + y^2) тЙд y / (X - |x|)^2 := by
  have hsq_eq : (x - X)^2 = (X - x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_sub_den x y X hX)

/-- тнР **PROVED тАФ bound on the `+` Cauchy term**. -/
lemma cauchy_add_term_le_tail
    (x y X : тДЭ) (hy : 0 тЙд y) (hX : |x| < X) :
    y / ((x + X)^2 + y^2) тЙд y / (X - |x|)^2 := by
  have hsq_eq : (x + X)^2 = (X + x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_add_den x y X hX)

/-- тнР **PROVED тАФ pointwise reciprocal Cauchy term is non-negative.** -/
lemma reciprocal_quadratic_nonneg (x X y : тДЭ) :
    0 тЙд 1 / ((x - X)^2 + y^2) := by positivity

/-- тнР **PROVED тАФ sum of reciprocal Cauchy terms is non-negative.** -/
lemma reciprocal_quadratic_sum_nonneg (x X y : тДЭ) :
    0 тЙд 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) := by positivity

/-- ЁЯМЯ **PROVED тАФ BASE KERNEL DECAY**:
  `|pairedCauchyImKernel x y X| тЙд 2y / (X тИТ |x|)┬▓`   when `0 тЙд y, |x| < X`.

The boundary-term inequality needed for the improper IBP limit. Pure
algebra: distribute `-y`, take abs, bound each Cauchy term by
`y/(XтИТ|x|)┬▓`, sum, factor `2`. -/
theorem abs_pairedCauchyImKernel_le_quadratic_tail
    (x y X : тДЭ) (hy : 0 тЙд y) (hX : |x| < X) :
    |pairedCauchyImKernel x y X|
      тЙд 2 * y / (X - |x|)^2 := by
  unfold pairedCauchyImKernel
  -- Rewrite `-y * sum` as `-(y ┬╖ sum)`, then `|тИТ┬╖| = |┬╖|`.
  have h_neg_form :
      -y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = -(y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))) := by ring
  rw [h_neg_form, abs_neg]
  -- The non-negated product is non-negative.
  have h_sum_nn : 0 тЙд 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) :=
    reciprocal_quadratic_sum_nonneg x X y
  have h_prod_nn : 0 тЙд y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2)) :=
    mul_nonneg hy h_sum_nn
  rw [abs_of_nonneg h_prod_nn]
  -- Distribute `y ┬╖ sum = y/A + y/B`.
  have h_distrib :
      y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = y / ((x - X)^2 + y^2) + y / ((x + X)^2 + y^2) := by
    rw [mul_add, mul_one_div, mul_one_div]
  rw [h_distrib]
  have h_sub := cauchy_sub_term_le_tail x y X hy hX
  have h_add := cauchy_add_term_le_tail x y X hy hX
  have h_double : y / (X - |x|)^2 + y / (X - |x|)^2
                = 2 * y / (X - |x|)^2 := by ring
  linarith

-- =====================================================================
-- ┬зCCI. Boundary term decay тЖТ 0 (crude asymptotics + squeeze)
-- =====================================================================
-- Goal:
--   `Tendsto (fun X => k(X) ┬╖ S(X)) atTop (ЁЭУЭ 0)`
-- under the log-envelope hypothesis `|S X| тЙд C┬╖log X + D` eventually.
--
-- Strategy (intentionally crude, to dodge the sharp asymptotic):
--   1. `(X тИТ |x|)┬▓ тЙе X┬▓/4` eventually (when `2|x| тЙд X`).
--   2. `log X тЙд X` eventually.
--   3. `C┬╖log X + D тЙд (C + |D| + 1)┬╖X` eventually.
--   4. `|k(X) ┬╖ S X| тЙд (8y(C+|D|+1))/X` eventually.
--   5. Squeeze with `const/X тЖТ 0`.

/-- тнР **PROVED тАФ `|x| < X` eventually.** -/
lemma eventually_abs_lt_atTop (x : тДЭ) :
    тИАс╢а X : тДЭ in Filter.atTop, |x| < X :=
  Filter.eventually_gt_atTop |x|

/-- тнР **PROVED тАФ `2 ┬╖ |x| тЙд X` eventually.** -/
lemma eventually_two_abs_le_atTop (x : тДЭ) :
    тИАс╢а X : тДЭ in Filter.atTop, 2 * |x| тЙд X :=
  Filter.eventually_ge_atTop (2 * |x|)

/-- тнР **PROVED тАФ shifted square lower bound:**
  `X┬▓/4 тЙд (X тИТ |x|)┬▓`   when `0 тЙд X` and `2|x| тЙд X`. -/
lemma shifted_sq_ge_quarter_sq
    (x X : тДЭ) (hX : 0 тЙд X) (hx : 2 * |x| тЙд X) :
    X^2 / 4 тЙд (X - |x|)^2 := by
  have hhalf : X / 2 тЙд X - |x| := by linarith
  have hhalf_nonneg : 0 тЙд X / 2 := by linarith
  nlinarith [hhalf, hhalf_nonneg, abs_nonneg x]

/-- тнР **PROVED тАФ `log X тЙд X`** eventually as `X тЖТ тИЮ`. -/
lemma eventually_log_le_self :
    тИАс╢а X : тДЭ in Filter.atTop, Real.log X тЙд X := by
  filter_upwards [Filter.eventually_gt_atTop (0 : тДЭ)] with X hX
  have h := Real.log_le_sub_one_of_pos hX
  linarith

/-- тнР **PROVED тАФ log envelope dominated by linear envelope** eventually:
  `C┬╖log X + D тЙд (C + |D| + 1) ┬╖ X`. -/
lemma log_envelope_le_linear_eventually
    (C D : тДЭ) (hC : 0 тЙд C) :
    тИАс╢а X : тДЭ in Filter.atTop,
      C * Real.log X + D тЙд (C + |D| + 1) * X := by
  filter_upwards
    [eventually_log_le_self,
     Filter.eventually_ge_atTop (1 : тДЭ)] with X hlog hXge1
  have hXnonneg : 0 тЙд X := by linarith
  have hClog_le : C * Real.log X тЙд C * X :=
    mul_le_mul_of_nonneg_left hlog hC
  have hD_le_abs : D тЙд |D| := le_abs_self D
  have habs_le_absX : |D| тЙд |D| * X := by
    have habs_nn : 0 тЙд |D| := abs_nonneg D
    nlinarith [habs_nn, hXge1]
  have h_one_X_nn : 0 тЙд 1 * X := by linarith
  nlinarith [hClog_le, hD_le_abs, habs_le_absX, hXnonneg]

/-- тнР **PROVED тАФ `A / X тЖТ 0` as `X тЖТ тИЮ`** for any constant `A`. -/
lemma const_div_tendsto_zero_atTop (A : тДЭ) :
    Tendsto (fun X : тДЭ => A / X) Filter.atTop (ЁЭУЭ 0) := by
  simpa [div_eq_mul_inv] using
    (tendsto_const_nhds (x := A)).mul tendsto_inv_atTop_zero

/-- тнР **PROVED тАФ boundary term dominated by `const/X` eventually.**
Combines the kernel decay bound, the shifted-square lower bound, and
the log-envelope linear domination. -/
lemma boundary_abs_le_const_over_X_eventually
    {S : тДЭ тЖТ тДЭ} {C D : тДЭ} (x y : тДЭ)
    (hy : 0 тЙд y) (hC : 0 тЙд C) (_hD : 0 тЙд D)
    (hS : тИАс╢а X in Filter.atTop, |S X| тЙд C * Real.log X + D) :
    тИАс╢а X in Filter.atTop,
      |pairedCauchyImKernel x y X * S X|
        тЙд (8 * y * (C + |D| + 1)) / X := by
  filter_upwards
    [hS,
     eventually_abs_lt_atTop x,
     Filter.eventually_gt_atTop (0 : тДЭ),
     eventually_two_abs_le_atTop x,
     log_envelope_le_linear_eventually C D hC]
    with X hSX hAbs hXpos h2abs hloglin
  have hk : |pairedCauchyImKernel x y X| тЙд 2 * y / (X - |x|)^2 :=
    abs_pairedCauchyImKernel_le_quadratic_tail x y X hy hAbs
  have hshift : X^2 / 4 тЙд (X - |x|)^2 :=
    shifted_sq_ge_quarter_sq x X hXpos.le h2abs
  have henv_nonneg : 0 тЙд C * Real.log X + D :=
    le_trans (abs_nonneg _) hSX
  have h_denom_pos : 0 < (X - |x|)^2 :=
    tailGap_sq_pos_of_abs_lt x X hAbs
  have h_quarter_pos : 0 < X^2 / 4 := by positivity
  have h_kbnd_nn : 0 тЙд 2 * y / (X - |x|)^2 :=
    div_nonneg (by linarith) h_denom_pos.le
  have h_quarter_inv_nn : 0 тЙд 2 * y / (X^2 / 4) :=
    div_nonneg (by linarith) h_quarter_pos.le
  -- Step 1: |k ┬╖ S| = |k| ┬╖ |S| тЙд (2y/(X-|x|)┬▓) ┬╖ env
  have h_step1 : |pairedCauchyImKernel x y X * S X|
              тЙд (2 * y / (X - |x|)^2) * (C * Real.log X + D) := by
    rw [abs_mul]
    exact mul_le_mul hk hSX (abs_nonneg _) h_kbnd_nn
  -- Step 2: (2y/(X-|x|)┬▓) ┬╖ env тЙд (2y/(X┬▓/4)) ┬╖ env
  have h_step2 : (2 * y / (X - |x|)^2) * (C * Real.log X + D)
              тЙд (2 * y / (X^2 / 4)) * (C * Real.log X + D) := by
    apply mul_le_mul_of_nonneg_right _ henv_nonneg
    exact div_le_div_of_nonneg_left (by linarith) h_quarter_pos hshift
  -- Step 3: (2y/(X┬▓/4)) ┬╖ env тЙд (2y/(X┬▓/4)) ┬╖ ((C+|D|+1)┬╖X)
  have h_step3 : (2 * y / (X^2 / 4)) * (C * Real.log X + D)
              тЙд (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X) :=
    mul_le_mul_of_nonneg_left hloglin h_quarter_inv_nn
  -- Step 4: algebra тАФ (2y/(X┬▓/4)) ┬╖ ((C+|D|+1)┬╖X) = 8y(C+|D|+1)/X
  have h_step4 : (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X)
              = 8 * y * (C + |D| + 1) / X := by
    have hXne : X тЙа 0 := ne_of_gt hXpos
    field_simp
    ring
  linarith

/-- ЁЯМЯЁЯМЯ **PROVED тАФ BOUNDARY TERM TENDS TO ZERO** under a log
envelope `|S X| тЙд C ┬╖ log X + D`:

  `Tendsto (fun X => k(X) ┬╖ S(X)) atTop (ЁЭУЭ 0)`.

Squeeze on the absolute value via the
`boundary_abs_le_const_over_X_eventually` upper bound + `const/X тЖТ 0`. -/
theorem boundary_atTop_of_log_envelope
    {S : тДЭ тЖТ тДЭ} {C D : тДЭ} (x y : тДЭ)
    (hy : 0 тЙд y) (hC : 0 тЙд C) (hD : 0 тЙд D)
    (hS : тИАс╢а X in Filter.atTop, |S X| тЙд C * Real.log X + D) :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (ЁЭУЭ 0) := by
  -- Step 1: prove |┬╖| тЖТ 0 via squeeze
  have h_abs_tendsto : Tendsto
      (fun X => |pairedCauchyImKernel x y X * S X|) Filter.atTop (ЁЭУЭ 0) := by
    apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
      tendsto_const_nhds
      (const_div_tendsto_zero_atTop (8 * y * (C + |D| + 1)))
    ┬╖ exact Filter.Eventually.of_forall (fun X => abs_nonneg _)
    ┬╖ exact boundary_abs_le_const_over_X_eventually x y hy hC hD hS
  -- Step 2: |┬╖| тЖТ 0 тЯ╣ ┬╖ тЖТ 0
  rw [tendsto_zero_iff_abs_tendsto_zero]
  exact h_abs_tendsto

-- =====================================================================
-- ┬зCCII. Derivative-side improper convergence: architecture + eventual bound
-- =====================================================================
-- Sets up the derivative-side improper limit lane:
--   тАв `derivativeSidePartial` тАФ the partial integral as a function of `X`
--   тАв `ImproperIntervalIntegralConverges` тАФ Prop wrapper around `Tendsto`
--   тАв `derivative_integral_tendsto_of_improperConverges` тАФ bridge
--   тАв `derivative_integrand_abs_le_log_kernel_eventually` тАФ combines log
--     envelope on `S` with the existing kernel decay
--     `abs_pairedCauchyImKernelDeriv_le_adaptive_18` to bound the
--     integrand by `(C┬╖log u + D) ┬╖ 18y/u┬│` eventually.
--
-- The actual convergence of the majorant integral (and hence the
-- derivative-side partial) is the analytic content; it's isolated here
-- as a Prop and inhabited in a follow-up patch (uses Mathlib's
-- absolute-convergence/DCT-for-improper-integrals machinery + the
-- explicit primitive of `log u / u┬│`).

/-- **Derivative-side partial integral**:
  `тИл_T^X S(u) ┬╖ k'(u) du`   where `k' = pairedCauchyImKernelDeriv x y`.
The variable side of the IBP whose limit as `X тЖТ тИЮ` is the open
analytic content of the improper IBP. -/
noncomputable def derivativeSidePartial
    (S : тДЭ тЖТ тДЭ) (x y T X : тДЭ) : тДЭ :=
  тИл u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Improper interval-integral convergence** for `f` at basepoint `T`:
there exists `L` such that `тИл_T^X f(u) du тЖТ L` as `X тЖТ тИЮ`. Prop
wrapper around `Tendsto`. -/
def ImproperIntervalIntegralConverges (f : тДЭ тЖТ тДЭ) (T : тДЭ) : Prop :=
  тИГ L : тДЭ, Tendsto (fun X : тДЭ => тИл u in T..X, f u) Filter.atTop (ЁЭУЭ L)

/-- тнР **PROVED тАФ derivative-side convergence bridge.** If the improper
integral of `S(u) ┬╖ k'(u)` converges (as a Prop), then the
`derivativeSidePartial` tends to that limit. Direct unpacking. -/
lemma derivative_integral_tendsto_of_improperConverges
    {S : тДЭ тЖТ тДЭ} {x y T : тДЭ}
    (h : ImproperIntervalIntegralConverges
          (fun u => S u * pairedCauchyImKernelDeriv x y u) T) :
    тИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (ЁЭУЭ J) := by
  obtain тЯиL, hLтЯй := h
  exact тЯиL, hLтЯй

/-- ЁЯМЯ **PROVED тАФ eventual bound on the derivative-side integrand.**
For `0 < y`, log envelope `|S u| тЙд C log u + D` eventually, and `u`
in the adaptive kernel regime `2(1 + |x| + y) тЙд u`:

  `|S(u) ┬╖ k'(u)| тЙд (C┬╖log u + D) ┬╖ 18y/u┬│`   eventually.

Combines the existing kernel decay
`abs_pairedCauchyImKernelDeriv_le_adaptive_18` (giving the `18y/u┬│`
envelope) with the log envelope on `S`. -/
lemma derivative_integrand_abs_le_log_kernel_eventually
    {S : тДЭ тЖТ тДЭ} {C D : тДЭ} (x y : тДЭ)
    (hy : 0 < y) (_hC : 0 тЙд C) (_hD : 0 тЙд D)
    (hS : тИАс╢а u in Filter.atTop, |S u| тЙд C * Real.log u + D) :
    тИАс╢а u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        тЙд (C * Real.log u + D) * (18 * y / u^3) := by
  filter_upwards
    [hS,
     Filter.eventually_ge_atTop (2 * (1 + |x| + y))] with u hSu h_reg
  rw [abs_mul]
  -- Adaptive bound: T = u (the threshold itself), so hT = h_reg and hu = le_refl u.
  have hkernel : |pairedCauchyImKernelDeriv x y u| тЙд 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 (le_of_lt hy) h_reg (le_refl u)
  have henv_nn : 0 тЙд C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hkernel (abs_nonneg _) henv_nn

/-- **Headline target (Prop-staged): under log envelope + majorant
convergence, the derivative-side partial integral converges.**

Stated with the majorant `(C┬╖log u + D) ┬╖ 18y/u┬│` whose explicit
primitive shows finite convergence (`тИл log u / u┬│` and `тИл 1/u┬│` both
integrate to terms vanishing at `тИЮ`). The Mathlib absolute-convergence
chase to actually inhabit the conclusion is the next analytic patch. -/
def DerivativeSideMajorantConverges
    (_x y T : тДЭ) (C D : тДЭ) : Prop :=
  ImproperIntervalIntegralConverges
    (fun u => (C * Real.log u + D) * (18 * y / u^3)) T

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `derivative_integral_tendsto_of_log_envelope` modulo
majorant convergence.** Given:

* `0 < y`, `0 тЙд C, 0 тЙд D`;
* log envelope `|S u| тЙд C┬╖log u + D` eventually;
* the majorant integral `тИл (C┬╖log u + D)┬╖18y/u┬│ du` converges as
  `X тЖТ тИЮ` (Prop `DerivativeSideMajorantConverges`);

the bridge to convergence of `derivativeSidePartial S x y T` would
follow by the absolute-convergence comparison theorem (next patch).

The current statement isolates exactly what's left: an absolute
domination lemma + Mathlib's "absolutely-convergent improper integral
converges" theorem. -/
def DerivativeSideConvergesUnderLogEnvelope
    (S : тДЭ тЖТ тДЭ) (x y T C D : тДЭ) : Prop :=
  (тИАс╢а u in Filter.atTop, |S u| тЙд C * Real.log u + D) тЖТ
  DerivativeSideMajorantConverges x y T C D тЖТ
  тИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
    Filter.atTop (ЁЭУЭ J)

-- =====================================================================
-- ┬зCCIII. Majorant primitive + DerivativeSideMajorantConverges discharge
-- =====================================================================
-- Discharges `DerivativeSideMajorantConverges` via explicit primitive:
--   `M(u)  := (C ┬╖ log u + D) ┬╖ 18y/u┬│`     (the majorant)
--   `P(u)  := тИТ9y ┬╖ (C ┬╖ log u + D + C/2) / u┬▓`   (a primitive)
-- with `P'(u) = M(u)` for `u > 0`, and `P(X) тЖТ 0` as `X тЖТ тИЮ`.

/-- **Named majorant** for the derivative-side integrand. -/
noncomputable def derivativeSideMajorant
    (y C D : тДЭ) (u : тДЭ) : тДЭ :=
  (C * Real.log u + D) * (18 * y / u^3)

/-- **Explicit primitive** of the majorant on `u > 0`:
  `P(u) = тИТ9y ┬╖ (C ┬╖ log u + D + C/2) / u┬▓`. -/
noncomputable def derivativeSideMajorantPrimitive
    (y C D : тДЭ) (u : тДЭ) : тДЭ :=
  -9 * y * (C * Real.log u + D + C / 2) / u^2

/-- ЁЯМЯ **PROVED тАФ `P'(u) = M(u)`** on `u > 0`. Calculus on
  `log`, `t^2`, and `HasDerivAt.div`, then `field_simp + ring` to
  reconcile the derivative shape. -/
lemma hasDerivAt_derivativeSideMajorantPrimitive
    (y C D u : тДЭ) (hu : 0 < u) :
    HasDerivAt
      (fun t => derivativeSideMajorantPrimitive y C D t)
      (derivativeSideMajorant y C D u)
      u := by
  unfold derivativeSideMajorantPrimitive derivativeSideMajorant
  have hu_ne : u тЙа 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have hu_sq_ne : u^2 тЙа 0 := ne_of_gt hu_sq_pos
  have h_log : HasDerivAt Real.log uтБ╗┬╣ u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * Real.log t + D + C / 2) (C * uтБ╗┬╣) u := by
    have h1 := h_log.const_mul C
    have h2 := h1.add_const D
    exact h2.add_const (C / 2)
  have h_sq : HasDerivAt (fun t : тДЭ => t^2) (2 * u) u := by
    have := (hasDerivAt_id u).pow 2
    simpa [pow_one] using this
  have h_div : HasDerivAt
      (fun t : тДЭ => (C * Real.log t + D + C / 2) / t^2)
      ((C * uтБ╗┬╣ * u^2 - (C * Real.log u + D + C / 2) * (2 * u)) / (u^2)^2) u :=
    h_g.div h_sq hu_sq_ne
  have h_neg9y : HasDerivAt
      (fun t : тДЭ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
      (-9 * y * ((C * uтБ╗┬╣ * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)) u :=
    h_div.const_mul (-9 * y)
  have h_fun_eq : (fun t : тДЭ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
                = (fun t : тДЭ => -9 * y * (C * Real.log t + D + C / 2) / t^2) := by
    funext t; ring
  rw [h_fun_eq] at h_neg9y
  have h_val :
      -9 * y * ((C * uтБ╗┬╣ * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)
        = (C * Real.log u + D) * (18 * y / u^3) := by
    field_simp
    ring
  rw [h_val] at h_neg9y
  exact h_neg9y

/-- тнР **PROVED тАФ majorant is continuous on `[T, X]`** for `0 < T тЙд X`. -/
lemma derivativeSideMajorant_continuousOn_Icc
    (y C D T X : тДЭ) (hT : 0 < T) (_hTX : T тЙд X) :
    ContinuousOn (fun u => derivativeSideMajorant y C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold derivativeSideMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.mul ?_ ?_
  ┬╖ refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  ┬╖ refine continuousAt_const.div ?_ ?_
    ┬╖ exact continuousAt_id.pow 3
    ┬╖ exact pow_ne_zero 3 (ne_of_gt hu_pos)

/-- тнР **PROVED тАФ majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma derivativeSideMajorant_intervalIntegrable
    (y C D T X : тДЭ) (hT : 0 < T) (hTX : T тЙд X) :
    IntervalIntegrable (fun u => derivativeSideMajorant y C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (derivativeSideMajorant_continuousOn_Icc y C D T X hT hTX)

/-- ЁЯМЯ **PROVED тАФ FTC for the majorant**:
  `тИл_T^X M(u) du = P(X) тИТ P(T)`. -/
lemma derivativeSideMajorant_integral_eq_sub
    (y C D T X : тДЭ) (hT : 0 < T) (hTX : T тЙд X) :
    (тИл u in T..X, derivativeSideMajorant y C D u)
      = derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ┬╖ intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_derivativeSideMajorantPrimitive y C D u hu_pos
  ┬╖ exact derivativeSideMajorant_intervalIntegrable y C D T X hT hTX

/-- тнР **PROVED тАФ `1/X┬▓ тЖТ 0`** as `X тЖТ тИЮ`. Via `Tendsto.mul` on `1/X ┬╖ 1/X`. -/
lemma one_div_sq_tendsto_zero :
    Tendsto (fun X : тДЭ => 1 / X^2) Filter.atTop (ЁЭУЭ 0) := by
  have h_inv := const_div_tendsto_zero_atTop (1 : тДЭ)
  have h_prod : Tendsto (fun X : тДЭ => 1 / X * (1 / X)) Filter.atTop (ЁЭУЭ (0 * 0)) :=
    h_inv.mul h_inv
  rw [show (0 * 0 : тДЭ) = 0 from by ring] at h_prod
  have h_eq : (fun X : тДЭ => 1 / X * (1 / X)) = (fun X : тДЭ => 1 / X^2) := by
    funext X; rw [pow_two]; ring
  rw [h_eq] at h_prod
  exact h_prod

/-- тнР **PROVED тАФ `log X / X┬▓ тЖТ 0`** as `X тЖТ тИЮ`. Squeeze between `0`
(eventually, for `X тЙе 1`) and `1/X`. -/
lemma log_div_sq_tendsto_zero :
    Tendsto (fun X : тДЭ => Real.log X / X^2) Filter.atTop (ЁЭУЭ 0) := by
  apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
    (tendsto_const_nhds (x := (0 : тДЭ)))
    (const_div_tendsto_zero_atTop (1 : тДЭ))
  ┬╖ -- 0 тЙд log X / X┬▓ eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : тДЭ)] with X hX
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:тДЭ) < 1) hX
    have hlog_nn : 0 тЙд Real.log X := Real.log_nonneg hX
    positivity
  ┬╖ -- log X / X┬▓ тЙд 1/X eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : тДЭ),
                    eventually_log_le_self] with X hX hlog
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:тДЭ) < 1) hX
    have hX_sq_pos : 0 < X^2 := by positivity
    rw [div_le_div_iffтВА hX_sq_pos hX_pos]
    -- log X * X тЙд X^2 * 1, i.e., X ┬╖ log X тЙд X┬▓
    have h_mul : X * Real.log X тЙд X * X :=
      mul_le_mul_of_nonneg_left hlog hX_pos.le
    nlinarith [h_mul]

/-- ЁЯМЯ **PROVED тАФ `P(X) тЖТ 0`** as `X тЖТ тИЮ`. The primitive splits as
two terms, each a constant times a vanishing piece (`log X / X┬▓` and
`1/X┬▓`). -/
lemma derivativeSideMajorantPrimitive_tendsto_zero
    (y C D : тДЭ) :
    Tendsto (fun X : тДЭ => derivativeSideMajorantPrimitive y C D X)
      Filter.atTop (ЁЭУЭ 0) := by
  unfold derivativeSideMajorantPrimitive
  -- -9y ┬╖ (C log X + D + C/2) / X┬▓ = (-9yC) ┬╖ log X/X┬▓ + (-9y(D+C/2)) ┬╖ 1/X┬▓
  have h_logterm : Tendsto (fun X : тДЭ => (-9 * y * C) * (Real.log X / X^2))
      Filter.atTop (ЁЭУЭ ((-9 * y * C) * 0)) :=
    log_div_sq_tendsto_zero.const_mul (-9 * y * C)
  have h_constterm : Tendsto (fun X : тДЭ => (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (ЁЭУЭ ((-9 * y * (D + C/2)) * 0)) :=
    one_div_sq_tendsto_zero.const_mul (-9 * y * (D + C/2))
  have h_sum : Tendsto (fun X : тДЭ =>
      (-9 * y * C) * (Real.log X / X^2) + (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (ЁЭУЭ ((-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  -- Rewrite our primitive to match the sum's form
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : тДЭ)] with X hX
  have hX_sq_ne : X^2 тЙа 0 := pow_ne_zero 2 (ne_of_gt hX)
  field_simp
  ring

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `DerivativeSideMajorantConverges`** for any `x`,
  `y`, `T > 0`, `C, D`. The limit is `тИТP(T)`. Combines FTC + primitive
  tending to 0. -/
theorem derivativeSideMajorantConverges
    (x y T C D : тДЭ) (hT : 0 < T) :
    DerivativeSideMajorantConverges x y T C D := by
  refine тЯи-derivativeSideMajorantPrimitive y C D T, ?_тЯй
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : тДЭ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (ЁЭУЭ (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : тДЭ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (ЁЭУЭ (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  -- Bridge to the integral form via FTC for X тЙе T
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

-- =====================================================================
-- ┬зCCIV. Absolute-convergence comparison scaffolding
-- =====================================================================
-- The missing analytic ingredient for `derivative_integral_tendsto`:
--   `|f| тЙд M eventually + тИл_T^X M тЖТ LM  тЯ╣  тИГ J, тИл_T^X f тЖТ J`.
-- Built in stages:
--   A. named partial/tail integrals (keeps the elaborator cheap);
--   B. tail identity `тИл_T^B тИТ тИл_T^A = тИл_A^B`;
--   C. tail smallness: `Tendsto M_partial atTop (ЁЭУЭ LM) тЗТ tails eventually small`;
--   D. finite comparison: `|тИл f| тЙд тИл M` (per-interval, given a pointwise bound).
-- The full comparison theorem (Cauchy criterion + completeness) is the
-- next analytic patch.

/-- **Named partial integral** at upper cutoff `X`. -/
noncomputable def intervalPartialIntegral
    (f : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДЭ :=
  тИл u in T..X, f u

/-- **Named tail integral** between `A` and `B`. -/
noncomputable def intervalTailIntegral
    (f : тДЭ тЖТ тДЭ) (A B : тДЭ) : тДЭ :=
  тИл u in A..B, f u

/-- тнР **PROVED тАФ tail identity for partial integrals.**
  `тИл_T^B f тИТ тИл_T^A f = тИл_A^B f`  for `T тЙд A тЙд B` with `f` integrable on `[T, B]`. -/
lemma intervalPartialIntegral_sub_eq_tail
    (f : тДЭ тЖТ тДЭ) (T A B : тДЭ)
    (hTA : T тЙд A) (hAB : A тЙд B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume T B) :
    intervalPartialIntegral f T B - intervalPartialIntegral f T A
      = intervalTailIntegral f A B := by
  unfold intervalPartialIntegral intervalTailIntegral
  have hTB : T тЙд B := le_trans hTA hAB
  have h_T_A : IntervalIntegrable f MeasureTheory.volume T A :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hTA, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_right hAB)
  have h_A_B : IntervalIntegrable f MeasureTheory.volume A B :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hAB, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_left hTA)
  have h_split : (тИл u in T..B, f u) = (тИл u in T..A, f u) + тИл u in A..B, f u :=
    (intervalIntegral.integral_add_adjacent_intervals h_T_A h_A_B).symm
  linarith

/-- ЁЯМЯ **PROVED тАФ tail smallness from partial-integral convergence.**
If `тИл_T^X M тЖТ LM` as `X тЖТ тИЮ`, then for any `╬╡ > 0` the tail integral
`тИл_A^B M` is `< ╬╡` for all sufficiently large `A тЙд B`. Pure
filter-algebra epsilon argument: pick `╬╡/2` neighborhoods of `LM`, use
the triangle inequality on the tail identity. -/
lemma tail_integral_small_of_partial_tendsto
    {M : тДЭ тЖТ тДЭ} {T LM : тДЭ}
    (hM_int_all : тИА X, IntervalIntegrable M MeasureTheory.volume T X)
    (hM : Tendsto (fun X => intervalPartialIntegral M T X)
            Filter.atTop (ЁЭУЭ LM)) :
    тИА ╬╡ > 0, тИАс╢а A in Filter.atTop, тИАс╢а B in Filter.atTop,
      A тЙд B тЖТ |intervalTailIntegral M A B| < ╬╡ := by
  intro ╬╡ h╬╡
  have h╬╡2 : 0 < ╬╡ / 2 := by linarith
  -- Tendsto in metric form: dist (partial X) LM < ╬╡/2 eventually
  have hA_close : тИАс╢а A in Filter.atTop,
      |intervalPartialIntegral M T A - LM| < ╬╡/2 := by
    have h := (Metric.tendsto_nhds.mp hM) (╬╡/2) h╬╡2
    filter_upwards [h] with A hdist
    rwa [Real.dist_eq] at hdist
  filter_upwards [hA_close, Filter.eventually_ge_atTop T] with A hAclose hTA
  filter_upwards [hA_close, Filter.eventually_ge_atTop A] with B hBclose hAB hABle
  -- Tail identity: тИл_A^B M = partial M T B тИТ partial M T A
  have h_tail_eq : intervalTailIntegral M A B
                 = intervalPartialIntegral M T B
                   - intervalPartialIntegral M T A := by
    have := intervalPartialIntegral_sub_eq_tail M T A B hTA hABle (hM_int_all B)
    linarith
  rw [h_tail_eq]
  -- Triangle inequality: |pB тИТ pA| тЙд |pB тИТ LM| + |pA тИТ LM| < ╬╡
  have h_tri : |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
            тЙд |intervalPartialIntegral M T B - LM|
              + |intervalPartialIntegral M T A - LM| := by
    calc |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
        = |(intervalPartialIntegral M T B - LM)
            + -(intervalPartialIntegral M T A - LM)| := by ring_nf
      _ тЙд |intervalPartialIntegral M T B - LM|
          + |-(intervalPartialIntegral M T A - LM)| := abs_add _ _
      _ = |intervalPartialIntegral M T B - LM|
          + |intervalPartialIntegral M T A - LM| := by rw [abs_neg]
  linarith

/-- ЁЯМЯ **PROVED тАФ finite-window absolute comparison**:
  `|тИл_A^B f| тЙд тИл_A^B M`  when `|f u| тЙд M u` on `[A, B]`, both integrable. -/
lemma intervalIntegral_abs_le_intervalIntegral_majorant
    {f M : тДЭ тЖТ тДЭ} {A B : тДЭ}
    (hAB : A тЙд B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume A B)
    (hM_int : IntervalIntegrable M MeasureTheory.volume A B)
    (hbound : тИА u тИИ Set.Icc A B, |f u| тЙд M u) :
    |тИл u in A..B, f u| тЙд тИл u in A..B, M u := by
  -- Step 1: |тИл f| тЙд тИл |f|
  have h_abs_int : IntervalIntegrable (fun u => |f u|) MeasureTheory.volume A B :=
    hf_int.abs
  have h1 : |тИл u in A..B, f u| тЙд тИл u in A..B, |f u| :=
    intervalIntegral.abs_integral_le_integral_abs hAB
  -- Step 2: тИл |f| тЙд тИл M via monotone
  have h2 : тИл u in A..B, |f u| тЙд тИл u in A..B, M u := by
    apply intervalIntegral.integral_mono_on hAB h_abs_int hM_int
    intro u hu
    exact hbound u hu
  linarith

-- =====================================================================
-- ┬зCCV. Comparison theorem: Cauchy + complete-space convergence
-- =====================================================================
-- The headline analytic theorem for derivative-side improper convergence:
--
--   `|f u| тЙд M u eventually  +  тИл_T^X M тЖТ LM
--      тЯ╣  тИГ J, тИл_T^X f тЖТ J`.
--
-- Strategy:
--   1. Show `(fun X => тИл_T^X f)` is Cauchy at `atTop` via the finite
--      comparison applied to tails (using the M partial integrals'
--      ╬╡/2 closeness to `LM`).
--   2. Conclude convergence via `CompleteSpace.complete` for `тДЭ`.

/-- ЁЯМЯЁЯМЯ **PROVED тАФ ABSOLUTE-CONVERGENCE COMPARISON THEOREM.**
For real-valued `f, M` with `f, M` interval-integrable on each `[T, X]`
for `X тЙе T`, `|f u| тЙд M u` eventually, and the M-partial integrals
converging:

  the f-partial integrals also converge.

The integrability hypothesis is restricted to `X тЙе T` because for many
natural majorants (e.g. `(C┬╖log u + D)┬╖18y/u┬│`) the integrand fails to
be integrable on `(0, T]` if `T < 0` etc. -/
theorem improperIntegralConverges_of_absMajorant
    {f M : тДЭ тЖТ тДЭ} {T LM : тДЭ}
    (hf_int : тИА X, T тЙд X тЖТ IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : тИА X, T тЙд X тЖТ IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => intervalPartialIntegral M T X)
                    Filter.atTop (ЁЭУЭ LM))
    (hbound : тИАс╢а u in Filter.atTop, |f u| тЙд M u) :
    ImproperIntervalIntegralConverges f T := by
  -- Step 1: show Cauchy of the f-partial integrals at `atTop`
  have h_cauchy : Cauchy
      (Filter.map (fun X => intervalPartialIntegral f T X) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine тЯиFilter.map_neBot, ?_тЯй
    intro ╬╡ h╬╡
    have h╬╡2 : 0 < ╬╡ / 2 := by linarith
    -- M partial close to LM eventually
    have h_M_close : тИАс╢а A in Filter.atTop,
        |intervalPartialIntegral M T A - LM| < ╬╡ / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (╬╡ / 2) h╬╡2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain тЯиN_M, hN_MтЯй := Filter.eventually_atTop.mp h_M_close
    obtain тЯиN0, hN0тЯй := Filter.eventually_atTop.mp hbound
    let N : тДЭ := max T (max N0 N_M)
    refine тЯи(fun X => intervalPartialIntegral f T X) '' {X | N тЙд X}, ?_, ?_тЯй
    ┬╖ exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    -- Orientation-safe distance argument via key lemma
    suffices key :
        тИА Y1 Y2 : тДЭ, N тЙд Y1 тЖТ N тЙд Y2 тЖТ Y1 тЙд Y2 тЖТ
          |intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1| < ╬╡ by
      rintro _ тЯиX1, hX1, rflтЯй _ тЯиX2, hX2, rflтЯй
      rw [Real.dist_eq]
      rcases le_total X1 X2 with hX12 | hX21
      ┬╖ rw [abs_sub_comm]; exact key X1 X2 hX1 hX2 hX12
      ┬╖ exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    -- Extract individual bounds from `N := max T (max N0 N_M)`
    have hT_Y1 : T тЙд Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T тЙд Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 тЙд Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M тЙд Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M тЙд Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    -- Tail identities for f and M
    have h_tail_f :
        intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1
          = intervalTailIntegral f Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail f T Y1 Y2 hT_Y1 hY12 (hf_int Y2 hT_Y2)
    have h_tail_M :
        intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1
          = intervalTailIntegral M Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail M T Y1 Y2 hT_Y1 hY12 (hM_int Y2 hT_Y2)
    rw [h_tail_f]
    -- Sub-interval integrability for the finite comparison
    have hsub_uIcc : Set.uIcc Y1 Y2 тКЖ Set.uIcc T Y2 := by
      rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
      exact Set.Icc_subset_Icc_left hT_Y1
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      (hf_int Y2 hT_Y2).mono_set hsub_uIcc
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      (hM_int Y2 hT_Y2).mono_set hsub_uIcc
    have hbound_Y1Y2 : тИА u тИИ Set.Icc Y1 Y2, |f u| тЙд M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    -- Finite comparison: |tail f| тЙд tail M
    have h_comp : |intervalTailIntegral f Y1 Y2| тЙд intervalTailIntegral M Y1 Y2 := by
      unfold intervalTailIntegral
      exact intervalIntegral_abs_le_intervalIntegral_majorant
        hY12 hf_int_Y1Y2 hM_int_Y1Y2 hbound_Y1Y2
    -- M partial-difference triangle: |partial M Y2 - partial M Y1| < ╬╡
    have h_M_partial_close : |intervalTailIntegral M Y1 Y2| < ╬╡ := by
      rw [тЖР h_tail_M]
      have h1 := hN_M Y1 hN_M_Y1
      have h2 := hN_M Y2 hN_M_Y2
      calc |intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1|
          тЙд |intervalPartialIntegral M T Y2 - LM|
            + |LM - intervalPartialIntegral M T Y1| := abs_sub_le _ _ _
        _ = |intervalPartialIntegral M T Y2 - LM|
            + |intervalPartialIntegral M T Y1 - LM| := by
              rw [abs_sub_comm LM]
        _ < ╬╡ / 2 + ╬╡ / 2 := add_lt_add h2 h1
        _ = ╬╡ := by ring
    -- tail M тЙе 0 (from |tail f| тЙд tail M and abs тЙе 0)
    have h_tail_M_nn : 0 тЙд intervalTailIntegral M Y1 Y2 :=
      le_trans (abs_nonneg _) h_comp
    have h_abs_tail_M : |intervalTailIntegral M Y1 Y2|
                      = intervalTailIntegral M Y1 Y2 :=
      abs_of_nonneg h_tail_M_nn
    rw [h_abs_tail_M] at h_M_partial_close
    exact lt_of_le_of_lt h_comp h_M_partial_close
  -- Step 2: Cauchy + complete-space тЯ╣ convergence
  obtain тЯиL, hLтЯй := CompleteSpace.complete h_cauchy
  exact тЯиL, hLтЯй

-- =====================================================================
-- ┬зCCVI. Derivative-side improper integral converges (wiring)
-- =====================================================================
-- Wires the generic comparison theorem `improperIntegralConverges_of_absMajorant`
-- to the derivative-side integrand `S(u) ┬╖ k'(u)`. The inputs are:
--   тАв `derivativeSideMajorantConverges`         (┬зCCIII)
--   тАв `derivativeSideMajorant_intervalIntegrable` (┬зCCIII)
--   тАв `derivative_integrand_abs_le_log_kernel_eventually` (┬зCCII)
-- The remaining open input is just integrability of `S ┬╖ k'` on each
-- finite window `[T, X]` (`X тЙе T`), which is a local regularity
-- condition on `S` тАФ for arbitrary `S` it must be supplied; for the
-- finite-fluctuation primitive it falls out of ┬зCXCVIII's machinery.

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ DERIVATIVE-SIDE IMPROPER CONVERGENCE under a log
envelope.** Given `0 < y`, `0 < T`, `0 тЙд C`, `0 тЙд D`, a log envelope
`|S u| тЙд C┬╖log u + D` eventually, and finite-window integrability of
`S ┬╖ k'` on each `[T, X]` (`T тЙд X`):

  `тИГ J, Tendsto (fun X => тИл_T^X S(u)┬╖k'(u) du) atTop (ЁЭУЭ J)`. -/
theorem derivative_integral_tendsto_of_log_envelope
    {S : тДЭ тЖТ тДЭ} {C D x y T : тДЭ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 тЙд C) (hD : 0 тЙд D)
    (hS : тИАс╢а u in Filter.atTop, |S u| тЙд C * Real.log u + D)
    (hf_int : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    тИГ J, Tendsto (fun X : тДЭ => derivativeSidePartial S x y T X)
      Filter.atTop (ЁЭУЭ J) := by
  -- Set up the majorant
  obtain тЯиLM, hLMтЯй := derivativeSideMajorantConverges x y T C D hT
  -- Integrability of the majorant on each `[T, X]` (`T тЙд X`)
  have hMint : тИА X, T тЙд X тЖТ
      IntervalIntegrable (derivativeSideMajorant y C D)
        MeasureTheory.volume T X :=
    fun X hTX => derivativeSideMajorant_intervalIntegrable y C D T X hT hTX
  -- Eventual pointwise bound
  have hbound : тИАс╢а u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        тЙд derivativeSideMajorant y C D u :=
    derivative_integrand_abs_le_log_kernel_eventually x y hy hC hD hS
  -- Apply the comparison theorem
  have hconv : ImproperIntervalIntegralConverges
      (fun u => S u * pairedCauchyImKernelDeriv x y u) T :=
    improperIntegralConverges_of_absMajorant
      (f := fun u => S u * pairedCauchyImKernelDeriv x y u)
      (M := derivativeSideMajorant y C D)
      (T := T) (LM := LM)
      hf_int hMint hLM hbound
  -- Bridge to derivativeSidePartial
  exact derivative_integral_tendsto_of_improperConverges
    (S := S) (x := x) (y := y) (T := T) hconv

-- =====================================================================
-- ┬зCCVII. partialF_tendsto + concrete partial convergence
-- =====================================================================
-- The third improper-limit obligation: `partialF X тЖТ L` as `X тЖТ тИЮ`.
-- Falls out of the finite IBP identity once the boundary term and
-- derivative-side partial integral both converge.

/-- ЁЯМЯ **PROVED тАФ generic partial-integral limit lemma** under the
**clean** finite IBP form (no `-k(T)┬╖S(T)` term, e.g. when `S(T) = 0`):

  `partialF X = k(X)┬╖S X тИТ derivativeSidePartial S x y T X` eventually,
  `k(X)┬╖S X тЖТ 0`,
  `derivativeSidePartial тЖТ J`
   тЯ╣ `partialF тЖТ тИТJ`. -/
lemma partialF_tendsto_of_clean_finiteIBP_and_limits
    {S partialF : тДЭ тЖТ тДЭ} {x y T J : тДЭ}
    (hfinite_eventually :
      тИАс╢а X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (ЁЭУЭ 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (ЁЭУЭ J)) :
    Tendsto partialF Filter.atTop (ЁЭУЭ (-J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
        Filter.atTop (ЁЭУЭ (0 - J)) := hboundary.sub hderiv
  have hzero : (0 - J : тДЭ) = -J := by ring
  rw [тЖР hzero]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - derivativeSidePartial S x y T X)
              =с╢а[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- ЁЯМЯ **PROVED тАФ generic partial-integral limit lemma** under the
**standard** finite IBP form (includes the `-k(T)┬╖S(T)` term):

  `partialF X = k(X)┬╖S X тИТ k(T)┬╖S T тИТ derivativeSidePartial X` eventually,
   тЯ╣ `partialF тЖТ тИТk(T)┬╖S T тИТ J`. -/
lemma partialF_tendsto_of_standard_finiteIBP_and_limits
    {S partialF : тДЭ тЖТ тДЭ} {x y T J : тДЭ}
    (hfinite_eventually :
      тИАс╢а X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (ЁЭУЭ 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (ЁЭУЭ J)) :
    Tendsto partialF Filter.atTop
      (ЁЭУЭ (-(pairedCauchyImKernel x y T * S T) - J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
        Filter.atTop
        (ЁЭУЭ (0 - pairedCauchyImKernel x y T * S T - J)) :=
    (hboundary.sub tendsto_const_nhds).sub hderiv
  have hconst :
      0 - pairedCauchyImKernel x y T * S T - J
        = -(pairedCauchyImKernel x y T * S T) - J := by ring
  rw [тЖР hconst]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - pairedCauchyImKernel x y T * S T
                          - derivativeSidePartial S x y T X)
              =с╢а[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- ЁЯМЯ **PROVED тАФ finite IBP identity holds eventually under
`OrderedTailWindowData`.** Combines `orderedWindow_eventually_atTop`
with `finiteFluctuationKernelPartial_true_ibp` and converts
`finiteFluctuationDerivativeIntegral` to `derivativeSidePartial`. -/
lemma finiteFluctuationKernelPartial_true_ibp_eventually
    (D : OrderedFluctuationMeasureData) (x y T : тДЭ) {m : тДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) :
    тИАс╢а X in Filter.atTop,
      finiteFluctuationKernelPartial D x y T X =
        pairedCauchyImKernel x y X
          * finiteFluctuationPrimitive D T X
          - derivativeSidePartial
              (fun U => finiteFluctuationPrimitive D T U) x y T X := by
  filter_upwards [orderedWindow_eventually_atTop D T Wtail,
                  Filter.eventually_ge_atTop T] with X W hTX
  have h := finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
  -- `finiteFluctuationDerivativeIntegral = derivativeSidePartial` for `S = ffP D T`.
  show finiteFluctuationKernelPartial D x y T X
        = pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
          - тИл u in T..X,
              finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u
  rw [h]
  rfl

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `finiteFluctuationKernelPartial` converges**
under a log envelope on `finiteFluctuationPrimitive D T` plus
finite-window integrability of `ffP ┬╖ k'`. The limit is `тИТJ` where
`J` is the limit of the derivative-side partial integral. -/
theorem finiteFluctuationKernelPartial_tendsto_of_logEnvelope
    (D : OrderedFluctuationMeasureData) (x y T C Dconst : тДЭ) {m : тДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 тЙд C) (hD : 0 тЙд Dconst)
    (hS : тИАс╢а X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| тЙд C * Real.log X + Dconst)
    (hInt : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    тИГ L, Tendsto (fun X => finiteFluctuationKernelPartial D x y T X)
      Filter.atTop (ЁЭУЭ L) := by
  obtain тЯиJ, hJтЯй :=
    derivative_integral_tendsto_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y) (T := T)
      hy hT hC hD hS hInt
  have hb :
      Tendsto (fun X => pairedCauchyImKernel x y X
                          * finiteFluctuationPrimitive D T X)
        Filter.atTop (ЁЭУЭ 0) :=
    boundary_atTop_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y)
      (le_of_lt hy) hC hD hS
  have hfinite :=
    finiteFluctuationKernelPartial_true_ibp_eventually D x y T Wtail hT hy
  exact тЯи-J, partialF_tendsto_of_clean_finiteIBP_and_limits
              hfinite hb hJтЯй

-- =====================================================================
-- ┬зCCVIII. EventualImproperKernelStieltjesIBP
-- =====================================================================
-- Eventual finite IBP variant of the ┬зCLXXXVIII improper record.
-- The existing `ImproperKernelStieltjesIBP` requires `FiniteKernelStieltjesIBP`
-- with the per-`X` IBP identity holding for ALL `X`. Our finite IBP only
-- holds for `X` large enough (eventually under `OrderedWindow`). This
-- eventual-form record is mathematically sufficient for the improper
-- limit, since `partial_tendsto` only uses the eventual identity.

/-- **Eventual improper kernel Stieltjes IBP package.** Same as
`ImproperKernelStieltjesIBP` (┬зCLXXXVIII) but accepts the finite IBP
identity as an `atTop`-eventual equality rather than `тИА X`. -/
structure EventualImproperKernelStieltjesIBP where
  S          : тДЭ тЖТ тДЭ
  partialF   : тДЭ тЖТ тДЭ
  x          : тДЭ
  y          : тДЭ
  T          : тДЭ
  L          : тДЭ
  finiteIBP_eventually :
    тИАс╢а X in Filter.atTop,
      partialF X =
        pairedCauchyImKernel x y X * S X
          - derivativeSidePartial S x y T X
  partial_tendsto :
    Tendsto partialF Filter.atTop (ЁЭУЭ L)
  boundary_atTop :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (ЁЭУЭ 0)
  derivative_integral_tendsto :
    тИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (ЁЭУЭ J)

/-- тнР **PROVED тАФ improper identity for the eventual record.**
The limit `L` equals `-J` where `J` is the limit of the derivative-side
partial integral. Uses `partialF_tendsto_of_clean_finiteIBP_and_limits`
to derive `Tendsto partialF (ЁЭУЭ (-J))`, then uniqueness pins `L = -J`. -/
theorem EventualImproperKernelStieltjesIBP.improper_identity
    (I : EventualImproperKernelStieltjesIBP) :
    тИГ J,
      Tendsto (fun X => derivativeSidePartial I.S I.x I.y I.T X)
        Filter.atTop (ЁЭУЭ J)
      тИз I.L = -J := by
  rcases I.derivative_integral_tendsto with тЯиJ, hJтЯй
  have hL' : Tendsto I.partialF Filter.atTop (ЁЭУЭ (-J)) :=
    partialF_tendsto_of_clean_finiteIBP_and_limits
      I.finiteIBP_eventually I.boundary_atTop hJ
  have huniq : I.L = -J := tendsto_nhds_unique I.partial_tendsto hL'
  exact тЯиJ, hJ, huniqтЯй

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ Eventual improper IBP from ordered-tail data
+ log envelope.** End-to-end constructor: given the window-invariant
zero-list data, `T > 0`, `y > 0`, a log envelope on the finite
fluctuation primitive, and finite-window integrability of `ffP ┬╖ k'`,
produces the eventual improper IBP record. -/
noncomputable def eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : тДЭ) {m : тДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 тЙд C) (hD : 0 тЙд Dconst)
    (hS : тИАс╢а X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| тЙд C * Real.log X + Dconst)
    (hInt : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    EventualImproperKernelStieltjesIBP :=
  -- We pre-extract the `L` witness via `Classical.choose`. `obtain` is
  -- unavailable in a structure-building term because `Exists.casesOn` is
  -- restricted to elimination into `Prop`.
  let hL_exists :=
    finiteFluctuationKernelPartial_tendsto_of_logEnvelope
      D x y T C Dconst Wtail hT hy hC hD hS hInt
  { S := fun U => finiteFluctuationPrimitive D T U
    partialF := fun X => finiteFluctuationKernelPartial D x y T X
    x := x
    y := y
    T := T
    L := hL_exists.choose
    finiteIBP_eventually :=
      finiteFluctuationKernelPartial_true_ibp_eventually
        D x y T Wtail hT hy
    partial_tendsto := hL_exists.choose_spec
    boundary_atTop :=
      boundary_atTop_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y)
        (le_of_lt hy) hC hD hS
    derivative_integral_tendsto :=
      derivative_integral_tendsto_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y) (T := T)
        hy hT hC hD hS hInt }

-- =====================================================================
-- ┬зCCIX. Bridge: EventualImproperKernelStieltjesIBP тЖТ ImaginaryStieltjesTailIBPBound
-- =====================================================================
-- Direct mirror of ┬зCXC `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`,
-- consuming the eventual improper IBP record. Mathematically identical
-- тАФ both versions only repack the data fields `S`, `T`, `x`, `y` plus
-- the user-supplied `B`, `integralBound`, `modelMargin`, `ibpMargin`.

/-- ЁЯМЯ **PROVED тАФ bridge from `EventualImproperKernelStieltjesIBP` to
`ImaginaryStieltjesTailIBPBound`** (┬з13 / ┬зCXC chain). Mirror of the
old `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`. -/
noncomputable def EventualImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : EventualImproperKernelStieltjesIBP)
    (B : тДЭ тЖТ тДЭ)
    (hS_bound : тИА u : тДЭ, I.T тЙд u тЖТ |I.S u| тЙд B u)
    (Jbound : тДЭ)
    (modelMargin : тДЭ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound тЙд modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

-- =====================================================================
-- ┬зCCX. Explicit `|J|` bound from the derivative-side majorant
-- =====================================================================
-- Pass the finite-window absolute comparison
--   `|тИл_T^X S┬╖k'| тЙд тИл_T^X M`
-- to the `X тЖТ тИЮ` limit using:
--   тАв `derivativeSidePartial тЖТ J`
--   тАв `тИл_T^X M тЖТ тИТP(T)`  (explicit Tendsto via the majorant primitive)
-- Combined via `le_of_tendsto_of_tendsto'`.

/-- ЁЯМЯ **PROVED тАФ explicit Tendsto for the majorant integral.**
The integral `тИл_T^X M(u) du` tends to `тИТP(T)` as `X тЖТ тИЮ`. Explicit
form (the existence-only `derivativeSideMajorantConverges` is the
тИГ-wrapped version of this). -/
theorem derivativeSideMajorant_integral_tendsto_atTop
    (_x y T C D : тДЭ) (hT : 0 < T) :
    Tendsto (fun X => тИл u in T..X, derivativeSideMajorant y C D u)
      Filter.atTop (ЁЭУЭ (-derivativeSideMajorantPrimitive y C D T)) := by
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : тДЭ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (ЁЭУЭ (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : тДЭ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (ЁЭУЭ (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

/-- ЁЯМЯ **PROVED тАФ finite-window absolute bound** for the derivative-side
partial integral. Requires:
* `T` already inside the adaptive regime (`2(1+|x|+y) тЙд T`);
* log envelope on `S` on `[T, тИЮ)`. -/
lemma derivativeSidePartial_abs_le_majorant_partial
    {S : тДЭ тЖТ тДЭ} (C D x y T X : тДЭ)
    (hy : 0 < y) (hT : 0 < T) (_hC : 0 тЙд C) (_hD : 0 тЙд D)
    (hreg : 2 * (1 + |x| + y) тЙд T)
    (hS_T : тИА u, T тЙд u тЖТ |S u| тЙд C * Real.log u + D)
    (hInt : IntervalIntegrable
      (fun u => S u * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X)
    (hTX : T тЙд X) :
    |derivativeSidePartial S x y T X|
      тЙд тИл u in T..X, derivativeSideMajorant y C D u := by
  unfold derivativeSidePartial
  apply intervalIntegral_abs_le_intervalIntegral_majorant hTX hInt
    (derivativeSideMajorant_intervalIntegrable y C D T X hT hTX)
  intro u hu
  unfold derivativeSideMajorant
  rw [abs_mul]
  have hSu : |S u| тЙд C * Real.log u + D := hS_T u hu.1
  have hreg_u : 2 * (1 + |x| + y) тЙд u := le_trans hreg hu.1
  have hk : |pairedCauchyImKernelDeriv x y u| тЙд 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le hreg_u le_rfl
  have henv_nn : 0 тЙд C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hk (abs_nonneg _) henv_nn

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ EXPLICIT `|J|` BOUND from the majorant primitive.**

Under `T` in the adaptive regime + log envelope on `S` from `T` onward
+ derivative-side integral convergence, the limit `J` satisfies

  `|J| тЙд тИТderivativeSideMajorantPrimitive y C D T`.

This is the explicit closed-form bound needed by the ┬з13 / ┬зCXC
slab-chain (which currently consumes `closedFormSErrorBoundCD`-style
quantities). Combines the finite-window absolute comparison with
`le_of_tendsto_of_tendsto'` at the `X тЖТ тИЮ` limit. -/
theorem derivative_integral_limit_abs_le_majorant_tail
    {S : тДЭ тЖТ тДЭ} {C D x y T J : тДЭ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 тЙд C) (hD : 0 тЙд D)
    (hreg : 2 * (1 + |x| + y) тЙд T)
    (hS_T : тИА u, T тЙд u тЖТ |S u| тЙд C * Real.log u + D)
    (hInt : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hJ : Tendsto (fun X => derivativeSidePartial S x y T X)
            Filter.atTop (ЁЭУЭ J)) :
    |J| тЙд -derivativeSideMajorantPrimitive y C D T := by
  -- absolute limit
  have h_abs_J : Tendsto
      (fun X => |derivativeSidePartial S x y T X|) Filter.atTop (ЁЭУЭ |J|) :=
    hJ.abs
  -- explicit majorant limit
  have h_M_lim : Tendsto
      (fun X => тИл u in T..X, derivativeSideMajorant y C D u) Filter.atTop
      (ЁЭУЭ (-derivativeSideMajorantPrimitive y C D T)) :=
    derivativeSideMajorant_integral_tendsto_atTop x y T C D hT
  -- eventually pointwise bound
  have h_eventually : тИАс╢а X in Filter.atTop,
      |derivativeSidePartial S x y T X|
        тЙд тИл u in T..X, derivativeSideMajorant y C D u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact derivativeSidePartial_abs_le_majorant_partial
      C D x y T X hy hT hC hD hreg hS_T (hInt X hTX) hTX
  -- combine via le_of_tendsto_of_tendsto (тИАс╢а form, no prime)
  exact le_of_tendsto_of_tendsto h_abs_J h_M_lim h_eventually

-- =====================================================================
-- ┬зCCXI. Real tail adapter (parallel to ┬зCLXXXV dummy; no deletion)
-- =====================================================================
-- Combines the ┬зCCVIII eventual improper IBP record with the ┬зCCX
-- explicit `|J|` bound and the ┬зCCIX tail-bound bridge into a single
-- theorem producing an `ImaginaryStieltjesTailIBPBound` directly from
-- ordered-tail data + log envelope + regularity. This is the
-- *real* tail-model adapter; it sits parallel to ┬зCLXXXV's dummy path
-- (`linearDensityTail100`) without replacing it yet.

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ REAL TAIL MODEL ADAPTER**:
end-to-end constructor producing an `ImaginaryStieltjesTailIBPBound`
from local ordered-tail / log-envelope / adaptive-regime data.

Hypotheses:
* `OrderedTailWindowData D T m` тАФ window-invariant zero data;
* `0 < T`, `0 < y`, `0 тЙд C`, `0 тЙд Dconst`;
* `2 (1 + |x| + y) тЙд T` тАФ adaptive-regime threshold;
* `hS_T` тАФ log envelope `|ffP D T u| тЙд C┬╖log u + Dconst` on `[T, тИЮ)`;
* `hInt` тАФ finite-window integrability of `ffP ┬╖ k'` on `[T, X]`;
* `hBbound` тАФ chosen `B : тДЭ тЖТ тДЭ` dominating `|ffP|` on `[T, тИЮ)`;
* `hmargin` тАФ the IBP-margin inequality
   `|k(T)|┬╖B(T) + (тИТP(T)) тЙд modelMargin`
  (the user-controlled "model margin" obligation).

Output: an `ImaginaryStieltjesTailIBPBound` with
`integralBound := тИТderivativeSideMajorantPrimitive y C Dconst T`. -/
noncomputable def imaginaryTailIBPBound_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : тДЭ) (B : тДЭ тЖТ тДЭ)
    (modelMargin : тДЭ) {m : тДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 тЙд C) (hD : 0 тЙд Dconst)
    (_hregime : 2 * (1 + |x| + y) тЙд T)
    (hS_T : тИА u, T тЙд u тЖТ
      |finiteFluctuationPrimitive D T u| тЙд C * Real.log u + Dconst)
    (hInt : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hBbound : тИА u, T тЙд u тЖТ |finiteFluctuationPrimitive D T u| тЙд B u)
    (hmargin :
      |pairedCauchyImKernel x y T| * B T
        + (-derivativeSideMajorantPrimitive y C Dconst T) тЙд modelMargin) :
    ImaginaryStieltjesTailIBPBound :=
  -- Derive the eventually form from the strong form
  let hS : тИАс╢а X in Filter.atTop,
      |finiteFluctuationPrimitive D T X| тЙд C * Real.log X + Dconst := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact hS_T X hTX
  -- Build the eventual improper IBP record
  let I := eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    D x y T C Dconst Wtail hT hy hC hD hS hInt
  -- Apply the ┬зCCIX bridge with Jbound := -P(T)
  I.toImaginaryTailIBPBound B hBbound
    (-derivativeSideMajorantPrimitive y C Dconst T)
    modelMargin hmargin

/-- тнР **PROVED тАФ the `|J|` bound the adapter relies on.**
The `derivative_integral_limit_abs_le_majorant_tail` theorem applied
to the finite-fluctuation primitive: under the adapter's hypotheses,

  `|J| тЙд тИТderivativeSideMajorantPrimitive y C Dconst T`

where `J` is the derivative-side improper integral's limit.

This is the *honesty witness* that `integralBound := тИТP(T)` in the
adapter above is a valid bound on the actual `J`. (The adapter itself
doesn't enforce this тАФ it just packages the data тАФ but having this
theorem ensures the user-supplied `hmargin` is a real margin.) -/
theorem imaginaryTailIBPBound_jBound_is_valid
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : тДЭ)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 тЙд C) (hD : 0 тЙд Dconst)
    (hregime : 2 * (1 + |x| + y) тЙд T)
    (hS_T : тИА u, T тЙд u тЖТ
      |finiteFluctuationPrimitive D T u| тЙд C * Real.log u + Dconst)
    (hInt : тИА X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    {J : тДЭ}
    (hJ : Tendsto (fun X => derivativeSidePartial
                              (fun u => finiteFluctuationPrimitive D T u)
                              x y T X)
            Filter.atTop (ЁЭУЭ J)) :
    |J| тЙд -derivativeSideMajorantPrimitive y C Dconst T :=
  derivative_integral_limit_abs_le_majorant_tail
    (S := fun u => finiteFluctuationPrimitive D T u)
    (C := C) (D := Dconst) (x := x) (y := y) (T := T)
    hy hT hC hD hregime hS_T hInt hJ

end Phase1IBP

-- =====================================================================
-- ┬зCCXII. Real-tail bridge to the dummy chain (no deletion)
-- =====================================================================
-- Bridges the real IBP majorant bound `-P(T)` to the existing
-- `closedFormErrorControlledOnFiniteBand` predicate that the ┬зCLXXXV
-- dummy chain consumes. Key algebraic fact:
--   `-P(T) тЙд closedFormSErrorBoundCD C D y T`   when `0 тЙд C, D, y`, `T тЙе 1`.
-- Both `-P` and `closedFormSErrorBoundCD` scale as `y/T┬▓` with similar
-- `(log T)` and constant coefficients; the `closedForm` coefficients are
-- uniformly larger (`17C` vs `9C`, `17D` vs `9D`, same `9C/2`). Difference
-- equals `8y(C┬╖log T + D)/T┬▓ тЙе 0`.

/-- ЁЯМЯ **PROVED тАФ KEY ALGEBRAIC BOUND**:
  `-derivativeSideMajorantPrimitive y C D T  тЙд  closedFormSErrorBoundCD C D y T`
when `0 тЙд C, D, y` and `T тЙе 1`. The difference is `8y(C┬╖log T + D)/T┬▓`. -/
lemma neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
    (C D y T : тДЭ) (hC : 0 тЙд C) (hD : 0 тЙд D) (hT_ge_1 : 1 тЙд T) (hy : 0 тЙд y) :
    -Phase1IBP.derivativeSideMajorantPrimitive y C D T
      тЙд closedFormSErrorBoundCD C D y T := by
  have hT_pos : 0 < T := lt_of_lt_of_le zero_lt_one hT_ge_1
  have hT2_pos : 0 < T^2 := by positivity
  have hT2_ne : T^2 тЙа 0 := ne_of_gt hT2_pos
  have hlog_T : 0 тЙд Real.log T := Real.log_nonneg hT_ge_1
  have h_diff :
      closedFormSErrorBoundCD C D y T
        - (-Phase1IBP.derivativeSideMajorantPrimitive y C D T)
        = 8 * y * (C * Real.log T + D) / T^2 := by
    unfold Phase1IBP.derivativeSideMajorantPrimitive closedFormSErrorBoundCD
    field_simp
    ring
  have h_diff_nn : 0 тЙд 8 * y * (C * Real.log T + D) / T^2 := by
    apply div_nonneg _ hT2_pos.le
    have h1 : 0 тЙд C * Real.log T := mul_nonneg hC hlog_T
    have h2 : 0 тЙд C * Real.log T + D := by linarith
    have h3 : 0 тЙд 8 * y := by linarith
    exact mul_nonneg h3 h2
  linarith

/-- ЁЯМЯЁЯМЯ **PROVED тАФ discharge `closedFormErrorControlledOnFiniteBand`
from a pointwise majorant-primitive bound on `Im(error z)`.**

Given `|Im(error z)| тЙд -P(z.im, (slabCD T).1, (slabCD T).2, T)` on the
`[10, 140]` adaptive region, the
`closedFormErrorControlledOnFiniteBand` predicate holds. Bridges real
IBP bounds into the existing dummy-chain infrastructure. -/
theorem closedFormErrorControlled_of_majorantPrimitive_bound
    (error : тДВ тЖТ тДВ)
    (hbound : тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
              2 * (1 + |z.re| + z.im) тЙд T тЖТ
              |(error z).im| тЙд
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    closedFormErrorControlledOnFiniteBand error := by
  intro z T hT10 hT140 hy hreg
  have h_input := hbound hT10 hT140 hy hreg
  have hC_nn : 0 тЙд (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD_nn : 0 тЙд (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hT_ge_1 : 1 тЙд T := by linarith
  have hy_nn : 0 тЙд z.im := le_of_lt hy
  have h_alg :
      -Phase1IBP.derivativeSideMajorantPrimitive z.im
          (slabCD T).1 (slabCD T).2 T
        тЙд closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T :=
    neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
      (slabCD T).1 (slabCD T).2 z.im T hC_nn hD_nn hT_ge_1 hy_nn
  linarith

/-- ЁЯМЯЁЯМЯ **PROVED тАФ DUMMY-SPECIALIZED real-tail wrapper.**
Specializes the ┬зCCXIII model-parametric
`localXiPackage_10_140_from_majorantBound` (below) to
`xiCloudDensityModel_zeros100ceil`. Preserved for backward
compatibility with the existing dummy chain тАФ prefer the
model-parametric version for new code. -/
noncomputable def localXiPackage_10_140_from_majorantBound_zeros100ceil
    (error : тДВ тЖТ тДВ)
    (hdecomp : тИА z : тДВ,
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (hbound : тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
              2 * (1 + |z.re| + z.im) тЙд T тЖТ
              |(error z).im| тЙд
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_10_140_zeros100ceil error hdecomp
    (closedFormErrorControlled_of_majorantPrimitive_bound error hbound)

-- =====================================================================
-- ┬зCCXIII. Model-parametric local package + ActualDensityTailData
-- =====================================================================
-- The previous ┬зCCXII `localXiPackage_10_140_from_majorantBound`
-- (now `..._zeros100ceil`) hardcoded the dummy
-- `xiCloudDensityModel_zeros100ceil`. This section breaks that
-- coupling at the local-package layer:
--   тАв New `localXiPackage_10_140_from_majorantBound` is model-parametric:
--     it takes any `M : CloudDensityTailModelDecomposition`
--     (with `M.zeros = zeros100ceil` and `AntiHerglotzUHP M.model`).
--   тАв Routes through the already-model-parametric
--     `localPackage_10_140_of_slabCD` (┬зCLXXXV, ~line 14159) тАФ the
--     existing infrastructure was already parametric; the ┬зCCXII
--     wrapper merely specialized it to the dummy.
--   тАв `ActualDensityTailData` provides the insertion point for the
--     forthcoming real complex-valued density tail
--     `тИл pairedCauchyKernel u z ┬╖ ╧Б(u) du`. The complex integral
--     itself is a separate task тАФ this structure just provides
--     the seat.
--
-- The dummy chain remains intact (no deletion). Any future real-tail
-- model `M_real` with the same finite-band predicate gives a package
-- without re-doing the IBP work.

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ MODEL-PARAMETRIC `LocalXiCloudDensityErrorPackage`
from a real majorant-primitive bound.**

Takes any `M : CloudDensityTailModelDecomposition` (with the standard
zeros-list compatibility + anti-Herglotz model), an IBP residual
`error`, the log-derivative decomposition `XiPullback = M.model + error`
on the `[10, 140]` adaptive region, and the majorant-primitive bound on
`|Im(error z)|`. Produces a `LocalXiCloudDensityErrorPackage`.

The dummy `xiCloudDensityModel_zeros100ceil` is no longer baked in;
any model satisfying the structural fields works. Routes through
`closedFormErrorControlled_of_majorantPrimitive_bound` + the existing
model-parametric `localPackage_10_140_of_slabCD`. -/
noncomputable def localXiPackage_10_140_from_majorantBound
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : тДВ тЖТ тДВ)
    (hdecomp : тИА z : тДВ,
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hbound : тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
              2 * (1 + |z.re| + z.im) тЙд T тЖТ
              |(error z).im| тЙд
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_10_140_of_slabCD M hM_zeros hmodelAnti error hdecomp
    (closedFormErrorControlled_of_majorantPrimitive_bound error hbound)

/-- ЁЯУж **`ActualDensityTailData`** тАФ future insertion point for the real
complex-valued density tail.

Packages everything `localXiPackage_10_140_from_majorantBound` needs:
the model `M` (with `zeros100ceil` + anti-Herglotz model), the IBP
residual `error`, the log-derivative decomposition, and the
majorant-primitive `|Im(error z)|` bound.

**Status:** abstract field-style structure. The real complex tail
integral
  `densityTail(z) = тИл u in T..тИЮ, pairedCauchyKernel u z dS(u)`
is *not* constructed here тАФ that requires complex-valued improper
integrals, real/imag-extraction commuting with limits, and the
complex kernel тЖФ `pairedCauchyImKernel` identity (separate task).
Once that lands, an inhabitant of this structure provides the
real-tail-instantiated `LocalXiCloudDensityErrorPackage` via
`localXiPackage_of_actualTailData` below. -/
structure ActualDensityTailData where
  /-- The density-tail model (eventually the real complex tail
  integral; for now any compatible `CloudDensityTailModelDecomposition`,
  including the dummy). -/
  M            : CloudDensityTailModelDecomposition
  /-- Compatibility with the `zeros100ceil` finite-band setup. -/
  hM_zeros     : M.zeros = zeros100ceil
  /-- Anti-Herglotz model (upper-half-plane sign law). -/
  hmodelAnti   : AntiHerglotzUHP M.model
  /-- IBP residual error: `XiPullback = M.model + error` on `[10,140]`. -/
  error        : тДВ тЖТ тДВ
  /-- The log-derivative decomposition on the adaptive `[10,140]` region. -/
  hdecomp      :
    тИА z : тДВ,
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      logDerivativeResponse XiPullback z = M.model z + error z
  /-- Majorant-primitive control on `|Im(error z)|`. -/
  hbound       :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      |(error z).im| тЙд
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T

/-- ЁЯМЯ **PROVED тАФ `LocalXiCloudDensityErrorPackage` from
`ActualDensityTailData`.** Convenience constructor: unpacks the
five fields and applies the ┬зCCXIII model-parametric local-package
theorem. -/
noncomputable def localXiPackage_of_actualTailData
    (A : ActualDensityTailData) : LocalXiCloudDensityErrorPackage :=
  localXiPackage_10_140_from_majorantBound
    A.M A.hM_zeros A.hmodelAnti A.error A.hdecomp A.hbound

/-- тнР **PROVED тАФ `ActualDensityTailData` is inhabited by the dummy
model.** Until the real complex tail integral lands, the existing
`xiCloudDensityModel_zeros100ceil` can be wrapped as an
`ActualDensityTailData` given the same `(error, hdecomp, hbound)`
data the ┬зCCXII path used. Documents that the structure is honest:
it doesn't *require* the real integral, just provides a seat for it. -/
noncomputable def actualDensityTailData_zeros100ceil
    (error : тДВ тЖТ тДВ)
    (hdecomp : тИА z : тДВ,
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (hbound : тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
              2 * (1 + |z.re| + z.im) тЙд T тЖТ
              |(error z).im| тЙд
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    ActualDensityTailData where
  M           := xiCloudDensityModel_zeros100ceil
  hM_zeros    := xiCloudDensityModel_zeros100ceil_zeros
  hmodelAnti  := xiCloudDensityModel_zeros100ceil_modelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound

-- =====================================================================
-- ┬зCCXIV. Complex tail decomposition scaffold
-- =====================================================================
-- Mirrors the real `derivativeSidePartial` strategy from ┬зCCII: define
-- finite-X partial integrals for a complex-valued density-tail kernel,
-- a convergence package, and the real/imag bridge. Does NOT prove the
-- actual paired-Cauchy convergence тАФ that's the next step. The point
-- here is to lay down the abstract interface so the eventual real-tail
-- construction has a clear target:
--
--   complexDensityTailPartial               тАФ finite [T,X] complex integral
--   ComplexDensityTailImproperConverges     тАФ convergence package
--   complexTail_im_tendsto_of_partial_im    тАФ generic тДВ тЖТ тДЭ bridge
--   complexDensityTailPartial_im_tendsto    тАФ specialization
--   ActualDensityTailData.ofComplexConvergence тАФ bundling adapter
--
-- The convergence package does NOT automatically discharge `hdecomp`
-- or `hbound` (those depend on what the kernel / S actually are);
-- the constructor just provides a structured entry point ready for
-- the eventual paired-Cauchy kernel instantiation.

/-- **Complex-tail finite partial integral.** Complex analogue of the
real `Phase1IBP.derivativeSidePartial` from ┬зCCII: a finite-window
`[T, X]` integral of a complex-valued kernel multiplied by a
real-valued density primitive `S`, evaluated at the complex point
`z`. Returns `тДВ`. -/
noncomputable def complexDensityTailPartial
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ) (T X : тДЭ) (z : тДВ) : тДВ :=
  тИл u in T..X, kernel u z * (S u : тДВ)

/-- **Convergence package for the complex tail integral.** Bundles a
candidate complex-valued `tail` together with pointwise convergence
of the finite partials at every `z`. Analogous to the real
`ImproperIntervalIntegralConverges` from ┬зCCII. -/
structure ComplexDensityTailImproperConverges
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ) (T : тДЭ) where
  /-- The candidate tail value at each `z`. -/
  tail     : тДВ тЖТ тДВ
  /-- The finite partials converge to `tail z` as `X тЖТ тИЮ`. -/
  tendsto  : тИА z : тДВ,
    Tendsto
      (fun X : тДЭ => complexDensityTailPartial kernel S T X z)
      Filter.atTop (ЁЭУЭ (tail z))

/-- ЁЯМЯ **PROVED тАФ generic real/imag bridge for `тДВ`-valued `Tendsto`.**
If `F X тЖТ L` in `тДВ`, then `(F X).im тЖТ L.im` in `тДЭ`. This is the
first genuinely necessary bridge from complex tail to the real IBP
machinery тАФ `Complex.im` is continuous, hence commutes with limits. -/
lemma complexTail_im_tendsto_of_partial_im
    {F : тДЭ тЖТ тДВ} {L : тДВ}
    (h : Tendsto F Filter.atTop (ЁЭУЭ L)) :
    Tendsto (fun X => (F X).im) Filter.atTop (ЁЭУЭ L.im) :=
  (Complex.continuous_im.tendsto L).comp h

/-- ЁЯМЯ **PROVED тАФ specialization to the complex tail partial.** The
imaginary parts of the complex tail partials converge to the
imaginary part of the candidate tail at each `z`. This is what
ultimately feeds the IBP-derived `|Im error| тЙд -P(T)` bound: the
RHS of the bound lives on the real side, so the LHS (which comes
from the complex integral) must first be projected via `.im`. -/
lemma complexDensityTailPartial_im_tendsto
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ} {T : тДЭ}
    (conv : ComplexDensityTailImproperConverges kernel S T) (z : тДВ) :
    Tendsto
      (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (ЁЭУЭ (conv.tail z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto z)

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `ActualDensityTailData` from a complex-tail
convergence package.**

Given a `ComplexDensityTailImproperConverges` providing the candidate
`tail`, a `CloudDensityTailModelDecomposition M` (with the standard
`zeros100ceil` + anti-Herglotz structural fields), and the IBP error
data (`error`, `hdecomp`, `hbound`), produces an `ActualDensityTailData`.

This is the second "seat" тАФ closer to the real target than
`actualDensityTailData_zeros100ceil`, because it explicitly carries
the complex-tail convergence witness. The convergence package does
not yet discharge `hdecomp` or `hbound` тАФ those remain user-supplied
until the IBP chain is wired to the specific paired-Cauchy kernel
(separate task). -/
noncomputable def ActualDensityTailData.ofComplexConvergence
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ} {T0 : тДЭ}
    (_conv : ComplexDensityTailImproperConverges kernel S T0)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : тДВ тЖТ тДВ)
    (hdecomp : тИА z : тДВ,
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hbound : тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
              2 * (1 + |z.re| + z.im) тЙд T тЖТ
              |(error z).im| тЙд
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound

-- =====================================================================
-- ┬зCCXV. T-family complex tail bridge: Im(complex tail) тЖФ real IBP
-- =====================================================================
-- ┬зCCXIV's `ActualDensityTailData.ofComplexConvergence` kept the
-- convergence witness inert (`_conv`). This section turns it into a
-- machine that actually produces the `hbound` field once a real-kernel
-- identity is supplied:
--
--   upperHalfPoint, upperHalfPoint_re_im        тАФ z = x + I┬╖y helper
--   ComplexDensityTailFamilyConverges           тАФ T-family convergence
--   complexDensityTailFamilyPartial_im_tendsto  тАФ Im commutes with limit
--   ComplexTailImaginaryPartMatchesRealIBP      тАФ eventual Im identity
--   complexTail_im_bound_from_realIBP           тАФ pointwise bound theorem
--   ComplexTailIBPBoundData                     тАФ z-indexed wrapper
--   hbound_of_complexTailIBPBoundData           тАФ produces hbound field
--
-- Design note: ┬зCCXIV's `ComplexDensityTailImproperConverges` fixed
-- one cutoff `T`. The `hbound` field quantifies over the adaptive
-- slab parameter `T`, so we add a T-family version alongside the
-- fixed-T one (which is preserved as the simpler special case).
-- The IBP bound here is delivered modulo the kernel-specific
-- imaginary-part identity, which still needs to be proven once the
-- specific `pairedCauchyKernel` is wired in (separate task).

/-- **`upperHalfPoint x y`** тАФ convenience for the complex number
`x + I┬╖y`, used as a uniform encoding so that the bridge theorems can
quantify cleanly over real coordinates `(x, y)` while landing in `тДВ`. -/
noncomputable def upperHalfPoint (x y : тДЭ) : тДВ :=
  (x : тДВ) + Complex.I * (y : тДВ)

/-- тнР **PROVED тАФ `upperHalfPoint` recovers any complex number from
its components.** Lets the bridge theorems written in `(x, y)`-form
specialize directly to a complex `z` via `z.re, z.im`. -/
lemma upperHalfPoint_re_im (z : тДВ) : upperHalfPoint z.re z.im = z := by
  unfold upperHalfPoint
  apply Complex.ext <;> simp

/-- **T-family convergence package for the complex tail integral.**
Generalizes ┬зCCXIV's `ComplexDensityTailImproperConverges` from one
fixed lower cutoff `T` to a family indexed by `T : тДЭ`. Required for
the adaptive `[10, 140]` band where `T` varies with `z`. -/
structure ComplexDensityTailFamilyConverges
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ) where
  /-- The candidate tail value at cutoff `T` and point `z`. -/
  tail     : тДЭ тЖТ тДВ тЖТ тДВ
  /-- The finite partials over `[T, X]` converge to `tail T z` as `X тЖТ тИЮ`,
  for every cutoff `T` and every point `z`. -/
  tendsto  : тИА T : тДЭ, тИА z : тДВ,
    Tendsto
      (fun X : тДЭ => complexDensityTailPartial kernel S T X z)
      Filter.atTop (ЁЭУЭ (tail T z))

/-- ЁЯМЯ **PROVED тАФ T-family specialization of `complexTail_im_tendsto`.**
For each `T` and `z`, the imaginary parts of the complex tail partials
converge to `(conv.tail T z).im`. -/
lemma complexDensityTailFamilyPartial_im_tendsto
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ}
    (conv : ComplexDensityTailFamilyConverges kernel S) (T : тДЭ) (z : тДВ) :
    Tendsto
      (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (ЁЭУЭ (conv.tail T z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto T z)

/-- **`ComplexTailImaginaryPartMatchesRealIBP`** тАФ eventual identity
between the imaginary part of the complex tail partial and the real
derivative-side partial. This is the kernel-specific obligation: once
the actual `pairedCauchyKernel` is plugged in, this identity should
follow from `Complex.im (a * b) = ...` plus the real definition of
`derivativeSidePartial` (a separate task). -/
structure ComplexTailImaginaryPartMatchesRealIBP
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ) (x y T : тДЭ) : Prop where
  finite_im_eq :
    тИАс╢а X in Filter.atTop,
      (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im
        = Phase1IBP.derivativeSidePartial S x y T X

/-- ЁЯМЯЁЯМЯ **PROVED тАФ pointwise complex-tail Im bound from real IBP.**
Given a T-family complex convergence package, the kernel-specific
imaginary-part identity for finite partials, a convergence witness for
the real derivative-side partial, and the real `|J| тЙд -P(T)` bound from
the IBP machinery, concludes:

  `|(conv.tail T (upperHalfPoint x y)).im| тЙд -P(y, C, D, T)`.

Proof: `Im` commutes with limit; the finite identity transports the
real `Tendsto` to the complex Im `Tendsto`; uniqueness of limits
identifies the two limits; the real bound transfers. -/
theorem complexTail_im_bound_from_realIBP
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ}
    {x y T C D J : тДЭ}
    (conv : ComplexDensityTailFamilyConverges kernel S)
    (hmatch : ComplexTailImaginaryPartMatchesRealIBP kernel S x y T)
    (hJ :
      Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S x y T X)
        Filter.atTop (ЁЭУЭ J))
    (hJbound : |J| тЙд -Phase1IBP.derivativeSideMajorantPrimitive y C D T) :
    |(conv.tail T (upperHalfPoint x y)).im|
      тЙд -Phase1IBP.derivativeSideMajorantPrimitive y C D T := by
  -- Im of complex partial tends to Im of tail
  have him_tail :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im)
        Filter.atTop
        (ЁЭУЭ (conv.tail T (upperHalfPoint x y)).im) :=
    complexDensityTailFamilyPartial_im_tendsto conv T (upperHalfPoint x y)
  -- Transport real Tendsto to complex Im via finite identity
  have him_real :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im)
        Filter.atTop (ЁЭУЭ J) := by
    apply Tendsto.congr' _ hJ
    filter_upwards [hmatch.finite_im_eq] with X heq
    exact heq.symm
  -- Limits agree тЖТ tail.im = J
  have huniq : (conv.tail T (upperHalfPoint x y)).im = J :=
    tendsto_nhds_unique him_tail him_real
  rw [huniq]
  exact hJbound

/-- **`ComplexTailIBPBoundData`** тАФ z-indexed wrapper supplying all
ingredients needed to produce the `hbound` field of `ActualDensityTailData`
from a T-family complex convergence package.

Fields:
* `error_im_eq_tail_im` тАФ in the adaptive band, the residual error's
  imaginary part equals the imaginary part of the tail at the
  corresponding adaptive `T` (kernel/error consistency obligation);
* `finite_im_match` тАФ for each `(z, T)` in the band, the eventual
  finite Im identity (kernel-specific obligation);
* `derivative_tendsto` тАФ for each `(z, T)` in the band, the real
  derivative-side partial converges (discharged by the ┬зCCVI/CCVII
  IBP machinery once instantiated);
* `derivative_bound` тАФ for each such limit, `|J| тЙд -P(...)`
  (discharged by ┬зCCIX/CCX).

All four fields are propositional; the structure itself is a `Prop`. -/
structure ComplexTailIBPBoundData
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ)
    (conv : ComplexDensityTailFamilyConverges kernel S)
    (error : тДВ тЖТ тДВ) : Prop where
  error_im_eq_tail_im :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      (error z).im = (conv.tail T z).im
  finite_im_match :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      ComplexTailImaginaryPartMatchesRealIBP kernel S z.re z.im T
  derivative_tendsto :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ J : тДЭ, Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (ЁЭУЭ J)
  derivative_bound :
    тИА {z : тДВ} {T : тДЭ} {J : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (ЁЭУЭ J) тЖТ
      |J| тЙд -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `hbound` field of `ActualDensityTailData` from a
`ComplexTailIBPBoundData`.** The end-to-end T-family bridge: a complex
convergence package, an Im-matching identity, real derivative-side
convergence, and the real IBP bound combine to produce the
`|(error z).im| тЙд -P(z.im, (slabCD T).1, (slabCD T).2, T)` predicate
that the local-package layer consumes. -/
theorem hbound_of_complexTailIBPBoundData
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ}
    {conv : ComplexDensityTailFamilyConverges kernel S}
    {error : тДВ тЖТ тДВ}
    (B : ComplexTailIBPBoundData kernel S conv error) :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      |(error z).im| тЙд
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain тЯиJ, hJтЯй := B.derivative_tendsto h10 h140 hy hregime
  have htail_bound :=
    complexTail_im_bound_from_realIBP
      (C := (slabCD T).1) (D := (slabCD T).2)
      conv
      (B.finite_im_match h10 h140 hy hregime)
      hJ
      (B.derivative_bound h10 h140 hy hregime hJ)
  -- Bridge: upperHalfPoint z.re z.im = z
  rw [upperHalfPoint_re_im z] at htail_bound
  rw [B.error_im_eq_tail_im h10 h140 hy hregime]
  exact htail_bound

-- =====================================================================
-- ┬зCCXVI. Paired complex kernel and finite-X Im identity
-- =====================================================================
-- Discharges the kernel-specific obligation
-- `ComplexTailImaginaryPartMatchesRealIBP` from ┬зCCXV for a concrete
-- complex kernel тАФ the "wrapper" kernel
--   `kernel u z := (pairedCauchyImKernelDeriv z.re z.im u : тДВ) * I`
-- whose imaginary part at `(upperHalfPoint x y)` is exactly the real
-- `pairedCauchyImKernelDeriv x y u`. Proves:
--
--   pairedCauchyComplexKernelDeriv               тАФ wrapper kernel
--   pairedCauchyComplexKernelDeriv_im            тАФ pointwise Im of kernel
--   pairedComplexKernelDeriv_integrand_im        тАФ pointwise Im of kernel ┬╖ S
--   complexDensityTailPartial_im_eq_derivativeSidePartial
--   complexTailImaginaryPartMatchesRealIBP_pairedDeriv
--
-- Design note: this is the "wrapper" kernel, not the true analytic
-- rational complex kernel. We prove the bridge through the interface
-- here; the next step (separate task) is to replace the wrapper with
-- the actual rational complex kernel and prove the corresponding
-- `_im` lemma тАФ the bridge above will then carry over unchanged.

/-- **Complex paired-Cauchy kernel derivative (wrapper).**
For now, the lift `realKernel x y u ┬╖ I`. Its imaginary part at
`upperHalfPoint x y` is exactly `pairedCauchyImKernelDeriv x y u`,
which is what the ┬зCCXV bridge requires. To be replaced by the true
rational complex kernel once that lands; the bridge theorems below
will keep working as long as the `_im` lemma still holds. -/
noncomputable def pairedCauchyComplexKernelDeriv (u : тДЭ) (z : тДВ) : тДВ :=
  (pairedCauchyImKernelDeriv z.re z.im u : тДВ) * Complex.I

/-- тнР **PROVED тАФ pointwise Im of the wrapper kernel at `upperHalfPoint`.** -/
lemma pairedCauchyComplexKernelDeriv_im (u x y : тДЭ) :
    (pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)).im
      = pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  simp

/-- тнР **PROVED тАФ pointwise Im of `kernel ┬╖ (S : тДВ)`.** The integrand
of the complex partial, evaluated pointwise тАФ its imaginary part is
the real integrand `S u ┬╖ pairedCauchyImKernelDeriv x y u`. -/
lemma pairedComplexKernelDeriv_integrand_im (S : тДЭ тЖТ тДЭ) (u x y : тДЭ) :
    (pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : тДВ)).im
      = S u * pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  simp [Complex.mul_im, Complex.mul_re]
  ring

/-- ЁЯМЯЁЯМЯ **PROVED тАФ finite-X Im identity for the complex partial.**
For the wrapper kernel, the imaginary part of the complex partial
integral equals the real `derivativeSidePartial`:

  `Im (тИл u in T..X, kernel u (UHP) ┬╖ (S u : тДВ))
      = тИл u in T..X, S u ┬╖ pairedCauchyImKernelDeriv x y u`.

Proof skeleton:
1. Pointwise: integrand = `((S u ┬╖ realKernel : тДЭ) : тДВ) ┬╖ I`.
2. Pull `I` out via `intervalIntegral.integral_mul_const`.
3. Pull `ofReal` out via `intervalIntegral.integral_ofReal`.
4. `(((r : тДЭ) : тДВ) ┬╖ I).im = r` closes by `simp`. -/
lemma complexDensityTailPartial_im_eq_derivativeSidePartial
    (S : тДЭ тЖТ тДЭ) (x y T X : тДЭ) :
    (complexDensityTailPartial
        pairedCauchyComplexKernelDeriv S T X (upperHalfPoint x y)).im
      = Phase1IBP.derivativeSidePartial S x y T X := by
  unfold complexDensityTailPartial Phase1IBP.derivativeSidePartial
  -- Step 1: pointwise simplification of integrand
  have hpoint : тИА u : тДЭ,
      pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : тДВ)
        = ((S u * pairedCauchyImKernelDeriv x y u : тДЭ) : тДВ)
          * Complex.I := by
    intro u
    unfold pairedCauchyComplexKernelDeriv
    have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
    have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
    rw [h1, h2]
    push_cast
    ring
  -- Step 2: rewrite the interval integral via pointwise equality
  have hint :
      (тИл u in T..X,
          pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : тДВ))
        = тИл u in T..X,
            ((S u * pairedCauchyImKernelDeriv x y u : тДЭ) : тДВ)
              * Complex.I :=
    intervalIntegral.integral_congr (fun u _ => hpoint u)
  rw [hint]
  -- Step 3: pull `I` out via `integral_mul_const`
  rw [intervalIntegral.integral_mul_const]
  -- Step 4: pull `ofReal` out via `integral_ofReal`
  rw [intervalIntegral.integral_ofReal]
  -- Step 5: `(((r : тДЭ) : тДВ) ┬╖ I).im = r`
  simp

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `ComplexTailImaginaryPartMatchesRealIBP` for the
wrapper paired-Cauchy kernel.** Discharges the ┬зCCXV abstract
obligation for this concrete kernel: the eventual finite-X Im identity
holds (in fact, it holds for *all* X, not just eventually). -/
theorem complexTailImaginaryPartMatchesRealIBP_pairedDeriv
    (S : тДЭ тЖТ тДЭ) (x y T : тДЭ) :
    ComplexTailImaginaryPartMatchesRealIBP
      pairedCauchyComplexKernelDeriv S x y T :=
  тЯиFilter.Eventually.of_forall fun X =>
    complexDensityTailPartial_im_eq_derivativeSidePartial S x y T XтЯй

-- =====================================================================
-- ┬зCCXVII. Wrapper-kernel adaptive complex convergence
-- =====================================================================
-- Builds the first concrete realization of the ┬зCCXV / ┬зCCXVI bridge:
-- given a packaged real-IBP family (real derivative-side convergence
-- + bound for every (z, T) in the adaptive band), produces an
-- adaptive-region complex convergence package for the wrapper kernel
-- of ┬зCCXVI. Adds:
--
--   RealIBPFamilyData                          тАФ Prop bundle of real IBP data
--   AdaptiveComplexDensityTailFamilyConverges  тАФ adaptive Type structure
--   pairedDerivAdaptiveTail                    тАФ wrapper tail (I ┬╖ J)
--   complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
--                                              тАФ full complex partial identity
--   adaptiveComplexConverges_pairedDeriv_of_realIBP
--
-- The wrapper kernel's complex integrand factors as `I ┬╖ (real : тДВ)`,
-- so the complex partial is `I ┬╖ (real partial : тДВ)`, so the limit at
-- тИЮ exists with value `I ┬╖ (J : тДВ)` whenever the real limit `J` exists.
-- ┬зCCXVIII will complete the wiring to `ComplexTailIBPBoundData`.

/-- **`RealIBPFamilyData S`** тАФ Prop bundle: for every `(z, T)` in the
adaptive band, the real derivative-side partial converges and the
limit satisfies the IBP majorant bound. Discharged by the ┬зCCVI/CCVII
+ ┬зCCIX/CCX machinery once instantiated for a specific `S`. -/
structure RealIBPFamilyData (S : тДЭ тЖТ тДЭ) : Prop where
  deriv_tendsto :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ J : тДЭ,
        Tendsto
          (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          Filter.atTop (ЁЭУЭ J)
  deriv_bound :
    тИА {z : тДВ} {T : тДЭ} {J : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (ЁЭУЭ J) тЖТ
      |J| тЙд -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- **Adaptive-region complex tail family convergence.** Like ┬зCCXV's
`ComplexDensityTailFamilyConverges` but only required to converge on
the adaptive `[10, 140]` band (matches the `hbound` quantifier shape).
The global version is preserved; this adds an adaptive variant. -/
structure AdaptiveComplexDensityTailFamilyConverges
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ) where
  tail     : тДЭ тЖТ тДВ тЖТ тДВ
  tendsto  :
    тИА {T : тДЭ} {z : тДВ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      Tendsto
        (fun X : тДЭ => complexDensityTailPartial kernel S T X z)
        Filter.atTop (ЁЭУЭ (tail T z))

/-- **Wrapper-kernel adaptive tail.** Inside the adaptive band, the
wrapper kernel's complex partial converges to `I ┬╖ (J : тДВ)` where `J`
is the real-side IBP limit. Outside the band, defined as `0` for
totality (irrelevant for the bridge). -/
noncomputable def pairedDerivAdaptiveTail
    (S : тДЭ тЖТ тДЭ) (R : RealIBPFamilyData S) (T : тДЭ) (z : тДВ) : тДВ :=
  if h : 10 тЙд T тИз T тЙд 140 тИз 0 < z.im тИз 2 * (1 + |z.re| + z.im) тЙд T then
    Complex.I *
      ((Classical.choose (R.deriv_tendsto h.1 h.2.1 h.2.2.1 h.2.2.2) : тДЭ) : тДВ)
  else
    0

/-- ЁЯМЯЁЯМЯ **PROVED тАФ full complex partial identity for the wrapper
kernel.** The complex partial equals `I ┬╖ (real partial : тДВ)` тАФ
strengthens ┬зCCXVI's `_im_eq_derivativeSidePartial` from imaginary
parts alone to the full complex value, which is what we need to
transfer convergence (not just convergence of Im). -/
lemma complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
    (S : тДЭ тЖТ тДЭ) (x y T X : тДЭ) :
    complexDensityTailPartial pairedCauchyComplexKernelDeriv
      S T X (upperHalfPoint x y)
      = Complex.I * ((Phase1IBP.derivativeSidePartial S x y T X : тДЭ) : тДВ) := by
  unfold complexDensityTailPartial Phase1IBP.derivativeSidePartial
  have hpoint : тИА u,
      pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : тДВ)
        = Complex.I * ((S u * pairedCauchyImKernelDeriv x y u : тДЭ) : тДВ) := by
    intro u
    unfold pairedCauchyComplexKernelDeriv
    have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
    have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
    rw [h1, h2]
    push_cast
    ring
  rw [intervalIntegral.integral_congr (fun u _ => hpoint u)]
  rw [intervalIntegral.integral_const_mul]
  congr 1
  exact intervalIntegral.integral_ofReal

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ wrapper kernel adaptive complex convergence
from real IBP family data.** End-to-end: the ┬зCCXVI wrapper kernel
combined with a real-IBP family witness produces an adaptive complex
convergence package. The tail is `pairedDerivAdaptiveTail`; the
convergence proof routes the real `Tendsto` through `ofReal` and
multiplication by `I`, then bridges to the complex partial via the
`pairedDeriv_eq_I_mul_derivativeSidePartial` identity. -/
noncomputable def adaptiveComplexConverges_pairedDeriv_of_realIBP
    (S : тДЭ тЖТ тДЭ) (R : RealIBPFamilyData S) :
    AdaptiveComplexDensityTailFamilyConverges
      pairedCauchyComplexKernelDeriv S where
  tail := pairedDerivAdaptiveTail S R
  tendsto := by
    intro T z h10 h140 hy hregime
    -- Witness J from the real IBP family
    have hExists := R.deriv_tendsto h10 h140 hy hregime
    set J := Classical.choose hExists with hJdef
    have hReal :
        Tendsto
          (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          Filter.atTop (ЁЭУЭ J) :=
      Classical.choose_spec hExists
    -- Lift real тЖТ complex via ofReal
    have hOfReal :
        Tendsto
          (fun X : тДЭ =>
            ((Phase1IBP.derivativeSidePartial S z.re z.im T X : тДЭ) : тДВ))
          Filter.atTop (ЁЭУЭ ((J : тДЭ) : тДВ)) :=
      (Complex.continuous_ofReal.tendsto J).comp hReal
    -- Multiply by I
    have hIComplex :
        Tendsto
          (fun X : тДЭ =>
            Complex.I *
              ((Phase1IBP.derivativeSidePartial S z.re z.im T X : тДЭ) : тДВ))
          Filter.atTop (ЁЭУЭ (Complex.I * ((J : тДЭ) : тДВ))) :=
      tendsto_const_nhds.mul hOfReal
    -- Bridge complex partial to I ┬╖ (real : тДВ) pointwise
    have hbridge : тИА X : тДЭ,
        complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X z
          = Complex.I *
              ((Phase1IBP.derivativeSidePartial S z.re z.im T X : тДЭ) : тДВ) := by
      intro X
      conv_lhs => rw [тЖР upperHalfPoint_re_im z]
      exact complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
        S z.re z.im T X
    -- Transfer Tendsto to the complex partial
    have hPartial :
        Tendsto
          (fun X : тДЭ =>
            complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X z)
          Filter.atTop (ЁЭУЭ (Complex.I * ((J : тДЭ) : тДВ))) :=
      hIComplex.congr (fun X => (hbridge X).symm)
    -- Identify the adaptive tail value with I ┬╖ (J : тДВ)
    have hh : 10 тЙд T тИз T тЙд 140 тИз 0 < z.im тИз 2 * (1 + |z.re| + z.im) тЙд T :=
      тЯиh10, h140, hy, hregimeтЯй
    have htail_val :
        pairedDerivAdaptiveTail S R T z = Complex.I * ((J : тДЭ) : тДВ) := by
      unfold pairedDerivAdaptiveTail
      rw [dif_pos hh]
    rw [htail_val]
    exact hPartial

-- =====================================================================
-- ┬зCCXVIII. Adaptive bound data + wrapper-kernel ActualDensityTailData
-- =====================================================================
-- Closes the wiring loop: adaptive convergence (┬зCCXVII) plus the
-- finite-Im identity (┬зCCXVI) plus real IBP data give an
-- `AdaptiveComplexTailIBPBoundData`, which produces the `hbound`
-- field, which feeds `ActualDensityTailData`, which feeds the
-- `LocalXiCloudDensityErrorPackage` via the ┬зCCXIII model-parametric
-- theorem. Adds:
--
--   AdaptiveComplexTailIBPBoundData                тАФ adaptive Prop bundle
--   adaptiveComplexDensityTailFamilyPartial_im_tendsto
--   hbound_of_adaptiveComplexTailIBPBoundData      тАФ produces hbound
--   adaptiveComplexTailIBPBoundData_pairedDeriv    тАФ wrapper instantiation
--   actualDensityTailData_of_pairedDerivWrapper    тАФ full ActualDensityTailData
--   localXiPackage_of_pairedDerivWrapper           тАФ final local package
--
-- After this lands, the only remaining gap in the real-tail direction
-- is the mathematical identity `(error z).im = (pairedDerivAdaptiveTail
-- S R T z).im` (a property of the actual log-derivative decomposition),
-- and eventually the replacement of the wrapper kernel with the true
-- rational complex kernel.

/-- **Adaptive `ComplexTailIBPBoundData`.** Mirrors ┬зCCXV's
`ComplexTailIBPBoundData` but consumes an adaptive convergence package
(`AdaptiveComplexDensityTailFamilyConverges`) тАФ matches the ┬зCCXVII
construction. -/
structure AdaptiveComplexTailIBPBoundData
    (kernel : тДЭ тЖТ тДВ тЖТ тДВ) (S : тДЭ тЖТ тДЭ)
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    (error : тДВ тЖТ тДВ) : Prop where
  error_im_eq_tail_im :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      (error z).im = (conv.tail T z).im
  finite_im_match :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      ComplexTailImaginaryPartMatchesRealIBP kernel S z.re z.im T
  derivative_tendsto :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ J : тДЭ, Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (ЁЭУЭ J)
  derivative_bound :
    тИА {z : тДВ} {T : тДЭ} {J : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      Tendsto
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (ЁЭУЭ J) тЖТ
      |J| тЙд -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- тнР **PROVED тАФ adaptive specialization of the Im-Tendsto lemma.**
For each adaptive `(T, z)`, the imaginary part of the complex partial
tends to the imaginary part of the adaptive tail. -/
lemma adaptiveComplexDensityTailFamilyPartial_im_tendsto
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ}
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    {T : тДЭ} {z : тДВ}
    (h10 : 10 тЙд T) (h140 : T тЙд 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) тЙд T) :
    Tendsto
      (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (ЁЭУЭ (conv.tail T z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto h10 h140 hy hregime)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `hbound` field from `AdaptiveComplexTailIBPBoundData`.**
Adaptive analogue of ┬зCCXV's `hbound_of_complexTailIBPBoundData`.
Combines the four `AdaptiveComplexTailIBPBoundData` fields into the
`|(error z).im| тЙд -P(...)` predicate that `ActualDensityTailData.hbound`
expects. -/
theorem hbound_of_adaptiveComplexTailIBPBoundData
    {kernel : тДЭ тЖТ тДВ тЖТ тДВ} {S : тДЭ тЖТ тДЭ}
    {conv : AdaptiveComplexDensityTailFamilyConverges kernel S}
    {error : тДВ тЖТ тДВ}
    (B : AdaptiveComplexTailIBPBoundData kernel S conv error) :
    тИА {z : тДВ} {T : тДЭ}, 10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      |(error z).im| тЙд
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain тЯиJ, hJтЯй := B.derivative_tendsto h10 h140 hy hregime
  -- Im of complex partial tends to Im of adaptive tail
  have htail_im :
      Tendsto
        (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im)
        Filter.atTop (ЁЭУЭ (conv.tail T z).im) :=
    adaptiveComplexDensityTailFamilyPartial_im_tendsto conv h10 h140 hy hregime
  -- Bridge the real Tendsto into Im-of-complex via finite_im_eq + UHP identity
  have hmatch :
      Tendsto
        (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im)
        Filter.atTop (ЁЭУЭ J) := by
    have hmatch_struct := B.finite_im_match h10 h140 hy hregime
    have heq :
        (fun X : тДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          =с╢а[Filter.atTop]
        (fun X : тДЭ => (complexDensityTailPartial kernel S T X z).im) := by
      filter_upwards [hmatch_struct.finite_im_eq] with X hX
      rw [upperHalfPoint_re_im z] at hX
      exact hX.symm
    exact Tendsto.congr' heq hJ
  -- Limits agree тЖТ tail.im = J
  have huniq : (conv.tail T z).im = J :=
    tendsto_nhds_unique htail_im hmatch
  -- Transfer to error.im, then apply derivative_bound
  rw [B.error_im_eq_tail_im h10 h140 hy hregime, huniq]
  exact B.derivative_bound h10 h140 hy hregime hJ

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ wrapper-kernel `AdaptiveComplexTailIBPBoundData`.**
Given real IBP family data `R` and an error-Im identity `herror`,
produces the adaptive bound data for the ┬зCCXVI wrapper kernel via
the ┬зCCXVII adaptive convergence package.

`herror` is the genuinely remaining mathematical input: it says the
residual error's imaginary part matches the wrapper adaptive tail's
