    z.im тЙд 4 := by
  rcases hz with тЯиhy, hboundтЯй
  nlinarith [abs_nonneg z.re]

/-- **Rectangular compact box** `|x| тЙд 4 тИз 0 < y тИз y тЙд 4`. -/
def lowCompactBox (x y : тДЭ) : Prop :=
  |x| тЙд 4 тИз 0 < y тИз y тЙд 4

/-- тнР **PROVED тАФ `lowCompactRegion z` projects to a compact box.** -/
lemma lowCompactBox_of_lowCompactRegion
    {z : тДВ} (hz : lowCompactRegion z) :
    lowCompactBox z.re z.im :=
  тЯиlowCompactRegion_abs_re_le_four hz, hz.1,
   lowCompactRegion_im_le_four hzтЯй

/-- ЁЯУж **`LowCompactNumericalCertificate`** тАФ the final compact-box
numerical certificate for the low band. Says: for every `(x, y)` in
the rectangular box `|x| тЙд 4, 0 < y тЙд 4`, the residual envelope at
`upperHalfPoint x y` is dominated by the model-margin envelope. This
is the shape an interval-arithmetic / first-zero numerical proof
should produce. -/
def LowCompactNumericalCertificate : Prop :=
  тИА x y : тДЭ,
    lowCompactBox x y тЖТ
    lowResidualEnvelope (upperHalfPoint x y)
      тЙд lowModelMarginEnvelope (upperHalfPoint x y)

/-- ЁЯМЯ **PROVED тАФ envelope dominance from the numerical certificate.**
Routes through `lowCompactBox_of_lowCompactRegion` and
`upperHalfPoint_re_im` to apply the certificate at each `z`. -/
theorem LowCompactEnvelopeDominates_of_numericalCertificate
    (H : LowCompactNumericalCertificate) :
    LowCompactEnvelopeDominates := by
  intro z hz
  have hbox := lowCompactBox_of_lowCompactRegion hz
  have huhp : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have h := H z.re z.im hbox
  rw [huhp] at h
  exact h

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `XiLowResidualMargin` from the compact
numerical certificate.** Composition of the two bridges. -/
theorem XiLowResidualMargin_of_numericalCertificate
    (H : LowCompactNumericalCertificate) :
    XiLowResidualMargin honestZeroDensityModelTwoPi :=
  XiLowResidualMargin_of_envelopeDominates
    (LowCompactEnvelopeDominates_of_numericalCertificate H)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **FINAL
FRONT DOOR (twoPi + tail limits + compact numerical low).**

The five-input Route B capstone with `Hlow` replaced by the bounded
compact-box numerical certificate:

```
hTuring + hHighLog              (parallel agent)
+ Hcanon_tailLimit              (mid residual Tendsto)
+ Hhigh_tailLimit               (high residual Tendsto)
+ Hcompact                      (numerical bound on |x| тЙд 4, 0 < y тЙд 4)
тЯ╣ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_compactLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hcanon_tailLimit :
      XiCanonicalResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hhigh_tailLimit :
      XiHighResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hcompact : LowCompactNumericalCertificate) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_tailLimits
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
    Hcanon_tailLimit Hhigh_tailLimit
    (XiLowResidualMargin_of_numericalCertificate Hcompact)

-- =====================================================================
-- ┬зCCLXXVII. Low residual explicit-formula interface
-- =====================================================================
-- `Hlow` cannot be reduced to rational/log bounds alone:
-- `xiResidualError honestZeroDensityModelTwoPi` contains `╬Ы[╬Ю]` with
-- no concrete computation in the repo. The correct move is the
-- low-band analogue of `Hcanon_tailLimit` / `Hhigh_tailLimit`: a named
-- explicit-formula residual bound at the canonical first-zero
-- parameters `(╬│тВБ, D) := (14, 1/2)`.
--
-- Adds:
--   lowResidualExplicitBound                            тАФ explicit closed form
--   XiLowResidualExplicitData                           тАФ residual тЙд explicit bound
--   LowMarginDominatesExplicitBound                     тАФ explicit bound тЙд model margin
--   XiLowResidualMargin_of_explicit_and_margin          тАФ bridge
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit
--                                                       тАФ final front door

/-- **Low residual explicit bound** тАФ `closedFormFirstZeroErrorBound`
at the canonical first-zero parameters `(╬│тВБ, D) := (14, 1/2)` and
inner cutoff `T := 2╧А`. Numerically `тЙИ 0.19 ┬╖ z.im` for
`0 < z.im тЙд 4`. -/
noncomputable def lowResidualExplicitBound (z : тДВ) : тДЭ :=
  closedFormFirstZeroErrorBound z.im (2 * Real.pi) 14 (1 / 2)

/-- ЁЯУж **`XiLowResidualExplicitData`** тАФ the low-band xi-specific
analytic target: on the compact low region, the canonical residual's
Im is bounded by `lowResidualExplicitBound z`. -/
structure XiLowResidualExplicitData
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_bound :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      |(xiResidualError M z).im| тЙд lowResidualExplicitBound z

/-- ЁЯУж **`LowMarginDominatesExplicitBound`** тАФ model-margin side of
the split: the explicit residual bound is dominated by the actual
model margin on the compact low region. Tractable via `simpleCloudSum`
+ `HonestSmoothTailRationalLB_twoPi`. -/
def LowMarginDominatesExplicitBound
    (M : CloudDensityTailModelDecomposition) : Prop :=
  тИА z : тДВ,
    lowCompactRegion z тЖТ
    lowResidualExplicitBound z тЙд -(M.model z).im

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `XiLowResidualMargin` from the two-piece split.**
Composes the explicit residual bound (xi-specific) with the model
margin dominance (model-side analytic). -/
theorem XiLowResidualMargin_of_explicit_and_margin
    (Hexplicit : XiLowResidualExplicitData honestZeroDensityModelTwoPi)
    (Hmargin : LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi) :
    XiLowResidualMargin honestZeroDensityModelTwoPi := by
  intro z hz
  exact le_trans (Hexplicit.residual_bound z hz) (Hmargin z hz)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **FINAL
FRONT DOOR (twoPi + tail limits + low explicit split).**

The low-band obligation is now split into two genuine analytic pieces:

```
hTuring + hHighLog              (parallel agent)
+ Hcanon_tailLimit              (mid residual Tendsto)
+ Hhigh_tailLimit               (high residual Tendsto)
+ Hlow_explicit                 (xi: residual тЙд closed-form first-zero bound)
+ Hlow_margin                   (model: closed-form bound тЙд -Im(model))
тЯ╣ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
