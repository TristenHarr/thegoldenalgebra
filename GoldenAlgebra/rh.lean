/-! ### Strong admissibility gives nonvanishing on the whole contour -/

/-- **V1.** Bundled nonvanishing of `ќґ` along the four edges. -/
structure ZetaRectangleContourNonvanishing (R : ZetaRectangle) : Prop where
  bottom :
    вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ riemannZeta (R.bottomEdge t) вЙ† 0
  right :
    вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ riemannZeta (R.rightEdge t) вЙ† 0
  top :
    вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ riemannZeta (R.topEdge t) вЙ† 0
  left :
    вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ riemannZeta (R.leftEdge t) вЙ† 0

theorem ZetaRectangleContourNonvanishing.of_stronglyAdmissible
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleContourNonvanishing where
  bottom := fun _t ht0 ht1 => zeta_ne_zero_bottomEdge hAdm ht0 ht1
  right := fun _t ht0 ht1 => zeta_ne_zero_rightEdge hAdm ht0 ht1
  top := fun _t ht0 ht1 => zeta_ne_zero_topEdge hAdm ht0 ht1
  left := fun _t ht0 ht1 => zeta_ne_zero_leftEdge hAdm ht0 ht1

/-- **V2.** Bundled "edge avoids the pole" condition. -/
structure ZetaRectangleContourAvoidsPole (R : ZetaRectangle) : Prop where
  bottom : вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ R.bottomEdge t вЙ† 1
  right : вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ R.rightEdge t вЙ† 1
  top : вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ R.topEdge t вЙ† 1
  left : вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ R.leftEdge t вЙ† 1

theorem ZetaRectangleContourAvoidsPole.of_stronglyAdmissible
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleContourAvoidsPole where
  bottom := by
    intro t ht0 ht1 h
    exact hAdm.poleNotOnBoundary
      (by rw [вЖР h]; exact R.bottomEdge_mem_boundary ht0 ht1)
  right := by
    intro t ht0 ht1 h
    exact hAdm.poleNotOnBoundary
      (by rw [вЖР h]; exact R.rightEdge_mem_boundary ht0 ht1)
  top := by
    intro t ht0 ht1 h
    exact hAdm.poleNotOnBoundary
      (by rw [вЖР h]; exact R.topEdge_mem_boundary ht0 ht1)
  left := by
    intro t ht0 ht1 h
    exact hAdm.poleNotOnBoundary
      (by rw [вЖР h]; exact R.leftEdge_mem_boundary ht0 ht1)

