lemma log_T_over_2pi_ge_const_32_36
    {T : ℝ} (hT32 : 32 ≤ T) (_hT36 : T ≤ 36) :
    (8 / 5 : ℝ) ≤ Real.log (T / (2 * Real.pi)) := by
