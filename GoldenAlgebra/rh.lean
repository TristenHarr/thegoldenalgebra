-- =====================================================================
-- ┬з16. Phase 1 + Phase 2 scaffolding (codifying ┬з15.A)
-- =====================================================================
-- The four sub-targets of the ┬з15.A roadmap, laid down as named Prop
-- structures with bridge theorems into the existing ┬з13/┬з10 pipeline.
-- Style mirrors ┬з13: define the data, expose Prop-field obligations,
-- and compose into the upstream chain
-- (`PerWindowClosedFormIBPData` / `ZeroCountingFluctuationBound` /
-- `LocalAnalyticZeroFactorization` /
-- `EntireLocalPoleDecompositionHypothesis`).

-- ---------------------------------------------------------------------
-- ┬з16.1. Fluctuation measure data (Phase 1.1)
-- ---------------------------------------------------------------------
-- The pair `(N, NтВА)` of the discrete zero-counting function and the
-- smooth model. The signed-measure `dS = dN тИТ dNтВА` is encoded by the
-- difference `S(u) = N(u) тИТ NтВА(u)` at the function level (the existing
-- ┬з13 `ZeroCountingFluctuationBound` already carries `S` in this
-- form). The structure below pins down the concrete construction of
-- `S` from a zero list `Z : тДХ тЖТ тДЭ` with multiplicities
-- `mult : тДХ тЖТ тДХ` and a smooth `NтВА : тДЭ тЖТ тДЭ` (e.g.
-- `smoothZeroCountingN0`). Once Mathlib's
-- `MeasureTheory.SignedMeasure тДЭ` packaging of
-- `dS = ╬г_{j<n} (mult j) тАв dirac (Z j) тИТ volume.withDensity ╧Б` lands,
-- this structure is the function-level bridge.

/-- **Discrete zero-counting function** for a list of zero ordinates
`Z : тДХ тЖТ тДЭ` with multiplicities `mult : тДХ тЖТ тДХ`, truncated to the
first `n` entries:
`N_{Z, mult, n}(u) = ╬г_{j < n, Z j тЙд u} mult j`. -/
noncomputable def discreteZeroCounting
    (Z : тДХ тЖТ тДЭ) (mult : тДХ тЖТ тДХ) (n : тДХ) (u : тДЭ) : тДЭ :=
  (Finset.range n).sum
    (fun j => if Z j тЙд u then (mult j : тДЭ) else 0)

/-- **Concrete fluctuation function** `S = N тИТ NтВА` from a zero list
and the smooth model. -/
noncomputable def concreteFluctuation
    (Z : тДХ тЖТ тДЭ) (mult : тДХ тЖТ тДХ) (n : тДХ) (NтВА : тДЭ тЖТ тДЭ) (u : тДЭ) : тДЭ :=
  discreteZeroCounting Z mult n u - NтВА u

/-- **Fluctuation measure data.** Packages the inputs to the
signed-measure construction `dS = dN тИТ dNтВА` together with the
function-level fluctuation `S : тДЭ тЖТ тДЭ`. Fields:

* `Z` тАФ zero ordinates (e.g. positive imaginary parts of the
  nontrivial zeros of `XiPullback`);
* `mult` тАФ algebraic multiplicities;
* `n` тАФ number of zeros included in the window;
* `NтВА` тАФ smooth model (concretely `smoothZeroCountingN0`);
* `S` тАФ the named fluctuation function;
* `S_eq` тАФ `S` agrees with the concrete `N тИТ NтВА` construction.

This is the input the ┬з13 `ZeroCountingFluctuationBound.S` field
expects, once the measure-theoretic side of Phase 1.1 lands. -/
structure FluctuationMeasureData where
  Z : тДХ тЖТ тДЭ
  mult : тДХ тЖТ тДХ
  n : тДХ
  NтВА : тДЭ тЖТ тДЭ
  S : тДЭ тЖТ тДЭ
  S_eq : тИА u : тДЭ, S u = concreteFluctuation Z mult n NтВА u

/-- тнР **PROVED тАФ fluctuation measure data unfolds to `N тИТ NтВА`.** -/
theorem FluctuationMeasureData.S_def
    (D : FluctuationMeasureData) (u : тДЭ) :
    D.S u =
      (Finset.range D.n).sum
        (fun j => if D.Z j тЙд u then (D.mult j : тДЭ) else 0)
      - D.NтВА u := by
  rw [D.S_eq u]; rfl

/-- тнР **PROVED тАФ canonical xi-facing instance.** Given any zero list
`Z` with multiplicities `mult`, truncated to `n` entries, the
fluctuation `S = N тИТ smoothZeroCountingN0` (the ┬з13 smooth model) is
a `FluctuationMeasureData`. -/
noncomputable def FluctuationMeasureData.ofXiSmooth
    (Z : тДХ тЖТ тДЭ) (mult : тДХ тЖТ тДХ) (n : тДХ) :
    FluctuationMeasureData where
  Z := Z
  mult := mult
  n := n
  NтВА := smoothZeroCountingN0
  S := fun u => concreteFluctuation Z mult n smoothZeroCountingN0 u
  S_eq := fun _ => rfl

-- ---------------------------------------------------------------------
-- ┬з16.2. Improper Stieltjes integral wrapper (Phase 1.2)
-- ---------------------------------------------------------------------
-- The improper integral `тИл_T^тИЮ f(u) dS(u)` is the `atTop` limit of the
-- finite Stieltjes integrals `F(X) = тИл_T^X f(u) dS(u)`. At the
-- function level (`S = N тИТ NтВА` as in ┬з16.1), the finite Stieltjes
-- integral splits as
--   `тИл_T^X f(u) dS(u)
--      = ╬г_{j: T тЙд Z j тЙд X} mult j ┬╖ f(Z j)  тИТ  тИл_T^X f(u) ┬╖ ╧Б(u) du`.
-- The Prop-level abstraction below names the limit value without
-- committing to that explicit split; the ┬з16.3 IBP bridge uses it.

/-- **Improper Stieltjes integral, function-level convergence.**
`ImproperStieltjesConverges F L` says the partial integral
`F : тДЭ тЖТ тДЭ` tends to `L` as the upper cutoff `X тЖТ тИЮ`. The function
`F` is a parameter so this abstraction is agnostic to whether the
partial integral is encoded via RiemannтАУStieltjes sums,
`intervalIntegral` against a signed measure, or any explicit split. -/
def ImproperStieltjesConverges (F : тДЭ тЖТ тДЭ) (L : тДЭ) : Prop :=
  Tendsto F (Filter.atTop : Filter тДЭ) (ЁЭУЭ L)

/-- **Improper Stieltjes integral data.** Bundles a candidate
partial-integral function `F : тДЭ тЖТ тДЭ`, a basepoint `T`, and a limit
value `L`, with the proof that `F X тЖТ L` as `X тЖТ тИЮ`. -/
structure ImproperStieltjesIntegralData where
  F : тДЭ тЖТ тДЭ
  T : тДЭ
  L : тДЭ
  converges : ImproperStieltjesConverges F L

/-- **PROVED тАФ extract the limit value.** -/
theorem ImproperStieltjesIntegralData.tendsto
    (I : ImproperStieltjesIntegralData) :
    Tendsto I.F (Filter.atTop : Filter тДЭ) (ЁЭУЭ I.L) := I.converges

/-- **Imaginary-kernel improper Stieltjes integral.** Specialization
to the integrand `pairedCauchyImKernel x y ┬╖ = Im K_┬╖(z)` at a fixed
probe `z = x + i┬╖y` and basepoint `T`. The convergence target `L` is
the value of `Im (тИл_T^тИЮ K_u(z) dS(u))`. -/
structure ImaginaryKernelImproperIntegral where
  x : тДЭ
  y : тДЭ
  T : тДЭ
  partialIntegral : тДЭ тЖТ тДЭ         -- X тЖж тИл_T^X k_z(u) dS(u)
  L : тДЭ                           -- limiting value Im тИл_T^тИЮ K dS
  converges : ImproperStieltjesConverges partialIntegral L

-- ---------------------------------------------------------------------
-- ┬з16.2-A. Function-level Stieltjes split (Phase 1 concretization)
-- ---------------------------------------------------------------------
-- The Mathlib signed measure `╬╝_S = dN тИТ dNтВА` has the awkward feature
-- that `dNтВА = volume.withDensity ╧Б` is infinite on `тДЭ`, so direct
-- subtraction as a `SignedMeasure тДЭ` requires either restricting to a
-- bounded interval or going through localized measures. The
-- *function-level* equivalent тАФ splitting the Stieltjes integral as
--   `тИл_T^X f dS = (╬г_{j: T тЙд Z j тЙд X} mult j ┬╖ f (Z j))
--                 тИТ (тИл_T^X f(u) ┬╖ ╧Б(u) du)`
-- тАФ sidesteps that completely. The discrete partial is computable; the
-- smooth partial is a named field so downstream code can supply it via
-- either an explicit `intervalIntegral` or any other encoding.

/-- **Discrete Stieltjes partial integral.** The contribution to
`тИл_T^X f dS` from the discrete Dirac part `dN = ╬г_j mult j ┬╖ ╬┤_{Z j}`:
  `discreteStieltjesPartial Z mult n f T X
     = ╬г_{j < n : T тЙд Z j тЙд X} mult j ┬╖ f (Z j)`. -/
noncomputable def discreteStieltjesPartial
    (Z : тДХ тЖТ тДЭ) (mult : тДХ тЖТ тДХ) (n : тДХ) (f : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДЭ :=
  (Finset.range n).sum (fun j =>
    if T тЙд Z j тИз Z j тЙд X then (mult j : тДЭ) * f (Z j) else 0)

/-- **Function-level Stieltjes partial integral split.** Encodes
`тИл_T^X f dS = (discrete part against `dN`) тИТ (smooth part against `d╧Б`)`
as named data. The `smoothPart` field stays abstract so it can be
either an explicit `intervalIntegral` or a Prop-level commitment to a
downstream integral computation. -/
structure StieltjesPartialSplit where
  Z : тДХ тЖТ тДЭ
  mult : тДХ тЖТ тДХ
  n : тДХ
  f : тДЭ тЖТ тДЭ
  T : тДЭ
  smoothPart : тДЭ тЖТ тДЭ      -- X тЖж тИл_T^X f(u) ┬╖ ╧Б(u) du
  total : тДЭ тЖТ тДЭ           -- X тЖж тИл_T^X f dS
  total_eq :
    тИА X : тДЭ,
      total X = discreteStieltjesPartial Z mult n f T X - smoothPart X

/-- тнР **PROVED тАФ function-level split projects to the abstract
improper-Stieltjes wrapper.** Given a `StieltjesPartialSplit` together
with a limit value `L` and a convergence proof for the `total` field,
construct the `ImproperStieltjesIntegralData` of ┬з16.2. -/
noncomputable def StieltjesPartialSplit.toImproperStieltjesIntegralData
    (S : StieltjesPartialSplit) (L : тДЭ)
    (hconv : ImproperStieltjesConverges S.total L) :
    ImproperStieltjesIntegralData where
  F := S.total
  T := S.T
  L := L
  converges := hconv

/-- тнР **PROVED тАФ discrete partial is nonneg when `f тЙе 0`.** Used in
positivity arguments: the discrete part of any Stieltjes integral
against a nonnegative integrand is nonnegative. -/
theorem discreteStieltjesPartial_nonneg_of_nonneg_f
    {Z : тДХ тЖТ тДЭ} {mult : тДХ тЖТ тДХ} {n : тДХ} {f : тДЭ тЖТ тДЭ} {T X : тДЭ}
    (hf : тИА u : тДЭ, 0 тЙд f u) :
    0 тЙд discreteStieltjesPartial Z mult n f T X := by
  unfold discreteStieltjesPartial
  apply Finset.sum_nonneg
  intro j _
  by_cases h : T тЙд Z j тИз Z j тЙд X
  ┬╖ rw [if_pos h]
    have : (0 : тДЭ) тЙд (mult j : тДЭ) := by positivity
    exact mul_nonneg this (hf _)
  ┬╖ rw [if_neg h]

/-- тнР **PROVED тАФ discrete partial telescope at `X = T тИТ 1`** (or any
`X < min Z j`): the partial is `0` when the upper cutoff is below all
zero ordinates. Trivially the empty-window case of the discrete
Stieltjes integral. -/
theorem discreteStieltjesPartial_eq_zero_of_X_lt
    {Z : тДХ тЖТ тДЭ} {mult : тДХ тЖТ тДХ} {n : тДХ} {f : тДЭ тЖТ тДЭ} {T X : тДЭ}
    (hX : тИА j : тДХ, j < n тЖТ X < Z j) :
    discreteStieltjesPartial Z mult n f T X = 0 := by
  unfold discreteStieltjesPartial
  apply Finset.sum_eq_zero
  intro j hj
  have hj_lt : j < n := Finset.mem_range.mp hj
  rw [if_neg]
  intro тЯи_, hZjтЯй
  exact absurd hZj (not_le_of_gt (hX j hj_lt))

-- ---------------------------------------------------------------------
-- ┬з16.3. IBP bound + `hmargin_from_ibp` bridge (Phase 1.3)
-- ---------------------------------------------------------------------
-- Bundles a `PerWindowClosedFormIBPData` together with the
-- identification `(error z).im = improper Stieltjes integral of
-- Im K_u(z) against dS(u) on [T, тИЮ)`. This is the data the existing
-- `PerWindowClosedFormIBPData.toZeroCountingFluctuationBound` needs to
-- have its `hmargin_from_ibp` hypothesis discharged constructively.

/-- **Stieltjes IBP data for a per-window package.** Given a
`PerWindowClosedFormIBPData` `P`, the analytic content required to
discharge `P.toZeroCountingFluctuationBound`'s `hmargin_from_ibp`
hypothesis splits into:

* `modelMargin_eq` тАФ for every `z` in `P.region` with `Im z > 0`,
  `P.modelMargin = тИТIm(model z)`. (Already a per-probe fact at `P.z`
  via `P.modelMargin_eq`; here we lift it to the whole region.)
* `tail_bound` тАФ for every `z` in `P.region` with `Im z > 0`,
  `|(P.error z).im| тЙд P.modelMargin`. This is exactly the IBP-side
  estimate certified by the ┬з13 closed-form S-error bound combined
  with `Im(error z) = тИл_T^тИЮ Im K_u(z) dS(u)`.

Together they yield the margin hypothesis required upstream. -/
structure StieltjesIBPDataFor (P : PerWindowClosedFormIBPData) where
  modelMargin_eq :
    тИА z : тДВ, P.region z тЖТ 0 < z.im тЖТ
      P.modelMargin = -(P.model z).im
  tail_bound :
    тИА z : тДВ, P.region z тЖТ 0 < z.im тЖТ
      |(P.error z).im| тЙд P.modelMargin

/-- тнР **PROVED тАФ Stieltjes IBP data discharges `hmargin_from_ibp`.**
Combine `tail_bound` (IBP-side estimate from ┬з13) and `modelMargin_eq`
(identification of `P.modelMargin` with `тИТIm(model z)`) to get the
margin hypothesis required by
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`. -/
theorem StieltjesIBPDataFor.hmargin
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    тИА z : тДВ, P.region z тЖТ 0 < z.im тЖТ
      |(P.error z).im| тЙд -(P.model z).im := by
  intro z hz hzim
  have h1 := D.tail_bound z hz hzim
  rw [D.modelMargin_eq z hz hzim] at h1
  exact h1

/-- тнР **PROVED тАФ Stieltjes IBP data + per-window data тЯ╣
zero-counting fluctuation bound.** Discharges the `hmargin_from_ibp`
hypothesis of the existing
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`
constructively. -/
noncomputable def StieltjesIBPDataFor.toZeroCountingFluctuationBound
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    ZeroCountingFluctuationBound :=
  P.toZeroCountingFluctuationBound D.hmargin

/-- **PROVED тАФ `modelMargin_eq` specializes to the per-probe fact at
`P.z`.** Sanity check: the region-wise generalization `modelMargin_eq`
that `StieltjesIBPDataFor` carries reduces, at the specific probe `P.z`,
to the per-window equality `P.modelMargin = тИТIm(P.model P.z)` that
`PerWindowClosedFormIBPData.modelMargin_eq` already guarantees. -/
theorem StieltjesIBPDataFor.modelMargin_eq_at_probe
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P)
    (hzReg : P.region P.z) (hzim : 0 < P.z.im) :
    P.modelMargin = -(P.model P.z).im :=
  D.modelMargin_eq P.z hzReg hzim

-- ---------------------------------------------------------------------
-- ┬з16.4. Entire-function pole-decomposition data (Phase 2.1)
-- ---------------------------------------------------------------------
-- Mathlib's analyticity machinery тАФ `AnalyticAt`, isolated-zeros via
-- `eventually = 0 тИи eventually тЙа 0`, and `HasFPowerSeriesAt` тАФ
-- discharges the local factorization `F z = (z тИТ ╧Б)^m ┬╖ g z` with
-- `g ╧Б тЙа 0` at any non-degenerate zero of an analytic function. The
-- ┬з10 pipeline already has `LocalAnalyticZeroFactorization тЖТ
-- LocalLogDerivPoleDecomposition`
-- (`localAnalyticZeroFactorization_gives_LocalLogDerivPoleDecomposition`)
