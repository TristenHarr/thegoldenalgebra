-- §CCCIII. Hadamard source + zero-contribution split
-- =====================================================================
-- Audit findings:
--   * `XiPullback_logDeriv_chain_rule` exists (needs diff hypothesis).
--   * `EntireXiPullback_logDeriv_chain_rule` exists (unconditional).
--   * No Hadamard product theorem, no zero-list representation, no
--     canonical product factorization currently in the file.
--   * No naming conflicts for `XiHadamardLogDerivativeSource` /
--     `XiZeroContributionSplit`.
--
-- This section separates the remaining mountain into:
--   A. Hadamard source: `Λ[Ξ](z) = zeroContribution z` (abstract source)
--   B. Zero split:       `zeroContribution z = model + fluctuation`
-- The bridge produces `XiExplicitFormulaPackage`.

/-- 📦 **`XiHadamardLogDerivativeSource`** — the Hadamard / zero-sum
representation of `Λ[Ξ]` as a function `zeroContribution : ℂ → ℂ`.
Concrete inhabitants will use the Hadamard product factorization of
`completedXiFunction` (or `entireRiemannXi`) to identify
`zeroContribution z` with a regularized sum over zeros. Abstract here
to keep the interface independent of the specific factorization. -/
structure XiHadamardLogDerivativeSource : Type where
  zeroContribution : ℂ → ℂ
  logDeriv_eq_zeroContribution :
    ∀ z : ℂ,
      0 < z.im →
      logDerivativeResponse XiPullback z = zeroContribution z

/-- 📦 **`XiZeroContributionSplit`** — the zero-side identification of
`zeroContribution z` with `M.model + fluctuation contribution`. Says
the high/mid contribution is a tail limit + model, and the low
contribution is boundary + finite integral + model. The substantive
analytic content is the **Stieltjes conversion** of the zero sum into
true-kernel partials against the fluctuation primitive. -/
structure XiZeroContributionSplit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition)
    (ZC : ℂ → ℂ) : Prop where
  high_tail_split :
    ∀ {z : ℂ} {T : ℝ},
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 T z L ∧
        ZC z = M.model z + L
  low_finite_split :
    ∀ z : ℂ,
      lowCompactRegion z →
      (ZC z - M.model z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- 🌟🌟🌟 **PROVED — `XiExplicitFormulaPackage` from Hadamard source
+ zero-contribution split.** Composes the abstract Hadamard source
with the zero-side split to produce the full xi-side bundle for
Path B.

The substantive analytic content is now exactly:
* `XiHadamardLogDerivativeSource` — Hadamard product / log-derivative source
* `XiZeroContributionSplit` — Stieltjes decomposition of the zero sum -/
theorem XiExplicitFormulaPackage_of_hadamardSource_and_zeroSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (Hsrc : XiHadamardLogDerivativeSource)
    (Hsplit : XiZeroContributionSplit Dzero T0 M Hsrc.zeroContribution) :
    XiExplicitFormulaPackage Dzero T0 M := by
  refine ⟨?tail, ?low⟩
  · refine ⟨?_⟩
    intro z T hy hregime
    obtain ⟨L, hL, hZ⟩ := Hsplit.high_tail_split hy hregime
    refine ⟨L, hL, ?_⟩
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ]
  · refine ⟨?_⟩
    intro z hz
    have hy : 0 < z.im := hz.1
    have h_resid :
        (xiResidualError M z).im
          = (Hsrc.zeroContribution z - M.model z).im := by
      unfold xiResidualError
      rw [Hsrc.logDeriv_eq_zeroContribution z hy]
    rw [h_resid]
    exact Hsplit.low_finite_split z hz

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
