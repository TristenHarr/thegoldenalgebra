            `= (9/2)y┬Àlog T/T┬▓ + (9/4)y/T┬▓ + (9/2)y/T┬▓`,
collected as
  `(4 + 9/2)y┬Àlog T/T┬▓ + (4 + 9/4 + 9/2)y/T┬▓ = (17/2)y┬Àlog T/T┬▓ + (43/4)y/T┬▓`. -/
noncomputable def closedFormSErrorBoundHalfPlusHalf (y T : ÔäØ) : ÔäØ :=
  (y / T^2) * ((17 / 2) * Real.log T + 43 / 4)

/-- Ô¡É **PROVED ÔÇö half-half simplification.** -/
theorem closedFormSErrorBoundCD_half_half_eq
    {T : ÔäØ} (hT : T Ôëá 0) (y : ÔäØ) :
    closedFormSErrorBoundCD (1 / 2 : ÔäØ) (1 / 2 : ÔäØ) y T
      = closedFormSErrorBoundHalfPlusHalf y T := by
  unfold closedFormSErrorBoundCD closedFormSErrorBoundHalfPlusHalf
  have hT2 : T^2 Ôëá 0 := pow_ne_zero 2 hT
  field_simp
  ring

