/-- **Polynomial logDeriv response (value form):** `╬Ы[p](z) = p'(z) / p(z)`. -/
noncomputable def polynomialLogDerivResponse (p : Polynomial тДВ) : тДВ тЖТ тДВ :=
  fun z => p.derivative.eval z / p.eval z

/-- **PROVED тАФ applied to the abstract engine: any polynomial supplying
a `LocalLogDerivPoleDecomposition` at an upper root has a positive
escape.** -/
theorem polynomial_local_pole_forces_escape
    (p : Polynomial тДВ) (╧Б : тДВ)
    (D : LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ╧Б) :
    PositiveUpperImaginaryEscape (polynomialLogDerivResponse p) :=
  localLogDerivPoleDecomposition_forces_escape D

/-- **Polynomial pole-witness hypothesis (deferred Mathlib instantiation).**
For every upper-half-plane root `╧Б` of `p` we have a
`LocalLogDerivPoleDecomposition` at `╧Б`. The general construction of such
a decomposition from `p тЙа 0` and `p.eval ╧Б = 0` requires Mathlib's
polynomial root-multiplicity + bounded-continuity machinery and lives in
CXXXII / Mathlib-side work. -/
structure PolynomialPoleWitnessHypothesis (p : Polynomial тДВ) : Prop where
  decomp_at_each_upper_root :
    тИА ╧Б : тДВ, p.eval ╧Б = 0 тЖТ 0 < ╧Б.im тЖТ
      Nonempty (LocalLogDerivPoleDecomposition
        (polynomialLogDerivResponse p) ╧Б)

/-- **PROVED тАФ polynomial log-derivative pole-witness law:** the
hypothesis package implies the abstract `LogDerivPoleWitnessLaw`. -/
theorem polynomial_logDeriv_poleWitness
    (p : Polynomial тДВ)
    (H : PolynomialPoleWitnessHypothesis p) :
    LogDerivPoleWitnessLaw
      (fun z => p.eval z)
      (polynomialLogDerivResponse p) where
  upper_zero_forces_escape := by
    intro ╧Б hroot hupper
    obtain тЯиDтЯй := H.decomp_at_each_upper_root ╧Б hroot hupper
    exact localLogDerivPoleDecomposition_forces_escape D

/-- тнР **PROVED тАФ finite RH-equivalence for polynomials.** Anti-Herglotz
of the log-derivative response + the polynomial pole-witness package +
conjugation symmetry тЗТ all roots of `p` are real. One-line composition
with ┬з6. -/
theorem polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    (p : Polynomial тДВ)
    (H : PolynomialPoleWitnessHypothesis p)
    (hanti : AntiHerglotzUHP (polynomialLogDerivResponse p))
    (hsym : тИА z : тДВ, p.eval (star z) = star (p.eval z)) :
    тИА ╧Б : тДВ, p.eval ╧Б = 0 тЖТ ╧Б.im = 0 :=
  antiHerglotz_plus_symmetry_forces_real_zeros_complex
    (polynomial_logDeriv_poleWitness p H) hanti hsym

-- =====================================================================
-- ┬з8. Discharging the polynomial pole-witness  (CXXXII AтАУD)
-- =====================================================================
-- The four steps that bring `PolynomialPoleWitnessHypothesis` within one
-- mechanical Mathlib chase of becoming an unconditional theorem:
--
--   A. Reusable analytic helper: continuity at ╧Б тЯ╣ uniform |Im|-bound on
--      the probe segment ╧Б тИТ ╬╡┬╖I.
--   B. Polynomial logDeriv background `q'/q` is continuous away from a
--      root of `q`.
--   C. Composition of A + B: the polynomial background is probe-bounded.
--   D. Polynomial factorization `p = (X тИТ C ╧Б)^m ┬╖ q` with `q.eval ╧Б тЙа 0`
--      and `m = rootMultiplicity ╧Б p > 0`.

/-- **CXXXII-A тАФ continuity тЯ╣ probe boundedness.** A function continuous
at `╧Б` is uniformly bounded (in imaginary part) along the probe segment
`╧Б тИТ ╬╡┬╖I` for `0 < ╬╡ < ╬╡0`. Reusable for both polynomial and xi targets:
pick metric `╬┤` for radius 1, take `╬╡0 = min(╬┤/2, ╧Б.im/2)`, `K = тАЦB ╧БтАЦ + 1`,
close via triangle inequality. -/
theorem continuousAt_implies_probe_bounded
    {B : тДВ тЖТ тДВ} {╧Б : тДВ}
    (hB : ContinuousAt B ╧Б)
    (hupper : 0 < ╧Б.im) :
    тИГ K : тДЭ, 0 < K тИз
    тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
        |(B (╧Б - (╬╡ : тДВ) * Complex.I)).im| тЙд K := by
  rw [Metric.continuousAt_iff] at hB
  obtain тЯи╬┤, h╬┤_pos, h╬┤тЯй := hB 1 zero_lt_one
  refine тЯитАЦB ╧БтАЦ + 1, by positivity,
          min (╬┤/2) (╧Б.im / 2), ?_, ?_, ?_тЯй
  ┬╖ refine lt_min (by linarith) (by linarith)
  ┬╖ exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬╡ h╬╡_pos h╬╡_lt
  have h╬╡_lt_╬┤ : ╬╡ < ╬┤ := by
    have : ╬╡ < ╬┤ / 2 := lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
    linarith
  set z : тДВ := ╧Б - (╬╡ : тДВ) * Complex.I with hz_def
  have hz╧Б : z - ╧Б = -(╬╡ : тДВ) * Complex.I := by
    show ╧Б - (╬╡ : тДВ) * Complex.I - ╧Б = -(╬╡ : тДВ) * Complex.I
    ring
  have hnorm : тАЦz - ╧БтАЦ = ╬╡ := by
    rw [hz╧Б, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show тАЦ((╬╡ : тДЭ) : тДВ)тАЦ = ╬╡
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos h╬╡_pos
  have hdist : dist z ╧Б < ╬┤ := by
    rw [dist_eq_norm, hnorm]; exact h╬╡_lt_╬┤
  have h_dist_B : dist (B z) (B ╧Б) < 1 := h╬┤ hdist
  rw [dist_eq_norm] at h_dist_B
  have h_im : |(B z).im| тЙд тАЦB zтАЦ := Complex.abs_im_le_norm (B z)
  have h_tri : тАЦB zтАЦ тЙд тАЦB z - B ╧БтАЦ + тАЦB ╧БтАЦ := by
    have h_eq : B z = (B z - B ╧Б) + B ╧Б := by ring
    nth_rewrite 1 [h_eq]
    exact norm_add_le (B z - B ╧Б) (B ╧Б)
  linarith

/-- **CXXXII-B тАФ polynomial logDeriv background is continuous at any
non-root.** `q'(z)/q(z)` is continuous at `╧Б` whenever `q.eval ╧Б тЙа 0`. -/
theorem polynomial_logDeriv_background_continuousAt
    {q : Polynomial тДВ} {╧Б : тДВ} (hq╧Б : q.eval ╧Б тЙа 0) :
    ContinuousAt (fun z => q.derivative.eval z / q.eval z) ╧Б := by
  apply ContinuousAt.div
  ┬╖ exact (Polynomial.continuous q.derivative).continuousAt
  ┬╖ exact (Polynomial.continuous q).continuousAt
  ┬╖ exact hq╧Б

/-- **CXXXII-C тАФ polynomial logDeriv background is probe-bounded.**
One-line composition of CXXXII-A and CXXXII-B. -/
theorem polynomial_logDeriv_background_bounded_on_probe
    {q : Polynomial тДВ} {╧Б : тДВ}
    (hq╧Б : q.eval ╧Б тЙа 0)
    (hupper : 0 < ╧Б.im) :
    тИГ K : тДЭ, 0 < K тИз
    тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
        |((q.derivative.eval (╧Б - (╬╡ : тДВ) * Complex.I)) /
           (q.eval (╧Б - (╬╡ : тДВ) * Complex.I))).im| тЙд K :=
  continuousAt_implies_probe_bounded
    (polynomial_logDeriv_background_continuousAt hq╧Б) hupper

/-- **CXXXII-D тАФ polynomial factorization at a root (Mathlib reduction).**
For `p тЙа 0` with `p.eval ╧Б = 0`, there exist `m > 0` and `q` such that
`p = (X тИТ C ╧Б)^m ┬╖ q` with `q.eval ╧Б тЙа 0`. Set `m := rootMultiplicity ╧Б p`;
positivity via `rootMultiplicity_pos`; factorization via
`pow_rootMultiplicity_dvd`; nonzero remainder by contradiction using
`dvd_iff_isRoot` + `mul_dvd_mul_left` + `pow_succ` +
`le_rootMultiplicity_iff`. -/
theorem polynomial_factor_at_root_with_nonzero_remainder
    {p : Polynomial тДВ} {╧Б : тДВ}
    (hp : p тЙа 0)
    (hroot : p.eval ╧Б = 0) :
    тИГ m : тДХ, 0 < m тИз
    тИГ q : Polynomial тДВ,
      p = (Polynomial.X - Polynomial.C ╧Б)^m * q тИз
      q.eval ╧Б тЙа 0 := by
  set m := p.rootMultiplicity ╧Б with hm_def
  have hm_pos : 0 < m := by
    rw [hm_def]
    exact (Polynomial.rootMultiplicity_pos hp).mpr hroot
  obtain тЯиq, hq_eqтЯй : (Polynomial.X - Polynomial.C ╧Б)^m тИг p :=
    Polynomial.pow_rootMultiplicity_dvd p ╧Б
  refine тЯиm, hm_pos, q, hq_eq, ?_тЯй
  -- if q.eval ╧Б = 0, then (X - C ╧Б) тИг q, so (X - C ╧Б)^(m+1) тИг p,
  -- contradicting maximality of m
  intro hq_eval
  have h_dvd_q : (Polynomial.X - Polynomial.C ╧Б) тИг q :=
    Polynomial.dvd_iff_isRoot.mpr hq_eval
  have h_succ_dvd : (Polynomial.X - Polynomial.C ╧Б)^(m+1) тИг p := by
    rw [hq_eq, pow_succ]
    exact mul_dvd_mul_left _ h_dvd_q
  have h_le := (Polynomial.le_rootMultiplicity_iff hp).mpr h_succ_dvd
  rw [тЖР hm_def] at h_le
  omega

-- =====================================================================
-- ┬з9. ValueтЖТpolynomial bridge & unconditional polynomial RH  (CXXXIII)
-- =====================================================================
-- The mechanical Mathlib chase that lifts ┬з5's value-form local
-- decomposition to the polynomial log-derivative response, and discharges
-- `PolynomialPoleWitnessHypothesis` for every nonzero polynomial. After
-- this section, ┬з7's finite RH-equivalence collapses to its hypothesis-free
-- form `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`:
--
--   p тЙа 0  +  AntiHerglotzUHP (╬Ы[p])  +  Schwarz symmetry on p
--   тЯ╣  every root of p is real.

/-- **PROVED тАФ probe never coincides with the pole when `╬╡ > 0`.**
The imaginary parts differ by exactly `╬╡`. -/
theorem probe_ne_pole (╧Б : тДВ) (╬╡ : тДЭ) (h╬╡ : 0 < ╬╡) :
    ╧Б - (╬╡ : тДВ) * Complex.I тЙа ╧Б := by
  intro h
  have him_diff : (╧Б - (╬╡ : тДВ) * Complex.I).im = ╧Б.im := by rw [h]
  have him_calc : (╧Б - (╬╡ : тДВ) * Complex.I).im = ╧Б.im - ╬╡ := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- **PROVED тАФ continuous-at-╧Б + nonzero-at-╧Б тЯ╣ nonzero on probe.**
Triangle bound: `тАЦf(z)тАЦ > тАЦf ╧БтАЦ/2` on a small enough probe segment. -/
theorem continuousAt_implies_probe_nonzero
    {f : тДВ тЖТ тДВ} {╧Б : тДВ}
    (hf : ContinuousAt f ╧Б)
    (hf╧Б : f ╧Б тЙа 0)
    (hupper : 0 < ╧Б.im) :
    тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
        f (╧Б - (╬╡ : тДВ) * Complex.I) тЙа 0 := by
  rw [Metric.continuousAt_iff] at hf
  have h_pos : 0 < тАЦf ╧БтАЦ := norm_pos_iff.mpr hf╧Б
  obtain тЯи╬┤, h╬┤_pos, h╬┤тЯй := hf (тАЦf ╧БтАЦ / 2) (by linarith)
  refine тЯиmin (╬┤/2) (╧Б.im / 2), ?_, ?_, ?_тЯй
  ┬╖ refine lt_min (by linarith) (by linarith)
  ┬╖ exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬╡ h╬╡_pos h╬╡_lt
  have h╬╡_lt_╬┤ : ╬╡ < ╬┤ := by
    have : ╬╡ < ╬┤ / 2 := lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
    linarith
  set z : тДВ := ╧Б - (╬╡ : тДВ) * Complex.I
  have hz╧Б : z - ╧Б = -(╬╡ : тДВ) * Complex.I := by
    show ╧Б - (╬╡ : тДВ) * Complex.I - ╧Б = -(╬╡ : тДВ) * Complex.I
    ring
  have hnorm : тАЦz - ╧БтАЦ = ╬╡ := by
    rw [hz╧Б, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show тАЦ((╬╡ : тДЭ) : тДВ)тАЦ = ╬╡
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos h╬╡_pos
  have hdist : dist z ╧Б < ╬┤ := by
    rw [dist_eq_norm, hnorm]; exact h╬╡_lt_╬┤
  have h_dist : dist (f z) (f ╧Б) < тАЦf ╧БтАЦ / 2 := h╬┤ hdist
  rw [dist_eq_norm] at h_dist
  intro hfz
  rw [hfz] at h_dist
  simp at h_dist
  linarith

/-- **PROVED тАФ THE CXXXIII BRIDGE.** Polynomial value-form pole
decomposition lifted to the log-derivative response: if
`p = (X тИТ C ╧Б)^(k+1) ┬╖ q` with `z тЙа ╧Б` and `q(z) тЙа 0`, then
`p'(z)/p(z) = (k+1)/(zтИТ╧Б) + q'(z)/q(z)`. Reduces to ┬з5's value-form
`complex_local_pole_decomposition_general` after evaluating `eval` of
the factorization and its derivative. -/
theorem polynomial_logDeriv_local_decomposition_of_factor
    {p q : Polynomial тДВ} {╧Б z : тДВ} {k : тДХ}
    (hfac : p = (Polynomial.X - Polynomial.C ╧Б) ^ (k + 1) * q)
    (hz╧Б : z тЙа ╧Б)
    (hqz : q.eval z тЙа 0) :
    polynomialLogDerivResponse p z =
      (((k + 1 : тДХ) : тДВ) / (z - ╧Б))
        + q.derivative.eval z / q.eval z := by
  unfold polynomialLogDerivResponse
  -- p.eval z = (z тИТ ╧Б)^(k+1) * q.eval z
  have hp_eval : p.eval z = (z - ╧Б)^(k+1) * q.eval z := by
    rw [hfac]
    simp [Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C]
  -- p'.eval z = (k+1) * (z тИТ ╧Б)^k * q.eval z + (z тИТ ╧Б)^(k+1) * q'.eval z
  have hp_deriv_eval : p.derivative.eval z
                    = ((k + 1 : тДХ) : тДВ) * (z - ╧Б)^k * q.eval z
                      + (z - ╧Б)^(k+1) * q.derivative.eval z := by
    rw [hfac, Polynomial.derivative_mul, Polynomial.derivative_pow_succ]
    simp [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C,
          Polynomial.derivative_sub, Polynomial.derivative_X,
          Polynomial.derivative_C]
  rw [hp_eval, hp_deriv_eval]
  exact complex_local_pole_decomposition_general z ╧Б (q.eval z)
          (q.derivative.eval z) k hz╧Б hqz

/-- **PROVED тАФ building `LocalLogDerivPoleDecomposition` from polynomial
factorization data.** Combines:

  тАв probe тЙа pole (`probe_ne_pole`),
  тАв polynomial background continuous (┬з8) & nonzero on probe (this section),
  тАв the valueтЖТpolynomial bridge above. -/
noncomputable def localLogDerivPoleDecomposition_of_polynomial_factor
    {p q : Polynomial тДВ} {╧Б : тДВ} {k : тДХ}
    (hupper : 0 < ╧Б.im)
    (hfac : p = (Polynomial.X - Polynomial.C ╧Б) ^ (k + 1) * q)
    (hq╧Б : q.eval ╧Б тЙа 0) :
    LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ╧Б :=
  -- Background continuity:
  let hcontB := polynomial_logDeriv_background_continuousAt hq╧Б
  let hcontQ : ContinuousAt (fun z => q.eval z) ╧Б :=
    (Polynomial.continuous q).continuousAt
  -- From continuity helpers, get bounded background and nonzero q on probe:
  let hboundedB : тИГ K : тДЭ, 0 < K тИз
      тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
        тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
          |((q.derivative.eval (╧Б - (╬╡ : тДВ) * Complex.I)) /
             (q.eval (╧Б - (╬╡ : тДВ) * Complex.I))).im| тЙд K :=
    continuousAt_implies_probe_bounded hcontB hupper
  let hnzQ : тИГ ╬╡0' : тДЭ, 0 < ╬╡0' тИз ╬╡0' < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0' тЖТ
        q.eval (╧Б - (╬╡ : тДВ) * Complex.I) тЙа 0 :=
    continuousAt_implies_probe_nonzero hcontQ hq╧Б hupper
  -- Extract and combine
  let K := hboundedB.choose
  let hK := hboundedB.choose_spec
  let ╬╡0B := hK.2.choose
  let h╬╡0B := hK.2.choose_spec
  let ╬╡0Q := hnzQ.choose
  let h╬╡0Q := hnzQ.choose_spec
  let ╬╡0 := min ╬╡0B ╬╡0Q
  { m := k + 1
    hm_pos := Nat.succ_pos k
    background := fun z => q.derivative.eval z / q.eval z
    ╬╡0 := ╬╡0
    h╬╡0 := lt_min h╬╡0B.1 h╬╡0Q.1
    h╬╡0_lt := lt_of_le_of_lt (min_le_left _ _) h╬╡0B.2.1
    K := K
    hK_pos := hK.1
    decomp_at_probe := fun ╬╡ h╬╡_pos h╬╡_lt => by
      have h╬╡_lt_B : ╬╡ < ╬╡0B :=
        lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
      have h╬╡_lt_Q : ╬╡ < ╬╡0Q :=
        lt_of_lt_of_le h╬╡_lt (min_le_right _ _)
      have hz╧Б : ╧Б - (╬╡ : тДВ) * Complex.I тЙа ╧Б := probe_ne_pole ╧Б ╬╡ h╬╡_pos
      have hqz : q.eval (╧Б - (╬╡ : тДВ) * Complex.I) тЙа 0 :=
        h╬╡0Q.2.2 ╬╡ h╬╡_pos h╬╡_lt_Q
      have h := polynomial_logDeriv_local_decomposition_of_factor
        hfac hz╧Б hqz
      convert h using 2
    background_bounded := fun ╬╡ h╬╡_pos h╬╡_lt => by
      have h╬╡_lt_B : ╬╡ < ╬╡0B :=
        lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
      exact h╬╡0B.2.2 ╬╡ h╬╡_pos h╬╡_lt_B }

/-- **PROVED тАФ THE DISCHARGE.** For any nonzero polynomial `p`, the
hypothesis package `PolynomialPoleWitnessHypothesis p` follows from
┬з8's root-multiplicity factorization combined with this section's
local pole decomposition. The abstract engine is no longer load-bearing
on this hypothesis. -/
theorem polynomialPoleWitnessHypothesis_of_nonzero_polynomial
    (p : Polynomial тДВ) (hp : p тЙа 0) :
    PolynomialPoleWitnessHypothesis p := by
  constructor
  intro ╧Б hroot hupper
  obtain тЯиm, hm, q, hfac, hq╧БтЯй :=
    polynomial_factor_at_root_with_nonzero_remainder hp hroot
  obtain тЯиk, rflтЯй : тИГ k, m = k + 1 :=
    тЯиm - 1, by omegaтЯй
  exact тЯиlocalLogDerivPoleDecomposition_of_polynomial_factor
    hupper hfac hq╧БтЯй

/-- тнР **PROVED тАФ FINITE RH-EQUIVALENCE FOR POLYNOMIALS (no hypothesis).**
For any nonzero polynomial `p`, anti-Herglotz log-derivative response
plus conjugation symmetry тЯ╣ all roots real. The hypothesis-free form of
┬з7's `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`. -/
theorem polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
    (p : Polynomial тДВ) (hp : p тЙа 0)
    (hanti : AntiHerglotzUHP (polynomialLogDerivResponse p))
    (hsym : тИА z : тДВ, p.eval (star z) = star (p.eval z)) :
    тИА ╧Б : тДВ, p.eval ╧Б = 0 тЖТ ╧Б.im = 0 :=
  polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    p (polynomialPoleWitnessHypothesis_of_nonzero_polynomial p hp)
    hanti hsym

-- =====================================================================
-- ┬з9-bis. Polynomial converse from a real linear factorization
-- =====================================================================
-- ┬з7-┬з9 close the FORWARD direction
--   AntiHerglotzUHP (╬Ы[p]) + Schwarz тЯ╣ all roots real.
-- The genuine converse тАФ "all roots real тЯ╣ anti-Herglotz" тАФ is also
-- true over тДВ but requires the polynomial splitting / root-multiset
-- machinery to descend from "real roots" to "real linear factorization".
--
-- This section first proves the converse in *factorized* form (which
-- only requires polynomial product / derivative algebra, plus ┬з2's
-- residue cloud lemma) and gives a finite-factorized iff. Bridging
-- from "all roots real" to a `PolynomialRealLinearFactorization`
-- (a `Polynomial.roots`-based proof) is left to a later phase since
-- it is independent algebra rather than overflow-residue content.

/-- **Real linear factorization data for a polynomial.** Witnesses that
`p` factors over тДВ as `C c ┬╖ тИП_i (X тИТ C r_i)` with `c тЙа 0` and real
roots `r_i` (counted with multiplicity by repetition in the list). -/
structure PolynomialRealLinearFactorization (p : Polynomial тДВ) where
  c : тДВ
  hc : c тЙа 0
  roots : List тДЭ
  factorization :
    p =
      Polynomial.C c *
        (roots.map fun r : тДЭ =>
          Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod

/-- **PROVED тАФ evaluation of a real linear product.** -/
private theorem prodLinearReal_eval
    (roots : List тДЭ) (z : тДВ) :
    (roots.map fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod.eval z
      = (roots.map fun r : тДЭ => z - (r : тДВ)).prod := by
  induction roots with
  | nil => simp
  | cons r rs ih =>
    simp [Polynomial.eval_mul, Polynomial.eval_sub, Polynomial.eval_X,
          Polynomial.eval_C, ih]

/-- **PROVED тАФ real linear product is nonzero at a point distinct from
all roots.** -/
private theorem prodLinearReal_eval_ne_zero
    (roots : List тДЭ) {z : тДВ} (hz : тИА r тИИ roots, z тЙа (r : тДВ)) :
    (roots.map fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod.eval z
      тЙа 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => simp
  | cons r rs ih =>
    have h_head : z тЙа (r : тДВ) := hz r (List.mem_cons_self ..)
    have h_tail : тИА s тИИ rs, z тЙа (s : тДВ) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    simp only [List.map_cons, List.prod_cons]
    exact mul_ne_zero (sub_ne_zero.mpr h_head) h_rest

/-- **PROVED тАФ log-derivative of a real linear product equals the cloud
sum.** Induction on the list of roots, using the product rule
  `(p ┬╖ q)' = p' ┬╖ q + p ┬╖ q'`
to split each factor.

At each step we have `((X тИТ C r) ┬╖ q)' / ((X тИТ C r) ┬╖ q) = 1/(z тИТ r) +
q'/q` (this is `complex_local_pole_decomposition_simple_root` instantiated
on values). Iterating gives the residue cloud. -/
theorem polynomialLogDeriv_of_linearProd_eq_cloud
    (roots : List тДЭ) (z : тДВ)
    (hz : тИА r тИИ roots, z тЙа (r : тДВ)) :
    polynomialLogDerivResponse
        (roots.map fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod z
      = (roots.map fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ))).sum := by
  induction roots with
  | nil =>
    -- empty product = 1; derivative = 0; cloud = 0
    simp [polynomialLogDerivResponse]
  | cons r rs ih =>
    have h_head : z тЙа (r : тДВ) := hz r (List.mem_cons_self ..)
    have h_tail : тИА s тИИ rs, z тЙа (s : тДВ) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    -- Names for the factors.
    set q : Polynomial тДВ :=
      (rs.map fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod
      with hq_def
    have hq_eval : q.eval z тЙа 0 :=
      prodLinearReal_eval_ne_zero rs h_tail
    -- p = (X - C r) * q.  Compute p.eval and p'.eval.
    have h_p_eval :
        ((List.map (fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ))
              (r :: rs)).prod).eval z
          = (z - (r : тДВ)) * q.eval z := by
      simp [hq_def, Polynomial.eval_mul, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have h_p_deriv_eval :
        (((List.map (fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ))
              (r :: rs)).prod).derivative).eval z
          = q.eval z + (z - (r : тДВ)) * q.derivative.eval z := by
      simp [hq_def, Polynomial.derivative_mul, Polynomial.derivative_sub,
            Polynomial.derivative_X, Polynomial.derivative_C,
            Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have hr_ne : z - (r : тДВ) тЙа 0 := sub_ne_zero.mpr h_head
    -- Compute the cloud equality directly.
    show polynomialLogDerivResponse
            (List.map (fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ))
              (r :: rs)).prod z
          = (List.map (fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ))) (r :: rs)).sum
    unfold polynomialLogDerivResponse
    rw [h_p_eval, h_p_deriv_eval]
    have h_alg :
        (q.eval z + (z - (r : тДВ)) * q.derivative.eval z) /
          ((z - (r : тДВ)) * q.eval z)
          = 1 / (z - (r : тДВ)) + q.derivative.eval z / q.eval z := by
      field_simp
      ring
    rw [h_alg, List.map_cons, List.sum_cons]
    -- Cancel matching first term, leaving `q'/q = (rs.map тАж).sum`, which
    -- is `h_rest` (defeq through `polynomialLogDerivResponse`).
    have h_rest' : q.derivative.eval z / q.eval z
                  = (List.map (fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ))) rs).sum :=
      h_rest
    rw [h_rest']

/-- **PROVED тАФ log-derivative is invariant under nonzero constant
multiplication.** `╬Ы[C c ┬╖ q](z) = ╬Ы[q](z)` when `q.eval z тЙа 0` and
`c тЙа 0`. -/
private theorem polynomialLogDeriv_C_mul
    (c : тДВ) (hc : c тЙа 0) (q : Polynomial тДВ) (z : тДВ) (hq : q.eval z тЙа 0) :
    polynomialLogDerivResponse (Polynomial.C c * q) z
      = polynomialLogDerivResponse q z := by
  unfold polynomialLogDerivResponse
  have h_eval : (Polynomial.C c * q).eval z = c * q.eval z := by
    simp [Polynomial.eval_mul, Polynomial.eval_C]
  have h_deriv :
      ((Polynomial.C c * q).derivative).eval z = c * q.derivative.eval z := by
    simp [Polynomial.derivative_mul, Polynomial.derivative_C,
          Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_C]
  rw [h_eval, h_deriv]
  field_simp
  ring

/-- **PROVED тАФ real linear product evaluates to zero at any root.** -/
private theorem prodLinearReal_eval_zero_of_mem
    (roots : List тДЭ) {z : тДВ} {r : тДЭ}
    (hr : r тИИ roots) (hz : z = (r : тДВ)) :
    (roots.map fun s : тДЭ => Polynomial.X - Polynomial.C ((s : тДЭ) : тДВ)).prod.eval z
      = 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => exact absurd hr (List.not_mem_nil)
  | cons s rs ih =>
    simp only [List.map_cons, List.prod_cons]
    rcases List.mem_cons.mp hr with rfl | hr_tail
    ┬╖ simp [hz]
    ┬╖ rw [ih hr_tail]; ring

/-- тнР **PROVED тАФ log-derivative of a real-linearly-factorized polynomial
equals the real residue cloud at any non-root.** -/
theorem polynomialLogDeriv_eq_real_residue_cloud_of_factorization
    {p : Polynomial тДВ}
    (F : PolynomialRealLinearFactorization p)
    (z : тДВ) (hz : p.eval z тЙа 0) :
    polynomialLogDerivResponse p z =
      (F.roots.map fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ))).sum := by
  -- Use an isolated `congrArg` for the rewrite to dodge motive issues
  -- (the goal contains `F.roots`, and naive `rw [F.factorization]` tries
  -- to rewrite `p` in `F`'s implicit type as well).
  set q : Polynomial тДВ :=
    (F.roots.map fun r : тДЭ => Polynomial.X - Polynomial.C ((r : тДЭ) : тДВ)).prod
    with hq_def
  -- 1. Recover `тИА r тИИ F.roots, z тЙа (r : тДВ)` from `hz`.
  have h_z_ne : тИА r тИИ F.roots, z тЙа (r : тДВ) := by
    intro r hr hz_eq
    apply hz
    have hp_eval : p.eval z = F.c * q.eval z := by
      have h := congrArg (Polynomial.eval z) F.factorization
      rw [h, Polynomial.eval_mul, Polynomial.eval_C]
    rw [hp_eval, prodLinearReal_eval_zero_of_mem F.roots hr hz_eq, mul_zero]
  -- 2. Express LHS via the factorization, isolated as a single congrArg.
  have h_q_eval : q.eval z тЙа 0 :=
    prodLinearReal_eval_ne_zero F.roots h_z_ne
  have hp_lhs :
      polynomialLogDerivResponse p z
        = polynomialLogDerivResponse (Polynomial.C F.c * q) z :=
    congrArg (fun r => polynomialLogDerivResponse r z) F.factorization
  rw [hp_lhs, polynomialLogDeriv_C_mul F.c F.hc q z h_q_eval]
  -- 3. Apply the linear-product cloud identity.
  exact polynomialLogDeriv_of_linearProd_eq_cloud F.roots z h_z_ne

/-- тнР **PROVED тАФ real-linearly-factorized polynomial тЯ╣ anti-Herglotz.**
The converse of `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`
in the factorized form. At a non-root we reduce `╬Ы[p]` to the real
residue cloud and apply ┬з2's `real_residue_cloud_antiHerglotz_list`. At
zeros, Lean's totalized `0 / 0 = 0` makes the inequality vacuous
(┬з6-bis `antiHerglotz_at_zero_is_vacuous`). -/
theorem polynomial_antiHerglotz_of_realLinearFactorization
    {p : Polynomial тДВ}
    (F : PolynomialRealLinearFactorization p) :
    AntiHerglotzUHP (polynomialLogDerivResponse p) := by
  intro z hz
  by_cases hpz : p.eval z = 0
  ┬╖ -- vacuous at a zero: totalized response is 0, so Im is 0 тЙд 0.
    show (polynomialLogDerivResponse p z).im тЙд 0
    unfold polynomialLogDerivResponse
    rw [hpz, div_zero, Complex.zero_im]
  ┬╖ rw [polynomialLogDeriv_eq_real_residue_cloud_of_factorization F z hpz]
    exact real_residue_cloud_antiHerglotz_list F.roots z hz

/-- тнР **PROVED тАФ finite-factorized polynomial iff.** Combining the ┬з7-┬з9
forward direction with the ┬з9-bis converse: for a real-linearly-factorized
polynomial, the anti-Herglotz target *is* equivalent to "all roots are
real". The reverse direction goes directly through the factorization
data `F`, not through "all roots real" тАФ so the `тИА ╧Б, real` premise is
not used to prove the implication, just to give the iff its honest shape
against the forward theorem. -/
theorem polynomial_realLinearFactorized_antiHerglotz_iff
    {p : Polynomial тДВ}
    (F : PolynomialRealLinearFactorization p)
    (hp : p тЙа 0)
    (hsym : тИА z : тДВ, p.eval (star z) = star (p.eval z)) :
    AntiHerglotzUHP (polynomialLogDerivResponse p)
      тЖФ тИА ╧Б : тДВ, p.eval ╧Б = 0 тЖТ ╧Б.im = 0 := by
  constructor
  ┬╖ intro hanti
    exact polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
      p hp hanti hsym
  ┬╖ intro _
    exact polynomial_antiHerglotz_of_realLinearFactorization F

-- =====================================================================
-- ┬з10. Entire-function generalization template  (CXXXIV)
-- =====================================================================
-- Mirrors ┬з7's polynomial template, one level up. The hypothesis
-- `EntireLocalPoleDecompositionHypothesis F` says: at every upper-half-plane
-- zero of `F`, the local pole structure is good enough to package into a
-- `LocalLogDerivPoleDecomposition`. This is the natural entire-function
-- analogue of ┬з7's `PolynomialPoleWitnessHypothesis` тАФ the only
-- difference is that there's no rootMultiplicity machinery yet to
-- discharge it unconditionally (the analytic bridge from
-- `тИАс╢а z, F z = (z тИТ ╧Б)^m ┬╖ g z` is the CXXXV next-phase target).
--
-- The capstone `entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`
-- delivers the entire-function template theorem
--
--     EntireLocalPoleDecompositionHypothesis F
--     +  AntiHerglotzUHP (╬Ы[F])
--     +  Schwarz symmetry on F
--     тЯ╣ every zero of F is real.

/-- **PROVED тАФ eventually-in-neighborhood тЯ╣ eventually-on-probe.**
Reusable helper: if `P` holds on a neighborhood of `╧Б`, then `P` holds
on the entire probe segment `╧Б тИТ ╬╡┬╖I` for all small enough `╬╡`. Useful
for both polynomial and xi-pullback discharges. -/
theorem eventually_nhds_implies_probe_eventually
    {P : тДВ тЖТ Prop} {╧Б : тДВ}
    (hP : тИАс╢а z in ЁЭУЭ ╧Б, P z)
    (hupper : 0 < ╧Б.im) :
    тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
        P (╧Б - (╬╡ : тДВ) * Complex.I) := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain тЯи╬┤, h╬┤_pos, h╬┤тЯй := hP
  refine тЯиmin (╬┤/2) (╧Б.im / 2), ?_, ?_, ?_тЯй
  ┬╖ refine lt_min (by linarith) (by linarith)
  ┬╖ exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬╡ h╬╡_pos h╬╡_lt
  apply h╬┤
  rw [dist_eq_norm,
      show ╧Б - (╬╡ : тДВ) * Complex.I - ╧Б = -((╬╡ : тДВ) * Complex.I) by ring,
      norm_neg, norm_mul, Complex.norm_I, mul_one]
  show тАЦ((╬╡ : тДЭ) : тДВ)тАЦ < ╬┤
  rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos h╬╡_pos]
  have h╬╡_lt_half : ╬╡ < ╬┤ / 2 := lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
  linarith

/-- **PROVED тАФ eventually-in-neighborhood propagates to a nhd of the probe.**
Strengthening of `eventually_nhds_implies_probe_eventually`: not only does
`P` hold *at* the probe `╧Б тИТ ╬╡┬╖I`, it holds on an entire neighbourhood of
it. This is the form needed when feeding the data into Mathlib lemmas of
the shape `Filter.EventuallyEq.deriv_eq`, which require eventual equality
*at* the differentiation point. -/
theorem eventually_nhds_implies_probe_eventually_nhds
    {P : тДВ тЖТ Prop} {╧Б : тДВ}
    (hP : тИАс╢а z in ЁЭУЭ ╧Б, P z)
    (hupper : 0 < ╧Б.im) :
    тИГ ╬╡0 : тДЭ, 0 < ╬╡0 тИз ╬╡0 < ╧Б.im тИз
      тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
        тИАс╢а z in ЁЭУЭ (╧Б - (╬╡ : тДВ) * Complex.I), P z := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain тЯи╬┤, h╬┤_pos, h╬┤тЯй := hP
  refine тЯиmin (╬┤ / 2) (╧Б.im / 2), ?_, ?_, ?_тЯй
  ┬╖ exact lt_min (by linarith) (by linarith)
  ┬╖ exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬╡ h╬╡_pos h╬╡_lt
  have h╬╡_lt_half : ╬╡ < ╬┤ / 2 := lt_of_lt_of_le h╬╡_lt (min_le_left _ _)
  rw [Metric.eventually_nhds_iff]
  refine тЯи╬┤ / 4, by linarith, ?_тЯй
  intro w hw
  apply h╬┤
  have hprobe_dist : dist (╧Б - (╬╡ : тДВ) * Complex.I) ╧Б = ╬╡ := by
    rw [dist_eq_norm,
        show ╧Б - (╬╡ : тДВ) * Complex.I - ╧Б = -((╬╡ : тДВ) * Complex.I) by ring,
        norm_neg, norm_mul, Complex.norm_I, mul_one]
    show тАЦ((╬╡ : тДЭ) : тДВ)тАЦ = ╬╡
    rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos h╬╡_pos]
  calc dist w ╧Б
        тЙд dist w (╧Б - (╬╡ : тДВ) * Complex.I) +
            dist (╧Б - (╬╡ : тДВ) * Complex.I) ╧Б := dist_triangle _ _ _
    _ < ╬┤ / 4 + ╬╡ := by linarith
    _ < ╬┤ := by linarith

/-- **Entire-function local pole-decomposition hypothesis.** At every
upper-half-plane zero of `F`, the local pole structure is good enough
to supply a `LocalLogDerivPoleDecomposition` for `╬Ы[F]`. This is the
entire-function analogue of ┬з7's `PolynomialPoleWitnessHypothesis`.

Constructively building an inhabitant of this structure from the natural
factorization data `тИАс╢а z in ЁЭУЭ ╧Б, F z = (z тИТ ╧Б)^m ┬╖ g z` (with `g(╧Б) тЙа 0`
and `g` analytic) is the CXXXV next-phase target тАФ see ┬з13. -/
structure EntireLocalPoleDecompositionHypothesis (F : тДВ тЖТ тДВ) : Prop where
  decomp_at_each_upper_zero :
    тИА ╧Б : тДВ, F ╧Б = 0 тЖТ 0 < ╧Б.im тЖТ
      Nonempty (LocalLogDerivPoleDecomposition (logDerivativeResponse F) ╧Б)

/-- **PROVED тАФ entire-function pole-decomposition hypothesis discharges
the abstract `LogDerivPoleWitnessLaw`.** One-line composition with ┬з5's
`localLogDerivPoleDecomposition_forces_escape`. -/
theorem entireLocalPoleDecomposition_gives_poleWitness
    {F : тДВ тЖТ тДВ} (H : EntireLocalPoleDecompositionHypothesis F) :
    LogDerivPoleWitnessLaw F (logDerivativeResponse F) where
  upper_zero_forces_escape := by
    intro ╧Б hzero hupper
    obtain тЯиDтЯй := H.decomp_at_each_upper_zero ╧Б hzero hupper
    exact localLogDerivPoleDecomposition_forces_escape D

/-- тнР **PROVED тАФ ENTIRE-FUNCTION TEMPLATE THEOREM.** For any function `F`
satisfying the entire-function local pole-decomposition hypothesis,
anti-Herglotz log-derivative plus Schwarz symmetry тЯ╣ every zero of `F`
is real. This is the entire-function analogue of ┬з7's polynomial
finite RH-equivalence.

Inhabiting `EntireLocalPoleDecompositionHypothesis F` for any analytic
`F` reduces to the local factorization at each zero plus the bounded
background тАФ both standard complex analysis, handled by ┬з8's reusable
`continuousAt_implies_probe_bounded`. -/
theorem entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    (F : тДВ тЖТ тДВ)
    (H : EntireLocalPoleDecompositionHypothesis F)
    (hanti : AntiHerglotzUHP (logDerivativeResponse F))
    (hsym : тИА z : тДВ, F (star z) = star (F z)) :
    тИА ╧Б : тДВ, F ╧Б = 0 тЖТ ╧Б.im = 0 :=
  antiHerglotz_plus_symmetry_forces_real_zeros_complex
    (entireLocalPoleDecomposition_gives_poleWitness H) hanti hsym

-- =====================================================================
-- ┬з10-bis. Local analytic factorization тЖТ pole-decomposition
--          (CXXXIV-A: entire-function analogue of ┬з9)
-- =====================================================================
-- Replays the ┬з9 polynomial bridge one level up:
--
--   ┬з9  (polynomial):
--     polynomial factor data           тЖТ  LocalLogDerivPoleDecomposition
--     PolynomialPoleWitnessHypothesis  (discharged unconditionally in ┬з9)
--
--   ┬з10-bis (entire-function):
--     LocalAnalyticZeroFactorization F ╧Б        (per-zero analytic data)
--     EntireZeroFactorizationHypothesis F       (quantified over zeros)
--     EntireLocalPoleDecompositionHypothesis F  (the ┬з10 target)
--
-- The only genuinely-new analytic content is `logDeriv_of_eventual_factorization`,
-- which lifts ┬з5's algebraic `complex_local_pole_decomposition_general` through
-- `Filter.EventuallyEq.deriv_eq` to the value form
--
--     ╬Ы[F](z) = m/(z тИТ ╧Б) + g'(z)/g(z).
--
-- Once an analytic `F` (e.g. `XiPullback`) supplies a `LocalAnalyticZeroFactorization`
-- at each upper-half-plane zero, the ┬з10 template `entire_function_roots_real_тАж`
-- becomes hypothesis-free for that `F`.

/-- **Local analytic factorization data at a zero.** Records the standard
analytic factorization
   F z = (z тИТ ╧Б)^m ┬╖ g z   eventually near ╧Б,
with `m тЙе 1`, `g` nonvanishing at `╧Б`, `g` differentiable on a neighbourhood
of `╧Б`, and the log-derivative background `g'/g` continuous at `╧Б`.

This is the natural complex-analytic input that any function holomorphic
on a neighbourhood of an isolated zero of multiplicity `m` provides. -/
structure LocalAnalyticZeroFactorization (F : тДВ тЖТ тДВ) (╧Б : тДВ) where
  m : тДХ
  hm_pos : 0 < m
  g : тДВ тЖТ тДВ
  hg╧Б : g ╧Б тЙа 0
  hg_diff_nhds : тИАс╢а z in ЁЭУЭ ╧Б, DifferentiableAt тДВ g z
  hcont_background : ContinuousAt (fun z => deriv g z / g z) ╧Б
  hfactor : тИАс╢а z in ЁЭУЭ ╧Б, F z = (z - ╧Б) ^ m * g z

/-- **PROVED тАФ log-derivative of an eventual factorization.**
If `F` agrees on a neighbourhood of `z` with `(┬╖ тИТ ╧Б)^m ┬╖ g` (with `m тЙе 1`,
`z тЙа ╧Б`, `g z тЙа 0`, `g` differentiable at `z`), then the algebraic identity
of ┬з5 transfers to the actual log-derivative response:

  `╬Ы[F](z)  =  m / (z тИТ ╧Б)  +  g'(z) / g(z)`.

Mechanism: `Filter.EventuallyEq.deriv_eq` rewrites `deriv F z` to the
derivative of the factored form; the product/power rules compute the
latter; ┬з5's `complex_local_pole_decomposition_general` reduces the
resulting algebraic ratio. -/
theorem logDeriv_of_eventual_factorization
    {F g : тДВ тЖТ тДВ} {╧Б z : тДВ} {m : тДХ}
    (hm : 0 < m)
    (hz╧Б : z тЙа ╧Б)
    (hgz : g z тЙа 0)
    (hF_eq : F =с╢а[ЁЭУЭ z] fun w => (w - ╧Б) ^ m * g w)
    (hgdiff : DifferentiableAt тДВ g z) :
    logDerivativeResponse F z =
      ((m : тДХ) : тДВ) / (z - ╧Б) + deriv g z / g z := by
  -- Rewrite m as k+1 to mesh with the ┬з5 general lemma.
  obtain тЯиk, rflтЯй : тИГ k, m = k + 1 := тЯиm - 1, by omegaтЯй
  -- Value of F at z.
  have hF_val : F z = (z - ╧Б) ^ (k + 1) * g z := hF_eq.eq_of_nhds
  -- Derivative of (┬╖тИТ╧Б)^(k+1) at z, then product with g.
  have h_sub : HasDerivAt (fun w : тДВ => w - ╧Б) 1 z := by
    simpa using (hasDerivAt_id z).sub_const ╧Б
  have h_pow : HasDerivAt (fun w : тДВ => (w - ╧Б) ^ (k + 1))
                (((k + 1 : тДХ) : тДВ) * (z - ╧Б) ^ k) z := by
    have h := h_sub.pow (k + 1)
    simpa using h
  have hg : HasDerivAt g (deriv g z) z := hgdiff.hasDerivAt
  have h_prod : HasDerivAt (fun w : тДВ => (w - ╧Б) ^ (k + 1) * g w)
                  (((k + 1 : тДХ) : тДВ) * (z - ╧Б) ^ k * g z +
                    (z - ╧Б) ^ (k + 1) * deriv g z) z := h_pow.mul hg
  have h_F_deriv : deriv F z =
      ((k + 1 : тДХ) : тДВ) * (z - ╧Б) ^ k * g z +
        (z - ╧Б) ^ (k + 1) * deriv g z := by
    rw [hF_eq.deriv_eq]; exact h_prod.deriv
  unfold logDerivativeResponse
  rw [h_F_deriv, hF_val]
  exact complex_local_pole_decomposition_general z ╧Б (g z) (deriv g z) k hz╧Б hgz

/-- **PROVED тАФ building `LocalLogDerivPoleDecomposition` from a
