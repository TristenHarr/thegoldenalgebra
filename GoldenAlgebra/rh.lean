/-! ### Guarded tail-limit structures -/

/-- ЁЯУж **Guarded mid tail-limit.** Same as `XiCanonicalResidualAsTailLimit`
but the Tendsto target identity is only asserted at `z` with
`XiPullback z тЙа 0`. At totalized zeros the identity has no chance of
holding (the LHS integral is continuous in `z`, the RHS is the forced
value `тИТM.model(╧Б)`), so this guard is what makes the hypothesis
genuinely weaker than RH. -/
structure XiCanonicalResidualAsTailLimitAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  tendsto_canonical :
    тИА {z : тДВ},
      0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      XiPullback z тЙа 0 тЖТ
      Tendsto
        (fun X : тДЭ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z)
        Filter.atTop
        (ЁЭУЭ (xiResidualError M z))

/-- ЁЯУж **Guarded high tail-limit.** -/
structure XiHighResidualAsTailLimitAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  tendsto_high :
    тИА {z : тДВ} {T : тДЭ},
      140 тЙд T тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      XiPullback z тЙа 0 тЖТ
      Tendsto
        (fun X : тДЭ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop
        (ЁЭУЭ (xiResidualError M z))

/-- **Old unguarded mid tail-limit тЗТ guarded.** Trivial weakening. -/
theorem XiCanonicalResidualAsTailLimitAwayFromZeros_of_unguarded
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiCanonicalResidualAsTailLimit Dzero T0 M) :
    XiCanonicalResidualAsTailLimitAwayFromZeros Dzero T0 M :=
  тЯиfun hz hmid _ => H.tendsto_canonical hz hmidтЯй

/-- **Old unguarded high tail-limit тЗТ guarded.** Trivial weakening. -/
theorem XiHighResidualAsTailLimitAwayFromZeros_of_unguarded
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiHighResidualAsTailLimit Dzero T0 M) :
    XiHighResidualAsTailLimitAwayFromZeros Dzero T0 M :=
  тЯиfun hT hy hreg _ => H.tendsto_high hT hy hregтЯй

/-! ### Guarded formula-data structures -/

/-- ЁЯУж **Guarded mid formula data.** Same as `XiResidualCanonicalFormulaData`
but the residual-equals-canonical-tail identity only holds at
`XiPullback z тЙа 0`. -/
structure XiResidualCanonicalFormulaDataAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_canonical_tail :
    тИА {z : тДВ},
