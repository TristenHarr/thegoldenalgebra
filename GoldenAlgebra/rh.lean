    XiHighResidualFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_140 M hHighLog := by
  refine вЯ®?_вЯ©
  intro z T hT140 hy hregime hne
  have hSlogEnv : вИАбґ† u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  have h_res_im :
      Tendsto
        (fun X : вДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop (рЭУЭ (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp
      (H.tendsto_high hT140 hy hregime hne)
  have h_tail_tendsto :=
    trueKernelTailOfLogEnvelope_tendsto
      Dzero T0 hT0_pos
      (le_trans hT0_le_140 hT140)
      (by linarith : (0 : вДЭ) < T) hy hSlogEnv
  have h_tail_im :
      Tendsto
        (fun X : вДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop
        (рЭУЭ (trueKernelTailOfLogEnvelope
          Dzero T0 hT0_pos
          (le_trans hT0_le_140 hT140)
          (by linarith : (0 : вДЭ) < T) hy hSlogEnv).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

