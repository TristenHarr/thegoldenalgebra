-- =====================================================================
-- ¬ІCCLXXXIV. Bounded low IBP internal pieces
-- =====================================================================
-- Build the bounded-interval analogues of the mid/high IBP objects for
-- the first-zero gap `[T, ќ≥]`. Concretely:
--
--   (A) `abs_pairedCauchyImKernel_adaptive_8` вАФ boundary kernel bound
--       `|k(T)| вЙ§ 8y/T¬≤` on the adaptive regime `2(1 + |x| + y) вЙ§ T`.
--   (B) `lowFirstZeroIBPIntegrand` вАФ the bounded IBP integrand
--       `S(u) ¬Ј k'(u)` with `S := Phase1IBP.finiteFluctuationPrimitive`.
--   (C) `lowFirstZeroDerivativeSide` вАФ bounded integral over `[T, ќ≥]`
--       with a `rfl` bridge to `Phase1IBP.derivativeSidePartial`.
--   (D) `lowFirstZeroBoundaryTerm` вАФ `k(T) ¬Ј S(T)` boundary product.
--   (E) `lowFirstZeroBoundaryTerm_abs_le` вАФ boundary absolute bound
--       `вЙ§ 8 y D / T¬≤` under `|S(T)| вЙ§ D` + adaptive regime.
--   (F) `integral_eighteen_y_D_over_u3` вАФ FTC evaluation
--       `вИЂ_T^ќ≥ 18yD/u¬≥ = 9yD/T¬≤ вИТ 9yD/ќ≥¬≤`.
--   (G) `lowFirstZeroDerivativeSide_abs_le_majorant` вАФ derivative-side
--       absolute bound `вЙ§ 9 y D / T¬≤ вИТ 9 y D / ќ≥¬≤` under pointwise
--       `|S| вЙ§ D`, adaptive regime, and integrability.
--   (H) `lowFirstZeroIBP_sum_le_closedForm` вАФ combined bound
--       `|boundary| + |derivative| вЙ§ closedFormFirstZeroErrorBound y T ќ≥ D`
--       via the existing `slabIBP_sum_le_closedFormFirstZeroErrorBound`.

/-- в≠Р **PROVED вАФ adaptive `8y/T¬≤` kernel bound** at the boundary.
On the adaptive regime `2(1 + |x| + y) вЙ§ T`,
`|pairedCauchyImKernel x y T| вЙ§ 8 ¬Ј y / T¬≤`. -/
lemma abs_pairedCauchyImKernel_adaptive_8
    {x y T : вДЭ} (hy : 0 вЙ§ y) (h_reg : 2 * (1 + |x| + y) вЙ§ T) :
    |pairedCauchyImKernel x y T| вЙ§ 8 * y / T ^ 2 := by
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_x_lt_T : |x| < T := by linarith
  have h_kbnd : |pairedCauchyImKernel x y T| вЙ§ 2 * y / (T - |x|) ^ 2 :=
    Phase1IBP.abs_pairedCauchyImKernel_le_quadratic_tail x y T hy h_x_lt_T
  have h_T_minus_x_ge : T / 2 вЙ§ T - |x| := by linarith
  have h_T_minus_x_nn : (0 : вДЭ) вЙ§ T / 2 := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_sq_ge : (T / 2) ^ 2 вЙ§ (T - |x|) ^ 2 :=
    pow_le_pow_leftвВА h_T_minus_x_nn h_T_minus_x_ge 2
  have h_half_sq_eq : (T / 2) ^ 2 = T ^ 2 / 4 := by ring
  rw [h_half_sq_eq] at h_sq_ge
  have h_sq_pos : 0 < (T - |x|) ^ 2 := pow_pos h_T_minus_x_pos 2
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_target : 2 * y / (T - |x|) ^ 2 вЙ§ 8 * y / T ^ 2 := by
    rw [div_le_div_iffвВА h_sq_pos h_T_sq_pos]
    nlinarith [h_sq_ge, hy]
  linarith

/-- **Bounded low IBP integrand**: `S(u) ¬Ј k'(u)` with
`S := Phase1IBP.finiteFluctuationPrimitive Dzero T0`. -/
noncomputable def lowFirstZeroIBPIntegrand
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y : вДЭ) :
    вДЭ вЖТ вДЭ :=
  fun u =>
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
      pairedCauchyImKernelDeriv x y u

/-- **Bounded low IBP derivative-side integral** over `[T, ќ≥]`. -/
noncomputable def lowFirstZeroDerivativeSide
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T ќ≥ : вДЭ) : вДЭ :=
  вИЂ u in T..ќ≥, lowFirstZeroIBPIntegrand Dzero T0 x y u

/-- в≠Р **PROVED вАФ `rfl` bridge to `Phase1IBP.derivativeSidePartial`.** -/
lemma lowFirstZeroDerivativeSide_eq_partial
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T ќ≥ : вДЭ) :
    lowFirstZeroDerivativeSide Dzero T0 x y T ќ≥ =
      Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) x y T ќ≥ :=
  rfl

/-- **Bounded low IBP boundary term**: `k(T) ¬Ј S(T)`. -/
noncomputable def lowFirstZeroBoundaryTerm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T : вДЭ) : вДЭ :=
  pairedCauchyImKernel x y T *
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 T

/-- в≠Р **PROVED вАФ boundary absolute bound `вЙ§ 8 y D / T¬≤`** under
`|S(T)| вЙ§ D` and the adaptive regime. -/
theorem lowFirstZeroBoundaryTerm_abs_le
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T D : вДЭ}
    (hy : 0 вЙ§ y)
    (h_reg : 2 * (1 + |x| + y) вЙ§ T)
    (hS_T : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T| вЙ§ D) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T| вЙ§ 8 * y * D / T ^ 2 := by
  unfold lowFirstZeroBoundaryTerm
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_k_bnd : |pairedCauchyImKernel x y T| вЙ§ 8 * y / T ^ 2 :=
    abs_pairedCauchyImKernel_adaptive_8 hy h_reg
  have h_k_nn : 0 вЙ§ 8 * y / T ^ 2 := by positivity
  have h_D_nn : 0 вЙ§ D := le_trans (abs_nonneg _) hS_T
  rw [abs_mul]
  calc |pairedCauchyImKernel x y T|
        * |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T|
      вЙ§ (8 * y / T ^ 2) * D :=
        mul_le_mul h_k_bnd hS_T (abs_nonneg _) h_k_nn
    _ = 8 * y * D / T ^ 2 := by ring

/-- в≠Р **PROVED вАФ FTC evaluation of the majorant integral**:
`вИЂ_T^ќ≥ 18¬Јy¬ЈD/u¬≥ du = 9¬Јy¬ЈD/T¬≤ вИТ 9¬Јy¬ЈD/ќ≥¬≤`.

Antiderivative `F(u) := вИТ9¬Јy¬ЈD/u¬≤`, with `F'(u) = 18¬Јy¬ЈD/u¬≥` for `u вЙ† 0`.
Applies `intervalIntegral.integral_eq_sub_of_hasDerivAt`. -/
lemma integral_eighteen_y_D_over_u3
    {y D T ќ≥ : вДЭ} (hT_pos : 0 < T) (hTќ≥ : T вЙ§ ќ≥) :
    вИЂ u in T..ќ≥, 18 * y * D / u ^ 3
      = 9 * y * D / T ^ 2 - 9 * y * D / ќ≥ ^ 2 := by
  have hќ≥_pos : 0 < ќ≥ := lt_of_lt_of_le hT_pos hTќ≥
  have h_deriv : вИА u вИИ Set.uIcc T ќ≥,
      HasDerivAt (fun v : вДЭ => -9 * y * D / v ^ 2)
        (18 * y * D / u ^ 3) u := by
    intro u hu
    rw [Set.uIcc_of_le hTќ≥] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    have hu_ne : u вЙ† 0 := ne_of_gt hu_pos
    have hu_sq_ne : u ^ 2 вЙ† 0 := pow_ne_zero 2 hu_ne
    have h_num : HasDerivAt (fun _ : вДЭ => -9 * y * D) 0 u :=
      hasDerivAt_const u _
    have h_den : HasDerivAt (fun v : вДЭ => v ^ 2)
                  ((2 : вДХ) * u ^ (2 - 1)) u :=
      hasDerivAt_pow 2 u
    have h_div_raw : HasDerivAt
        (fun v : вДЭ => -9 * y * D / v ^ 2)
        ((0 * u ^ 2 - (-9 * y * D) * ((2 : вДХ) * u ^ (2 - 1))) / (u ^ 2) ^ 2) u :=
      h_num.div h_den hu_sq_ne
    convert h_div_raw using 1
    have hu_cube_ne : u ^ 3 вЙ† 0 := pow_ne_zero 3 hu_ne
    field_simp
    ring
  have h_cont : ContinuousOn (fun u : вДЭ => 18 * y * D / u ^ 3)
                  (Set.uIcc T ќ≥) := by
    rw [Set.uIcc_of_le hTќ≥]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_int : IntervalIntegrable (fun u : вДЭ => 18 * y * D / u ^ 3)
                MeasureTheory.volume T ќ≥ :=
    h_cont.intervalIntegrable
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int]
  ring

/-- рЯМЯ **PROVED вАФ derivative-side absolute bound** `вЙ§ 9 y D / T¬≤ вИТ 9 y D / ќ≥¬≤`
under pointwise `|S| вЙ§ D`, the adaptive regime, and integrability of
`|S ¬Ј k'|`. -/
theorem lowFirstZeroDerivativeSide_abs_le_majorant
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    {x y T ќ≥ D : вДЭ}
    (hy : 0 < y)
    (h_reg : 2 * (1 + |x| + y) вЙ§ T)
    (hTќ≥ : T вЙ§ ќ≥)
    (hD : 0 вЙ§ D)
    (hS : вИА u, T вЙ§ u вЖТ u вЙ§ ќ≥ вЖТ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| вЙ§ D)
    (hSint : IntervalIntegrable
              (fun u => |lowFirstZeroIBPIntegrand Dzero T0 x y u|)
              MeasureTheory.volume T ќ≥) :
    |lowFirstZeroDerivativeSide Dzero T0 x y T ќ≥|
      вЙ§ 9 * y * D / T ^ 2 - 9 * y * D / ќ≥ ^ 2 := by
  unfold lowFirstZeroDerivativeSide
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_abs_int :
      |вИЂ u in T..ќ≥, lowFirstZeroIBPIntegrand Dzero T0 x y u|
        вЙ§ вИЂ u in T..ќ≥, |lowFirstZeroIBPIntegrand Dzero T0 x y u| :=
    intervalIntegral.abs_integral_le_integral_abs hTќ≥
  have h_pointwise : вИА u вИИ Set.Icc T ќ≥,
      |lowFirstZeroIBPIntegrand Dzero T0 x y u| вЙ§ 18 * y * D / u ^ 3 := by
    intro u hu
    obtain вЯ®huT, huќ≥вЯ© := hu
    unfold lowFirstZeroIBPIntegrand
    rw [abs_mul]
    have hS_u : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| вЙ§ D :=
      hS u huT huќ≥
    have h_k_bnd : |pairedCauchyImKernelDeriv x y u| вЙ§ 18 * y / u ^ 3 :=
      abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le h_reg huT
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos huT
    have h_k_nn : 0 вЙ§ 18 * y / u ^ 3 := by positivity
    calc |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          * |pairedCauchyImKernelDeriv x y u|
        вЙ§ D * (18 * y / u ^ 3) :=
          mul_le_mul hS_u h_k_bnd (abs_nonneg _) hD
      _ = 18 * y * D / u ^ 3 := by ring
  have h_maj_cont : ContinuousOn (fun u : вДЭ => 18 * y * D / u ^ 3)
                      (Set.uIcc T ќ≥) := by
    rw [Set.uIcc_of_le hTќ≥]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_maj_int : IntervalIntegrable (fun u : вДЭ => 18 * y * D / u ^ 3)
                    MeasureTheory.volume T ќ≥ :=
    h_maj_cont.intervalIntegrable
  have h_int_mono :
      вИЂ u in T..ќ≥, |lowFirstZeroIBPIntegrand Dzero T0 x y u|
        вЙ§ вИЂ u in T..ќ≥, 18 * y * D / u ^ 3 :=
    intervalIntegral.integral_mono_on hTќ≥ hSint h_maj_int h_pointwise
  have h_maj_eval :
      вИЂ u in T..ќ≥, 18 * y * D / u ^ 3
        = 9 * y * D / T ^ 2 - 9 * y * D / ќ≥ ^ 2 :=
    integral_eighteen_y_D_over_u3 hT_pos hTќ≥
  linarith [h_abs_int, h_int_mono, h_maj_eval]

/-- рЯМЯрЯМЯ **PROVED вАФ closed-form combination** of boundary + derivative
absolute bounds. Direct composition with
`slabIBP_sum_le_closedFormFirstZeroErrorBound`. -/
theorem lowFirstZeroIBP_sum_le_closedForm
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T ќ≥ D : вДЭ}
    (hbdy :
      |lowFirstZeroBoundaryTerm Dzero T0 x y T| вЙ§ 8 * y * D / T ^ 2)
    (hderiv :
      |lowFirstZeroDerivativeSide Dzero T0 x y T ќ≥|
        вЙ§ 9 * y * D / T ^ 2 - 9 * y * D / ќ≥ ^ 2) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T|
      + |lowFirstZeroDerivativeSide Dzero T0 x y T ќ≥|
        вЙ§ closedFormFirstZeroErrorBound y T ќ≥ D :=
  slabIBP_sum_le_closedFormFirstZeroErrorBound hbdy hderiv

