-- =====================================================================
-- §CCCXVI. ξ-side Hadamard source + bridge through chain rule
-- =====================================================================
-- The Hadamard product theorem is naturally stated for the completed
-- ξ on the s-plane. The chain rule `XiPullback_logDeriv_chain_rule`
-- converts to the z-plane pullback. This section adds the ξ-side
-- source Prop and bridges it to `XiHadamardLogDerivativeSourceAFZ`.
--
-- Note on differentiability: `completedXiFunction` (Γ-based) is NOT
-- automatically differentiable at every `1/2 + I·z` with `0 < z.im`
-- — Γ has poles at non-positive integers and the trivial-zero
-- cancellation isn't built into the definition. The ξ-side source
-- carries differentiability AFZ as a field; concrete inhabitants
-- discharge it via the Hadamard product factorization or by
-- bridging to Mathlib's `entireRiemannXi`.

/-- 📦 **`CompletedXiLogDerivativeSourceAFZ`** — ξ-side Hadamard source
on the s-plane. -/
structure CompletedXiLogDerivativeSourceAFZ : Type where
  xiZeroContribution : ℂ → ℂ
  xi_diff_at :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ completedXiFunction s
  xi_logDeriv_eq :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      logDerivativeResponse completedXiFunction s = xiZeroContribution s

/-- **Pullback of the ξ-side zero contribution to the z-plane.**
`Λ[Ξ] = I · Λ[ξ](½ + I·z)` from the chain rule. -/
noncomputable def pullbackZeroContribution
    (H : CompletedXiLogDerivativeSourceAFZ) : ℂ → ℂ :=
  fun z => Complex.I * H.xiZeroContribution ((1 / 2 : ℂ) + Complex.I * z)

/-- 🌟🌟🌟 **PROVED — z-plane AFZ Hadamard source from ξ-side AFZ
source via chain rule.** -/
noncomputable def XiHadamardLogDerivativeSourceAFZ_of_completedXi
    (H : CompletedXiLogDerivativeSourceAFZ) :
    XiHadamardLogDerivativeSourceAFZ :=
  { zeroContribution := pullbackZeroContribution H
    logDeriv_eq_zeroContribution := by
      intro z _hy hne
      have hs_ne :
          completedXiFunction ((1 / 2 : ℂ) + Complex.I * z) ≠ 0 := by
        unfold XiPullback at hne
        exact hne
      have hxi_diff := H.xi_diff_at _ hs_ne
      have hchain := XiPullback_logDeriv_chain_rule hxi_diff
      have h_logderiv := H.xi_logDeriv_eq _ hs_ne
      unfold logDerivativeResponse at h_logderiv
      rw [hchain]
      unfold pullbackZeroContribution
      rw [h_logderiv] }

