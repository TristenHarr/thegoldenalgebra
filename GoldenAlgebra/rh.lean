-- All constants are rational; the only log work is one helper
-- `log(T/(2ѕА)) вЙ• 3/10` for `T вЙ• 9`, which discharges via
-- `Real.add_one_le_exp (-0.3)` вЖТ `exp(0.3) вЙ§ 10/7 вЙ§ 9/(2ѕА)`.

/-- в≠Р **PROVED вАФ `log(T/(2ѕА)) вЙ• 3/10` for `T вЙ• 9`.**

Chain: `Real.add_one_le_exp(-0.3) вЯє 7/10 вЙ§ exp(-0.3) = 1/exp(0.3) вЯє
exp(0.3) вЙ§ 10/7`. With `ѕА вЙ§ 3.15`: `9/(2ѕА) вЙ• 10/7 вЙ• exp(0.3)`. Then
`log` monotonicity gives `log(T/(2ѕА)) вЙ• log(exp(0.3)) = 0.3`. -/
theorem log_T_div_2pi_ge_3_10_of_ge_9
    {T : вДЭ} (hT : 9 вЙ§ T) :
    (3 / 10 : вДЭ) вЙ§ Real.log (T / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_03_pos : 0 < Real.exp 0.3 := Real.exp_pos 0.3
  have h_one_sub : (-0.3 : вДЭ) + 1 вЙ§ Real.exp (-0.3) := Real.add_one_le_exp (-0.3)
  have h_07 : (7 / 10 : вДЭ) вЙ§ Real.exp (-0.3) := by linarith
  rw [Real.exp_neg] at h_07
  have h_07_mul : (7 / 10 : вДЭ) * Real.exp 0.3 вЙ§ 1 := by
    have := mul_le_mul_of_nonneg_right h_07 (le_of_lt h_exp_03_pos)
    rwa [inv_mul_cancelвВА (ne_of_gt h_exp_03_pos)] at this
  have h_exp_03_le : Real.exp 0.3 вЙ§ 10 / 7 := by linarith
  have h_T_2pi_ge : (10 / 7 : вДЭ) вЙ§ T / (2 * Real.pi) := by
    rw [le_div_iffвВА h_2pi_pos]
    nlinarith
  have h_T_2pi_ge_exp : Real.exp 0.3 вЙ§ T / (2 * Real.pi) :=
    le_trans h_exp_03_le h_T_2pi_ge
  have h_log_ge : Real.log (Real.exp 0.3) вЙ§ Real.log (T / (2 * Real.pi)) :=
    Real.log_le_log h_exp_03_pos h_T_2pi_ge_exp
  rw [Real.log_exp] at h_log_ge
  linarith

/-- в≠Р **PROVED вАФ `cert_9_10_real`.** The first REAL (non-demo)
first-zero sub-cert: `closedFormSErrorBoundCD 0 (1/100) y T вЙ§
вИТIm(cloudModel [] z + demoDensityTailT T z)` for any admissible probe
in `[9, 10]`.

Uses the empty cloud (simplest viable choice on `[9, 10]`); the proof
chain is `LHS вЙ§ 17¬Јy/8100 вЙ§ 11¬Јy/1575 вЙ§ smoothTail вЙ§ вИТIm(model)`, each
step a tiny rational arithmetic or one Lean lemma. -/
theorem cert_9_10_real :
    вИА z : вДВ, вИА T : вДЭ,
      9 вЙ§ T вЖТ T вЙ§ 10 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        closedFormSErrorBoundCD 0 (1 / 100 : вДЭ) z.im T
          вЙ§ -((cloudModel [] z + demoDensityTailT T z).im) := by
  intro z T hT9 hT10 hy hreg
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have hT_2pi : 2 * Real.pi вЙ§ T := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 вЙ§ z.im := le_of_lt hy
  have h_cloud_zero : (cloudModel ([] : List вДЭ) z).im = 0 := by
    simp [cloudModel]
  have htail := demoDensityTailT_neg_im T z
  have h_split :
      -((cloudModel ([] : List вДЭ) z + demoDensityTailT T z).im)
        = -(cloudModel ([] : List вДЭ) z).im + -(demoDensityTailT T z).im := by
    rw [Complex.add_im]; ring
  have h_log_lb := log_T_div_2pi_ge_3_10_of_ge_9 hT9
  -- ѕБ(T) вЙ• 1/21 (using log(T/(2ѕА)) вЙ• 3/10 and ѕА вЙ§ 3.15)
  have h_rho_ge : (1 / 21 : вДЭ) вЙ§ zeroDensityRho T := by
    unfold zeroDensityRho
    have h_2pi_pos : (0 : вДЭ) < 2 * Real.pi := by linarith
    rw [show (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
          = Real.log (T / (2 * Real.pi)) / (2 * Real.pi) by ring,
        le_div_iffвВА h_2pi_pos]
    nlinarith [h_log_lb, h_pi_lt]
  -- (22/15)¬ЈѕБ(T)¬Јy/T вЙ§ smoothTail (from CLV)
  have h_smooth_22_15 := smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg
  -- 11¬Јy/1575 вЙ§ (22/15)¬ЈѕБ(T)¬Јy/T (key constant + T вЙ§ 10 step)
  have h_smooth_linear :
      (11 / 1575 : вДЭ) * z.im
        вЙ§ (22 / 15 : вДЭ) * zeroDensityRho T * z.im / T := by
    have h_rho_nn : 0 вЙ§ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT_2pi
    rw [le_div_iffвВА hT_pos]
    -- want (11/1575)¬Јy¬ЈT вЙ§ (22/15)¬ЈѕБ(T)¬Јy
    -- вЯЇ 11¬Ј15¬Јy¬ЈT вЙ§ 1575¬Ј22¬ЈѕБ(T)¬Јy  (positive scaling)
    -- вЯЇ 165¬Јy¬ЈT вЙ§ 34650¬ЈѕБ(T)¬Јy       (= 11¬Ј15 vs 1575¬Ј22)
    -- T вЙ§ 10 вЖТ 165¬Јy¬ЈT вЙ§ 1650¬Јy; ѕБ(T) вЙ• 1/21 вЖТ 34650¬ЈѕБ(T)¬Јy вЙ• 1650¬Јy. вЬУ
    nlinarith [h_rho_ge, hT10, hT_pos, hy_nn,
               mul_nonneg hy_nn h_rho_nn,
               mul_nonneg hy_nn (le_of_lt hT_pos)]
  have h_smooth_lb :
      (11 / 1575 : вДЭ) * z.im вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T :=
    le_trans h_smooth_linear h_smooth_22_15
  -- LHS = 17¬Јy/(100¬ЈT¬≤)
  have h_lhs_eq :
      closedFormSErrorBoundCD 0 (1/100 : вДЭ) z.im T
        = 17 * z.im / (100 * T^2) := by
    unfold closedFormSErrorBoundCD
    ring
  -- 17¬Јy/(100¬ЈT¬≤) вЙ§ 17¬Јy/8100 (using T¬≤ вЙ• 81)
  have hT_sq_ge : (81 : вДЭ) вЙ§ T^2 := by nlinarith
  have h_lhs_le : 17 * z.im / (100 * T^2) вЙ§ 17 * z.im / 8100 := by
    apply div_le_div_of_nonneg_left (by positivity) (by norm_num) (by nlinarith)
  -- 17¬Јy/8100 вЙ§ 11¬Јy/1575 (rational constant)
  have h_const_step : (17 : вДЭ) * z.im / 8100 вЙ§ 11 * z.im / 1575 := by
    rcases hy_nn.lt_or_eq with hy_pos | hy_zero
    ¬Ј rw [div_le_div_iffвВА (by norm_num : (0:вДЭ) < 8100) (by norm_num : (0:вДЭ) < 1575)]
      nlinarith
    ¬Ј rw [вЖР hy_zero]; simp
  -- Final chain
  rw [h_lhs_eq, h_split, htail, h_cloud_zero]
  linarith [h_lhs_le, h_const_step, h_smooth_lb]

