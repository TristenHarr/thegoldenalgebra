/-! ## AX: Small-square route for the punctured Cauchy-Goursat -/

/-! ### AX1: small axis-aligned square inside the rectangle -/

/-- A small axis-aligned closed square centered at `a` whose interior lies
strictly inside the open rectangle.  The square uses half-side `r` in both
real and imaginary directions. -/
structure SmallSquareInsideRectangle
    (R : ZetaRectangle) (a : Ôäé) where
  r : ÔäØ
  r_pos : 0 < r
  square_subset_open :
    {z : Ôäé | |z.re - a.re| Ôëñ r Ôêº |z.im - a.im| Ôëñ r} Ôèå
      {z : Ôäé | R.ContainsOpen z}

/-! ### AX2: existence from `ContainsOpen a` -/

/-- A point strictly inside the rectangle admits a small interior square. -/
theorem exists_smallSquareInsideRectangle
    {R : ZetaRectangle} {a : Ôäé}
    (ha : R.ContainsOpen a) :
    Nonempty (R.SmallSquareInsideRectangle a) := by
  obtain Ôƒ¿hL, hRt, hB, hTÔƒ® := ha
  set r : ÔäØ :=
    min (min ((a.re - R.left) / 2) ((R.right - a.re) / 2))
      (min ((a.im - R.bottom) / 2) ((R.top - a.im) / 2)) with hr_def
  have hr_pos : 0 < r := by
    refine lt_min (lt_min ?_ ?_) (lt_min ?_ ?_) <;> linarith
  refine Ôƒ¿Ôƒ¿r, hr_pos, ?_Ôƒ®Ôƒ®
  intro z hz
  obtain Ôƒ¿hre_abs, him_absÔƒ® := hz
  obtain Ôƒ¿hre_low, hre_highÔƒ® := abs_le.mp hre_abs
  obtain Ôƒ¿him_low, him_highÔƒ® := abs_le.mp him_abs
  have hr_le_left : r Ôëñ (a.re - R.left) / 2 :=
    (min_le_left _ _).trans (min_le_left _ _)
  have hr_le_right : r Ôëñ (R.right - a.re) / 2 :=
    (min_le_left _ _).trans (min_le_right _ _)
  have hr_le_bottom : r Ôëñ (a.im - R.bottom) / 2 :=
    (min_le_right _ _).trans (min_le_left _ _)
  have hr_le_top : r Ôëñ (R.top - a.im) / 2 :=
    (min_le_right _ _).trans (min_le_right _ _)
  refine Ôƒ¿?_, ?_, ?_, ?_Ôƒ® <;> linarith

/-! ### AX3: the small square as its own `ZetaRectangle` and its unit-kernel
