-- ¬ІCCXCII. `HlowArith` normalization (factor out `y > 0`)
-- =====================================================================
-- Both sides of `LowExplicitArithmeticBound_11_14_half` are linear in
-- `y := z.im`:
--   LHS  `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ¬Ј CвВА`
--          where `CвВА := 17/242 вИТ 9/392 вЙИ 0.0473`,
--   RHS  `simpleCloudSum zeros100ceil x y = y ¬Ј simpleCloudSumNorm ...`
--   RHS  `smoothTailRationalLowerBoundAbs x y 10 = y ¬Ј smoothTailRationalLowerBoundAbsNorm x y 10`.
-- Since `y > 0` on `lowCompactRegion`, dividing both sides by `y`
-- removes the y-scaling and reduces the inequality to a single
-- constant `CвВА вЙ§ simpleCloudSumNorm + smoothTailRationalLowerBoundAbsNorm`
-- вАФ independent of the small-y regime and easier to attack via
-- regional decomposition.
--
-- Adds:
--   simpleCloudSumNorm                            вАФ `ќ£ 2/(x¬≤+ќ≥¬≤+y¬≤)`
--   smoothTailRationalLowerBoundAbsNorm           вАФ smooth LB / y
--   lowArithConst_11_14_half                       вАФ `17/242 вИТ 9/392`
--   simpleCloudSum_eq_y_mul_norm                   вАФ y-factorization
--   smoothTailRationalLowerBoundAbs_eq_y_mul_norm  вАФ y-factorization
--   closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const  вАФ y-factorization
--   LowExplicitArithmeticBoundNorm_11_14_half      вАФ normalized Prop
--   LowExplicitArithmeticBound_11_14_half_of_norm  вАФ bridge from normalized

/-- **Normalized `simpleCloudSum`** вАФ divide out the leading `y` factor:
`ќ£ 2/(x¬≤+ќ≥¬≤+y¬≤)`. -/
noncomputable def simpleCloudSumNorm (zeros : List вДЭ) (x y : вДЭ) : вДЭ :=
  (zeros.map fun g => 2 / (x ^ 2 + g ^ 2 + y ^ 2)).sum

/-- **Normalized `smoothTailRationalLowerBoundAbs`** вАФ divide out the
leading `y` factor:
`ѕБ(T) ¬Ј ((T вИТ |x|)/((T вИТ |x|)¬≤ + y¬≤) + (T + |x|)/((T + |x|)¬≤ + y¬≤))`. -/
noncomputable def smoothTailRationalLowerBoundAbsNorm (x y T : вДЭ) : вДЭ :=
  zeroDensityRho T *
    ((T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + (T + |x|) / ((T + |x|) ^ 2 + y ^ 2))

/-- **Path B arithmetic constant**: `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ¬Ј lowArithConst_11_14_half`.
Equals `17/242 вИТ 9/392 вЙИ 0.0473`. -/
noncomputable def lowArithConst_11_14_half : вДЭ := 17 / 242 - 9 / 392

/-- в≠Р **PROVED вАФ `simpleCloudSum` y-factorization.** -/
lemma simpleCloudSum_eq_y_mul_norm (zeros : List вДЭ) (x y : вДЭ) :
    simpleCloudSum zeros x y = y * simpleCloudSumNorm zeros x y := by
  unfold simpleCloudSum simpleCloudSumNorm
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    rw [ih]
    ring

/-- в≠Р **PROVED вАФ `smoothTailRationalLowerBoundAbs` y-factorization.** -/
lemma smoothTailRationalLowerBoundAbs_eq_y_mul_norm (x y T : вДЭ) :
    smoothTailRationalLowerBoundAbs x y T
      = y * smoothTailRationalLowerBoundAbsNorm x y T := by
  unfold smoothTailRationalLowerBoundAbs smoothTailRationalLowerBoundAbsNorm
  ring

/-- в≠Р **PROVED вАФ `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ¬Ј CвВА`**. -/
lemma closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const (y : вДЭ) :
    closedFormFirstZeroErrorBound y 11 14 (1 / 2)
      = y * lowArithConst_11_14_half := by
  unfold closedFormFirstZeroErrorBound lowArithConst_11_14_half
  ring

/-- рЯУ¶ **`LowExplicitArithmeticBoundNorm_11_14_half`** вАФ y-normalized
arithmetic obligation. Removes the y-scaling and reduces the problem
to a single constant inequality on the compact box. -/
def LowExplicitArithmeticBoundNorm_11_14_half : Prop :=
  вИА z : вДВ,
    lowCompactRegion z вЖТ
    lowArithConst_11_14_half
      вЙ§ simpleCloudSumNorm zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbsNorm z.re z.im 10

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ bridge from normalized to original `HlowArith`.**
Multiplies the normalized inequality by `y > 0` to recover the
y-scaled form. -/
theorem LowExplicitArithmeticBound_11_14_half_of_norm
    (h : LowExplicitArithmeticBoundNorm_11_14_half) :
    LowExplicitArithmeticBound_11_14_half := by
  intro z hz
  have hy : 0 < z.im := hz.1
  have h_norm := h z hz
  -- Rewrite LHS and RHS in y-factored form
  show lowResidualExplicitBoundAt 11 14 (1 / 2) z
        вЙ§ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  show closedFormFirstZeroErrorBound z.im 11 14 (1 / 2)
        вЙ§ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  rw [closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const,
      simpleCloudSum_eq_y_mul_norm,
      smoothTailRationalLowerBoundAbs_eq_y_mul_norm]
  have h_combine :
      z.im * simpleCloudSumNorm zeros100ceil z.re z.im
        + z.im * smoothTailRationalLowerBoundAbsNorm z.re z.im 10
        = z.im * (simpleCloudSumNorm zeros100ceil z.re z.im
                  + smoothTailRationalLowerBoundAbsNorm z.re z.im 10) := by
    ring
  rw [h_combine]
  exact mul_le_mul_of_nonneg_left h_norm (le_of_lt hy)

