-- =====================================================================
-- ┬ºCCLXXXI. Extend `smoothZeroCountingN0` half-bound to `[2¤Ç, 14]`
-- =====================================================================
-- Path B requires `|NÔéÇ(u)| Ôëñ 1/2` on `[2¤Ç, 14]` (since the inner cutoff
-- is `T = 11` and `╬│Ôéü = 14`). The existing `[2¤Ç, 10]` infrastructure
-- (`abs_smoothZeroCountingN0_le_half_on_first_band`) covers only up to
-- 10. This section extends it.
--
-- The proof of the new endpoint `smoothZeroCountingN0_at_14_le_half`
-- adapts the `_at_10_le_half` template: replace the `log(5/¤Ç) Ôëñ log 2`
-- trick (which used `5/¤Ç < 2`) by the tangent-line bound
-- `log(q) Ôëñ log 2 + q/2 ÔêÆ 1` (obtained from
-- `Real.log_le_sub_one_of_pos` applied to `q/2`), valid for any `q > 0`,
-- which is sharper near `q = 2`. Numerical margin to `1/2`: Ôëê 0.068.
--
-- This section does NOT build the xiÔåöfirst-zero bridge ÔÇö that is a
-- separate analytic step. It only provides the clean monotonicity /
-- endpoint extensions needed downstream.
--
-- Adds:
--   smoothZeroCountingN0_at_14_le_half                   ÔÇö NÔéÇ(14) Ôëñ 1/2
--   abs_smoothZeroCountingN0_le_half_on_first_band_param ÔÇö generic [2¤Ç, U]
--   abs_smoothZeroCountingN0_le_half_on_first_band_14    ÔÇö [2¤Ç, 14] specialization
--   firstZeroGapSBound_14_half                           ÔÇö `FirstZeroGapSBound`
--                                                          inhabitant at (╬│Ôéü=14, D=1/2)

/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0(14) Ôëñ 1/2`.**

Chain (with `q := 7/¤Ç`):
* `7/¤Ç Ôêê (2.222, 2.23)` from `Real.pi_lt_d2` / `Real.pi_gt_d2`;
* tangent at `q = 2`: `log q Ôëñ log 2 + q/2 ÔêÆ 1` via
  `Real.log_le_sub_one_of_pos` applied to `q/2`;
* `log 2 Ôëñ 0.6932` via `Real.log_two_lt_d9`;
* `q ┬À q Ôëñ q ┬À 2.23` from `q Ôëñ 2.23`;
* combine: `q ┬À log q Ôëñ q ┬À 0.6932 + q ┬À 1.115 ÔêÆ q = q ┬À 0.8082`;
* `NÔéÇ(14) = q ┬À log q ÔêÆ q + 7/8 Ôëñ ÔêÆ0.1918 ┬À q + 7/8`;
* `q > 2.222 Ôƒ╣ ÔêÆ0.1918 ┬À q < ÔêÆ0.4262`, so `NÔéÇ(14) < 0.449 Ôëñ 1/2`. -/
theorem smoothZeroCountingN0_at_14_le_half :
    smoothZeroCountingN0 14 Ôëñ 1 / 2 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  -- 14/(2¤Ç) = 7/¤Ç
  have h_eq : (14 : ÔäØ) / (2 * Real.pi) = 7 / Real.pi := by ring
  rw [h_eq]
  -- 7/¤Ç positivity and bounds
  have h_7pi_pos : 0 < 7 / Real.pi := by positivity
  have h_7pi_nn : 0 Ôëñ 7 / Real.pi := le_of_lt h_7pi_pos
  -- 7/¤Ç < 2.23 (from ¤Ç > 3.14: 2.23 ┬À 3.14 = 7.0022 > 7)
  have h_7pi_lt : 7 / Real.pi < 2.23 := by
    rw [div_lt_iffÔéÇ h_pi_pos]; linarith
  -- 7/¤Ç > 2.222 (from ¤Ç < 3.15: 2.222 ┬À 3.15 = 6.9993 < 7)
  have h_7pi_gt : (2.222 : ÔäØ) < 7 / Real.pi := by
    rw [lt_div_iffÔéÇ h_pi_pos]; linarith
  -- (7/¤Ç)/2 > 0 for `log_le_sub_one_of_pos`
  have h_7pi_half_pos : 0 < 7 / Real.pi / 2 := by linarith
  -- Tangent at q=2: log(q/2) Ôëñ q/2 - 1
  have h_log_qhalf_le : Real.log (7 / Real.pi / 2) Ôëñ 7 / Real.pi / 2 - 1 :=
    Real.log_le_sub_one_of_pos h_7pi_half_pos
  -- log(q/2) = log q - log 2
  have h_log_div : Real.log (7 / Real.pi / 2)
                = Real.log (7 / Real.pi) - Real.log 2 :=
    Real.log_div (ne_of_gt h_7pi_pos) (by norm_num : (2 : ÔäØ) Ôëá 0)
  -- log q Ôëñ log 2 + q/2 - 1
  have h_log_q_bound :
      Real.log (7 / Real.pi) Ôëñ Real.log 2 + 7 / Real.pi / 2 - 1 := by
    linarith
  -- log 2 Ôëñ 0.6932
  have h_log2_lt : Real.log 2 Ôëñ 0.6932 := by
    have := Real.log_two_lt_d9
    linarith
  -- q ┬À log q Ôëñ q ┬À (log 2 + q/2 - 1) = q ┬À log 2 + q┬▓/2 - q
  have h_mul1 : (7 / Real.pi) * Real.log (7 / Real.pi)
              Ôëñ (7 / Real.pi) * (Real.log 2 + 7 / Real.pi / 2 - 1) :=
    mul_le_mul_of_nonneg_left h_log_q_bound h_7pi_nn
  -- q ┬À log 2 Ôëñ q ┬À 0.6932
  have h_mul2 : (7 / Real.pi) * Real.log 2 Ôëñ (7 / Real.pi) * 0.6932 :=
    mul_le_mul_of_nonneg_left h_log2_lt h_7pi_nn
  -- q ┬À q Ôëñ q ┬À 2.23
  have h_qsq : (7 / Real.pi) * (7 / Real.pi) Ôëñ (7 / Real.pi) * 2.23 :=
    mul_le_mul_of_nonneg_left h_7pi_lt.le h_7pi_nn
  nlinarith [h_mul1, h_mul2, h_qsq, h_7pi_lt, h_7pi_gt, h_7pi_pos]

/-- Ô¡É **PROVED ÔÇö `|NÔéÇ(u)| Ôëñ 1/2` for `u Ôêê [2¤Ç, U]`** given the right
endpoint bound `NÔéÇ(U) Ôëñ 1/2`. Parameterized generalization of
`abs_smoothZeroCountingN0_le_half_on_first_band` (which fixes `U = 10`).

Lower bound is automatic from `smoothZeroCountingN0_at_two_pi`
(`NÔéÇ(2¤Ç) = -1/8 ÔëÑ -1/2`) and monotonicity on `[2¤Ç, Ôê×)`. -/
theorem abs_smoothZeroCountingN0_le_half_on_first_band_param
    {U : ÔäØ} (hU_ge_two_pi : 2 * Real.pi Ôëñ U)
    (hN0_U_le_half : smoothZeroCountingN0 U Ôëñ 1 / 2)
    {u : ÔäØ}
    (hlo : 2 * Real.pi Ôëñ u) (hhi : u Ôëñ U) :
    |smoothZeroCountingN0 u| Ôëñ (1 / 2 : ÔäØ) := by
  have h_mono := smoothZeroCountingN0_monotoneOn_Ici_two_pi
  have h_2pi_mem : (2 * Real.pi : ÔäØ) Ôêê Set.Ici (2 * Real.pi) := Set.left_mem_Ici
  have h_u_mem : u Ôêê Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hlo
  have h_U_mem : U Ôêê Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hU_ge_two_pi
  have h_low : smoothZeroCountingN0 (2 * Real.pi) Ôëñ smoothZeroCountingN0 u :=
    h_mono h_2pi_mem h_u_mem hlo
  have h_high : smoothZeroCountingN0 u Ôëñ smoothZeroCountingN0 U :=
    h_mono h_u_mem h_U_mem hhi
  rw [smoothZeroCountingN0_at_two_pi] at h_low
  have h_high' : smoothZeroCountingN0 u Ôëñ 1 / 2 :=
    le_trans h_high hN0_U_le_half
  rw [abs_le]
  refine Ôƒ¿?_, h_high'Ôƒ®
  linarith

/-- ­ƒîƒ **PROVED ÔÇö `|NÔéÇ(u)| Ôëñ 1/2` for `u Ôêê [2¤Ç, 14]`.**
Specialization of `abs_smoothZeroCountingN0_le_half_on_first_band_param`
with the new endpoint `smoothZeroCountingN0_at_14_le_half`. -/
