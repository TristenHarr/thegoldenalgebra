-- =====================================================================
-- ┬º8. Discharging the polynomial pole-witness  (CXXXII AÔÇôD)
-- =====================================================================
-- The four steps that bring `PolynomialPoleWitnessHypothesis` within one
-- mechanical Mathlib chase of becoming an unconditional theorem:
--
--   A. Reusable analytic helper: continuity at ¤ü Ôƒ╣ uniform |Im|-bound on
--      the probe segment ¤ü ÔêÆ ╬Á┬ÀI.
--   B. Polynomial logDeriv background `q'/q` is continuous away from a
--      root of `q`.
--   C. Composition of A + B: the polynomial background is probe-bounded.
--   D. Polynomial factorization `p = (X ÔêÆ C ¤ü)^m ┬À q` with `q.eval ¤ü Ôëá 0`
--      and `m = rootMultiplicity ¤ü p > 0`.

/-- **CXXXII-A ÔÇö continuity Ôƒ╣ probe boundedness.** A function continuous
at `¤ü` is uniformly bounded (in imaginary part) along the probe segment
`¤ü ÔêÆ ╬Á┬ÀI` for `0 < ╬Á < ╬Á0`. Reusable for both polynomial and xi targets:
pick metric `╬┤` for radius 1, take `╬Á0 = min(╬┤/2, ¤ü.im/2)`, `K = ÔÇûB ¤üÔÇû + 1`,
close via triangle inequality. -/
theorem continuousAt_implies_probe_bounded
    {B : Ôäé ÔåÆ Ôäé} {¤ü : Ôäé}
    (hB : ContinuousAt B ¤ü)
    (hupper : 0 < ¤ü.im) :
    Ôêâ K : ÔäØ, 0 < K Ôêº
    Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
        |(B (¤ü - (╬Á : Ôäé) * Complex.I)).im| Ôëñ K := by
  rw [Metric.continuousAt_iff] at hB
  obtain Ôƒ¿╬┤, h╬┤_pos, h╬┤Ôƒ® := hB 1 zero_lt_one
  refine Ôƒ¿ÔÇûB ¤üÔÇû + 1, by positivity,
          min (╬┤/2) (¤ü.im / 2), ?_, ?_, ?_Ôƒ®
  ┬À refine lt_min (by linarith) (by linarith)
  ┬À exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬Á h╬Á_pos h╬Á_lt
  have h╬Á_lt_╬┤ : ╬Á < ╬┤ := by
    have : ╬Á < ╬┤ / 2 := lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
    linarith
  set z : Ôäé := ¤ü - (╬Á : Ôäé) * Complex.I with hz_def
  have hz¤ü : z - ¤ü = -(╬Á : Ôäé) * Complex.I := by
    show ¤ü - (╬Á : Ôäé) * Complex.I - ¤ü = -(╬Á : Ôäé) * Complex.I
    ring
  have hnorm : ÔÇûz - ¤üÔÇû = ╬Á := by
    rw [hz¤ü, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show ÔÇû((╬Á : ÔäØ) : Ôäé)ÔÇû = ╬Á
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos h╬Á_pos
  have hdist : dist z ¤ü < ╬┤ := by
    rw [dist_eq_norm, hnorm]; exact h╬Á_lt_╬┤
  have h_dist_B : dist (B z) (B ¤ü) < 1 := h╬┤ hdist
  rw [dist_eq_norm] at h_dist_B
  have h_im : |(B z).im| Ôëñ ÔÇûB zÔÇû := Complex.abs_im_le_norm (B z)
  have h_tri : ÔÇûB zÔÇû Ôëñ ÔÇûB z - B ¤üÔÇû + ÔÇûB ¤üÔÇû := by
    have h_eq : B z = (B z - B ¤ü) + B ¤ü := by ring
    nth_rewrite 1 [h_eq]
    exact norm_add_le (B z - B ¤ü) (B ¤ü)
  linarith

/-- **CXXXII-B ÔÇö polynomial logDeriv background is continuous at any
non-root.** `q'(z)/q(z)` is continuous at `¤ü` whenever `q.eval ¤ü Ôëá 0`. -/
theorem polynomial_logDeriv_background_continuousAt
    {q : Polynomial Ôäé} {¤ü : Ôäé} (hq¤ü : q.eval ¤ü Ôëá 0) :
    ContinuousAt (fun z => q.derivative.eval z / q.eval z) ¤ü := by
  apply ContinuousAt.div
  ┬À exact (Polynomial.continuous q.derivative).continuousAt
  ┬À exact (Polynomial.continuous q).continuousAt
  ┬À exact hq¤ü

/-- **CXXXII-C ÔÇö polynomial logDeriv background is probe-bounded.**
One-line composition of CXXXII-A and CXXXII-B. -/
theorem polynomial_logDeriv_background_bounded_on_probe
    {q : Polynomial Ôäé} {¤ü : Ôäé}
    (hq¤ü : q.eval ¤ü Ôëá 0)
    (hupper : 0 < ¤ü.im) :
    Ôêâ K : ÔäØ, 0 < K Ôêº
    Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
        |((q.derivative.eval (¤ü - (╬Á : Ôäé) * Complex.I)) /
           (q.eval (¤ü - (╬Á : Ôäé) * Complex.I))).im| Ôëñ K :=
  continuousAt_implies_probe_bounded
    (polynomial_logDeriv_background_continuousAt hq¤ü) hupper

/-- **CXXXII-D ÔÇö polynomial factorization at a root (Mathlib reduction).**
For `p Ôëá 0` with `p.eval ¤ü = 0`, there exist `m > 0` and `q` such that
`p = (X ÔêÆ C ¤ü)^m ┬À q` with `q.eval ¤ü Ôëá 0`. Set `m := rootMultiplicity ¤ü p`;
positivity via `rootMultiplicity_pos`; factorization via
`pow_rootMultiplicity_dvd`; nonzero remainder by contradiction using
`dvd_iff_isRoot` + `mul_dvd_mul_left` + `pow_succ` +
`le_rootMultiplicity_iff`. -/
theorem polynomial_factor_at_root_with_nonzero_remainder
    {p : Polynomial Ôäé} {¤ü : Ôäé}
    (hp : p Ôëá 0)
    (hroot : p.eval ¤ü = 0) :
    Ôêâ m : Ôäò, 0 < m Ôêº
    Ôêâ q : Polynomial Ôäé,
      p = (Polynomial.X - Polynomial.C ¤ü)^m * q Ôêº
      q.eval ¤ü Ôëá 0 := by
  set m := p.rootMultiplicity ¤ü with hm_def
  have hm_pos : 0 < m := by
    rw [hm_def]
    exact (Polynomial.rootMultiplicity_pos hp).mpr hroot
  obtain Ôƒ¿q, hq_eqÔƒ® : (Polynomial.X - Polynomial.C ¤ü)^m Ôêú p :=
    Polynomial.pow_rootMultiplicity_dvd p ¤ü
  refine Ôƒ¿m, hm_pos, q, hq_eq, ?_Ôƒ®
  -- if q.eval ¤ü = 0, then (X - C ¤ü) Ôêú q, so (X - C ¤ü)^(m+1) Ôêú p,
  -- contradicting maximality of m
  intro hq_eval
  have h_dvd_q : (Polynomial.X - Polynomial.C ¤ü) Ôêú q :=
    Polynomial.dvd_iff_isRoot.mpr hq_eval
  have h_succ_dvd : (Polynomial.X - Polynomial.C ¤ü)^(m+1) Ôêú p := by
    rw [hq_eq, pow_succ]
    exact mul_dvd_mul_left _ h_dvd_q
  have h_le := (Polynomial.le_rootMultiplicity_iff hp).mpr h_succ_dvd
  rw [ÔåÉ hm_def] at h_le
  omega

-- =====================================================================
-- ┬º9. ValueÔåÆpolynomial bridge & unconditional polynomial RH  (CXXXIII)
-- =====================================================================
-- The mechanical Mathlib chase that lifts ┬º5's value-form local
-- decomposition to the polynomial log-derivative response, and discharges
-- `PolynomialPoleWitnessHypothesis` for every nonzero polynomial. After
-- this section, ┬º7's finite RH-equivalence collapses to its hypothesis-free
-- form `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`:
--
--   p Ôëá 0  +  AntiHerglotzUHP (╬ø[p])  +  Schwarz symmetry on p
--   Ôƒ╣  every root of p is real.

/-- **PROVED ÔÇö probe never coincides with the pole when `╬Á > 0`.**
The imaginary parts differ by exactly `╬Á`. -/
theorem probe_ne_pole (¤ü : Ôäé) (╬Á : ÔäØ) (h╬Á : 0 < ╬Á) :
    ¤ü - (╬Á : Ôäé) * Complex.I Ôëá ¤ü := by
  intro h
  have him_diff : (¤ü - (╬Á : Ôäé) * Complex.I).im = ¤ü.im := by rw [h]
  have him_calc : (¤ü - (╬Á : Ôäé) * Complex.I).im = ¤ü.im - ╬Á := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- **PROVED ÔÇö continuous-at-¤ü + nonzero-at-¤ü Ôƒ╣ nonzero on probe.**
Triangle bound: `ÔÇûf(z)ÔÇû > ÔÇûf ¤üÔÇû/2` on a small enough probe segment. -/
theorem continuousAt_implies_probe_nonzero
    {f : Ôäé ÔåÆ Ôäé} {¤ü : Ôäé}
    (hf : ContinuousAt f ¤ü)
    (hf¤ü : f ¤ü Ôëá 0)
    (hupper : 0 < ¤ü.im) :
    Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
        f (¤ü - (╬Á : Ôäé) * Complex.I) Ôëá 0 := by
  rw [Metric.continuousAt_iff] at hf
  have h_pos : 0 < ÔÇûf ¤üÔÇû := norm_pos_iff.mpr hf¤ü
  obtain Ôƒ¿╬┤, h╬┤_pos, h╬┤Ôƒ® := hf (ÔÇûf ¤üÔÇû / 2) (by linarith)
  refine Ôƒ¿min (╬┤/2) (¤ü.im / 2), ?_, ?_, ?_Ôƒ®
  ┬À refine lt_min (by linarith) (by linarith)
  ┬À exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬Á h╬Á_pos h╬Á_lt
  have h╬Á_lt_╬┤ : ╬Á < ╬┤ := by
    have : ╬Á < ╬┤ / 2 := lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
    linarith
  set z : Ôäé := ¤ü - (╬Á : Ôäé) * Complex.I
  have hz¤ü : z - ¤ü = -(╬Á : Ôäé) * Complex.I := by
    show ¤ü - (╬Á : Ôäé) * Complex.I - ¤ü = -(╬Á : Ôäé) * Complex.I
    ring
  have hnorm : ÔÇûz - ¤üÔÇû = ╬Á := by
    rw [hz¤ü, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show ÔÇû((╬Á : ÔäØ) : Ôäé)ÔÇû = ╬Á
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos h╬Á_pos
  have hdist : dist z ¤ü < ╬┤ := by
    rw [dist_eq_norm, hnorm]; exact h╬Á_lt_╬┤
  have h_dist : dist (f z) (f ¤ü) < ÔÇûf ¤üÔÇû / 2 := h╬┤ hdist
  rw [dist_eq_norm] at h_dist
  intro hfz
  rw [hfz] at h_dist
  simp at h_dist
