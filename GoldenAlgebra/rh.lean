-- CLXXXVb: Per-window global error control + 3-band dispatcher
-- =====================================================================
-- Following the file's `[2ѕА,10] / [10,140] / [140,вИЮ)` band structure,
-- this section defines `PerWindowGlobalErrorControl` (bundle of low/mid/high
-- hypotheses) and proves the dispatcher `errorMargin_of_globalErrorControl`
-- that picks the right band by case-splitting on `T`. The mid band is
-- the slab cert (already proved); low and high are still hypothesis
-- placeholders for the Phase1IBP / first-zero / large-T analytic work.

/-- **Per-window global error control.** Bundles the three band-specific
error-margin hypotheses needed for global covering:
- `low`: `[2ѕА, 10]` band вАФ first-zero / `NвВА` control;
- `mid`: `[10, 140]` band вАФ the slab cert via `closedFormErrorControlledOnFiniteBand`;
- `high`: `[140, вИЮ)` band вАФ large-T smooth-tail domination. -/
structure PerWindowGlobalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (error : вДВ вЖТ вДВ) where
  low : вИА {z : вДВ} {T : вДЭ},
    2 * Real.pi вЙ§ T вЖТ T вЙ§ 10 вЖТ
    0 < z.im вЖТ
    2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      |(error z).im| вЙ§ -(M.model z).im
  mid : closedFormErrorControlledOnFiniteBand error
  high : вИА {z : вДВ} {T : вДЭ},
    140 вЙ§ T вЖТ
    0 < z.im вЖТ
    2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      |(error z).im| вЙ§ -(M.model z).im

/-- рЯОѓ **PROVED вАФ Per-window dispatcher.** From the bundled
`PerWindowGlobalErrorControl`, picks the right band by case-splitting
on `T`. Uses `finiteBand_errorMargin_of_slabCD` in the mid band. -/
theorem errorMargin_of_globalErrorControl
    {M : CloudDensityTailModelDecomposition}
    {error : вДВ вЖТ вДВ}
    (hzeros : M.zeros = zeros100ceil)
    (H : PerWindowGlobalErrorControl M error)
    {z : вДВ} {T : вДЭ}
    (hT2pi : 2 * Real.pi вЙ§ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(error z).im| вЙ§ -(M.model z).im := by
  by_cases hT10 : T вЙ§ 10
  ¬Ј exact H.low hT2pi hT10 hy hreg
  ¬Ј push_neg at hT10
    have hT10_le : (10 : вДЭ) вЙ§ T := le_of_lt hT10
    by_cases hT140 : T вЙ§ 140
    ¬Ј exact finiteBand_errorMargin_of_slabCD
        (M := M) (error := error)
        hzeros H.mid hT10_le hT140 hy hreg
    ¬Ј push_neg at hT140
      have hT140_le : (140 : вДЭ) вЙ§ T := le_of_lt hT140
      exact H.high hT140_le hy hreg

/-- рЯОѓ **PROVED вАФ Per-window local-package constructor.** Given a chosen
region containing only points admissible at some `T`, produces a
`LocalXiCloudDensityErrorPackage`. The dispatched error-margin proof
comes from `errorMargin_of_globalErrorControl`. -/
noncomputable def localPackage_of_globalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : вДВ вЖТ вДВ)
    (region : вДВ вЖТ Prop)
    (hregT : вИА z : вДВ, region z вЖТ
        вИГ T : вДЭ, 2 * Real.pi вЙ§ T вИІ 2 * (1 + |z.re| + z.im) вЙ§ T)
    (hdecomp : вИА z : вДВ, region z вЖТ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (H : PerWindowGlobalErrorControl M error) :
    LocalXiCloudDensityErrorPackage :=
  { model := M.model
    error := error
    region := region
    decomp := hdecomp
    modelAnti := hmodelAnti
    errorMargin := by
      intro z hreg hz
      obtain вЯ®T, hT2pi, hregT_valвЯ© := hregT z hreg
      exact errorMargin_of_globalErrorControl
        (M := M) (error := error)
        hM_zeros H hT2pi hz hregT_val }

