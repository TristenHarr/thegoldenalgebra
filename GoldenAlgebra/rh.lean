/-- в≠Р **PROVED вАФ smooth-tail LB on the full `[48, 80]` range.** Reuses
the `tailK_80_140` def since the form `(22/15)¬Ј(2/(2ѕА))/T` is identical;
this lemma just establishes the underlying `2/(2ѕА) вЙ§ ѕБ(T)` on `[48, 80]`. -/
lemma smoothTail_ge_const_48_80
    {x y T : вДЭ}
    (hx : 0 вЙ§ x) (hT48 : 48 вЙ§ T) (hT80 : T вЙ§ 80)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) вЙ§ T) :
    y * tailK_80_140 T вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_80_140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hT_2pi : 2 * Real.pi вЙ§ T := by linarith
  have hreg' : 2 * (1 + |x| + y) вЙ§ T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : ((2 : вДЭ) / (2 * Real.pi)) вЙ§ zeroDensityRho T :=
    zeroDensityRho_ge_const_48_80 hT48 hT80
  have h_22_15_nn : (0 : вДЭ) вЙ§ 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : вДЭ) * ((2 : вДЭ) / (2 * Real.pi))
      вЙ§ (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : вДЭ) вЙ§ y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : вДЭ) * ((2 : вДЭ) / (2 * Real.pi)) * y / T
        вЙ§ (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : вДЭ) * ((2 : вДЭ) / (2 * Real.pi)) * (y / T)
          = (22 / 15 : вДЭ) * ((2 : вДЭ) / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : вДЭ) * zeroDensityRho T * (y / T)
          = (22 / 15 : вДЭ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : вДЭ) * zeroDensityRho T * y / T
                вЙ§ smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : вДЭ) *
      ((2 : вДЭ) / (2 * Real.pi)) / T)
      = (22 / 15 : вДЭ) * ((2 : вДЭ) / (2 * Real.pi)) * y / T := by ring
