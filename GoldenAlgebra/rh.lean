    pow_lt_pow_leftÔéÇ h_exp_1_gt (le_of_lt h_2718_pos) (by norm_num)
  have h_36_5_le_27 : (36 : ÔäØ)^5 Ôëñ (2.7182818283 : ÔäØ)^18 := by norm_num
