/-- Ô¡É **PROVED ÔÇö `closedFormSErrorBoundCD C D y T Ôëñ y` on the band**
for `(C, D) Ôêê [0, 1/2] ├ù [0, 49/20]` and `T Ôêê [10, 140]`. -/
theorem closedFormSErrorBoundCD_le_y_on_band
    {C D y T : ÔäØ}
    (hC_nn : 0 Ôëñ C) (hC_le : C Ôëñ 1/2)
    (hD_nn : 0 Ôëñ D) (hD_le : D Ôëñ 49/20)
    (hy_nn : 0 Ôëñ y)
    (hT_ge : 10 Ôëñ T) (hT_le : T Ôëñ 140) :
    closedFormSErrorBoundCD C D y T Ôëñ y := by
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have hT_sq_pos : 0 < T^2 := by positivity
  have hT_sq_ge : (100 : ÔäØ) Ôëñ T^2 := by nlinarith
  have hlogT_le : Real.log T Ôëñ 5 := log_T_le_5_of_le_140 hT_pos hT_le
  have h_log_T_nn : 0 Ôëñ Real.log T := by
    have h := Real.log_le_log (by norm_num : (0:ÔäØ) < 10) hT_ge
    have h_log10_nn : (0 : ÔäØ) Ôëñ Real.log 10 := Real.log_nonneg (by norm_num)
    linarith
  rw [closedFormSErrorBoundCD_expand C D y T hT_ne]
  -- Coefficient Ôëñ 17┬À(1/2)┬À5 + 17┬À(49/20) + 9┬À(1/2)/2 = 86.4
  have h_clog_le : C * Real.log T Ôëñ (1/2) * 5 :=
    mul_le_mul hC_le hlogT_le h_log_T_nn (by norm_num : (0:ÔäØ) Ôëñ 1/2)
  have h_coeff_le : 17 * C * Real.log T + 17 * D + 9 * C / 2 Ôëñ 86.4 := by
    nlinarith [h_clog_le, hD_le, hC_le]
  have h_clog_nn : 0 Ôëñ C * Real.log T := mul_nonneg hC_nn h_log_T_nn
  have h_coeff_nn : 0 Ôëñ 17 * C * Real.log T + 17 * D + 9 * C / 2 := by
    nlinarith [h_clog_nn, hD_nn, hC_nn]
  have h_y_T2_nn : 0 Ôëñ y / T^2 := div_nonneg hy_nn (le_of_lt hT_sq_pos)
  -- (y/T┬▓)┬À(coeff) Ôëñ (y/T┬▓)┬À86.4 Ôëñ y┬À86.4/100 Ôëñ y
  have h_step : (y / T^2) * (17 * C * Real.log T + 17 * D + 9 * C / 2)
              Ôëñ (y / T^2) * 86.4 :=
    mul_le_mul_of_nonneg_left h_coeff_le h_y_T2_nn
  have h_yT2_le : (y / T^2) * 86.4 Ôëñ y := by
    rw [div_mul_eq_mul_div, div_le_iffÔéÇ hT_sq_pos]
    nlinarith
  linarith

