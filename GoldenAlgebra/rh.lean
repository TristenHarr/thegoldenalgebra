        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ)) :
    XiPullbackAntiHerglotzTarget := by
  exact
    XiPullbackAntiHerglotzTarget_of_entireHadamard_canonicalStieltjesInputs
      Dzero
      H.h_Z_ge_15
      hTuring
      hHighLog
      H.Hhad
      H.Hst

