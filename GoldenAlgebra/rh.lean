/-- **Adaptive `ComplexTailIBPBoundData`.** Mirrors ¬ІCCXV's
`ComplexTailIBPBoundData` but consumes an adaptive convergence package
(`AdaptiveComplexDensityTailFamilyConverges`) вАФ matches the ¬ІCCXVII
construction. -/
structure AdaptiveComplexTailIBPBoundData
    (kernel : вДЭ вЖТ вДВ вЖТ вДВ) (S : вДЭ вЖТ вДЭ)
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    (error : вДВ вЖТ вДВ) : Prop where
  error_im_eq_tail_im :
    вИА {z : вДВ} {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      (error z).im = (conv.tail T z).im
  finite_im_match :
    вИА {z : вДВ} {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
