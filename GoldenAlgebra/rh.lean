/-- Ô¡É **PROVED ÔÇö TOP-LEVEL one-shot via the bundle.** -/
theorem hclosed_on_10_140_of_polyBundle
    (M : CloudDensityTailModelDecomposition)
    (B : NineSlabPolyInequalities M.zeros)
    {z : Ôäé} {T : ÔäØ}
    (hT10 : 10 Ôëñ T) (hT140 : T Ôëñ 140)
