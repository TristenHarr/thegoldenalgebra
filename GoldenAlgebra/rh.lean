/-- 🌟🌟🌟🌟🌟🌟🌟 **PROVED — guarded `_of_honestPackages_canonicalMid`.**
Same shape as `XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid`
but consumes guarded `Rcanon` / `Rhigh`. -/
theorem XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMidAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (RcanonAFZ : XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (RhighAFZ : XiHighResidualFormulaDataAwayFromZeros
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M hHighLog)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(xiResidualError HModel.M z).im| ≤ -(HModel.M.model z).im) :
    XiPullbackAntiHerglotzTarget := by
  have hmodelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  let mid : LocalXiCloudDensityErrorPackage :=
    midLocalPackage_of_canonicalResidualFormulaAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us Tsmooth hTsmooth_ge HModel RcanonAFZ
  let high : LocalXiCloudDensityErrorPackage :=
    highLocalPackage_of_XiHighResidualFormulaDataAwayFromZeros
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M HModel.hzeros hmodelAnti hHighLog RhighAFZ
  let low : LocalXiCloudDensityErrorPackage :=
    lowLocalPackage_of_residualLowMargin HModel.M hmodelAnti hlowMargin
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n =>
        if n = 0 then mid else if n = 1 then high else low
      covers := ?_ }
  intro z hz
  by_cases hmid :
      ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T
  · refine ⟨0, ?_⟩
    show mid.region z
    exact hmid
  · refine ⟨1, ?_⟩
    show high.region z
    exact hmid

