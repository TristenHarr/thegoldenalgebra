/-- в≠Р **PROVED вАФ `scalarGap22_15` is monotone on `[140, вИЮ)`.**

Derivative-free proof via the algebraic identity
  `scalarGap22_15(b) вИТ scalarGap22_15(a)`
   `= (11/(15ѕА))¬Ј(bвИТa)¬Јlog(b/(2ѕА))`
   ` + (11¬Јa/(15ѕА) вИТ 17/2)¬Јlog(b/a).`

Both terms are nonnegative on `[140, вИЮ)`:
  * `b вЙ• a вЙ• 140 > 2ѕА`, so `log(b/(2ѕА)) вЙ• 0` and `log(b/a) вЙ• 0`;
  * `11¬Јa/(15ѕА) вИТ 17/2 вЙ• 0` for `a вЙ• 140`: the inequality reduces to
    `22¬Јa вЙ• 255ѕА`, and `22¬Ј140 = 3080 вЙ• 1020 вЙ• 255¬Ј4 > 255ѕА`. -/
theorem scalarGap22_15_monotoneOn_Ici_140 :
    MonotoneOn scalarGap22_15 (Set.Ici 140) := by
  intro a ha b hb hab
  -- Unfold membership
  have ha_ge : (140 : вДЭ) вЙ§ a := ha
  have hb_ge : (140 : вДЭ) вЙ§ b := hb
  have hap : 0 < a := by linarith
  have hbp : 0 < b := by linarith
  have h_a_ne : a вЙ† 0 := ne_of_gt hap
  have h_b_ne : b вЙ† 0 := ne_of_gt hbp
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi) вЙ† 0 := ne_of_gt h_2pi_pos
  have h_15pi_pos : 0 < 15 * Real.pi := by linarith
  have h_15pi_ne : (15 * Real.pi) вЙ† 0 := ne_of_gt h_15pi_pos
  -- 2ѕА < 8 < 140 вЙ§ a, b
  have h_2pi_lt_a : 2 * Real.pi < a := by linarith
  have h_2pi_lt_b : 2 * Real.pi < b := by linarith
  -- log(a/(2ѕА)) вЙ• 0, log(b/(2ѕА)) вЙ• 0
  have h_a_2pi_gt_1 : 1 < a / (2 * Real.pi) := by
    rw [lt_div_iffвВА h_2pi_pos]; linarith
  have h_b_2pi_gt_1 : 1 < b / (2 * Real.pi) := by
    rw [lt_div_iffвВА h_2pi_pos]; linarith
  have h_log_b_2pi_nn : 0 вЙ§ Real.log (b / (2 * Real.pi)) :=
    le_of_lt (Real.log_pos h_b_2pi_gt_1)
  -- log(b/a) вЙ• 0 since b вЙ• a > 0
  have h_b_div_a_ge_1 : 1 вЙ§ b / a := by
    rw [le_div_iffвВА hap]; linarith
  have h_log_ba_nn : 0 вЙ§ Real.log (b / a) := Real.log_nonneg h_b_div_a_ge_1
  -- 11¬Јa/(15ѕА) вЙ• 17/2: equivalent to 22¬Јa вЙ• 255ѕА, holds since 22¬Ј140 = 3080 вЙ• 1020 > 255¬ЈѕА
  have h_ќ±_a_ge : (17 / 2 : вДЭ) вЙ§ 11 * a / (15 * Real.pi) := by
    rw [le_div_iffвВА h_15pi_pos]
    -- want (17/2)¬Ј(15ѕА) вЙ§ 11¬Јa, i.e., 255ѕА/2 вЙ§ 11¬Јa, i.e., 255ѕА вЙ§ 22a
    nlinarith [ha_ge, h_pi_lt_4]
  -- Log identities
  have h_log_a_2pi : Real.log (a / (2 * Real.pi))
                  = Real.log a - Real.log (2 * Real.pi) :=
    Real.log_div h_a_ne h_2pi_ne
  have h_log_b_2pi : Real.log (b / (2 * Real.pi))
                  = Real.log b - Real.log (2 * Real.pi) :=
    Real.log_div h_b_ne h_2pi_ne
  have h_log_ba : Real.log (b / a) = Real.log b - Real.log a :=
    Real.log_div h_b_ne h_a_ne
  -- Algebraic identity for the difference
  unfold scalarGap22_15
  have h_id :
      (((22 / 15) * b / (2 * Real.pi)) * Real.log (b / (2 * Real.pi))
        - ((17 / 2) * Real.log b + 439 / 10))
      - (((22 / 15) * a / (2 * Real.pi)) * Real.log (a / (2 * Real.pi))
        - ((17 / 2) * Real.log a + 439 / 10))
      = (11 / (15 * Real.pi)) * (b - a) * Real.log (b / (2 * Real.pi))
        + (11 * a / (15 * Real.pi) - 17 / 2) * Real.log (b / a) := by
    rw [h_log_a_2pi, h_log_b_2pi, h_log_ba]
    field_simp
    ring
  -- Both terms вЙ• 0
  have h_term1_nn :
      0 вЙ§ (11 / (15 * Real.pi)) * (b - a) * Real.log (b / (2 * Real.pi)) := by
    apply mul_nonneg
    ¬Ј apply mul_nonneg
      ¬Ј positivity
      ¬Ј linarith
    ¬Ј exact h_log_b_2pi_nn
  have h_term2_nn :
      0 вЙ§ (11 * a / (15 * Real.pi) - 17 / 2) * Real.log (b / a) :=
    mul_nonneg (by linarith) h_log_ba_nn
  linarith

