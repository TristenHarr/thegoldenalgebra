    have h := Real.exp_one_pow 24
    have h_cast : ((24 : тДХ) : тДЭ) = (24 : тДЭ) := by norm_num
    rw [тЖР h_cast]
    exact h.symm
  have h_exp_24_5_pow : (Real.exp (24 / 5 : тДЭ))^5 = Real.exp 24 := by
    have h := Real.exp_nat_mul (24 / 5 : тДЭ) 5
    have h_eq : ((5 : тДХ) : тДЭ) * (24 / 5 : тДЭ) = 24 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_pow_num : (2.72 : тДЭ)^24 < (140 : тДЭ)^5 := by norm_num
  have h_exp_pow_lt :
      (Real.exp (24 / 5 : тДЭ))^5 < (140 : тДЭ)^5 := by
    rw [h_exp_24_5_pow, h_exp24_eq]
    linarith
  have hexp_nn : 0 тЙд Real.exp (24 / 5 : тДЭ) :=
    le_of_lt (Real.exp_pos _)
  have h140_nn : (0 : тДЭ) тЙд 140 := by norm_num
  exact
    (pow_lt_pow_iff_leftтВА hexp_nn h140_nn
      (by norm_num : (5 : тДХ) тЙа 0)).mp h_exp_pow_lt

