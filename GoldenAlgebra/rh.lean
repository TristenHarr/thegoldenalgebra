/-- в≠Р **PROVED вАФ Pad√© bound** `2(5вИТѕА)/(5+ѕА) вЙ§ log(5/ѕА)`. -/
lemma pade_log_5_div_pi :
    2 * (5 - Real.pi) / (5 + Real.pi) вЙ§ Real.log (5 / Real.pi) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_5_lt_pi : Real.pi < 5 := by linarith
  have hѕА_ne : Real.pi вЙ† 0 := ne_of_gt h_pi_pos
  have h_5_plus_pi_pos : (0 : вДЭ) < 5 + Real.pi := by linarith
  have h_x_nn : (0 : вДЭ) вЙ§ (5 - Real.pi) / Real.pi := by
    apply div_nonneg
    ¬Ј linarith
    ¬Ј exact le_of_lt h_pi_pos
  have h_one_add : 1 + (5 - Real.pi) / Real.pi = 5 / Real.pi := by
    field_simp
  have h_pade := Real.le_log_one_add_of_nonneg h_x_nn
  rw [h_one_add] at h_pade
  -- Multiply h_pade by ((5-ѕА)/ѕА + 2) > 0
  have h_inner_pos : (0 : вДЭ) < (5 - Real.pi) / Real.pi + 2 := by positivity
  have h_inner_ne : ((5 - Real.pi) / Real.pi + 2) вЙ† 0 := ne_of_gt h_inner_pos
  have h_step1 :
      2 * ((5 - Real.pi) / Real.pi)
        вЙ§ ((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_right h_pade (le_of_lt h_inner_pos)
    rw [div_mul_cancelвВА _ h_inner_ne] at h
    linarith
  -- Multiply by ѕА > 0
  have h_step2 :
      2 * (5 - Real.pi) вЙ§ (5 + Real.pi) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_left h_step1 (le_of_lt h_pi_pos)
    have hl : Real.pi * (2 * ((5 - Real.pi) / Real.pi)) = 2 * (5 - Real.pi) := by
      field_simp
    have h_factor :
        Real.pi * ((5 - Real.pi) / Real.pi + 2) = 5 + Real.pi := by
      field_simp; ring
    have hr :
        Real.pi * (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
          = (5 + Real.pi) * Real.log (5 / Real.pi) := by
      rw [show Real.pi *
            (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
            = (Real.pi * ((5 - Real.pi) / Real.pi + 2))
                * Real.log (5 / Real.pi) from by ring,
          h_factor]
    linarith [h, hl.le, hl.symm.le, hr.le, hr.symm.le]
  -- Divide by (5+ѕА) > 0 to recover 2(5-ѕА)/(5+ѕА) вЙ§ log(5/ѕА)
  have h5pѕА_ne : (5 + Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_5_plus_pi_pos
  rw [div_le_iffвВА h_5_plus_pi_pos]
  linarith [h_step2]

/-- в≠Р **PROVED вАФ rational `74/163 вЙ§ 2(5вИТѕА)/(5+ѕА)`** from `ѕА вЙ§ 3.15`. -/
