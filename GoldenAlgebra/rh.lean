-- ¬ІCCCXLII. Canonical Hadamard zero index package
-- =====================================================================
-- Names the zero index type + zero-locating map + characterizing
-- properties. The analytic agent's first concrete choice (e.g.,
-- ќє = вДХ with `zeroLoc n` = the n-th nontrivial zeta zero ordinate).

/-- рЯУ¶ **`CompletedXiZeroIndexPackage`** вАФ characterization of the
zero set of `completedXiFunction` via an explicit index type. -/
structure CompletedXiZeroIndexPackage where
  ќє : Type
  zeroLoc : ќє вЖТ вДВ
  zeroLoc_ne_zero :
    вИА i : ќє, zeroLoc i вЙ† 0
  zeroLoc_is_zero :
    вИА i : ќє, completedXiFunction (zeroLoc i) = 0
  all_completedXi_zeros :
    вИА s : вДВ,
      completedXiFunction s = 0 вЖТ
      вИГ i : ќє, zeroLoc i = s

-- =====================================================================
-- ¬ІCCCXLIII. Hadamard prefactor data package
-- =====================================================================

/-- рЯУ¶ **`CompletedXiHadamardPrefactorData`** вАФ AFZ properties of the
Hadamard prefactor as a Prop. -/
structure CompletedXiHadamardPrefactorData (prefactor : вДВ вЖТ вДВ) : Prop where
  differentiable_at_nonzero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      DifferentiableAt вДВ prefactor s
  nonzero_at_nonzero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      prefactor s вЙ† 0

-- =====================================================================
-- ¬ІCCCXLIV. Hadamard factorization data + assembly
-- =====================================================================

/-- рЯУ¶ **`CompletedXiHadamardFactorizationData`** вАФ the classical
factorization identity `ќЊ = prefactor ¬Ј вИП EвВБ(¬Ј/ѕБбµҐ)`. -/
structure CompletedXiHadamardFactorizationData
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) (prefactor : вДВ вЖТ вДВ) : Prop where
  factorization :
    вИА s : вДВ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `ClassicalPathBAnalyticInputs` from the
Hadamard packages.** Assembles the bundled inputs from the
separately-developed Hadamard components. -/
noncomputable def ClassicalPathBAnalyticInputs.of_hadamard_packages
    {ќє : Type} {zeroLoc : ќє вЖТ вДВ} {prefactor : вДВ вЖТ вДВ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ s вИИ Hluc.region)
    (HnonzeroRegion : вИА s вИИ Hluc.region, вИА i, s вЙ† zeroLoc i)
    (Hfact : CompletedXiHadamardFactorizationData zeroLoc prefactor)
    (Hpref : CompletedXiHadamardPrefactorData prefactor) :
    ClassicalPathBAnalyticInputs ќє :=
  { zeroLoc := zeroLoc
    prefactor := prefactor
    Hinv := Hinv
    Hluc := Hluc
    Hregion := Hregion
    HnonzeroRegion := HnonzeroRegion
    Hfact := Hfact.factorization
    Hpref_diff := Hpref.differentiable_at_nonzero
    Hpref_ne := Hpref.nonzero_at_nonzero }

