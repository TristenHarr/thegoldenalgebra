-- CLXXXVc: High-range `[140, вИЮ)` margin bridge
-- =====================================================================
-- The high-T analogue of `slabCD`. Uses the existing `proved_numerics_22_15_at_140`
-- + `largeTScalarConditionTwentyTwoFifteenths_implies_domination` chain.
-- Output: a deterministic closed-form bound + `le_trans`-style adapter so
-- the high field of `PerWindowGlobalErrorControl` has a clean landing pad.

/-- **Deterministic high-`T` closed-form bound.** At all `T вЙ• 140` we know
the closed form at `(C, D) = (1/2, 49/20)` is dominated by
`smoothTailRationalLowerBoundAbs`, which in turn is bounded by `-Im(densityTail)`. -/
noncomputable def highTClosedFormBound (y T : вДЭ) : вДЭ :=
  closedFormSErrorBoundCD (1 / 2) (49 / 20) y T

/-- в≠Р **PROVED вАФ High-`T` closed-form bound dominates `-Im(M.model)`** for
`T вЙ• 140` and `M.zeros = zeros100ceil`. Chain:

`highTClosedFormBound = closedFormSErrorBoundCD (1/2) (49/20)`
  `вЙ§ smoothTailRationalLowerBoundAbs`  (via `largeTScalarвА¶_implies_domination`
                                          + `proved_numerics_22_15_at_140`)
  `вЙ§ -(densityTail).im`                (via `M.densityTailRationalLB`)
  `вЙ§ -(densityTail).im + -(cloud).im = -(model).im` (cloud anti-Herglotz). -/
theorem highTClosedFormBound_le_neg_model_im
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    {z : вДВ} {T : вДЭ}
    (hT140 : 140 вЙ§ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    highTClosedFormBound z.im T вЙ§ -(M.model z).im := by
  unfold highTClosedFormBound
  have hscalar : largeTScalarMarginConditionTwentyTwoFifteenths T :=
    largeTScalarMarginConditionTwentyTwoFifteenths_of_ge_140_from_numerics
      proved_numerics_22_15_at_140 hT140
  have h_dom :
      closedFormSErrorBoundCD (1 / 2 : вДЭ) (49 / 20 : вДЭ) z.im T
        вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T :=
    largeTScalarConditionTwentyTwoFifteenths_implies_domination hT140 hy hreg hscalar
  have hT_2pi : 2 * Real.pi вЙ§ T := by
    have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_tail_lb :
      smoothTailRationalLowerBoundAbs z.re z.im T вЙ§ -(M.densityTail z).im :=
    M.densityTailRationalLB z T hT_2pi hy hreg
  have h_model : M.model z = cloudModel M.zeros z + M.densityTail z := rfl
  have h_model' : M.model z = cloudModel zeros100ceil z + M.densityTail z := by
    rw [h_model, hM_zeros]
  have h_cloud_im_nonpos : (cloudModel zeros100ceil z).im вЙ§ 0 :=
    cloudModel_im_nonpos _ hy
  have h_model_im :
      -(M.model z).im = -(cloudModel zeros100ceil z).im + -(M.densityTail z).im := by
    rw [h_model', Complex.add_im]; ring
  linarith [h_dom, h_tail_lb, h_cloud_im_nonpos, h_model_im]

/-- **High-`T` closed-form error control.** The IBP/large-T-side
hypothesis: `|Im(error z)| вЙ§ highTClosedFormBound z.im T` on `[140, вИЮ)`. -/
def highTErrorControlled (error : вДВ вЖТ вДВ) : Prop :=
  вИА {z : вДВ} {T : вДЭ},
    140 вЙ§ T вЖТ
    0 < z.im вЖТ
    2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      |(error z).im| вЙ§ highTClosedFormBound z.im T

/-- рЯМЯ **PROVED вАФ High-`T` error margin via `le_trans`.** Chains the
IBP-side error control with the model-margin domination, BOTH using
the same `highTClosedFormBound z.im T`. -/
theorem highT_errorMargin_of_highTErrorControlled
    {M : CloudDensityTailModelDecomposition}
    {error : вДВ вЖТ вДВ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : highTErrorControlled error)
    {z : вДВ} {T : вДЭ}
    (hT140 : 140 вЙ§ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(error z).im| вЙ§ -(M.model z).im :=
