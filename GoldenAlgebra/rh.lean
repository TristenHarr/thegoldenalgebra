-- =====================================================================
-- ┬зCCLXX. Smooth-tail `-Im` as a positive real integral
-- =====================================================================
-- The honest tail's `-Im` is a real improper integral of
-- `╧Б(u) ┬╖ y ┬╖ paired-Cauchy-positive-kernel(z, u)`. This section
-- captures the structural decomposition needed by any proof of
-- `HonestSmoothTailRationalLB`. The CLV analytic estimate remains
-- as the named obligation тАФ the structural pieces here let an
-- analytic agent attack it on the real-integral form.
--
-- Adds:
--   neg_pairedCauchyImKernel_eq                            тАФ pointwise identity
--   smoothDensityTailModelPartial_neg_im_eq_real_integral  тАФ -Im(partial) as real integral

/-- тнР **PROVED тАФ pointwise identity for `-pairedCauchyImKernel`.**
Writes `-pairedCauchyImKernel x y u` as the explicit positive
combination `y ┬╖ (1/((x-u)┬▓+y┬▓) + 1/((x+u)┬▓+y┬▓))`. -/
lemma neg_pairedCauchyImKernel_eq (x y u : тДЭ) :
    -pairedCauchyImKernel x y u
      = y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2)) := by
  unfold pairedCauchyImKernel
  ring

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `-Im` of the smooth-density finite partial as a
real integral.** Pointwise Im identity + `Complex.imCLM.intervalIntegral_comp_comm`
yields the positive real integrand. -/
lemma smoothDensityTailModelPartial_neg_im_eq_real_integral
    (╧Б : тДЭ тЖТ тДЭ) (T X : тДЭ) {z : тДВ}
    (h_int : IntervalIntegrable
              (fun u =>
                (╧Б u : тДВ) *
                  ((1 : тДВ) / (z - (u : тДВ)) +
                   (1 : тДВ) / (z + (u : тДВ))))
              MeasureTheory.volume T X) :
    -(smoothDensityTailModelPartial ╧Б T X z).im
      = тИл u in T..X,
          ╧Б u * (z.im *
            (1 / ((z.re - u)^2 + z.im^2)
              + 1 / ((z.re + u)^2 + z.im^2))) := by
  unfold smoothDensityTailModelPartial
  rw [show (тИл u in T..X,
              (╧Б u : тДВ) *
                ((1 : тДВ) / (z - (u : тДВ)) +
                 (1 : тДВ) / (z + (u : тДВ)))).im
          = Complex.imCLM (тИл u in T..X,
              (╧Б u : тДВ) *
                ((1 : тДВ) / (z - (u : тДВ)) +
                 (1 : тДВ) / (z + (u : тДВ)))) from rfl,
      тЖР Complex.imCLM.intervalIntegral_comp_comm h_int]
  rw [тЖР intervalIntegral.integral_neg]
  refine intervalIntegral.integral_congr ?_
  intro u _
  show -(Complex.imCLM ((╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) +
             (1 : тДВ) / (z + (u : тДВ)))))
    = ╧Б u * (z.im *
      (1 / ((z.re - u)^2 + z.im^2)
        + 1 / ((z.re + u)^2 + z.im^2)))
  rw [Complex.imCLM_apply]
  have hpair : (pairedCauchyKernel u z).im = pairedCauchyImKernel z.re z.im u := by
    have h := pairedCauchyKernel_im_eq_imKernel z.re z.im u
    rw [Complex.re_add_im z] at h
    exact h
  have h_im :
      ((╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im
        = ╧Б u * pairedCauchyImKernel z.re z.im u := by
    show ((╧Б u : тДВ) * pairedCauchyKernel u z).im
          = ╧Б u * pairedCauchyImKernel z.re z.im u
    have hmul : ((╧Б u : тДВ) * pairedCauchyKernel u z).im
            = ╧Б u * (pairedCauchyKernel u z).im := by
      simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
    rw [hmul, hpair]
  rw [h_im]
  have hneg : -pairedCauchyImKernel z.re z.im u
              = z.im * (1 / ((z.re - u)^2 + z.im^2)
                        + 1 / ((z.re + u)^2 + z.im^2)) :=
    neg_pairedCauchyImKernel_eq z.re z.im u
  linear_combination ╧Б u * hneg

-- =====================================================================
-- ┬зCCLXXI. Real-integral limit form of the smooth tail's `-Im`
-- =====================================================================
-- Bridges ┬зCCLXX's finite-partial identity to the improper limit. The
-- end goal is the named target the CLV agent will attack:
--
--   `-Im(zeroDensitySmoothTailModel Tsmooth z)
--      = lim_{XтЖТтИЮ} тИл_{Tsmooth}^X ╧Б(u) ┬╖ y ┬╖ paired-pos-kernel(z, u) du`.
--
-- Adds:
--   zeroDensitySmoothTailModel_tendsto_complex                 тАФ complex Tendsto witness
--   zeroDensitySmoothTailModel_neg_im_tendsto_real_integral    тАФ real Tendsto bridge

/-- ЁЯМЯЁЯМЯ **PROVED тАФ complex Tendsto witness for the honest smooth tail.**
The finite complex partials `smoothDensityTailModelPartial zeroDensityRho Tsmooth X z`
converge to `zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z` as
`X тЖТ тИЮ`. Extracted via the same majorant construction
`zeroDensitySmoothTailModel` is built from; proof-irrelevance makes
the two `SmoothDensityTailMajorantDataUHP` instances definitionally
equal, so the Tendsto's target matches the named tail. -/
theorem zeroDensitySmoothTailModel_tendsto_complex
    (Tsmooth : тДЭ) (hTsmooth_ge : 2 * Real.pi тЙд Tsmooth)
    {z : тДВ} (hz : 0 < z.im) :
    Tendsto
      (fun X : тДЭ =>
        smoothDensityTailModelPartial zeroDensityRho Tsmooth X z)
      Filter.atTop
      (ЁЭУЭ (zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : тДЭ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have h2pi_inv_nn : (0 : тДЭ) тЙд 1 / (2 * Real.pi) := by positivity
  exact
    (smoothDensityTailModelConvergesUHP_of_majorant zeroDensityRho Tsmooth
      (smoothDensityTailMajorantDataUHP_of_logGrowth
        zeroDensityRho Tsmooth (1 / (2 * Real.pi)) 0
        h2pi_inv_nn le_rfl hTpos
        zeroDensityRho_log_growth_eventually
        (fun z X hz hTX =>
          zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
            Tsmooth X hTpos hTX hz))).tendsto z hz

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `-Im` of the honest smooth tail as an `atTop`
real-integral limit.** Composes ┬зCCLXX-2 (the finite-partial real
integral form) with `zeroDensitySmoothTailModel_tendsto_complex` and
`(continuous_neg тИШ Complex.continuous_im)`. The CLV analytic agent
can now attack the target purely in real-integral language. -/
theorem zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
    (Tsmooth : тДЭ) (hTsmooth_ge : 2 * Real.pi тЙд Tsmooth)
    {z : тДВ} (hz : 0 < z.im) :
    Tendsto
      (fun X : тДЭ =>
        тИл u in Tsmooth..X,
          zeroDensityRho u *
            (z.im *
              (1 / ((z.re - u)^2 + z.im^2) +
               1 / ((z.re + u)^2 + z.im^2))))
      Filter.atTop
      (ЁЭУЭ (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : тДЭ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have hcomplex :=
    zeroDensitySmoothTailModel_tendsto_complex Tsmooth hTsmooth_ge hz
  have him :
      Tendsto
        (fun X : тДЭ =>
          -(smoothDensityTailModelPartial zeroDensityRho Tsmooth X z).im)
        Filter.atTop
        (ЁЭУЭ (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) :=
    (continuous_neg.tendsto _).comp
      ((Complex.continuous_im.tendsto _).comp hcomplex)
  refine him.congr' ?_
  filter_upwards [Filter.eventually_ge_atTop Tsmooth] with X hTX
  exact smoothDensityTailModelPartial_neg_im_eq_real_integral
    zeroDensityRho Tsmooth X
    (zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
      Tsmooth X hTpos hTX hz)

-- =====================================================================
-- ┬зCCLXXII-A. Monotonicity, positivity, and pointwise lower bounds
-- =====================================================================
-- Foundation for the CLV/arctan estimate. Names the positive smooth
-- kernel and proves the pointwise comparison
-- `╧Б(T) ┬╖ K(u) тЙд ╧Б(u) ┬╖ K(u)` on the tail `u тЙе T тЙе 2╧А`. This is the
-- single ingredient needed to factor `╧Б(T)` out of the integral in
-- ┬зCCLXXII-B.
--
-- Adds:
--   positiveSmoothKernel                          тАФ `y┬╖(1/((x-u)┬▓+y┬▓) + 1/((x+u)┬▓+y┬▓))`
--   positiveSmoothKernel_nonneg
--   zeroDensityRho_mono_on_tail
--   zeroDensityRho_le_of_tail
--   zeroDensity_kernel_lower_bound

/-- **Positive smooth kernel** тАФ the absolute-value form of the paired
Cauchy kernel's imaginary part. Manifestly nonneg for `y > 0`. -/
noncomputable def positiveSmoothKernel (x y u : тДЭ) : тДЭ :=
  y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2))

/-- тнР **PROVED тАФ `positiveSmoothKernel` is nonneg for `y > 0`.** -/
lemma positiveSmoothKernel_nonneg
    {x y u : тДЭ} (hy : 0 < y) :
    0 тЙд positiveSmoothKernel x y u := by
  unfold positiveSmoothKernel
  have h1 : (0 : тДЭ) < (x - u)^2 + y^2 := by positivity
  have h2 : (0 : тДЭ) < (x + u)^2 + y^2 := by positivity
  have hy' : (0 : тДЭ) тЙд y := le_of_lt hy
  positivity

/-- тнР **PROVED тАФ `zeroDensityRho` is monotone on `[2╧А, тИЮ)`.** Follows
from `log` monotonicity on `[1, тИЮ)` after dividing by `2╧А`. -/
lemma zeroDensityRho_mono_on_tail :
    MonotoneOn zeroDensityRho (Set.Ici (2 * Real.pi)) := by
  intro a ha b hb hab
  unfold zeroDensityRho
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : тДЭ) тЙд 1 / (2 * Real.pi) := by positivity
  have hab_div : a / (2 * Real.pi) тЙд b / (2 * Real.pi) := by
    exact div_le_div_of_nonneg_right hab (le_of_lt h2pi_pos)
  have ha_div_pos : 0 < a / (2 * Real.pi) :=
    div_pos (lt_of_lt_of_le h2pi_pos ha) h2pi_pos
  have h_log_le :
      Real.log (a / (2 * Real.pi)) тЙд Real.log (b / (2 * Real.pi)) :=
    Real.log_le_log ha_div_pos hab_div
  exact mul_le_mul_of_nonneg_left h_log_le h2pi_inv_nn

/-- тнР **PROVED тАФ `╧Б(T) тЙд ╧Б(u)` on the tail.** -/
lemma zeroDensityRho_le_of_tail
    {T u : тДЭ} (hT : 2 * Real.pi тЙд T) (hTu : T тЙд u) :
    zeroDensityRho T тЙд zeroDensityRho u := by
  exact zeroDensityRho_mono_on_tail hT (le_trans hT hTu) hTu

/-- ЁЯМЯ **PROVED тАФ pointwise weighted-kernel lower bound on the tail.**
For `u тЙе T тЙе 2╧А`, `╧Б(T) ┬╖ K(u) тЙд ╧Б(u) ┬╖ K(u)`. -/
lemma zeroDensity_kernel_lower_bound
    {x y T u : тДЭ}
    (hT : 2 * Real.pi тЙд T) (hTu : T тЙд u) (hy : 0 < y) :
    zeroDensityRho T * positiveSmoothKernel x y u
      тЙд zeroDensityRho u * positiveSmoothKernel x y u :=
  mul_le_mul_of_nonneg_right
    (zeroDensityRho_le_of_tail hT hTu)
    (positiveSmoothKernel_nonneg hy)

-- =====================================================================
-- ┬зCCLXXII-B. Finite-window integral lower bound (`╧Б(T)` factored out)
-- =====================================================================
-- Uses ┬зCCLXXII-A pointwise lower bound + `intervalIntegral.integral_mono_on`
-- to factor `╧Б(T)` out of the integral.
--
-- The hypotheses include explicit integrability of both the kernel and
-- the density-weighted kernel тАФ these will be discharged downstream by
-- continuity on the compact `[T, X]`.
--
-- Adds:
--   zeroDensity_realIntegral_ge_constDensity_finite

/-- ЁЯМЯЁЯМЯ **PROVED тАФ finite-window integral lower bound** factoring
`╧Б(T)` outside the integral.

  `╧Б(T) ┬╖ тИл_T^X K(u) du тЙд тИл_T^X ╧Б(u) ┬╖ K(u) du`

for `T тЙе 2╧А` and `T тЙд X`, by pointwise `╧Б` monotonicity (┬зCCLXXII-A).
Integrability of both integrands is taken as a hypothesis here (to be
discharged downstream by continuity). -/
theorem zeroDensity_realIntegral_ge_constDensity_finite
    {x y T X : тДЭ}
    (hT : 2 * Real.pi тЙд T)
    (hTX : T тЙд X)
    (hy : 0 < y)
    (hKInt : IntervalIntegrable
              (fun u => positiveSmoothKernel x y u)
              MeasureTheory.volume T X)
    (hRInt : IntervalIntegrable
              (fun u => zeroDensityRho u * positiveSmoothKernel x y u)
              MeasureTheory.volume T X) :
    zeroDensityRho T * (тИл u in T..X, positiveSmoothKernel x y u)
      тЙд тИл u in T..X, zeroDensityRho u * positiveSmoothKernel x y u := by
  -- Rewrite the constant times the integral as an integral of the
  -- constant-scaled kernel.
  rw [тЖР intervalIntegral.integral_const_mul]
  -- Now apply pointwise monotone comparison on `[T, X]`.
  apply intervalIntegral.integral_mono_on hTX
  ┬╖ -- integrability of the LHS integrand `╧Б(T) * K(u)`
    exact hKInt.const_mul (zeroDensityRho T)
  ┬╖ -- integrability of the RHS integrand `╧Б(u) * K(u)`
    exact hRInt
  ┬╖ -- pointwise comparison: `╧Б(T) * K(u) тЙд ╧Б(u) * K(u)` on `[T, X]`
    intro u hu
    have hTu : T тЙд u := hu.1
    exact zeroDensity_kernel_lower_bound hT hTu hy

-- =====================================================================
-- ┬зCCLXXII-C. One-sided Cauchy kernel тАФ arctan primitive + tail Tendsto
-- =====================================================================
-- Foundational arctan / integral facts for ONE side of the paired
-- Cauchy kernel `y / ((u - a)┬▓ + y┬▓)`. The two-sided (paired) bound
-- in ┬зCCLXXII-D will follow by adding the `+a` and `-a` instances.
--
-- Adds:
--   arctan_shift_deriv_algebra                              тАФ algebra cleanup
--   hasDerivAt_arctan_shift_div                             тАФ chain rule
--   integral_cauchy_one_side_eq_arctan_sub                  тАФ FTC formula
--   tendsto_arctan_shift_atTop                              тАФ atTop limit of shift
--   cauchy_one_side_tail_integral_tendsto                   тАФ tail Tendsto

/-- тнР **PROVED тАФ algebra cleanup for arctan-shift derivative.** Isolates
the field manipulation `(1/y) / (1 + ((u - a)/y)┬▓) = y/((u - a)┬▓ + y┬▓)`. -/
lemma arctan_shift_deriv_algebra
    {a y u : тДЭ} (hy : y тЙа 0) :
    (1 / (1 + ((u - a) / y) ^ 2)) * (1 / y)
      = y / ((u - a) ^ 2 + y ^ 2) := by
  have hy2 : y ^ 2 тЙа 0 := pow_ne_zero 2 hy
  field_simp
  ring

/-- ЁЯМЯ **PROVED тАФ chain rule: derivative of `arctan ((u - a) / y)` in `u`.** -/
lemma hasDerivAt_arctan_shift_div
    (a : тДЭ) {y : тДЭ} (hy : y тЙа 0) (u : тДЭ) :
    HasDerivAt
      (fun v : тДЭ => Real.arctan ((v - a) / y))
      (y / ((u - a) ^ 2 + y ^ 2))
      u := by
  have h_inner :
      HasDerivAt (fun v : тДЭ => (v - a) / y) (1 / y) u := by
    have h_sub : HasDerivAt (fun v : тДЭ => v - a) (1 : тДЭ) u :=
      (hasDerivAt_id u).sub_const a
    simpa [one_div] using h_sub.div_const y
  have h_arctan :=
    (Real.hasDerivAt_arctan ((u - a) / y)).comp u h_inner
  -- h_arctan : HasDerivAt (fun v => arctan ((v - a)/y))
  --              ((1 / (1 + ((u - a)/y)^2)) * (1 / y)) u
  have h_eq := arctan_shift_deriv_algebra (a := a) (y := y) (u := u) hy
  rw [h_eq] at h_arctan
  exact h_arctan

/-- ЁЯМЯЁЯМЯ **PROVED тАФ FTC for the one-sided Cauchy kernel.**
`тИл_T^X y / ((u - a)┬▓ + y┬▓) du = arctan((X - a)/y) тИТ arctan((T - a)/y)`. -/
lemma integral_cauchy_one_side_eq_arctan_sub
    (a T X : тДЭ) {y : тДЭ} (hy : y тЙа 0) :
    (тИл u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ┬╖ intro u _
    exact hasDerivAt_arctan_shift_div a hy u
  ┬╖ -- The integrand is continuous, hence interval-integrable
    have h_cont : Continuous (fun u : тДЭ => y / ((u - a) ^ 2 + y ^ 2)) := by
      refine continuous_const.div ?_ ?_
      ┬╖ exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
      ┬╖ intro u
        have h1 : (0 : тДЭ) тЙд (u - a) ^ 2 := sq_nonneg _
        have h2 : (0 : тДЭ) < y ^ 2 := by positivity
        linarith
    exact h_cont.intervalIntegrable T X

/-- ЁЯМЯ **PROVED тАФ `arctan ((X - a)/y) тЖТ ╧А/2` as `X тЖТ тИЮ` for `y > 0`.**
The inner shift `(X - a)/y тЖТ тИЮ` (since `y > 0`); compose with
`Real.tendsto_arctan_atTop`. -/
lemma tendsto_arctan_shift_atTop
    (a : тДЭ) {y : тДЭ} (hy : 0 < y) :
    Tendsto
      (fun X : тДЭ => Real.arctan ((X - a) / y))
      Filter.atTop
      (ЁЭУЭ (Real.pi / 2)) := by
  have h_shift : Tendsto (fun X : тДЭ => (X - a) / y)
      Filter.atTop Filter.atTop := by
    have h_sub : Tendsto (fun X : тДЭ => X - a) Filter.atTop Filter.atTop :=
      tendsto_atTop_add_const_right Filter.atTop (-a) tendsto_id
    exact h_sub.atTop_div_const hy
  have h_arctan_at_top :
      Tendsto Real.arctan Filter.atTop (ЁЭУЭ (Real.pi / 2)) :=
    tendsto_nhds_of_tendsto_nhdsWithin Real.tendsto_arctan_atTop
  exact h_arctan_at_top.comp h_shift

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ one-sided Cauchy tail integral converges to
`╧А/2 тИТ arctan((T - a)/y)` as `X тЖТ тИЮ`.** Composes the FTC formula
with the arctan-shift limit. -/
lemma cauchy_one_side_tail_integral_tendsto
    (a T : тДЭ) {y : тДЭ} (hy : 0 < y) :
    Tendsto
      (fun X : тДЭ => тИл u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      Filter.atTop
      (ЁЭУЭ (Real.pi / 2 - Real.arctan ((T - a) / y))) := by
  have hy_ne : y тЙа 0 := ne_of_gt hy
  have h_eq : тИА X : тДЭ,
      (тИл u in T..X, y / ((u - a) ^ 2 + y ^ 2))
        = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
    intro X
    exact integral_cauchy_one_side_eq_arctan_sub a T X hy_ne
  have h_arctan_T : Tendsto (fun _ : тДЭ => Real.arctan ((T - a) / y))
      Filter.atTop (ЁЭУЭ (Real.arctan ((T - a) / y))) :=
    tendsto_const_nhds
  have h_sub :
      Tendsto
        (fun X : тДЭ =>
          Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y))
        Filter.atTop
        (ЁЭУЭ (Real.pi / 2 - Real.arctan ((T - a) / y))) :=
    (tendsto_arctan_shift_atTop a hy).sub h_arctan_T
  exact (h_sub.congr' (Filter.Eventually.of_forall fun X => (h_eq X).symm))

-- =====================================================================
-- ┬зCCLXXII-D. Paired kernel tail integral + multiplication by ╧Б(T)
-- =====================================================================
-- Combines two `cauchy_one_side_tail_integral_tendsto` instances at
-- `a := x` and `a := -x` into the paired `positiveSmoothKernel` tail
-- Tendsto. Then multiplies by the constant `╧Б(T)`.
--
-- Adds:
--   cauchy_one_side_intervalIntegrable                       тАФ integrability
--   positiveSmoothKernel_eq_sum_one_sides                    тАФ paired pointwise split
--   positiveSmoothKernel_tail_integral_tendsto               тАФ paired tail Tendsto
--   constDensity_positiveSmoothKernel_tail_tendsto           тАФ ├Ч ╧Б(T) version

/-- тнР **PROVED тАФ interval integrability of the one-sided Cauchy kernel.**
The integrand is continuous (denominator strictly positive for
`y тЙа 0`), hence interval-integrable on any `[T, X]`. -/
lemma cauchy_one_side_intervalIntegrable
    (a T X : тДЭ) {y : тДЭ} (hy : y тЙа 0) :
    IntervalIntegrable
      (fun u => y / ((u - a) ^ 2 + y ^ 2))
      MeasureTheory.volume T X := by
  have h_cont : Continuous (fun u : тДЭ => y / ((u - a) ^ 2 + y ^ 2)) := by
    refine continuous_const.div ?_ ?_
    ┬╖ exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
    ┬╖ intro u
      have h1 : (0 : тДЭ) тЙд (u - a) ^ 2 := sq_nonneg _
      have h2 : (0 : тДЭ) < y ^ 2 := by positivity
      linarith
  exact h_cont.intervalIntegrable T X

/-- тнР **PROVED тАФ paired positive kernel as sum of two one-sided pieces.**
Aligns with the one-sided lemma by taking `a := x` and `a := -x`. -/
lemma positiveSmoothKernel_eq_sum_one_sides
    (x y u : тДЭ) :
    positiveSmoothKernel x y u
      = y / ((u - x) ^ 2 + y ^ 2)
        + y / ((u - (-x)) ^ 2 + y ^ 2) := by
  unfold positiveSmoothKernel
  have h1 : (x - u) ^ 2 = (u - x) ^ 2 := by ring
  have h2 : (x + u) ^ 2 = (u - (-x)) ^ 2 := by ring
  rw [h1, h2]
  ring

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ paired `positiveSmoothKernel` tail integral
Tendsto.** Sum of two one-sided arctan-shift Tendsto results
(┬зCCLXXII-C5) with `a := x` and `a := -x`. -/
theorem positiveSmoothKernel_tail_integral_tendsto
    (x T : тДЭ) {y : тДЭ} (hy : 0 < y) :
    Tendsto
      (fun X : тДЭ => тИл u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (ЁЭУЭ ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y)))) := by
  have hy_ne : y тЙа 0 := ne_of_gt hy
  have h1 := cauchy_one_side_tail_integral_tendsto x T hy
  have h2 := cauchy_one_side_tail_integral_tendsto (-x) T hy
  have h_sum := h1.add h2
  refine h_sum.congr' ?_
  refine Filter.Eventually.of_forall (fun X => ?_)
  -- тИл_T^X positiveSmoothKernel = (тИл ... a=x) + (тИл ... a=-x)
  have hpoint : тИА u : тДЭ,
      positiveSmoothKernel x y u
        = y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2) :=
    fun u => positiveSmoothKernel_eq_sum_one_sides x y u
  have hcongr_integrand :
      (тИл u in T..X, positiveSmoothKernel x y u)
        = тИл u in T..X,
            (y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2)) :=
    intervalIntegral.integral_congr (fun u _ => hpoint u)
  have h_int_x := cauchy_one_side_intervalIntegrable x T X hy_ne
  have h_int_neg_x := cauchy_one_side_intervalIntegrable (-x) T X hy_ne
  have hsplit :
      (тИл u in T..X,
          (y / ((u - x) ^ 2 + y ^ 2)
            + y / ((u - (-x)) ^ 2 + y ^ 2)))
        = (тИл u in T..X, y / ((u - x) ^ 2 + y ^ 2))
            + тИл u in T..X, y / ((u - (-x)) ^ 2 + y ^ 2) :=
    intervalIntegral.integral_add h_int_x h_int_neg_x
  exact (hsplit.symm.trans hcongr_integrand.symm)

/-- ЁЯМЯЁЯМЯ **PROVED тАФ paired kernel tail integral times constant `╧Б(T)`
Tendsto.** Direct `Tendsto.mul` with the constant `╧Б(T)`. -/
theorem constDensity_positiveSmoothKernel_tail_tendsto
    (x T : тДЭ) {y : тДЭ} (hy : 0 < y) :
    Tendsto
      (fun X : тДЭ =>
        zeroDensityRho T *
          тИл u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (ЁЭУЭ (zeroDensityRho T *
        ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y))))) :=
  tendsto_const_nhds.mul
    (positiveSmoothKernel_tail_integral_tendsto x T hy)

-- =====================================================================
-- ┬зCCLXXII-E. Arctan rational lower bound `s/(1+s┬▓) тЙд arctan s`
-- =====================================================================
-- Mathlib doesn't have this lemma (only upper bounds and strict
-- monotonicity). Proof: let `f(t) := arctan t тИТ t/(1+t┬▓)`;
-- `f(0) = 0` and `f'(t) = 2t┬▓/(1+t┬▓)┬▓ тЙе 0`; so `f(s) тЙе 0` for `s тЙе 0`
-- by FTC + `integral_nonneg`.
--
-- Adds:
--   hasDerivAt_arctan_minus_div_one_add_sq    тАФ derivative of f(t)
--   div_one_add_sq_le_arctan                  тАФ rational lower bound on `arctan`
--   arctan_div_lower_rational                 тАФ `y┬╖A/(A┬▓+y┬▓) тЙд arctan(y/A)` form

/-- ЁЯМЯ **PROVED тАФ derivative of `arctan t тИТ t/(1+t┬▓)` is `2t┬▓/(1+t┬▓)┬▓`.**
Chain through `Real.hasDerivAt_arctan` + quotient rule. -/
lemma hasDerivAt_arctan_minus_div_one_add_sq (t : тДЭ) :
    HasDerivAt
      (fun x : тДЭ => Real.arctan x - x / (1 + x ^ 2))
      (2 * t ^ 2 / (1 + t ^ 2) ^ 2)
      t := by
  have h_arctan : HasDerivAt Real.arctan (1 / (1 + t ^ 2)) t :=
    Real.hasDerivAt_arctan t
  have h_id : HasDerivAt (fun x : тДЭ => x) (1 : тДЭ) t := hasDerivAt_id t
  have h_sq : HasDerivAt (fun x : тДЭ => x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_id t).pow 2
    simpa [pow_one] using h
  have h_den : HasDerivAt (fun x : тДЭ => 1 + x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_const t (1 : тДЭ)).add h_sq
    rwa [zero_add] at h
  have h_ne : (1 : тДЭ) + t ^ 2 тЙа 0 := by
    have h1 : (0 : тДЭ) тЙд t ^ 2 := sq_nonneg t
    linarith
  have h_div :
      HasDerivAt (fun x : тДЭ => x / (1 + x ^ 2))
        ((1 * (1 + t ^ 2) - t * (2 * t)) / (1 + t ^ 2) ^ 2) t :=
    h_id.div h_den h_ne
  have h_sub := h_arctan.sub h_div
  convert h_sub using 1
  field_simp
  ring

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `s/(1+s┬▓) тЙд arctan s` for `s тЙе 0`.** Routes through
the FTC for `f(t) := arctan t тИТ t/(1+t┬▓)`, noting `f(0) = 0` and
`f' тЙе 0`. -/
lemma div_one_add_sq_le_arctan {s : тДЭ} (hs : 0 тЙд s) :
    s / (1 + s ^ 2) тЙд Real.arctan s := by
  have h_zero : Real.arctan 0 - 0 / (1 + (0 : тДЭ) ^ 2) = 0 := by
    rw [Real.arctan_zero]; simp
  have h_cont :
      Continuous (fun t : тДЭ => 2 * t ^ 2 / (1 + t ^ 2) ^ 2) := by
    refine (continuous_const.mul (continuous_pow 2)).div ?_ ?_
    ┬╖ exact ((continuous_const.add (continuous_pow 2)).pow 2)
    ┬╖ intro t
      have h1 : (0 : тДЭ) тЙд t ^ 2 := sq_nonneg t
      have h_pos : (0 : тДЭ) < 1 + t ^ 2 := by linarith
      have : (0 : тДЭ) < (1 + t ^ 2) ^ 2 := by positivity
      linarith
  have hFTC :
      (Real.arctan s - s / (1 + s ^ 2))
          - (Real.arctan 0 - 0 / (1 + (0 : тДЭ) ^ 2))
        = тИл t in (0 : тДЭ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    have h := intervalIntegral.integral_eq_sub_of_hasDerivAt
      (fun t _ => hasDerivAt_arctan_minus_div_one_add_sq t)
      (h_cont.intervalIntegrable 0 s)
    exact h.symm
  rw [h_zero, sub_zero] at hFTC
  have h_int_nn :
      0 тЙд тИл t in (0 : тДЭ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    apply intervalIntegral.integral_nonneg hs
    intro u _
    have h_t_sq : (0 : тДЭ) тЙд 2 * u ^ 2 := by nlinarith [sq_nonneg u]
    have h_den : (0 : тДЭ) < (1 + u ^ 2) ^ 2 := by positivity
    exact div_nonneg h_t_sq (le_of_lt h_den)
  linarith

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ CLV-shaped rational lower bound on `arctan (y/A)`.**
For `A > 0`, `y тЙе 0`:

  `y ┬╖ A / (A┬▓ + y┬▓) тЙд arctan (y / A)`.

Direct application of `div_one_add_sq_le_arctan` at `s := y/A` after
the algebraic identity `(y/A)/(1+(y/A)┬▓) = yA/(A┬▓+y┬▓)`. -/
lemma arctan_div_lower_rational
    {A y : тДЭ} (hA : 0 < A) (hy : 0 тЙд y) :
    y * A / (A ^ 2 + y ^ 2) тЙд Real.arctan (y / A) := by
  have hA_ne : A тЙа 0 := ne_of_gt hA
  have h_div_nn : 0 тЙд y / A := div_nonneg hy (le_of_lt hA)
  have h_base : (y / A) / (1 + (y / A) ^ 2) тЙд Real.arctan (y / A) :=
    div_one_add_sq_le_arctan h_div_nn
  have h_alg : (y / A) / (1 + (y / A) ^ 2) = y * A / (A ^ 2 + y ^ 2) := by
    have hA_sq_pos : 0 < A ^ 2 := by positivity
    have hAy_sq_pos : 0 < A ^ 2 + y ^ 2 := by positivity
    field_simp
    ring
  rw [h_alg] at h_base
  exact h_base

-- =====================================================================
-- ┬зCCLXXII-F1. Arctan complement identity + one-sided tail lower bound
-- =====================================================================
-- Adds:
--   pi_div_two_sub_arctan_eq_arctan_inv
--   pi_div_two_sub_arctan_shift_eq_arctan_div
--   one_side_tail_lower_rational

/-- тнР **PROVED тАФ `╧А/2 тИТ arctan s = arctan (1/s)` for `s > 0`.**
Direct from Mathlib's `Real.arctan_inv_of_pos`. -/
lemma pi_div_two_sub_arctan_eq_arctan_inv
    {s : тДЭ} (hs : 0 < s) :
    Real.pi / 2 - Real.arctan s = Real.arctan (1 / s) := by
  rw [one_div]
  exact (Real.arctan_inv_of_pos hs).symm

/-- тнР **PROVED тАФ `╧А/2 тИТ arctan(A/y) = arctan(y/A)` for `A, y > 0`.**
CLV-shaped specialization of the complement identity. -/
lemma pi_div_two_sub_arctan_shift_eq_arctan_div
    {A y : тДЭ} (hA : 0 < A) (hy : 0 < y) :
    Real.pi / 2 - Real.arctan (A / y) = Real.arctan (y / A) := by
  have hs : 0 < A / y := div_pos hA hy
  rw [pi_div_two_sub_arctan_eq_arctan_inv hs]
  congr 1
  field_simp

/-- ЁЯМЯЁЯМЯ **PROVED тАФ one-sided tail rational lower bound.**
For `A, y > 0`:

  `y ┬╖ A / (A┬▓ + y┬▓) тЙд ╧А/2 тИТ arctan(A/y)`.

Combines ┬зCCLXXII-F1's complement identity with ┬зCCLXXII-E's
`arctan_div_lower_rational`. -/
lemma one_side_tail_lower_rational
    {A y : тДЭ} (hA : 0 < A) (hy : 0 < y) :
    y * A / (A ^ 2 + y ^ 2) тЙд Real.pi / 2 - Real.arctan (A / y) := by
  rw [pi_div_two_sub_arctan_shift_eq_arctan_div hA hy]
  exact arctan_div_lower_rational hA (le_of_lt hy)

-- =====================================================================
-- ┬зCCLXXII-F2. Paired arctan-tail rational lower bound
-- =====================================================================
-- Pairs `+|x|` and `-|x|` instances of ┬зCCLXXII-F1. Case-split on the
-- sign of `x` aligns `T ┬▒ |x|` with `T ┬▒ x` in the arctan arguments.
--
-- Adds:
--   paired_arctan_tail_lower_rational

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ paired arctan-tail rational lower bound.**
For `y > 0`, `T - |x| > 0`, `T + |x| > 0`:

  `y ┬╖ (T-|x|)/((T-|x|)┬▓ + y┬▓) + y ┬╖ (T+|x|)/((T+|x|)┬▓ + y┬▓)
     тЙд (╧А/2 тИТ arctan((T-x)/y)) + (╧А/2 тИТ arctan((T+x)/y))`.

Each LHS term is bounded by `one_side_tail_lower_rational`; case-split
on `0 тЙд x` aligns the arctan arguments. -/
lemma paired_arctan_tail_lower_rational
    {x y T : тДЭ}
    (hy : 0 < y)
    (hminus : 0 < T - |x|)
    (hplus : 0 < T + |x|) :
    y * (T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + y * (T + |x|) / ((T + |x|) ^ 2 + y ^ 2)
    тЙд (Real.pi / 2 - Real.arctan ((T - x) / y))
      + (Real.pi / 2 - Real.arctan ((T + x) / y)) := by
  have h_minus := one_side_tail_lower_rational hminus hy
  have h_plus := one_side_tail_lower_rational hplus hy
  by_cases hx : 0 тЙд x
  ┬╖ have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at h_minus h_plus
    rw [habs]
    linarith
  ┬╖ push_neg at hx
    have habs : |x| = -x := abs_of_neg hx
    have eq1 : T - (-x : тДЭ) = T + x := by ring
    have eq2 : T + (-x : тДЭ) = T - x := by ring
    rw [habs] at h_minus h_plus
    rw [eq1] at h_minus
    rw [eq2] at h_plus
    rw [habs, eq1, eq2]
    linarith

-- =====================================================================
-- ┬зCCLXXII-F3. Final composition: `HonestSmoothTailRationalLB` at `2╧А`
-- =====================================================================
-- Combines all CLV pieces into the honest tail lower bound at the
-- canonical basepoint `Tsmooth := 2╧А`.
--
-- Adds:
--   positiveSmoothKernel_continuous
--   positiveSmoothKernel_intervalIntegrable
--   zeroDensity_mul_positiveSmoothKernel_nonneg
--   zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
--   zeroDensity_realIntegral_mono_lower_limit
--   constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im
--   HonestSmoothTailRationalLB_twoPi

/-- тнР **PROVED тАФ `positiveSmoothKernel` is continuous in `u` for `y тЙа 0`.**
Denominators `(x ┬▒ u)┬▓ + y┬▓ тЙе y┬▓ > 0` are nonvanishing. -/
lemma positiveSmoothKernel_continuous {x y : тДЭ} (hy : y тЙа 0) :
    Continuous (fun u : тДЭ => positiveSmoothKernel x y u) := by
  have hy2 : (0 : тДЭ) < y ^ 2 := by positivity
  unfold positiveSmoothKernel
  refine continuous_const.mul ?_
  refine Continuous.add ?_ ?_
  ┬╖ refine continuous_const.div ?_ ?_
    ┬╖ exact ((continuous_const.sub continuous_id).pow 2).add continuous_const
    ┬╖ intro u
      have h : (0 : тДЭ) тЙд (x - u) ^ 2 := sq_nonneg _
      linarith
  ┬╖ refine continuous_const.div ?_ ?_
    ┬╖ exact ((continuous_const.add continuous_id).pow 2).add continuous_const
    ┬╖ intro u
      have h : (0 : тДЭ) тЙд (x + u) ^ 2 := sq_nonneg _
      linarith

/-- тнР **PROVED тАФ `positiveSmoothKernel` is interval-integrable.** -/
lemma positiveSmoothKernel_intervalIntegrable
    {x y : тДЭ} (hy : y тЙа 0) (a b : тДЭ) :
    IntervalIntegrable
      (fun u => positiveSmoothKernel x y u)
      MeasureTheory.volume a b :=
  (positiveSmoothKernel_continuous hy).intervalIntegrable a b

/-- тнР **PROVED тАФ `╧Б(u) ┬╖ K(u) тЙе 0` on the tail.** -/
lemma zeroDensity_mul_positiveSmoothKernel_nonneg
    {u x y : тДЭ} (hu : 2 * Real.pi тЙд u) (hy : 0 < y) :
    0 тЙд zeroDensityRho u * positiveSmoothKernel x y u :=
  mul_nonneg
    (zeroDensityRho_nonneg_of_ge_two_pi hu)
    (positiveSmoothKernel_nonneg hy)

/-- тнР **PROVED тАФ `╧Б ┬╖ K` is interval-integrable on `[a, b] тКВ (0, тИЮ)`.** -/
lemma zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
    {x y a b : тДЭ} (ha : 0 < a) (hab : a тЙд b) (hy : y тЙа 0) :
    IntervalIntegrable
      (fun u => zeroDensityRho u * positiveSmoothKernel x y u)
      MeasureTheory.volume a b := by
  refine ContinuousOn.intervalIntegrable_of_Icc hab ?_
  refine ContinuousOn.mul ?_ ((positiveSmoothKernel_continuous hy).continuousOn)
  exact Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    (fun u hu => lt_of_lt_of_le ha hu.1)

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `тИл_T^X` dominated by `тИл_{2╧А}^X` for nonneg integrand.**
Via interval additivity `тИл_{2╧А}^X = тИл_{2╧А}^T + тИл_T^X` plus
nonnegativity of `тИл_{2╧А}^T ╧Б┬╖K`. -/
lemma zeroDensity_realIntegral_mono_lower_limit
    {x y T X : тДЭ}
    (hT : 2 * Real.pi тЙд T)
    (hTX : T тЙд X)
    (hy : 0 < y) :
    (тИл u in T..X, zeroDensityRho u * positiveSmoothKernel x y u)
      тЙд тИл u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel x y u := by
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have hy_ne : y тЙа 0 := ne_of_gt hy
  have h_int_left :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) h2pi_pos hT hy_ne
  have h_int_right :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) (lt_of_lt_of_le h2pi_pos hT) hTX hy_ne
  have hadd := intervalIntegral.integral_add_adjacent_intervals
    h_int_left h_int_right
  have h_nn :
      0 тЙд тИл u in (2 * Real.pi)..T,
            zeroDensityRho u * positiveSmoothKernel x y u := by
    apply intervalIntegral.integral_nonneg hT
    intro u hu
    exact zeroDensity_mul_positiveSmoothKernel_nonneg hu.1 hy
  linarith

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ KEY CLV BRIDGE.** The constant-density `╧Б(T)`
times the paired arctan-tail integral target is dominated by
`-(zeroDensitySmoothTailModel (2╧А) z).im` for any adaptive `(z, T)`.

Composes:
* ┬зCCLXXII-D's `constDensity_positiveSmoothKernel_tail_tendsto`
  (LHS Tendsto);
* ┬зCCLXXI's `zeroDensitySmoothTailModel_neg_im_tendsto_real_integral`
  (RHS Tendsto);
* eventual finite-`X` chain: ┬зCCLXXII-B (`╧Б(T) тИл_T^X K тЙд тИл_T^X ╧Б┬╖K`)
  followed by ┬зCCLXXII-F3-3 (`тИл_T^X ╧Б┬╖K тЙд тИл_{2╧А}^X ╧Б┬╖K`);
* `le_of_tendsto_of_tendsto'` to pass through the limits. -/
theorem constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im
    {z : тДВ} {T : тДЭ}
    (hT : 2 * Real.pi тЙд T)
    (hy : 0 < z.im) :
    zeroDensityRho T *
      ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
        + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
      тЙд -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  have hy_ne : z.im тЙа 0 := ne_of_gt hy
  -- LHS Tendsto (┬зCCLXXII-D)
  have h_lhs := constDensity_positiveSmoothKernel_tail_tendsto z.re T hy
  -- RHS Tendsto, rewritten using `positiveSmoothKernel` (┬зCCLXXI + integral_congr)
  have h_rhs_raw :=
    zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
      (2 * Real.pi) le_rfl hy
  have h_rhs : Tendsto
      (fun X : тДЭ =>
        тИл u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel z.re z.im u)
      Filter.atTop
      (ЁЭУЭ (-(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im)) := by
    refine h_rhs_raw.congr' ?_
    refine Filter.Eventually.of_forall (fun X => ?_)
    apply intervalIntegral.integral_congr
    intro u _
    show zeroDensityRho u
            * (z.im * (1 / ((z.re - u) ^ 2 + z.im ^ 2)
                + 1 / ((z.re + u) ^ 2 + z.im ^ 2)))
          = zeroDensityRho u * positiveSmoothKernel z.re z.im u
    unfold positiveSmoothKernel
    ring
  -- Eventually `X тЙе T`: LHS тЙд RHS finite
  have h_ev :
      тИАс╢а X : тДЭ in Filter.atTop,
        zeroDensityRho T *
            (тИл u in T..X, positiveSmoothKernel z.re z.im u)
          тЙд тИл u in (2 * Real.pi)..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    have h_kInt :=
      positiveSmoothKernel_intervalIntegrable (x := z.re) (y := z.im) hy_ne T X
    have h_rInt :=
      zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
        (x := z.re) (y := z.im)
        (lt_of_lt_of_le (by positivity : (0 : тДЭ) < 2 * Real.pi) hT)
        hTX hy_ne
    have h_step1 :
        zeroDensityRho T *
            (тИл u in T..X, positiveSmoothKernel z.re z.im u)
          тЙд тИл u in T..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u :=
      zeroDensity_realIntegral_ge_constDensity_finite
        (x := z.re) (y := z.im) hT hTX hy h_kInt h_rInt
    have h_step2 :=
      zeroDensity_realIntegral_mono_lower_limit
        (x := z.re) (y := z.im) hT hTX hy
    linarith
  -- Pass through the limits (eventual form)
  exact le_of_tendsto_of_tendsto_of_frequently h_lhs h_rhs h_ev.frequently

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `HonestSmoothTailRationalLB` at the
canonical basepoint `Tsmooth := 2╧А`.** Final composition:
* `smoothTailRationalLowerBoundAbs` unfolds to `╧Б(T) ┬╖ rational(T)`;
* ┬зCCLXXII-F2 (`paired_arctan_tail_lower_rational`) replaces
  `rational(T)` by the arctan-sum;
* ┬зCCLXXII-F3 bridge dominates the arctan-sum by the honest tail. -/
theorem HonestSmoothTailRationalLB_twoPi :
    HonestSmoothTailRationalLB (2 * Real.pi) le_rfl := by
  intro z T hT hy hregime
  -- Geometry: 2(1 + |z.re| + z.im) тЙд T тЯ╣ |z.re| < T/2 < T, so T - |z.re| > 0.
  have habs_nn : (0 : тДЭ) тЙд |z.re| := abs_nonneg _
  have hminus : 0 < T - |z.re| := by
    have hy_nn : (0 : тДЭ) тЙд z.im := le_of_lt hy
    nlinarith
  have hplus : 0 < T + |z.re| := by
    have h_pi_pos : (0 : тДЭ) < Real.pi := Real.pi_pos
    have : (0 : тДЭ) < 2 * Real.pi := by positivity
    linarith
  -- Unfold `smoothTailRationalLowerBoundAbs`
  have h_unfold :
      smoothTailRationalLowerBoundAbs z.re z.im T
        = zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2)) := rfl
  rw [h_unfold]
  -- Apply paired arctan rational bound
  have h_paired := paired_arctan_tail_lower_rational
    (x := z.re) (y := z.im) (T := T) hy hminus hplus
  have h╧Б_nn : 0 тЙд zeroDensityRho T :=
    zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_chain1 :
      zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2))
        тЙд zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T + z.re) / z.im))) :=
    mul_le_mul_of_nonneg_left h_paired h╧Б_nn
  -- Bridge: arctan-sum тЙд honest tail neg-Im
  have h_chain2 :
      zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
        тЙд -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im :=
    constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im hT hy
  -- Align `T - (-z.re)` with `T + z.re`
  have hT_neg_re : T - (-z.re) = T + z.re := by ring
  rw [hT_neg_re] at h_chain2
  linarith

