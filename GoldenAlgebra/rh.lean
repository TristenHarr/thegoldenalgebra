    {f : вДВ вЖТ вДВ} {s : вДВ} {m : вДХ}
    (hAn : AnalyticAt вДВ f s)
    (_hm_pos : 0 < m)
    (horder : analyticOrderAt f s = (m : вДХвИЮ))
    (_hnotLocal : ¬ђ f =бґ†[рЭУЭ s] 0) :
    HasAnalyticZeroFactorization f s m :=
  let hExists :
