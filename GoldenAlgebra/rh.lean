        - bottom / (2 * Real.pi) + 7 / 8
  top_main_arith :
    (top / (2 * Real.pi)) * topLogUpper
      - top / (2 * Real.pi) + 7 / 8
        вЙ§ mainUpper
  upperCount_minus_lowerMain_le :
    (rightCount : вДЭ) - mainLower вЙ§ (25167 / 10000 : вДЭ)
