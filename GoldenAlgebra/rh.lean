/-- **PROVED вАФ L2 product law (scalar form).** -/
theorem Lambda_product_law (f g df dg : вДЭ) (hf : f вЙ† 0) (hg : g вЙ† 0) :
    (df * g + f * dg) / (f * g) = df / f + dg / g := by
  field_simp
  ring

/-- **PROVED вАФ L3 quotient law (scalar form).** -/
theorem Lambda_quotient_law (f g df dg : вДЭ) (hf : f вЙ† 0) (hg : g вЙ† 0) :
    ((df * g - f * dg) / g^2) / (f / g) = df / f - dg / g := by
  field_simp
  ring

/-- **PROVED вАФ L4 power law at m=2.** -/
theorem Lambda_power_law_two (f df : вДЭ) (hf : f вЙ† 0) :
    (2 * f * df) / (f^2) = 2 * (df / f) := by
  field_simp
  ring

/-- **PROVED вАФ L4 power law at m=3.** -/
theorem Lambda_power_law_three (f df : вДЭ) (hf : f вЙ† 0) :
    (3 * f^2 * df) / (f^3) = 3 * (df / f) := by
  field_simp
  ring

/-- **PROVED вАФ L6 local charge for simple root (real form).** -/
theorem Lambda_local_charge_simple_root
    (z a g dg : вДЭ) (ha : z вЙ† a) (hg : g вЙ† 0) :
    (g + (z - a) * dg) / ((z - a) * g)
      = 1 / (z - a) + dg / g := by
  have ha' : z - a вЙ† 0 := sub_ne_zero.mpr ha
  field_simp
  ring

/-- **PROVED вАФ L7 divisor field for 3 simple roots.** -/
theorem divisor_field_three_roots (z a b c : вДЭ)
    (ha : z вЙ† a) (hb : z вЙ† b) (hc : z вЙ† c) :
    1 / (z - a) + 1 / (z - b) + 1 / (z - c)
      = ((z-b)*(z-c) + (z-a)*(z-c) + (z-a)*(z-b))
          / ((z-a)*(z-b)*(z-c)) := by
  have ha' : z - a вЙ† 0 := sub_ne_zero.mpr ha
  have hb' : z - b вЙ† 0 := sub_ne_zero.mpr hb
  have hc' : z - c вЙ† 0 := sub_ne_zero.mpr hc
  field_simp
  ring

/-- **PROVED вАФ L8 critical equilibrium for 2 simple roots at midpoint.** -/
theorem critical_equilibrium_two_roots (a b : вДЭ) (hab : a вЙ† b) :
    let z := (a + b) / 2
    1 / (z - a) + 1 / (z - b) = 0 := by
  have h1 : ((a + b) / 2 - a) = (b - a) / 2 := by ring
  have h2 : ((a + b) / 2 - b) = (a - b) / 2 := by ring
  have hba : b - a вЙ† 0 := sub_ne_zero.mpr (Ne.symm hab)
  have hab' : a - b вЙ† 0 := sub_ne_zero.mpr hab
  simp only [h1, h2]
