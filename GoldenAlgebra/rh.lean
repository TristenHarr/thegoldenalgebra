/-- **Closed-form error bound discharged on the finite band.**
The IBP/Stieltjes-side hypothesis: there's an `error : вДВ вЖТ вДВ` whose
imaginary part is bounded by the slab-specific closed form on all of
`[10, 140]`. -/
def closedFormErrorControlledOnFiniteBand (error : вДВ вЖТ вДВ) : Prop :=
  вИА {z : вДВ} {T : вДЭ},
    10 вЙ§ T вЖТ T вЙ§ 140 вЖТ
    0 < z.im вЖТ
    2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      |(error z).im|
        вЙ§ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T

/-- рЯМЯ **PROVED вАФ Finite-band error margin** via `slabCD`. Direct `le_trans`
chaining the IBP-side error bound with the slab-side model-margin
domination вАФ BOTH using the same `(slabCD T).1, (slabCD T).2`. -/
theorem finiteBand_errorMargin_of_slabCD
    {M : CloudDensityTailModelDecomposition}
    {error : вДВ вЖТ вДВ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : closedFormErrorControlledOnFiniteBand error)
    {z : вДВ} {T : вДЭ}
    (hT10 : 10 вЙ§ T) (hT140 : T вЙ§ 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(error z).im| вЙ§ -(M.model z).im :=
  le_trans (herr hT10 hT140 hy hreg)
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hT10 hT140 hy hreg)

-- =====================================================================
-- CLXXXV: Concrete `xiCloudDensityModel_zeros100ceil`
-- =====================================================================
-- A trivial-but-valid concrete `CloudDensityTailModelDecomposition`
-- with `zeros = zeros100ceil`. Uses a deliberately massive linear density
-- tail `densityTail z := -i ¬Ј (100 ¬Ј z.im)` so the `densityTailRationalLB`
-- obligation reduces to the crude bound `smoothTail вЙ§ 100¬Јy` on the
-- adaptive region. Plumbing only вАФ the real analytic decomposition and
-- IBP/Stieltjes error bound remain open.

/-- **Trivial massive-margin density tail.** `-i ¬Ј 100¬Јz.im` so its
`-Im` is `100¬Јz.im`, which trivially dominates any reasonable
`smoothTailRationalLowerBoundAbs` on the admissible region. -/
noncomputable def linearDensityTail100 : вДВ вЖТ вДВ :=
  fun z => -Complex.I * ((100 * z.im : вДЭ) : вДВ)

/-- в≠Р **PROVED вАФ `-Im(linearDensityTail100 z) = 100¬Јz.im`.** -/
lemma linearDensityTail100_neg_im (z : вДВ) :
    -(linearDensityTail100 z).im = 100 * z.im := by
  unfold linearDensityTail100
  simp [Complex.mul_im, Complex.neg_im, Complex.I_re, Complex.I_im,
        Complex.ofReal_re, Complex.ofReal_im]

/-- в≠Р **PROVED вАФ `(linearDensityTail100 z).im = -100¬Јz.im вЙ§ 0`** for `0 < z.im`. -/
lemma linearDensityTail100_im_nonpos
    {z : вДВ} (hz : 0 < z.im) :
    (linearDensityTail100 z).im вЙ§ 0 := by
  have h := linearDensityTail100_neg_im z
  linarith

/-- в≠Р **PROVED вАФ `zeroDensityRho T вЙ§ T`** for `T вЙ• 2ѕА`.
Via `log x вЙ§ x` applied to `x = T/(2ѕА)`, then `log(T/(2ѕА))/(2ѕА) вЙ§ T/(4ѕА¬≤) вЙ§ T`
(since `4ѕА¬≤ > 1`). -/
lemma zeroDensityRho_le_T
    {T : вДЭ} (hT2pi : 2 * Real.pi вЙ§ T) :
    zeroDensityRho T вЙ§ T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_pos : 0 < T / (2 * Real.pi) := by positivity
  have h_log_le : Real.log (T / (2 * Real.pi)) вЙ§ T / (2 * Real.pi) - 1 :=
    Real.log_le_sub_one_of_pos hT_2pi_pos
  have h_log_le_T_2pi : Real.log (T / (2 * Real.pi)) вЙ§ T / (2 * Real.pi) := by
    linarith
  have h_inv_pos : (0 : вДЭ) < 1 / (2 * Real.pi) := by positivity
  have h_step :
      (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        вЙ§ (1 / (2 * Real.pi)) * (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_log_le_T_2pi (le_of_lt h_inv_pos)
  -- (1/(2ѕА))¬Ј(T/(2ѕА)) = T/(4ѕА¬≤)
  have h_2pi_ne : (2 * Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_2pi_pos
  have h_eq :
      (1 / (2 * Real.pi)) * (T / (2 * Real.pi))
        = T / ((2 * Real.pi)^2) := by
    rw [sq, mul_comm (2 * Real.pi) (2 * Real.pi)]
    field_simp
  have h_2pi_sq_gt_1 : (1 : вДЭ) вЙ§ (2 * Real.pi)^2 := by
    nlinarith [h_pi_gt_d2]
  have h_T_div_le : T / ((2 * Real.pi)^2) вЙ§ T := by
    rw [div_le_iffвВА (by positivity : (0:вДЭ) < (2 * Real.pi)^2)]
    nlinarith [hT_pos, h_2pi_sq_gt_1]
  linarith [h_step, h_eq, h_T_div_le]

/-- в≠Р **PROVED вАФ Crude smooth-tail kernel bound.**
On the admissible region, each kernel term `y¬ЈU/(U¬≤+y¬≤) вЙ§ y/U`, and
`T-|x|, T+|x| вЙ• T/2` gives `y/U вЙ§ 2y/T`. So the sum is `вЙ§ 4y/T`,
which we round up to `5y/T` for safety margin (any bound suffices). -/
lemma smoothTail_kernel_le_five_y_div_T
    {x y T : вДЭ}
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) вЙ§ T) :
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))
      вЙ§ 5 * y / T := by
  have h_absx_nn : 0 вЙ§ |x| := abs_nonneg _
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hT_ge : T вЙ• 2 := by linarith
  have hT_pos : 0 < T := by linarith
  have hTpos2 : 0 < T / 2 := by linarith
  -- |x| вЙ§ T/2 - 1, y вЙ§ T/2 - 1, so T - |x| вЙ• T/2 + 1 > T/2
  have h_T_minus_x_lo : T / 2 вЙ§ T - |x| := by linarith
  have h_T_plus_x_lo : T вЙ§ T + |x| := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_T_plus_x_pos : 0 < T + |x| := by linarith
  -- First term: y¬Ј(T-|x|)/((T-|x|)¬≤+y¬≤) вЙ§ y/(T-|x|)
  have h_term1_bound : y * (T - |x|) / ((T - |x|)^2 + y^2) вЙ§ y / (T - |x|) := by
    rw [div_le_div_iffвВА (by positivity : 0 < (T - |x|)^2 + y^2) h_T_minus_x_pos]
    nlinarith [sq_nonneg (T - |x|), sq_nonneg y]
  have h_term2_bound : y * (T + |x|) / ((T + |x|)^2 + y^2) вЙ§ y / (T + |x|) := by
    rw [div_le_div_iffвВА (by positivity : 0 < (T + |x|)^2 + y^2) h_T_plus_x_pos]
    nlinarith [sq_nonneg (T + |x|), sq_nonneg y]
  -- y/(T-|x|) вЙ§ y/(T/2) = 2y/T
  have h_term1_le_2yT : y / (T - |x|) вЙ§ 2 * y / T := by
    rw [div_le_div_iffвВА h_T_minus_x_pos hT_pos]
    nlinarith [h_T_minus_x_lo, hy_nn]
  have h_term2_le_yT : y / (T + |x|) вЙ§ y / T :=
    div_le_div_of_nonneg_left hy_nn hT_pos h_T_plus_x_lo
  -- Combine: total вЙ§ 2y/T + y/T = 3y/T вЙ§ 5y/T
  have h_total : y / (T - |x|) + y / (T + |x|) вЙ§ 3 * y / T := by
    have : 2 * y / T + y / T = 3 * y / T := by ring
    linarith [h_term1_le_2yT, h_term2_le_yT]
  have h3le5 : 3 * y / T вЙ§ 5 * y / T := by
    apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
    nlinarith
  linarith [h_term1_bound, h_term2_bound, h_total, h3le5]

/-- в≠Р **PROVED вАФ Crude smooth-tail upper bound on the adaptive region.**
`smoothTail вЙ§ ѕБ(T)¬Ј5y/T вЙ§ T¬Ј5y/T = 5y вЙ§ 100¬Јy`. -/
lemma smoothTailRationalLowerBoundAbs_le_100y
    {x y T : вДЭ}
    (hT2pi : 2 * Real.pi вЙ§ T)
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) вЙ§ T) :
    smoothTailRationalLowerBoundAbs x y T вЙ§ 100 * y := by
  unfold smoothTailRationalLowerBoundAbs
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have h_rho_le : zeroDensityRho T вЙ§ T := zeroDensityRho_le_T hT2pi
  have h_rho_nn : 0 вЙ§ zeroDensityRho T := by
    unfold zeroDensityRho
    have h_2pi_pos : 0 < 2 * Real.pi := by linarith
    have hT_2pi_ge_one : (1 : вДЭ) вЙ§ T / (2 * Real.pi) := by
      rw [le_div_iffвВА h_2pi_pos]; linarith
    have h_log_nn : 0 вЙ§ Real.log (T / (2 * Real.pi)) := Real.log_nonneg hT_2pi_ge_one
    positivity
  have h_kernel : (y * (T - |x|) / ((T - |x|)^2 + y^2)
                    + y * (T + |x|) / ((T + |x|)^2 + y^2))
                    вЙ§ 5 * y / T :=
    smoothTail_kernel_le_five_y_div_T hy hreg
  have h_kernel_nn :
      0 вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h_absx_nn : 0 вЙ§ |x| := abs_nonneg _
    have hT_ge : T вЙ• 2 := by linarith
    have h_T_minus_x_pos : 0 < T - |x| := by linarith
    have h_T_plus_x_pos : 0 < T + |x| := by linarith
    have h1 : 0 вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
      apply div_nonneg
      ¬Ј exact mul_nonneg hy_nn (le_of_lt h_T_minus_x_pos)
      ¬Ј positivity
    have h2 : 0 вЙ§ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
      apply div_nonneg
      ¬Ј exact mul_nonneg hy_nn (le_of_lt h_T_plus_x_pos)
      ¬Ј positivity
    linarith
  have h_combine :
      zeroDensityRho T * (y * (T - |x|) / ((T - |x|)^2 + y^2)
        + y * (T + |x|) / ((T + |x|)^2 + y^2))
        вЙ§ T * (5 * y / T) := by
    apply mul_le_mul h_rho_le h_kernel h_kernel_nn (by linarith)
  have h_T5y : T * (5 * y / T) = 5 * y := by
    field_simp
  have h_5y_le : 5 * y вЙ§ 100 * y := by linarith
  linarith

/-- в≠Р **PROVED вАФ `linearDensityTail100` discharges the rational LB obligation.** -/
theorem linearDensityTail100_rationalLB :
    вИА z : вДВ, вИА T : вДЭ, 2 * Real.pi вЙ§ T вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        smoothTailRationalLowerBoundAbs z.re z.im T
          вЙ§ -(linearDensityTail100 z).im := by
  intro z T hT2pi hy hreg
  rw [linearDensityTail100_neg_im]
  exact smoothTailRationalLowerBoundAbs_le_100y hT2pi hy hreg

/-- рЯОѓрЯОѓрЯОѓ **CONCRETE xi-facing cloud-density model over `zeros100ceil`.** рЯОѓрЯОѓрЯОѓ
The first concrete inhabitant of `CloudDensityTailModelDecomposition`
plumbed in this file. Uses `linearDensityTail100` (trivial massive-margin
