  have h_factor := smoothKernelNormFactor_ge_five_div_twentyNine hy hxy
  have h_rho_nn : (0 : ℝ) ≤ 259 / 3586 := by norm_num
  have h_factor_nn : (0 : ℝ) ≤ 5 / 29 := by norm_num
  have h_rho_nn' : (0 : ℝ) ≤ zeroDensityRho 10 := le_trans h_rho_nn h_rho
  exact mul_le_mul h_rho h_factor h_factor_nn h_rho_nn'

