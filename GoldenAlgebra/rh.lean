/-! ### CW29: large-height Trudgian split for the remaining Backlund theorem -/

/-- Trudgian-style explicit envelope for the argument of the zeta
function on the critical line.  The coefficients are the standard
published shape
`0.111 log T + 0.275 log log T + 2.450`. -/
noncomputable def trudgianBacklundEnvelope (T : ℝ) : ℝ :=
  (111 / 1000 : ℝ) * Real.log T
    + (11 / 40 : ℝ) * Real.log (Real.log T)
    + 49 / 20

/-- Sourced large-height explicit `S(T)` estimate.  This is the analytic
number-theory input supplied by the Trudgian/Backlund explicit argument
bound, restricted here to the range needed by the final split. -/
structure TrudgianBacklundLargeHeightInput : Prop where
  bound :
