  have h_exp24_eq : Real.exp (24 : ℝ) = (Real.exp 1)^24 := by
    have h := Real.exp_one_pow 24
    have h_cast : ((24 : ℕ) : ℝ) = (24 : ℝ) := by norm_num
    rw [← h_cast]
    exact h.symm
  have h_exp_24_5_pow : (Real.exp (24 / 5 : ℝ))^5 = Real.exp 24 := by
    have h := Real.exp_nat_mul (24 / 5 : ℝ) 5
    have h_eq : ((5 : ℕ) : ℝ) * (24 / 5 : ℝ) = 24 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_pow_num : (2.72 : ℝ)^24 < (140 : ℝ)^5 := by norm_num
  have h_exp_pow_lt :
      (Real.exp (24 / 5 : ℝ))^5 < (140 : ℝ)^5 := by
    rw [h_exp_24_5_pow, h_exp24_eq]
    linarith
  have hexp_nn : 0 ≤ Real.exp (24 / 5 : ℝ) :=
    le_of_lt (Real.exp_pos _)
  have h140_nn : (0 : ℝ) ≤ 140 := by norm_num
  exact
    (pow_lt_pow_iff_left₀ hexp_nn h140_nn
      (by norm_num : (5 : ℕ) ≠ 0)).mp h_exp_pow_lt

