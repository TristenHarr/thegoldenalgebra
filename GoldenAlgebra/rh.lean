/-! ## CW: Begin the Backlund theorem layer -/

/-! ### CW1: named structure for the Backlund good-height counting estimate -/

/-- Named structure for Backlund's good-height zero-counting estimate.
This is a thin wrapper around `ConcreteSBacklundEstimateFrom140OnGoodHeights`
that provides a fixed location for future refinement into named classical
pieces (Jensen's bound, argument variation estimate, zero-count window
inequality, etc.). -/
structure BacklundGoodHeightCountingEstimate : Prop where
  bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Inhabit `ConcreteSBacklundEstimateFrom140OnGoodHeights` from the
named Backlund counting estimate. -/
noncomputable def BacklundGoodHeightCountingEstimate.toH140
    (B : BacklundGoodHeightCountingEstimate) :
    ConcreteSBacklundEstimateFrom140OnGoodHeights :=
  B.bound

/-! ### CW2: named jump-extension input for `E` -/

/-- Named structure for the zero-count jump / right-limit regularity needed
to extend the good-height Backlund estimate (H140) to all heights `T ≥ 140`.
This is the second classical analytic obligation; placing it in a named
structure provides a fixed anchor for future refinement into right-
continuity + density-of-good-heights lemmas. -/
structure ConcreteSBacklundJumpExtensionInput
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights) : Prop where
  extension : ConcreteSBacklundEstimateExtensionFrom140 H140

/-- Inhabit `ConcreteSBacklundEstimateExtensionFrom140 H140` from the
named jump-extension package. -/
noncomputable def ConcreteSBacklundJumpExtensionInput.toExtension
    {H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights}
    (J : ConcreteSBacklundJumpExtensionInput H140) :
    ConcreteSBacklundEstimateExtensionFrom140 H140 :=
  J.extension

/-! ### CW3: final theorem using H140 + jump-extension inputs -/

/-- **CW3 — FINAL THEOREM via Backlund + jump-extension inputs:** takes the
Backlund good-height counting estimate (anchored by CW1) and the zero-count
jump-extension input (anchored by CW2), producing the headline bound. -/
theorem concreteS_halfLogPlusHalf_of_backlundAndJumpInputs
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (J : ConcreteSBacklundJumpExtensionInput H140)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundInputs H140 J.toExtension hT

/-! ### CW4: split `J` into a real-analysis bridge and a right-continuity input -/

/-- Right-continuity input for `concreteS` at heights `T ≥ 140`.  This is
the genuine zero-count regularity content behind extending the Backlund
bound from good heights to all heights. -/
structure ConcreteSRightContinuityInput : Prop where
  right_continuous_at :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      Filter.Tendsto concreteS (nhdsWithin T (Set.Ioi T)) (nhds (concreteS T))

/-- Density/right-continuity bridge: if the good-height Backlund estimate
holds and `concreteS` is right-continuous on `[140, ∞)`, then the estimate
extends to all `T ≥ 140`.  This packages the bridge so that future code
can specialize either the analytic content (`RC`) or the discharging
proof. -/
structure ConcreteSBacklundRightContinuityBridge
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (_RC : ConcreteSRightContinuityInput) : Prop where
  extension : ConcreteSBacklundEstimateExtensionFrom140 H140

/-- Inhabit the jump-extension input from the right-continuity bridge. -/
noncomputable def ConcreteSBacklundRightContinuityBridge.toJumpExtension
    {H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights}
    {RC : ConcreteSRightContinuityInput}
    (B : ConcreteSBacklundRightContinuityBridge H140 RC) :
    ConcreteSBacklundJumpExtensionInput H140 where
  extension := B.extension

/-- **CW4 — FINAL THEOREM via Backlund + right-continuity inputs:** uses the
right-continuity-based bridge. -/
theorem concreteS_halfLogPlusHalf_of_backlundAndRightContinuity
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (RC : ConcreteSRightContinuityInput)
    (B : ConcreteSBacklundRightContinuityBridge H140 RC)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundAndJumpInputs
    H140 B.toJumpExtension hT

/-- **CW4 — proof of the bridge from right-continuity alone.**  Given
`RC` (right-continuity of `concreteS` at every `T ≥ 140`) and the
good-height Backlund estimate `H140`, the estimate extends to all
`T ≥ 140`.  Proof: at every `T ≥ 140`, the existing good-height density
lemma `exists_goodHeight_between_self_add` builds a sequence
`u_n ∈ (T, T + 1/(n+1))` of good heights `≥ 140`; `H140` bounds the
inequality at each `u_n`; right-continuity of `concreteS` plus continuity
of `(1/2)·log u + 1/2` lets us pass to the limit as `u_n → T⁺`. -/
noncomputable def ConcreteSRightContinuityInput.toBacklundExtension
    (RC : ConcreteSRightContinuityInput)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights) :
    ConcreteSBacklundEstimateExtensionFrom140 H140 where
  extension := by
    intro T hT
    have h140_pos : (0 : ℝ) < 140 := by norm_num
    have hT_pos : (0 : ℝ) < T := lt_of_lt_of_le h140_pos hT
    -- Sequence of good heights u_n ∈ (T, T + 1/(n+1)), with u_n ≥ 140.
    have hseq : ∀ n : ℕ, ∃ U : ℝ,
        RvMGoodHeight U ∧ (140 : ℝ) ≤ U ∧ T < U ∧
          U < T + 1 / ((n : ℝ) + 1) := by
      intro n
      have hε : (0 : ℝ) < 1 / ((n : ℝ) + 1) := by positivity
      obtain ⟨U, hTU, hUeps, hUgood⟩ :=
        exists_goodHeight_between_self_add hT_pos hε
      have hUpos : (0 : ℝ) < U := lt_trans hT_pos hTU
      have hUlower : (140 : ℝ) ≤ U := le_trans hT (le_of_lt hTU)
      exact ⟨U, ⟨hUpos, hUgood⟩, hUlower, hTU, hUeps⟩
    choose u hugood hulower hu_strict hu_lt using hseq
    -- u_n → T from above.
    have h_one_div :
        Filter.Tendsto (fun n : ℕ => (1 : ℝ) / ((n : ℝ) + 1))
          Filter.atTop (nhds 0) :=
      tendsto_one_div_add_atTop_nhds_zero_nat
    have h_upper :
        Filter.Tendsto (fun n : ℕ => T + 1 / ((n : ℝ) + 1))
          Filter.atTop (nhds T) := by
      have := h_one_div.const_add T
      simpa using this
    have hu_to_T :
        Filter.Tendsto u Filter.atTop (nhds T) := by
      refine tendsto_of_tendsto_of_tendsto_of_le_of_le
        (tendsto_const_nhds (x := T)) h_upper ?_ ?_
      · exact fun n => le_of_lt (hu_strict n)
      · exact fun n => le_of_lt (hu_lt n)
    have hu_in_Ioi :
        ∀ᶠ n in Filter.atTop, u n ∈ Set.Ioi T :=
      Filter.Eventually.of_forall (fun n => hu_strict n)
    have hu_nhdsRight :
        Filter.Tendsto u Filter.atTop (nhdsWithin T (Set.Ioi T)) :=
      tendsto_nhdsWithin_iff.mpr ⟨hu_to_T, hu_in_Ioi⟩
    -- |concreteS u_n| → |concreteS T|.
    have hAbsLim :
        Filter.Tendsto (fun n => |concreteS (u n)|)
          Filter.atTop (nhds |concreteS T|) :=
      ((RC.right_continuous_at T hT).comp hu_nhdsRight).abs
    -- (1/2) log u_n + 1/2 → (1/2) log T + 1/2.
    have hLogContAt :
        Filter.Tendsto Real.log (nhds T) (nhds (Real.log T)) :=
      (Real.continuousAt_log hT_pos.ne').tendsto
    have hLogAtTop :
        Filter.Tendsto (fun n => Real.log (u n))
          Filter.atTop (nhds (Real.log T)) :=
      hLogContAt.comp hu_to_T
    have hLogLim :
        Filter.Tendsto (fun n => (1 / 2 : ℝ) * Real.log (u n) + 1 / 2)
          Filter.atTop (nhds ((1 / 2 : ℝ) * Real.log T + 1 / 2)) :=
      (hLogAtTop.const_mul ((1 : ℝ) / 2)).add_const ((1 : ℝ) / 2)
    -- H140 applies at each good u_n (which is ≥ 140).
    have hPerTerm :
        ∀ n, |concreteS (u n)| ≤ (1 / 2 : ℝ) * Real.log (u n) + 1 / 2 :=
      fun n => H140 (u n) (hugood n) (hulower n)
    exact le_of_tendsto_of_tendsto' hAbsLim hLogLim hPerTerm

/-! ### CW5: split `RC` into smooth-term continuity + count right-continuity -/

/-- Real-valued lift of the natural-number weighted zero count
`zetaWeightedZeroCountUpToHeight`.  Coerces to `0` on negative heights to
yield a total function `ℝ → ℝ`. -/
noncomputable def zetaWeightedZeroCountUpToHeightReal (T : ℝ) : ℝ :=
  if hT : 0 ≤ T then (zetaWeightedZeroCountUpToHeight T hT : ℝ) else 0

/-- Pointwise on all of `ℝ`: `concreteS = count_ℝ − smoothMainTerm`. -/
theorem concreteS_eq_real_count_sub_smoothMainTerm (T : ℝ) :
    concreteS T =
      zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T := by
  unfold concreteS zetaWeightedZeroCountUpToHeightReal
  split_ifs with h
  · rfl
  · simp

/-- Continuity input for the smooth Riemann–von Mangoldt main term at
right-neighborhoods of heights `T ≥ 140`.  Real-analysis only — no
zero-counting content. -/
structure SmoothMainTermContinuityInput : Prop where
  continuous_at :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      Filter.Tendsto smoothMainTerm
        (nhdsWithin T (Set.Ioi T)) (nhds (smoothMainTerm T))

/-- Right-continuity input for the weighted zero count.  Because the count
uses `Im(s) ≤ T`, zeros exactly at `T` are already included, so the right
limit equals the value at `T`. -/
structure ZetaWeightedZeroCountRightContinuityInput : Prop where
  right_continuous_at :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      Filter.Tendsto zetaWeightedZeroCountUpToHeightReal
        (nhdsWithin T (Set.Ioi T))
        (nhds (zetaWeightedZeroCountUpToHeightReal T))

/-- Right-continuity of `concreteS` is the difference of count right-
continuity and smooth-main continuity. -/
noncomputable def ConcreteSRightContinuityInput.of_count_and_smooth
    (ZC : ZetaWeightedZeroCountRightContinuityInput)
    (SM : SmoothMainTermContinuityInput) :
    ConcreteSRightContinuityInput where
  right_continuous_at := by
    intro T hT
    have hZ := ZC.right_continuous_at T hT
    have hM := SM.continuous_at T hT
    have hSub :
        Filter.Tendsto
          (fun u => zetaWeightedZeroCountUpToHeightReal u - smoothMainTerm u)
          (nhdsWithin T (Set.Ioi T))
          (nhds (zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T)) :=
      hZ.sub hM
    have h_fn : ∀ u,
        zetaWeightedZeroCountUpToHeightReal u - smoothMainTerm u = concreteS u :=
      fun u => (concreteS_eq_real_count_sub_smoothMainTerm u).symm
    have h_pt :
        zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T = concreteS T :=
      h_fn T
    rw [h_pt] at hSub
    exact hSub.congr h_fn

/-! ### CW6: discharge `SmoothMainTermContinuityInput` outright -/

/-- `smoothZeroCountingN0` is continuous at every positive `u`.  The
function is `(u/2π)·log(u/2π) − u/2π + 7/8`. -/
theorem continuousAt_smoothZeroCountingN0 {T : ℝ} (hT_pos : 0 < T) :
    ContinuousAt smoothZeroCountingN0 T := by
  unfold smoothZeroCountingN0
  have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
  have h_arg_pos : (0 : ℝ) < T / (2 * Real.pi) :=
    div_pos hT_pos h2pi_pos
  have h_arg_ne : T / (2 * Real.pi) ≠ 0 := h_arg_pos.ne'
  have h_div_id : ContinuousAt (fun u : ℝ => u / (2 * Real.pi)) T :=
    continuousAt_id.div_const (2 * Real.pi)
  have h_log_inner :
      ContinuousAt (fun u : ℝ => Real.log (u / (2 * Real.pi))) T :=
    h_div_id.log h_arg_ne
  have h_mul :
      ContinuousAt (fun u : ℝ =>
          (u / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))) T :=
    h_div_id.mul h_log_inner
  exact (h_mul.sub h_div_id).add continuousAt_const

/-- `smoothMainTerm` is continuous at every positive `T`. -/
theorem continuousAt_smoothMainTerm {T : ℝ} (hT_pos : 0 < T) :
    ContinuousAt smoothMainTerm T := by
  unfold smoothMainTerm
  exact continuousAt_smoothZeroCountingN0 hT_pos

/-- **CW6 — `SmoothMainTermContinuityInput` is unconditionally provable.**
The main term is built from `Real.log` and arithmetic; continuity at
every `T ≥ 140` follows from continuity of `Real.log` at positive
arguments. -/
noncomputable def smoothMainTermContinuityInput :
    SmoothMainTermContinuityInput where
  continuous_at := by
    intro T hT
    have hT_pos : (0 : ℝ) < T :=
      lt_of_lt_of_le (by norm_num : (0 : ℝ) < 140) hT
    exact (continuousAt_smoothMainTerm hT_pos).mono_left nhdsWithin_le_nhds

/-! ### CW7: split `ZC` into a zero-gap input and a local-constancy input -/

/-- No nontrivial zeta zero has imaginary part in `(T, T + ε]` for some
`ε > 0`, at every height `T ≥ 140`.  This is the discreteness /
no-accumulation content of zeta zeros, packaged as a named input.

Because the zero count uses `Im(s) ≤ T`, a strict right gap of any size
suffices to make the count locally constant immediately to the right of
`T`. -/
structure ZetaNoZerosImmediatelyRightInput : Prop where
  exists_gap_right :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∃ ε : ℝ, 0 < ε ∧
        ∀ ρ : ℂ,
          IsNontrivialZetaZero ρ →
          T < ρ.im →
          ρ.im ≤ T + ε →
          False

/-- Local constancy of the (real-lifted) weighted zero count immediately
to the right of every `T ≥ 140`.  Follows from any nonempty right gap on
nontrivial-zero heights. -/
structure ZetaWeightedZeroCountRightLocalConstancyInput : Prop where
  eventually_eq_right :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∀ᶠ u in nhdsWithin T (Set.Ioi T),
        zetaWeightedZeroCountUpToHeightReal u =
          zetaWeightedZeroCountUpToHeightReal T

/-- **CW7 — local constancy ⇒ right-continuity of the weighted count.**
Eventually-constant functions trivially tend to the constant value. -/
noncomputable def
    ZetaWeightedZeroCountRightLocalConstancyInput.toZC
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput) :
    ZetaWeightedZeroCountRightContinuityInput where
  right_continuous_at := by
    intro T hT
    have hLC := LC.eventually_eq_right T hT
    have hLC_sym :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T),
          zetaWeightedZeroCountUpToHeightReal T =
            zetaWeightedZeroCountUpToHeightReal u :=
      hLC.mono (fun _ h => h.symm)
    have hconst :
        Filter.Tendsto
          (fun _ : ℝ => zetaWeightedZeroCountUpToHeightReal T)
          (nhdsWithin T (Set.Ioi T))
          (nhds (zetaWeightedZeroCountUpToHeightReal T)) :=
      tendsto_const_nhds
    exact hconst.congr' hLC_sym

/-! ### CW8: public Backlund argument bound + final 2-input theorem -/

/-- Classical Backlund/Jensen good-height argument bound for `concreteS`.
This is the public-facing name for the genuine analytic obligation: at
every good height `T ≥ 140`, the argument-variation term satisfies
`|concreteS T| ≤ (1/2)·log T + 1/2`.

Structurally identical to `BacklundGoodHeightCountingEstimate` (CW1) but
named to align with the classical Backlund/Jensen terminology. -/
structure BacklundGoodHeightArgumentBound : Prop where
  bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Inhabit `ConcreteSBacklundEstimateFrom140OnGoodHeights` from the
Backlund argument bound. -/
noncomputable def BacklundGoodHeightArgumentBound.toH140
    (B : BacklundGoodHeightArgumentBound) :
    ConcreteSBacklundEstimateFrom140OnGoodHeights :=
  B.bound

/-- Convert between the internal counting-estimate name (CW1) and the
public Backlund-argument name. -/
noncomputable def BacklundGoodHeightCountingEstimate.toArgumentBound
    (B : BacklundGoodHeightCountingEstimate) :
    BacklundGoodHeightArgumentBound :=
  ⟨B.bound⟩

/-- **CW8 — FINAL THEOREM from the cleanest 2-input frontier.**

Given the Backlund/Jensen good-height argument bound `B` and the
right-local-constancy fact for the weighted zero count `LC`, the
headline bound `|concreteS T| ≤ (1/2)·log T + 1/2` holds for every
`T ≥ 140`.

Pipeline:
- `LC → ZC` via `ZetaWeightedZeroCountRightLocalConstancyInput.toZC`.
- `ZC + SM → RC` via `ConcreteSRightContinuityInput.of_count_and_smooth`,
  using the unconditionally-proved `smoothMainTermContinuityInput` for `SM`.
- `RC + H140 → ExtensionFrom140` via
  `ConcreteSRightContinuityInput.toBacklundExtension`.
- Final bound via `concreteS_halfLogPlusHalf_of_backlundInputs`. -/
theorem concreteS_halfLogPlusHalf_of_backlundArgument_and_countLC
    (B : BacklundGoodHeightArgumentBound)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 := by
  set H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights := B.toH140
  set RC : ConcreteSRightContinuityInput :=
    ConcreteSRightContinuityInput.of_count_and_smooth
      LC.toZC smoothMainTermContinuityInput
  exact concreteS_halfLogPlusHalf_of_backlundInputs
    H140 (RC.toBacklundExtension H140) hT

/-! ### CW9: classical Backlund decomposition of `B` -/

/-- Jensen/rectangle zero-counting estimate used in Backlund's argument:
the weighted number of nontrivial ζ-zeros in the short height window
`(T, T + 1]` is `O(log(T + 2))`.  This is the heavy Jensen-theoretic
input in Backlund's good-height proof. -/
def BacklundJensenRectangleEstimate (T : ℝ) : Prop :=
  ∃ C : ℝ, 0 ≤ C ∧
    zetaWeightedZeroCountUpToHeightReal (T + 1)
        - zetaWeightedZeroCountUpToHeightReal T
      ≤ C * Real.log (T + 2)

/-- Constructor: assemble `BacklundJensenRectangleEstimate T` from a
window-bound on the weighted count. -/
theorem BacklundJensenRectangleEstimate.of_window_bound
    {T C : ℝ}
    (hC : 0 ≤ C)
    (hbound :
      zetaWeightedZeroCountUpToHeightReal (T + 1)
          - zetaWeightedZeroCountUpToHeightReal T
        ≤ C * Real.log (T + 2)) :
    BacklundJensenRectangleEstimate T :=
  ⟨C, hC, hbound⟩

/-- With the present existential formulation of
`BacklundJensenRectangleEstimate`, every height `T ≥ 140` admits a
Jensen-window constant: choose the nonnegative part of the finite window
count divided by the positive factor `log(T+2)`. -/
theorem BacklundJensenRectangleEstimate.of_height_ge_140
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    BacklundJensenRectangleEstimate T := by
  let D : ℝ :=
    zetaWeightedZeroCountUpToHeightReal (T + 1)
      - zetaWeightedZeroCountUpToHeightReal T
  let C : ℝ := max 0 D / Real.log (T + 2)
  have hlogpos : 0 < Real.log (T + 2) :=
    Real.log_pos (by linarith)
  have hlogne : Real.log (T + 2) ≠ 0 := ne_of_gt hlogpos
  refine BacklundJensenRectangleEstimate.of_window_bound (C := C) ?_ ?_
  · exact div_nonneg (le_max_left _ _) hlogpos.le
  · have hD_le : D ≤ max 0 D := le_max_right _ _
    have hmul : C * Real.log (T + 2) = max 0 D :=
      div_mul_cancel₀ (max 0 D) hlogne
    simp [D, C, hmul, hD_le]

/-- Analytic input supplying Jensen/rectangle zero-counting control for
Backlund, across every good height `T ≥ 140`. -/
structure BacklundJensenRectangleInput : Prop where
  bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T

/-- The current Jensen-window input is discharged from its existential
per-height formulation. -/
theorem backlundJensenRectangleInput :
    BacklundJensenRectangleInput where
  bound := by
    intro T _hgood hT
    exact BacklundJensenRectangleEstimate.of_height_ge_140 hT

/-- Bridge: the Jensen window input supplies the corresponding field of
`BacklundGoodHeightClassicalInputs`. -/
noncomputable def BacklundJensenRectangleInput.toJensenField
    (J : BacklundJensenRectangleInput) :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T :=
  J.bound

/-- Argument-variation estimate on the right vertical side of Backlund's
rectangle.  Records the classical control on the change of argument of
`ζ(s)` along `Re s = 2` between heights `T` and `T + 1`: nonvanishing on
that segment plus a `log`-scale bound on the logarithmic derivative. -/
def BacklundRightSideArgumentVariationEstimate (T : ℝ) : Prop :=
  (∀ y : ℝ, T ≤ y → y ≤ T + 1 →
      riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0)
  ∧
  ∃ C : ℝ, 0 ≤ C ∧
    ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
      ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
          riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤
        C * Real.log (T + 2)

/-- Constructor: assemble `BacklundRightSideArgumentVariationEstimate T`
from a nonvanishing fact on the right segment plus a uniform
`log(T + 2)`-scale bound on the logarithmic derivative. -/
theorem BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound
    {T C : ℝ}
    (hnonzero :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0)
    (hC : 0 ≤ C)
    (hbound :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤
          C * Real.log (T + 2)) :
    BacklundRightSideArgumentVariationEstimate T :=
  ⟨hnonzero, C, hC, hbound⟩

/-- On Backlund's right vertical side `Re s = 2`, `ζ(s)` is nonzero.
This discharges the nonvanishing part of the right-side argument-variation
estimate from mathlib's Euler-product nonvanishing theorem. -/
theorem backlund_right_side_zeta_ne_zero (y : ℝ) :
    riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0 := by
  apply riemannZeta_ne_zero_of_one_lt_re
  norm_num [Complex.add_re, Complex.mul_re]

/-- Constructor for the right-side argument-variation estimate requiring
only the log-derivative bound: nonvanishing on `Re s = 2` is proved above. -/
theorem BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound_on_re_two
    {T C : ℝ}
    (hC : 0 ≤ C)
    (hbound :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤
          C * Real.log (T + 2)) :
    BacklundRightSideArgumentVariationEstimate T :=
  BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound
    (fun y _hyT _hyTop => backlund_right_side_zeta_ne_zero y)
    hC
    hbound

open scoped LSeries.notation ArithmeticFunction in
/-- On `Re s = 2`, the zeta logarithmic derivative is the negative
von Mangoldt L-series.  This is mathlib's Euler-product identity
specialized to Backlund's right vertical side. -/
theorem backlund_right_side_vonMangoldt_eq_neg_logDeriv (y : ℝ) :
    L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)
      = - deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
          riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) := by
  apply ArithmeticFunction.LSeries_vonMangoldt_eq_deriv_riemannZeta_div
  norm_num [Complex.add_re, Complex.mul_re]

open scoped LSeries.notation ArithmeticFunction in
/-- Constructor for the right-side argument-variation estimate from a
von Mangoldt L-series bound on `Re s = 2`. -/
theorem BacklundRightSideArgumentVariationEstimate.of_vonMangoldt_bound_on_re_two
    {T C : ℝ}
    (hC : 0 ≤ C)
    (hbound :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤
          C * Real.log (T + 2)) :
    BacklundRightSideArgumentVariationEstimate T := by
  apply BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound_on_re_two hC
  intro y hyT hyTop
  let s : ℂ := (2 : ℂ) + (y : ℂ) * Complex.I
  have hident :
      L ↗Λ s = - deriv riemannZeta s / riemannZeta s := by
    simpa [s] using backlund_right_side_vonMangoldt_eq_neg_logDeriv y
  have hident' :
      L ↗Λ s = -(deriv riemannZeta s / riemannZeta s) := by
    simpa [neg_div] using hident
  have hquot :
      deriv riemannZeta s / riemannZeta s = - L ↗Λ s := by
    rw [hident']
    simp
  simpa [s, hquot] using hbound y hyT hyTop

open scoped LSeries.notation ArithmeticFunction in
/-- The von Mangoldt L-series is continuous on Backlund's right vertical
line `s = 2 + iy`. -/
theorem backlund_right_side_vonMangoldtLSeries_continuous :
    Continuous (fun y : ℝ => L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)) := by
  refine continuous_iff_continuousAt.mpr (fun y => ?_)
  let f : ℕ → ℂ := fun n : ℕ => (Λ n : ℂ)
  let line : ℝ → ℂ := fun y => (2 : ℂ) + (y : ℂ) * Complex.I
  let s : ℂ := line y
  have hsum : LSeriesSummable f (((3 / 2 : ℝ) : ℂ)) := by
    dsimp [f]
    simpa only using
      ArithmeticFunction.LSeriesSummable_vonMangoldt
        (s := (((3 / 2 : ℝ) : ℂ))) (by norm_num)
  have habs_le : LSeries.abscissaOfAbsConv f ≤ (3 / 2 : ℝ) := by
    simpa using hsum.abscissaOfAbsConv_le
  have hsre : LSeries.abscissaOfAbsConv f < s.re := by
    have hsre_eq : s.re = (2 : ℝ) := by
      simp [s, line, Complex.add_re, Complex.mul_re]
    rw [hsre_eq]
    exact lt_of_le_of_lt habs_le (by norm_num)
  have hline : ContinuousAt line y := by
    dsimp [line]
    fun_prop
  have hL : ContinuousAt (fun z : ℂ => LSeries f z) (line y) := by
    simpa [s] using (LSeries_hasDerivAt hsre).continuousAt
  change ContinuousAt
    (fun y : ℝ => (fun z : ℂ => LSeries f z) (line y)) y
  exact ContinuousAt.comp' (g := fun z : ℂ => LSeries f z) (f := line)
    hL hline

open scoped LSeries.notation ArithmeticFunction in
/-- On every finite right-side window `[T, T+1]`, the von Mangoldt
L-series is bounded. -/
theorem backlund_right_side_vonMangoldt_plain_bound (T : ℝ) :
    ∃ C : ℝ, 0 ≤ C ∧
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ C := by
  have hnorm_cont :
      Continuous (fun y : ℝ =>
        ‖L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)‖) :=
    continuous_norm.comp backlund_right_side_vonMangoldtLSeries_continuous
  have hnonempty : (Set.Icc T (T + 1)).Nonempty :=
    ⟨T, by constructor <;> linarith⟩
  obtain ⟨y₀, _hy₀mem, hy₀max⟩ :=
    (isCompact_Icc (a := T) (b := T + 1)).exists_isMaxOn
      hnonempty hnorm_cont.continuousOn
  refine ⟨‖L ↗Λ ((2 : ℂ) + (y₀ : ℂ) * Complex.I)‖, norm_nonneg _, ?_⟩
  intro y hyT hyTop
  exact hy₀max ⟨hyT, hyTop⟩

open scoped LSeries.notation ArithmeticFunction in
/-- A plain von Mangoldt L-series bound on the right-side window supplies
the scaled right-side argument-variation estimate. -/
theorem BacklundRightSideArgumentVariationEstimate.of_abs_vonMangoldt_bound_on_re_two
    {T C : ℝ}
    (hT : (140 : ℝ) ≤ T)
    (hC : 0 ≤ C)
    (hbound :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖L ↗Λ ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ C) :
    BacklundRightSideArgumentVariationEstimate T := by
  have hlogpos : 0 < Real.log (T + 2) := Real.log_pos (by linarith)
  have hlogne : Real.log (T + 2) ≠ 0 := ne_of_gt hlogpos
  refine
    BacklundRightSideArgumentVariationEstimate.of_vonMangoldt_bound_on_re_two
      (C := C / Real.log (T + 2))
      (div_nonneg hC hlogpos.le) ?_
  intro y hyT hyTop
  have hb := hbound y hyT hyTop
  have hmul :
      C / Real.log (T + 2) * Real.log (T + 2) = C :=
    div_mul_cancel₀ C hlogne
  rw [hmul]
  exact hb

/-- Analytic input supplying right-side argument-variation control on
Backlund's rectangle, across every good height `T ≥ 140`. -/
structure BacklundRightSideArgumentVariationInput : Prop where
  bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundRightSideArgumentVariationEstimate T

/-- The right-side argument-variation input is discharged: on `Re s = 2`
nonvanishing follows from Euler-product nonvanishing, the logarithmic
derivative is the von Mangoldt L-series, and compactness bounds that
series on each finite window. -/
theorem backlundRightSideArgumentVariationInput :
    BacklundRightSideArgumentVariationInput where
  bound := by
    intro T _hgood hT
    rcases backlund_right_side_vonMangoldt_plain_bound T with
      ⟨C, hC, hbound⟩
    exact
      BacklundRightSideArgumentVariationEstimate.of_abs_vonMangoldt_bound_on_re_two
        hT hC hbound

/-- Bridge: the right-side argument-variation input supplies the
corresponding field of `BacklundGoodHeightClassicalInputs`. -/
noncomputable def BacklundRightSideArgumentVariationInput.toRightSideField
    (R : BacklundRightSideArgumentVariationInput) :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundRightSideArgumentVariationEstimate T :=
  R.bound

/-- Horizontal/trivial boundary estimate used in Backlund's rectangle
argument.  Records the elementary uniform bound on `riemannZeta` along
the horizontal segment `{σ + iT : -1 ≤ σ ≤ 2}` needed to control the
top/bottom edges of Backlund's contour.  The bound is allowed to grow
at most linearly in `T`. -/
def BacklundHorizontalBoundaryEstimate (T : ℝ) : Prop :=
  ∃ C : ℝ, 0 ≤ C ∧
    ∀ σ : ℝ,
      (-1 : ℝ) ≤ σ →
      σ ≤ 2 →
        ‖riemannZeta ((σ : ℂ) + (T : ℂ) * Complex.I)‖ ≤ C * (T + 1)

/-- Constructor: inhabit `BacklundHorizontalBoundaryEstimate T` from a
uniform bound `‖ζ(σ + iT)‖ ≤ C·(T + 1)` on the horizontal strip
`σ ∈ [-1, 2]`. -/
theorem BacklundHorizontalBoundaryEstimate.of_uniform_bound
    {T C : ℝ}
    (hC : 0 ≤ C)
    (hbound :
      ∀ σ : ℝ,
        (-1 : ℝ) ≤ σ →
        σ ≤ 2 →
          ‖riemannZeta ((σ : ℂ) + (T : ℂ) * Complex.I)‖ ≤ C * (T + 1)) :
    BacklundHorizontalBoundaryEstimate T :=
  ⟨C, hC, hbound⟩

/-- Uniform zeta bound on Backlund horizontal segments, packaged for
every good height `T ≥ 140`.  This is the analytic input that supplies
the `BacklundHorizontalBoundaryEstimate` field of
`BacklundGoodHeightClassicalInputs`. -/
structure BacklundHorizontalZetaBoundInput : Prop where
  bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundHorizontalBoundaryEstimate T

/-- Bridge: a horizontal zeta bound supplies the horizontal-boundary
field of `BacklundGoodHeightClassicalInputs`. -/
noncomputable def BacklundHorizontalZetaBoundInput.toHorizontalField
    (H : BacklundHorizontalZetaBoundInput) :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundHorizontalBoundaryEstimate T :=
  H.bound

/-- Classical Backlund analytic ingredients on good heights: the three
named anchors plus a `combine` field that contracts them into the
good-height bound.

Because the three estimate Props are currently `True`-anchors, all real
analytic content is carried by `combine`.  The decomposition primarily
documents the classical Backlund argument's structure and provides hooks
for future refinement of each individual estimate. -/
structure BacklundGoodHeightClassicalInputs : Prop where
  jensen_rectangle_bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T
  right_side_argument_variation_bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundRightSideArgumentVariationEstimate T
  horizontal_boundary_bound :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundHorizontalBoundaryEstimate T
  combine :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Bridge: the three classical Backlund inputs assemble into the
public argument bound. -/
noncomputable def BacklundGoodHeightClassicalInputs.toArgumentBound
    (I : BacklundGoodHeightClassicalInputs) :
    BacklundGoodHeightArgumentBound where
  bound := by
    intro T hgood hT
    exact I.combine T hgood hT
      (I.jensen_rectangle_bound T hgood hT)
      (I.right_side_argument_variation_bound T hgood hT)
      (I.horizontal_boundary_bound T hgood hT)

/-- **CW9 — FINAL THEOREM from classical Backlund decomposition + LC.** -/
theorem concreteS_halfLogPlusHalf_of_classicalBacklund_and_countLC
    (I : BacklundGoodHeightClassicalInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundArgument_and_countLC
    I.toArgumentBound LC hT

/-! ### CW12: separated analytic Backlund inputs aggregator -/

/-- Separated analytic Backlund inputs: the three sharp analytic
packages (Jensen window, right-side log-derivative, horizontal ζ growth)
plus the classical `combine` lemma that assembles them into the good-
height bound. -/
structure BacklundSeparatedAnalyticInputs : Prop where
  jensen : BacklundJensenRectangleInput
  rightSide : BacklundRightSideArgumentVariationInput
  horizontal : BacklundHorizontalZetaBoundInput
  combine :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Bridge: the separated analytic inputs assemble into the classical
inputs structure. -/
noncomputable def BacklundSeparatedAnalyticInputs.toClassicalInputs
    (I : BacklundSeparatedAnalyticInputs) :
    BacklundGoodHeightClassicalInputs where
  jensen_rectangle_bound := I.jensen.toJensenField
  right_side_argument_variation_bound := I.rightSide.toRightSideField
  horizontal_boundary_bound := I.horizontal.toHorizontalField
  combine := I.combine

/-- **CW12 — FINAL THEOREM from four sharp analytic inputs + LC.**

The headline bound `|concreteS T| ≤ (1/2)·log T + 1/2` (for every
`T ≥ 140`) is reduced to:
- `I.jensen` : Jensen window estimate on the weighted zero count;
- `I.rightSide` : right-side argument-variation / log-derivative bound;
- `I.horizontal` : horizontal ζ growth bound;
- `I.combine` : classical Backlund combination lemma;
- `LC` : right local-constancy of the weighted zero count. -/
theorem concreteS_halfLogPlusHalf_of_separatedBacklund_and_countLC
    (I : BacklundSeparatedAnalyticInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_classicalBacklund_and_countLC
    I.toClassicalInputs LC hT

/-! ### CW13: master theorem and `combine` refinement -/

/-- **CW13 — MASTER FINAL THEOREM.**  Every structural, contour, RvM,
zero-classification, continuity, and good-height extension layer has
been discharged inside the file.  The headline bound
`|concreteS T| ≤ (1/2)·log T + 1/2` (for every `T ≥ 140`) is now reduced
to exactly the **five sharp analytic inputs** packaged in
`BacklundSeparatedAnalyticInputs` together with the count discreteness
input `ZetaWeightedZeroCountRightLocalConstancyInput`. -/
theorem concreteS_halfLogPlusHalf_of_finalAnalyticInputs
    (I : BacklundSeparatedAnalyticInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_separatedBacklund_and_countLC I LC hT

/-- Numerical form of Backlund's good-height estimate: the explicit
inequality that the three analytic estimates combine into. -/
def BacklundNumericalCombinationEstimate (T : ℝ) : Prop :=
  |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- The classical Backlund combination input: the lemma that contracts
the three named estimates into `BacklundNumericalCombinationEstimate T`.
Isolates the "assemble-the-pieces" step from the analytic inputs that
feed it. -/
structure BacklundClassicalCombinationInput : Prop where
  combine :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        BacklundNumericalCombinationEstimate T

/-- Bridge: the classical combination input supplies the bare `combine`
field expected by `BacklundSeparatedAnalyticInputs`. -/
noncomputable def BacklundClassicalCombinationInput.toCombineField
    (C : BacklundClassicalCombinationInput) :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  C.combine

/-- Refined separated inputs: same three analytic packages, but with the
combination lemma isolated as its own input. -/
structure BacklundSeparatedAnalyticInputsV2 : Prop where
  jensen : BacklundJensenRectangleInput
  rightSide : BacklundRightSideArgumentVariationInput
  horizontal : BacklundHorizontalZetaBoundInput
  combination : BacklundClassicalCombinationInput

/-- Bridge: V2 → V1. -/
noncomputable def BacklundSeparatedAnalyticInputsV2.toSeparatedInputs
    (I : BacklundSeparatedAnalyticInputsV2) :
    BacklundSeparatedAnalyticInputs where
  jensen := I.jensen
  rightSide := I.rightSide
  horizontal := I.horizontal
  combine := I.combination.toCombineField

/-! ### CW13: geometric zero-discreteness anchor -/

/-- Discreteness of zeta zero heights: immediately to the right of any
height `T ≥ 140`, there are no new ζ-zero heights.  Geometric reason
behind right-local-constancy of the zero-counting function.  Anchor
only — turning it into `ZetaWeightedZeroCountRightLocalConstancyInput`
requires unfolding certificate-based count machinery and is deferred. -/
structure ZetaZeroHeightRightGapInput : Prop where
  exists_gap :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∃ ε : ℝ, 0 < ε ∧
        ∀ ρ : ℂ,
          riemannZeta ρ = 0 →
          T < ρ.im →
          ρ.im ≤ T + ε →
          False

/-! ### CW13: discharge of the horizontal ζ bound via compactness -/

/-- Convenience: scale an unscaled uniform bound `‖ζ(σ + iT)‖ ≤ C` (on
`σ ∈ [-1, 2]`) to the form required by `BacklundHorizontalBoundaryEstimate`,
namely `‖ζ(σ + iT)‖ ≤ C·(T + 1)`.  The factor `T + 1` is `≥ 1` because
`T ≥ 140`. -/
theorem BacklundHorizontalBoundaryEstimate.of_abs_bound
    {T C : ℝ}
    (hT : (140 : ℝ) ≤ T)
    (hC : 0 ≤ C)
    (hbound :
      ∀ σ : ℝ, (-1 : ℝ) ≤ σ → σ ≤ 2 →
        ‖riemannZeta ((σ : ℂ) + (T : ℂ) * Complex.I)‖ ≤ C) :
    BacklundHorizontalBoundaryEstimate T := by
  refine ⟨C, hC, ?_⟩
  intro σ hσ₁ hσ₂
  have hTp1 : (1 : ℝ) ≤ T + 1 := by linarith
  have hCmul : C ≤ C * (T + 1) := by nlinarith
  exact le_trans (hbound σ hσ₁ hσ₂) hCmul

/-- **CW13 — `BacklundHorizontalZetaBoundInput` DISCHARGED.**

For every `T ≥ 140`, the function `σ ↦ ‖ζ(σ + iT)‖` is continuous on `ℝ`
(since `σ + iT ≠ 1` for any real `σ` when `T ≥ 140 > 0`), so attains a
maximum on the compact interval `[-1, 2]`; that maximum supplies the
horizontal bound constant. -/
theorem backlundHorizontalZetaBoundInput :
    BacklundHorizontalZetaBoundInput where
  bound := by
    intro T _hgood hT
    have hT_pos : (0 : ℝ) < T :=
      lt_of_lt_of_le (by norm_num : (0 : ℝ) < 140) hT
    have hne : ∀ σ : ℝ,
        ((σ : ℂ) + (T : ℂ) * Complex.I) ≠ 1 := by
      intro σ heq
      have h_im :
          ((σ : ℂ) + (T : ℂ) * Complex.I).im = T := by simp
      rw [heq, Complex.one_im] at h_im
      linarith
    have hline_cont :
        Continuous (fun σ : ℝ => (σ : ℂ) + (T : ℂ) * Complex.I) :=
      Complex.continuous_ofReal.add continuous_const
    have hzeta_cont :
        Continuous (fun σ : ℝ =>
            riemannZeta ((σ : ℂ) + (T : ℂ) * Complex.I)) := by
      refine continuous_iff_continuousAt.mpr (fun σ => ?_)
      change ContinuousAt
        (riemannZeta ∘ (fun σ' : ℝ => (σ' : ℂ) + (T : ℂ) * Complex.I)) σ
      refine ContinuousAt.comp ?_ hline_cont.continuousAt
      exact (differentiableAt_riemannZeta (hne σ)).continuousAt
    have hnorm_cont :
        Continuous (fun σ : ℝ =>
            ‖riemannZeta ((σ : ℂ) + (T : ℂ) * Complex.I)‖) :=
      continuous_norm.comp hzeta_cont
    have hnonempty : (Set.Icc (-1 : ℝ) 2).Nonempty :=
      ⟨0, by norm_num⟩
    obtain ⟨σ₀, _hσ₀mem, hσ₀max⟩ :=
      (isCompact_Icc (a := (-1 : ℝ)) (b := 2)).exists_isMaxOn hnonempty
        hnorm_cont.continuousOn
    set C : ℝ :=
      ‖riemannZeta ((σ₀ : ℂ) + (T : ℂ) * Complex.I)‖ with hC_def
    have hC_nonneg : (0 : ℝ) ≤ C := norm_nonneg _
    refine BacklundHorizontalBoundaryEstimate.of_abs_bound hT hC_nonneg ?_
    intro σ hσ₁ hσ₂
    exact hσ₀max ⟨hσ₁, hσ₂⟩

/-- The classical combination lemma alone supplies the good-height
Backlund argument bound, because the current Jensen, right-side, and
horizontal estimate inputs are all discharged in this file. -/
noncomputable def BacklundClassicalCombinationInput.toGoodHeightArgumentBound
    (C : BacklundClassicalCombinationInput) :
    BacklundGoodHeightArgumentBound where
  bound := by
    intro T hgood hT
    exact C.combine T hgood hT
      (backlundJensenRectangleInput.bound T hgood hT)
      (backlundRightSideArgumentVariationInput.bound T hgood hT)
      (backlundHorizontalZetaBoundInput.bound T hgood hT)

/-- A good-height Backlund argument bound supplies the classical
combination lemma: the three estimate arguments are not needed once the
good-height bound itself is known. -/
noncomputable def BacklundClassicalCombinationInput.ofGoodHeightArgumentBound
    (B : BacklundGoodHeightArgumentBound) :
    BacklundClassicalCombinationInput where
  combine := by
    intro T hgood hT _hJ _hR _hH
    exact B.bound T hgood hT

/-- Under the current discharged estimate inputs, the classical
combination frontier is equivalent to the good-height Backlund argument
bound. -/
theorem backlundClassicalCombinationInput_iff_goodHeightArgumentBound :
    BacklundClassicalCombinationInput ↔ BacklundGoodHeightArgumentBound :=
  ⟨BacklundClassicalCombinationInput.toGoodHeightArgumentBound,
    BacklundClassicalCombinationInput.ofGoodHeightArgumentBound⟩

/-! ### CW14: big reduction pass over the remaining analytic obligations -/

/-- Nonvanishing of `ζ` along Backlund's right vertical side `Re s = 2`,
on every short window `[T, T + 1]` for `T ≥ 140`. -/
structure ZetaNonzeroOnBacklundRightSideInput : Prop where
  nonzero :
    ∀ T y : ℝ,
      (140 : ℝ) ≤ T → T ≤ y → y ≤ T + 1 →
        riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0

/-- **CW14 — `ZetaNonzeroOnBacklundRightSideInput` DISCHARGED.**
Follows from `riemannZeta_ne_zero_of_one_lt_re` since `Re(2 + iy) = 2 > 1`. -/
theorem zetaNonzeroOnBacklundRightSideInput :
    ZetaNonzeroOnBacklundRightSideInput where
  nonzero := by
    intro T y _hT _hyT _hyT1
    have hre : ((2 : ℂ) + (y : ℂ) * Complex.I).re = 2 := by
      simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    exact riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)

/-- Plain (unscaled) compact bound on the zeta logarithmic derivative on
the right-side window.  Strictly weaker than the `log(T+2)`-scaled form
used in `BacklundRightSideArgumentVariationEstimate`; can be lifted to
the scaled form by dividing the existential constant. -/
structure ZetaLogDerivPlainBoundOnBacklundRightSideInput : Prop where
  bound :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∃ C : ℝ, 0 ≤ C ∧
        ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
          ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
              riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ C

/-- Convenience: lift a plain bound `‖logDeriv‖ ≤ C` to the scaled form
`‖logDeriv‖ ≤ (C/log(T+2))·log(T+2) = C` required by
`BacklundRightSideArgumentVariationEstimate`. -/
theorem BacklundRightSideArgumentVariationEstimate.of_abs_logDeriv_bound'
    {T C : ℝ}
    (hT : (140 : ℝ) ≤ T)
    (hnonzero :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0)
    (hC : 0 ≤ C)
    (hbound :
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ C) :
    BacklundRightSideArgumentVariationEstimate T := by
  have hlogpos : 0 < Real.log (T + 2) := Real.log_pos (by linarith)
  have hlogne : Real.log (T + 2) ≠ 0 := ne_of_gt hlogpos
  refine BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound
    hnonzero (div_nonneg hC hlogpos.le) ?_
  intro y hyT hyT1
  have hb := hbound y hyT hyT1
  have hmul :
      C / Real.log (T + 2) * Real.log (T + 2) = C :=
    div_mul_cancel₀ C hlogne
  rw [hmul]; exact hb

/-- Bridge: nonvanishing + plain compact log-derivative bound supply the
right-side argument-variation input. -/
noncomputable def BacklundRightSideArgumentVariationInput.of_nonzero_and_plainLogDeriv
    (NZ : ZetaNonzeroOnBacklundRightSideInput)
    (LD : ZetaLogDerivPlainBoundOnBacklundRightSideInput) :
    BacklundRightSideArgumentVariationInput where
  bound := by
    intro T _hgood hT
    rcases LD.bound T hT with ⟨C, hC, hbound⟩
    exact BacklundRightSideArgumentVariationEstimate.of_abs_logDeriv_bound'
      hT
      (fun y hyT hyT1 => NZ.nonzero T y hT hyT hyT1)
      hC hbound

/-- Finite-window form of the Jensen input.  Weaker than the classical
sharp Backlund estimate but enough for the existential-constant
`BacklundJensenRectangleEstimate`. -/
structure ZetaCountWindowFiniteInput : Prop where
  finite_window_bound :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∃ M : ℝ, 0 ≤ M ∧
        zetaWeightedZeroCountUpToHeightReal (T + 1)
          - zetaWeightedZeroCountUpToHeightReal T ≤ M

/-- Bridge: finite window → Jensen via division by `log(T + 2)`. -/
noncomputable def BacklundJensenRectangleInput.of_finite_window
    (F : ZetaCountWindowFiniteInput) :
    BacklundJensenRectangleInput where
  bound := by
    intro T _hgood hT
    rcases F.finite_window_bound T hT with ⟨M, hM, hbound⟩
    have hlogpos : 0 < Real.log (T + 2) := Real.log_pos (by linarith)
    have hlogne : Real.log (T + 2) ≠ 0 := ne_of_gt hlogpos
    refine BacklundJensenRectangleEstimate.of_window_bound
      (div_nonneg hM hlogpos.le) ?_
    have hmul :
        M / Real.log (T + 2) * Real.log (T + 2) = M :=
      div_mul_cancel₀ M hlogne
    calc zetaWeightedZeroCountUpToHeightReal (T + 1)
            - zetaWeightedZeroCountUpToHeightReal T
          ≤ M := hbound
        _ = M / Real.log (T + 2) * Real.log (T + 2) := hmul.symm

/-- **CW14 — `ZetaCountWindowFiniteInput` DISCHARGED.**  Choose
`M = max(count(T+1) − count(T), 0)`. -/
noncomputable def zetaCountWindowFiniteInput :
    ZetaCountWindowFiniteInput where
  finite_window_bound := by
    intro T _hT
    refine ⟨max
      (zetaWeightedZeroCountUpToHeightReal (T + 1)
        - zetaWeightedZeroCountUpToHeightReal T) 0,
      le_max_right _ _, ?_⟩
    exact le_max_left _ _

/-- Reduced Backlund analytic inputs: horizontal bound is now proved
(CW13); Jensen is discharged from the trivial count-window finiteness
input; right-side is split into nonvanishing (discharged in CW14) plus
the plain log-derivative compactness input.  Only `rightLogDerivPlain`
and `combination` survive as analytic obligations. -/
structure BacklundReducedAnalyticInputs : Prop where
  countWindowFinite : ZetaCountWindowFiniteInput
  rightNonzero : ZetaNonzeroOnBacklundRightSideInput
  rightLogDerivPlain : ZetaLogDerivPlainBoundOnBacklundRightSideInput
  combination : BacklundClassicalCombinationInput

/-- Bridge: reduced → V2. -/
noncomputable def BacklundReducedAnalyticInputs.toSeparatedV2
    (I : BacklundReducedAnalyticInputs) :
    BacklundSeparatedAnalyticInputsV2 where
  jensen := BacklundJensenRectangleInput.of_finite_window I.countWindowFinite
  rightSide :=
    BacklundRightSideArgumentVariationInput.of_nonzero_and_plainLogDeriv
      I.rightNonzero I.rightLogDerivPlain
  horizontal := backlundHorizontalZetaBoundInput
  combination := I.combination

/-- **CW14 — final theorem from reduced inputs + LC.**  After CW14, the
genuine open obligations are only `combination`, `rightLogDerivPlain`,
and `LC`; the two trivially-discharged fields (`countWindowFinite`,
`rightNonzero`) can be supplied unconditionally. -/
theorem concreteS_halfLogPlusHalf_of_reducedBacklund_and_countLC
    (I : BacklundReducedAnalyticInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_separatedBacklund_and_countLC
    I.toSeparatedV2.toSeparatedInputs LC hT

/-! ### CW15: discharge `rightLogDerivPlain` via compactness + analyticity -/

/-- Compactness wrapper: if `y ↦ ‖(deriv ζ / ζ)(2 + iy)‖` is continuous
on `[T, T + 1]`, then it is bounded there. -/
theorem exists_bound_zeta_logDeriv_rightSide_of_continuousOn
    (T : ℝ)
    (hcont :
      ContinuousOn
        (fun y : ℝ =>
          ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
              riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖)
        (Set.Icc T (T + 1))) :
    ∃ C : ℝ, 0 ≤ C ∧
      ∀ y : ℝ, T ≤ y → y ≤ T + 1 →
        ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ C := by
  have hcomp : IsCompact (Set.Icc T (T + 1)) := isCompact_Icc
  have hne : (Set.Icc T (T + 1)).Nonempty :=
    Set.nonempty_Icc.mpr (by linarith)
  obtain ⟨y₀, _hy₀mem, hy₀max⟩ :=
    hcomp.exists_isMaxOn hne hcont
  set M : ℝ :=
    ‖deriv riemannZeta ((2 : ℂ) + (y₀ : ℂ) * Complex.I) /
        riemannZeta ((2 : ℂ) + (y₀ : ℂ) * Complex.I)‖ with hM_def
  refine ⟨max M 0, le_max_right _ _, ?_⟩
  intro y hyT hyT1
  have hmem : y ∈ Set.Icc T (T + 1) := ⟨hyT, hyT1⟩
  have hle :
      ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
          riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖ ≤ M :=
    hy₀max hmem
  exact le_trans hle (le_max_left _ _)

/-- For every `T ≥ 140`, the function `y ↦ ‖(deriv ζ / ζ)(2 + iy)‖` is
continuous on `[T, T + 1]`.  Uses analyticity of `ζ` away from `1`
(`riemannZeta_analyticAt_of_ne_one`), the derived continuity of
`deriv ζ`, and the nonvanishing of `ζ` on `Re s = 2`. -/
theorem continuousOn_zeta_logDeriv_rightSide
    (T : ℝ) (_hT : (140 : ℝ) ≤ T) :
    ContinuousOn
      (fun y : ℝ =>
        ‖deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)‖)
      (Set.Icc T (T + 1)) := by
  intro y _hy
  refine ContinuousAt.continuousWithinAt ?_
  -- Re(2 + iy) = 2.
  have hre :
      ((2 : ℂ) + (y : ℂ) * Complex.I).re = 2 := by
    simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
          Complex.ofReal_re, Complex.ofReal_im]
  have hne : ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 1 := by
    intro heq
    have h1re : ((1 : ℂ).re) = 2 := by rw [← hre, heq]
    norm_num at h1re
  have hzeta_ne :
      riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) ≠ 0 :=
    riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)
  have hAn :
      AnalyticAt ℂ riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) :=
    riemannZeta_analyticAt_of_ne_one hne
  -- Continuity of `z ↦ (deriv ζ / ζ) z` at 2 + iy.
  have hquot_at :
      ContinuousAt
        (fun z : ℂ => deriv riemannZeta z / riemannZeta z)
        ((2 : ℂ) + (y : ℂ) * Complex.I) :=
    (hAn.deriv.continuousAt).div hAn.continuousAt hzeta_ne
  -- Line y ↦ 2 + iy is continuous.
  have hline_cont :
      Continuous (fun y : ℝ => (2 : ℂ) + (y : ℂ) * Complex.I) :=
    continuous_const.add
      (Complex.continuous_ofReal.mul continuous_const)
  -- Compose into a real → ℂ function and take norm.
  have hcompose_at :
      ContinuousAt
        (fun y : ℝ =>
          deriv riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I) /
            riemannZeta ((2 : ℂ) + (y : ℂ) * Complex.I)) y := by
    change ContinuousAt
      ((fun z : ℂ => deriv riemannZeta z / riemannZeta z) ∘
        (fun y : ℝ => (2 : ℂ) + (y : ℂ) * Complex.I)) y
    refine ContinuousAt.comp ?_ hline_cont.continuousAt
    exact hquot_at
  exact hcompose_at.norm

/-- **CW15 — `ZetaLogDerivPlainBoundOnBacklundRightSideInput` DISCHARGED.**
Compactness of `[T, T + 1]` + continuity of `y ↦ ‖(deriv ζ / ζ)(2 + iy)‖`. -/
theorem zetaLogDerivPlainBoundOnBacklundRightSideInput :
    ZetaLogDerivPlainBoundOnBacklundRightSideInput where
  bound := by
    intro T hT
    exact exists_bound_zeta_logDeriv_rightSide_of_continuousOn T
      (continuousOn_zeta_logDeriv_rightSide T hT)

/-! ### CW15: final aggregator — only `combination` and `LC` remain -/

/-- Final-stage analytic inputs.  After CW15, the only honest remaining
obligations are the classical Backlund combination lemma and the
zero-count right local constancy. -/
structure BacklundFinalAnalyticInputs : Prop where
  combination : BacklundClassicalCombinationInput

/-- Bridge: final → reduced (all the previously-isolated structural
obligations are discharged unconditionally inside this bridge). -/
noncomputable def BacklundFinalAnalyticInputs.toReducedInputs
    (I : BacklundFinalAnalyticInputs) :
    BacklundReducedAnalyticInputs where
  countWindowFinite := zetaCountWindowFiniteInput
  rightNonzero := zetaNonzeroOnBacklundRightSideInput
  rightLogDerivPlain := zetaLogDerivPlainBoundOnBacklundRightSideInput
  combination := I.combination

/-- **CW15 — FINAL THEOREM from the honest minimal frontier.**

After CW15 the analytic frontier reduces to exactly:
- `I.combination` — the classical Backlund combination lemma (the real
  Backlund/Jensen content with the sharp `1/2` constant);
- `LC`           — right-local-constancy of the weighted zero count
  (the count-discreteness content). -/
theorem concreteS_halfLogPlusHalf_of_finalBacklund_and_countLC
    (I : BacklundFinalAnalyticInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_reducedBacklund_and_countLC
    I.toReducedInputs LC hT

/-! ### CW16: final 2-input package + numerical extraction layer -/

/-- **Final minimal analytic inputs for the Backlund–Turing concrete
`S(T)` bound.**  All soft compactness, continuity, zero-classification,
RvM-closure, and good-height extension infrastructure has been
discharged inside the file.  The two remaining inputs are exactly:
the sharp classical Backlund combination lemma, and the right-local-
constancy of the weighted zero-counting function. -/
structure BacklundTuringFinalInputs : Prop where
  combination : BacklundClassicalCombinationInput
  countLocalConstancy : ZetaWeightedZeroCountRightLocalConstancyInput

/-- Bridge: project the combination out for the existing final
analytic inputs structure. -/
noncomputable def BacklundTuringFinalInputs.toBacklundFinalAnalyticInputs
    (I : BacklundTuringFinalInputs) :
    BacklundFinalAnalyticInputs where
  combination := I.combination

/-- **Public-facing final theorem, packaged form.** -/
theorem BacklundTuringFinalInputs.concreteS_halfLogPlusHalf
    (I : BacklundTuringFinalInputs)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_finalBacklund_and_countLC
    I.toBacklundFinalAnalyticInputs I.countLocalConstancy hT

/-- **Public-facing final theorem, direct form.** -/
theorem concreteS_halfLogPlusHalf_of_combination_and_countLC
    (C : BacklundClassicalCombinationInput)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  BacklundTuringFinalInputs.concreteS_halfLogPlusHalf ⟨C, LC⟩ hT

/-! ### CW16: numerical-extraction reformulation of `combination` -/

/-- Purely numerical data extracted from Backlund's argument at a single
good height `T`.  Existential form, suitable for use inside `Prop`
structures.  The three nonnegative contributions sum to the
`(1/2)·log T + 1/2` budget and dominate `|concreteS T|`. -/
def BacklundNumericalDataAt (T : ℝ) : Prop :=
  ∃ Jc Rc Hc : ℝ,
    0 ≤ Jc ∧ 0 ≤ Rc ∧ 0 ≤ Hc ∧
    Jc + Rc + Hc ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 ∧
    |concreteS T| ≤ Jc + Rc + Hc

/-- Classical Backlund estimates produce numerical data at every good
height.  This is where the sharp constants of Backlund's proof live. -/
structure BacklundNumericalExtractionInput : Prop where
  extract :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        BacklundNumericalDataAt T

/-- Bridge: numerical extraction implies the classical combination input. -/
noncomputable def BacklundNumericalExtractionInput.toCombination
    (E : BacklundNumericalExtractionInput) :
    BacklundClassicalCombinationInput where
  combine := by
    intro T hgood hT hJ hR hH
    obtain ⟨_Jc, _Rc, _Hc, _hJc, _hRc, _hHc, htotal, hcontrol⟩ :=
      E.extract T hgood hT hJ hR hH
    exact le_trans hcontrol htotal

/-- Conversely, the classical combination lemma supplies numerical
extraction by placing the full public budget in the Jensen slot.  Thus
the remaining `BacklundClassicalCombinationInput` and
`BacklundNumericalExtractionInput` frontiers are equivalent under the
current APIs. -/
noncomputable def BacklundNumericalExtractionInput.ofCombination
    (C : BacklundClassicalCombinationInput) :
    BacklundNumericalExtractionInput where
  extract := by
    intro T hgood hT hJ hR hH
    refine ⟨(1 / 2 : ℝ) * Real.log T + 1 / 2, 0, 0, ?_, ?_, ?_, ?_, ?_⟩
    · have hT_one : (1 : ℝ) ≤ T := by linarith
      have hlog : 0 ≤ Real.log T := Real.log_nonneg hT_one
      nlinarith
    · norm_num
    · norm_num
    · linarith
