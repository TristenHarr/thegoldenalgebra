    AnalyticAt Ôäé riemannZetaPoleUnit (1 : Ôäé) := by
  set f : Ôäé ÔåÆ Ôäé := fun z => (z - 1) * riemannZeta z with hf_def
  have h_tend : Tendsto f (­ØôØ[Ôëá] (1 : Ôäé)) (­ØôØ 1) := riemannZeta_residue_one
  have h_lim_one : limUnder (­ØôØ[Ôëá] (1 : Ôäé)) f = 1 := h_tend.limUnder_eq
  -- ÔÇûf zÔÇû < 2 eventually on ­ØôØ[Ôëá] 1
