/-! ### CW25: constant-parameterized Backlund budget -/

/-- Numerical constants for the final Backlund budget.  Splits a future
choice of explicit Backlund/Jensen constants into six named scalars: a
log-coefficient and an additive constant for each of the three classical
contributions. -/
structure BacklundNumericalConstants : Type where
  jensenLogCoeff : ℝ
  jensenConst : ℝ
  rightLogCoeff : ℝ
  rightConst : ℝ
  horizontalLogCoeff : ℝ
  horizontalConst : ℝ

namespace BacklundNumerics

/-- Jensen allowance parameterized by a constants package. -/
noncomputable def jensenAllowanceOf
    (K : BacklundNumericalConstants) (T : ℝ) : ℝ :=
  K.jensenLogCoeff * Real.log T + K.jensenConst

/-- Right-side allowance parameterized by a constants package. -/
noncomputable def rightSideAllowanceOf
    (K : BacklundNumericalConstants) (T : ℝ) : ℝ :=
  K.rightLogCoeff * Real.log T + K.rightConst

/-- Horizontal-boundary allowance parameterized by a constants package. -/
noncomputable def horizontalAllowanceOf
    (K : BacklundNumericalConstants) (T : ℝ) : ℝ :=
  K.horizontalLogCoeff * Real.log T + K.horizontalConst

/-- Total allowance parameterized by a constants package. -/
noncomputable def totalAllowanceOf
    (K : BacklundNumericalConstants) (T : ℝ) : ℝ :=
  jensenAllowanceOf K T +
    rightSideAllowanceOf K T +
    horizontalAllowanceOf K T

end BacklundNumerics

/-- Pure arithmetic admissibility: the chosen Backlund constants give
nonnegative allowances at every `T ≥ 140` and the total fits under the
target `(1/2)·log T + 1/2`. -/
structure BacklundNumericalConstantsAdmissible
    (K : BacklundNumericalConstants) : Prop where
  jensen_nonneg :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      0 ≤ BacklundNumerics.jensenAllowanceOf K T
  right_nonneg :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      0 ≤ BacklundNumerics.rightSideAllowanceOf K T
  horizontal_nonneg :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      0 ≤ BacklundNumerics.horizontalAllowanceOf K T
  total_le :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      BacklundNumerics.totalAllowanceOf K T
        ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Arithmetic helper for the final Backlund constants.  Once the
historical constants are inserted, admissibility reduces to checking
nonnegativity of the six individual scalars and the two summed budget
inequalities. -/
theorem BacklundNumericalConstantsAdmissible.of_nonneg_coeffs_and_budget
    {K : BacklundNumericalConstants}
    (hJlog : 0 ≤ K.jensenLogCoeff)
    (hRlog : 0 ≤ K.rightLogCoeff)
    (hHlog : 0 ≤ K.horizontalLogCoeff)
    (hJconst : 0 ≤ K.jensenConst)
    (hRconst : 0 ≤ K.rightConst)
    (hHconst : 0 ≤ K.horizontalConst)
    (hLogBudget :
      K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff
        ≤ (1 / 2 : ℝ))
    (hConstBudget :
      K.jensenConst + K.rightConst + K.horizontalConst
        ≤ (1 / 2 : ℝ)) :
    BacklundNumericalConstantsAdmissible K where
  jensen_nonneg := by
    intro T hT
    have hT_one : (1 : ℝ) ≤ T := by linarith
    have hlog : 0 ≤ Real.log T := Real.log_nonneg hT_one
    have hmul : 0 ≤ K.jensenLogCoeff * Real.log T :=
      mul_nonneg hJlog hlog
    dsimp [BacklundNumerics.jensenAllowanceOf]
    nlinarith
  right_nonneg := by
    intro T hT
    have hT_one : (1 : ℝ) ≤ T := by linarith
    have hlog : 0 ≤ Real.log T := Real.log_nonneg hT_one
    have hmul : 0 ≤ K.rightLogCoeff * Real.log T :=
      mul_nonneg hRlog hlog
    dsimp [BacklundNumerics.rightSideAllowanceOf]
    nlinarith
  horizontal_nonneg := by
    intro T hT
    have hT_one : (1 : ℝ) ≤ T := by linarith
    have hlog : 0 ≤ Real.log T := Real.log_nonneg hT_one
    have hmul : 0 ≤ K.horizontalLogCoeff * Real.log T :=
      mul_nonneg hHlog hlog
    dsimp [BacklundNumerics.horizontalAllowanceOf]
    nlinarith
  total_le := by
    intro T hT
    have hT_one : (1 : ℝ) ≤ T := by linarith
    have hlog : 0 ≤ Real.log T := Real.log_nonneg hT_one
    have hLogTerm :
        (K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff)
            * Real.log T
          ≤ (1 / 2 : ℝ) * Real.log T :=
      mul_le_mul_of_nonneg_right hLogBudget hlog
    calc
      BacklundNumerics.totalAllowanceOf K T
          = (K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff)
              * Real.log T
            + (K.jensenConst + K.rightConst + K.horizontalConst) := by
              simp [BacklundNumerics.totalAllowanceOf,
                BacklundNumerics.jensenAllowanceOf,
                BacklundNumerics.rightSideAllowanceOf,
                BacklundNumerics.horizontalAllowanceOf]
              ring
      _ ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 := by
            linarith

/-- Analytic obligation: at every good height `T ≥ 140`, the three
classical estimates produce a `|concreteS T|` bound by the total
allowance attached to a fixed constants package. -/
structure BacklundNumericalExtractionWithConstants
    (K : BacklundNumericalConstants) : Prop where
  controls :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        |concreteS T| ≤ BacklundNumerics.totalAllowanceOf K T

/-- Parallel explicit-bounds structure parameterized by a constants
package `K`. -/
structure BacklundExplicitNumericalBoundsWithConstantsAt
    (K : BacklundNumericalConstants) (T : ℝ) : Prop where
  hJ_nonneg :
    0 ≤ BacklundNumerics.jensenAllowanceOf K T
  hR_nonneg :
    0 ≤ BacklundNumerics.rightSideAllowanceOf K T
  hH_nonneg :
    0 ≤ BacklundNumerics.horizontalAllowanceOf K T
  controls :
    |concreteS T| ≤ BacklundNumerics.totalAllowanceOf K T
  total_le :
    BacklundNumerics.totalAllowanceOf K T
      ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Bridge: constants-parameterized explicit bounds → parameterized
budget. -/
noncomputable def BacklundExplicitNumericalBoundsWithConstantsAt.toBudget
    {K : BacklundNumericalConstants} {T : ℝ}
    (B : BacklundExplicitNumericalBoundsWithConstantsAt K T) :
    BacklundNumericalBudgetAt T where
  J := BacklundNumerics.jensenAllowanceOf K T
  R := BacklundNumerics.rightSideAllowanceOf K T
  H := BacklundNumerics.horizontalAllowanceOf K T
  hJ_nonneg := B.hJ_nonneg
  hR_nonneg := B.hR_nonneg
  hH_nonneg := B.hH_nonneg
  hcontrol := by
    simpa [BacklundNumerics.totalAllowanceOf] using B.controls
  hbudget := by
    simpa [BacklundNumerics.totalAllowanceOf] using B.total_le

/-- Bridge: analytic extraction + admissibility → pointwise extraction. -/
noncomputable def BacklundNumericalExtractionWithConstants.toPointwise
    {K : BacklundNumericalConstants}
    (Adm : BacklundNumericalConstantsAdmissible K)
    (E : BacklundNumericalExtractionWithConstants K) :
    BacklundPointwiseNumericalExtractionInput where
  extract_at := by
    intro T hgood hT hJ hR hH
    exact
      (BacklundExplicitNumericalBoundsWithConstantsAt.toBudget
        { hJ_nonneg := Adm.jensen_nonneg T hT
          hR_nonneg := Adm.right_nonneg T hT
          hH_nonneg := Adm.horizontal_nonneg T hT
          controls := E.controls T hgood hT hJ hR hH
          total_le := Adm.total_le T hT })

/-- **CW25 — final theorem from constants + admissibility + extraction.**
The remaining Backlund work cleanly factors as:
- *choose* a constants package `K`;
- *prove arithmetic* `BacklundNumericalConstantsAdmissible K`;
- *prove analytic* `BacklundNumericalExtractionWithConstants K`. -/
theorem concreteS_halfLogPlusHalf_of_backlundConstants
    {K : BacklundNumericalConstants}
    (Adm : BacklundNumericalConstantsAdmissible K)
    (E : BacklundNumericalExtractionWithConstants K)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_pointwiseBacklundNumerics
    (E.toPointwise Adm) hT

/-! ### CW26: classical Backlund–Turing theorem wrapper + headline -/

/-- Classical Backlund–Turing numerical extraction theorem.  Bundles the
choice of constants `K` together with both the arithmetic admissibility
proof and the analytic extraction proof.  `Type`-valued because it
carries the constants `K`. -/
structure ClassicalBacklundTuringTheorem where
  K : BacklundNumericalConstants
  admissible : BacklundNumericalConstantsAdmissible K
  extraction : BacklundNumericalExtractionWithConstants K

/-- The `|concreteS T|` bound at every `T ≥ 140` derived from the
classical Backlund–Turing theorem. -/
theorem ClassicalBacklundTuringTheorem.concreteS_halfLogPlusHalf
    (B : ClassicalBacklundTuringTheorem)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundConstants
    B.admissible B.extraction hT

/-- **CW26 — headline theorem.**  The Backlund–Turing concrete `S(T)`
bound `|concreteS T| ≤ (1/2)·log T + 1/2` for every `T ≥ 140`, derived
from the single packaged classical theorem. -/
theorem concreteS_halfLogPlusHalf_of_classicalBacklundTuring
    (B : ClassicalBacklundTuringTheorem)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  B.concreteS_halfLogPlusHalf hT

/-! ### CW27: start of the actual classical Backlund–Turing proof skeleton -/

namespace ClassicalBacklundTuringProof

/-- Headline-budget constants for the final Backlund–Turing target.

This package assigns the full public budget
