-- =====================================================================
-- ┬ºCCXXXV. Smooth density tail model + anti-Herglotz closure
-- =====================================================================
-- Reduces `SmoothDensityTailModelData.tailAnti` to: a partial-integral
-- definition of the smooth tail at finite cutoffs `[T, X]`, an eventual
-- anti-Herglotz property of those partials, and pointwise convergence
-- of the partials to a candidate tail. The limit closure follows from
-- the fact that `AntiHerglotzUHP R := ÔêÇ z (hz : 0 < z.im), (R z).im Ôëñ 0`
-- is a pointwise sign condition closed under pointwise limits.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto     ÔÇö reusable closure
--   smoothDensityTailModelPartial                     ÔÇö finite partial def
--   SmoothDensityTailModelConverges                   ÔÇö convergence package
--   SmoothDensityTailFiniteAntiData                   ÔÇö finite anti-Herglotz
--   smoothDensityTailModelData_of_converges           ÔÇö assembled tailModel

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `AntiHerglotzUHP` closes under eventual pointwise
limits.** If `F X` is eventually anti-Herglotz and `F X z ÔåÆ f z`
pointwise, then `f` is anti-Herglotz. This is a pure order/topology
lemma: the imaginary part is continuous, so `(F X z).im Ôëñ 0`
eventually transfers to `(f z).im Ôëñ 0` via `le_of_tendsto_of_tendsto`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto
    {F : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé} {f : Ôäé ÔåÆ Ôäé}
    (hF : ÔêÇßÂá X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : ÔêÇ z, Tendsto (fun X => F X z) Filter.atTop (­ØôØ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto : Tendsto (fun X => (F X z).im) Filter.atTop (­ØôØ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z)
  have hF_im_le : ÔêÇßÂá X in Filter.atTop, (F X z).im Ôëñ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **Smooth density tail partial.** Finite `[T, X]` integral of
`¤ü(u) ┬À (1/(z-u) + 1/(z+u))`. -/
noncomputable def smoothDensityTailModelPartial
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T X : ÔäØ) : Ôäé ÔåÆ Ôäé :=
  fun z : Ôäé =>
    Ôê½ u in T..X,
      ((¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) +
         (1 : Ôäé) / (z + (u : Ôäé))))

/-- **Smooth density tail convergence package.** Bundles a candidate
`tailModel : Ôäé ÔåÆ Ôäé` with pointwise convergence of the finite partials
as `X ÔåÆ Ôê×`. -/
structure SmoothDensityTailModelConverges
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) where
  tailModel : Ôäé ÔåÆ Ôäé
  tendsto   : ÔêÇ z : Ôäé,
    Tendsto
      (fun X : ÔäØ => smoothDensityTailModelPartial ¤ü T X z)
      Filter.atTop (­ØôØ (tailModel z))

/-- **Smooth density tail finite-window anti-Herglotz data.** Asserts
that each finite partial `smoothDensityTailModelPartial ¤ü T X` is
anti-Herglotz (for `X ÔëÑ T`). This is the analytic obligation a Lean
proof of the integral identity must discharge ÔÇö for a nonnegative
density `¤ü` and a paired Cauchy kernel, this follows by linearity of
the integral and pointwise anti-Herglotz of each `(1/(z-u) + 1/(z+u))`. -/
structure SmoothDensityTailFiniteAntiData
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) : Prop where
  finiteAnti :
    ÔêÇ X, T Ôëñ X ÔåÆ AntiHerglotzUHP (smoothDensityTailModelPartial ¤ü T X)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelData` from finite-partial
data + convergence.** Composes the ┬ºCCXXXV closure theorem with the
finite-anti-Herglotz hypothesis (restricted to `X ÔëÑ T` via
`Filter.eventually_ge_atTop`). -/
noncomputable def smoothDensityTailModelData_of_converges
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (C : SmoothDensityTailModelConverges ¤ü T)
    (Hfinite : SmoothDensityTailFiniteAntiData ¤ü T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto
      (F := fun X => smoothDensityTailModelPartial ¤ü T X)
    ┬À filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ┬À exact C.tendsto

-- =====================================================================
-- ┬ºCCXXXVI. Finite smooth-density partial anti-Herglotz from ¤ü ÔëÑ 0
-- =====================================================================
-- Discharges `SmoothDensityTailFiniteAntiData` for any nonnegative
-- density `¤ü`:
--   ÔÇó each `(1/(z-u) + 1/(z+u))` has Im Ôëñ 0 on UHP (existing
--     `pairedCauchyKernel_im_nonpos_at` from ┬º12-C);
--   ÔÇó multiplied by `(¤ü u : Ôäé)` with `¤ü u ÔëÑ 0`, the integrand Im Ôëñ 0;
--   ÔÇó integrating preserves the sign (Im commutes with the integral
--     via `Complex.imCLM.intervalIntegral_comp_comm`, then
--     `intervalIntegral.integral_nonneg` applied to the negation).
--
-- Adds:
--   smoothDensityTail_integrand_im_nonpos
--   smoothDensityTailModelPartial_im_nonpos
--   smoothDensityTailFiniteAntiData_of_nonneg

/-- Ô¡É **PROVED ÔÇö smooth density integrand has Im Ôëñ 0 on UHP.**
For `¤ü u ÔëÑ 0` and `z.im > 0`:
  `Im[(¤ü u : Ôäé) ┬À (1/(z-u) + 1/(z+u))] = ¤ü u ┬À Im[ÔÇª] Ôëñ 0`. -/
lemma smoothDensityTail_integrand_im_nonpos
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T u : ÔäØ) {z : Ôäé}
    (hTu : T Ôëñ u)
    (h¤ü : ÔêÇ v, T Ôëñ v ÔåÆ 0 Ôëñ ¤ü v)
    (hz : 0 < z.im) :
    (((¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im) Ôëñ 0 := by
  have h¤üu : 0 Ôëñ ¤ü u := h¤ü u hTu
  -- The paired kernel at z is exactly `pairedCauchyKernel u z`.
  have hk_eq : (1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))
             = pairedCauchyKernel u z := rfl
  have hk : ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))).im Ôëñ 0 := by
    rw [hk_eq]
    exact pairedCauchyKernel_im_nonpos_at z u hz
  -- Im of (real : Ôäé) ┬À w = real ┬À w.im
  have him_eq :
      (((¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im)
        = ¤ü u * ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))).im := by
    simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
  rw [him_eq]
  exact mul_nonpos_of_nonneg_of_nonpos h¤üu hk

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `(smoothDensityTailModelPartial ¤ü T X z).im Ôëñ 0`**
for `T Ôëñ X`, `0 < z.im`, and `¤ü ÔëÑ 0` on `[T, Ôê×)`. Routes Im through
the integral via `Complex.imCLM.intervalIntegral_comp_comm`, then
applies `intervalIntegral.integral_nonneg` to the negation. -/
lemma smoothDensityTailModelPartial_im_nonpos
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T X : ÔäØ) {z : Ôäé}
    (hTX : T Ôëñ X) (hz : 0 < z.im)
    (h¤ü_nonneg : ÔêÇ u, T Ôëñ u ÔåÆ 0 Ôëñ ¤ü u)
    (hInt :
      IntervalIntegrable
        (fun u =>
          (¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
        MeasureTheory.volume T X) :
    (smoothDensityTailModelPartial ¤ü T X z).im Ôëñ 0 := by
  unfold smoothDensityTailModelPartial
  -- Pull `.im` inside the integral via Complex.imCLM commutation
  have h_imCLM_comm := Complex.imCLM.intervalIntegral_comp_comm
    (╬╝ := MeasureTheory.volume) (a := T) (b := X) hInt
  -- Both sides written with Complex.imCLM, then simp to .im
  have him_eq :
      (Ôê½ u in T..X,
        (¤ü u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im
        =
      Ôê½ u in T..X,
        ((¤ü u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im := by
    simpa [Complex.imCLM_apply] using h_imCLM_comm.symm
  rw [him_eq]
  -- Apply nonnegativity to the negation
  have h_neg_nonneg :
      0 Ôëñ Ôê½ u in T..X,
        -(((¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im) := by
    apply intervalIntegral.integral_nonneg hTX
    intro u hu
    have hTu : T Ôëñ u := hu.1
    have hpt := smoothDensityTail_integrand_im_nonpos ¤ü T u hTu h¤ü_nonneg hz
    linarith
  have h_int_neg :
      (Ôê½ u in T..X,
        -(((¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im))
        =
      -(Ôê½ u in T..X,
        ((¤ü u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im) :=
    intervalIntegral.integral_neg
  linarith

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailFiniteAntiData` from
nonnegative ¤ü + finite-window integrability.** Each finite partial
`smoothDensityTailModelPartial ¤ü T X` is anti-Herglotz on UHP. -/
theorem smoothDensityTailFiniteAntiData_of_nonneg
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (h¤ü_nonneg : ÔêÇ u, T Ôëñ u ÔåÆ 0 Ôëñ ¤ü u)
    (hInt :
      ÔêÇ X z, T Ôëñ X ÔåÆ 0 < z.im ÔåÆ
        IntervalIntegrable
          (fun u =>
            (¤ü u : Ôäé) *
              ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
          MeasureTheory.volume T X) :
    SmoothDensityTailFiniteAntiData ¤ü T where
  finiteAnti := by
    intro X hTX z hz
    exact smoothDensityTailModelPartial_im_nonpos
      ¤ü T X hTX hz h¤ü_nonneg (hInt X z hTX hz)

-- =====================================================================
-- ┬ºCCXXXVII. Smooth density tail convergence from a norm majorant
-- =====================================================================
-- Discharges `SmoothDensityTailModelConverges ¤ü T` from a real-valued
-- pointwise majorant whose improper integral converges. Routes through
-- ┬ºCCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   SmoothDensityTailMajorantData                       ÔÇö majorant bundle
--   smoothDensityTailModel_converges_at                 ÔÇö pointwise existence
--   smoothDensityTailModelConverges_of_majorant         ÔÇö adaptive package
--   smoothDensityTailModelData_of_majorant_nonneg       ÔÇö full SmoothTail data

/-- ­ƒôª **`SmoothDensityTailMajorantData ¤ü T`** ÔÇö bundles the analytic
input needed to apply `improperComplexIntegralConverges_of_normMajorant`
to the smooth density integrand `(¤ü u : Ôäé) ┬À (1/(z-u) + 1/(z+u))`:

* `majorant z u` ÔÇö real majorant function (typically `O(log u / u┬▓)`);
* `majorant_intervalIntegrable` ÔÇö finite-window integrability;
* `majorant_converges` ÔÇö improper integral converges;
* `integrand_intervalIntegrable` ÔÇö finite-window integrability of the
  complex integrand;
* `norm_bound_eventually` ÔÇö `ÔÇûintegrandÔÇû Ôëñ majorant z u` eventually. -/
structure SmoothDensityTailMajorantData
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) where
  majorant : Ôäé ÔåÆ ÔäØ ÔåÆ ÔäØ
  majorant_intervalIntegrable :
    ÔêÇ z X, T Ôëñ X ÔåÆ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    ÔêÇ z, Ôêâ L : ÔäØ,
      Tendsto (fun X : ÔäØ => Ôê½ u in T..X, majorant z u)
        Filter.atTop (­ØôØ L)
  integrand_intervalIntegrable :
    ÔêÇ z X, T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          (¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    ÔêÇ z, ÔêÇßÂá u in Filter.atTop,
      ÔÇû(¤ü u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))ÔÇû
        Ôëñ majorant z u

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö pointwise smooth tail convergence from majorant.**
At each `z`, the smooth density partials converge as `X ÔåÆ Ôê×`. -/
theorem smoothDensityTailModel_converges_at
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (H : SmoothDensityTailMajorantData ¤ü T) (z : Ôäé) :
    Ôêâ L : Ôäé,
      Tendsto
        (fun X : ÔäØ => smoothDensityTailModelPartial ¤ü T X z)
        Filter.atTop (­ØôØ L) := by
  rcases H.majorant_converges z with Ôƒ¿LM, hLMÔƒ®
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hTX)
    hLM
    (H.norm_bound_eventually z)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelConverges` from majorant
data.** Uses `Classical.choose` on the pointwise existence theorem. -/
noncomputable def smoothDensityTailModelConverges_of_majorant
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (H : SmoothDensityTailMajorantData ¤ü T) :
    SmoothDensityTailModelConverges ¤ü T where
  tailModel := fun z =>
    Classical.choose (smoothDensityTailModel_converges_at ¤ü T H z)
  tendsto := fun z =>
    Classical.choose_spec (smoothDensityTailModel_converges_at ¤ü T H z)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelData` from `¤ü ÔëÑ 0` +
norm majorant.** End-to-end constructor: nonnegative density + complex
majorant data Ôƒ╣ full smooth-tail model data (including
anti-Herglotz). Composes ┬ºCCXXXVI's finite-anti discharger with
┬ºCCXXXVII's convergence theorem. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (h¤ü_nonneg : ÔêÇ u, T Ôëñ u ÔåÆ 0 Ôëñ ¤ü u)
    (H : SmoothDensityTailMajorantData ¤ü T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges ¤ü T
    (smoothDensityTailModelConverges_of_majorant ¤ü T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ¤ü T h¤ü_nonneg
      (fun X z hTX _hz => H.integrand_intervalIntegrable z X hTX))

-- =====================================================================
-- ┬ºCCXXXVIII. Smooth density majorant from log-growth + paired kernel
-- =====================================================================
-- Provides a real theorem-producing bridge: a log-growth bound on `|¤ü|`
-- plus the paired-Cauchy kernel cancellation `1/(z-u) + 1/(z+u) =
-- 2z/(z┬▓ - u┬▓)` gives a `1/u┬▓` decay on the kernel norm, hence a
-- log-over-`u┬▓` majorant for the smooth density integrand. Combined
-- with ┬ºCCXXIX-4a's `trueKernelLogMajorant` machinery, this discharges
-- `SmoothDensityTailMajorantData ¤ü T`.
--
-- Adds:
--   norm_pairedCauchyKernel_le_const_div_sq_eventually
--     ÔÇö `ÔÇû1/(z-u) + 1/(z+u)ÔÇû Ôëñ 4(ÔÇûzÔÇû+1)/u┬▓` for `u` eventually large
--   smoothDensityTailMajorantData_of_logGrowth
--     ÔÇö full constructor with explicit log envelope on `|¤ü|`

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö paired Cauchy kernel norm `1/u┬▓` decay.** For each
fixed `z`, eventually `ÔÇû1/(z-u) + 1/(z+u)ÔÇû Ôëñ 4(ÔÇûzÔÇû+1)/u┬▓`. Proof: use
the cancellation identity `1/(z-u) + 1/(z+u) = 2z/(z┬▓-u┬▓)` (existing
`pairedCauchyKernel_eq_two_mul`), bound `ÔÇûz┬▓ - u┬▓ÔÇû ÔëÑ u┬▓/2` for `u`
large via reverse triangle, and conclude. -/
lemma norm_pairedCauchyKernel_le_const_div_sq_eventually
    (z : Ôäé) :
    ÔêÇßÂá u : ÔäØ in Filter.atTop,
      ÔÇû(1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))ÔÇû
        Ôëñ 4 * (ÔÇûzÔÇû + 1) / u^2 := by
  filter_upwards
    [Filter.eventually_ge_atTop (2 * (ÔÇûzÔÇû + 1)),
     Filter.eventually_gt_atTop (0 : ÔäØ)]
    with u hu_large hu_pos
  have h_z_nn : 0 Ôëñ ÔÇûzÔÇû := norm_nonneg z
  have h_u_pos_sq : 0 < u^2 := by positivity
  have h_2_zp1_nn : (0 : ÔäØ) Ôëñ 2 * (ÔÇûzÔÇû + 1) := by linarith
  have h_u_sq_ge : (2 * (ÔÇûzÔÇû + 1))^2 Ôëñ u^2 := by
    have := mul_self_le_mul_self h_2_zp1_nn hu_large
    nlinarith [this]
  have h_diff_bound : u^2 / 2 Ôëñ u^2 - ÔÇûzÔÇû^2 := by
    nlinarith [h_u_sq_ge, h_z_nn]
  have h_norm_u_sq : ÔÇû((u : Ôäé))^2ÔÇû = u^2 := by
    have h_pow : ((u : Ôäé))^2 = ((u^2 : ÔäØ) : Ôäé) := by push_cast; ring
    rw [h_pow, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (sq_nonneg u)]
  have h_norm_z_sq : ÔÇûz^2ÔÇû = ÔÇûzÔÇû^2 := by
    rw [pow_two, pow_two, norm_mul]
  have h_rev_tri : u^2 - ÔÇûzÔÇû^2 Ôëñ ÔÇûz^2 - (u : Ôäé)^2ÔÇû := by
    have h := norm_sub_norm_le ((u : Ôäé)^2) (z^2)
    rw [h_norm_u_sq, h_norm_z_sq, ÔåÉ norm_sub_rev] at h
    exact h
  have h_diff_lower : u^2 / 2 Ôëñ ÔÇûz^2 - (u : Ôäé)^2ÔÇû :=
    le_trans h_diff_bound h_rev_tri
  have h_u_half_pos : 0 < u^2 / 2 := by linarith
  have h_diff_norm_pos : 0 < ÔÇûz^2 - (u : Ôäé)^2ÔÇû :=
    lt_of_lt_of_le h_u_half_pos h_diff_lower
  have h_diff_ne : z^2 - (u : Ôäé)^2 Ôëá 0 := norm_pos_iff.mp h_diff_norm_pos
  have h_z_sq_ne : z^2 Ôëá (u : Ôäé)^2 := sub_ne_zero.mp h_diff_ne
  have h_kernel_eq :
      (1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))
        = 2 * z / (z^2 - (u : Ôäé)^2) := by
    have := pairedCauchyKernel_eq_two_mul u z h_z_sq_ne
    unfold pairedCauchyKernel at this
    exact this
  rw [h_kernel_eq, norm_div]
  have h_num_norm : ÔÇû(2 : Ôäé) * zÔÇû = 2 * ÔÇûzÔÇû := by
    rw [norm_mul]; simp
  rw [h_num_norm]
  have h_2z_nn : 0 Ôëñ 2 * ÔÇûzÔÇû := by linarith
  calc 2 * ÔÇûzÔÇû / ÔÇûz^2 - (u : Ôäé)^2ÔÇû
      Ôëñ 2 * ÔÇûzÔÇû / (u^2 / 2) :=
        div_le_div_of_nonneg_left h_2z_nn h_u_half_pos h_diff_lower
    _ = 4 * ÔÇûzÔÇû / u^2 := by field_simp; ring
    _ Ôëñ 4 * (ÔÇûzÔÇû + 1) / u^2 := by
        gcongr
        linarith

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailMajorantData` from log growth.**
Given a log envelope `|¤ü u| Ôëñ A log u + B` and finite-window
integrability of the integrand, produces the full majorant bundle.
The constructed majorant is
`majorant z u := trueKernelLogMajorant ((ÔÇûzÔÇû+1)┬ÀA/2) ((ÔÇûzÔÇû+1)┬ÀB/2) u`
= `4(ÔÇûzÔÇû+1)┬À(A log u + B)/u┬▓`. -/
noncomputable def smoothDensityTailMajorantData_of_logGrowth
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) (A B : ÔäØ)
    (_hA_nn : 0 Ôëñ A) (_hB_nn : 0 Ôëñ B)
    (hTpos : 0 < T)
    (h¤ü_bound : ÔêÇßÂá u in Filter.atTop, |¤ü u| Ôëñ A * Real.log u + B)
    (h¤ü_int :
      ÔêÇ z X, T Ôëñ X ÔåÆ
        IntervalIntegrable
          (fun u =>
            (¤ü u : Ôäé) *
              ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantData ¤ü T where
  majorant := fun z u =>
    trueKernelLogMajorant ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z
    refine Ôƒ¿-trueKernelLogMajorantPrimitive
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T, ?_Ôƒ®
    exact trueKernelLogMajorantConverges
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := h¤ü_int
  norm_bound_eventually := by
    intro z
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, h¤ü_bound] with u hk h¤üu
    rw [norm_mul]
    have h_norm_ofReal : ÔÇû(¤ü u : Ôäé)ÔÇû = |¤ü u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 Ôëñ A * Real.log u + B :=
      le_trans (abs_nonneg _) h¤üu
    calc |¤ü u| * ÔÇû(1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))ÔÇû
        Ôëñ (A * Real.log u + B) * (4 * (ÔÇûzÔÇû + 1) / u^2) :=
          mul_le_mul h¤üu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- ┬ºCCXXXIX. `zeroDensityRho` log-growth bound
-- =====================================================================
-- Concrete deliverable for the `zeroDensityRho` density:
-- `|zeroDensityRho u| Ôëñ (1/(2¤Ç)) ┬À log u` for `u ÔëÑ 2¤Ç` (the positivity
-- threshold). This is exactly the `h¤ü_bound` field shape required by
-- ┬ºCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`.
--
-- Note: the full `SmoothDensityTailMajorantData` for `zeroDensityRho`
-- additionally requires per-`(z, X)` integrability of the integrand
-- `(zeroDensityRho u : Ôäé) ┬À (1/(z-u) + 1/(z+u))`. That field is
-- universally quantified over `z` in the structure, but the kernel
-- has poles for real `z` lying in `[T, X]`, so integrability genuinely
-- fails there. A full instantiation would require either restricting
-- the structure to UHP `z` or providing the integrability as an
-- additional explicit hypothesis (deferred).
--
-- Adds:
--   zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
--   zeroDensityRho_log_growth_eventually

/-- Ô¡É **PROVED ÔÇö `|zeroDensityRho u| Ôëñ (1/(2¤Ç)) ┬À log u` for `u ÔëÑ 2¤Ç`.**
For `u ÔëÑ 2¤Ç`, `¤ü u = (1/(2¤Ç))┬À(log u - log(2¤Ç)) ÔëÑ 0` and `log(2¤Ç) ÔëÑ 0`
(since `2¤Ç ÔëÑ 1`), so `|¤ü u| = ¤ü u Ôëñ (1/(2¤Ç)) log u`. -/
lemma zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
    {u : ÔäØ} (hu : 2 * Real.pi Ôëñ u) :
    |zeroDensityRho u| Ôëñ (1 / (2 * Real.pi)) * Real.log u := by
  have h_nn : 0 Ôëñ zeroDensityRho u := zeroDensityRho_nonneg_of_ge_two_pi hu
  rw [abs_of_nonneg h_nn]
  unfold zeroDensityRho
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : ÔäØ) Ôëñ 1 / (2 * Real.pi) := by positivity
  have h2pi_ge_one : (1 : ÔäØ) Ôëñ 2 * Real.pi := by
    have := Real.pi_gt_three
    linarith
  have h_log_2pi_nn : 0 Ôëñ Real.log (2 * Real.pi) := Real.log_nonneg h2pi_ge_one
  have h_log_eq : Real.log (u / (2 * Real.pi))
                  = Real.log u - Real.log (2 * Real.pi) := by
    have h_u_pos : 0 < u := lt_of_lt_of_le h2pi_pos hu
    rw [Real.log_div (ne_of_gt h_u_pos) (ne_of_gt h2pi_pos)]
  rw [h_log_eq]
  -- (1/(2¤Ç)) * (log u - log(2¤Ç)) Ôëñ (1/(2¤Ç)) * log u
  -- since -(1/(2¤Ç)) * log(2¤Ç) Ôëñ 0
  have h_diff_nn :
      (1 / (2 * Real.pi)) * Real.log u -
        (1 / (2 * Real.pi)) * (Real.log u - Real.log (2 * Real.pi))
        = (1 / (2 * Real.pi)) * Real.log (2 * Real.pi) := by ring
  nlinarith [mul_nonneg h2pi_inv_nn h_log_2pi_nn]

/-- Ô¡É **PROVED ÔÇö eventual log-growth bound for `zeroDensityRho`.**
For `A := 1/(2¤Ç)`, `B := 0`, eventually `|¤ü u| Ôëñ A ┬À log u + B`. Direct
form for plugging into ┬ºCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`. -/
lemma zeroDensityRho_log_growth_eventually :
    ÔêÇßÂá u : ÔäØ in Filter.atTop,
      |zeroDensityRho u| Ôëñ (1 / (2 * Real.pi)) * Real.log u + 0 := by
  filter_upwards [Filter.eventually_ge_atTop (2 * Real.pi)] with u hu
  have := zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi hu
  linarith

-- =====================================================================
-- ┬ºCCXL. UHP-restricted smooth density majorant chain
-- =====================================================================
-- Compatibility refinement: the existing ┬ºCCXXXV / ┬ºCCXXXVII universal-`z`
-- structures `SmoothDensityTailModelConverges` and
-- `SmoothDensityTailMajorantData` are too strong for densities like
-- `zeroDensityRho` whose paired-kernel integrand has poles at real
-- `z Ôêê [T, X]`. This section adds UHP-restricted siblings that quantify
-- the convergence / integrability fields over `0 < z.im` only ÔÇö which
-- is what the downstream `AntiHerglotzUHP` actually consumes.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
--   SmoothDensityTailModelConvergesUHP
--   SmoothDensityTailMajorantDataUHP
--   smoothDensityTailModel_converges_at_UHP
--   smoothDensityTailModelConvergesUHP_of_majorant
--   smoothDensityTailModelData_of_converges_UHP
--   smoothDensityTailModelData_of_majorant_nonneg_UHP
--   smoothDensityTailMajorantDataUHP_of_logGrowth

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö UHP-restricted closure for `AntiHerglotzUHP`.**
If `F X` is eventually anti-Herglotz and `F X z ÔåÆ f z` pointwise *only
on UHP*, then `f` is anti-Herglotz. Same proof structure as
`AntiHerglotzUHP.of_eventual_pointwise_tendsto` (┬ºCCXXXV), just
restricting the convergence hypothesis to `0 < z.im`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
    {F : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé} {f : Ôäé ÔåÆ Ôäé}
    (hF : ÔêÇßÂá X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : ÔêÇ z, 0 < z.im ÔåÆ
      Tendsto (fun X => F X z) Filter.atTop (­ØôØ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto :
      Tendsto (fun X => (F X z).im) Filter.atTop (­ØôØ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z hz)
  have hF_im_le : ÔêÇßÂá X in Filter.atTop, (F X z).im Ôëñ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **UHP-restricted convergence package.** Like
`SmoothDensityTailModelConverges` but with convergence required only
for `z` with `0 < z.im`. Outside UHP, `tailModel` is free (typically 0). -/
structure SmoothDensityTailModelConvergesUHP
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) where
  tailModel : Ôäé ÔåÆ Ôäé
  tendsto   : ÔêÇ z : Ôäé, 0 < z.im ÔåÆ
    Tendsto
      (fun X : ÔäØ => smoothDensityTailModelPartial ¤ü T X z)
      Filter.atTop (­ØôØ (tailModel z))

/-- ­ƒôª **`SmoothDensityTailMajorantDataUHP ¤ü T`** ÔÇö UHP-restricted
sibling of `SmoothDensityTailMajorantData`. All four fields are
quantified over `0 < z.im` to avoid the real-`z` pole non-integrability. -/
structure SmoothDensityTailMajorantDataUHP
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) where
  majorant : Ôäé ÔåÆ ÔäØ ÔåÆ ÔäØ
  majorant_intervalIntegrable :
    ÔêÇ z X, 0 < z.im ÔåÆ T Ôëñ X ÔåÆ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    ÔêÇ z, 0 < z.im ÔåÆ Ôêâ L : ÔäØ,
      Tendsto (fun X : ÔäØ => Ôê½ u in T..X, majorant z u)
        Filter.atTop (­ØôØ L)
  integrand_intervalIntegrable :
    ÔêÇ z X, 0 < z.im ÔåÆ T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          (¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    ÔêÇ z, 0 < z.im ÔåÆ ÔêÇßÂá u in Filter.atTop,
      ÔÇû(¤ü u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))ÔÇû
        Ôëñ majorant z u

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö UHP pointwise smooth tail convergence from
majorant.** Sibling of ┬ºCCXXXVII's `smoothDensityTailModel_converges_at`
restricted to UHP `z`. -/
theorem smoothDensityTailModel_converges_at_UHP
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (H : SmoothDensityTailMajorantDataUHP ¤ü T)
    (z : Ôäé) (hz : 0 < z.im) :
    Ôêâ L : Ôäé,
      Tendsto
        (fun X : ÔäØ => smoothDensityTailModelPartial ¤ü T X z)
        Filter.atTop (­ØôØ L) := by
  rcases H.majorant_converges z hz with Ôƒ¿LM, hLMÔƒ®
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hz hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hz hTX)
    hLM
    (H.norm_bound_eventually z hz)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelConvergesUHP` from
majorant data.** Uses `Classical.choose` on the UHP pointwise
existence theorem, with `tailModel z := 0` outside UHP. -/
noncomputable def smoothDensityTailModelConvergesUHP_of_majorant
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (H : SmoothDensityTailMajorantDataUHP ¤ü T) :
    SmoothDensityTailModelConvergesUHP ¤ü T where
  tailModel := fun z =>
    if hz : 0 < z.im then
      Classical.choose (smoothDensityTailModel_converges_at_UHP ¤ü T H z hz)
    else 0
  tendsto := by
    intro z hz
    have hExists := smoothDensityTailModel_converges_at_UHP ¤ü T H z hz
    have htail_val :
        (if hz' : 0 < z.im then
            Classical.choose
              (smoothDensityTailModel_converges_at_UHP ¤ü T H z hz')
          else 0)
          = Classical.choose hExists := by
      rw [dif_pos hz]
    rw [htail_val]
    exact Classical.choose_spec hExists

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelData` from UHP convergence
+ finite anti.** UHP-friendly sibling of ┬ºCCXXXV's
`smoothDensityTailModelData_of_converges`. -/
noncomputable def smoothDensityTailModelData_of_converges_UHP
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (C : SmoothDensityTailModelConvergesUHP ¤ü T)
    (Hfinite : SmoothDensityTailFiniteAntiData ¤ü T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
      (F := fun X => smoothDensityTailModelPartial ¤ü T X)
    ┬À filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ┬À exact C.tendsto

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelData` from `¤ü ÔëÑ 0` + UHP
norm majorant.** End-to-end UHP-restricted constructor. Mirrors
┬ºCCXXXVII's `smoothDensityTailModelData_of_majorant_nonneg`. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg_UHP
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ)
    (h¤ü_nonneg : ÔêÇ u, T Ôëñ u ÔåÆ 0 Ôëñ ¤ü u)
    (H : SmoothDensityTailMajorantDataUHP ¤ü T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges_UHP ¤ü T
    (smoothDensityTailModelConvergesUHP_of_majorant ¤ü T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ¤ü T h¤ü_nonneg
      (fun X z hTX hz => H.integrand_intervalIntegrable z X hz hTX))

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö UHP `SmoothDensityTailMajorantDataUHP` from log
growth.** Sibling of ┬ºCCXXXVIII restricted to UHP `z`. -/
noncomputable def smoothDensityTailMajorantDataUHP_of_logGrowth
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) (A B : ÔäØ)
    (_hA_nn : 0 Ôëñ A) (_hB_nn : 0 Ôëñ B)
    (hTpos : 0 < T)
    (h¤ü_bound : ÔêÇßÂá u in Filter.atTop, |¤ü u| Ôëñ A * Real.log u + B)
    (h¤ü_int :
      ÔêÇ z X, 0 < z.im ÔåÆ T Ôëñ X ÔåÆ
        IntervalIntegrable
          (fun u =>
            (¤ü u : Ôäé) *
              ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantDataUHP ¤ü T where
  majorant := fun z u =>
    trueKernelLogMajorant ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X _hz hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z _hz
    refine Ôƒ¿-trueKernelLogMajorantPrimitive
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T, ?_Ôƒ®
    exact trueKernelLogMajorantConverges
      ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := h¤ü_int
  norm_bound_eventually := by
    intro z _hz
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, h¤ü_bound] with u hk h¤üu
    rw [norm_mul]
    have h_norm_ofReal : ÔÇû(¤ü u : Ôäé)ÔÇû = |¤ü u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 Ôëñ A * Real.log u + B :=
      le_trans (abs_nonneg _) h¤üu
    calc |¤ü u| * ÔÇû(1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))ÔÇû
        Ôëñ (A * Real.log u + B) * (4 * (ÔÇûzÔÇû + 1) / u^2) :=
          mul_le_mul h¤üu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((ÔÇûzÔÇû + 1) * A / 2) ((ÔÇûzÔÇû + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- ┬ºCCXLI. `zeroDensityRho` smooth-tail UHP integrability + concrete data
-- =====================================================================
-- Final piece needed to fully discharge `SmoothDensityTailModelData` for
-- `zeroDensityRho`: continuity-based interval integrability of the
-- integrand `(zeroDensityRho u : Ôäé) ┬À (1/(z-u) + 1/(z+u))` on `[T, X]`
-- for UHP `z`, then composition with ┬ºCCXL's UHP majorant chain.
--
-- Adds:
--   complex_sub_real_ne_zero_of_im_pos
--   complex_add_real_ne_zero_of_im_pos
--   continuous_pairedCauchyKernel_u_of_im_pos
--   zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
--   smoothDensityTailModelData_zeroDensityRho

/-- Ô¡É **PROVED ÔÇö `z - (u : Ôäé) Ôëá 0` when `0 < z.im`.** -/
lemma complex_sub_real_ne_zero_of_im_pos
    {z : Ôäé} (hz : 0 < z.im) (u : ÔäØ) :
    z - (u : Ôäé) Ôëá 0 := by
  intro h
  have him : (z - (u : Ôäé)).im = 0 := by rw [h]; rfl
  have him' : (z - (u : Ôäé)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- Ô¡É **PROVED ÔÇö `z + (u : Ôäé) Ôëá 0` when `0 < z.im`.** -/
lemma complex_add_real_ne_zero_of_im_pos
    {z : Ôäé} (hz : 0 < z.im) (u : ÔäØ) :
    z + (u : Ôäé) Ôëá 0 := by
  intro h
  have him : (z + (u : Ôäé)).im = 0 := by rw [h]; rfl
  have him' : (z + (u : Ôäé)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö paired Cauchy kernel continuous in `u` for UHP `z`.**
For `0 < z.im`, the map `u Ôåª 1/(z - u) + 1/(z + u)` is continuous on ÔäØ,
since both denominators are non-vanishing. -/
lemma continuous_pairedCauchyKernel_u_of_im_pos
    {z : Ôäé} (hz : 0 < z.im) :
    Continuous fun u : ÔäØ =>
      (1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)) := by
  refine Continuous.add ?_ ?_
  ┬À apply Continuous.divÔéÇ continuous_const
    ┬À exact continuous_const.sub Complex.continuous_ofReal
    ┬À intro u
      exact complex_sub_real_ne_zero_of_im_pos hz u
  ┬À apply Continuous.divÔéÇ continuous_const
    ┬À exact continuous_const.add Complex.continuous_ofReal
    ┬À intro u
      exact complex_add_real_ne_zero_of_im_pos hz u

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö UHP interval integrability of
`zeroDensityRho ├ù paired Cauchy kernel`.** For `0 < T Ôëñ X` and
`0 < z.im`, the integrand is continuous on `[T, X]` (both factors
continuous + denominators non-vanishing), hence interval-integrable. -/
theorem zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
    (T X : ÔäØ) {z : Ôäé}
    (hTpos : 0 < T) (hTX : T Ôëñ X) (hz : 0 < z.im) :
    IntervalIntegrable
      (fun u =>
        (zeroDensityRho u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
      MeasureTheory.volume T X := by
  -- ¤ü continuous on Icc T X (subset of Ioi 0)
  have h¤ü_real : ContinuousOn zeroDensityRho (Set.Icc T X) := by
    apply Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    intro u hu
    exact lt_of_lt_of_le hTpos hu.1
  have h¤ü : ContinuousOn (fun u : ÔäØ => (zeroDensityRho u : Ôäé))
      (Set.Icc T X) :=
    Complex.continuous_ofReal.comp_continuousOn h¤ü_real
  -- Kernel continuous on UHP for fixed z
  have hk : ContinuousOn
      (fun u : ÔäØ =>
        (1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))
      (Set.Icc T X) :=
    (continuous_pairedCauchyKernel_u_of_im_pos hz).continuousOn
  have hprod : ContinuousOn
      (fun u =>
        (zeroDensityRho u : Ôäé) *
          ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé))))
      (Set.Icc T X) :=
    h¤ü.mul hk
  exact ContinuousOn.intervalIntegrable_of_Icc hTX hprod

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `SmoothDensityTailModelData` for the concrete
`zeroDensityRho` density.** Given `T ÔëÑ 2¤Ç`, produces a full
`SmoothDensityTailModelData` by composing ┬ºCCXLI's integrability
discharger with ┬ºCCXL's UHP majorant chain and ┬ºCCXXXIX's log-growth
bound. -/
noncomputable def smoothDensityTailModelData_zeroDensityRho
    (T : ÔäØ) (hT_ge : 2 * Real.pi Ôëñ T) :
    SmoothDensityTailModelData := by
  have hTpos : 0 < T := by
    have hpi : (0 : ÔäØ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hT_ge
  have h2pi_inv_nn : (0 : ÔäØ) Ôëñ 1 / (2 * Real.pi) := by positivity
  exact smoothDensityTailModelData_of_majorant_nonneg_UHP
    zeroDensityRho T
    (fun u hTu =>
      zeroDensityRho_nonneg_of_ge_two_pi (le_trans hT_ge hTu))
    (smoothDensityTailMajorantDataUHP_of_logGrowth
      zeroDensityRho T
      (1 / (2 * Real.pi)) 0
      h2pi_inv_nn le_rfl hTpos
      zeroDensityRho_log_growth_eventually
      (fun z X hz hTX =>
        zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
          T X hTpos hTX hz))

