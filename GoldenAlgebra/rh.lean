-- §CCLXXXVIII. Zero-branch regression + taint convention
-- =====================================================================

/-- 🌟 **PROVED — regression: the zero-branch margin guard.** Names the
exact algebra step every guarded local-package constructor relies on in
its `XiPullback z = 0` branch. -/
theorem lowResidualMargin_zero_branch_guard_test
    {M : CloudDensityTailModelDecomposition}
    {z : ℂ}
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hdecomp :
      ∀ z : ℂ,
        logDerivativeResponse XiPullback z =
          M.model z + xiResidualError M z)
    (hz : 0 < z.im)
    (hzero : XiPullback z = 0) :
    |(xiResidualError M z).im| ≤ -(M.model z).im :=
  errorMargin_at_XiPullback_zero_of_decomp
    hmodelAnti hdecomp hz hzero

/-! ### Taint convention

`logDerivativeResponse XiPullback z` is the `a / 0 = 0` totalization of
`deriv (XiPullback) z / XiPullback z`. At any `z` with
`XiPullback z = 0`, the value collapses to `0` — *not* the analytic
limit. `xiResidualError M z := logDerivativeResponse XiPullback z −
M.model z` inherits this taint: at a zero, the residual is
*definitionally* `−M.model z`, regardless of any analytic interpretation.

Rule of thumb. Any public analytic input that mentions either
`logDerivativeResponse XiPullback z` or `xiResidualError M z` for `z`
ranging over a region of UHP must carry an explicit
`XiPullback z ≠ 0 →` guard. The only places allowed to drop the guard
are trusted wrapper constructors that internally do
```
by_cases hzero : XiPullback z = 0
· exact errorMargin_at_XiPullback_zero_of_decomp ...
· exact analytic_input ... hzero
```
The §CCL-bis / §CCLXXXII / §CCLXXXVII chain implements this convention.
Discharge of an unguarded analytic input cannot proceed at a zero
without circularity. -/

-- =====================================================================
-- §CCLXXXVII. Discharge `Hgap` via structural `DzeroStartsAfter` + N₀-root
-- =====================================================================
-- The §CCLXXXV `FirstZeroGapForDzero` Prop says
-- `finiteFluctuationPrimitive Dzero T0 u = -smoothZeroCountingN0 u`
-- on `[2π, γ]`. Under `DzeroStartsAfter γ` (no fluctuation atoms in
-- `[T0, γ]`) the discrete part vanishes and the structural identity
-- reduces to
--   `finiteFluctuationPrimitive Dzero T0 u
--      = smoothZeroCountingN0 T0 − smoothZeroCountingN0 u`.
-- So the §CCLXXXV shape `= -N₀(u)` holds **iff** `smoothZeroCountingN0 T0 = 0`,
-- i.e., iff `T0` is the unique root `u₀ ≈ 9.74` of `N₀` in `(2π, ∞)`.
-- This section honestly carries that constraint as the `hN0_T0`
-- hypothesis. A future refactor could replace `FirstZeroGapForDzero`
-- with a basepoint-adjusted shape `S(T0, u) = N₀(T0) − N₀(u)` that
-- accepts arbitrary `T0 ≤ 2π`.
--
-- Adds:
--   DzeroStartsAfter                                      — no atoms below γ
--   discreteCountingPrimitive_eq_zero_of_startsAfter      — discrete vanishes
--   smoothCountingPrimitive_eq_N0_diff                    — FTC bridge
--   finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter  — structural identity
--   FirstZeroGapForDzero_of_startsAfter_at_root           — inhabit Hgap
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowFiniteIBP_11_14_half_startsAfter
--                                                          — Hgap-free front door

/-- 📦 **`DzeroStartsAfter Dzero γ`** — strict structural condition:
every zero ordinate in `Dzero.Z` is strictly greater than `γ`. For
`zeros100ceil` with first entry `15`, `DzeroStartsAfter Dzero 14`
holds (`14 < 15`). The strict inequality avoids edge cases at `u = γ`. -/
structure DzeroStartsAfter
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (γ : ℝ) : Prop where
  z_gt_gamma : ∀ i : ℕ, γ < Dzero.toFluctuationMeasureData.Z i

/-- ⭐ **PROVED — discrete counting primitive vanishes on `[T0, u]`** when
all atoms lie strictly above `γ ≥ u`. Each `if T0 ≤ Z_j ∧ Z_j ≤ u`
term is false because `u < Z_j`. -/
lemma discreteCountingPrimitive_eq_zero_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 γ u : ℝ}
    (H : DzeroStartsAfter Dzero γ) (hu : u ≤ γ) :
    Phase1IBP.discreteCountingPrimitive
        Dzero.toFluctuationMeasureData T0 u = 0 := by
  classical
  unfold Phase1IBP.discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j _
  have hZj : γ < Dzero.toFluctuationMeasureData.Z j := H.z_gt_gamma j
  have hu_Zj : u < Dzero.toFluctuationMeasureData.Z j :=
    lt_of_le_of_lt hu hZj
  have hnot :
      ¬ (T0 ≤ Dzero.toFluctuationMeasureData.Z j ∧
         Dzero.toFluctuationMeasureData.Z j ≤ u) := by
    intro ⟨_, h⟩
    exact (not_lt.mpr h) hu_Zj
  simp [hnot]

/-- ⭐ **PROVED — `smoothCountingPrimitive T0 u = N₀(u) − N₀(T0)`** for
positive `T0 ≤ u`, via FTC and `hasDerivAt_smoothZeroCountingN0`. -/
lemma smoothCountingPrimitive_eq_N0_diff
    {T0 u : ℝ} (hT0 : 0 < T0) (hT0u : T0 ≤ u) :
    Phase1IBP.smoothCountingPrimitive T0 u
      = smoothZeroCountingN0 u - smoothZeroCountingN0 T0 := by
  unfold Phase1IBP.smoothCountingPrimitive
  have h_deriv : ∀ v ∈ Set.uIcc T0 u,
      HasDerivAt smoothZeroCountingN0 (zeroDensityRho v) v := by
    intro v hv
    rw [Set.uIcc_of_le hT0u] at hv
    exact hasDerivAt_smoothZeroCountingN0
      (lt_of_lt_of_le hT0 hv.1)
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T0 u :=
    Phase1IBP.zeroDensityRho_intervalIntegrable hT0 hT0u
  exact intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int

/-- ⭐ **PROVED — structural identity for `finiteFluctuationPrimitive`**
on the first-zero gap under `DzeroStartsAfter`:
`S(T0, u) = N₀(T0) − N₀(u)`. -/
theorem finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 γ u : ℝ}
    (H : DzeroStartsAfter Dzero γ)
    (hT0_pos : 0 < T0) (hT0u : T0 ≤ u) (hu : u ≤ γ) :
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
      = smoothZeroCountingN0 T0 - smoothZeroCountingN0 u := by
  unfold Phase1IBP.finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_eq_zero_of_startsAfter H hu,
      smoothCountingPrimitive_eq_N0_diff hT0_pos hT0u]
  ring

/-- 🌟🌟 **PROVED — `FirstZeroGapForDzero Dzero T0 14` inhabitant** from
the structural pieces. Requires:
* `H : DzeroStartsAfter Dzero 14` — no atoms below 14;
* `hT0_pos : 0 < T0`;
* `hT0_le_2pi : T0 ≤ 2π` — so the smooth-bridge integration on
  `[T0, u]` extends over the full gap `[2π, 14]`;
* `hN0_T0 : smoothZeroCountingN0 T0 = 0` — the basepoint-root condition
  needed to specialize the structural identity to the §CCLXXXV shape.

The `hN0_T0` hypothesis pins `T0` to the unique root `u₀ ≈ 9.74` of
`N₀` in `(2π, ∞)`. A future refactor of §CCLXXXV's Hgap shape to
`S(T0, u) = N₀(T0) − N₀(u)` would eliminate this constraint. -/
theorem FirstZeroGapForDzero_of_startsAfter_at_root
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    (H : DzeroStartsAfter Dzero 14)
    (hT0_pos : 0 < T0)
    (hT0_le_2pi : T0 ≤ 2 * Real.pi)
    (hN0_T0 : smoothZeroCountingN0 T0 = 0) :
    FirstZeroGapForDzero Dzero T0 14 := by
  refine ⟨?_⟩
  intro u hu_2pi hu14
  have hT0u : T0 ≤ u := le_trans hT0_le_2pi hu_2pi
  have h := finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter
              H hT0_pos hT0u hu14
  rw [h, hN0_T0]
  ring

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
FRONT DOOR (`Hgap` discharged via `DzeroStartsAfter` + `N₀(T0) = 0`)**.

Replaces the §CCLXXXVI `Hgap` input with the structural pair
`(Hstarts, hN0_T0)`:

```
hTuring + hHighLog
+ Hcanon_tailLimit
+ Hhigh_tailLimit
+ Hdom                          (xi: residual ≤ |boundary| + |deriv|)
+ Hstarts : DzeroStartsAfter Dzero 14   (structural, true for any Dzero
                                         whose Z list starts above 14)
+ hN0_T0  : smoothZeroCountingN0 T0 = 0 (analytic, true for T0 = u₀ ≈ 9.74)
+ HlowArith                     (model arithmetic at (11, 14, 1/2))
⟹ XiPullbackAntiHerglotzTarget
```

The structural side `Hstarts` is the cheap win — for `zeros100ceil`
the first entry is `15`, so `14 < 15` discharges `Hstarts` directly. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_lowFiniteIBP_11_14_half_startsAfterAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hT0_le_2pi : T0 ≤ 2 * Real.pi)
    (hN0_T0 : smoothZeroCountingN0 T0 = 0)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hcanon_tailLimit :
      XiCanonicalResidualAsTailLimitAwayFromZeros
        Dzero T0 honestZeroDensityModelTwoPi)
    (Hhigh_tailLimit :
      XiHighResidualAsTailLimitAwayFromZeros
        Dzero T0 honestZeroDensityModelTwoPi)
    (Hdom :
      XiLowResidualFiniteIBPDominationAwayFromZeros
        Dzero T0 honestZeroDensityModelTwoPi)
    (Hstarts : DzeroStartsAfter Dzero 14)
    (HlowArith : LowExplicitArithmeticBound_11_14_half) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_lowFiniteIBP_11_14_half_noHintAwayFromZeros
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
    Hcanon_tailLimit Hhigh_tailLimit Hdom
    (FirstZeroGapForDzero_of_startsAfter_at_root
