-- =====================================================================
-- ┬ºCCXIX. Kernel replacement adapter
-- =====================================================================
-- The ┬ºCCXVI wrapper kernel
--   `pairedCauchyComplexKernelDeriv u z := (real x y u : Ôäé) * I`
-- is purely imaginary-axis-aligned, which is artificial. The actual
-- analytic complex kernel is rational:
--   `pairedCauchyComplexKernelTrue u z := 1/(z - u)┬▓ - 1/(z + u)┬▓`
-- (the u-derivative of `pairedCauchyKernel = 1/(z - u) + 1/(z + u)`).
-- This section provides an adapter so that any complex kernel sharing
-- the wrapper's imaginary part at UHP inherits the ┬ºCCXVIÔÇô┬ºCCXVIII
-- bridge, and proves that `pairedCauchyComplexKernelTrue` qualifies.
--
-- Adds:
--   ComplexKernelImCompatible                              ÔÇö Prop adapter
--   complexDensityTailPartial_im_eq_of_kernelImCompatible  ÔÇö adapter for partials
--   complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
--   pairedCauchyComplexKernelTrue                          ÔÇö true rational kernel
--   im_inv_sq_complex                                      ÔÇö helper Im of 1/w┬▓
--   pairedCauchyComplexKernelTrue_im                       ÔÇö Im at UHP identity
--   pairedCauchyComplexKernelTrue_imCompatible             ÔÇö adapter witness
--
-- The integral-Im commutation requires integrability hypotheses; we
-- thread them through the adapter theorems.

/-- **`ComplexKernelImCompatible kernelÔéü kernelÔéé`** ÔÇö pointwise
imaginary-part equality on UHP coordinates: the two complex kernels
agree on the imaginary axis where the bridge cares. -/
structure ComplexKernelImCompatible (kernelÔéü kernelÔéé : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé) : Prop where
  im_eq : ÔêÇ (u x y : ÔäØ),
    (kernelÔéü u (upperHalfPoint x y)).im
      = (kernelÔéé u (upperHalfPoint x y)).im

/-- ­ƒîƒ **PROVED ÔÇö Im of complex partial only depends on Im of kernel.**
Given pointwise Im compatibility and interval-integrability of both
integrands, the Im of their complex partials over `[T, X]` agree.
Proof: route through `Complex.imCLM.intervalIntegral_comp_comm`. -/
lemma complexDensityTailPartial_im_eq_of_kernelImCompatible
    {kernelÔéü kernelÔéé : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé}
    (H : ComplexKernelImCompatible kernelÔéü kernelÔéé)
    (S : ÔäØ ÔåÆ ÔäØ) (x y T X : ÔäØ)
    (h_intÔéü : IntervalIntegrable
                (fun u => kernelÔéü u (upperHalfPoint x y) * (S u : Ôäé))
                MeasureTheory.volume T X)
    (h_intÔéé : IntervalIntegrable
                (fun u => kernelÔéé u (upperHalfPoint x y) * (S u : Ôäé))
                MeasureTheory.volume T X) :
    (complexDensityTailPartial kernelÔéü S T X (upperHalfPoint x y)).im
      = (complexDensityTailPartial kernelÔéé S T X (upperHalfPoint x y)).im := by
  unfold complexDensityTailPartial
  -- Convert (Ôê½ ...).im into Complex.imCLM (Ôê½ ...)
  rw [ÔåÉ Complex.imCLM_apply (Ôê½ u in T..X,
        kernelÔéü u (upperHalfPoint x y) * (S u : Ôäé)),
      ÔåÉ Complex.imCLM_apply (Ôê½ u in T..X,
        kernelÔéé u (upperHalfPoint x y) * (S u : Ôäé))]
  -- Pull imCLM inside the integrals
  rw [ÔåÉ Complex.imCLM.intervalIntegral_comp_comm h_intÔéü,
      ÔåÉ Complex.imCLM.intervalIntegral_comp_comm h_intÔéé]
  -- Pointwise: Im of integrands equal under H
  apply intervalIntegral.integral_congr
  intro u _
  show Complex.imCLM (kernelÔéü u (upperHalfPoint x y) * (S u : Ôäé))
     = Complex.imCLM (kernelÔéé u (upperHalfPoint x y) * (S u : Ôäé))
  rw [Complex.imCLM_apply, Complex.imCLM_apply]
  simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im, H.im_eq u x y]

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö finite Im match transfers across kernel-Im-compatible
kernels.** Lets any kernel with the wrapper's UHP-Im profile inherit
`ComplexTailImaginaryPartMatchesRealIBP` (via ┬ºCCXVI's wrapper proof). -/
theorem complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
    {kernel : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé}
    (H : ComplexKernelImCompatible kernel pairedCauchyComplexKernelDeriv)
    (S : ÔäØ ÔåÆ ÔäØ) (x y T : ÔäØ)
    (h_intÔéü : ÔêÇ X, IntervalIntegrable
                (fun u => kernel u (upperHalfPoint x y) * (S u : Ôäé))
                MeasureTheory.volume T X)
    (h_intÔéé : ÔêÇ X, IntervalIntegrable
                (fun u =>
                  pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)
                    * (S u : Ôäé))
                MeasureTheory.volume T X) :
    ComplexTailImaginaryPartMatchesRealIBP kernel S x y T := by
  refine Ôƒ¿?_Ôƒ®
  filter_upwards
    [(complexTailImaginaryPartMatchesRealIBP_pairedDeriv S x y T).finite_im_eq]
    with X hwrap
  rw [complexDensityTailPartial_im_eq_of_kernelImCompatible
        H S x y T X (h_intÔéü X) (h_intÔéé X)]
  exact hwrap

/-- **True complex paired-Cauchy kernel derivative.** The u-derivative
of `pairedCauchyKernel u z = 1/(z - u) + 1/(z + u)`, i.e.
  `K'_u(z) = 1/(z - u)┬▓ - 1/(z + u)┬▓`.
This is the genuine rational complex kernel; the ┬ºCCXVI wrapper was
a synthetic stand-in. -/
noncomputable def pairedCauchyComplexKernelTrue (u : ÔäØ) (z : Ôäé) : Ôäé :=
  1 / (z - (u : Ôäé))^2 - 1 / (z + (u : Ôäé))^2

/-- Ô¡É **PROVED ÔÇö Im of `1/(a + I┬Àb)┬▓`** when `a┬▓ + b┬▓ Ôëá 0`:
  `Im(1/(a + I┬Àb)┬▓) = -2┬Àa┬Àb / (a┬▓ + b┬▓)┬▓`.
Direct algebra via `Complex.inv_im` + `Complex.normSq`. -/
lemma im_inv_sq_complex (a b : ÔäØ) (_h : a^2 + b^2 Ôëá 0) :
    (((a : Ôäé) + Complex.I * (b : Ôäé))^2)Ôü╗┬╣.im
      = -2 * a * b / (a^2 + b^2)^2 := by
  have hsq_re : (((a : Ôäé) + Complex.I * (b : Ôäé))^2).re = a^2 - b^2 := by
    rw [pow_two]
    simp [Complex.mul_re, Complex.mul_im, Complex.add_re, Complex.add_im,
          Complex.I_re, Complex.I_im, Complex.ofReal_re, Complex.ofReal_im]
    ring
  have hsq_im : (((a : Ôäé) + Complex.I * (b : Ôäé))^2).im = 2 * a * b := by
    rw [pow_two]
    simp [Complex.mul_re, Complex.mul_im, Complex.add_re, Complex.add_im,
          Complex.I_re, Complex.I_im, Complex.ofReal_re, Complex.ofReal_im]
    ring
  rw [Complex.inv_im, hsq_im, Complex.normSq_apply, hsq_re, hsq_im]
  have h_denom :
      (a^2 - b^2) * (a^2 - b^2) + 2 * a * b * (2 * a * b) = (a^2 + b^2)^2 := by
    ring
  rw [h_denom]
  ring

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö Im of the true kernel at UHP equals the real
kernel derivative.** -/
lemma pairedCauchyComplexKernelTrue_im (u x y : ÔäØ) (hy : y Ôëá 0) :
    (pairedCauchyComplexKernelTrue u (upperHalfPoint x y)).im
      = pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelTrue
  rw [Complex.sub_im]
  have h1 : upperHalfPoint x y - (u : Ôäé)
            = ((x - u : ÔäØ) : Ôäé) + Complex.I * ((y : ÔäØ) : Ôäé) := by
    unfold upperHalfPoint
    push_cast
    ring
  have h2 : upperHalfPoint x y + (u : Ôäé)
            = ((x + u : ÔäØ) : Ôäé) + Complex.I * ((y : ÔäØ) : Ôäé) := by
    unfold upperHalfPoint
    push_cast
    ring
  rw [show ((1 : Ôäé) / (upperHalfPoint x y - (u : Ôäé))^2)
        = ((upperHalfPoint x y - (u : Ôäé))^2)Ôü╗┬╣ from one_div _]
  rw [show ((1 : Ôäé) / (upperHalfPoint x y + (u : Ôäé))^2)
        = ((upperHalfPoint x y + (u : Ôäé))^2)Ôü╗┬╣ from one_div _]
  rw [h1, h2]
  have hd1 : (x - u)^2 + y^2 Ôëá 0 := by
    have h_pos : 0 < (x - u)^2 + y^2 := by
      have : 0 < y^2 := by positivity
      linarith [sq_nonneg (x - u)]
    exact ne_of_gt h_pos
  have hd2 : (x + u)^2 + y^2 Ôëá 0 := by
    have h_pos : 0 < (x + u)^2 + y^2 := by
      have : 0 < y^2 := by positivity
      linarith [sq_nonneg (x + u)]
    exact ne_of_gt h_pos
  rw [im_inv_sq_complex (x - u) y hd1, im_inv_sq_complex (x + u) y hd2]
  unfold pairedCauchyImKernelDeriv
  ring

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö true kernel is Im-compatible with the wrapper.**
Discharges `ComplexKernelImCompatible` for the rational kernel against
the ┬ºCCXVI wrapper. Both have the same Im profile at every UHP point,
so any wrapper-based bridge result transfers to the true kernel via
the adapter theorems above.

Handles `y = 0` by direct simp (both sides collapse to `0`): the
wrapper Im is `pairedCauchyImKernelDeriv x 0 u = 2┬À0┬À(ÔÇª) = 0`, and the
true kernel is purely real on the real axis. -/
theorem pairedCauchyComplexKernelTrue_imCompatible :
    ComplexKernelImCompatible
      pairedCauchyComplexKernelTrue
      pairedCauchyComplexKernelDeriv := by
  refine Ôƒ¿?_Ôƒ®
  intro u x y
  by_cases hy : y = 0
  ┬À subst hy
    -- Show both .im = 0 independently
    have h_kw :
        (pairedCauchyComplexKernelDeriv u (upperHalfPoint x 0)).im = 0 := by
      unfold pairedCauchyComplexKernelDeriv pairedCauchyImKernelDeriv
      simp [upperHalfPoint]
    have h_kt :
        (pairedCauchyComplexKernelTrue u (upperHalfPoint x 0)).im = 0 := by
      have hUHP : upperHalfPoint x 0 = (x : Ôäé) := by
        unfold upperHalfPoint; simp
      unfold pairedCauchyComplexKernelTrue
      rw [hUHP, Complex.sub_im]
      rw [show ((1 : Ôäé) / ((x : Ôäé) - (u : Ôäé))^2 : Ôäé)
            = (((x : Ôäé) - (u : Ôäé))^2)Ôü╗┬╣ from one_div _]
      rw [show ((1 : Ôäé) / ((x : Ôäé) + (u : Ôäé))^2 : Ôäé)
            = (((x : Ôäé) + (u : Ôäé))^2)Ôü╗┬╣ from one_div _]
      rw [Complex.inv_im, Complex.inv_im]
      have h_sub_im : (((x : Ôäé) - (u : Ôäé))^2).im = 0 := by
        rw [pow_two, Complex.mul_im]; simp
      have h_add_im : (((x : Ôäé) + (u : Ôäé))^2).im = 0 := by
        rw [pow_two, Complex.mul_im]; simp
      rw [h_sub_im, h_add_im]
      ring
    rw [h_kt, h_kw]
  ┬À rw [pairedCauchyComplexKernelTrue_im u x y hy]
    rw [pairedCauchyComplexKernelDeriv_im u x y]

-- =====================================================================
-- ┬ºCCXX. True-kernel integrability + true-kernel bound data
-- =====================================================================
-- The ┬ºCCXIX kernel-replacement adapter requires interval integrability
-- of both kernels' integrands. The wrapper kernel is trivially integrable
-- (its real component is the standard `pairedCauchyImKernelDeriv`); for
-- the true kernel we need to know its denominators don't vanish on the
-- real `u`-axis (true when `y Ôëá 0`) and that the kernel is continuous
-- in `u`.
--
-- Adds:
--   upperHalfPoint_sub_real_ne_zero / _add_real_ne_zero  ÔÇö denominator non-zero
--   continuous_pairedCauchyComplexKernelTrue_u           ÔÇö continuity in u
--   complexTailImaginaryPartMatchesRealIBP_trueKernel    ÔÇö finite Im match for true kernel
--   adaptiveComplexTailIBPBoundData_trueKernel           ÔÇö true-kernel bound data
--
-- Finite-window integrability is kept as an explicit hypothesis: it
-- requires `S` to be regular enough to combine with the bounded
-- continuous kernel on a compact interval. The continuity lemma here
-- is the building block; the actual integrability of `kernel ┬À S`
-- is conjured by the caller from continuity + regularity of `S`.

/-- Ô¡É **PROVED ÔÇö UHP non-vanishing of `z - u`.** For `y Ôëá 0`, the
denominator `upperHalfPoint x y - (u : Ôäé)` is non-zero for every
real `u` (its imaginary part is `y Ôëá 0`). -/
lemma upperHalfPoint_sub_real_ne_zero
    (x y u : ÔäØ) (hy : y Ôëá 0) :
    upperHalfPoint x y - (u : Ôäé) Ôëá 0 := by
  intro h
  have him_eq : (upperHalfPoint x y - (u : Ôäé)).im = 0 := by
    rw [h]; rfl
  have him_val : (upperHalfPoint x y - (u : Ôäé)).im = y := by
    unfold upperHalfPoint
    simp
  rw [him_val] at him_eq
  exact hy him_eq

/-- Ô¡É **PROVED ÔÇö UHP non-vanishing of `z + u`.** -/
lemma upperHalfPoint_add_real_ne_zero
    (x y u : ÔäØ) (hy : y Ôëá 0) :
    upperHalfPoint x y + (u : Ôäé) Ôëá 0 := by
  intro h
  have him_eq : (upperHalfPoint x y + (u : Ôäé)).im = 0 := by
    rw [h]; rfl
  have him_val : (upperHalfPoint x y + (u : Ôäé)).im = y := by
    unfold upperHalfPoint
    simp
  rw [him_val] at him_eq
  exact hy him_eq

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö continuity of the true complex kernel in `u`.**
At fixed `z = upperHalfPoint x y` with `y Ôëá 0`, the map
`u Ôåª pairedCauchyComplexKernelTrue u z` is continuous on `ÔäØ`. The
denominators `(z ┬▒ u)┬▓` never vanish (Im is `y Ôëá 0`), so division is
well-defined and continuous. -/
lemma continuous_pairedCauchyComplexKernelTrue_u
    (x y : ÔäØ) (hy : y Ôëá 0) :
    Continuous fun u : ÔäØ =>
      pairedCauchyComplexKernelTrue u (upperHalfPoint x y) := by
  unfold pairedCauchyComplexKernelTrue
  refine Continuous.sub ?_ ?_
  ┬À apply Continuous.divÔéÇ continuous_const
    ┬À exact (continuous_const.sub Complex.continuous_ofReal).pow 2
    ┬À intro u
      exact pow_ne_zero 2 (upperHalfPoint_sub_real_ne_zero x y u hy)
  ┬À apply Continuous.divÔéÇ continuous_const
    ┬À exact (continuous_const.add Complex.continuous_ofReal).pow 2
    ┬À intro u
      exact pow_ne_zero 2 (upperHalfPoint_add_real_ne_zero x y u hy)

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö finite Im match for the true kernel.** Specializes
┬ºCCXIX's `complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible`
to `pairedCauchyComplexKernelTrue` via
`pairedCauchyComplexKernelTrue_imCompatible`. Requires interval
integrability of both kernel-times-S integrands (carried by the
caller). -/
theorem complexTailImaginaryPartMatchesRealIBP_trueKernel
    (S : ÔäØ ÔåÆ ÔäØ) (x y T : ÔäØ)
    (htrue_int : ÔêÇ X, IntervalIntegrable
                  (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint x y)
                              * (S u : Ôäé))
                  MeasureTheory.volume T X)
    (hwrap_int : ÔêÇ X, IntervalIntegrable
                  (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)
                              * (S u : Ôäé))
                  MeasureTheory.volume T X) :
    ComplexTailImaginaryPartMatchesRealIBP
      pairedCauchyComplexKernelTrue S x y T :=
  complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
    pairedCauchyComplexKernelTrue_imCompatible
    S x y T htrue_int hwrap_int

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö true-kernel adaptive bound data.** Mirrors ┬ºCCXVIII's
`adaptiveComplexTailIBPBoundData_pairedDeriv` but for the true rational
kernel. Threads finite-window integrability through; everything else
delegates to the ┬ºCCXIX kernel-compatibility transfer + ┬ºCCXVII
real-IBP data. -/
theorem adaptiveComplexTailIBPBoundData_trueKernel
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (conv : AdaptiveComplexDensityTailFamilyConverges
              pairedCauchyComplexKernelTrue S)
    (error : Ôäé ÔåÆ Ôäé)
    (herror :
      ÔêÇ {z : Ôäé} {T : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        (error z).im = (conv.tail T z).im)
    (htrue_int :
      ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u z * (S u : Ôäé))
          MeasureTheory.volume T X)
    (hwrap_int :
      ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u z * (S u : Ôäé))
          MeasureTheory.volume T X) :
    AdaptiveComplexTailIBPBoundData
      pairedCauchyComplexKernelTrue S conv error where
  error_im_eq_tail_im := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime
  finite_im_match := by
    intro z T h10 h140 hy hregime
    have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
    have htrue_int_uhp :
        ÔêÇ X, IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                      * (S u : Ôäé))
          MeasureTheory.volume T X := by
      intro X
      rw [hz]
      exact htrue_int h10 h140 hy hregime
    have hwrap_int_uhp :
        ÔêÇ X, IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                      * (S u : Ôäé))
          MeasureTheory.volume T X := by
      intro X
      rw [hz]
      exact hwrap_int h10 h140 hy hregime
    exact complexTailImaginaryPartMatchesRealIBP_trueKernel
      S z.re z.im T htrue_int_uhp hwrap_int_uhp
  derivative_tendsto := by
    intro z T h10 h140 hy hregime
    exact R.deriv_tendsto h10 h140 hy hregime
  derivative_bound := by
    intro z T J h10 h140 hy hregime hJ
    exact R.deriv_bound h10 h140 hy hregime hJ

