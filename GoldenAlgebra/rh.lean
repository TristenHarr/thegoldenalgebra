/-- Ô¡É **PROVED ÔÇö Helper: `simpleCloudSum` monotone under list append.** -/
lemma simpleCloudSum_append_ge_left
    (zs extra : List ÔäØ) {x y : ÔäØ} (hy : 0 < y) :
    simpleCloudSum zs x y Ôëñ simpleCloudSum (zs ++ extra) x y := by
  unfold simpleCloudSum
  rw [List.map_append, List.sum_append]
  have hnonneg :
      0 Ôëñ (extra.map (fun ╬│ => 2 * y / (x^2 + ╬│^2 + y^2))).sum := by
    apply List.sum_nonneg
    intro a ha
    simp only [List.mem_map] at ha
    rcases ha with Ôƒ¿╬│, _, rflÔƒ®
    have hnum : (0 : ÔäØ) Ôëñ 2 * y := by linarith
    have hdenpos : 0 < x^2 + ╬│^2 + y^2 := by positivity
    exact div_nonneg hnum (le_of_lt hdenpos)
  linarith

/-- Ô¡É **PROVED ÔÇö Helper: `cloudK_T` monotone under list append.** -/
