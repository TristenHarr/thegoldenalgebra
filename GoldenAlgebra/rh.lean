    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 ╬│ : ÔäØ) : Prop where
  fluct_eq_neg_N0 :
    ÔêÇ u : ÔäØ, 2 * Real.pi Ôëñ u ÔåÆ u Ôëñ ╬│ ÔåÆ
      Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
