/-- **Trivial massive-margin model.** `вИТIm(trivialModel100 T z) = 100¬Јz.im`,
easily dominating any `closedFormSErrorBoundCD` on `[10, 140]`. -/
noncomputable def trivialModel100 : вДЭ вЖТ вДВ вЖТ вДВ :=
  fun _T z => -Complex.I * ((100 : вДЭ) * z.im : вДВ)

/-- в≠Р **PROVED вАФ `вИТIm(trivialModel100 T z) = 100¬Јz.im`.** -/
theorem trivialModel100_neg_im (T : вДЭ) (z : вДВ) :
    -(trivialModel100 T z).im = 100 * z.im := by
  unfold trivialModel100
  simp [Complex.mul_im, Complex.neg_im, Complex.I_re, Complex.I_im,
        Complex.ofReal_re, Complex.ofReal_im]

/-- в≠Р **PROVED вАФ `log T вЙ§ 5` for `T вЙ§ 140`** via `2.71вБµ вЙ• 140`. -/
theorem log_T_le_5_of_le_140 {T : вДЭ} (hT_pos : 0 < T) (hT : T вЙ§ 140) :
    Real.log T вЙ§ 5 := by
  have h_e_gt : 2.71 < Real.exp 1 := lt_trans (by norm_num) Real.exp_one_gt_d9
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_e_nn : 0 вЙ§ Real.exp 1 := le_of_lt h_e_pos
  have h_exp5_eq :
      Real.exp 5 = Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (5 : вДЭ) = 1 + 1 + 1 + 1 + 1 from by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add]
  have h_271_nn : (0 : вДЭ) вЙ§ 2.71 := by norm_num
  have h_e_ge : (2.71 : вДЭ) вЙ§ Real.exp 1 := le_of_lt h_e_gt
  have h_e_sq_ge : (2.71 : вДЭ) * 2.71 вЙ§ Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_ge h_e_ge h_271_nn h_e_nn
  have h_e_cube_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_sq_ge h_e_ge h_271_nn (by positivity)
  have h_e_q_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 * 2.71
        вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_cube_ge h_e_ge h_271_nn (by positivity)
  have h_e_5_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 * 2.71 * 2.71
        вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_q_ge h_e_ge h_271_nn (by positivity)
  have h_140_le_271_5 :
      (140 : вДЭ) вЙ§ 2.71 * 2.71 * 2.71 * 2.71 * 2.71 := by norm_num
  have h_T_le_exp5 : T вЙ§ Real.exp 5 := by
    rw [h_exp5_eq]; linarith
  have h := Real.log_le_log hT_pos h_T_le_exp5
  rwa [Real.log_exp] at h

/-- в≠Р **PROVED вАФ closed-form expansion.**
`closedFormSErrorBoundCD C D y T = (y/T¬≤)¬Ј(17¬ЈC¬Јlog T + 17¬ЈD + 9¬ЈC/2)`. -/
theorem closedFormSErrorBoundCD_expand
    (C D y T : вДЭ) (hT : T вЙ† 0) :
    closedFormSErrorBoundCD C D y T
      = (y / T^2) * (17 * C * Real.log T + 17 * D + 9 * C / 2) := by
  unfold closedFormSErrorBoundCD
  have hT2 : T^2 вЙ† 0 := pow_ne_zero 2 hT
  field_simp
  ring

/-- в≠Р **PROVED вАФ `closedFormSErrorBoundCD C D y T вЙ§ y` on the band**
for `(C, D) вИИ [0, 1/2] √Ч [0, 49/20]` and `T вИИ [10, 140]`. -/
theorem closedFormSErrorBoundCD_le_y_on_band
    {C D y T : вДЭ}
    (hC_nn : 0 вЙ§ C) (hC_le : C вЙ§ 1/2)
    (hD_nn : 0 вЙ§ D) (hD_le : D вЙ§ 49/20)
    (hy_nn : 0 вЙ§ y)
    (hT_ge : 10 вЙ§ T) (hT_le : T вЙ§ 140) :
    closedFormSErrorBoundCD C D y T вЙ§ y := by
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT_sq_pos : 0 < T^2 := by positivity
  have hT_sq_ge : (100 : вДЭ) вЙ§ T^2 := by nlinarith
  have hlogT_le : Real.log T вЙ§ 5 := log_T_le_5_of_le_140 hT_pos hT_le
  have h_log_T_nn : 0 вЙ§ Real.log T := by
    have h := Real.log_le_log (by norm_num : (0:вДЭ) < 10) hT_ge
    have h_log10_nn : (0 : вДЭ) вЙ§ Real.log 10 := Real.log_nonneg (by norm_num)
    linarith
  rw [closedFormSErrorBoundCD_expand C D y T hT_ne]
  -- Coefficient вЙ§ 17¬Ј(1/2)¬Ј5 + 17¬Ј(49/20) + 9¬Ј(1/2)/2 = 86.4
  have h_clog_le : C * Real.log T вЙ§ (1/2) * 5 :=
    mul_le_mul hC_le hlogT_le h_log_T_nn (by norm_num : (0:вДЭ) вЙ§ 1/2)
  have h_coeff_le : 17 * C * Real.log T + 17 * D + 9 * C / 2 вЙ§ 86.4 := by
    nlinarith [h_clog_le, hD_le, hC_le]
  have h_clog_nn : 0 вЙ§ C * Real.log T := mul_nonneg hC_nn h_log_T_nn
  have h_coeff_nn : 0 вЙ§ 17 * C * Real.log T + 17 * D + 9 * C / 2 := by
    nlinarith [h_clog_nn, hD_nn, hC_nn]
  have h_y_T2_nn : 0 вЙ§ y / T^2 := div_nonneg hy_nn (le_of_lt hT_sq_pos)
  -- (y/T¬≤)¬Ј(coeff) вЙ§ (y/T¬≤)¬Ј86.4 вЙ§ y¬Ј86.4/100 вЙ§ y
  have h_step : (y / T^2) * (17 * C * Real.log T + 17 * D + 9 * C / 2)
              вЙ§ (y / T^2) * 86.4 :=
    mul_le_mul_of_nonneg_left h_coeff_le h_y_T2_nn
  have h_yT2_le : (y / T^2) * 86.4 вЙ§ y := by
    rw [div_mul_eq_mul_div, div_le_iffвВА hT_sq_pos]
    nlinarith
  linarith

/-- в≠Р **PROVED вАФ generic slab cert via the trivial model.** -/
theorem slab_cert_trivial_generic
    {C D : вДЭ}
    (hC_nn : 0 вЙ§ C) (hC_le : C вЙ§ 1/2)
    (hD_nn : 0 вЙ§ D) (hD_le : D вЙ§ 49/20)
    {Tmin Tmax : вДЭ}
    (hTmin_ge : 10 вЙ§ Tmin) (hTmax_le : Tmax вЙ§ 140) :
    вИА z : вДВ, вИА T : вДЭ,
