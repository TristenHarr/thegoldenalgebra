    have h_eq : ((3 : Ôäò) : ÔäØ) * (5 / 3 : ÔäØ) = 5 := by norm_num
    rw [h_eq] at h; exact h.symm
  have h_exp_5_3_le : Real.exp (5 / 3 : ÔäØ) Ôëñ 11 / 2 := by
    have h_pow : (Real.exp (5 / 3 : ÔäØ))^3 Ôëñ (11 / 2 : ÔäØ)^3 := by
