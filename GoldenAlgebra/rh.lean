/-! ### W1тАУW5: analytic readiness for `╬╢'/╬╢` on the contour -/

/-- **W1.** `zetaLogDeriv` is continuous at every point where ╬╢ is
analytic and nonzero.  Uses `AnalyticAt.deriv` (analyticity of `╬╢`
implies analyticity of `deriv ╬╢`), `AnalyticAt.continuousAt`, and
`ContinuousAt.div`. -/
theorem continuousAt_zetaLogDeriv
    {z : тДВ}
    (hz_ne_one : z тЙа 1)
    (hz_ne_zero : riemannZeta z тЙа 0) :
    ContinuousAt zetaLogDeriv z := by
  unfold zetaLogDeriv
  have hAn : AnalyticAt тДВ riemannZeta z :=
    riemannZeta_analyticAt_of_ne_one hz_ne_one
  have hDerivCont : ContinuousAt (deriv riemannZeta) z :=
    hAn.deriv.continuousAt
  exact hDerivCont.div hAn.continuousAt hz_ne_zero

/-- **W2.** `t тЖж zetaLogDeriv (╬│ t)` is continuous on `[0, 1]` given
edge-readiness. -/
theorem continuousOn_logDeriv_comp_edge
    {╬│ : тДЭ тЖТ тДВ}
    (h╬│ : EdgeLogDerivReady ╬│) :
    ContinuousOn (fun t : тДЭ => zetaLogDeriv (╬│ t)) (Set.Icc 0 1) := by
  intro t ht
  have ht0 : 0 тЙд t := ht.1
  have ht1 : t тЙд 1 := ht.2
  have hcont :=
    continuousAt_zetaLogDeriv
      (h╬│.avoids_pole t ht0 ht1) (h╬│.zeta_ne_zero t ht0 ht1)
  exact hcont.comp_continuousWithinAt
    h╬│.continuous_edge.continuousAt.continuousWithinAt

/-- **W3.** The full log-derivative integrand is interval-integrable on
`[0, 1]` given edge-readiness plus continuity of the edge derivative. -/
theorem intervalIntegrable_logDerivIntegrand_of_edgeReady
    {╬│ : тДЭ тЖТ тДВ}
    (h╬│ : EdgeLogDerivReady ╬│)
    (h╬│_deriv : ContinuousOn (fun t : тДЭ => deriv ╬│ t) (Set.Icc 0 1)) :
    IntervalIntegrable
      (fun t : тДЭ => zetaLogDeriv (╬│ t) * deriv ╬│ t)
      MeasureTheory.volume 0 1 := by
  have h1 := continuousOn_logDeriv_comp_edge h╬│
  have hmul :
      ContinuousOn (fun t : тДЭ => zetaLogDeriv (╬│ t) * deriv ╬│ t)
        (Set.Icc 0 1) := h1.mul h╬│_deriv
  exact hmul.intervalIntegrable_of_Icc (by norm_num : (0 : тДЭ) тЙд 1)

/-- **W4.** Package for continuity of the four rectangle edge
derivatives on `[0, 1]`.  Affine edges have constant derivatives so
this is straightforward, but we package it separately to defer the
