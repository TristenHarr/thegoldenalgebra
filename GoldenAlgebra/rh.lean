      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (Htail : StieltjesTailContributionData Dzero 10 Hsrc.zeroContribution)
    (Hlow : StieltjesLowContributionData Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesFormula
    Dzero h_Z_ge_15 hTuring hHighLog Hsrc
    (ZeroContributionStieltjesFormula_of_tail_low_data Htail Hlow)

-- =====================================================================
-- §CCCX. Regional tail Stieltjes data + bridge bypassing global form
-- =====================================================================
-- `StieltjesTailContributionData` and `XiModelTailExplicitFormula` are
-- region-agnostic — they quantify over ALL `T` with `regime`, including
-- small `T` where convergence may require non-existent log envelopes.
-- The actual consumers only need mid (`T = canonicalAdaptiveT z` with
-- `10 ≤ T ≤ 140`) and high (`T ≥ 140`).
--
-- This section adds the regional Props (`XiMidHighTailExplicitFormula`,
-- `StieltjesMidHighTailContributionData`), bridges them through to the
-- corrected-split front door, and separates equality from convergence
-- so the Stieltjes equality theorem doesn't have to re-prove convergence
-- already covered by `trueKernelComplexTail_converges_at_of_logEnvelope`.

/-- 📦 **`XiMidHighTailExplicitFormula`** — regional analogue of
`XiModelTailExplicitFormula`. Covers mid (at `canonicalAdaptiveT z`)
and high (`T ≥ 140`) only — matches actual use cases. -/
structure XiMidHighTailExplicitFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  mid_formula :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L ∧
        logDerivativeResponse XiPullback z = M.model z + L
  high_formula :
    ∀ {z : ℂ} {T : ℝ},
      140 ≤ T →
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 T z L ∧
        logDerivativeResponse XiPullback z = M.model z + L

/-- 🌟🌟🌟 **PROVED — bridge from regional formula to
`XiLogDerivativeModelTailDecomposition`.** Direct unpacking of the
mid/high fields. Bypasses the over-strong global
`XiModelTailExplicitFormula`. -/
theorem XiLogDerivativeModelTailDecomposition_of_midHighTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiMidHighTailExplicitFormula Dzero T0 M) :
    XiLogDerivativeModelTailDecomposition Dzero T0 M := by
  refine ⟨?_, ?_⟩
  · intro z T hT hy hr
    obtain ⟨L, hL, hd⟩ := H.high_formula hT hy hr
    exact ⟨L, hL.tendsto_tail, hd⟩
  · intro z hy hm
    obtain ⟨L, hL, hd⟩ := H.mid_formula hy hm
    exact ⟨L, hL.tendsto_tail, hd⟩

/-- 📦 **`StieltjesMidHighTailContributionData`** — regional Stieltjes
identification of the zero contribution. Mid uses `canonicalAdaptiveT z`,
high uses any `T ≥ 140`. -/
structure StieltjesMidHighTailContributionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  mid_tail :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L ∧
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L
  high_tail :
    ∀ {z : ℂ} {T : ℝ},
      140 ≤ T →
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 T z L ∧
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L

/-- 🌟🌟🌟 **PROVED — `XiMidHighTailExplicitFormula` from Hadamard
source + regional Stieltjes data** (at the honest twoPi model). -/
theorem XiMidHighTailExplicitFormula_of_hadamardSource_and_midHighTailData
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    (Hsrc : XiHadamardLogDerivativeSource)
    (Htail :
      StieltjesMidHighTailContributionData
        Dzero T0 Hsrc.zeroContribution) :
    XiMidHighTailExplicitFormula
      Dzero T0 honestZeroDensityModelTwoPi := by
  refine ⟨?_, ?_⟩
  · intro z hy hm
    obtain ⟨L, hL, hZ⟩ := Htail.mid_tail hy hm
    refine ⟨L, hL, ?_⟩
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]
  · intro z T hT hy hr
    obtain ⟨L, hL, hZ⟩ := Htail.high_tail hT hy hr
    refine ⟨L, hL, ?_⟩
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]

/-- 📦 **`StieltjesMidHighTailEquality`** — Stieltjes equality only,
given a converged `L`. Separates the equality content from the
convergence content (which comes from log envelopes / Turing). -/
structure StieltjesMidHighTailEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  mid_eq :
    ∀ {z : ℂ} {L : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L →
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L
  high_eq :
    ∀ {z : ℂ} {T : ℝ} {L : ℂ},
      140 ≤ T →
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      XiFluctuationTailValue Dzero T0 T z L →
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- 🌟🌟🌟 **PROVED — `StieltjesMidHighTailContributionData` from
convergence + equality.** Convergence supplies `L`; equality provides
the Stieltjes identification.

The convergence hypothesis `Hconv_mid` / `Hconv_high` is exactly what
the existing `trueKernelComplexTail_converges_at_of_logEnvelope` machinery
discharges from `hTuring` / `hHighLog` log envelopes. -/
theorem StieltjesMidHighTailContributionData_of_convergence_and_equality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ} {ZC : ℂ → ℂ}
    (Hconv_mid :
      ∀ {z : ℂ},
        0 < z.im →
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        ∃ L : ℂ, XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L)
    (Hconv_high :
      ∀ {z : ℂ} {T : ℝ},
        140 ≤ T →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        ∃ L : ℂ, XiFluctuationTailValue Dzero T0 T z L)
    (Heq : StieltjesMidHighTailEquality Dzero T0 ZC) :
    StieltjesMidHighTailContributionData Dzero T0 ZC := by
  refine ⟨?_, ?_⟩
  · intro z hy hm
    obtain ⟨L, hL⟩ := Hconv_mid hy hm
    exact ⟨L, hL, Heq.mid_eq hy hm hL⟩
  · intro z T hT hy hr
    obtain ⟨L, hL⟩ := Hconv_high hT hy hr
    exact ⟨L, hL, Heq.high_eq hT hy hr hL⟩

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
FINAL FRONT DOOR (regional mid/high tail + low)**.

Replaces the over-strong global `StieltjesTailContributionData` with
the regionally-correct `StieltjesMidHighTailContributionData`. The
Stieltjes theorem now matches the actual analytic use cases — mid at
canonical T, high at any T ≥ 140 — without quantifying over irrelevant
small T.

```
hTuring + hHighLog                                      (parallel agent)
+ Hsrc       : XiHadamardLogDerivativeSource             (A)
+ HtailMidHi : StieltjesMidHighTailContributionData ... ZC   (B1 regional)
+ Hlow       : StieltjesLowContributionData ... ZC       (B2)
+ h_Z_ge_15                                              (trivial)
⟹ XiPullbackAntiHerglotzTarget
```

The mid/high Stieltjes target is now matched to actual regimes. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesMidHighTailLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (HtailMidHi :
      StieltjesMidHighTailContributionData
        Dzero 10 Hsrc.zeroContribution)
    (Hlow :
      StieltjesLowContributionData
        Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget := by
  have Htail_fmla :
      XiMidHighTailExplicitFormula
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiMidHighTailExplicitFormula_of_hadamardSource_and_midHighTailData
      Hsrc HtailMidHi
  have Htail_decomp :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiLogDerivativeModelTailDecomposition_of_midHighTailFormula Htail_fmla
  have HlowA :
      XiLowResidualImEqBoundaryAddIntegralIm
        Dzero 10 honestZeroDensityModelTwoPi := by
    refine ⟨?_⟩
    intro z hz
    have hy : 0 < z.im := hz.1
    have h_resid :
        (xiResidualError honestZeroDensityModelTwoPi z).im
          = (Hsrc.zeroContribution z
              - honestZeroDensityModelTwoPi.model z).im := by
      unfold xiResidualError
      rw [Hsrc.logDeriv_eq_zeroContribution z hy]
    rw [h_resid, honestZeroDensityModelTwoPi_model_eq z]
    exact Hlow.low_value z hz
  exact XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowCorrectedSplit
    Dzero h_Z_ge_15 hTuring hHighLog Htail_decomp HlowA

-- =====================================================================
-- §CCCXI. B1-conv: tail convergence from log envelopes
-- =====================================================================
-- Discharges the convergence half of `StieltjesMidHighTailContributionData`
-- using existing `trueKernelComplexTail_converges_at_of_logEnvelope`
-- + `hTuring` / `hHighLog`. After this, B1's only remaining content is
-- `StieltjesMidHighTailEquality`.

/-- 🌟🌟🌟 **PROVED — mid convergence at canonical T from `hTuring`.**
For every `z` in the adaptive region, `XiFluctuationTailValue` exists at
`canonicalAdaptiveT z`. Convergence is supplied by the log-envelope
machinery applied to the Turing bound at the canonical T. -/
theorem XiFluctuationTailValue_exists_mid_of_turing
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2) :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L := by
  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  have h10 : 10 ≤ canonicalAdaptiveT z := hc.1
  have h140 : canonicalAdaptiveT z ≤ 140 := hc.2.1
  have hregime : 2 * (1 + |z.re| + z.im) ≤ canonicalAdaptiveT z := hc.2.2
  have hT0leT : T0 ≤ canonicalAdaptiveT z := by linarith
  have hTpos : 0 < canonicalAdaptiveT z := by linarith
  have hEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD (canonicalAdaptiveT z)).1 * Real.log u
              + (slabCD (canonicalAdaptiveT z)).2 := by
    filter_upwards [Filter.eventually_ge_atTop (canonicalAdaptiveT z)] with u hu
    exact hTuring h10 h140 hy hregime hu
  obtain ⟨L, hL⟩ :=
    trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0leT hTpos hy hEnv
  exact ⟨L, ⟨hL⟩⟩

/-- 🌟🌟🌟 **PROVED — high convergence at any `T ≥ 140` from `hHighLog`.**
For every `z` with `0 < z.im` and any `T ≥ 140` in the regime,
`XiFluctuationTailValue` exists at `T`. -/
theorem XiFluctuationTailValue_exists_high_of_highLog
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ)) :
    ∀ {z : ℂ} {T : ℝ},
      140 ≤ T →
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 T z L := by
  intro z T hT140 hy hregime
  have hT0leT : T0 ≤ T := by linarith
  have hTpos : 0 < T := by linarith
  have hEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  obtain ⟨L, hL⟩ :=
    trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0leT hTpos hy hEnv
  exact ⟨L, ⟨hL⟩⟩

/-- 🌟🌟🌟 **PROVED — `StieltjesMidHighTailContributionData` from
Turing + highLog + equality.** Composes the two convergence theorems
(mid, high) with `StieltjesMidHighTailEquality` via the
`_of_convergence_and_equality` constructor. -/
theorem StieltjesMidHighTailContributionData_of_turing_highLog_and_equality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    {ZC : ℂ → ℂ}
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Heq : StieltjesMidHighTailEquality Dzero T0 ZC) :
    StieltjesMidHighTailContributionData Dzero T0 ZC := by
  have hT0_le_140 : T0 ≤ 140 := by linarith
  exact
    StieltjesMidHighTailContributionData_of_convergence_and_equality
      (XiFluctuationTailValue_exists_mid_of_turing
        Dzero T0 hT0_pos hT0_le_10 hTuring)
      (XiFluctuationTailValue_exists_high_of_highLog
        Dzero T0 hT0_pos hT0_le_140 hHighLog)
      Heq

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
FINAL FRONT DOOR (equality-only B1)**.

B1's convergence is now internalized — only the equality content
`StieltjesMidHighTailEquality` is required. This is exactly the
Stieltjes core mathematics.

```
hTuring + hHighLog                                 (parallel agent — envelopes)
+ Hsrc     : XiHadamardLogDerivativeSource          (A: Hadamard log-deriv)
+ HtailEq  : StieltjesMidHighTailEquality ... ZC    (B1-eq: Stieltjes equality)
+ Hlow     : StieltjesLowContributionData ... ZC    (B2: low Stieltjes)
+ h_Z_ge_15                                          (trivial)
⊢ XiPullbackAntiHerglotzTarget
```

The remaining xi-side analytic content is now three theorems:
* `XiHadamardLogDerivativeSource` (Hadamard product log-deriv)
* `StieltjesMidHighTailEquality` (Stieltjes equality, given convergence)
* `StieltjesLowContributionData` (low finite Stieltjes split) -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesMidHighEqLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (HtailEq :
      StieltjesMidHighTailEquality
        Dzero 10 Hsrc.zeroContribution)
    (Hlow :
      StieltjesLowContributionData
        Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesMidHighTailLow
    Dzero h_Z_ge_15 hTuring hHighLog Hsrc
    (StieltjesMidHighTailContributionData_of_turing_highLog_and_equality
      Dzero 10 (by norm_num : (0 : ℝ) < 10) (by norm_num : (10 : ℝ) ≤ 10)
      hTuring hHighLog HtailEq)
    Hlow

-- =====================================================================
-- §CCCXII. B2 low Stieltjes decomposition
-- =====================================================================
-- Audit findings:
--   * `FirstZeroGapForDzero` (line 40124) gives `S = -N₀` on `[2π, γ]`
--     — too specific (requires T0 root condition).
--   * `finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter` gives the
--     general `S(T0, u) = N₀(T0) − N₀(u)` for any `T0 ≤ u ≤ γ` under
--     `DzeroStartsAfter Dzero γ`. This is what B2 actually needs at T0 = 10.
--
-- Adds the low-side Stieltjes equality decomposition mirroring the
-- high/mid track: the analytic content of B2 is isolated as
-- `LowFiniteStieltjesFormulaOnFirstZeroGap`.

/-- **Low finite fluctuation contribution** — the RHS of B2 as a single
real-valued object. -/
noncomputable def lowFiniteFluctuationContribution
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (z : ℂ) : ℝ :=
  lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
    + (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        11 14 z).im

/-- ⭐ **PROVED — `StieltjesLowContributionData` iff Im equality with
the named contribution.** Compact target for the analytic equality. -/
theorem StieltjesLowContributionData_iff_lowFiniteContribution
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ} {ZC : ℂ → ℂ} :
    StieltjesLowContributionData Dzero T0 ZC ↔
      ∀ z, lowCompactRegion z →
        (ZC z - (cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
          = lowFiniteFluctuationContribution Dzero T0 z := by
  constructor
  · intro H z hz
    simpa [lowFiniteFluctuationContribution] using H.low_value z hz
  · intro H
    refine ⟨?_⟩
    intro z hz
    simpa [lowFiniteFluctuationContribution] using H z hz

/-- 📦 **`LowZeroContributionImaginarySplit`** — Stieltjes-side
imaginary-part identification on `lowCompactRegion`, using the named
`lowFiniteFluctuationContribution`. Equivalent to
`StieltjesLowContributionData`. -/
structure LowZeroContributionImaginarySplit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  im_split :
    ∀ z : ℂ,
      lowCompactRegion z →
      (ZC z - (cloudModel zeros100ceil z
        + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
