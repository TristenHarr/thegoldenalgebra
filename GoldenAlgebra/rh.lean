  unfold unitPrincipalKernel
  have h_id : AnalyticAt Ôäé (fun w : Ôäé => w) z := analyticAt_id
  have h_const_a : AnalyticAt Ôäé (fun _ : Ôäé => a) z := analyticAt_const
  have h_den : AnalyticAt Ôäé (fun w : Ôäé => w - a) z := h_id.sub h_const_a
  have h_num : AnalyticAt Ôäé (fun _ : Ôäé => (1 : Ôäé)) z := analyticAt_const
  exact h_num.div h_den (sub_ne_zero.mpr hz)

