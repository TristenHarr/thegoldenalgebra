/-- в≠Р **PROVED вАФ sharper cloud lower bound using combined `x¬≤ + y¬≤` cap.**
For any `M вЙ• 0` with `x¬≤ + y¬≤ вЙ§ M¬≤` and `y > 0`:
  `simpleCloudSum zeros x y вЙ• 2y ¬Ј ќ£ 1/(M¬≤ + ќ≥¬≤)`.
Tighter than the per-axis `simpleCloudSum_ge_const_bound` (which uses
`x_max¬≤ + y_max¬≤`, loose when worst-case `(x_max, y_max)` is impossible). -/
theorem simpleCloudSum_ge_T_box_bound
    (zeros : List вДЭ) (x y M : вДЭ)
    (h_sq : x^2 + y^2 вЙ§ M^2) (hy : 0 < y) :
    2 * y * (zeros.map fun g => 1 / (M^2 + g^2)).sum
      вЙ§ simpleCloudSum zeros x y := by
  unfold simpleCloudSum
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_den_pos : 0 < x^2 + g^2 + y^2 := by positivity
    have h_den_le : x^2 + g^2 + y^2 вЙ§ M^2 + g^2 := by linarith [sq_nonneg g]
    have h_term : 1 / (M^2 + g^2) вЙ§ 1 / (x^2 + g^2 + y^2) :=
      one_div_le_one_div_of_le h_den_pos h_den_le
    have hy_nn : (0 : вДЭ) вЙ§ 2 * y := by linarith
    have h_term_mul : 2 * y * (1 / (M^2 + g^2))
                    вЙ§ 2 * y * (1 / (x^2 + g^2 + y^2)) :=
      mul_le_mul_of_nonneg_left h_term hy_nn
    have h_two_y_div :
        2 * y * (1 / (x^2 + g^2 + y^2)) = 2 * y / (x^2 + g^2 + y^2) := by
      field_simp
    have h_two_y_div_max :
        2 * y * (1 / (M^2 + g^2)) = 2 * y / (M^2 + g^2) := by field_simp
    have h_distrib :
        2 * y * (1 / (M^2 + g^2)
            + (List.map (fun g => 1 / (M^2 + g^2)) rest).sum)
          = 2 * y * (1 / (M^2 + g^2))
            + 2 * y * (List.map (fun g => 1 / (M^2 + g^2)) rest).sum := by
      ring
    rw [h_distrib]
    linarith [h_term_mul, h_two_y_div, h_two_y_div_max, ih]

/-- в≠Р **PROVED вАФ `log T вЙ§ log TвВА + (T - TвВА)/TвВА`** for `T, TвВА > 0`.
Concavity of log; tangent at `TвВА` is an upper bound. -/
theorem Real.log_le_tangent {T TвВА : вДЭ} (hT : 0 < T) (hTвВА : 0 < TвВА) :
    Real.log T вЙ§ Real.log TвВА + (T - TвВА) / TвВА := by
  -- From `log (T/TвВА) вЙ§ T/TвВА - 1`: log T - log TвВА вЙ§ (T - TвВА)/TвВА
  have h_ratio_pos : 0 < T / TвВА := div_pos hT hTвВА
  have h := Real.log_le_sub_one_of_pos h_ratio_pos
  -- h : log (T/TвВА) вЙ§ T/TвВА - 1
  rw [Real.log_div (ne_of_gt hT) (ne_of_gt hTвВА)] at h
  -- h : log T - log TвВА вЙ§ T/TвВА - 1 = (T - TвВА)/TвВА
  have h_simp : (T - TвВА) / TвВА = T / TвВА - 1 := by
    field_simp
  linarith [h, h_simp]

/-- в≠Р **PROVED вАФ secant lower bound for `Real.log`** on `[ќ±, ќ≤] вКЖ (0, вИЮ)`. -/
theorem Real.secant_le_log
    {ќ± ќ≤ T : вДЭ} (hќ± : 0 < ќ±) (hќ±ќ≤ : ќ± < ќ≤) (hќ±T : ќ± вЙ§ T) (hTќ≤ : T вЙ§ ќ≤) :
    ((ќ≤ - T) / (ќ≤ - ќ±)) * Real.log ќ± + ((T - ќ±) / (ќ≤ - ќ±)) * Real.log ќ≤
      вЙ§ Real.log T := by
  have hќ≤ : 0 < ќ≤ := lt_trans hќ± hќ±ќ≤
  have hќ≤ќ± : 0 < ќ≤ - ќ± := by linarith
  set a := (ќ≤ - T) / (ќ≤ - ќ±) with ha_def
  set b := (T - ќ±) / (ќ≤ - ќ±) with hb_def
  have ha_nn : 0 вЙ§ a := div_nonneg (by linarith) (le_of_lt hќ≤ќ±)
  have hb_nn : 0 вЙ§ b := div_nonneg (by linarith) (le_of_lt hќ≤ќ±)
  have hab : a + b = 1 := by
    unfold a b
    rw [div_add_div_same]
    field_simp
  have h_avg : a * ќ± + b * ќ≤ = T := by
    unfold a b
    field_simp
    ring
  have hќ±_mem : ќ± вИИ Set.Ioi (0 : вДЭ) := hќ±
  have hќ≤_mem : ќ≤ вИИ Set.Ioi (0 : вДЭ) := hќ≤
  have h_concave := strictConcaveOn_log_Ioi.concaveOn.2 hќ±_mem hќ≤_mem ha_nn hb_nn hab
  simp only [smul_eq_mul] at h_concave
  rw [h_avg] at h_concave
  exact h_concave

