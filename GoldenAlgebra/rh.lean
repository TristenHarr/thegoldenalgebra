/-- **CW17 тАФ local finiteness тЗТ right gap in the strip.**  Take the
minimum positive distance from `T` to any zero height in the finite
window; halve it (and cap at `1`) to produce an open right gap. -/
noncomputable def
    ZetaZerosLocallyFiniteInBacklundStripInput.toRightGapInStrip
    (F : ZetaZerosLocallyFiniteInBacklundStripInput) :
    ZetaZeroHeightRightGapInBacklundStripInput where
  exists_gap := by
    classical
    intro T hT
    set S : Set тДВ :=
      {╧Б : тДВ | riemannZeta ╧Б = 0 тИз (-1 : тДЭ) тЙд ╧Б.re тИз ╧Б.re тЙд 2 тИз
        T < ╧Б.im тИз ╧Б.im тЙд T + 1} with hS_def
    have hfin : S.Finite := F.finite_window T hT
    by_cases hS_ne : S.Nonempty
    ┬╖ set gaps : Finset тДЭ :=
        hfin.toFinset.image (fun ╧Б : тДВ => ╧Б.im - T) with hgaps_def
      have hgaps_ne : gaps.Nonempty := by
        rcases hS_ne with тЯи╧Б, h╧БтЯй
        refine тЯи╧Б.im - T, ?_тЯй
        exact Finset.mem_image.mpr тЯи╧Б, hfin.mem_toFinset.mpr h╧Б, rflтЯй
      set ╬┤ : тДЭ := gaps.min' hgaps_ne with h╬┤_def
      have h╬┤_pos : 0 < ╬┤ := by
        have hmem : ╬┤ тИИ gaps := gaps.min'_mem hgaps_ne
        rcases Finset.mem_image.mp hmem with тЯи╧Б, h╧Бmem, h╧БeqтЯй
        have h╧БS : ╧Б тИИ S := hfin.mem_toFinset.mp h╧Бmem
        have hT_lt : T < ╧Б.im := h╧БS.2.2.2.1
        linarith [h╧Бeq]
      refine тЯиmin ╬┤ 1 / 2, by positivity, ?_тЯй
      intro ╧Б hzero hre1 hre2 him him_upper
      have h╬╡_le_╬┤half : min ╬┤ 1 / 2 тЙд ╬┤ / 2 := by
        have hm : min ╬┤ 1 тЙд ╬┤ := min_le_left _ _
        linarith
      have h╬╡_le_one : min ╬┤ 1 / 2 тЙд 1 := by
        have hm : min ╬┤ 1 тЙд 1 := min_le_right _ _
        linarith
      have him_le_one : ╧Б.im тЙд T + 1 := by linarith
      have h╧БS : ╧Б тИИ S := тЯиhzero, hre1, hre2, him, him_le_oneтЯй
      have hgap_mem : ╧Б.im - T тИИ gaps :=
        Finset.mem_image.mpr тЯи╧Б, hfin.mem_toFinset.mpr h╧БS, rflтЯй
      have h╬┤_le : ╬┤ тЙд ╧Б.im - T := gaps.min'_le _ hgap_mem
      linarith
    ┬╖ refine тЯи1, by norm_num, ?_тЯй
      intro ╧Б hzero hre1 hre2 him him_upper
      exact hS_ne тЯи╧Б, hzero, hre1, hre2, him, him_upperтЯй

