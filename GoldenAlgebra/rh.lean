    have hden_nn : 0 тЙд (T / 2 - 1)^2 + ╬│^2 := by positivity
    exact one_div_nonneg.mpr hden_nn
  linarith

/-- тнР **PROVED тАФ termwise comparison TтЖТ11/2 for the cloud denominator.**
For `12 тЙд T тЙд 13` and any `╬│`,
  `1/((11/2)┬▓ + ╬│┬▓) тЙд 1/((T/2 - 1)┬▓ + ╬│┬▓)`.
(The denominator on the right is positive since `T/2 - 1 тЙе 5 > 0`.) -/
lemma one_div_Tbox_le_one_div_12_13
    {T ╬│ : тДЭ}
    (hT12 : 12 тЙд T) (hT13 : T тЙд 13) :
    1 / (((11 / 2 : тДЭ)^2) + ╬│^2)
      тЙд 1 / (((T / 2 - 1)^2) + ╬│^2) := by
  have hlow : 0 тЙд T / 2 - 1 := by linarith
  have hhi : T / 2 - 1 тЙд (11 / 2 : тДЭ) := by linarith
  have hsq : (T / 2 - 1)^2 тЙд ((11 / 2 : тДЭ)^2) := sq_le_sq' (by linarith) hhi
  have hden : (T / 2 - 1)^2 + ╬│^2 тЙд ((11 / 2 : тДЭ)^2) + ╬│^2 := by linarith
  have hT_half_pos : 0 < T / 2 - 1 := by linarith
  have hTsq_pos : 0 < (T / 2 - 1)^2 := pow_pos hT_half_pos 2
  have hdenpos : 0 < (T / 2 - 1)^2 + ╬│^2 := by
    have h╬│2 : 0 тЙд ╬│^2 := sq_nonneg _
    linarith
  exact one_div_le_one_div_of_le hdenpos hden

