    mellin (fun t : ÔäØ => ((f t : ÔäØ) : Ôäé)) (star s)
      = star (mellin (fun t : ÔäØ => ((f t : ÔäØ) : Ôäé)) s) := by
  unfold mellin
  -- Move star inside the RHS integral via integral_conj.
  rw [show star (Ôê½ t in Set.Ioi (0 : ÔäØ),
        ((t : Ôäé) ^ (s - 1) ÔÇó ((f t : ÔäØ) : Ôäé)))
      = Ôê½ t in Set.Ioi (0 : ÔäØ),
        star ((t : Ôäé) ^ (s - 1) ÔÇó ((f t : ÔäØ) : Ôäé))
      from (integral_conj
        (f := fun t : ÔäØ => (t : Ôäé) ^ (s - 1) ÔÇó ((f t : ÔäØ) : Ôäé))
        (╬╝ := MeasureTheory.volume.restrict (Set.Ioi 0))).symm]
  -- Match integrands pointwise on Ioi 0.
  refine MeasureTheory.setIntegral_congr_fun measurableSet_Ioi ?_
  intro t ht
  -- Beta-reduce the lambda-wrapped goal.
  show (t : Ôäé) ^ (star s - 1) ÔÇó ((f t : ÔäØ) : Ôäé)
        = star ((t : Ôäé) ^ (s - 1) ÔÇó ((f t : ÔäØ) : Ôäé))
  have htpos : 0 < t := ht
  have h_arg : ((t : Ôäé)).arg Ôëá Real.pi := by
    rw [Complex.arg_ofReal_of_nonneg htpos.le]
    exact (Real.pi_pos.ne').symm
  rw [Complex.star_def, smul_eq_mul, smul_eq_mul, map_mul, Complex.conj_ofReal]
  congr 1
  -- (t : Ôäé) ^ (star s - 1) = conj((t : Ôäé) ^ (s - 1))
  have h_cpow := Complex.cpow_conj (t : Ôäé) (s - 1) h_arg
  rw [Complex.conj_ofReal] at h_cpow
  have h_sub : (starRingEnd Ôäé) (s - 1) = (starRingEnd Ôäé) s - 1 := by
    rw [map_sub, map_one]
  rw [ÔåÉ h_sub]
  exact h_cpow

