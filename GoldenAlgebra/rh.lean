-- =====================================================================
-- ¬ІCCLXVI. Canonical-T mid local package + replacement front door
-- =====================================================================
-- Replaces the over-strong `XiResidualFormulaData`-based mid pathway
-- with a canonical-T-only pathway using `XiResidualCanonicalFormulaData`
-- (¬ІCCLXV). The honest mid-band local package picks `T := canonicalAdaptiveT z`
-- per `z`, so the error margin chain is consistent without invoking
-- any tail-Im T-independence claim.
--
-- Adds:
--   trueKernelAdaptiveTail_im_bound                          вАФ Im bound at canonical T
--   canonicalMidResidual_closedFormBound                     вАФ residual вЙ§ closed form
--   canonicalMidResidual_errorMargin                         вАФ residual вЙ§ -Im(M.model)
--   midLocalPackage_of_canonicalResidualFormula              вАФ Local mid package
--   XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
--                                                            вАФ final replacement front door

/-- рЯМЯрЯМЯ **PROVED вАФ Im bound for `trueKernelAdaptiveTail` at any
adaptive `T`.** Routes through ¬ІCCLV-3 + Tendsto uniqueness:
`trueKernelAdaptiveTail` and `trueKernelTailOfLogEnvelope` agree at
the adaptive band (both are the XвЖТвИЮ limit of the same complex
partials), so the ¬ІCCLV-3 Im bound transfers. -/
theorem trueKernelAdaptiveTail_im_bound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : вДВ} {T : вДЭ}
    (h10 : 10 вЙ§ T) (h140 : T вЙ§ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im|
      вЙ§ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T := by
  have hT_pos : (0 : вДЭ) < T := by linarith
  have hT_ge_one : (1 : вДЭ) вЙ§ T := by linarith
  have hT0_le_T : T0 вЙ§ T := le_trans hT0_le_10 h10
  have hS_T : вИА u, T вЙ§ u вЖТ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2 :=
    fun u hu => hTuring h10 h140 hy hregime hu
  have hSlogEnv : вИАбґ† u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hS_T u hu
  have h1 := trueKernelAdaptiveTail_tendsto
    Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
  have h2 := trueKernelTailOfLogEnvelope_tendsto
    Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv
  have h_eq : trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
            = trueKernelTailOfLogEnvelope
                Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv :=
    tendsto_nhds_unique h1 h2
  rw [h_eq]
  have hC : (0 : вДЭ) вЙ§ (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD : (0 : вДЭ) вЙ§ (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  exact trueKernelTailOfLogEnvelope_im_bound
    Dzero T0 hT0_pos hT0_le_T hT_pos hT_ge_one hy hC hD hregime hS_T

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ canonical mid residual closed-form bound.**
Combines `Rcanon` (residual.im = canonical tail.im) with ¬ІCCLXVI's
`trueKernelAdaptiveTail_im_bound` at `T := canonicalAdaptiveT z`. -/
theorem canonicalMidResidual_closedFormBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : вДВ}
    (hy : 0 < z.im)
    (hmid : вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
      2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(xiResidualError M z).im|
      вЙ§ closedFormSErrorBoundCD
          (slabCD (canonicalAdaptiveT z)).1
          (slabCD (canonicalAdaptiveT z)).2
          z.im
          (canonicalAdaptiveT z) := by
  have hc := canonicalAdaptiveT_spec hmid
  rw [Rcanon.residual_im_eq_canonical_tail hy hmid]
  exact trueKernelAdaptiveTail_im_bound
    Dzero T0 hT0_pos hT0_le_10 hTuring
    hc.1 hc.2.1 hy hc.2.2

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ canonical mid residual model margin.**
Chains the closed-form bound (¬ІCCLXVI step 2) with the slab cert
(¬ІCLXXXIVa `hclosed_on_10_140_zeros100ceil_slabCD`) at `T := canonicalAdaptiveT z`. -/
theorem canonicalMidResidual_errorMargin
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : вДВ}
    (hy : 0 < z.im)
    (hmid : вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
      2 * (1 + |z.re| + z.im) вЙ§ T) :
    |(xiResidualError M z).im| вЙ§ -(M.model z).im := by
  have hc := canonicalAdaptiveT_spec hmid
  have h_closed_bound :=
    canonicalMidResidual_closedFormBound
      Dzero T0 hT0_pos hT0_le_10 hTuring M Rcanon hy hmid
  exact le_trans h_closed_bound
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hc.1 hc.2.1 hy hc.2.2)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ canonical mid `LocalXiCloudDensityErrorPackage`.**
Bundles the canonical mid residual into a `LocalXiCloudDensityErrorPackage`
whose `region` is the mid existential. No `Rmid` over-strong hypothesis;
the canonical-T choice handles arbitrary `T` in the region via
`canonicalAdaptiveT z`. -/
noncomputable def midLocalPackage_of_canonicalResidualFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List вДЭ)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M) :
    LocalXiCloudDensityErrorPackage where
  model := HModel.M.model
  error := xiResidualError HModel.M
  region := fun z =>
    вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T
  decomp := fun z _ => xiResidualError_decomp HModel.M z
  modelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  errorMargin := fun _ hreg hy =>
    canonicalMidResidual_errorMargin
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M HModel.hzeros Rcanon
      hy hreg

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **HONEST MASTER FRONT
DOOR (canonical mid).** Replaces `XiPullbackAntiHerglotzTarget_of_honestPackages`
with a version using `Rcanon : XiResidualCanonicalFormulaData` instead
of the over-strong `Rmid : XiResidualFormulaData`. Assembles three
local packages (low, mid via canonical, high) into a `XiCloudDensityCoveringFamily`
covered by `low.region вИ® mid.region вИ® highComplementRegion`. -/
theorem XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
    (us : List вДЭ)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (Rhigh : XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : вДЭ) вЙ§ 140))
      HModel.M hHighLog)
    (hlowMargin :
      вИА {z : вДВ} {T : вДЭ},
        2 * Real.pi вЙ§ T вЖТ T вЙ§ 10 вЖТ
        0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        |(xiResidualError HModel.M z).im| вЙ§ -(HModel.M.model z).im) :
    XiPullbackAntiHerglotzTarget := by
  have hmodelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  let mid : LocalXiCloudDensityErrorPackage :=
    midLocalPackage_of_canonicalResidualFormula
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us Tsmooth hTsmooth_ge HModel Rcanon
  let high : LocalXiCloudDensityErrorPackage :=
    highLocalPackage_of_XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : вДЭ) вЙ§ 140))
      HModel.M HModel.hzeros hmodelAnti hHighLog Rhigh
  let low : LocalXiCloudDensityErrorPackage :=
    lowLocalPackage_of_residualLowMargin HModel.M hmodelAnti hlowMargin
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n =>
        if n = 0 then mid else if n = 1 then high else low
      covers := ?_ }
  intro z hz
  by_cases hmid :
      вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T
  ¬Ј refine вЯ®0, ?_вЯ©
    show mid.region z
    exact hmid
  ¬Ј refine вЯ®1, ?_вЯ©
    show high.region z
    exact hmid

-- =====================================================================
-- ¬ІCCLXVII. Compact low-band residual margin target
-- =====================================================================
-- The `hlowMargin` obligation is `T`-parametric, but the low-band
-- constraint `2(1 + |z.re| + z.im) вЙ§ T вЙ§ 10` collapses the geometry
-- to `0 < z.im вИІ |z.re| + z.im вЙ§ 4`. This section repackages the
-- obligation as a compact-region inequality so the analytic agent
-- has a single clean target.
--
-- Adds:
--   lowCompactRegion                              вАФ `0 < z.im вИІ 2(1+|z.re|+z.im) вЙ§ 10`
--   lowCompactRegion_of_lowT                      вАФ `T`-parametric вЖТ compact
--   XiLowResidualMargin                           вАФ Prop over `lowCompactRegion`
--   hlowMargin_of_XiLowResidualMargin             вАФ bridge to old shape
--   XiPullbackAntiHerglotzTarget_of_honestPackages_lowCompact
--                                                 вАФ final front door consuming `Hlow`

/-- **Low-band compact region predicate.** Equivalent to the
adaptive-band condition for any `T вИИ [2ѕА, 10]`: `0 < z.im вИІ
2(1 + |z.re| + z.im) вЙ§ 10`. -/
def lowCompactRegion (z : вДВ) : Prop :=
  0 < z.im вИІ 2 * (1 + |z.re| + z.im) вЙ§ 10

/-- в≠Р **PROVED вАФ low `T`-parametric region вЯє low compact region.** -/
lemma lowCompactRegion_of_lowT
    {z : вДВ} {T : вДЭ}
    (_hTlo : 2 * Real.pi вЙ§ T)
    (hThi : T вЙ§ 10)
    (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    lowCompactRegion z :=
  вЯ®hy, le_trans hregime hThiвЯ©

/-- рЯУ¶ **`XiLowResidualMargin M`** вАФ the actual low-band analytic
target. Says: on the compact low region (`0 < z.im` and
`2(1 + |z.re| + z.im) вЙ§ 10`), the canonical residual's imaginary part
is dominated by the model margin. A single compact-region inequality. -/
def XiLowResidualMargin
    (M : CloudDensityTailModelDecomposition) : Prop :=
  вИА z : вДВ,
    lowCompactRegion z вЖТ
    |(xiResidualError M z).im| вЙ§ -(M.model z).im

/-- в≠Р **PROVED вАФ `hlowMargin` (T-parametric) from `XiLowResidualMargin`.**
The compact target subsumes the T-parametric obligation via
`lowCompactRegion_of_lowT`. -/
theorem hlowMargin_of_XiLowResidualMargin
    (M : CloudDensityTailModelDecomposition)
    (Hlow : XiLowResidualMargin M) :
    вИА {z : вДВ} {T : вДЭ},
      2 * Real.pi вЙ§ T вЖТ T вЙ§ 10 вЖТ
      0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      |(xiResidualError M z).im| вЙ§ -(M.model z).im := by
  intro z T hTlo hThi hy hregime
  exact Hlow z (lowCompactRegion_of_lowT hTlo hThi hy hregime)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **FINAL HONEST FRONT
DOOR (compact low).** Specializes
`XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid` to
consume a `Hlow : XiLowResidualMargin HModel.M` compact-region
hypothesis instead of the T-parametric `hlowMargin`. The five
substantive named xi-specific inputs are now uniformly compact /
single-Prop:

```
hTuring + hHighLog       (parallel agent)
+ HModel                  (honest model identity)
+ Rcanon                  (mid canonical-T residual identity)
+ Rhigh                   (high residual identity)
+ Hlow                    (compact low residual margin)
вЯє XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_honestPackages_lowCompact
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
    (us : List вДЭ)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (Rhigh : XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : вДЭ) вЙ§ 140))
      HModel.M hHighLog)
    (Hlow : XiLowResidualMargin HModel.M) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
    us Tsmooth hTsmooth_ge HModel Rcanon Rhigh
    (hlowMargin_of_XiLowResidualMargin HModel.M Hlow)

-- =====================================================================
-- ¬ІCCLXVIII. High residual-as-tail-limit target (the next analytic step)
-- =====================================================================
-- The next analytic step toward `Rhigh : XiHighResidualFormulaData` is
-- a Stieltjes-style high explicit formula: the canonical residual is
-- the `X вЖТ вИЮ` complex limit of true-kernel partials over `[T, X]` for
-- every high-band `(z, T)`. This section names that target as a single
-- Prop and provides the trivial bridge to `Rhigh` via ¬ІCCLXIV's
-- `XiHighResidualFormulaData.of_complex_tendsto`.
--
-- Adds:
--   XiHighResidualAsTailLimit                       вАФ the high-band limit Prop
--   XiHighResidualFormulaData_of_tailLimit          вАФ bridge to Rhigh

/-- рЯУ¶ **`XiHighResidualAsTailLimit`** вАФ the next high-band analytic
target. Says: for every high-band UHP `z`, the canonical residual
`xiResidualError M z` is the `X вЖТ вИЮ` complex limit of the true-kernel
partials `complexDensityTailPartial pairedCauchyComplexKernelTrue ... T X z`.
This is the natural Stieltjes-style explicit formula shape.

Note: this Prop does **not** depend on a high-band log envelope вАФ it
is purely the limit identity. The log envelope `hHighLog` is needed
downstream when constructing `Rhigh : XiHighResidualFormulaData` to
identify the limit value with `trueKernelTailOfLogEnvelope`. -/
structure XiHighResidualAsTailLimit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  tendsto_high :
    вИА {z : вДВ} {T : вДЭ},
      140 вЙ§ T вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      Tendsto
        (fun X : вДЭ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop
        (рЭУЭ (xiResidualError M z))

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `XiHighResidualFormulaData` from
`XiHighResidualAsTailLimit`.** Direct composition with ¬ІCCLXIV's
`XiHighResidualFormulaData.of_complex_tendsto`: a high-band tail-limit
identity is exactly the input shape needed to inhabit `Rhigh`. -/
def XiHighResidualFormulaData_of_tailLimit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 вЙ§ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
    (H : XiHighResidualAsTailLimit Dzero T0 M) :
    XiHighResidualFormulaData Dzero T0 hT0_pos hT0_le_140 M hHighLog :=
  XiHighResidualFormulaData.of_complex_tendsto
    Dzero T0 hT0_pos hT0_le_140 M hHighLog
    (fun hT140 hy hregime => H.tendsto_high hT140 hy hregime)

-- =====================================================================
-- ¬ІCCLXIX. Honest zeroDensity model construction (CLV obligation isolated)
-- =====================================================================
-- An attempt to inhabit `HonestZeroDensityModelData` directly with the
-- honest `zeroDensitySmoothTailModel`. The only remaining obstacle is
-- the `densityTailRationalLB` field of `CloudDensityTailModelDecomposition`:
--
--   `smoothTailRationalLowerBoundAbs z.re z.im T вЙ§ -(zeroDensitySmoothTailModel z).im`
--
-- for every `T вЙ• 2ѕА` in the adaptive band. This is the CLV chain that
-- hasn't been proved in the file yet. This section isolates it as a
-- single named Prop `HonestSmoothTailRationalLB`, then provides the
-- honest model + bundle + master front door parameterized on it.
--
-- After this lands, the entire `HModel` obligation collapses to a
-- single analytic Prop. The master front door takes seven inputs:
-- two parallel-agent + `hLB` + `Rcanon` + `Rhigh` + `Hlow` (no `HModel`
-- as a free input).
--
-- Adds:
--   HonestSmoothTailRationalLB                              вАФ CLV target Prop
