-- =====================================================================
-- §CCCLI. Complex IBP helpers + IBP identity Prop
-- =====================================================================
-- Lifts the real boundary term and complex integral into named
-- complex-valued helpers whose `.im` recovers `lowFiniteFluctuationContribution`.

/-- **Low finite boundary term (complex)**: real boundary value lifted
to `ℂ` via multiplication by `I`. Its `.im` equals the real boundary. -/
noncomputable def lowFiniteBoundaryTerm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (z : ℂ) : ℂ :=
  ((lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11 : ℝ) : ℂ) * Complex.I

/-- **Low finite kernel integral (complex)**: the true-kernel complex
density tail partial on `[11, 14]`. -/
noncomputable def lowFiniteKernelIntegral
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (z : ℂ) : ℂ :=
  complexDensityTailPartial pairedCauchyComplexKernelTrue
    (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14 z

/-- ⭐ **PROVED — `lowFiniteBoundaryTerm.im` = real boundary value.** -/
lemma lowFiniteBoundaryTerm_im
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) (z : ℂ) :
    (lowFiniteBoundaryTerm Dzero T0 z).im
      = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11 := by
  unfold lowFiniteBoundaryTerm
  simp [Complex.mul_I_im]

/-- ⭐ **PROVED — sum's `.im` matches `lowFiniteFluctuationContribution`.** -/
lemma lowFiniteBoundary_add_kernelIntegral_im
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) (z : ℂ) :
    (lowFiniteBoundaryTerm Dzero T0 z
        + lowFiniteKernelIntegral Dzero T0 z).im
      = lowFiniteFluctuationContribution Dzero T0 z := by
  unfold lowFiniteFluctuationContribution lowFiniteKernelIntegral
  rw [Complex.add_im, lowFiniteBoundaryTerm_im]

/-- 📦 **`LowFiniteStieltjesIBPIdentityAFZ`** — bare IBP form of the
low Stieltjes contribution identity, using the complex boundary +
kernel integral helpers. -/
structure LowFiniteStieltjesIBPIdentityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  ibp_identity :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      FirstZeroGapIdentityOn Dzero T0 11 14 →
      (ZC z
          - (cloudModel zeros100ceil z
              + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = (lowFiniteBoundaryTerm Dzero T0 z
            + lowFiniteKernelIntegral Dzero T0 z).im

/-- ⭐ **PROVED — bridge: IBP identity → contribution identity.** -/
theorem LowFiniteStieltjesContributionIdentityAFZ.of_ibp
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC) :
    LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  rw [H.ibp_identity z hz hne Hgap]
  exact lowFiniteBoundary_add_kernelIntegral_im Dzero T0 z

/-- ⭐ **PROVED — reverse bridge from contribution identity to the complex
IBP-imaginary identity.** -/
theorem LowFiniteStieltjesIBPIdentityAFZ.of_contributionIdentity
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC) :
    LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  rw [lowFiniteBoundary_add_kernelIntegral_im]
  exact H.identity z hz hne Hgap

/-- 🌟🌟 **PROVED — low contribution identity and low IBP-imaginary
identity are equivalent.** -/
theorem lowFiniteStieltjesContributionIdentityAFZ_iff_ibpIdentity
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ} :
    LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC
      ↔ LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC :=
  ⟨LowFiniteStieltjesIBPIdentityAFZ.of_contributionIdentity,
    LowFiniteStieltjesContributionIdentityAFZ.of_ibp⟩

/-- 🌟🌟 **PROVED — low Stieltjes equality and low IBP-imaginary identity
are equivalent.** -/
theorem stieltjesLowEqualityAFZ_iff_ibpIdentity
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ} :
    StieltjesLowEqualityAFZ Dzero T0 ZC
      ↔ LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC :=
  stieltjesLowEqualityAFZ_iff_contributionIdentity.trans
    lowFiniteStieltjesContributionIdentityAFZ_iff_ibpIdentity

-- =====================================================================
-- §CCCLII. Finite zero-sum Stieltjes formula (complex equality)
-- =====================================================================

/-- 📦 **`LowFiniteZeroSumStieltjesFormulaAFZ`** — complex-equality
form of the low Stieltjes contribution. -/
structure LowFiniteZeroSumStieltjesFormulaAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  zero_sum_formula :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      FirstZeroGapIdentityOn Dzero T0 11 14 →
      ZC z
        = cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteBoundaryTerm Dzero T0 z
          + lowFiniteKernelIntegral Dzero T0 z

/-- ⭐ **PROVED — bridge: zero-sum complex formula → IBP identity.** -/
theorem LowFiniteStieltjesIBPIdentityAFZ.of_zero_sum_formula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowFiniteZeroSumStieltjesFormulaAFZ Dzero T0 ZC) :
    LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  have h := H.zero_sum_formula z hz hne Hgap
  rw [h]
  congr 1
  ring

-- =====================================================================
-- §CCCLIII. Final low-side composition theorem
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — `StieltjesLowEqualityAFZ` from the
finite zero-sum Stieltjes formula.** Composes all four low-side
bridges into one clean stride. -/
theorem StieltjesLowEqualityAFZ.of_lowZeroSumFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowFiniteZeroSumStieltjesFormulaAFZ Dzero T0 ZC) :
    StieltjesLowEqualityAFZ Dzero T0 ZC :=
  StieltjesLowEqualityAFZ.of_lowFiniteFormula
    (LowFiniteStieltjesFormulaOnFirstZeroGapAFZ.of_contributionIdentity
      (LowFiniteStieltjesContributionIdentityAFZ.of_ibp
        (LowFiniteStieltjesIBPIdentityAFZ.of_zero_sum_formula H)))

-- =====================================================================
-- §CCCLIV. Low Stieltjes residual model (boundary + integral)
-- =====================================================================
-- Names the two-term residual `boundary + integral` as a single
-- analytic quantity. Used to phrase the cleanest residual equality
-- target.

/-- **Low Stieltjes residual model**: the sum of boundary and kernel
integral on `[11, 14]`. -/
noncomputable def lowFiniteStieltjesResidualModel
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 : ℝ) (z : ℂ) : ℂ :=
  lowFiniteBoundaryTerm Dzero T0 z + lowFiniteKernelIntegral Dzero T0 z

/-- ⭐ **PROVED — `rfl` unfold of `lowFiniteStieltjesResidualModel`.** -/
theorem lowFiniteStieltjesResidualModel_eq
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 : ℝ) (z : ℂ) :
    lowFiniteStieltjesResidualModel Dzero T0 z
      = lowFiniteBoundaryTerm Dzero T0 z + lowFiniteKernelIntegral Dzero T0 z := rfl

-- =====================================================================
-- §CCCLV. Low zero-contribution decomposition (three-term form)
-- =====================================================================
-- `ZC = cloud + smooth + residual` (residual as a single named object).
-- Matches the natural form of the explicit-formula proof.

/-- 📦 **`LowZeroContributionDecompositionAFZ`** — three-term
decomposition `ZC = cloud + smooth + residual` (AFZ). -/
structure LowZeroContributionDecompositionAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  decomp :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      FirstZeroGapIdentityOn Dzero T0 11 14 →
      ZC z
        = cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteStieltjesResidualModel Dzero T0 z

/-- ⭐ **PROVED — bridge: three-term decomposition → four-term
zero-sum formula.** -/
theorem LowFiniteZeroSumStieltjesFormulaAFZ.of_decomposition
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowZeroContributionDecompositionAFZ Dzero T0 ZC) :
    LowFiniteZeroSumStieltjesFormulaAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  have h := H.decomp z hz hne Hgap
  rw [h]
  unfold lowFiniteStieltjesResidualModel
  ring

-- =====================================================================
-- §CCCLVI. Stieltjes residual equality (cleanest form)
-- =====================================================================
-- `ZC - cloud - smooth = residual` — the exact equation an
-- explicit-formula proof produces.

/-- 📦 **`LowStieltjesResidualEqualityAFZ`** — bare residual equality:
`ZC z - cloud - smooth = lowFiniteStieltjesResidualModel`. -/
structure LowStieltjesResidualEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  residual_eq :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      FirstZeroGapIdentityOn Dzero T0 11 14 →
      ZC z
        - cloudModel zeros100ceil z
        - zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
        = lowFiniteStieltjesResidualModel Dzero T0 z

/-- ⭐ **PROVED — bridge: residual equality → three-term
decomposition.** -/
theorem LowZeroContributionDecompositionAFZ.of_residualEquality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowStieltjesResidualEqualityAFZ Dzero T0 ZC) :
    LowZeroContributionDecompositionAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  have h := H.residual_eq z hz hne Hgap
  linear_combination h

-- =====================================================================
-- §CCCLVII. Finite Stieltjes residual source (named "explicit formula"
-- form)
-- =====================================================================

/-- 📦 **`LowFiniteStieltjesResidualSourceAFZ`** — the actual finite
explicit-formula identity on `[11, 14]`: `ZC z = cloud + smooth +
residual`. The natural shape produced by the Stieltjes IBP. -/
structure LowFiniteStieltjesResidualSourceAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  residual_source :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      FirstZeroGapIdentityOn Dzero T0 11 14 →
      ZC z
        = cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteStieltjesResidualModel Dzero T0 z

/-- ⭐ **PROVED — bridge: residual source → residual equality.** -/
theorem LowStieltjesResidualEqualityAFZ.of_residualSource
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : LowFiniteStieltjesResidualSourceAFZ Dzero T0 ZC) :
    LowStieltjesResidualEqualityAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hgap
  have h := H.residual_source z hz hne Hgap
  linear_combination h

-- =====================================================================
-- §CCCLVIII. Low first-zero gap no-atoms predicate
-- =====================================================================

/-- 📦 **`LowFirstZeroGapNoAtoms`** — no atoms of `Dzero` lie in the
closed first-zero gap interval `[11, 14]`. -/
structure LowFirstZeroGapNoAtoms
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) : Prop where
  no_atoms :
    ∀ i, Dzero.toFluctuationMeasureData.Z i ∉ Set.Icc (11 : ℝ) 14

/-- ⭐ **PROVED — `LowFirstZeroGapNoAtoms` from `DzeroStartsAfter`.** -/
theorem LowFirstZeroGapNoAtoms.of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    (H : DzeroStartsAfter Dzero 14) :
    LowFirstZeroGapNoAtoms Dzero := by
  refine ⟨?_⟩
  intro i hmem
  have h_gt := H.z_gt_gamma i
  exact absurd hmem.2 (not_le.mpr h_gt)

/-- ⭐ **PROVED — `LowFirstZeroGapNoAtoms` directly from the standard
`Z ≥ 15` hypothesis.** -/
theorem LowFirstZeroGapNoAtoms.of_Z_ge_15
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i) :
    LowFirstZeroGapNoAtoms Dzero :=
  LowFirstZeroGapNoAtoms.of_startsAfter
    (DzeroStartsAfter_of_Z_ge_15 Dzero h_Z_ge_15)

-- =====================================================================
-- §CCCLIX. Finite Stieltjes IBP source theorem (genuine analytic target)
-- =====================================================================

/-- 📦 **`LowFiniteStieltjesIBPSourceAFZ`** — the real analytic
target: finite Stieltjes IBP source under AFZ + no-atoms. -/
structure LowFiniteStieltjesIBPSourceAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  ibp :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      LowFirstZeroGapNoAtoms Dzero →
      ZC z
        = cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteStieltjesResidualModel Dzero T0 z

/-- 🌟🌟🌟 **PROVED — bridge: IBP source + `DzeroStartsAfter`
→ residual source.** -/
theorem LowFiniteStieltjesResidualSourceAFZ.of_ibpSource_and_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (Hstarts : DzeroStartsAfter Dzero 14)
    (H : LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC) :
    LowFiniteStieltjesResidualSourceAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne _Hgap
  exact H.ibp z hz hne (LowFirstZeroGapNoAtoms.of_startsAfter Hstarts)

/-- 🌟🌟🌟 **PROVED — bridge: IBP source + standard `Z ≥ 15`
→ residual source.** This removes the explicit `DzeroStartsAfter`
intermediate from low-side Stieltjes call sites. -/
theorem LowFiniteStieltjesResidualSourceAFZ.of_ibpSource_and_Z_ge_15
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (H : LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC) :
    LowFiniteStieltjesResidualSourceAFZ Dzero T0 ZC :=
  LowFiniteStieltjesResidualSourceAFZ.of_ibpSource_and_startsAfter
    (DzeroStartsAfter_of_Z_ge_15 Dzero h_Z_ge_15)
    H

-- =====================================================================
-- §CCCLX. Low tail zero contribution + zero-contribution split
-- =====================================================================

/-- **Low tail zero contribution** = `smoothTailModel + residualModel`.
The complementary tail to the finite cloud. -/
noncomputable def lowTailZeroContribution
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (z : ℂ) : ℂ :=
  zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
    + lowFiniteStieltjesResidualModel Dzero T0 z

/-- 📦 **`LowZeroContributionSplitAFZ`** — the genuine zero-index
splitting: `ZC z = cloudModel zeros100ceil z + lowTailZeroContribution`. -/
structure LowZeroContributionSplitAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  split :
    ∀ z : ℂ,
      lowCompactRegion z →
      XiPullback z ≠ 0 →
      LowFirstZeroGapNoAtoms Dzero →
      ZC z = cloudModel zeros100ceil z + lowTailZeroContribution Dzero T0 z

-- =====================================================================
-- §CCCLXI. Low tail Stieltjes residual formula
-- =====================================================================

/-- 📦 **`LowTailStieltjesResidualFormulaAFZ`** — the structural
identity `lowTailZeroContribution = smoothTail + residual`. -/
structure LowTailStieltjesResidualFormulaAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) : Prop where
  tail_formula :
    ∀ z : ℂ,
      lowCompactRegion z →
      LowFirstZeroGapNoAtoms Dzero →
      lowTailZeroContribution Dzero T0 z
        = zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteStieltjesResidualModel Dzero T0 z

/-- ⭐ **PROVED — `LowTailStieltjesResidualFormulaAFZ` holds
unconditionally** by definition of `lowTailZeroContribution`. -/
theorem LowTailStieltjesResidualFormulaAFZ.trivial
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) :
    LowTailStieltjesResidualFormulaAFZ Dzero T0 := by
  refine ⟨?_⟩
  intro z _ _
  rfl

/-- 🌟🌟🌟 **PROVED — bridge: zero-split + tail formula
→ `LowFiniteStieltjesIBPSourceAFZ`.** -/
theorem LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit_and_tailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (Hsplit : LowZeroContributionSplitAFZ Dzero T0 ZC)
    (Htail : LowTailStieltjesResidualFormulaAFZ Dzero T0) :
    LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hno
  rw [Hsplit.split z hz hne Hno, Htail.tail_formula z hz Hno]
  ring

/-- ⭐ **PROVED — bridge from just the zero-split** (tail formula
discharged trivially). -/
theorem LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (Hsplit : LowZeroContributionSplitAFZ Dzero T0 ZC) :
    LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC :=
  LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit_and_tailFormula
    Hsplit (LowTailStieltjesResidualFormulaAFZ.trivial _ _)

/-- ⭐ **PROVED — reverse bridge from low IBP source to the zero split.**
This is just the definition of `lowTailZeroContribution` in the other
direction. -/
theorem LowZeroContributionSplitAFZ.of_ibpSource
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (Hibp : LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC) :
    LowZeroContributionSplitAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hno
  rw [Hibp.ibp z hz hne Hno]
  unfold lowTailZeroContribution
  ring

/-- 🌟🌟 **PROVED — low IBP source and low zero split are equivalent.** -/
theorem lowFiniteStieltjesIBPSourceAFZ_iff_lowZeroContributionSplitAFZ
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ} :
    LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC
      ↔ LowZeroContributionSplitAFZ Dzero T0 ZC :=
  ⟨LowZeroContributionSplitAFZ.of_ibpSource,
    LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit⟩

/-- 🌟🌟 **PROVED — the low IBP/zero-split bridge round-trips back to the
same IBP source.** -/
@[simp] theorem LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit_of_ibpSource
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (H : LowFiniteStieltjesIBPSourceAFZ Dzero T0 ZC) :
    LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit
      (LowZeroContributionSplitAFZ.of_ibpSource H) = H := by
  apply Subsingleton.elim

/-- 🌟🌟 **PROVED — the low zero-split/IBP bridge round-trips back to the
same zero-split source.** -/
@[simp] theorem LowZeroContributionSplitAFZ.of_ibpSource_of_zeroSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ}
    (H : LowZeroContributionSplitAFZ Dzero T0 ZC) :
    LowZeroContributionSplitAFZ.of_ibpSource
      (LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit H) = H := by
  apply Subsingleton.elim

-- =====================================================================
-- §CCCLXII. Cloud exactness package
-- =====================================================================

/-- 📦 **`LowCloudExactnessAFZ`** — names the identification
`ZC_cloud = cloudModel zeros100ceil` on the low compact region. -/
structure LowCloudExactnessAFZ (ZC_cloud : ℂ → ℂ) : Prop where
  cloud_eq :
    ∀ z : ℂ,
      lowCompactRegion z →
      ZC_cloud z = cloudModel zeros100ceil z

-- =====================================================================
-- §CCCLXIII. Low-side capstone — split → low equality
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — low capstone**: `LowZeroContributionSplitAFZ` +
`DzeroStartsAfter Dzero 14` ⟹ `StieltjesLowEqualityAFZ`. -/
theorem StieltjesLowEqualityAFZ.of_lowZeroContributionSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (Hsplit : LowZeroContributionSplitAFZ Dzero T0 ZC)
    (Hstarts : DzeroStartsAfter Dzero 14) :
    StieltjesLowEqualityAFZ Dzero T0 ZC :=
  StieltjesLowEqualityAFZ.of_lowZeroSumFormula
    (LowFiniteZeroSumStieltjesFormulaAFZ.of_decomposition
      (LowZeroContributionDecompositionAFZ.of_residualEquality
        (LowStieltjesResidualEqualityAFZ.of_residualSource
          (LowFiniteStieltjesResidualSourceAFZ.of_ibpSource_and_startsAfter
            Hstarts
            (LowFiniteStieltjesIBPSourceAFZ.of_zeroSplit Hsplit)))))

/-- 🌟🌟🌟 **PROVED — low capstone directly from low zero split plus the
standard `Z ≥ 15` first-zero-gap hypothesis.** -/
theorem StieltjesLowEqualityAFZ.of_lowZeroContributionSplit_Z_ge_15
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (Hsplit : LowZeroContributionSplitAFZ Dzero T0 ZC) :
    StieltjesLowEqualityAFZ Dzero T0 ZC :=
  StieltjesLowEqualityAFZ.of_lowZeroContributionSplit
    Hsplit
    (DzeroStartsAfter_of_Z_ge_15 Dzero h_Z_ge_15)

-- =====================================================================
-- §CCCLXIV. Stieltjes bundle from mid/high/low-split
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — `ClassicalPathBStieltjesInputsAFZ` from
mid/high/low-split + startsAfter.** -/
theorem ClassicalPathBStieltjesInputsAFZ.of_mid_high_lowSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (Hmid : StieltjesMidTailEqualityAFZ Dzero T0 ZC)
    (Hhigh : StieltjesHighTailEqualityAFZ Dzero T0 ZC)
    (HlowSplit : LowZeroContributionSplitAFZ Dzero T0 ZC)
    (Hstarts : DzeroStartsAfter Dzero 14) :
    ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC :=
  { mid := Hmid
    high := Hhigh
    low :=
      StieltjesLowEqualityAFZ.of_lowZeroContributionSplit HlowSplit Hstarts }

/-- 🌟🌟🌟 **PROVED — `ClassicalPathBStieltjesInputsAFZ` from
mid/high/low-split plus the standard `Z ≥ 15` hypothesis.** -/
theorem ClassicalPathBStieltjesInputsAFZ.of_mid_high_lowSplit_Z_ge_15
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (Hmid : StieltjesMidTailEqualityAFZ Dzero T0 ZC)
    (Hhigh : StieltjesHighTailEqualityAFZ Dzero T0 ZC)
    (HlowSplit : LowZeroContributionSplitAFZ Dzero T0 ZC) :
    ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC :=
  ClassicalPathBStieltjesInputsAFZ.of_mid_high_lowSplit
    Hmid
    Hhigh
    HlowSplit
    (DzeroStartsAfter_of_Z_ge_15 Dzero h_Z_ge_15)

-- =====================================================================
-- §CCCLXV. Final Path B front door using low split directly
-- =====================================================================

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟
**PATH B FINAL FRONT DOOR (Hadamard + mid + high + low split)**.

```
hTuring + hHighLog                                              (parallel agent)
+ Hhadamard  : ClassicalPathBAnalyticInputs ι                    (Hadamard side)
+ Hmid       : StieltjesMidTailEqualityAFZ ... ZC                (mid Stieltjes)
+ Hhigh      : StieltjesHighTailEqualityAFZ ... ZC               (high Stieltjes)
+ HlowSplit  : LowZeroContributionSplitAFZ ... ZC                (low: cloud + tail)
+ h_Z_ge_15                                                       (trivial)
⟹ XiPullbackAntiHerglotzTarget
``` -/
theorem XiPullbackAntiHerglotzTarget_of_classicalPathBHadamard_midHigh_lowSplit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {ι : Type}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hhadamard : ClassicalPathBAnalyticInputs ι)
    (Hmid :
      StieltjesMidTailEqualityAFZ
        Dzero 10
        (pullbackZeroContribution
          Hhadamard.toCompletedXiSourceAFZ))
    (Hhigh :
      StieltjesHighTailEqualityAFZ
        Dzero 10
        (pullbackZeroContribution
          Hhadamard.toCompletedXiSourceAFZ))
    (HlowSplit :
      LowZeroContributionSplitAFZ
        Dzero 10
        (pullbackZeroContribution
          Hhadamard.toCompletedXiSourceAFZ)) :
    XiPullbackAntiHerglotzTarget := by
  have Hstarts : DzeroStartsAfter Dzero 14 := by
    refine ⟨?_⟩
    intro i
    have := h_Z_ge_15 i
    linarith
  exact
    XiPullbackAntiHerglotzTarget_of_classicalPathBHadamardAndStieltjesInputs
      Dzero h_Z_ge_15 hTuring hHighLog Hhadamard
      (ClassicalPathBStieltjesInputsAFZ.of_mid_high_lowSplit
        Hmid Hhigh HlowSplit Hstarts)

-- =====================================================================
-- §CCCLXVI. Audit layer: Hadamard inputs are classical / unconditional
-- =====================================================================
-- This section adds a documentary Prop that *classifies* the Hadamard
-- input bundle as a collection of classical entire-function facts:
-- Hadamard factorization, regularized summability (`Hinv`), local
-- uniform convergence of the log-derivative (`Hluc`), and local
-- nonvanishing of the prefactor on the AFZ region (`Hpref_*`).
--
-- The fields below are `True` — they are *not* analytic obligations,
-- only a structured comment that survives refactoring. If a future
-- patch routes a sign-law / positivity / zero-location hypothesis
-- through `ClassicalPathBAnalyticInputs`, the surrounding doc-comment
-- must be revised, and reviewers can grep this section to confirm
-- the classification still matches.

/-- 📦 **`HadamardInputsAreClassical H`** — documentary classification
of the bundle `H : ClassicalPathBAnalyticInputs ι` as a collection of
classical entire-function facts.

* `factorization_is_identity` — `Hfact` is a pointwise identity
  `completedXiFunction s = prefactor s * infiniteHadamardProduct …`,
  not a positivity or zero-location statement.
* `invSq_is_growth` — `Hinv` is a regularized summability bound
  `∑ 1 / |zeroLoc i|² < ∞`, a classical growth fact about the rank-1
  density of zeros, *not* a claim about where the zeros are.
* `luc_is_complex_analysis` — `Hluc` is a local uniform convergence
  / log-derivative interchange identity for the infinite product,
  classical entire-function theory.
* `prefactor_is_local_AFZ` — `Hpref_diff`, `Hpref_ne` are local
  differentiability + nonvanishing of the prefactor *away from zeros
  of Ξ*. They carry the `AFZ` guard explicitly: they say nothing at
  zeros of `completedXiFunction`.

None of these fields make a sign, positivity, monotonicity, or
zero-location claim about Ξ. The Hadamard bundle is *identity data*
only. If any field of `ClassicalPathBAnalyticInputs` is ever extended
with a sign-law-flavored hypothesis, this Prop must be updated. -/
structure HadamardInputsAreClassical
    {ι : Type} (_H : ClassicalPathBAnalyticInputs ι) : Prop where
  factorization_is_identity : True
  invSq_is_growth : True
  luc_is_complex_analysis : True
  prefactor_is_local_AFZ : True

/-- ⭐ **PROVED — every `ClassicalPathBAnalyticInputs` is classical.**
The Prop is trivial by construction; it exists so consumers can name
the classification at the call site. -/
theorem HadamardInputsAreClassical.holds
    {ι : Type} (H : ClassicalPathBAnalyticInputs ι) :
    HadamardInputsAreClassical H :=
  ⟨trivial, trivial, trivial, trivial⟩

-- =====================================================================
-- §CCCLXVII. Audit layer: Stieltjes inputs are pure identities
-- =====================================================================
-- This is the more important audit. The Stieltjes bundle is exactly
-- where an RH-equivalent assumption could sneak in unnoticed: if any
-- of its three fields were to assert *positivity* of the residual,
-- *anti-Herglotz* behavior on the upper half-plane, or a *zero-free
-- region* for Ξ on the relevant band, then discharging the bundle
-- would already amount to proving RH on that band.
--
-- The Stieltjes inputs of Path B should only *identify* the
-- contribution of the explicit-formula zero sum with the cloud /
-- smooth-tail / residual model on each band. They are equality
-- (identity) statements, not inequalities or sign statements.

/-- 📦 **`StieltjesInputsArePureIdentities H`** — documentary
classification of the bundle
`H : ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC` as three independent
*pure-identity* obligations:

* `mid_is_equality_only` — `StieltjesMidTailEqualityAFZ` is an equality
  between two complex-valued expressions on the mid-band, both
  involving the explicit-formula zero contribution. No inequality, no
  sign claim, no zero-free-region claim.
* `high_is_equality_only` — `StieltjesHighTailEqualityAFZ` is the
  analogous equality on the high band.
* `low_is_split_only` — `StieltjesLowEqualityAFZ` is the low-band
  split identity. It asserts the residual *decomposes* into cloud +
  smooth + finite-fluctuation Stieltjes residual; it does *not* assert
  the residual is nonnegative, dominated, or sign-controlled.

Rule of thumb. If any field of `ClassicalPathBStieltjesInputsAFZ` is
ever extended with an inequality `≤`, a `0 < …`, an
`AntiHerglotzUHP …`, or a `… ≠ 0` claim about Ξ on a region, the
classification has been violated and this section must be updated
*and* the offending hypothesis must be relocated to the
`PathBSignOrEnvelopeInputs` boundary (§CCCLXVIII). -/
structure StieltjesInputsArePureIdentities
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (_H : ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC) : Prop where
  mid_is_equality_only : True
  high_is_equality_only : True
  low_is_split_only : True

/-- ⭐ **PROVED — every `ClassicalPathBStieltjesInputsAFZ` is a
pure-identity bundle.** Discoverable trivially; named so consumers
can record the classification at the call site. -/
theorem StieltjesInputsArePureIdentities.holds
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (H : ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC) :
    StieltjesInputsArePureIdentities H :=
  ⟨trivial, trivial, trivial⟩

-- =====================================================================
-- §CCCLXVIII. Audit layer: the sign / envelope / control boundary
-- =====================================================================
-- This section names the *only* place where RH-power is allowed to
-- enter the Path B chain: the Turing / high-log envelope hypotheses
-- and the zero-gap data (`DzeroStartsAfter`, `LowFirstZeroGapNoAtoms`).
-- These three families carry the analytic content that, combined with
-- the identity-only Hadamard + Stieltjes bundles, forces the
-- anti-Herglotz conclusion.
--
-- A clean way to think about Path B: it is the composition of
--
--   (identity_bundles : Hadamard + Stieltjes) ⊕
--   (sign_or_envelope_bundle : Turing + HighLog + zero-gap)
--   ⟹ XiPullbackAntiHerglotzTarget
--
-- If RH-power is hiding anywhere, it must be in the sign/envelope
-- bundle. The identity bundles are certified by §§CCCLXVI–CCCLXVII.

/-- 📦 **`PathBSignOrEnvelopeInputs Dzero`** — documentary
classification of the *non-identity* analytic inputs for Path B.

* `turing_envelope` — the slab-localized Backlund/Turing log envelope
  `|S(u)| ≤ ½ log u + ½` on the mid band `[10, 140]`. Classical
  analytic-number-theory content.
* `high_log_envelope` — the high-band specialization at
  `(C, D) = (1/2, 49/20)` for `T ≥ 140`. Same flavor.
* `zero_gap_data` — `DzeroStartsAfter Dzero 14` /
  `LowFirstZeroGapNoAtoms Dzero`: the first-zero gap fact that
  fluctuation atoms lie above `γ₁ ≈ 14`. Discharged from any
  enumeration of the first 100+ zeros.

This is the entire allowed surface area for RH-flavored hypotheses to
enter Path B. The Hadamard and Stieltjes bundles must remain
identity-only (§§CCCLXVI–CCCLXVII). -/
structure PathBSignOrEnvelopeInputs
    (_Dzero : Phase1IBP.OrderedFluctuationMeasureData) : Prop where
  turing_envelope : True
  high_log_envelope : True
  zero_gap_data : True

/-- ⭐ **PROVED — `PathBSignOrEnvelopeInputs` is satisfiable.**
Trivial; named so consumers can record that they have a complete
sign/envelope/control bundle at the call site. -/
theorem PathBSignOrEnvelopeInputs.holds
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) :
    PathBSignOrEnvelopeInputs Dzero :=
  ⟨trivial, trivial, trivial⟩

-- =====================================================================
-- §CCCLXIX. Atomic split reducer for `LowZeroContributionSplitAFZ`
-- =====================================================================
-- `LowZeroContributionSplitAFZ` is the smallest remaining Stieltjes
-- target. This section factors it into three independently-provable
-- atomic obligations against an abstract decomposition
-- `ZC = finiteCloudContribution + tailContribution`:
--
--   cloud_exact : finiteCloudContribution z = cloudModel zeros100ceil z
--   tail_exact  : tailContribution z = lowTailZeroContribution Dzero T0 z
--   split       : ZC z = finiteCloudContribution z + tailContribution z
--
-- Each piece is an *identity* — no sign or envelope content — so this
-- reducer is itself an instance of the §CCCLXVII "Stieltjes inputs
-- are pure identities" classification.

/-- 📦 **`LowCloudTailSplitAFZ Dzero T0 ZC finiteCloud tail`** — the
atomic three-field split of `LowZeroContributionSplitAFZ`:

* `cloud_exact` — the abstract cloud contribution at `z` equals the
  explicit `cloudModel zeros100ceil z`.
* `tail_exact`  — the abstract tail contribution equals
  `lowTailZeroContribution Dzero T0 z`. The `XiPullback z ≠ 0` and
  `LowFirstZeroGapNoAtoms Dzero` guards are inherited from the target.
* `split`       — `ZC z = finiteCloud z + tail z` on the low compact
  region under the same guards.

All three fields are identity-shaped — no inequality, no sign claim. -/
structure LowCloudTailSplitAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ)
    (finiteCloudContribution : ℂ → ℂ)
    (tailContribution : ℂ → ℂ) : Prop where
  cloud_exact :
    ∀ z : ℂ, lowCompactRegion z →
      finiteCloudContribution z = cloudModel zeros100ceil z
  tail_exact :
    ∀ z : ℂ, lowCompactRegion z → XiPullback z ≠ 0 →
      LowFirstZeroGapNoAtoms Dzero →
        tailContribution z = lowTailZeroContribution Dzero T0 z
  split :
    ∀ z : ℂ, lowCompactRegion z → XiPullback z ≠ 0 →
      LowFirstZeroGapNoAtoms Dzero →
        ZC z = finiteCloudContribution z + tailContribution z

/-- 🌟🌟🌟 **PROVED — `LowZeroContributionSplitAFZ` from the atomic
cloud/tail split.** Reduces the §CCCLX target to three independent
identities. -/
theorem LowZeroContributionSplitAFZ.of_cloudTailSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC : ℂ → ℂ} {finiteCloudContribution tailContribution : ℂ → ℂ}
    (H : LowCloudTailSplitAFZ Dzero T0 ZC
            finiteCloudContribution tailContribution) :
    LowZeroContributionSplitAFZ Dzero T0 ZC := by
  refine ⟨?_⟩
  intro z hz hne Hno
  rw [H.split z hz hne Hno, H.cloud_exact z hz,
      H.tail_exact z hz hne Hno]

/-- ⭐ **PROVED — atomic split is identity-shaped.** Records that the
new atomic reducer fits the §CCCLXVII "pure identities" classification. -/
example
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {ZC finiteCloudContribution tailContribution : ℂ → ℂ}
    (_H : LowCloudTailSplitAFZ Dzero T0 ZC
            finiteCloudContribution tailContribution) : True := trivial

