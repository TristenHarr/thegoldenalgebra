-- CLXXXV: Concrete `xiCloudDensityModel_zeros100ceil`
-- =====================================================================
-- A trivial-but-valid concrete `CloudDensityTailModelDecomposition`
-- with `zeros = zeros100ceil`. Uses a deliberately massive linear density
-- tail `densityTail z := -i ┬À (100 ┬À z.im)` so the `densityTailRationalLB`
-- obligation reduces to the crude bound `smoothTail Ôëñ 100┬Ày` on the
-- adaptive region. Plumbing only ÔÇö the real analytic decomposition and
-- IBP/Stieltjes error bound remain open.

/-- **Trivial massive-margin density tail.** `-i ┬À 100┬Àz.im` so its
`-Im` is `100┬Àz.im`, which trivially dominates any reasonable
`smoothTailRationalLowerBoundAbs` on the admissible region. -/
noncomputable def linearDensityTail100 : Ôäé ÔåÆ Ôäé :=
  fun z => -Complex.I * ((100 * z.im : ÔäØ) : Ôäé)

/-- Ô¡É **PROVED ÔÇö `-Im(linearDensityTail100 z) = 100┬Àz.im`.** -/
lemma linearDensityTail100_neg_im (z : Ôäé) :
    -(linearDensityTail100 z).im = 100 * z.im := by
  unfold linearDensityTail100
  simp [Complex.mul_im, Complex.neg_im, Complex.I_re, Complex.I_im,
        Complex.ofReal_re, Complex.ofReal_im]

/-- Ô¡É **PROVED ÔÇö `(linearDensityTail100 z).im = -100┬Àz.im Ôëñ 0`** for `0 < z.im`. -/
lemma linearDensityTail100_im_nonpos
    {z : Ôäé} (hz : 0 < z.im) :
    (linearDensityTail100 z).im Ôëñ 0 := by
  have h := linearDensityTail100_neg_im z
  linarith

/-- Ô¡É **PROVED ÔÇö `zeroDensityRho T Ôëñ T`** for `T ÔëÑ 2¤Ç`.
Via `log x Ôëñ x` applied to `x = T/(2¤Ç)`, then `log(T/(2¤Ç))/(2¤Ç) Ôëñ T/(4¤Ç┬▓) Ôëñ T`
(since `4¤Ç┬▓ > 1`). -/
lemma zeroDensityRho_le_T
    {T : ÔäØ} (hT2pi : 2 * Real.pi Ôëñ T) :
    zeroDensityRho T Ôëñ T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_pos : 0 < T / (2 * Real.pi) := by positivity
  have h_log_le : Real.log (T / (2 * Real.pi)) Ôëñ T / (2 * Real.pi) - 1 :=
    Real.log_le_sub_one_of_pos hT_2pi_pos
  have h_log_le_T_2pi : Real.log (T / (2 * Real.pi)) Ôëñ T / (2 * Real.pi) := by
    linarith
  have h_inv_pos : (0 : ÔäØ) < 1 / (2 * Real.pi) := by positivity
  have h_step :
      (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        Ôëñ (1 / (2 * Real.pi)) * (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_log_le_T_2pi (le_of_lt h_inv_pos)
  -- (1/(2¤Ç))┬À(T/(2¤Ç)) = T/(4¤Ç┬▓)
  have h_2pi_ne : (2 * Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h_2pi_pos
  have h_eq :
      (1 / (2 * Real.pi)) * (T / (2 * Real.pi))
        = T / ((2 * Real.pi)^2) := by
    rw [sq, mul_comm (2 * Real.pi) (2 * Real.pi)]
    field_simp
  have h_2pi_sq_gt_1 : (1 : ÔäØ) Ôëñ (2 * Real.pi)^2 := by
    nlinarith [h_pi_gt_d2]
  have h_T_div_le : T / ((2 * Real.pi)^2) Ôëñ T := by
    rw [div_le_iffÔéÇ (by positivity : (0:ÔäØ) < (2 * Real.pi)^2)]
    nlinarith [hT_pos, h_2pi_sq_gt_1]
  linarith [h_step, h_eq, h_T_div_le]

/-- Ô¡É **PROVED ÔÇö Crude smooth-tail kernel bound.**
On the admissible region, each kernel term `y┬ÀU/(U┬▓+y┬▓) Ôëñ y/U`, and
`T-|x|, T+|x| ÔëÑ T/2` gives `y/U Ôëñ 2y/T`. So the sum is `Ôëñ 4y/T`,
which we round up to `5y/T` for safety margin (any bound suffices). -/
lemma smoothTail_kernel_le_five_y_div_T
    {x y T : ÔäØ}
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) Ôëñ T) :
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))
      Ôëñ 5 * y / T := by
  have h_absx_nn : 0 Ôëñ |x| := abs_nonneg _
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hT_ge : T ÔëÑ 2 := by linarith
  have hT_pos : 0 < T := by linarith
  have hTpos2 : 0 < T / 2 := by linarith
  -- |x| Ôëñ T/2 - 1, y Ôëñ T/2 - 1, so T - |x| ÔëÑ T/2 + 1 > T/2
  have h_T_minus_x_lo : T / 2 Ôëñ T - |x| := by linarith
  have h_T_plus_x_lo : T Ôëñ T + |x| := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_T_plus_x_pos : 0 < T + |x| := by linarith
  -- First term: y┬À(T-|x|)/((T-|x|)┬▓+y┬▓) Ôëñ y/(T-|x|)
  have h_term1_bound : y * (T - |x|) / ((T - |x|)^2 + y^2) Ôëñ y / (T - |x|) := by
    rw [div_le_div_iffÔéÇ (by positivity : 0 < (T - |x|)^2 + y^2) h_T_minus_x_pos]
    nlinarith [sq_nonneg (T - |x|), sq_nonneg y]
  have h_term2_bound : y * (T + |x|) / ((T + |x|)^2 + y^2) Ôëñ y / (T + |x|) := by
    rw [div_le_div_iffÔéÇ (by positivity : 0 < (T + |x|)^2 + y^2) h_T_plus_x_pos]
    nlinarith [sq_nonneg (T + |x|), sq_nonneg y]
  -- y/(T-|x|) Ôëñ y/(T/2) = 2y/T
  have h_term1_le_2yT : y / (T - |x|) Ôëñ 2 * y / T := by
    rw [div_le_div_iffÔéÇ h_T_minus_x_pos hT_pos]
    nlinarith [h_T_minus_x_lo, hy_nn]
  have h_term2_le_yT : y / (T + |x|) Ôëñ y / T :=
    div_le_div_of_nonneg_left hy_nn hT_pos h_T_plus_x_lo
  -- Combine: total Ôëñ 2y/T + y/T = 3y/T Ôëñ 5y/T
  have h_total : y / (T - |x|) + y / (T + |x|) Ôëñ 3 * y / T := by
    have : 2 * y / T + y / T = 3 * y / T := by ring
    linarith [h_term1_le_2yT, h_term2_le_yT]
  have h3le5 : 3 * y / T Ôëñ 5 * y / T := by
    apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
    nlinarith
  linarith [h_term1_bound, h_term2_bound, h_total, h3le5]

/-- Ô¡É **PROVED ÔÇö Crude smooth-tail upper bound on the adaptive region.**
`smoothTail Ôëñ ¤ü(T)┬À5y/T Ôëñ T┬À5y/T = 5y Ôëñ 100┬Ày`. -/
lemma smoothTailRationalLowerBoundAbs_le_100y
    {x y T : ÔäØ}
    (hT2pi : 2 * Real.pi Ôëñ T)
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) Ôëñ T) :
    smoothTailRationalLowerBoundAbs x y T Ôëñ 100 * y := by
  unfold smoothTailRationalLowerBoundAbs
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have h_rho_le : zeroDensityRho T Ôëñ T := zeroDensityRho_le_T hT2pi
  have h_rho_nn : 0 Ôëñ zeroDensityRho T := by
    unfold zeroDensityRho
    have h_2pi_pos : 0 < 2 * Real.pi := by linarith
    have hT_2pi_ge_one : (1 : ÔäØ) Ôëñ T / (2 * Real.pi) := by
      rw [le_div_iffÔéÇ h_2pi_pos]; linarith
    have h_log_nn : 0 Ôëñ Real.log (T / (2 * Real.pi)) := Real.log_nonneg hT_2pi_ge_one
    positivity
  have h_kernel : (y * (T - |x|) / ((T - |x|)^2 + y^2)
                    + y * (T + |x|) / ((T + |x|)^2 + y^2))
                    Ôëñ 5 * y / T :=
    smoothTail_kernel_le_five_y_div_T hy hreg
  have h_kernel_nn :
      0 Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h_absx_nn : 0 Ôëñ |x| := abs_nonneg _
    have hT_ge : T ÔëÑ 2 := by linarith
    have h_T_minus_x_pos : 0 < T - |x| := by linarith
    have h_T_plus_x_pos : 0 < T + |x| := by linarith
    have h1 : 0 Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
      apply div_nonneg
      ┬À exact mul_nonneg hy_nn (le_of_lt h_T_minus_x_pos)
      ┬À positivity
    have h2 : 0 Ôëñ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
      apply div_nonneg
      ┬À exact mul_nonneg hy_nn (le_of_lt h_T_plus_x_pos)
      ┬À positivity
    linarith
  have h_combine :
      zeroDensityRho T * (y * (T - |x|) / ((T - |x|)^2 + y^2)
        + y * (T + |x|) / ((T + |x|)^2 + y^2))
        Ôëñ T * (5 * y / T) := by
    apply mul_le_mul h_rho_le h_kernel h_kernel_nn (by linarith)
  have h_T5y : T * (5 * y / T) = 5 * y := by
    field_simp
  have h_5y_le : 5 * y Ôëñ 100 * y := by linarith
  linarith

/-- Ô¡É **PROVED ÔÇö `linearDensityTail100` discharges the rational LB obligation.** -/
theorem linearDensityTail100_rationalLB :
    ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 2 * Real.pi Ôëñ T ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        smoothTailRationalLowerBoundAbs z.re z.im T
          Ôëñ -(linearDensityTail100 z).im := by
  intro z T hT2pi hy hreg
  rw [linearDensityTail100_neg_im]
  exact smoothTailRationalLowerBoundAbs_le_100y hT2pi hy hreg

