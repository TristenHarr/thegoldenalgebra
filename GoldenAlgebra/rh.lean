/-- тнР **PROVED тАФ Helper 1: box bound from adaptive region.**
On the adaptive region, `x┬▓ + y┬▓ тЙд (T/2 - 1)┬▓`. Removes repeated
geometry from every cert. -/
lemma x2_add_y2_le_T_half_sub_one_sq
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hy : 0 тЙд y)
    (hreg : 2 * (1 + x + y) тЙд T) :
    x^2 + y^2 тЙд (T / 2 - 1)^2 := by
  have hxy : x + y тЙд T / 2 - 1 := by linarith
  have hsum_nn : 0 тЙд x + y := by linarith
  have h_T_half_nn : 0 тЙд T / 2 - 1 := by linarith
  have hxyle : x^2 + y^2 тЙд (x + y)^2 := by
    nlinarith [mul_nonneg hx hy]
  have hsq_le : (x + y)^2 тЙд (T / 2 - 1)^2 := by
    have h1 : -(T/2 - 1) тЙд x + y := by linarith
    exact sq_le_sq' h1 hxy
  linarith

/-- **Helper 2 def**: `cloudK_T zeros T = ╬г 1/((T/2-1)┬▓ + ╬│┬▓)`. -/
noncomputable def cloudK_T (zeros : List тДЭ) (T : тДЭ) : тДЭ :=
  (zeros.map fun g => 1 / ((T / 2 - 1)^2 + g^2)).sum

/-- тнР **PROVED тАФ Helper 2: simpleCloudSum lower bound via adaptive box.**
Wraps `simpleCloudSum_ge_T_box_bound` with `M = T/2 - 1` extracted from
the adaptive region. The slab cert never needs to manually prove the
`x┬▓ + y┬▓` box bound. -/
lemma simpleCloudSum_ge_admissible_T_bound
    (zeros : List тДЭ) {x y T : тДЭ}
    (hx : 0 тЙд x) (hy : 0 < y)
    (hreg : 2 * (1 + x + y) тЙд T) :
    2 * y * cloudK_T zeros T тЙд simpleCloudSum zeros x y := by
  have hy0 : 0 тЙд y := le_of_lt hy
  have hbox : x^2 + y^2 тЙд (T / 2 - 1)^2 :=
    x2_add_y2_le_T_half_sub_one_sq hx hy0 hreg
  exact simpleCloudSum_ge_T_box_bound zeros x y (T / 2 - 1) hbox hy

/-- тнР **PROVED тАФ Helper 3a: `log(12/(2╧А)) тЙе 2/5`.**
Via `Real.add_one_le_exp(-2/5)` тЯ╣ `exp(2/5) тЙд 5/3 тЙд 12/(2╧А)`. -/
lemma log_12_div_2pi_ge_2_5 :
    (2 / 5 : тДЭ) тЙд Real.log (12 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_pos : 0 < Real.exp (2/5) := Real.exp_pos _
  have h_one_sub : (-(2/5 : тДЭ)) + 1 тЙд Real.exp (-(2/5)) := Real.add_one_le_exp _
  have h_35 : (3/5 : тДЭ) тЙд Real.exp (-(2/5)) := by linarith
  rw [Real.exp_neg] at h_35
  have h_exp_le : Real.exp (2/5) тЙд 5/3 := by
    have := mul_le_mul_of_nonneg_right h_35 (le_of_lt h_exp_pos)
    rw [inv_mul_cancelтВА (ne_of_gt h_exp_pos)] at this
    linarith
  have h_12_2pi_ge : (5/3 : тДЭ) тЙд 12 / (2 * Real.pi) := by
    rw [le_div_iffтВА h_2pi_pos]; nlinarith
  have h_T_ge_exp : Real.exp (2/5) тЙд 12 / (2 * Real.pi) :=
    le_trans h_exp_le h_12_2pi_ge
  have h := Real.log_le_log h_exp_pos h_T_ge_exp
  rwa [Real.log_exp] at h

/-- тнР **PROVED тАФ Helper 3b: `log(13/(2╧А)) тЙе 1/2`.**
Via `Real.add_one_le_exp(-1/2)` тЯ╣ `exp(1/2) тЙд 2 тЙд 13/(2╧А)`. -/
lemma log_13_div_2pi_ge_1_2 :
    (1 / 2 : тДЭ) тЙд Real.log (13 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_pos : 0 < Real.exp (1/2) := Real.exp_pos _
  have h_one_sub : (-(1/2 : тДЭ)) + 1 тЙд Real.exp (-(1/2)) := Real.add_one_le_exp _
  have h_half : (1/2 : тДЭ) тЙд Real.exp (-(1/2)) := by linarith
  rw [Real.exp_neg] at h_half
  have h_exp_le : Real.exp (1/2) тЙд 2 := by
    have := mul_le_mul_of_nonneg_right h_half (le_of_lt h_exp_pos)
    rw [inv_mul_cancelтВА (ne_of_gt h_exp_pos)] at this
    linarith
  have h_13_2pi_ge : (2 : тДЭ) тЙд 13 / (2 * Real.pi) := by
    rw [le_div_iffтВА h_2pi_pos]; nlinarith
  have h_T_ge_exp : Real.exp (1/2) тЙд 13 / (2 * Real.pi) :=
    le_trans h_exp_le h_13_2pi_ge
  have h := Real.log_le_log h_exp_pos h_T_ge_exp
