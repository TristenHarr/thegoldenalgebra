/-! ### Bridges: guarded Tendsto вЖТ guarded formula data -/

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ guarded mid formula data from guarded Tendsto.**
The proof copies `xiResidualCanonicalTailIdentity_of_complex_tendsto` but
threads the `XiPullback z вЙ† 0` guard through. The guard is consumed at
the call to `hResTendsto`, not at the analysis step. -/
def XiResidualCanonicalFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hResTendsto :
      вИА {z : вДВ},
        0 < z.im вЖТ
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
          2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        XiPullback z вЙ† 0 вЖТ
        Tendsto
          (fun X : вДЭ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop (рЭУЭ (xiResidualError M z))) :
    XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring M := by
  refine вЯ®?_вЯ©
  intro z hy hmid hne
  have hc := canonicalAdaptiveT_spec hmid
  have h_res_im :
      Tendsto
        (fun X : вДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop (рЭУЭ (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp (hResTendsto hy hmid hne)
  have h_tail_tendsto :=
    trueKernelAdaptiveTail_tendsto
      Dzero T0 hT0_pos hT0_le_10 hTuring
      hc.1 hc.2.1 hy hc.2.2
  have h_tail_im :
      Tendsto
        (fun X : вДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop
        (рЭУЭ (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ guarded high formula data from guarded Tendsto.**
Same chain as `xiHighResidualTailIdentity_of_complex_tendsto`, with the
`XiPullback z вЙ† 0` guard threaded through. -/
def XiHighResidualFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 вЙ§ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
