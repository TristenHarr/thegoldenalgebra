theorem FirstZeroAdjustedSBound_of_AdjustedGap_and_diffBound
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ D : тДЭ}
    (Hgap : FirstZeroGapForDzeroAdjusted Dzero T0 ╬│)
