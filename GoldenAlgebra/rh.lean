-- =====================================================================
-- ┬ºCCXLVI. Tail additivity and cutoff-change formula
-- =====================================================================
-- The raw improper tail genuinely depends on `T`. Before assuming any
-- form of `htail_indep`, we expose the exact cutoff-change relation:
--
--   tail(TÔéü) = Ôê½_{TÔéü}^{TÔéé} kernel┬ÀS + tail(TÔéé)
--
-- On Im, this lands on the real `derivativeSidePartial` and hence on
-- the integral of `S ┬À pairedCauchyImKernelDeriv` ÔÇö the explicit
-- finite-correction term that determines when (and only when) tail Im
-- is invariant in `T`.
--
-- Adds:
--   complexDensityTailPartial_add_adjacent                    ÔÇö finite splitting
--   trueKernelAdaptiveTail_eq_finite_add_tail                 ÔÇö limit additivity
--   trueKernelAdaptiveTail_im_sub_eq_finite_real_integral     ÔÇö Im cutoff-change

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö finite partial additivity.** Splits a finite
complex partial `[TÔéü, X]` across an intermediate cutoff `TÔéé`. Direct
application of `intervalIntegral.integral_add_adjacent_intervals`
after restricting the global integrability to each subinterval via
`IntervalIntegrable.mono_set`. -/
lemma complexDensityTailPartial_add_adjacent
    (kernel : ÔäØ ÔåÆ Ôäé ÔåÆ Ôäé) (S : ÔäØ ÔåÆ ÔäØ)
    {TÔéü TÔéé X : ÔäØ} (z : Ôäé)
    (h12 : TÔéü Ôëñ TÔéé) (h2X : TÔéé Ôëñ X)
    (hInt :
      IntervalIntegrable
        (fun u => kernel u z * (S u : Ôäé))
        MeasureTheory.volume TÔéü X) :
    complexDensityTailPartial kernel S TÔéü X z =
      complexDensityTailPartial kernel S TÔéü TÔéé z +
      complexDensityTailPartial kernel S TÔéé X z := by
  unfold complexDensityTailPartial
  have h1X : TÔéü Ôëñ X := le_trans h12 h2X
  have hInt_12 : IntervalIntegrable
      (fun u => kernel u z * (S u : Ôäé))
      MeasureTheory.volume TÔéü TÔéé := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h12, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_right h2X
  have hInt_2X : IntervalIntegrable
      (fun u => kernel u z * (S u : Ôäé))
      MeasureTheory.volume TÔéé X := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h2X, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_left h12
  exact (intervalIntegral.integral_add_adjacent_intervals hInt_12 hInt_2X).symm

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `trueKernelAdaptiveTail` additivity across
adaptive cutoffs.** For `TÔéü Ôëñ TÔéé` both in the adaptive band at `z`,

  `trueKernelAdaptiveTail TÔéü z
     = finite[TÔéü,TÔéé] partial + trueKernelAdaptiveTail TÔéé z`.

Proof: both tails are pointwise limits of complex partials; for
`X ÔëÑ TÔéé` the partial at `TÔéü` splits via ┬ºCCXLVI-1; the finite
`[TÔéü, TÔéé]` partial is constant in `X`; uniqueness of limits closes. -/
theorem trueKernelAdaptiveTail_eq_finite_add_tail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : Ôäé} {TÔéü TÔéé : ÔäØ}
    (h1 : 10 Ôëñ TÔéü) (h1' : TÔéü Ôëñ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) Ôëñ TÔéü)
    (h2 : 10 Ôëñ TÔéé) (h2' : TÔéé Ôëñ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) Ôëñ TÔéé)
    (h12 : TÔéü Ôëñ TÔéé) :
    trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéü z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z
      + trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z := by
  -- Local helper: convergence directly to `trueKernelAdaptiveTail ... T z`
  have hconv_at : ÔêÇ {T : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      Tendsto (fun X : ÔäØ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (­ØôØ (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z)) := by
    intro T hT10 hT140 hTreg
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring hT10 hT140 hy hTreg
    have hregion :
        10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 0 < z.im Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T :=
      Ôƒ¿hT10, hT140, hy, hTregÔƒ®
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists
  have hT1_conv := hconv_at h1 h1' hr1
  have hT2_conv := hconv_at h2 h2' hr2
  have hsplit_ev : ÔêÇßÂá X : ÔäØ in Filter.atTop,
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü X z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z +
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéé X z := by
    filter_upwards [Filter.eventually_ge_atTop TÔéé] with X hT2X
    have h1X : TÔéü Ôëñ X := le_trans h12 hT2X
    have hInt :=
      true_int_of_finiteFluctuation
        Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h1X
    exact complexDensityTailPartial_add_adjacent
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z h12 hT2X hInt
  have h_const_finite :
      Tendsto (fun _ : ÔäØ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TÔéü TÔéé z) Filter.atTop
      (­ØôØ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z)) := tendsto_const_nhds
  have h_sum_tendsto :
      Tendsto (fun X : ÔäØ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TÔéü TÔéé z +
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TÔéé X z) Filter.atTop
      (­ØôØ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z)) :=
    h_const_finite.add hT2_conv
  have hT1_to_sum :
      Tendsto (fun X : ÔäØ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TÔéü X z) Filter.atTop
      (­ØôØ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z)) :=
    h_sum_tendsto.congr' (hsplit_ev.mono (fun X hX => hX.symm))
  exact tendsto_nhds_unique hT1_conv hT1_to_sum

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö cutoff-change formula on Im (the real
finite correction term).** Subtracting `Im` across the additivity
theorem lands on the explicit real integral

  `(tail TÔéü).im ÔêÆ (tail TÔéé).im
     = Ôê½_{TÔéü}^{TÔéé} S(u) ┬À pairedCauchyImKernelDeriv z.re z.im u du`,

where `S = Phase1IBP.finiteFluctuationPrimitive Dzero T0`. This is the
honest cutoff-dependence ÔÇö `htail_indep` holds (in Im) iff the RHS
vanishes; in general it does not, and any formula combining `model`
with `error` must absorb this finite correction. -/
theorem trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : Ôäé} {TÔéü TÔéé : ÔäØ}
    (h1 : 10 Ôëñ TÔéü) (h1' : TÔéü Ôëñ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) Ôëñ TÔéü)
    (h2 : 10 Ôëñ TÔéé) (h2' : TÔéé Ôëñ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) Ôëñ TÔéé)
    (h12 : TÔéü Ôëñ TÔéé) :
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéü z).im -
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z).im
      = Ôê½ u in TÔéü..TÔéé,
          Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
            pairedCauchyImKernelDeriv z.re z.im u := by
  have hadd := trueKernelAdaptiveTail_eq_finite_add_tail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    h1 h1' hy hr1 h2 h2' hr2 h12
  have him_sum := congrArg Complex.im hadd
  simp only [Complex.add_im] at him_sum
  have him_diff :
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéü z).im -
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z).im =
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TÔéü TÔéé z).im := by
    linarith
  rw [him_diff]
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hInt_true := true_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_wrap := wrap_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_true_uhp : IntervalIntegrable
      (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im) *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ÔäØ) : Ôäé))
