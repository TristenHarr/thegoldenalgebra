theorem StieltjesMidHighTailContributionData_of_convergence_and_equality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : вДЭ} {ZC : вДВ вЖТ вДВ}
    (Hconv_mid :
      вИА {z : вДВ},
        0 < z.im вЖТ
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
          2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        вИГ L : вДВ, XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L)
    (Hconv_high :
      вИА {z : вДВ} {T : вДЭ},
        140 вЙ§ T вЖТ
        0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        вИГ L : вДВ, XiFluctuationTailValue Dzero T0 T z L)
    (Heq : StieltjesMidHighTailEquality Dzero T0 ZC) :
    StieltjesMidHighTailContributionData Dzero T0 ZC := by
  refine вЯ®?_, ?_вЯ©
  ¬Ј intro z hy hm
    obtain вЯ®L, hLвЯ© := Hconv_mid hy hm
    exact вЯ®L, hL, Heq.mid_eq hy hm hLвЯ©
  ¬Ј intro z T hT hy hr
    obtain вЯ®L, hLвЯ© := Hconv_high hT hy hr
    exact вЯ®L, hL, Heq.high_eq hT hy hr hLвЯ©

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **PATH B
FINAL FRONT DOOR (regional mid/high tail + low)**.

Replaces the over-strong global `StieltjesTailContributionData` with
the regionally-correct `StieltjesMidHighTailContributionData`. The
Stieltjes theorem now matches the actual analytic use cases вАФ mid at
canonical T, high at any T вЙ• 140 вАФ without quantifying over irrelevant
small T.

```
hTuring + hHighLog                                      (parallel agent)
+ Hsrc       : XiHadamardLogDerivativeSource             (A)
+ HtailMidHi : StieltjesMidHighTailContributionData ... ZC   (B1 regional)
+ Hlow       : StieltjesLowContributionData ... ZC       (B2)
+ h_Z_ge_15                                              (trivial)
вЯє XiPullbackAntiHerglotzTarget
```

The mid/high Stieltjes target is now matched to actual regimes. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesMidHighTailLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : вИА i : вДХ, (15 : вДЭ) вЙ§ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (HtailMidHi :
      StieltjesMidHighTailContributionData
        Dzero 10 Hsrc.zeroContribution)
    (Hlow :
      StieltjesLowContributionData
        Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget := by
  have Htail_fmla :
      XiMidHighTailExplicitFormula
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiMidHighTailExplicitFormula_of_hadamardSource_and_midHighTailData
      Hsrc HtailMidHi
  have Htail_decomp :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiLogDerivativeModelTailDecomposition_of_midHighTailFormula Htail_fmla
  have HlowA :
      XiLowResidualImEqBoundaryAddIntegralIm
        Dzero 10 honestZeroDensityModelTwoPi := by
    refine вЯ®?_вЯ©
    intro z hz
    have hy : 0 < z.im := hz.1
    have h_resid :
        (xiResidualError honestZeroDensityModelTwoPi z).im
          = (Hsrc.zeroContribution z
              - honestZeroDensityModelTwoPi.model z).im := by
      unfold xiResidualError
      rw [Hsrc.logDeriv_eq_zeroContribution z hy]
    rw [h_resid, honestZeroDensityModelTwoPi_model_eq z]
    exact Hlow.low_value z hz
  exact XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowCorrectedSplit
    Dzero h_Z_ge_15 hTuring hHighLog Htail_decomp HlowA

-- =====================================================================
-- ¬ІCCCXI. B1-conv: tail convergence from log envelopes
-- =====================================================================
-- Discharges the convergence half of `StieltjesMidHighTailContributionData`
-- using existing `trueKernelComplexTail_converges_at_of_logEnvelope`
-- + `hTuring` / `hHighLog`. After this, B1's only remaining content is
-- `StieltjesMidHighTailEquality`.

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ mid convergence at canonical T from `hTuring`.**
For every `z` in the adaptive region, `XiFluctuationTailValue` exists at
`canonicalAdaptiveT z`. Convergence is supplied by the log-envelope
machinery applied to the Turing bound at the canonical T. -/
theorem XiFluctuationTailValue_exists_mid_of_turing
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2) :
    вИА {z : вДВ},
      0 < z.im вЖТ
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
        2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
      вИГ L : вДВ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L := by
  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  have h10 : 10 вЙ§ canonicalAdaptiveT z := hc.1
  have h140 : canonicalAdaptiveT z вЙ§ 140 := hc.2.1
  have hregime : 2 * (1 + |z.re| + z.im) вЙ§ canonicalAdaptiveT z := hc.2.2
  have hT0leT : T0 вЙ§ canonicalAdaptiveT z := by linarith
  have hTpos : 0 < canonicalAdaptiveT z := by linarith
  have hEnv :
      вИАбґ† u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD (canonicalAdaptiveT z)).1 * Real.log u
              + (slabCD (canonicalAdaptiveT z)).2 := by
    filter_upwards [Filter.eventually_ge_atTop (canonicalAdaptiveT z)] with u hu
    exact hTuring h10 h140 hy hregime hu
  obtain вЯ®L, hLвЯ© :=
    trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0leT hTpos hy hEnv
  exact вЯ®L, вЯ®hLвЯ©вЯ©

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ high convergence at any `T вЙ• 140` from `hHighLog`.**
For every `z` with `0 < z.im` and any `T вЙ• 140` in the regime,
`XiFluctuationTailValue` exists at `T`. -/
theorem XiFluctuationTailValue_exists_high_of_highLog
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 вЙ§ 140)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ)) :
    вИА {z : вДВ} {T : вДЭ},
      140 вЙ§ T вЖТ
      0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      вИГ L : вДВ,
        XiFluctuationTailValue Dzero T0 T z L := by
  intro z T hT140 hy hregime
  have hT0leT : T0 вЙ§ T := by linarith
  have hTpos : 0 < T := by linarith
  have hEnv :
      вИАбґ† u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  obtain вЯ®L, hLвЯ© :=
    trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0leT hTpos hy hEnv
  exact вЯ®L, вЯ®hLвЯ©вЯ©

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `StieltjesMidHighTailContributionData` from
Turing + highLog + equality.** Composes the two convergence theorems
(mid, high) with `StieltjesMidHighTailEquality` via the
