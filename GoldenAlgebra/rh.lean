  derivative_tendsto := by
    intro z T h10 h140 hy hregime
    exact R.deriv_tendsto h10 h140 hy hregime
  derivative_bound := by
    intro z T J h10 h140 hy hregime hJ
    exact R.deriv_bound h10 h140 hy hregime hJ

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ full `ActualDensityTailData` from wrapper
