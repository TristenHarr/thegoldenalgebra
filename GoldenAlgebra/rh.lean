    push_neg at h1
    by_cases h2 : T Ôëñ 8
    ┬À exact I.cert_7_8 z T (le_of_lt h1) h2 hy hreg
    push_neg at h2
    by_cases h3 : T Ôëñ 9
    ┬À exact I.cert_8_9 z T (le_of_lt h2) h3 hy hreg
