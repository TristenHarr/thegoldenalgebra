-- =====================================================================
-- ┬зCCCXX. Hadamard product formula scaffold
-- =====================================================================
-- A more directly-Hadamard-shaped source: gives the Hadamard product
-- equality plus the product-side log-derivative. Provides exactly the
-- API the Hadamard agent needs to inhabit.

/-- ЁЯУж **`CompletedXiHadamardProductFormula`** тАФ Hadamard product
formula scaffold. Splits the Hadamard content into:
* `product_eq` тАФ `completedXiFunction = productSide` (factorization);
* `product_differentiable_at` тАФ productSide differentiability AFZ;
* `product_logDeriv_eq` тАФ productSide log-derivative equals the
  abstract `xiZeroContribution`. -/
structure CompletedXiHadamardProductFormula : Type where
  xiZeroContribution : тДВ тЖТ тДВ
  productSide : тДВ тЖТ тДВ
  product_eq :
    тИА s : тДВ, completedXiFunction s = productSide s
  product_differentiable_at :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      DifferentiableAt тДВ productSide s
  product_logDeriv_eq :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      logDerivativeResponse productSide s = xiZeroContribution s

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `CompletedXiLogDerivativeSourceAFZ` from
Hadamard product formula.** Transfers differentiability and
log-derivative via `product_eq` (pointwise function equality). -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductFormula
    (H : CompletedXiHadamardProductFormula) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := H.xiZeroContribution
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  ┬╖ intro s hs
    have hfun_eq : completedXiFunction = H.productSide := funext H.product_eq
    rw [hfun_eq]
    exact H.product_differentiable_at s hs
  ┬╖ intro s hs
    have hfun_eq : completedXiFunction = H.productSide := funext H.product_eq
    have h := H.product_logDeriv_eq s hs
    unfold logDerivativeResponse at h тКв
    rw [hfun_eq]
    exact h

-- =====================================================================
-- ┬зCCCXXI. Finite canonical Hadamard product scaffolds
-- =====================================================================
-- Genus-1 Weierstrass factor `EтВБ(s/╧Б) = (1 - s/╧Б) ┬╖ exp(s/╧Б)` and
-- the finite Hadamard product. Uses Mathlib's `logDeriv_prod` for the
-- structural log-derivative-of-product identity. The per-factor
-- log-derivative computation `logDeriv (EтВБ(┬╖/╧Б)) s = 1/(s-╧Б) + 1/╧Б`
-- is deferred to a future stride.

/-- **Genus-1 Hadamard factor** `EтВБ(s/╧Б) = (1 - s/╧Б) ┬╖ exp(s/╧Б)`. -/
noncomputable def hadamardGenus1Factor (╧Б s : тДВ) : тДВ :=
  (1 - s / ╧Б) * Complex.exp (s / ╧Б)

/-- тнР **PROVED тАФ genus-1 factor non-vanishing when `s тЙа ╧Б` and `╧Б тЙа 0`.** -/
lemma hadamardGenus1Factor_ne_zero {╧Б s : тДВ} (h╧Б : ╧Б тЙа 0) (hs╧Б : s тЙа ╧Б) :
    hadamardGenus1Factor ╧Б s тЙа 0 := by
  unfold hadamardGenus1Factor
  apply mul_ne_zero
  ┬╖ intro h
    have h1 : s / ╧Б = 1 := by linear_combination -h
    have h2 : s = ╧Б := by
      have := h1
      field_simp at this
      exact this
    exact hs╧Б h2
  ┬╖ exact Complex.exp_ne_zero _

/-- тнР **PROVED тАФ genus-1 factor is differentiable everywhere.** -/
lemma hadamardGenus1Factor_differentiableAt (╧Б s : тДВ) :
    DifferentiableAt тДВ (hadamardGenus1Factor ╧Б) s := by
  unfold hadamardGenus1Factor
  have h_left : DifferentiableAt тДВ (fun y : тДВ => 1 - y / ╧Б) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner : DifferentiableAt тДВ (fun y : тДВ => y / ╧Б) s :=
    differentiableAt_id'.div_const _
  have h_right : DifferentiableAt тДВ (fun y : тДВ => Complex.exp (y / ╧Б)) s :=
    h_inner.cexp
  exact h_left.mul h_right

/-- **Finite Hadamard product** over a finite list of zero ordinates. -/
noncomputable def finiteHadamardProduct (zeros : Finset тДВ) (s : тДВ) : тДВ :=
  тИП ╧Б тИИ zeros, hadamardGenus1Factor ╧Б s

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `logDeriv` of the finite Hadamard product = ╬г of
per-factor `logDeriv`s.** Direct application of Mathlib's
`logDeriv_prod`. -/
theorem logDeriv_finiteHadamardProduct
    {zeros : Finset тДВ} {s : тДВ}
    (h╧Б_ne : тИА ╧Б тИИ zeros, ╧Б тЙа 0)
    (hs_ne : тИА ╧Б тИИ zeros, s тЙа ╧Б) :
    logDeriv (finiteHadamardProduct zeros) s
      = тИС ╧Б тИИ zeros, logDeriv (hadamardGenus1Factor ╧Б) s := by
  unfold finiteHadamardProduct
  exact logDeriv_prod zeros (fun ╧Б => hadamardGenus1Factor ╧Б) s
    (fun ╧Б h╧Б => hadamardGenus1Factor_ne_zero (h╧Б_ne ╧Б h╧Б) (hs_ne ╧Б h╧Б))
    (fun ╧Б _ => hadamardGenus1Factor_differentiableAt ╧Б s)

/-- тнР **PROVED тАФ bridge between `logDeriv` (Mathlib) and
`logDerivativeResponse` (this file).** Definitionally equal. -/
theorem logDerivativeResponse_eq_logDeriv (f : тДВ тЖТ тДВ) (z : тДВ) :
    logDerivativeResponse f z = logDeriv f z := rfl

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `logDerivativeResponse` of the finite Hadamard
product = ╬г of per-factor responses.** Same as `logDeriv_finiteHadamardProduct`
under the definitional equality. -/
theorem logDerivativeResponse_finiteHadamardProduct
    {zeros : Finset тДВ} {s : тДВ}
    (h╧Б_ne : тИА ╧Б тИИ zeros, ╧Б тЙа 0)
    (hs_ne : тИА ╧Б тИИ zeros, s тЙа ╧Б) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = тИС ╧Б тИИ zeros, logDerivativeResponse (hadamardGenus1Factor ╧Б) s := by
  simp only [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct h╧Б_ne hs_ne

-- =====================================================================
-- ┬зCCCXXII. Per-factor log-derivative of the genus-1 Hadamard factor
-- =====================================================================
-- Closes the explicit value of `logDeriv (hadamardGenus1Factor ╧Б) s`
-- as the classical `1/(s-╧Б) + 1/╧Б`. Combined with ┬зCCCXXI's finite
-- product log-derivative, this gives the regularized zero-sum form of
-- the finite Hadamard product log-derivative.

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ per-factor log-derivative of the genus-1
Hadamard factor.** `logDeriv ((1 - ┬╖/╧Б) ┬╖ exp(┬╖/╧Б)) s = 1/(s-╧Б) + 1/╧Б`. -/
theorem logDeriv_hadamardGenus1Factor {╧Б s : тДВ} (h╧Б : ╧Б тЙа 0) (hs : s тЙа ╧Б) :
    logDeriv (hadamardGenus1Factor ╧Б) s = 1 / (s - ╧Б) + 1 / ╧Б := by
  have h_left_diff : DifferentiableAt тДВ (fun y : тДВ => 1 - y/╧Б) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner_diff : DifferentiableAt тДВ (fun y : тДВ => y/╧Б) s :=
    differentiableAt_id'.div_const _
  have h_right_diff : DifferentiableAt тДВ (fun y : тДВ => Complex.exp (y/╧Б)) s :=
    h_inner_diff.cexp
  have hsm╧Б : s - ╧Б тЙа 0 := sub_ne_zero.mpr hs
  have h_left_ne : (1 : тДВ) - s/╧Б тЙа 0 := by
    intro h
    have h1 : s/╧Б = 1 := by linear_combination -h
    apply hs
    field_simp at h1
    exact h1
  have h_exp_ne : Complex.exp (s/╧Б) тЙа 0 := Complex.exp_ne_zero _
  have h_deriv_inner : deriv (fun y : тДВ => y/╧Б) s = 1/╧Б := by
    rw [deriv_div_const, deriv_id'']
  have h_deriv_left : deriv (fun y : тДВ => 1 - y/╧Б) s = -(1/╧Б) := by
    rw [deriv_sub (differentiableAt_const _) (differentiableAt_id'.div_const _),
        deriv_const, h_deriv_inner]
    ring
  have h_deriv_right : deriv (fun y : тДВ => Complex.exp (y/╧Б)) s
      = Complex.exp (s/╧Б) * (1/╧Б) := by
    rw [deriv_cexp h_inner_diff, h_deriv_inner]
  have h╧Бs : ╧Б - s тЙа 0 := sub_ne_zero.mpr (Ne.symm hs)
  rw [logDeriv_apply]
  unfold hadamardGenus1Factor
  rw [deriv_mul h_left_diff h_right_diff, h_deriv_left, h_deriv_right]
  -- Factor `Complex.exp (s/╧Б)` out of numerator and cancel with denominator
  rw [show -(1 / ╧Б) * Complex.exp (s / ╧Б)
            + (1 - s / ╧Б) * (Complex.exp (s / ╧Б) * (1 / ╧Б))
          = Complex.exp (s / ╧Б) * (-(1 / ╧Б) + (1 - s / ╧Б) * (1 / ╧Б)) from by ring,
      show (1 - s / ╧Б) * Complex.exp (s / ╧Б)
          = Complex.exp (s / ╧Б) * (1 - s / ╧Б) from by ring,
      mul_div_mul_left _ _ h_exp_ne]
  -- Now: (-(1/╧Б) + (1 - s/╧Б) * (1/╧Б)) / (1 - s/╧Б) = 1/(s-╧Б) + 1/╧Б
  -- Simplify numerator to -s/╧Б┬▓
  rw [show -(1 / ╧Б) + (1 - s / ╧Б) * (1 / ╧Б) = -s / ╧Б ^ 2 from by
        field_simp; ring]
  -- Now: (-s/╧Б┬▓) / (1 - s/╧Б) = 1/(s-╧Б) + 1/╧Б
  rw [show (1 : тДВ) - s / ╧Б = (╧Б - s) / ╧Б from by field_simp]
  -- Now: (-s/╧Б┬▓) / ((╧Б - s)/╧Б) = 1/(s-╧Б) + 1/╧Б
  field_simp
  ring

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ per-factor `logDerivativeResponse` of the genus-1
Hadamard factor.** Same identity under the definitional bridge. -/
theorem logDerivativeResponse_hadamardGenus1Factor
    {╧Б s : тДВ} (h╧Б : ╧Б тЙа 0) (hs : s тЙа ╧Б) :
    logDerivativeResponse (hadamardGenus1Factor ╧Б) s = 1 / (s - ╧Б) + 1 / ╧Б := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_hadamardGenus1Factor h╧Б hs

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ regularized form of the finite Hadamard product
log-derivative.** `logDeriv (finiteHadamardProduct zeros) s =
╬г_{╧Б тИИ zeros} (1/(s-╧Б) + 1/╧Б)`. The classical paired/regularized zero
sum. -/
theorem logDeriv_finiteHadamardProduct_regularized
    {zeros : Finset тДВ} {s : тДВ}
    (h╧Б_ne : тИА ╧Б тИИ zeros, ╧Б тЙа 0)
    (hs_ne : тИА ╧Б тИИ zeros, s тЙа ╧Б) :
    logDeriv (finiteHadamardProduct zeros) s
      = тИС ╧Б тИИ zeros, (1 / (s - ╧Б) + 1 / ╧Б) := by
  rw [logDeriv_finiteHadamardProduct h╧Б_ne hs_ne]
  apply Finset.sum_congr rfl
  intro ╧Б h╧Бmem
  exact logDeriv_hadamardGenus1Factor (h╧Б_ne ╧Б h╧Бmem) (hs_ne ╧Б h╧Бmem)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ regularized form of the finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_finiteHadamardProduct_regularized
    {zeros : Finset тДВ} {s : тДВ}
    (h╧Б_ne : тИА ╧Б тИИ zeros, ╧Б тЙа 0)
    (hs_ne : тИА ╧Б тИИ zeros, s тЙа ╧Б) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = тИС ╧Б тИИ zeros, (1 / (s - ╧Б) + 1 / ╧Б) := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct_regularized h╧Б_ne hs_ne

-- =====================================================================
-- ┬зCCCXXIII. Mathlib infinite-product / series API audit
-- =====================================================================
-- Located in `Mathlib/Topology/Algebra/InfiniteSum/Defs.lean`:
--   * `HasProd f a := Tendsto (тИП b тИИ s, f b) atTop (ЁЭУЭ a)` (Finset net).
--   * `Multipliable f := тИГ a, HasProd f a`.
--   * `tprod f`, notation `тИП' i, f i` (irreducible_def, falls back to 1).
--   * Additive analogues via `@[to_additive]`: `HasSum`, `Summable`, `tsum`,
--     `тИС' i, f i`.
--
-- For locally uniform convergence (needed for product = entire function):
--   `Mathlib/Topology/Algebra/InfiniteSum/UniformOn.lean`:
--     * `HasProdLocallyUniformlyOn`, `MultipliableLocallyUniformlyOn`.
--   `Mathlib/Analysis/NormedSpace/MultipliableUniformlyOn.lean`:
--     * normed-space adapted lemmas.
--
-- These are the right APIs for the infinite Hadamard product. Use
-- `HasProd` / `tprod` for the product value; `HasSum` / `tsum` for the
-- regularized log-derivative series.

-- =====================================================================
-- ┬зCCCXXIV. Infinite Hadamard product + regularized log-deriv series
-- =====================================================================
-- Lifts the finite Hadamard products to the indexed/infinite setting.
-- Introduces the named target series so the analytic agent can prove
-- the convergence/equality statements directly.

/-- **Indexed infinite Hadamard product** over an arbitrary index set
of zero ordinates. Falls back to `1` when not multipliable (Mathlib's
`tprod` convention). -/
noncomputable def infiniteHadamardProduct
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) (s : тДВ) : тДВ :=
  тИП' i : ╬╣, hadamardGenus1Factor (zeroLoc i) s

/-- **Indexed regularized log-derivative series**: the term-wise sum
`╬г (1/(s-╧Бс╡в) + 1/╧Бс╡в)` that the infinite Hadamard log-derivative should
converge to. Falls back to `0` when not summable. -/
noncomputable def hadamardRegularizedLogDerivSeries
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) (s : тДВ) : тДВ :=
  тИС' i : ╬╣, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Finite regularized log-derivative sum** over a Finset. -/
noncomputable def finiteHadamardRegularizedSum
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) (F : Finset ╬╣) (s : тДВ) : тДВ :=
  тИС i тИИ F, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Indexed finite Hadamard product**: the partial product over a
Finset, used for finite truncations of `infiniteHadamardProduct`. -/
noncomputable def indexedFiniteHadamardProduct
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) (F : Finset ╬╣) (s : тДВ) : тДВ :=
  тИП i тИИ F, hadamardGenus1Factor (zeroLoc i) s

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ indexed finite Hadamard product log-derivative.**
The log-derivative of the indexed finite product equals the
indexed regularized sum. -/
theorem logDeriv_indexedFiniteHadamardProduct
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {F : Finset ╬╣} {s : тДВ}
    (h╧Б : тИА i тИИ F, zeroLoc i тЙа 0)
    (hs : тИА i тИИ F, s тЙа zeroLoc i) :
    logDeriv (fun s' : тДВ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  unfold indexedFiniteHadamardProduct finiteHadamardRegularizedSum
  rw [logDeriv_prod F (fun i s' => hadamardGenus1Factor (zeroLoc i) s') s
        (fun i hi => hadamardGenus1Factor_ne_zero (h╧Б i hi) (hs i hi))
        (fun i _ => hadamardGenus1Factor_differentiableAt (zeroLoc i) s)]
  apply Finset.sum_congr rfl
  intro i hi
  exact logDeriv_hadamardGenus1Factor (h╧Б i hi) (hs i hi)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ indexed finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {F : Finset ╬╣} {s : тДВ}
    (h╧Б : тИА i тИИ F, zeroLoc i тЙа 0)
    (hs : тИА i тИИ F, s тЙа zeroLoc i) :
    logDerivativeResponse
        (fun s' : тДВ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_indexedFiniteHadamardProduct h╧Б hs

-- =====================================================================
-- ┬зCCCXXV. Locally-uniform Hadamard product analytic data
-- =====================================================================
-- The data structure that says: "this genus-1 infinite product is
-- analytically legitimate on the points where ╬╛ is non-zero, and its
-- log-derivative equals the regularized zero-sum series."
--
-- The Mathlib `MultipliableLocallyUniformlyOn` Prop is the natural
-- analytic-agent target for inhabiting `product_differentiable_at_xi_nonzero`
-- and `logDeriv_eq_tsum_at_xi_nonzero`; we expose those AFZ-projected
-- consequences directly rather than threading the universe-quantified
-- LUC predicate through the bundle.

/-- ЁЯУж **`HadamardLocallyUniformProductData`** тАФ the analytic
legitimacy package for the infinite genus-1 Hadamard product. -/
structure HadamardLocallyUniformProductData
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) : Type where
  product_multipliable :
    тИА s : тДВ,
      Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s
  product_differentiable_at_xi_nonzero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      DifferentiableAt тДВ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at_xi_nonzero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at_xi_nonzero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- ┬зCCCXXVI. Hadamard product with zeros + bridge to ╬╛-side AFZ source
-- =====================================================================

/-- ЁЯУж **`CompletedXiHadamardProductWithZeros`** тАФ the classical
Hadamard product representation of `completedXiFunction` with a
possible analytic prefactor. Parameterized by the zero index type `╬╣`. -/
structure CompletedXiHadamardProductWithZeros (╬╣ : Type) : Type where
  zeroLoc : ╬╣ тЖТ тДВ
  prefactor : тДВ тЖТ тДВ
  prefactor_differentiable_at :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      DifferentiableAt тДВ prefactor s
  prefactor_ne_zero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      prefactor s тЙа 0
  xi_eq_product :
    тИА s : тДВ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s
  product_data : HadamardLocallyUniformProductData zeroLoc

/-- **Zero contribution from a Hadamard-with-zeros bundle**:
`logDeriv prefactor + tsum regularized`. -/
noncomputable def xiZeroContributionFromHadamard
    {╬╣ : Type} (H : CompletedXiHadamardProductWithZeros ╬╣) : тДВ тЖТ тДВ :=
  fun s =>
    logDerivativeResponse H.prefactor s
      + hadamardRegularizedLogDerivSeries H.zeroLoc s

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `CompletedXiLogDerivativeSourceAFZ` from
Hadamard-with-zeros bundle.** Uses `logDeriv_mul` (Mathlib) to split
the log-derivative of `prefactor ┬╖ product`, then identifies the
product's log-derivative with the regularized series via
`product_data.logDeriv_eq_tsum_at_xi_nonzero`. -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    {╬╣ : Type} (H : CompletedXiHadamardProductWithZeros ╬╣) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := xiZeroContributionFromHadamard H
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  ┬╖ intro s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    rw [hxi_eq_fun]
    exact (H.prefactor_differentiable_at s hs).mul
      (H.product_data.product_differentiable_at_xi_nonzero s hs)
  ┬╖ intro s hs
    have h_pref_ne : H.prefactor s тЙа 0 := H.prefactor_ne_zero s hs
    have h_prod_ne : infiniteHadamardProduct H.zeroLoc s тЙа 0 := by
      intro h
      apply hs
      rw [H.xi_eq_product s, h, mul_zero]
    have h_pref_diff := H.prefactor_differentiable_at s hs
    have h_prod_diff := H.product_data.product_differentiable_at_xi_nonzero s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    calc logDerivativeResponse completedXiFunction s
        = logDeriv completedXiFunction s := rfl
      _ = logDeriv (H.prefactor * infiniteHadamardProduct H.zeroLoc) s := by
          rw [hxi_eq_fun]
      _ = logDeriv H.prefactor s
            + logDeriv (infiniteHadamardProduct H.zeroLoc) s :=
          logDeriv_mul s h_pref_ne h_prod_ne h_pref_diff h_prod_diff
      _ = logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroLoc s := by
          rw [тЖР logDerivativeResponse_eq_logDeriv (f := H.prefactor),
              тЖР logDerivativeResponse_eq_logDeriv
                  (f := infiniteHadamardProduct H.zeroLoc),
              H.product_data.logDeriv_eq_tsum_at_xi_nonzero s hs]
      _ = xiZeroContributionFromHadamard H s := rfl

-- =====================================================================
-- ┬зCCCXXVII. Log-derivative limit data (separate from convergence)
-- =====================================================================
-- The product-convergence content (`Multipliable`) is independent of
-- the log-derivative content (differentiability + summability + log-deriv
-- equal to tsum). Isolate the latter into its own data bundle, keyed by
-- an arbitrary `region : Set тДВ`. The bridge to
-- `HadamardLocallyUniformProductData` then takes a region-coverage
-- hypothesis (AFZ тКЖ region).

/-- ЁЯУж **`HadamardLogDerivLimitData`** тАФ the log-derivative-of-limit
content, packaged on an arbitrary `region : Set тДВ`. The genuine
analytic theorem (log-deriv interchanges with locally uniform
convergence) inhabits this bundle on the AFZ region of `╬╛`. -/
structure HadamardLogDerivLimitData
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) : Type where
  region : Set тДВ
  product_differentiable_at :
    тИА s тИИ region,
      DifferentiableAt тДВ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at :
    тИА s тИИ region,
      Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at :
    тИА s тИИ region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `HadamardLocallyUniformProductData` from
log-derivative limit data + region coverage.** -/
noncomputable def HadamardLocallyUniformProductData.of_logDerivLimitData
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ}
    (Hprod :
      тИА s : тДВ,
        Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s)
    (Hlim : HadamardLogDerivLimitData zeroLoc)
    (h_region :
      тИА s : тДВ, completedXiFunction s тЙа 0 тЖТ s тИИ Hlim.region) :
    HadamardLocallyUniformProductData zeroLoc :=
  { product_multipliable := Hprod
    product_differentiable_at_xi_nonzero := fun s hs =>
      Hlim.product_differentiable_at s (h_region s hs)
    regularized_summable_at_xi_nonzero := fun s hs =>
      Hlim.regularized_summable_at s (h_region s hs)
    logDeriv_eq_tsum_at_xi_nonzero := fun s hs =>
      Hlim.logDeriv_eq_tsum_at s (h_region s hs) }

-- =====================================================================
-- ┬зCCCXXVIII. Finite exhaustion interface
-- =====================================================================
-- The natural finite-to-infinite convergence interface: a sequence of
-- Finsets that exhausts the index type, with the partial products
-- converging to the infinite product and the partial regularized sums
-- converging to the regularized series.

/-- ЁЯУж **`HadamardFiniteExhaustion`** тАФ finite-truncation convergence
interface for the genus-1 Hadamard product. -/
structure HadamardFiniteExhaustion
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) where
  exhaust : тДХ тЖТ Finset ╬╣
  exhaust_mono :
    тИА {n m : тДХ}, n тЙд m тЖТ exhaust n тКЖ exhaust m
  product_tendsto :
    тИА s : тДВ,
      Tendsto
        (fun n => indexedFiniteHadamardProduct zeroLoc (exhaust n) s)
        Filter.atTop
        (ЁЭУЭ (infiniteHadamardProduct zeroLoc s))
  regularized_sum_tendsto :
    тИА s : тДВ,
      Tendsto
        (fun n => finiteHadamardRegularizedSum zeroLoc (exhaust n) s)
        Filter.atTop
        (ЁЭУЭ (hadamardRegularizedLogDerivSeries zeroLoc s))

/-- тнР **PROVED тАФ finite-truncation log-derivative identity at every
exhaustion stage.** Direct specialization of ┬зCCCXXIV's
`logDerivativeResponse_indexedFiniteHadamardProduct`. -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct_at_exhaustion
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ}
    (Hex : HadamardFiniteExhaustion zeroLoc)
    {s : тДВ} {n : тДХ}
    (h╧Б : тИА i тИИ Hex.exhaust n, zeroLoc i тЙа 0)
    (hs : тИА i тИИ Hex.exhaust n, s тЙа zeroLoc i) :
    logDerivativeResponse
        (fun s' : тДВ => indexedFiniteHadamardProduct zeroLoc (Hex.exhaust n) s') s
      = finiteHadamardRegularizedSum zeroLoc (Hex.exhaust n) s :=
  logDerivativeResponse_indexedFiniteHadamardProduct h╧Б hs

-- =====================================================================
-- ┬зCCCXXIX. Regularized Hadamard term тАФ algebraic identity + norm
-- =====================================================================

/-- тнР **PROVED тАФ paired/regularized identity.** The combined term
collapses to `s / ((s - ╧Б) ┬╖ ╧Б)`. -/
lemma hadamard_regularized_term_eq {s ╧Б : тДВ} (h╧Б : ╧Б тЙа 0) (hs╧Б : s тЙа ╧Б) :
    1 / (s - ╧Б) + 1 / ╧Б = s / ((s - ╧Б) * ╧Б) := by
  have hs╧Б' : s - ╧Б тЙа 0 := sub_ne_zero.mpr hs╧Б
  field_simp

/-- тнР **PROVED тАФ norm form of the regularized identity.** -/
lemma norm_hadamard_regularized_term_eq
    {s ╧Б : тДВ} (h╧Б : ╧Б тЙа 0) (hs╧Б : s тЙа ╧Б) :
    тАЦ1 / (s - ╧Б) + 1 / ╧БтАЦ = тАЦsтАЦ / (тАЦs - ╧БтАЦ * тАЦ╧БтАЦ) := by
  rw [hadamard_regularized_term_eq h╧Б hs╧Б, norm_div, norm_mul]

-- =====================================================================
-- ┬зCCCXXX. Large-zero bound for the regularized term
-- =====================================================================

/-- тнР **PROVED тАФ reverse-triangle large-zero bound.** When
`2 тАЦsтАЦ тЙд тАЦ╧БтАЦ`, we have `тАЦs тИТ ╧БтАЦ тЙе тАЦ╧БтАЦ/2`. -/
lemma norm_sub_ge_half_of_two_norm_le {s ╧Б : тДВ}
    (hlarge : 2 * тАЦsтАЦ тЙд тАЦ╧БтАЦ) :
    тАЦ╧БтАЦ / 2 тЙд тАЦs - ╧БтАЦ := by
  have htriangle : тАЦ╧БтАЦ тЙд тАЦsтАЦ + тАЦs - ╧БтАЦ := by
    have h_sub := norm_sub_le s (s - ╧Б)
    have h_eq : s - (s - ╧Б) = ╧Б := by ring
    rw [h_eq] at h_sub
    exact h_sub
  linarith

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ large-zero bound on the regularized Hadamard
term.** `тАЦ1/(sтИТ╧Б) + 1/╧БтАЦ тЙд 2 тАЦsтАЦ / тАЦ╧БтАЦ┬▓` for `тАЦ╧БтАЦ тЙе 2 тАЦsтАЦ`. -/
lemma norm_hadamard_regularized_term_le_large {s ╧Б : тДВ}
    (h╧Б : ╧Б тЙа 0) (hs╧Б : s тЙа ╧Б) (hlarge : 2 * тАЦsтАЦ тЙд тАЦ╧БтАЦ) :
    тАЦ1 / (s - ╧Б) + 1 / ╧БтАЦ тЙд 2 * тАЦsтАЦ / тАЦ╧БтАЦ ^ 2 := by
  rw [norm_hadamard_regularized_term_eq h╧Б hs╧Б]
  have h╧Б_pos : 0 < тАЦ╧БтАЦ := norm_pos_iff.mpr h╧Б
  have h_s╧Б_pos : 0 < тАЦs - ╧БтАЦ := norm_pos_iff.mpr (sub_ne_zero.mpr hs╧Б)
  have h_denom_pos : 0 < тАЦs - ╧БтАЦ * тАЦ╧БтАЦ := mul_pos h_s╧Б_pos h╧Б_pos
  have h_╧Б_sq_pos : 0 < тАЦ╧БтАЦ ^ 2 := by positivity
  have h_s╧Б_ge : тАЦ╧БтАЦ / 2 тЙд тАЦs - ╧БтАЦ := norm_sub_ge_half_of_two_norm_le hlarge
  have h_s_nn : 0 тЙд тАЦsтАЦ := norm_nonneg _
  rw [div_le_div_iffтВА h_denom_pos h_╧Б_sq_pos]
  have h_╧Б_le : тАЦ╧БтАЦ тЙд 2 * тАЦs - ╧БтАЦ := by linarith
  have h_mul : тАЦ╧БтАЦ * тАЦ╧БтАЦ тЙд 2 * тАЦs - ╧БтАЦ * тАЦ╧БтАЦ :=
    mul_le_mul_of_nonneg_right h_╧Б_le h╧Б_pos.le
  have h_╧Б_sq : тАЦ╧БтАЦ ^ 2 = тАЦ╧БтАЦ * тАЦ╧БтАЦ := by ring
  nlinarith [h_mul, h_s_nn, h_╧Б_sq]

-- =====================================================================
-- ┬зCCCXXXI. Summability of regularized terms via inv-sq summability
-- =====================================================================

/-- ЁЯУж **`HadamardZeroInvSqSummability`** тАФ the classical analytic
hypothesis on a zero set: `╬г 1/тАЦ╧БтАЦ┬▓ < тИЮ` (genus тЙд 1) and for every
`s`, eventually `тАЦ╧БтАЦ тЙе 2тАЦsтАЦ`. -/
structure HadamardZeroInvSqSummability
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) : Prop where
  zero_ne : тИА i, zeroLoc i тЙа 0
  inv_sq_summable :
    Summable fun i : ╬╣ => (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣
  eventually_large :
    тИА s : тДВ, тИАс╢а i in Filter.cofinite, 2 * тАЦsтАЦ тЙд тАЦzeroLoc iтАЦ

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ regularized series is summable from inv-sq
summability + eventually-large.** -/
theorem summable_hadamard_regularized_terms_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {s : тДВ}
    (hzero_ne : тИА i, zeroLoc i тЙа 0)
    (hs_ne : тИА i, s тЙа zeroLoc i)
    (hinv_sq : Summable fun i : ╬╣ => (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
    (heventual_large :
      тИАс╢а i in Filter.cofinite, 2 * тАЦsтАЦ тЙд тАЦzeroLoc iтАЦ) :
    Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 2 * тАЦsтАЦ * (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
  ┬╖ exact hinv_sq.mul_left (2 * тАЦsтАЦ)
  ┬╖ filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_hadamard_regularized_term_le_large (hzero_ne i) (hs_ne i) hi
    have h_eq :
        (2 : тДЭ) * тАЦsтАЦ / тАЦzeroLoc iтАЦ ^ 2
          = 2 * тАЦsтАЦ * (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣ := by
      rw [div_eq_mul_inv]
    linarith [h_eq тЦ╕ h_bound]

/-- тнР **PROVED тАФ regularized summability from the data bundle
`HadamardZeroInvSqSummability`.** -/
theorem HadamardZeroInvSqSummability.summable_regularized
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    {s : тДВ} (hs_ne : тИА i, s тЙа zeroLoc i) :
    Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i :=
  summable_hadamard_regularized_terms_of_inv_sq
    H.zero_ne hs_ne H.inv_sq_summable (H.eventually_large s)

-- =====================================================================
-- ┬зCCCXXXII. Genus-one Taylor bound (data + specialization)
-- =====================================================================

/-- ЁЯУж **`GenusOneTaylorBoundData`** тАФ quantitative form of
`1 - (1-w)┬╖exp(w) = O(w┬▓)`. Standard genus-one decay; `C = 4` is
unsharp but suffices for convergence. -/
structure GenusOneTaylorBoundData : Prop where
  bound :
    тИА w : тДВ, тАЦwтАЦ тЙд 1 тЖТ
      тАЦ1 - (1 - w) * Complex.exp wтАЦ тЙд 4 * тАЦwтАЦ ^ 2

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ specialization to `hadamardGenus1Factor` with
`тАЦsтАЦ тЙд тАЦ╧БтАЦ`.** -/
lemma norm_one_sub_hadamardGenus1Factor_le_large
    {╧Б s : тДВ} (h╧Б : ╧Б тЙа 0) (hlarge : тАЦsтАЦ тЙд тАЦ╧БтАЦ)
    (Hbound : GenusOneTaylorBoundData) :
    тАЦ1 - hadamardGenus1Factor ╧Б sтАЦ тЙд 4 * (тАЦsтАЦ ^ 2 / тАЦ╧БтАЦ ^ 2) := by
  unfold hadamardGenus1Factor
  have h╧Б_pos : 0 < тАЦ╧БтАЦ := norm_pos_iff.mpr h╧Б
  have hw : тАЦs / ╧БтАЦ тЙд 1 := by
    rw [norm_div]
    exact div_le_one_of_leтВА hlarge (norm_nonneg _)
  have h := Hbound.bound (s / ╧Б) hw
  rw [norm_div, div_pow] at h
  exact h

-- =====================================================================
-- ┬зCCCXXXIII. Product convergence from inverse-square zero summability
-- =====================================================================

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ norm-summability of `1 - EтВБ(s/╧Бс╡в)`.** -/
theorem summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {s : тДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : тИА i, zeroLoc i тЙа 0)
    (hinv_sq : Summable fun i : ╬╣ => (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
    (heventual_large :
      тИАс╢а i in Filter.cofinite, тАЦsтАЦ тЙд тАЦzeroLoc iтАЦ) :
    Summable fun i : ╬╣ => тАЦ1 - hadamardGenus1Factor (zeroLoc i) sтАЦ := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 4 * тАЦsтАЦ ^ 2 * (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
  ┬╖ exact hinv_sq.mul_left (4 * тАЦsтАЦ ^ 2)
  ┬╖ filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_one_sub_hadamardGenus1Factor_le_large (hzero_ne i) hi Hbound
    have h_eq : (4 : тДЭ) * тАЦsтАЦ ^ 2 * (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣
              = 4 * (тАЦsтАЦ ^ 2 / тАЦzeroLoc iтАЦ ^ 2) := by
      rw [div_eq_mul_inv]; ring
    rw [Real.norm_of_nonneg (norm_nonneg _)]
    linarith [h_eq тЦ╕ h_bound]

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ тДВ-valued `Summable (1 - EтВБ(s/╧Бс╡в))` from norm.** -/
theorem summable_one_sub_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {s : тДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : тИА i, zeroLoc i тЙа 0)
    (hinv_sq : Summable fun i : ╬╣ => (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
    (heventual_large :
      тИАс╢а i in Filter.cofinite, тАЦsтАЦ тЙд тАЦzeroLoc iтАЦ) :
    Summable fun i : ╬╣ => 1 - hadamardGenus1Factor (zeroLoc i) s :=
  Summable.of_norm
    (summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `Multipliable (hadamardGenus1Factor тИШ zeroLoc)`
from inverse-square zero summability + Taylor bound.** Uses Mathlib's
`Complex.multipliable_one_add_of_summable`. -/
theorem multipliable_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ} {s : тДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : тИА i, zeroLoc i тЙа 0)
    (hinv_sq : Summable fun i : ╬╣ => (тАЦzeroLoc iтАЦ ^ 2)тБ╗┬╣)
    (heventual_large :
      тИАс╢а i in Filter.cofinite, тАЦsтАЦ тЙд тАЦzeroLoc iтАЦ) :
    Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s := by
  have h_sum :=
    summable_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large
  have h_sum_neg :
      Summable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s - 1 := by
    have := h_sum.neg
    simpa [neg_sub] using this
  have h_mul := Complex.multipliable_one_add_of_summable h_sum_neg
  simpa using h_mul

/-- тнР **PROVED тАФ `Multipliable` from the `HadamardZeroInvSqSummability`
bundle + Taylor bound.** -/
theorem HadamardZeroInvSqSummability.multipliable_genus1
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    (Hbound : GenusOneTaylorBoundData) (s : тДВ) :
    Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s := by
  apply multipliable_hadamardGenus1Factor_of_inv_sq
    Hbound H.zero_ne H.inv_sq_summable
  filter_upwards [H.eventually_large s] with i hi
  have h_s_nn : 0 тЙд тАЦsтАЦ := norm_nonneg s
  linarith

-- =====================================================================
-- ┬зCCCXXXIV. Prove `GenusOneTaylorBoundData`
-- =====================================================================
-- Inhabits the genus-one Taylor bound via Mathlib's
-- `Complex.norm_exp_sub_one_le` and `Complex.norm_exp_sub_one_sub_id_le`.
-- Decomposition:
--   `1 - (1-w)┬╖exp(w) = -(exp(w) - 1 - w) + w┬╖(exp(w) - 1)`
-- Triangle inequality + the two Mathlib bounds give `тАЦ┬╖тАЦ тЙд 3┬╖тАЦwтАЦ┬▓`,
-- which dominates `4┬╖тАЦwтАЦ┬▓` for free.

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `GenusOneTaylorBoundData` inhabited.** -/
theorem genusOneTaylorBoundData : GenusOneTaylorBoundData := by
  refine тЯи?_тЯй
  intro w hw
  have h_decomp :
      (1 : тДВ) - (1 - w) * Complex.exp w
        = -(Complex.exp w - 1 - w) + w * (Complex.exp w - 1) := by
    ring
  rw [h_decomp]
  have h_exp_sub_1_sub_id := Complex.norm_exp_sub_one_sub_id_le hw
  have h_exp_sub_1 := Complex.norm_exp_sub_one_le hw
  have h_w_nn : 0 тЙд тАЦwтАЦ := norm_nonneg _
  calc тАЦ-(Complex.exp w - 1 - w) + w * (Complex.exp w - 1)тАЦ
      тЙд тАЦ-(Complex.exp w - 1 - w)тАЦ + тАЦw * (Complex.exp w - 1)тАЦ :=
        norm_add_le _ _
    _ = тАЦComplex.exp w - 1 - wтАЦ + тАЦwтАЦ * тАЦComplex.exp w - 1тАЦ := by
        rw [norm_neg, norm_mul]
    _ тЙд тАЦwтАЦ ^ 2 + тАЦwтАЦ * (2 * тАЦwтАЦ) := by
        gcongr
    _ = 3 * тАЦwтАЦ ^ 2 := by ring
    _ тЙд 4 * тАЦwтАЦ ^ 2 := by nlinarith [sq_nonneg тАЦwтАЦ]

-- =====================================================================
-- ┬зCCCXXXV. Hypothesis-free product-convergence convenience
-- =====================================================================

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `Multipliable (hadamardGenus1Factor тИШ zeroLoc)`
from `HadamardZeroInvSqSummability` alone** (no Taylor hypothesis). -/
theorem HadamardZeroInvSqSummability.product_multipliable
    {╬╣ : Type*} {zeroLoc : ╬╣ тЖТ тДВ}
    (H : HadamardZeroInvSqSummability zeroLoc) :
    тИА s : тДВ,
      Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s :=
  fun s => H.multipliable_genus1 genusOneTaylorBoundData s

-- =====================================================================
-- ┬зCCCXXXVI. LUC log-derivative interchange scaffold
-- =====================================================================
-- The genuine analytic content of "log-derivative interchanges with
-- locally uniform convergence." Packaged as data on a region.

/-- ЁЯУж **`HadamardProductLUCLogDerivData`** тАФ the LUC + log-derivative
interchange data on `region : Set тДВ`. -/
structure HadamardProductLUCLogDerivData
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) where
  region : Set тДВ
  locally_uniform_product :
    TendstoLocallyUniformlyOn
      (fun F : Finset ╬╣ => fun s : тДВ =>
        indexedFiniteHadamardProduct zeroLoc F s)
