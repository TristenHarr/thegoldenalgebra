/-! ## CF: Global zeta-zero classification тЖТ safe-height data -/

/-! ### CF1: zeta-zero classification input -/

/-- Global zeta-zero classification facts (proved from the functional
equation + standard zero theory):

* `left_edge_zero_free`: `╬╢ тЙа 0` on the vertical line `Re = -1`.
* `zeros_nontrivial_of_pos_im`: every zeta zero with positive imaginary
  part is a nontrivial zero (rules out trivial and exotic zeros). -/
structure ZetaZeroClassificationInput : Prop where
  left_edge_zero_free :
    тИА y : тДЭ, riemannZeta тЯи-1, yтЯй тЙа 0
  zeros_nontrivial_of_pos_im :
    тИА z : тДВ, 0 < z.im тЖТ riemannZeta z = 0 тЖТ IsNontrivialZetaZero z

/-! ### CF2: safe-height data from zero classification + good height -/

/-- Given the global zero-classification facts plus a good height
`T > 0`, build the safe-height data: pick a good bottom in `(0, T)` via
CB7, and discharge every classification field of `zeroClass` from `ZC`. -/
noncomputable def rvmSafeHeightDataOfZeroClassification
    (ZC : ZetaZeroClassificationInput)
    {T : тДЭ} (hT : RvMGoodHeight T) (hTpos : 0 < T) :
    ZetaRectangle.RvMSafeHeightData T :=
  let hexists := ZetaRectangle.existsSafeBottomHeight hTpos
  let B := Classical.choose hexists
  let hspec := Classical.choose_spec hexists
  { B := B
    B_pos := hspec.1
    B_lt_T := hspec.2.1
    goodBottom := hspec.2.2
    goodTop := hT.good
    zeroClass :=
      { left_edge := ZC.left_edge_zero_free
        bottom_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; exact hspec.1) hzeta
        top_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; linarith [hspec.1, hspec.2.1]) hzeta
        interior_zeros_nontrivial := fun z hzOpen hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by
              have hB_lt : B < z.im := hzOpen.2.2.1
              linarith [hspec.1])
            hzeta } }

/-! ## CG: Split `ZetaZeroClassificationInput` into Mathlib-facing targets -/

/-! ### CG1: split into vertical-line and positive-im classification -/

/-- No zeta zero on the vertical line `Re s = -1`.  Functional-equation
target. -/
def ZetaLeftEdgeZeroFree : Prop :=
  тИА y : тДЭ, riemannZeta тЯи-1, yтЯй тЙа 0

/-- Every zeta zero with positive imaginary part is a nontrivial zero. -/
def ZetaZeroPositiveImaginaryNontrivial : Prop :=
  тИА z : тДВ, 0 < z.im тЖТ riemannZeta z = 0 тЖТ IsNontrivialZetaZero z

/-! ### CG2a: proven half of CG2 тАФ `z.re < 1` from `riemannZeta_ne_zero_of_one_le_re` -/

/-- Every zeta zero satisfies `Re z < 1` тАФ immediate from
`riemannZeta_ne_zero_of_one_le_re`. -/
theorem zetaZero_re_lt_one {z : тДВ} (hzeta : riemannZeta z = 0) :
    z.re < 1 := by
  by_contra h
  push_neg at h
  exact riemannZeta_ne_zero_of_one_le_re h hzeta

/-! ### CG2b: sub-target тАФ `0 < z.re` for zeros with positive imaginary part -/

/-- Sub-target: every zeta zero with positive imaginary part satisfies
`0 < Re z`.  Functional-equation content (zeros with `Re z тЙд 0` are the
trivial zeros, which are real). -/
def ZetaZeroPosImagPosRe : Prop :=
  тИА z : тДВ, 0 < z.im тЖТ riemannZeta z = 0 тЖТ 0 < z.re

/-- Combine the sub-target `0 < Re z` with the proved upper bound
`Re z < 1` to discharge `ZetaZeroPositiveImaginaryNontrivial`. -/
theorem ZetaZeroPositiveImaginaryNontrivial.of_posRe
    (H : ZetaZeroPosImagPosRe) :
    ZetaZeroPositiveImaginaryNontrivial :=
  fun z hzIm hzeta =>
    тЯиhzeta, H z hzIm hzeta, zetaZero_re_lt_one hzetaтЯй

/-! ### CG4: split combinator for the full classification input -/

/-- Inhabit `ZetaZeroClassificationInput` from the two split targets. -/
def ZetaZeroClassificationInput.of_split
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPositiveImaginaryNontrivial) :
    ZetaZeroClassificationInput where
  left_edge_zero_free := Hleft
  zeros_nontrivial_of_pos_im := Hpos

/-- Two-level split: a left-edge target plus the proved upper bound plus
the lower-bound sub-target. -/
def ZetaZeroClassificationInput.of_three_targets
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPosImagPosRe) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_split Hleft
    (ZetaZeroPositiveImaginaryNontrivial.of_posRe Hpos)

/-! ## CH: Functional-equation zero-transfer wrapper -/

/-- Functional-equation zero transfer package: bundles the two
functional-equation consequences `ZetaLeftEdgeZeroFree` and
`ZetaZeroPosImagPosRe`.  Either field is a direct consequence of
`riemannZeta_one_sub` plus nonvanishing of the trig/╬У/cpow/╬╢(2-iy)
factors. -/
structure ZetaFunctionalEquationZeroTransferInput : Prop where
  left_edge : ZetaLeftEdgeZeroFree
  pos_im_pos_re : ZetaZeroPosImagPosRe

/-- Inhabit `ZetaZeroClassificationInput` from the functional-equation
zero-transfer package тАФ closes the entire zero-classification side
modulo two functional-equation Props. -/
def ZetaZeroClassificationInput.of_functionalEquationTransfer
    (F : ZetaFunctionalEquationZeroTransferInput) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_three_targets F.left_edge F.pos_im_pos_re

/-! ### CH (extended): standard functional-equation zero-free facts -/

/-- The standard functional-equation consequence: `╬╢` has no zeros in the
left half-plane (`Re тЙд 0`) at positive imaginary heights.  Equivalent to
the classical statement that `╬╢` zeros outside the critical strip are
exactly the real trivial zeros. -/
def ZetaNoZerosLeftHalfPlaneUpper : Prop :=
  тИА z : тДВ, z.re тЙд 0 тЖТ 0 < z.im тЖТ riemannZeta z тЙа 0

/-- The functional-equation no-zero fact in the left half-plane upper
half implies the sub-target `ZetaZeroPosImagPosRe`.  Contrapositive: a
zero with `Im > 0` and `Re тЙд 0` would contradict the no-zero fact. -/
theorem ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper
    (H : ZetaNoZerosLeftHalfPlaneUpper) :
    ZetaZeroPosImagPosRe := by
  intro z hzIm hzeta
  by_contra hzre_not
  have hzre : z.re тЙд 0 := le_of_not_gt hzre_not
  exact H z hzre hzIm hzeta

/-- Bundled standard functional-equation zero-free facts: the no-zero
property in the left half-plane upper half + the (broader) no-zero
property on the vertical line `Re = -1`. -/
structure ZetaFunctionalEquationStandardZeroFacts : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeZeroFree : ZetaLeftEdgeZeroFree

/-- The standard zero-free facts inhabit the transfer input package тАФ only
the two named functional-equation Props remain. -/
def ZetaFunctionalEquationStandardZeroFacts.toTransferInput
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaFunctionalEquationZeroTransferInput where
  left_edge := F.leftEdgeZeroFree
  pos_im_pos_re :=
    ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper F.noZerosLeftHalfPlaneUpper

/-- Top-level: inhabit `ZetaZeroClassificationInput` directly from the
standard functional-equation facts. -/
def ZetaZeroClassificationInput.of_standardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_functionalEquationTransfer F.toTransferInput

/-! ## CL: Functional-equation transfer on the line `Re = -1` -/

/-! ### CL1: easy right-half nonzero + transfer Prop -/

/-- For real `y`, `(1 - тЯи-1, yтЯй).re = 2`, so `╬╢ тЙа 0` there via
`riemannZeta_ne_zero_of_one_lt_re`. -/
theorem zeta_one_sub_leftEdge_ne_zero (y : тДЭ) :
    riemannZeta ((1 : тДВ) - тЯи(-1 : тДЭ), yтЯй) тЙа 0 := by
  apply riemannZeta_ne_zero_of_one_lt_re
  show (1 : тДЭ) < ((1 : тДВ) - тЯи(-1 : тДЭ), yтЯй).re
  simp [Complex.sub_re, Complex.one_re]

/-- Functional-equation nonzero transfer on the line `Re s = -1`: if
`╬╢(1 - z) тЙа 0`, then `╬╢(z) тЙа 0`, for `z = тЯи-1, yтЯй`.  This is the precise
Mathlib-facing analytic obligation underlying `ZetaLeftEdgeZeroFree`. -/
def ZetaFunctionalEquationLeftEdgeTransfer : Prop :=
  тИА y : тДЭ,
    riemannZeta ((1 : тДВ) - тЯи(-1 : тДЭ), yтЯй) тЙа 0 тЖТ
      riemannZeta тЯи(-1 : тДЭ), yтЯй тЙа 0

/-- `ZetaLeftEdgeZeroFree` follows from the functional-equation transfer
plus the easy right-half nonzero fact `zeta_one_sub_leftEdge_ne_zero`. -/
theorem ZetaLeftEdgeZeroFree.of_functionalEquationTransfer
    (H : ZetaFunctionalEquationLeftEdgeTransfer) :
    ZetaLeftEdgeZeroFree := fun y =>
  H y (zeta_one_sub_leftEdge_ne_zero y)

/-! ### CL4: standard zero facts via the transfer Prop -/

/-- Variant of `ZetaFunctionalEquationStandardZeroFacts` that takes the
functional-equation transfer (CL1) instead of the assembled
`leftEdgeZeroFree`.  This reduces the left-edge obligation to a single
precise FE transfer lemma. -/
structure ZetaFunctionalEquationStandardZeroFactsViaTransfer : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeTransfer : ZetaFunctionalEquationLeftEdgeTransfer

/-- The transfer-based standard facts package inhabits the original
assembled package. -/
def ZetaFunctionalEquationStandardZeroFactsViaTransfer.toStandardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer) :
    ZetaFunctionalEquationStandardZeroFacts where
  noZerosLeftHalfPlaneUpper := F.noZerosLeftHalfPlaneUpper
  leftEdgeZeroFree :=
    ZetaLeftEdgeZeroFree.of_functionalEquationTransfer F.leftEdgeTransfer

/-! ## CI: Tautological `mainEval` via `concreteS` as `Sarg` -/

/-! ### CI3: build `RvMGoodHeightAnalyticInputs` from safe-data, with `Sarg := concreteS` -/

/-- Build `RvMGoodHeightAnalyticInputs` using `concreteS` as the
correction term `Sarg`.  The `mainEval` field is then immediate from
`concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm`. -/
noncomputable def RvMGoodHeightAnalyticInputs.of_concreteS_safeData
    (safe :
      тИА T : тДЭ, RvMGoodHeight T тЖТ ZetaRectangle.RvMSafeHeightData T) :
    RvMGoodHeightAnalyticInputs where
  Sarg := concreteS
  safeData := safe
  mainEval := fun T hT => by
    have h := concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm hT.nonneg
    linarith

/-! ### CI4: top-level pipeline from zero-classification + height-positivity -/

/-- The final pipeline assembler: given the zeta-zero classification
package (closing the rectangle-side analytic content), build the full
`RvMGoodHeightAnalyticInputs` тАФ `RvMGoodHeight T` now bakes in the
required positivity, so no extra hypothesis is needed. -/
noncomputable def RvMGoodHeightAnalyticInputs.of_zeroClassification
    (ZC : ZetaZeroClassificationInput) :
    RvMGoodHeightAnalyticInputs :=
  RvMGoodHeightAnalyticInputs.of_concreteS_safeData
    (fun _ hT => rvmSafeHeightDataOfZeroClassification ZC hT hT.pos)

/-! ## CM: Concrete `concreteS` Backlund estimate on good heights -/

/-! ### CM1: data package -/

/-- The concrete Backlund estimate for `concreteS` on good heights.
Bundles a threshold `lower тЙе 2╧А` and the half-log-plus-half bound
above the threshold.  This is the analytic estimate that remains after
all rectangle/contour/RvM plumbing. -/
structure ConcreteSBacklundEstimateOnGoodHeights where
  lower : тДЭ
  lower_ge_two_pi : 2 * Real.pi тЙд lower
  bound :
    тИА T : тДЭ, RvMGoodHeight T тЖТ lower тЙд T тЖТ
      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-! ### CM2: conversion to existing `BacklundArgumentBoundOnGoodHeights` -/

/-- The concrete-S estimate inhabits the existing
`BacklundArgumentBoundOnGoodHeights concreteS` package by promoting the
`GoodHeight T + lower тЙд T` pair to `RvMGoodHeight T` via the positivity
`0 < lower`. -/
noncomputable def
    ConcreteSBacklundEstimateOnGoodHeights.toBacklundArgumentBoundOnGoodHeights
    (E : ConcreteSBacklundEstimateOnGoodHeights) :
    BacklundArgumentBoundOnGoodHeights concreteS where
  lower := E.lower
  lower_ge_two_pi := E.lower_ge_two_pi
  bound := fun T hlower hgood => by
    refine E.bound T тЯи?_, hgoodтЯй hlower
    have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
    linarith [E.lower_ge_two_pi]

/-! ### CM3: 140-threshold version -/

/-- The classical Backlund-style 140-threshold estimate for `concreteS`
on good heights.  Plain `Prop` of `тИА`, since the threshold is fixed. -/
def ConcreteSBacklundEstimateFrom140OnGoodHeights : Prop :=
  тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-- The 140-threshold estimate inhabits the data package with
`lower := 140` (since `2╧А < 8 < 140`). -/
noncomputable def ConcreteSBacklundEstimateFrom140OnGoodHeights.toEstimate
    (H : ConcreteSBacklundEstimateFrom140OnGoodHeights) :
    ConcreteSBacklundEstimateOnGoodHeights where
  lower := 140
  lower_ge_two_pi := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  bound := H

/-! ### CM4: final headline theorem from the 140-threshold + extension package -/

/-- **CM4 тАФ FINAL ASSEMBLER:** the classical 140-threshold estimate plus
the four other analytic inputs yields the headline half-log-plus-half
bound on `concreteS` for every `T тЙе 140`. -/
theorem ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (Ext : RvMGoodHeightExtension
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BExt : BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 := by
  let ZC := ZetaZeroClassificationInput.of_standardZeroFacts F.toStandardZeroFacts
  let I := RvMGoodHeightAnalyticInputs.of_zeroClassification ZC
  exact I.to_concreteS_halfLogPlusHalf Ext
    H140.toEstimate.toBacklundArgumentBoundOnGoodHeights BExt hT

/-! ## CN: `BacklundGoodHeightBoundExtension` from good-height closure -/

/-! ### CN1: closure/continuity input package -/

/-- Continuity-style closure for the concrete Backlund bound: if at every
height above the threshold there is an arbitrarily-close good-height
witness of the bound, then the bound holds at that height. -/
structure ConcreteSBoundGoodHeightClosure (lower : тДЭ) : Prop where
  closure :
    тИА T : тДЭ, lower тЙд T тЖТ
      (тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ
        тИГ U : тДЭ, RvMGoodHeight U тИз lower тЙд U тИз |U - T| < ╬╡ тИз
          |concreteS U| тЙд (1 / 2 : тДЭ) * Real.log U + 1 / 2) тЖТ
      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-! ### CN2: good-height density right-approximation above a positive threshold -/

/-- Right-approximation: for `T` at or above a positive `lower`, every
positive `╬╡` produces a good height `U тИИ (T, T + ╬╡)` with `lower тЙд U`. -/
theorem exists_goodHeight_near_right_ge_lower
    {lower T ╬╡ : тДЭ}
    (hLower_pos : 0 < lower) (hLT : lower тЙд T) (h╬╡ : 0 < ╬╡) :
    тИГ U : тДЭ, RvMGoodHeight U тИз lower тЙд U тИз |U - T| < ╬╡ := by
  have hTpos : 0 < T := lt_of_lt_of_le hLower_pos hLT
  obtain тЯиU, hTU, hUeps, hUgoodтЯй :=
    exists_goodHeight_between_self_add hTpos h╬╡
  have hUpos : 0 < U := lt_trans hTpos hTU
  refine тЯиU, { pos := hUpos, good := hUgood }, ?_, ?_тЯй
  ┬╖ linarith
  ┬╖ rw [abs_of_pos (by linarith : (0 : тДЭ) < U - T)]
    linarith

/-! ### CN3: build `BacklundGoodHeightBoundExtension` from closure + estimate -/

/-- The closure principle (CN1) plus the good-height Backlund estimate
(CM3) yields the `BacklundGoodHeightBoundExtension`. -/
noncomputable def BacklundGoodHeightBoundExtension.of_closure
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (C : ConcreteSBoundGoodHeightClosure 140) :
    BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights where
  bound_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ╬╡ h╬╡
    have h140_pos : (0 : тДЭ) < 140 := by norm_num
    obtain тЯиU, hUgood, hUlower, hdistтЯй :=
      exists_goodHeight_near_right_ge_lower
        (lower := 140) h140_pos hT h╬╡
    exact тЯиU, hUgood, hUlower, hdist, H140 U hUgood hUlowerтЯй

/-! ### CN4: final theorem using the closure principle instead of `BExt` -/

/-- **CN4 тАФ alternate final assembler:** uses the closure principle
(CN1) in place of the `BacklundGoodHeightBoundExtension` field. -/
theorem ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf_of_closure
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (Ext : RvMGoodHeightExtension
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (C : ConcreteSBoundGoodHeightClosure 140)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  H140.to_concreteS_halfLogPlusHalf F Ext
    (BacklundGoodHeightBoundExtension.of_closure H140 C) hT

/-! ## CO: `RvMGoodHeightExtension` from RvM-formula closure -/

/-! ### CO1: density of good heights near any nonnegative `T` -/

/-- For every nonnegative `T` and every `╬╡ > 0`, there is a good RvM
height `U` with `|U - T| < ╬╡`.  Uses `exists_goodHeight_between` for
the boundary case `T = 0` and `exists_goodHeight_between_self_add`
for `T > 0`. -/
theorem exists_goodHeight_near
    {T ╬╡ : тДЭ} (hT : 0 тЙд T) (h╬╡ : 0 < ╬╡) :
    тИГ U : тДЭ, RvMGoodHeight U тИз |U - T| < ╬╡ := by
  rcases eq_or_lt_of_le hT with hT_eq | hT_pos
  ┬╖ -- T = 0: pick U тИИ (╬╡/2, ╬╡)
    have h╬╡_half_pos : (0 : тДЭ) < ╬╡ / 2 := by linarith
    have h╬╡_half_lt : ╬╡ / 2 < ╬╡ := by linarith
    obtain тЯиU, hAU, hUB, hUgoodтЯй :=
      exists_goodHeight_between h╬╡_half_pos h╬╡_half_lt
    refine тЯиU, тЯиlt_trans h╬╡_half_pos hAU, hUgoodтЯй, ?_тЯй
    rw [тЖР hT_eq, sub_zero, abs_of_pos (lt_trans h╬╡_half_pos hAU)]
    exact hUB
  ┬╖ -- T > 0: pick U тИИ (T, T+╬╡)
    obtain тЯиU, hTU, hUeps, hUgoodтЯй :=
      exists_goodHeight_between_self_add hT_pos h╬╡
    refine тЯиU, тЯиlt_trans hT_pos hTU, hUgoodтЯй, ?_тЯй
    rw [abs_of_pos (by linarith : (0 : тДЭ) < U - T)]
    linarith

/-! ### CO2: closure principle for the RvM formula -/

/-- Closure/continuity principle for extending the RvM formula from
good heights to all nonnegative heights: if at every nonnegative `T`
there is an arbitrarily-close good-height witness of the formula, then
the formula holds at `T`. -/
structure RvMFormulaGoodHeightClosure
    (Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights) : Prop where
  closure :
    тИА T : тДЭ, тИА hT : 0 тЙд T,
      (тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ
        тИГ U : тДЭ, тИГ hU : RvMGoodHeight U, |U - T| < ╬╡ тИз
          (zetaWeightedZeroCountUpToHeight U hU.nonneg : тДЭ) =
            riemannVonMangoldtMainTerm U + Fgood.Sarg U) тЖТ
      (zetaWeightedZeroCountUpToHeight T hT : тДЭ) =
        riemannVonMangoldtMainTerm T + Fgood.Sarg T

/-! ### CO3: build `RvMGoodHeightExtension` from the closure principle -/

/-- The RvM-formula closure principle inhabits `RvMGoodHeightExtension`:
for any `T тЙе 0`, produce a nearby good height (CO1) and use the closure
plus `Fgood.formula` at the witness. -/
noncomputable def RvMGoodHeightExtension.of_closure
    {Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights}
    (C : RvMFormulaGoodHeightClosure Fgood) :
    RvMGoodHeightExtension Fgood where
  formula_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ╬╡ h╬╡
    obtain тЯиU, hUgood, hdistтЯй := exists_goodHeight_near hT h╬╡
    exact тЯиU, hUgood, hdist, Fgood.formula U hUgoodтЯй

/-! ### CO4: final theorem using both closure principles -/

/-- **CO4 тАФ FINAL ASSEMBLER WITH BOTH CLOSURES:** the headline bound
on `concreteS` for all `T тЙе 140`, derived from exactly four analytic
