-- CLXII: Push scalar threshold from T=140 down to T=130
-- ---------------------------------------------------------------------
-- Python: `scalarGap22_15(130) = 6.66` (vs 15.53 at T=140). The proof
-- structure mirrors `scalarGap22_15_at_140_nonneg` exactly, with
-- constants `286/ѕА` instead of `308/ѕА` (since 22¬Ј130/30 = 286 vs
-- 22¬Ј140/30 = 308). Lower bound:
--   gap(130) вЙ• (286/ѕА)¬Ј1 + ... = 286/ѕА вИТ 86.4 вЙ• 90.79 вИТ 86.4 = 4.39 вЙ• 0.
-- using the same log bounds `log(130/(2ѕА)) > 3` and `log 130 < 5`
-- (both hold: 2ѕА¬Јe¬≥ вЙ§ 126.78 < 130 and 130 < 146.17 вЙ§ 2.71вБµ вЙ§ eвБµ).

/-- в≠Р **PROVED вАФ `0 вЙ§ scalarGap22_15 130`.**
Same chain as the T=140 proof, sharper margin (gap вЙИ 6.66 vs 15.53). -/
theorem scalarGap22_15_at_130_nonneg :
    (0 : вДЭ) вЙ§ scalarGap22_15 130 := by
  unfold scalarGap22_15
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_d2 : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi) вЙ† 0 := ne_of_gt h_2pi_pos
  have h_pi_ne : (Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_pi_pos
  -- exp 1 bounds
  have h_e_lt : Real.exp 1 < 2.72 := lt_trans Real.exp_one_lt_d9 (by norm_num)
  have h_e_gt : 2.71 < Real.exp 1 := lt_trans (by norm_num) Real.exp_one_gt_d9
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_e_nn : 0 вЙ§ Real.exp 1 := le_of_lt h_e_pos
  -- Step 1: log(130 / (2ѕА)) > 3
  have h_exp3_eq : Real.exp 3 = Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (3 : вДЭ) = 1 + 1 + 1 from by norm_num,
        Real.exp_add, Real.exp_add]
  have h_e_le : Real.exp 1 вЙ§ 2.72 := le_of_lt h_e_lt
  have h_e_sq_le : Real.exp 1 * Real.exp 1 вЙ§ 2.72 * 2.72 :=
    mul_le_mul h_e_le h_e_le h_e_nn (by norm_num)
  have h_e_cube_le :
      Real.exp 1 * Real.exp 1 * Real.exp 1 вЙ§ 2.72 * 2.72 * 2.72 :=
    mul_le_mul h_e_sq_le h_e_le h_e_nn (by positivity)
  have h_272_cube : (2.72 : вДЭ) * 2.72 * 2.72 = 20.123648 := by norm_num
  have h_exp3_le : Real.exp 3 вЙ§ 20.124 := by
    rw [h_exp3_eq]; linarith
  have h_exp3_pos : 0 < Real.exp 3 := Real.exp_pos 3
  have h_exp3_nn : 0 вЙ§ Real.exp 3 := le_of_lt h_exp3_pos
  have h_2pi_le : 2 * Real.pi вЙ§ 6.3 := by linarith
  have h_2pi_exp3_le : 2 * Real.pi * Real.exp 3 вЙ§ 6.3 * 20.124 :=
    mul_le_mul h_2pi_le h_exp3_le h_exp3_nn (by norm_num)
  have h_63_201 : (6.3 : вДЭ) * 20.124 = 126.7812 := by norm_num
  -- 130 > 2ѕА ¬Ј exp 3
  have h_2pi_exp3_lt_130 : 2 * Real.pi * Real.exp 3 < 130 := by linarith
  have h_130_2pi_gt_e3 : Real.exp 3 < 130 / (2 * Real.pi) := by
    rw [lt_div_iffвВА h_2pi_pos]; linarith
  have h_log_130_2pi_gt_3 : 3 < Real.log (130 / (2 * Real.pi)) := by
    have h := Real.log_lt_log h_exp3_pos h_130_2pi_gt_e3
    rwa [Real.log_exp] at h
  -- Step 2: log 130 < 5
  have h_exp5_eq :
      Real.exp 5 = Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (5 : вДЭ) = 1 + 1 + 1 + 1 + 1 from by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add]
  have h_271_nn : (0 : вДЭ) вЙ§ 2.71 := by norm_num
  have h_e_ge : (2.71 : вДЭ) вЙ§ Real.exp 1 := le_of_lt h_e_gt
  have h_e_sq_ge : (2.71 : вДЭ) * 2.71 вЙ§ Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_ge h_e_ge h_271_nn h_e_nn
  have h_e_cube_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_sq_ge h_e_ge h_271_nn (by positivity)
  have h_e_q_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 * 2.71
        вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_cube_ge h_e_ge h_271_nn (by positivity)
  have h_e_5_ge :
      (2.71 : вДЭ) * 2.71 * 2.71 * 2.71 * 2.71
        вЙ§ Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_q_ge h_e_ge h_271_nn (by positivity)
  have h_130_lt_271_5 :
      (130 : вДЭ) < 2.71 * 2.71 * 2.71 * 2.71 * 2.71 := by norm_num
  have h_exp5_gt : (130 : вДЭ) < Real.exp 5 := by
    rw [h_exp5_eq]; linarith
  have h_130_pos : (0 : вДЭ) < 130 := by norm_num
  have h_log130_lt_5 : Real.log 130 < 5 := by
    have h := Real.log_lt_log h_130_pos h_exp5_gt
    rwa [Real.log_exp] at h
  -- Step 3: combine
  -- coefficient (22/15)¬Ј130/(2ѕА) = 286/(3ѕА)
  have h_coeff_pos : 0 < 286 / (3 * Real.pi) := by positivity
  have h_coeff_eq :
      (22 / 15) * 130 / (2 * Real.pi) = 286 / (3 * Real.pi) := by
    field_simp; ring
  have h_LHS_ge : 286 / Real.pi
        вЙ§ ((22 / 15) * 130 / (2 * Real.pi)) * Real.log (130 / (2 * Real.pi)) := by
    rw [h_coeff_eq]
    have h_step :
        (286 / (3 * Real.pi)) * 3
          вЙ§ (286 / (3 * Real.pi)) * Real.log (130 / (2 * Real.pi)) :=
      mul_le_mul_of_nonneg_left (le_of_lt h_log_130_2pi_gt_3) (le_of_lt h_coeff_pos)
    have h_eq : (286 / (3 * Real.pi)) * 3 = 286 / Real.pi := by
      field_simp; ring
    linarith
  -- 286/ѕА вЙ• 286/3.15 вЙ• 90 (since 286/3.15 вЙИ 90.79)
  have h_pi_le : Real.pi вЙ§ 3.15 := le_of_lt h_pi_lt_d2
  have h_286_pi_ge : (286 : вДЭ) / 3.15 вЙ§ 286 / Real.pi :=
    div_le_div_of_nonneg_left (by norm_num) h_pi_pos h_pi_le
  have h_286_315_ge_90 : (90 : вДЭ) вЙ§ 286 / 3.15 := by
    rw [le_div_iffвВА (by norm_num : (0:вДЭ) < 3.15)]; norm_num
  have h_LHS_ge_90 : (90 : вДЭ)
        вЙ§ ((22 / 15) * 130 / (2 * Real.pi)) * Real.log (130 / (2 * Real.pi)) := by
    linarith
  -- RHS upper bound: (17/2)¬Јlog 130 + 43.9 < (17/2)¬Ј5 + 43.9 = 86.4
  have h_RHS_le : (17 / 2 : вДЭ) * Real.log 130 + 439 / 10 вЙ§ 86.4 := by
    have h_log_le : (17 / 2 : вДЭ) * Real.log 130 вЙ§ (17 / 2) * 5 :=
      mul_le_mul_of_nonneg_left (le_of_lt h_log130_lt_5) (by norm_num)
    have h_calc : (17 / 2 : вДЭ) * 5 = 42.5 := by norm_num
    linarith
  -- Combine: gap вЙ• 90 - 86.4 = 3.6 > 0
  linarith

