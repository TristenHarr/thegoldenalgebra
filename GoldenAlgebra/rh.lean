-- =====================================================================
-- ┬зCCXCII. `HlowArith` normalization (factor out `y > 0`)
-- =====================================================================
-- Both sides of `LowExplicitArithmeticBound_11_14_half` are linear in
-- `y := z.im`:
--   LHS  `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ┬╖ CтВА`
--          where `CтВА := 17/242 тИТ 9/392 тЙИ 0.0473`,
--   RHS  `simpleCloudSum zeros100ceil x y = y ┬╖ simpleCloudSumNorm ...`
--   RHS  `smoothTailRationalLowerBoundAbs x y 10 = y ┬╖ smoothTailRationalLowerBoundAbsNorm x y 10`.
-- Since `y > 0` on `lowCompactRegion`, dividing both sides by `y`
-- removes the y-scaling and reduces the inequality to a single
-- constant `CтВА тЙд simpleCloudSumNorm + smoothTailRationalLowerBoundAbsNorm`
-- тАФ independent of the small-y regime and easier to attack via
-- regional decomposition.
--
-- Adds:
--   simpleCloudSumNorm                            тАФ `╬г 2/(x┬▓+╬│┬▓+y┬▓)`
--   smoothTailRationalLowerBoundAbsNorm           тАФ smooth LB / y
--   lowArithConst_11_14_half                       тАФ `17/242 тИТ 9/392`
--   simpleCloudSum_eq_y_mul_norm                   тАФ y-factorization
--   smoothTailRationalLowerBoundAbs_eq_y_mul_norm  тАФ y-factorization
--   closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const  тАФ y-factorization
--   LowExplicitArithmeticBoundNorm_11_14_half      тАФ normalized Prop
--   LowExplicitArithmeticBound_11_14_half_of_norm  тАФ bridge from normalized

/-- **Normalized `simpleCloudSum`** тАФ divide out the leading `y` factor:
`╬г 2/(x┬▓+╬│┬▓+y┬▓)`. -/
noncomputable def simpleCloudSumNorm (zeros : List тДЭ) (x y : тДЭ) : тДЭ :=
  (zeros.map fun g => 2 / (x ^ 2 + g ^ 2 + y ^ 2)).sum

/-- **Normalized `smoothTailRationalLowerBoundAbs`** тАФ divide out the
leading `y` factor:
`╧Б(T) ┬╖ ((T тИТ |x|)/((T тИТ |x|)┬▓ + y┬▓) + (T + |x|)/((T + |x|)┬▓ + y┬▓))`. -/
noncomputable def smoothTailRationalLowerBoundAbsNorm (x y T : тДЭ) : тДЭ :=
  zeroDensityRho T *
    ((T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + (T + |x|) / ((T + |x|) ^ 2 + y ^ 2))

/-- **Path B arithmetic constant**: `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ┬╖ lowArithConst_11_14_half`.
Equals `17/242 тИТ 9/392 тЙИ 0.0473`. -/
noncomputable def lowArithConst_11_14_half : тДЭ := 17 / 242 - 9 / 392

/-- тнР **PROVED тАФ `simpleCloudSum` y-factorization.** -/
lemma simpleCloudSum_eq_y_mul_norm (zeros : List тДЭ) (x y : тДЭ) :
    simpleCloudSum zeros x y = y * simpleCloudSumNorm zeros x y := by
  unfold simpleCloudSum simpleCloudSumNorm
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    rw [ih]
    ring

/-- тнР **PROVED тАФ `smoothTailRationalLowerBoundAbs` y-factorization.** -/
lemma smoothTailRationalLowerBoundAbs_eq_y_mul_norm (x y T : тДЭ) :
    smoothTailRationalLowerBoundAbs x y T
      = y * smoothTailRationalLowerBoundAbsNorm x y T := by
  unfold smoothTailRationalLowerBoundAbs smoothTailRationalLowerBoundAbsNorm
  ring

/-- тнР **PROVED тАФ `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ┬╖ CтВА`**. -/
lemma closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const (y : тДЭ) :
    closedFormFirstZeroErrorBound y 11 14 (1 / 2)
      = y * lowArithConst_11_14_half := by
  unfold closedFormFirstZeroErrorBound lowArithConst_11_14_half
  ring

/-- ЁЯУж **`LowExplicitArithmeticBoundNorm_11_14_half`** тАФ y-normalized
arithmetic obligation. Removes the y-scaling and reduces the problem
to a single constant inequality on the compact box. -/
def LowExplicitArithmeticBoundNorm_11_14_half : Prop :=
  тИА z : тДВ,
    lowCompactRegion z тЖТ
    lowArithConst_11_14_half
      тЙд simpleCloudSumNorm zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbsNorm z.re z.im 10

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ bridge from normalized to original `HlowArith`.**
Multiplies the normalized inequality by `y > 0` to recover the
y-scaled form. -/
theorem LowExplicitArithmeticBound_11_14_half_of_norm
    (h : LowExplicitArithmeticBoundNorm_11_14_half) :
    LowExplicitArithmeticBound_11_14_half := by
  intro z hz
  have hy : 0 < z.im := hz.1
  have h_norm := h z hz
  -- Rewrite LHS and RHS in y-factored form
  show lowResidualExplicitBoundAt 11 14 (1 / 2) z
        тЙд simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  show closedFormFirstZeroErrorBound z.im 11 14 (1 / 2)
        тЙд simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  rw [closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const,
      simpleCloudSum_eq_y_mul_norm,
      smoothTailRationalLowerBoundAbs_eq_y_mul_norm]
  have h_combine :
      z.im * simpleCloudSumNorm zeros100ceil z.re z.im
        + z.im * smoothTailRationalLowerBoundAbsNorm z.re z.im 10
        = z.im * (simpleCloudSumNorm zeros100ceil z.re z.im
                  + smoothTailRationalLowerBoundAbsNorm z.re z.im 10) := by
    ring
  rw [h_combine]
  exact mul_le_mul_of_nonneg_left h_norm (le_of_lt hy)

