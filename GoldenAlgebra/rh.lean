-- ---------------------------------------------------------------------
-- CLXVII: cert_2pi_7_real (vanishing-errorBound)
-- ---------------------------------------------------------------------
-- For [2╧А, 7] the bound `log(T/(2╧А))` vanishes at the left endpoint,
-- so a constant-D `closedFormSErrorBoundCD` is incompatible. Instead
-- use an errorBound that vanishes at `T = 2╧А`:
--   errorBound z T := (T тИТ 2╧А) ┬╖ y / 1000.
-- Chain: LHS тЙд 11(TтИТ2╧А)y/(15╧А┬╖T┬▓) тЙд (22/15)┬╖╧Б(T)┬╖y/T тЙд smoothTail тЙд тИТIm(model).
-- Key: ╧Б(T) тЙе (TтИТ2╧А)/(T┬╖2╧А) via `log_ge_one_sub_inv` (from add_one_le_exp).
-- Constants: 15╧А┬╖T┬▓ тЙд 15┬╖3.15┬╖49 = 2315.25 тЙд 11000.

/-- тнР **PROVED тАФ `cert_2pi_7_real`.** Vanishing-errorBound cert for the
irreducible first-zero sub-band `[2╧А, 7]`. Closes the 4th and final
first-zero sub-cert. -/
theorem cert_2pi_7_real :
    тИА z : тДВ, тИА T : тДЭ,
      2 * Real.pi тЙд T тЖТ T тЙд 7 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        (T - 2 * Real.pi) * z.im / 1000
          тЙд -((cloudModel [] z + demoDensityTailT T z).im) := by
  intro z T hT2pi hT7 hy hreg
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_nn : 0 тЙд T - 2 * Real.pi := by linarith
  have hy_nn : 0 тЙд z.im := le_of_lt hy
  have h_cloud_zero : (cloudModel ([] : List тДЭ) z).im = 0 := by
    simp [cloudModel]
  have htail := demoDensityTailT_neg_im T z
  have h_split :
      -((cloudModel ([] : List тДЭ) z + demoDensityTailT T z).im)
        = -(cloudModel ([] : List тДЭ) z).im + -(demoDensityTailT T z).im := by
    rw [Complex.add_im]; ring
  -- log(T/(2╧А)) тЙе (T - 2╧А)/T
  have h_T_2pi_div_pos : 0 < T / (2 * Real.pi) := div_pos hT_pos h_2pi_pos
  have h_log_bound : (T - 2 * Real.pi) / T тЙд Real.log (T / (2 * Real.pi)) := by
    have h := Real.add_one_le_exp (-(Real.log (T / (2 * Real.pi))))
    rw [Real.exp_neg, Real.exp_log h_T_2pi_div_pos] at h
    have h_inv : (T / (2 * Real.pi))тБ╗┬╣ = (2 * Real.pi) / T := by rw [inv_div]
    rw [h_inv] at h
    have h_simp : (T - 2 * Real.pi) / T = 1 - (2 * Real.pi) / T := by
      field_simp
    rw [h_simp]
    linarith
  -- ╧Б(T) тЙе (T - 2╧А)/(T ┬╖ 2╧А)
  have h_rho_ge :
      (T - 2 * Real.pi) / (T * (2 * Real.pi)) тЙд zeroDensityRho T := by
    unfold zeroDensityRho
    have h_step :
        (1 / (2 * Real.pi)) * ((T - 2 * Real.pi) / T)
          тЙд (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi)) :=
      mul_le_mul_of_nonneg_left h_log_bound (by positivity)
    have h_eq :
        (T - 2 * Real.pi) / (T * (2 * Real.pi))
          = (1 / (2 * Real.pi)) * ((T - 2 * Real.pi) / T) := by
      have hT_ne : T тЙа 0 := ne_of_gt hT_pos
      have h_2pi_ne : (2 * Real.pi : тДЭ) тЙа 0 := ne_of_gt h_2pi_pos
      rw [mul_comm T (2 * Real.pi), тЖР div_div]
      rw [mul_div_assoc' (1 / (2 * Real.pi)) (T - 2 * Real.pi) T]
      rw [one_div_mul_eq_div]
    rw [h_eq]
    exact h_step
  have h_smooth_22_15 := smoothTailRationalLowerBoundAbs_ge_22_15 hT2pi hy hreg
  -- (T-2╧А)┬╖y/1000 тЙд (22/15)┬╖╧Б(T)┬╖y/T via the ╧Б lower bound + key constant
  have h_smooth_linear :
      (T - 2 * Real.pi) * z.im / 1000
        тЙд (22 / 15 : тДЭ) * zeroDensityRho T * z.im / T := by
    have h_chain :
        (22 / 15 : тДЭ) * ((T - 2 * Real.pi) / (T * (2 * Real.pi))) * z.im / T
          тЙд (22 / 15) * zeroDensityRho T * z.im / T := by
      apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
      apply mul_le_mul_of_nonneg_right _ hy_nn
      apply mul_le_mul_of_nonneg_left h_rho_ge (by norm_num)
    apply le_trans _ h_chain
    -- Goal: (T-2╧А)┬╖y/1000 тЙд (22/15)┬╖((T-2╧А)/(T┬╖2╧А))┬╖y/T
    --     = 11┬╖(T-2╧А)┬╖y/(15╧А┬╖T┬▓)
    have hT_sq_le : T^2 тЙд 49 := by nlinarith
    have h_15piT_le : 15 * Real.pi * T^2 тЙд 11000 := by nlinarith
    have h_prod_nn : 0 тЙд (T - 2 * Real.pi) * z.im := mul_nonneg hT_2pi_nn hy_nn
    have h_rhs_eq :
        (22 / 15 : тДЭ) * ((T - 2 * Real.pi) / (T * (2 * Real.pi))) * z.im / T
          = 11 * (T - 2 * Real.pi) * z.im / (15 * Real.pi * T^2) := by
      have hT_ne : T тЙа 0 := ne_of_gt hT_pos
      have h_pi_ne : Real.pi тЙа 0 := ne_of_gt h_pi_pos
      field_simp
      ring
    rw [h_rhs_eq]
    rw [div_le_div_iffтВА (by norm_num : (0:тДЭ) < 1000) (by positivity)]
    nlinarith [h_15piT_le, h_prod_nn, hy_nn, hT_2pi_nn]
  have h_smooth_lb :
      (T - 2 * Real.pi) * z.im / 1000
        тЙд smoothTailRationalLowerBoundAbs z.re z.im T :=
    le_trans h_smooth_linear h_smooth_22_15
  rw [h_split, htail, h_cloud_zero]
  linarith [h_smooth_lb]

