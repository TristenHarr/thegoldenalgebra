    (hT1 : T ≤ 10)
    (hz : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T)
    (hne : XiPullback z ≠ 0) :
    |(error z).im| ≤ B z :=
  herr hT0 hT1 hz hreg hne

/-- 🌟 **PROVED — Concrete-model specialization** of the low-T adapter. -/
theorem lowT_errorMargin_zeros100ceil
    {error : ℂ → ℂ}
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi)
    (hF_B : F.B = 10)
    (hF_model : F.model = xiCloudDensityModel_zeros100ceil.model)
    (herr : lowTErrorControlled error F.errorBound)
    {z : ℂ} {T : ℝ}
    (hT2pi : 2 * Real.pi ≤ T)
    (hT10 : T ≤ 10)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(error z).im| ≤
      -(xiCloudDensityModel_zeros100ceil.model z).im :=
  lowT_errorMargin_of_firstZeroDirect
    (M := xiCloudDensityModel_zeros100ceil)
    F hF_A hF_B hF_model herr hT2pi hT10 hy hreg

/-- 🎯🎯🎯 **PROVED — Combined three-band constructor for `PerWindowGlobalErrorControl`.**

Given:
- a low-band first-zero certificate (with `A = 2π`, `B = 10`, model matched),
- the low/mid/high error controls,

builds the full `PerWindowGlobalErrorControl xiCloudDensityModel_zeros100ceil error`
struct, ready for the dispatcher. This is the **final landing pad** for the
analytic work: once `hlow`/`hmid`/`hhigh` are supplied, the global error
margin is automatic. -/
noncomputable def perWindowGlobalErrorControl_of_low_mid_high
    {error : ℂ → ℂ}
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi)
    (hF_B : F.B = 10)
    (hF_model : F.model = xiCloudDensityModel_zeros100ceil.model)
    (hlow : lowTErrorControlled error F.errorBound)
    (hmid : closedFormErrorControlledOnFiniteBand error)
    (hhigh : highTErrorControlled error) :
    PerWindowGlobalErrorControl xiCloudDensityModel_zeros100ceil error where
  low := by
    intro z T hT2pi hT10 hy hreg
    exact lowT_errorMargin_zeros100ceil
      F hF_A hF_B hF_model hlow hT2pi hT10 hy hreg
  mid := hmid
  high := by
    intro z T hT140 hy hreg
    exact highT_errorMargin_of_highTErrorControlled
      (M := xiCloudDensityModel_zeros100ceil) (error := error)
      xiCloudDensityModel_zeros100ceil_zeros hhigh hT140 hy hreg

-- =====================================================================
-- CLXXXVe: Decomposition scaffolding — concrete `xiModelError` + global target
-- =====================================================================
-- Makes the log-derivative decomposition trivial-by-definition: define
-- `xiModelError z := Λ[XiPullback] z - M.model z`. Then the entire analytic
-- mountain reduces to three error-bound theorems (low/mid/high) on this
-- concrete residual. Phase1IBP / first-zero / large-T can each target
-- exactly one of those three predicates.

/-- **Canonical error function.** Defined by residual subtraction:
`xiModelError z := logDerivativeResponse XiPullback z - xiCloudDensityModel_zeros100ceil.model z`.

The decomposition `logDeriv = model + error` then holds by definition. -/
noncomputable def xiModelError_zeros100ceil (z : ℂ) : ℂ :=
  logDerivativeResponse XiPullback z
    - xiCloudDensityModel_zeros100ceil.model z

/-- ⭐ **PROVED — Trivial-by-definition decomposition.** -/
theorem xiModelError_zeros100ceil_decomp (z : ℂ) :
    logDerivativeResponse XiPullback z =
      xiCloudDensityModel_zeros100ceil.model z
        + xiModelError_zeros100ceil z := by
  unfold xiModelError_zeros100ceil
  ring

/-- **Global control target for the canonical residual.**
Bundles the three remaining analytic mountains as a single propositional
target: a first-zero certificate matching the low band, plus the three
error-bound predicates instantiated at `xiModelError_zeros100ceil`. -/
structure XiModelErrorGlobalControlTarget where
  F : FirstZeroDirectBandCertificate
  hFA : F.A = 2 * Real.pi
  hFB : F.B = 10
  hFmodel : F.model = xiCloudDensityModel_zeros100ceil.model
  hlow : lowTErrorControlled xiModelError_zeros100ceil F.errorBound
  hmid : closedFormErrorControlledOnFiniteBand xiModelError_zeros100ceil
  hhigh : highTErrorControlled xiModelError_zeros100ceil

/-- ⭐ **PROVED — Existence of admissible `T` for any `z : ℂ`.**
For any complex `z`, picking `T = max(2π, 2·(1+|z.re|+z.im))` gives
`2π ≤ T` and the adaptive-region constraint. -/
lemma exists_admissible_T (z : ℂ) :
    ∃ T : ℝ, 2 * Real.pi ≤ T ∧ 2 * (1 + |z.re| + z.im) ≤ T := by
  refine ⟨max (2 * Real.pi) (2 * (1 + |z.re| + z.im)), ?_, ?_⟩
  · exact le_max_left _ _
  · exact le_max_right _ _

/-- 🌟🌟🌟 **PROVED — Global `LocalXiCloudDensityErrorPackage`** from the
canonical-error global control target.

This is the **final analytic landing pad**: once the three error-bound
hypotheses (lowT/closedForm/highT) are supplied for the canonical
`xiModelError_zeros100ceil` residual, the entire local package falls out,
covering all of `ℂ` (region = `True`). -/
noncomputable def localPackage_global_of_xiModelErrorGlobalControl
    (H : XiModelErrorGlobalControlTarget) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_of_globalErrorControl
    xiCloudDensityModel_zeros100ceil
    xiCloudDensityModel_zeros100ceil_zeros
    xiCloudDensityModel_zeros100ceil_modelAnti
    xiModelError_zeros100ceil
    (fun _ => True)
    (fun z _ => exists_admissible_T z)
    (fun z _ => xiModelError_zeros100ceil_decomp z)
    (perWindowGlobalErrorControl_of_low_mid_high
      H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)

/-- 🌟🌟🌟🌟 **PROVED — Global `XiPullbackAntiHerglotzTarget`** from the
canonical-error global control target.

Since the local package covers all of `ℂ` (region = `True`), its
`implies_regionAntiHerglotz` gives `(Λ[XiPullback] z).im ≤ 0` for all
`z` with `0 < z.im` — exactly `XiPullbackAntiHerglotzTarget`. -/
theorem xiPullbackAntiHerglotzTarget_of_xiModelErrorGlobalControl
    (H : XiModelErrorGlobalControlTarget) :
    XiPullbackAntiHerglotzTarget := by
  intro z hz
  -- Inline the local package's anti-Herglotz on z directly via the
  -- model-Anti + finite-band error margin chain (sidesteps the
  -- `P.region z = (fun _ => True) z` definitional-reduction issue).
  rw [xiModelError_zeros100ceil_decomp z, Complex.add_im]
  have h_model_im :
      (xiCloudDensityModel_zeros100ceil.model z).im ≤ 0 :=
    xiCloudDensityModel_zeros100ceil_modelAnti z hz
  obtain ⟨T, hT2pi, hregT⟩ := exists_admissible_T z
  have h_err_margin :
      |(xiModelError_zeros100ceil z).im|
        ≤ -(xiCloudDensityModel_zeros100ceil.model z).im :=
    errorMargin_of_globalErrorControl
      (M := xiCloudDensityModel_zeros100ceil)
      (error := xiModelError_zeros100ceil)
      xiCloudDensityModel_zeros100ceil_zeros
      (perWindowGlobalErrorControl_of_low_mid_high
        H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)
      hT2pi hz hregT
  have h_err_le :
      (xiModelError_zeros100ceil z).im
        ≤ |(xiModelError_zeros100ceil z).im| :=
    le_abs_self _
  linarith

-- =====================================================================
-- CLXXXVI: Phase 1.1 — localized fluctuation measures (Mathlib measure objects)
-- =====================================================================
-- The §16.1 `FluctuationMeasureData` records `S = N − N₀` at the
-- function level. This section lifts the same data to actual Mathlib
-- `Measure ℝ` objects:
--   `dN = Σ_{j<n} (mult j) • dirac (Z j)`     (Phase 1.1 discrete part)
--   `dN₀ = volume.withDensity ρ`              (Phase 1.1 smooth part)
-- and their localized restrictions to a window `[T, X]`. We do NOT yet
-- subtract them as a `SignedMeasure ℝ` on the whole real line —
-- `dN₀` is infinite globally, so that is the trap. Localized first,
-- whole-line later via `X → ∞`.

namespace Phase1Measure

open MeasureTheory
open scoped ENNReal

/-- **Discrete zero-counting measure:**
  `dN = Σ_{j<n} (mult j) • dirac (Z j)`.
The atomic measure supported on the zero ordinates `{Z 0, …, Z (n-1)}`
with weight `mult j` at each. -/
noncomputable def discreteZeroMeasure
    (D : FluctuationMeasureData) : Measure ℝ :=
  (Finset.range D.n).sum fun j =>
    ((D.mult j : ℝ≥0∞)) • Measure.dirac (D.Z j)

/-- **Smooth zero-counting measure:**
  `dN₀ = volume.withDensity (ENNReal.ofReal ∘ ρ)`,
where `ρ = zeroDensityRho = (1/(2π))·log(u/(2π))`. Infinite on `ℝ`
globally; finite when restricted to a bounded window. -/
noncomputable def smoothZeroCountingMeasure : Measure ℝ :=
  (MeasureTheory.volume : Measure ℝ).withDensity
    (fun u : ℝ => ENNReal.ofReal (zeroDensityRho u))

/-- **Localized discrete measure** on `[T, X]`. -/
noncomputable def discreteZeroMeasureOn
    (D : FluctuationMeasureData) (T X : ℝ) : Measure ℝ :=
  (discreteZeroMeasure D).restrict (Set.Icc T X)

/-- **Localized smooth measure** on `[T, X]`. Finite on any bounded
interval because `ρ` is bounded there. -/
noncomputable def smoothZeroCountingMeasureOn
    (T X : ℝ) : Measure ℝ :=
  smoothZeroCountingMeasure.restrict (Set.Icc T X)

end Phase1Measure

-- =====================================================================
-- CLXXXVII: Bridge — concrete smooth Stieltjes partial via intervalIntegral
-- =====================================================================
-- The §16.2-A `StieltjesPartialSplit` keeps `smoothPart : ℝ → ℝ` abstract.
-- This section pins it down to the explicit interval integral
--   `smoothStieltjesPartial f T X := ∫ u in T..X, f u · ρ(u) du`
-- and constructs `FluctuationMeasureData.toStieltjesPartialSplit` from
-- any `FluctuationMeasureData D` and integrand `f`, with the discrete
-- Σ-of-Diracs side defaulting to `discreteStieltjesPartial D.Z D.mult D.n`.

namespace Phase1Measure

open MeasureTheory
open intervalIntegral

/-- **Smooth Stieltjes partial integral** for a real integrand `f`:
  `∫_T^X f(u) · ρ(u) du`. -/
noncomputable def smoothStieltjesPartial
    (f : ℝ → ℝ) (T X : ℝ) : ℝ :=
  ∫ u in T..X, f u * zeroDensityRho u

/-- **Concrete total finite Stieltjes partial** for `f`:
  `Σ_{T ≤ Z j ≤ X} mult j · f(Z j) − ∫_T^X f(u)·ρ(u) du`.
The function-level realization of `∫_T^X f dS = ∫_T^X f d(N − N₀)`. -/
noncomputable def concreteStieltjesPartial
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) : ℝ :=
  discreteStieltjesPartial D.Z D.mult D.n f T X
    - smoothStieltjesPartial f T X

/-- ⭐ **PROVED — `FluctuationMeasureData` projects to `StieltjesPartialSplit`.**
The discrete side is the canonical `discreteStieltjesPartial`; the smooth
side is the concrete `smoothStieltjesPartial`; the `total` field is the
difference and `total_eq` is `rfl`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toStieltjesPartialSplit
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T : ℝ) :
    StieltjesPartialSplit where
  Z          := D.Z
  mult       := D.mult
  n          := D.n
  f          := f
  T          := T
  smoothPart := fun X => smoothStieltjesPartial f T X
  total      := fun X => concreteStieltjesPartial D f T X
  total_eq   := fun _ => rfl

/-- ⭐ **PROVED — specialization to the imaginary paired-Cauchy kernel.**
Plugs `f := pairedCauchyImKernel x y` into the generic
`toStieltjesPartialSplit`. This is the integrand that appears on the
imaginary side of `∫ K_u(z) dS(u)`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toKernelStieltjesPartialSplit
    (D : FluctuationMeasureData) (x y T : ℝ) :
    StieltjesPartialSplit :=
  D.toStieltjesPartialSplit
    (fun u : ℝ => pairedCauchyImKernel x y u) T

end Phase1Measure

-- =====================================================================
-- CLXXXVIII: Phase 1.3 — finite + improper kernel IBP scaffolds
-- =====================================================================
-- The integration-by-parts identity
--   `∫_T^X k_z(u) dS(u)
--      = k_z(X)·S(X) − k_z(T)·S(T) − ∫_T^X S(u)·k_z'(u) du`
-- packaged as named data. `FiniteKernelStieltjesIBP` carries the finite
-- identity per `X`; `ImproperKernelStieltjesIBP` adds the three limits
-- needed to pass `X → ∞`:
--   (i)  partial X → L
--   (ii) k_z(X)·S(X) → 0  (boundary at ∞)
--   (iii) ∫_T^X S k' → J
-- From these, the improper IBP identity reads `L = −k_z(T)·S(T) − J`
-- and the bound `|L| ≤ |k_z(T)|·B(T) + ∫_T^∞ B(u)·|k_z'(u)| du` follows
-- from `|S u| ≤ B u` and the kernel decay envelopes
-- (`abs_pairedCauchyImKernelDeriv_le_adaptive_18`).

namespace Phase1IBP

open Filter Topology
open intervalIntegral

/-- **IBP boundary term** for the imaginary paired-Cauchy kernel:
  `k_z(X)·S(X) − k_z(T)·S(T)`. -/
noncomputable def kernelBoundaryTerm
    (S : ℝ → ℝ) (x y T X : ℝ) : ℝ :=
  pairedCauchyImKernel x y X * S X
    - pairedCauchyImKernel x y T * S T

/-- **IBP derivative-side integral**:
  `∫_T^X S(u) · k_z'(u) du`. -/
noncomputable def kernelIBPDerivativeIntegral
    (S : ℝ → ℝ) (x y T X : ℝ) : ℝ :=
  ∫ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Finite Stieltjes IBP identity for the imaginary kernel.**
Packages the per-`X` identity
  `partial X = k_z(X)·S(X) − k_z(T)·S(T) − ∫_T^X S k'`.
The `partial` field is the running finite Stieltjes integral
  `∫_T^X k_z(u) dS(u)`
(realized in practice via `concreteStieltjesPartial`). -/
structure FiniteKernelStieltjesIBP where
  S          : ℝ → ℝ
  partialF   : ℝ → ℝ
  x          : ℝ
  y          : ℝ
  T          : ℝ
  finite_ibp :
    ∀ X : ℝ,
      partialF X =
        kernelBoundaryTerm S x y T X
          - kernelIBPDerivativeIntegral S x y T X

/-- **Improper Stieltjes IBP for the imaginary kernel.** Extends the
finite identity with three limits that let us pass `X → ∞`:

* `partial_tendsto`            — `partial X → L`
* `boundary_atTop`             — `k_z(X)·S(X) → 0`
* `derivative_integral_tendsto` — `∫_T^X S k' → J`

The improper IBP identity that follows: `L = −k_z(T)·S(T) − J`. -/
structure ImproperKernelStieltjesIBP where
  S          : ℝ → ℝ
  partialF   : ℝ → ℝ
  x          : ℝ
  y          : ℝ
  T          : ℝ
  L          : ℝ
  finiteIBP  : FiniteKernelStieltjesIBP
  finiteIBP_S_eq        : finiteIBP.S = S
  finiteIBP_partial_eq  : finiteIBP.partialF = partialF
  finiteIBP_x_eq        : finiteIBP.x = x
  finiteIBP_y_eq        : finiteIBP.y = y
  finiteIBP_T_eq        : finiteIBP.T = T
  partialF_tendsto :
    Tendsto partialF atTop (𝓝 L)
  boundary_atTop :
    Tendsto
      (fun X : ℝ => pairedCauchyImKernel x y X * S X)
      atTop
      (𝓝 0)
  derivative_integral_tendsto :
    ∃ J : ℝ,
      Tendsto
        (fun X : ℝ => kernelIBPDerivativeIntegral S x y T X)
        atTop
        (𝓝 J)

/-- ⭐ **PROVED — improper IBP identity: `L = −k_z(T)·S(T) − J`.**
The three limits combined with the per-`X` finite identity force the
limiting value of the partial integral to be the boundary term at `T`
plus the (negated) derivative-side integral at infinity. -/
theorem ImproperKernelStieltjesIBP.improper_identity
    (I : ImproperKernelStieltjesIBP) :
    ∃ J : ℝ,
      Tendsto
        (fun X : ℝ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (𝓝 J) ∧
      I.L = - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J := by
  obtain ⟨J, hJ⟩ := I.derivative_integral_tendsto
  refine ⟨J, hJ, ?_⟩
  -- partial X = k(X)·S(X) − k(T)·S(T) − ∫_T^X S k'
  have h_finite_X :
      ∀ X : ℝ,
        I.partialF X =
          pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X := by
    intro X
    have h := I.finiteIBP.finite_ibp X
    -- rewrite finiteIBP fields → I fields via the *_eq hypotheses
    rw [I.finiteIBP_partial_eq] at h
    unfold kernelBoundaryTerm at h
    rw [I.finiteIBP_S_eq, I.finiteIBP_x_eq, I.finiteIBP_y_eq, I.finiteIBP_T_eq] at h
    exact h
  -- Pass to the limit `X → ∞`.
  have h_const :
      Tendsto
        (fun _ : ℝ => pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (𝓝 (pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    tendsto_const_nhds
  have h_diff :
      Tendsto
        (fun X : ℝ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (𝓝 (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    I.boundary_atTop.sub h_const
  have h_rhs :
      Tendsto
        (fun X : ℝ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T
            - kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (𝓝 (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) :=
    h_diff.sub hJ
  -- partial = RHS as functions, so the limit of partial is the same.
  have h_partial_rhs :
      (fun X : ℝ => I.partialF X) =
      (fun X : ℝ =>
        pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X) :=
    funext h_finite_X
  have h_partial_lim :
      Tendsto (fun X : ℝ => I.partialF X) atTop
        (𝓝 (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) := by
    rw [h_partial_rhs]; exact h_rhs
  -- Unique limit of `partial` ⟹ `L = 0 − k(T)·S(T) − J`.
  have h_unique :
      I.L = 0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J :=
    tendsto_nhds_unique I.partialF_tendsto h_partial_lim
  linarith

/-- ⭐ **PROVED — improper IBP wrapper.** Extract the `ImproperStieltjesIntegralData`
of §16.2 from an `ImproperKernelStieltjesIBP`. -/
noncomputable def ImproperKernelStieltjesIBP.toImproperData
    (I : ImproperKernelStieltjesIBP) :
    ImproperStieltjesIntegralData where
  F        := I.partialF
  T        := I.T
  L        := I.L
  converges := I.partialF_tendsto

-- ---------------------------------------------------------------------
-- CLXXXIX: IBP-side bound on |L|
-- ---------------------------------------------------------------------
-- With `|S(u)| ≤ B(u)` on `[T, ∞)` and the derivative-side integral
-- bounded in absolute value by ∫_T^∞ B(u)·|k_z'(u)| du, the improper
-- identity `L = −k_z(T)·S(T) − J` gives
--   |L|  ≤  |k_z(T)|·B(T) + |J|
--         ≤  |k_z(T)|·B(T) + ∫_T^∞ B(u)·|k_z'(u)| du.
-- The first inequality is triangle; the second is the hypothesis on
-- the derivative-side integral.

/-- ⭐ **PROVED — triangle bound on the improper IBP value.**
`|L| ≤ |k_z(T)·S(T)| + |J|`. Pure arithmetic from the improper IBP
identity. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_triangle
    (I : ImproperKernelStieltjesIBP) :
    ∃ J : ℝ,
      Tendsto
        (fun X : ℝ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (𝓝 J) ∧
      |I.L| ≤ |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
  obtain ⟨J, hJ, hL⟩ := I.improper_identity
  refine ⟨J, hJ, ?_⟩
  -- L = -k(T)·S(T) - J, so |L| = |-k·S - J| ≤ |k·S| + |J|.
  rw [hL]
  calc |(- pairedCauchyImKernel I.x I.y I.T * I.S I.T) - J|
      ≤ |- pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := abs_sub _ _
    _ = |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
        rw [neg_mul, abs_neg]

/-- ⭐ **PROVED — `|L|` bound via `|S(T)| ≤ B(T)` and a derivative-integral
envelope.** Given:
- `|S(u)| ≤ B(u)` on `[T, ∞)`;
- the derivative-side integral has limit `J` with `|J| ≤ Jbound`;
the improper IBP value satisfies
  `|L|  ≤  |k_z(T)|·B(T)  +  Jbound`.

The shape matches the `ibpMargin` field of `ImaginaryStieltjesTailIBPBound`
(§13, CXLIV): `|k_z(T)|·B(T) + integralBound ≤ modelMargin`. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_of_S_and_J_bound
    (I : ImproperKernelStieltjesIBP)
    (B : ℝ → ℝ)
    (hS_bound : ∀ u : ℝ, I.T ≤ u → |I.S u| ≤ B u)
    (Jbound : ℝ)
    (hJ_bound :
      ∀ J : ℝ,
        Tendsto
          (fun X : ℝ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
          atTop
          (𝓝 J) → |J| ≤ Jbound) :
    |I.L| ≤ |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound := by
  obtain ⟨J, hJ, hLtri⟩ := I.abs_L_le_triangle
  have hJ_le : |J| ≤ Jbound := hJ_bound J hJ
  have hS_T : |I.S I.T| ≤ B I.T := hS_bound I.T le_rfl
  have h_kS : |pairedCauchyImKernel I.x I.y I.T * I.S I.T|
              ≤ |pairedCauchyImKernel I.x I.y I.T| * B I.T := by
    rw [abs_mul]
    exact mul_le_mul_of_nonneg_left hS_T (abs_nonneg _)
  linarith [hLtri, hJ_le, h_kS]

end Phase1IBP

-- =====================================================================
-- CXC: Closed-form discharge of `ImaginaryStieltjesTailIBPBound`
-- =====================================================================
-- Threads `Phase1IBP.ImproperKernelStieltjesIBP` into the existing
-- §13 `ImaginaryStieltjesTailIBPBound`. The discharge requires:
--   • the improper IBP package (which we just defined);
--   • a bound function `B : ℝ → ℝ` for the fluctuation;
--   • a closed-form bound `Jbound` for the derivative-side improper
--     integral (the analytic content that produces the `18y/u³` decay
--     envelope, currently a hypothesis until the next-pass IBP grind
--     produces it from `abs_pairedCauchyImKernelDeriv_le_adaptive_18`).
-- The output is an `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
-- is exactly the IBP-side bound the §13 chain consumes.

namespace Phase1IBP

open Filter Topology

/-- ⭐ **PROVED — `ImproperKernelStieltjesIBP` discharges
`ImaginaryStieltjesTailIBPBound`.** Given:

* the improper IBP package `I`;
* the bound function `B` for `|S|` on `[T, ∞)`;
* a closed-form envelope `Jbound` for the derivative-side integral;
* and the margin hypothesis `|k_z(T)|·B(T) + Jbound ≤ modelMargin`
  (already certified by the §13/§CLXXXIII slab bundle in the form
  `closedFormSErrorBoundCD C D y T ≤ -(model z).im`),

construct the §13 `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
field is the headline inequality. -/
noncomputable def ImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : ImproperKernelStieltjesIBP)
    (B : ℝ → ℝ)
    (hS_bound : ∀ u : ℝ, I.T ≤ u → |I.S u| ≤ B u)
    (Jbound : ℝ)
    (modelMargin : ℝ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound ≤ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

end Phase1IBP

-- =====================================================================
-- §CXCI. Smooth finite-window kernel IBP (Phase 1.3 grind, smooth side)
-- =====================================================================
-- The first concrete piece of the IBP chain. For a closed window
-- `[T, X]` with `0 < T ≤ X`, the integration-by-parts identity
--   `∫_T^X k_z(u)·ρ(u) du
--      = k_z(X)·S(X) − k_z(T)·S(T) − ∫_T^X S(u)·k_z'(u) du`
-- where `S(u) := ∫_T^u ρ(v) dv = smoothCountingPrimitive T u`.
-- This is the *smooth* half of `FiniteKernelStieltjesIBP`; the discrete
-- Abel summation against the zero Diracs is §CXCII (next).
-- Built on Mathlib's:
--   • `intervalIntegral.integral_hasDerivAt_right` (FTC, upper endpoint)
--   • `intervalIntegral.integral_mul_deriv_eq_deriv_mul` (IBP)
--   • `Real.continuousAt_log` (continuity of `log` away from 0).

namespace Phase1IBP

open MeasureTheory Filter Topology

/-- **Smooth counting primitive** for the zero-counting density:
  `S(X) = ∫_T^X ρ(u) du`. -/
noncomputable def smoothCountingPrimitive (T X : ℝ) : ℝ :=
  ∫ u in T..X, zeroDensityRho u

/-- ⭐ **PROVED — `S(T) = 0`**. Trivial via `integral_same`. -/
lemma smoothCountingPrimitive_self (T : ℝ) :
    smoothCountingPrimitive T T = 0 := by
  unfold smoothCountingPrimitive
  exact intervalIntegral.integral_same

/-- ⭐ **PROVED — `zeroDensityRho` is continuous at any `X > 0`.**
`ρ(u) = (1/(2π))·log(u/(2π))`; `log` is continuous away from `0`. -/
lemma zeroDensityRho_continuousAt {X : ℝ} (hX : 0 < X) :
    ContinuousAt zeroDensityRho X := by
  unfold zeroDensityRho
  have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
  have h_div_pos : 0 < X / (2 * Real.pi) := div_pos hX h2pi_pos
  have h_div_ne : X / (2 * Real.pi) ≠ 0 := ne_of_gt h_div_pos
  have h_inner : ContinuousAt (fun u : ℝ => u / (2 * Real.pi)) X :=
    (continuous_id.div_const _).continuousAt
  -- Use `ContinuousAt.log` which composes cleanly (avoids the
  -- `HDiv.hDiv` unification trap that bites `Real.continuousAt_log.comp`).
  have h_log : ContinuousAt (fun u : ℝ => Real.log (u / (2 * Real.pi))) X :=
    h_inner.log h_div_ne
  exact continuousAt_const.mul h_log

/-- ⭐ **PROVED — `zeroDensityRho` is continuous on `Set.Ioi 0`.** -/
lemma zeroDensityRho_continuousOn_Ioi :
    ContinuousOn zeroDensityRho (Set.Ioi 0) :=
  fun _ hu => (zeroDensityRho_continuousAt hu).continuousWithinAt

/-- ⭐ **PROVED — `zeroDensityRho` is `IntervalIntegrable` on `[T, X]`
when `0 < T ≤ X`.** Continuity on the compact `[T, X] ⊂ (0, ∞)` gives
integrability. -/
lemma zeroDensityRho_intervalIntegrable
    {T X : ℝ} (hT : 0 < T) (hTX : T ≤ X) :
    IntervalIntegrable zeroDensityRho MeasureTheory.volume T X := by
  refine ContinuousOn.intervalIntegrable_of_Icc hTX ?_
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  exact (zeroDensityRho_continuousAt hu_pos).continuousWithinAt

/-- ⭐ **PROVED — FTC: `smoothCountingPrimitive T` is differentiable on
`(0, ∞)` and its derivative is `zeroDensityRho`.** -/
lemma smoothCountingPrimitive_hasDerivAt
    {T X : ℝ} (hT : 0 < T) (hTX : T ≤ X) :
    HasDerivAt (fun u : ℝ => smoothCountingPrimitive T u)
      (zeroDensityRho X) X := by
  have hX : 0 < X := lt_of_lt_of_le hT hTX
  have hX_cont : ContinuousAt zeroDensityRho X := zeroDensityRho_continuousAt hX
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  -- StronglyMeasurableAtFilter via a continuity neighborhood: on `Ioi 0`,
  -- `ρ` is continuous, hence AE-strongly-measurable.
  have h_Ioi_mem : Set.Ioi (0 : ℝ) ∈ 𝓝 X := Ioi_mem_nhds hX
  have h_smaf : StronglyMeasurableAtFilter zeroDensityRho (𝓝 X) MeasureTheory.volume :=
    ⟨Set.Ioi 0, h_Ioi_mem,
     zeroDensityRho_continuousOn_Ioi.aestronglyMeasurable measurableSet_Ioi⟩
  exact intervalIntegral.integral_hasDerivAt_right h_int h_smaf hX_cont

/-- ⭐ **PROVED — `pairedCauchyImKernel x y` is differentiable at every `u`
for `y > 0`, with `HasDerivAt`-form derivative `pairedCauchyImKernelDeriv`.**
Lifts the `deriv` form (CXLV `deriv_pairedCauchyImKernel`) to the
`HasDerivAt` form by composing `DifferentiableAt` combinators and
substituting the proven derivative value. -/
lemma pairedCauchyImKernel_hasDerivAt
    {y : ℝ} (hy : 0 < y) (x u : ℝ) :
    HasDerivAt (fun v : ℝ => pairedCauchyImKernel x y v)
      (pairedCauchyImKernelDeriv x y u) u := by
  have hd1_pos : (0 : ℝ) < (x - u)^2 + y^2 := by positivity
  have hd2_pos : (0 : ℝ) < (x + u)^2 + y^2 := by positivity
  have h_diff : DifferentiableAt ℝ (fun v : ℝ => pairedCauchyImKernel x y v) u := by
    unfold pairedCauchyImKernel
    have h1 : DifferentiableAt ℝ (fun v : ℝ => (x - v)^2 + y^2) u :=
      (((differentiableAt_const x).sub differentiableAt_id).pow 2).add_const _
    have h2 : DifferentiableAt ℝ (fun v : ℝ => (x + v)^2 + y^2) u :=
      (((differentiableAt_const x).add differentiableAt_id).pow 2).add_const _
    have hi1 : DifferentiableAt ℝ (fun v : ℝ => 1 / ((x - v)^2 + y^2)) u :=
      (differentiableAt_const _).div h1 (ne_of_gt hd1_pos)
    have hi2 : DifferentiableAt ℝ (fun v : ℝ => 1 / ((x + v)^2 + y^2)) u :=
      (differentiableAt_const _).div h2 (ne_of_gt hd2_pos)
    exact (differentiableAt_const (-y)).mul (hi1.add hi2)
  have h_value : deriv (fun v : ℝ => pairedCauchyImKernel x y v) u
                  = pairedCauchyImKernelDeriv x y u :=
    deriv_pairedCauchyImKernel x y u hy
  rw [← h_value]
  exact h_diff.hasDerivAt

/-- ⭐ **PROVED — `pairedCauchyImKernelDeriv x y` is continuous on `ℝ`
for `y > 0`.** Used to discharge the integrability hypothesis of IBP. -/
lemma pairedCauchyImKernelDeriv_continuous
    {y : ℝ} (hy : 0 < y) (x : ℝ) :
    Continuous (fun u : ℝ => pairedCauchyImKernelDeriv x y u) := by
  unfold pairedCauchyImKernelDeriv
  have h_plus_sq : Continuous (fun u : ℝ => ((x + u)^2 + y^2)^2) := by
    have h : Continuous (fun u : ℝ => (x + u)^2 + y^2) :=
      ((continuous_const.add continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have h_minus_sq : Continuous (fun u : ℝ => ((x - u)^2 + y^2)^2) := by
    have h : Continuous (fun u : ℝ => (x - u)^2 + y^2) :=
      ((continuous_const.sub continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have hne_plus : ∀ u : ℝ, ((x + u)^2 + y^2)^2 ≠ 0 := fun u => by
    have : 0 < ((x + u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have hne_minus : ∀ u : ℝ, ((x - u)^2 + y^2)^2 ≠ 0 := fun u => by
    have : 0 < ((x - u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have h_div_plus : Continuous (fun u : ℝ => (x + u) / ((x + u)^2 + y^2)^2) :=
    (continuous_const.add continuous_id).div h_plus_sq hne_plus
  have h_div_minus : Continuous (fun u : ℝ => (x - u) / ((x - u)^2 + y^2)^2) :=
    (continuous_const.sub continuous_id).div h_minus_sq hne_minus
  exact continuous_const.mul (h_div_plus.sub h_div_minus)

/-- ⭐ **PROVED — `pairedCauchyImKernelDeriv` is `IntervalIntegrable`** on
any window. Direct from continuity. -/
lemma pairedCauchyImKernelDeriv_intervalIntegrable
    {y : ℝ} (hy : 0 < y) (x T X : ℝ) :
    IntervalIntegrable (fun u : ℝ => pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
  (pairedCauchyImKernelDeriv_continuous hy x).intervalIntegrable T X

/-- 🌟 **PROVED — SMOOTH FINITE-WINDOW IBP IDENTITY** for the imaginary
paired-Cauchy kernel against the zero-counting density:

  `∫_T^X k_z(u)·ρ(u) du
     = k_z(X)·S(X) − k_z(T)·S(T) − ∫_T^X S(u)·k_z'(u) du`

where `S(u) := smoothCountingPrimitive T u`. The smooth half of the
finite Stieltjes IBP — combined with the discrete Abel summation
(next), this yields the first concrete inhabitant of
`FiniteKernelStieltjesIBP`. -/
theorem smooth_zeroDensity_kernel_ibp
    {y : ℝ} (hy : 0 < y) (x T X : ℝ)
    (hT : 0 < T) (hTX : T ≤ X) :
    (∫ u in T..X, pairedCauchyImKernel x y u * zeroDensityRho u) =
      pairedCauchyImKernel x y X * smoothCountingPrimitive T X
        - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
        - ∫ u in T..X,
            smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
  have hu_deriv :
      ∀ u ∈ Set.uIcc T X,
        HasDerivAt (fun v : ℝ => pairedCauchyImKernel x y v)
          (pairedCauchyImKernelDeriv x y u) u :=
    fun u _ => pairedCauchyImKernel_hasDerivAt hy x u
  have hv_deriv :
      ∀ u ∈ Set.uIcc T X,
        HasDerivAt (fun v : ℝ => smoothCountingPrimitive T v)
          (zeroDensityRho u) u := by
    intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    exact smoothCountingPrimitive_hasDerivAt hT hu.1
  have hu'_int :
      IntervalIntegrable (fun u : ℝ => pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    pairedCauchyImKernelDeriv_intervalIntegrable hy x T X
  have hv'_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  have h_ibp :=
    intervalIntegral.integral_mul_deriv_eq_deriv_mul
      hu_deriv hv_deriv hu'_int hv'_int
  -- h_ibp :  ∫ k * ρ = k(X)·S(X) − k(T)·S(T) − ∫ k' * S
  -- target:  ∫ k * ρ = k(X)·S(X) − k(T)·S(T) − ∫ S * k'
  have h_swap :
      (∫ u in T..X,
         pairedCauchyImKernelDeriv x y u * smoothCountingPrimitive T u) =
      (∫ u in T..X,
         smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u) := by
    refine intervalIntegral.integral_congr ?_
    intro u _; exact mul_comm _ _
  linarith [h_ibp, h_swap]

end Phase1IBP

-- =====================================================================
-- §CXCII-A. Ordered discrete Abel summation (Phase 1.3 grind, discrete side)
-- =====================================================================
-- The discrete half of `FiniteKernelStieltjesIBP`. The safe path:
-- prove the pure algebraic summation-by-parts identity over
-- `Finset.range (n + 1)` first, then instantiate with clipped zero
-- weights against the imaginary kernel.
--
-- Pure algebra:
--   `∑_{j ≤ n} a_j · b_j
--      = (∑_{j ≤ n} a_j) · b_n
--        − ∑_{j < n} (∑_{i ≤ j} a_i) · (b_{j+1} − b_j)`
--
-- Clipped instantiation:
--   `a_j := if T ≤ Z_j ≤ X then mult_j else 0`
--   `b_j := f (Z_j)`.

namespace Phase1IBP

open BigOperators

/-- ⭐ **PROVED — pure algebraic Abel/summation-by-parts identity over
`Finset.range (n + 1)`.** -/
lemma fin_sum_mul_eq_boundary_sub_sum_succ
    (n : ℕ) (a b : ℕ → ℝ) :
    (∑ j ∈ Finset.range (n + 1), a j * b j)
      =
    (∑ j ∈ Finset.range (n + 1), a j) * b n
      -
    ∑ j ∈ Finset.range n,
      (∑ i ∈ Finset.range (j + 1), a i) * (b (j + 1) - b j) := by
  induction n with
  | zero => simp
  | succ n ih =>
    rw [Finset.sum_range_succ (fun j => a j * b j) (n + 1), ih,
        Finset.sum_range_succ (fun j => a j) (n + 1),
        Finset.sum_range_succ
          (fun j => (∑ i ∈ Finset.range (j + 1), a i) * (b (j + 1) - b j)) n]
    ring

/-- **Discrete counting primitive** for the zero list, clipped to `[T, X]`:
  `N_{T,X}(D) = Σ_{j < n : T ≤ Z_j ≤ X} mult_j`. -/
noncomputable def discreteCountingPrimitive
    (D : FluctuationMeasureData) (T X : ℝ) : ℝ :=
  ∑ j ∈ Finset.range D.n,
    if T ≤ D.Z j ∧ D.Z j ≤ X then (D.mult j : ℝ) else 0

/-- **Discrete kernel partial** for an arbitrary integrand `f`:
  `Σ_{j < n : T ≤ Z_j ≤ X} mult_j · f(Z_j)`. -/
noncomputable def discreteKernelPartial
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) : ℝ :=
  ∑ j ∈ Finset.range D.n,
    if T ≤ D.Z j ∧ D.Z j ≤ X then (D.mult j : ℝ) * f (D.Z j) else 0

/-- ⭐ **PROVED — counting primitive at `X = T`.** Only ordinates
exactly at `T` contribute. -/
lemma discreteCountingPrimitive_left
    (D : FluctuationMeasureData) (T : ℝ) :
    discreteCountingPrimitive D T T
      =
    ∑ j ∈ Finset.range D.n,
      if D.Z j = T then (D.mult j : ℝ) else 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : D.Z j = T
  · have hpair : T ≤ D.Z j ∧ D.Z j ≤ T := ⟨h.ge, h.le⟩
    simp [h, hpair]
  · have hnot : ¬ (T ≤ D.Z j ∧ D.Z j ≤ T) := by
      intro hpair
      exact h (le_antisymm hpair.2 hpair.1)
    simp [h, hnot]

/-- ⭐ **PROVED — counting primitive is monotone in the upper cutoff.** -/
lemma discreteCountingPrimitive_mono
    (D : FluctuationMeasureData) (T : ℝ) :
    Monotone (fun X => discreteCountingPrimitive D T X) := by
  classical
  intro X Y hXY
  unfold discreteCountingPrimitive
  apply Finset.sum_le_sum
  intro j _
  have hmult_nn : (0 : ℝ) ≤ (D.mult j : ℝ) := Nat.cast_nonneg _
  by_cases hTX : T ≤ D.Z j
  · by_cases hZX : D.Z j ≤ X
    · have hZY : D.Z j ≤ Y := le_trans hZX hXY
      have hX_pair : T ≤ D.Z j ∧ D.Z j ≤ X := ⟨hTX, hZX⟩
      have hY_pair : T ≤ D.Z j ∧ D.Z j ≤ Y := ⟨hTX, hZY⟩
      rw [if_pos hX_pair, if_pos hY_pair]
    · by_cases hZY : D.Z j ≤ Y
      · have hY_pair : T ≤ D.Z j ∧ D.Z j ≤ Y := ⟨hTX, hZY⟩
        have hX_nopair : ¬ (T ≤ D.Z j ∧ D.Z j ≤ X) := fun ⟨_, h⟩ => hZX h
        rw [if_neg hX_nopair, if_pos hY_pair]
        exact hmult_nn
      · have hX_nopair : ¬ (T ≤ D.Z j ∧ D.Z j ≤ X) := fun ⟨_, h⟩ => hZX h
        have hY_nopair : ¬ (T ≤ D.Z j ∧ D.Z j ≤ Y) := fun ⟨_, h⟩ => hZY h
        rw [if_neg hX_nopair, if_neg hY_nopair]
  · have hX_nopair : ¬ (T ≤ D.Z j ∧ D.Z j ≤ X) := fun ⟨h, _⟩ => hTX h
    have hY_nopair : ¬ (T ≤ D.Z j ∧ D.Z j ≤ Y) := fun ⟨h, _⟩ => hTX h
    rw [if_neg hX_nopair, if_neg hY_nopair]

/-- **Ordered-zero-list fluctuation data.** Extends `FluctuationMeasureData`
with monotonicity of the ordinate sequence — the discrete Abel summation
needs the ordinates in order. -/
structure OrderedFluctuationMeasureData extends FluctuationMeasureData where
  mono_Z : Monotone Z

/-- **Clipped weight**: `a_j = mult_j` if `T ≤ Z_j ≤ X`, else `0`. -/
noncomputable def clippedWeight
    (D : FluctuationMeasureData) (T X : ℝ) : ℕ → ℝ :=
  fun j => if T ≤ D.Z j ∧ D.Z j ≤ X then (D.mult j : ℝ) else 0

/-- ⭐ **PROVED — `discreteKernelPartial` rewritten as a clipped pure sum.**
The clipped weight absorbs the indicator so the partial collapses to
`∑ a_j · b_j` for `a_j = clippedWeight`, `b_j = f (Z_j)`. -/
lemma discreteKernelPartial_eq_clippedSum
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) :
    discreteKernelPartial D f T X
      =
    ∑ j ∈ Finset.range D.n,
      clippedWeight D T X j * f (D.Z j) := by
  unfold discreteKernelPartial clippedWeight
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : T ≤ D.Z j ∧ D.Z j ≤ X
  · rw [if_pos h, if_pos h]
  · rw [if_neg h, if_neg h, zero_mul]

/-- ⭐ **PROVED — `discreteCountingPrimitive` is the sum of `clippedWeight`.** -/
lemma discreteCountingPrimitive_eq_clippedSum
    (D : FluctuationMeasureData) (T X : ℝ) :
    discreteCountingPrimitive D T X
      = ∑ j ∈ Finset.range D.n, clippedWeight D T X j := rfl

/-- 🌟 **PROVED — RAW ABEL IDENTITY** for the ordered discrete kernel
partial over `Finset.range (m + 1)`, with `D.n = m + 1`.

  `discreteKernelPartial D f T X
     = (∑ clippedWeight) · f (Z m)
       − ∑_{j < m} (cumulative clippedWeight up to j) · (f (Z_{j+1}) − f (Z_j))`

The discrete-side analogue of `smooth_zeroDensity_kernel_ibp` (§CXCI),
generic in the integrand. -/
theorem ordered_discrete_kernel_abel_clipped
    (D : OrderedFluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) {m : ℕ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (∑ j ∈ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) * f (D.Z m)
      -
    ∑ j ∈ Finset.range m,
      (∑ i ∈ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (f (D.Z (j + 1)) - f (D.Z j)) := by
  rw [discreteKernelPartial_eq_clippedSum, hn]
  exact fin_sum_mul_eq_boundary_sub_sum_succ m
    (fun j => clippedWeight D.toFluctuationMeasureData T X j)
    (fun j => f (D.Z j))

/-- 🌟 **PROVED — paired-Cauchy-imaginary kernel Abel identity.**
Specializes `ordered_discrete_kernel_abel_clipped` to
`f := pairedCauchyImKernel x y`. This is the discrete-side companion
to `smooth_zeroDensity_kernel_ibp` (§CXCI). -/
theorem ordered_discrete_pairedCauchyIm_abel_clipped
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    (∑ j ∈ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) *
          pairedCauchyImKernel x y (D.Z m)
      -
    ∑ j ∈ Finset.range m,
      (∑ i ∈ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (pairedCauchyImKernel x y (D.Z (j + 1))
          - pairedCauchyImKernel x y (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- §CXCII-B. Named primitives, Abel remainder, finite fluctuation
-- =====================================================================
-- Wraps the Abel identity in readable named forms:
--   • `clippedCumulativeWeight`: the prefix-sum primitive appearing on
--     the Abel RHS (this is `discreteCountingPrimitive` restricted to
--     `Finset.range (j + 1)`);
--   • `discreteAbelRemainder f`: the sum of cumulative × kernel-difference
--     terms (the discrete analogue of `∫ S·k'`);
--   • `discreteKernelAbelRemainder`: paired-Cauchy specialization;
--   • `ordered_discrete_kernel_ibp_raw`: the compact discrete IBP.

/-- **Cumulative clipped weight** through index `j`:
  `Σ_{i ≤ j} clippedWeight i = Σ_{i ≤ j, T ≤ Z i ≤ X} mult i`. -/
noncomputable def clippedCumulativeWeight
    (D : OrderedFluctuationMeasureData) (T X : ℝ) (j : ℕ) : ℝ :=
  ∑ i ∈ Finset.range (j + 1), clippedWeight D.toFluctuationMeasureData T X i

/-- ⭐ **PROVED — `clippedCumulativeWeight` unfolds to the discrete
counting prefix sum (rfl).** -/
lemma clippedCumulativeWeight_eq_discreteCountingPrefix
    (D : OrderedFluctuationMeasureData) (T X : ℝ) (j : ℕ) :
    clippedCumulativeWeight D T X j
      =
    ∑ i ∈ Finset.range (j + 1),
      if T ≤ D.Z i ∧ D.Z i ≤ X then (D.mult i : ℝ) else 0 := rfl

/-- ⭐ **PROVED — Abel identity with the named primitives.** Rewrites
`ordered_discrete_kernel_abel_clipped` using `discreteCountingPrimitive`
and `clippedCumulativeWeight`. Pure renaming; defeq through both. -/
theorem ordered_discrete_kernel_abel_clipped_named
    (D : OrderedFluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) {m : ℕ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (discreteCountingPrimitive D.toFluctuationMeasureData T X) * f (D.Z m)
      -
    ∑ j ∈ Finset.range m,
      clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D f T X hn

/-- **Discrete Abel remainder** for an arbitrary integrand `f`:
the sum of cumulative weights × kernel differences. Discrete analogue
of `∫_T^X S(u)·f'(u) du`. -/
noncomputable def discreteAbelRemainder
    (D : OrderedFluctuationMeasureData) (f : ℝ → ℝ)
    (T X : ℝ) (m : ℕ) : ℝ :=
  ∑ j ∈ Finset.range m,
    clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j))

/-- **Discrete Abel remainder** specialized to the imaginary
paired-Cauchy kernel. -/
noncomputable def discreteKernelAbelRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) (m : ℕ) : ℝ :=
  discreteAbelRemainder D (fun u => pairedCauchyImKernel x y u) T X m

/-- 🌟 **PROVED — RAW DISCRETE IBP** for the imaginary paired-Cauchy
kernel against the clipped zero counts, in named-primitive form:

  `discreteKernelPartial D k T X
     = discreteCountingPrimitive D T X · k(Z_m)
       − discreteKernelAbelRemainder D x y T X m`.

The compact discrete-side companion to `smooth_zeroDensity_kernel_ibp`. -/
theorem ordered_discrete_kernel_ibp_raw
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m := by
  unfold discreteKernelAbelRemainder discreteAbelRemainder
  exact ordered_discrete_kernel_abel_clipped_named D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- §CXCIII. Finite fluctuation primitive + raw combined IBP
-- =====================================================================
-- Now combine the smooth (§CXCI) and discrete (§CXCII) halves into the
-- finite-window fluctuation IBP identity.
--
--   `S_total(u) := S_discrete(u) − S_smooth(u)`
--   `F(T, X)   := ∫_T^X k dS_total = discreteKernelPartial − ∫ k·ρ`
--
-- The raw identity reads
--
--   `F(T, X) = N(X)·k(Z_m) − R_discrete
--             − (k(X)·S_smooth(X) − k(T)·S_smooth(T) − ∫ S_smooth · k')`
--
-- Note: the boundary on the discrete side is at `k(Z_m)`, not yet at
-- `k(X)`. The endpoint correction is §CXCIV (next patch).

/-- **Finite fluctuation primitive**:
  `S(T, X) := N(X) − S_smooth(X)` (discrete count minus smooth integral). -/
noncomputable def finiteFluctuationPrimitive
    (D : OrderedFluctuationMeasureData) (T X : ℝ) : ℝ :=
  discreteCountingPrimitive D.toFluctuationMeasureData T X
    - smoothCountingPrimitive T X

/-- ⭐ **PROVED — finite fluctuation primitive at the left endpoint.**
`S_smooth(T) = 0`, so `S(T, T) = N(T, T)`. -/
lemma finiteFluctuationPrimitive_left
    (D : OrderedFluctuationMeasureData) (T : ℝ) :
    finiteFluctuationPrimitive D T T
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T T := by
  simp [finiteFluctuationPrimitive, smoothCountingPrimitive_self]

/-- ⭐ **PROVED — when there is no zero atom at `T`, the discrete count
at `X = T` vanishes.** Optional convention; keeps boundary atoms
visible by being separately stated rather than baked into the
primitive. -/
lemma discreteCountingPrimitive_left_zero_of_no_atom
    (D : FluctuationMeasureData) (T : ℝ)
    (hno : ∀ j ∈ Finset.range D.n, D.Z j ≠ T) :
    discreteCountingPrimitive D T T = 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j hj
  have hnot : ¬ (T ≤ D.Z j ∧ D.Z j ≤ T) := by
    intro h
    exact hno j hj (le_antisymm h.2 h.1)
  simp [hnot]

/-- **Finite fluctuation kernel partial** for the imaginary paired-Cauchy
kernel:
  `F(T, X) := Σ_clipped mult·k(Z) − ∫_T^X k·ρ`. -/
noncomputable def finiteFluctuationKernelPartial
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) : ℝ :=
  discreteKernelPartial D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X
    -
  ∫ u in T..X,
      pairedCauchyImKernel x y u * zeroDensityRho u

/-- **Raw mixed remainder** combining the discrete Abel remainder and
the smooth integral `∫ S_smooth · k'`. The first ingredient of the
finite fluctuation IBP body. -/
noncomputable def finiteFluctuationRawRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) (m : ℕ) : ℝ :=
  discreteKernelAbelRemainder D x y T X m
    -
  ∫ u in T..X,
      smoothCountingPrimitive T u *
        pairedCauchyImKernelDeriv x y u

/-- 🌟🌟 **PROVED — RAW FINITE FLUCTUATION IBP IDENTITY.**

Combines `ordered_discrete_kernel_ibp_raw` (§CXCII) and
`smooth_zeroDensity_kernel_ibp` (§CXCI) into

  `finiteFluctuationKernelPartial D x y T X
     = N(X)·k(Z_m) − R_discrete
       − (k(X)·S_smooth(X) − k(T)·S_smooth(T) − ∫ S_smooth·k')`.

The boundary on the discrete side is at `k(Z_m)` (the last ordinate of
the indexed finite list), NOT yet at `k(X)`. Bringing the boundary to
`k(X)` requires the endpoint correction `k(X) − k(Z_m)`, which is
§CXCIV. This raw form is the honest output of summation-by-parts plus
FTC IBP. -/
theorem finiteFluctuationKernelPartial_raw_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T ≤ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m
      -
    (pairedCauchyImKernel x y X * smoothCountingPrimitive T X
      - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
      - ∫ u in T..X,
          smoothCountingPrimitive T u *
            pairedCauchyImKernelDeriv x y u) := by
  unfold finiteFluctuationKernelPartial
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn,
      smooth_zeroDensity_kernel_ibp hy x T X hT hTX]

-- =====================================================================
-- §CXCIV. Endpoint correction — shift boundary from k(Z_m) to k(X)
-- =====================================================================
-- The raw discrete IBP boundary is `N · k(Z_m)`. Analytic estimates want
-- the boundary at the cutoff `k(X)`. The difference is the endpoint
-- correction `N · (k(X) - k(Z_m))`. Subtracting it gives the
-- analytically clean IBP identity.

/-- **Generic discrete Abel endpoint correction**: the boundary delta
between `f(X)` and `f(D.Z m)` scaled by the discrete count primitive. -/
noncomputable def discreteAbelEndpointCorrection
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) (m : ℕ) : ℝ :=
  discreteCountingPrimitive D T X * (f X - f (D.Z m))

/-- ⭐ **PROVED — Endpoint-corrected discrete IBP (paired Cauchy
kernel).** Rearranges `ordered_discrete_kernel_ibp_raw` so the boundary
uses `pairedCauchyImKernel x y X` instead of `pairedCauchyImKernel x y (D.Z m)`,
introducing the endpoint correction term explicitly. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteAbelEndpointCorrection D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X m := by
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn]
  unfold discreteAbelEndpointCorrection
  ring

/-- **Paired-Cauchy specialization** of the discrete Abel endpoint
correction. -/
noncomputable def discreteKernelEndpointCorrection
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ) : ℝ :=
  discreteAbelEndpointCorrection D.toFluctuationMeasureData
    (fun u => pairedCauchyImKernel x y u) T X m

/-- ⭐ **PROVED — Endpoint-corrected discrete IBP**, paired-kernel form
using the specialized `discreteKernelEndpointCorrection`. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected_paired
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteKernelEndpointCorrection D x y T X m := by
  unfold discreteKernelEndpointCorrection
  exact ordered_discrete_kernel_ibp_endpoint_corrected D x y T X hn

/-- **Combined endpoint correction** for the finite fluctuation IBP.
Same data as the discrete endpoint correction (the smooth side has its
boundary at `k(X) · S_smooth(X)` already, so no smooth correction). -/
noncomputable def finiteFluctuationEndpointCorrection
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) (m : ℕ) : ℝ :=
  discreteKernelEndpointCorrection D x y T X m

/-- 🌟🌟🌟 **PROVED — Endpoint-corrected finite fluctuation IBP.**
The analytically clean shape:

  `finiteFluctuationKernelPartial D x y T X
     = finiteFluctuationPrimitive D T X · k(X)
       − finiteFluctuationRawRemainder D x y T X m
       − finiteFluctuationEndpointCorrection D x y T X m`.

Both boundaries now align at `k(X)`. Uses `smoothCountingPrimitive_self`
to discharge `S_smooth(T) = 0` (so the `k(T) · S_smooth(T)` term in the
raw IBP vanishes). -/
theorem finiteFluctuationKernelPartial_endpoint_corrected_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T ≤ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    finiteFluctuationPrimitive D T X
      * pairedCauchyImKernel x y X
      -
    finiteFluctuationRawRemainder D x y T X m
      -
    finiteFluctuationEndpointCorrection D x y T X m := by
  rw [finiteFluctuationKernelPartial_raw_ibp D x y T X hn hT hTX hy]
  unfold finiteFluctuationPrimitive finiteFluctuationRawRemainder
        finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection
        discreteAbelEndpointCorrection
  rw [smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- §CXCIV-bounds: Endpoint correction zero case + absolute bounds
-- =====================================================================
-- Makes the endpoint correction harmless: it vanishes when X is chosen
-- AT an atom (X = D.Z m), and is bounded by `count · |k(X)-k(D.Z m)|`
-- otherwise. Then a Lipschitz-style wrapper lets future kernel-derivative
-- bounds slot in. Finally `..._abs_le_of_parts` combines raw remainder +
-- endpoint correction bounds via the triangle inequality.

/-- ⭐ **PROVED — Generic endpoint correction vanishes** when `X = D.Z m`. -/
theorem discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) (m : ℕ)
    (hX : X = D.Z m) :
    discreteAbelEndpointCorrection D f T X m = 0 := by
  unfold discreteAbelEndpointCorrection
  rw [hX]
  ring

/-- ⭐ **PROVED — Paired-Cauchy endpoint correction vanishes** at `X = D.Z m`. -/
theorem discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ)
    (hX : X = D.Z m) :
    discreteKernelEndpointCorrection D x y T X m = 0 := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m hX

/-- ⭐ **PROVED — Combined endpoint correction vanishes** at `X = D.Z m`. -/
theorem finiteFluctuationEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ)
    (hX : X = D.Z m) :
    finiteFluctuationEndpointCorrection D x y T X m = 0 := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z D x y T X m hX

/-- ⭐ **PROVED — Generic endpoint correction absolute bound.** -/
theorem discreteAbelEndpointCorrection_abs_le
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) (m : ℕ) :
    |discreteAbelEndpointCorrection D f T X m|
      ≤ |discreteCountingPrimitive D T X|
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul]

/-- ⭐ **PROVED — Cleaner bound** when the count primitive is nonneg. -/
theorem discreteAbelEndpointCorrection_abs_le_count
    (D : FluctuationMeasureData) (f : ℝ → ℝ) (T X : ℝ) (m : ℕ)
    (hN : 0 ≤ discreteCountingPrimitive D T X) :
    |discreteAbelEndpointCorrection D f T X m|
      ≤ discreteCountingPrimitive D T X
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul, abs_of_nonneg hN]

/-- ⭐ **PROVED — Paired-Cauchy endpoint absolute bound.** -/
theorem discreteKernelEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ) :
    |discreteKernelEndpointCorrection D x y T X m|
      ≤ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_abs_le
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m

/-- ⭐ **PROVED — Combined finite-fluctuation endpoint absolute bound.** -/
theorem finiteFluctuationEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ) :
    |finiteFluctuationEndpointCorrection D x y T X m|
      ≤ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_abs_le D x y T X m

/-- ⭐ **PROVED — Lipschitz-hypothesis wrapper.**
Given an externally-supplied kernel-difference bound `K · |X − D.Z m|`,
yields `count · K · |X − D.Z m|`. Future kernel-derivative work can plug
the Lipschitz `K` here without re-proving the structural bound. -/
theorem discreteKernelEndpointCorrection_abs_le_deriv_bound
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ) (K : ℝ)
    (hN : 0 ≤ discreteCountingPrimitive D.toFluctuationMeasureData T X)
    (hLip :
      |pairedCauchyImKernel x y X
        - pairedCauchyImKernel x y (D.Z m)|
        ≤ K * |X - D.Z m|) :
    |discreteKernelEndpointCorrection D x y T X m|
      ≤ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by
  have h0 :
      |discreteKernelEndpointCorrection D x y T X m|
        ≤ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
            * |pairedCauchyImKernel x y X
                - pairedCauchyImKernel x y (D.Z m)| :=
    discreteKernelEndpointCorrection_abs_le D x y T X m
  rw [abs_of_nonneg hN] at h0
  have h_step :
      discreteCountingPrimitive D.toFluctuationMeasureData T X
        * |pairedCauchyImKernel x y X
            - pairedCauchyImKernel x y (D.Z m)|
        ≤ discreteCountingPrimitive D.toFluctuationMeasureData T X
            * (K * |X - D.Z m|) :=
    mul_le_mul_of_nonneg_left hLip hN
  calc |discreteKernelEndpointCorrection D x y T X m|
      ≤ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := h0
    _ ≤ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * (K * |X - D.Z m|) := h_step
    _ = discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by ring

/-- **Per-piece IBP-correction bound predicate.**
The IBP body has two analytic terms to bound: the raw remainder and the
endpoint correction. This predicate names both budgets simultaneously. -/
def finiteFluctuationRemainderControlled
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ)
    (Braw Bend : ℝ) : Prop :=
  |finiteFluctuationRawRemainder D x y T X m| ≤ Braw ∧
  |finiteFluctuationEndpointCorrection D x y T X m| ≤ Bend

/-- ⭐ **PROVED — Triangle inequality combines raw + endpoint bounds.**
The full IBP correction (raw remainder + endpoint correction) is bounded
by the sum of the individual bounds. The abstract building block that
turns piece-wise IBP estimates into a single error budget. -/
theorem finiteFluctuationCorrection_abs_le_of_parts
    {D : OrderedFluctuationMeasureData} {x y T X : ℝ} {m : ℕ}
    {Braw Bend : ℝ}
    (hraw : |finiteFluctuationRawRemainder D x y T X m| ≤ Braw)
    (hend : |finiteFluctuationEndpointCorrection D x y T X m| ≤ Bend) :
    |finiteFluctuationRawRemainder D x y T X m
      + finiteFluctuationEndpointCorrection D x y T X m|
      ≤ Braw + Bend := by
  calc |finiteFluctuationRawRemainder D x y T X m
        + finiteFluctuationEndpointCorrection D x y T X m|
      ≤ |finiteFluctuationRawRemainder D x y T X m|
        + |finiteFluctuationEndpointCorrection D x y T X m| := abs_add _ _
    _ ≤ Braw + Bend := add_le_add hraw hend

-- =====================================================================
-- §CXCV. FTC bridge — Abel sums → interval integrals of N · k'
-- =====================================================================
-- Goal:
--   `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
--      = ∫_T^X N(u) · k'(u) du`
-- under clean window assumptions (`OrderedWindow`): all indexed
-- ordinates lie in `[T, X]` and are strictly increasing.
--
-- Strategy (Option A — Window):
--   1. Express the clipped weights as raw `mult` (clipping is trivial
--      since every `Z_j ∈ [T, X]`).
--   2. Rewrite the cumulative weights as the unclipped partial sums.
--   3. Decompose `N(u)` as `∑_i mult_i · [Z_i ≤ u]` on `[T, X]`.
--   4. By linearity + a per-`i` FTC identity
--        `∫_T^X [Z_i ≤ u] · k'(u) du = k(X) − k(Z_i)`
--      the integral equals `∑_i mult_i · (k(X) − k(Z_i))`.
--   5. This matches `R + EC` via the endpoint-corrected discrete IBP.
--
-- Steps 1–3 and 5 are pure algebra and land here. Step 4 — the
-- indicator-against-`k'` FTC integral — is the genuine analytic
-- content; it lives as a Prop hypothesis on the headline theorem,
-- matching the file's "capstone consumes Prop hypotheses" pattern.

/-- **Ordered-window data**: every indexed ordinate lies inside
`[T, X]` and the ordinates are strictly increasing. The clean
hypothesis package that lets the Abel/FTC bridge land without
juggling boundary atoms or duplicate ordinates. -/
structure OrderedWindow
    (D : OrderedFluctuationMeasureData) (T X : ℝ) (m : ℕ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T ≤ D.Z 0
  hlast_le_X  : D.Z m ≤ X
  hstrict     : ∀ j, j < m → D.Z j < D.Z (j + 1)

/-- ⭐ **PROVED — under `OrderedWindow`, every indexed ordinate
`Z_j` lies in `[T, X]`.** Monotonicity from `D.mono_Z` together with
`T ≤ Z_0` and `Z_m ≤ X` does the job. -/
lemma OrderedWindow.Z_mem_window
    {D : OrderedFluctuationMeasureData} {T X : ℝ} {m j : ℕ}
    (W : OrderedWindow D T X m) (hj : j ≤ m) :
    T ≤ D.Z j ∧ D.Z j ≤ X := by
  refine ⟨?_, ?_⟩
  · exact le_trans W.hT_le_first (D.mono_Z (Nat.zero_le j))
  · exact le_trans (D.mono_Z hj) W.hlast_le_X

/-- ⭐ **PROVED — under `OrderedWindow`, the clipped weight equals the
raw multiplicity for every `j ≤ m`.** -/
lemma clippedWeight_eq_mult_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : ℝ} {m j : ℕ}
    (W : OrderedWindow D T X m) (hj : j ≤ m) :
    clippedWeight D.toFluctuationMeasureData T X j = (D.mult j : ℝ) := by
  unfold clippedWeight
  rw [if_pos (W.Z_mem_window hj)]

/-- ⭐ **PROVED — under `OrderedWindow`, the clipped cumulative weight
through index `j ≤ m` equals the unclipped partial sum
`∑_{i ≤ j} mult_i`.** -/
lemma clippedCumulativeWeight_eq_partialSum_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : ℝ} {m j : ℕ}
    (W : OrderedWindow D T X m) (hj : j ≤ m) :
    clippedCumulativeWeight D T X j
      = ∑ i ∈ Finset.range (j + 1), (D.mult i : ℝ) := by
  unfold clippedCumulativeWeight
  apply Finset.sum_congr rfl
  intro i hi
  have hi_le_m : i ≤ m := by
    have hi_lt : i < j + 1 := Finset.mem_range.mp hi
    omega
  exact clippedWeight_eq_mult_of_orderedWindow W hi_le_m

/-- ⭐ **PROVED — under `OrderedWindow`, the full clipped sum
(= `discreteCountingPrimitive D T X` = `N(X)`) equals the total
multiplicity.** -/
lemma discreteCountingPrimitive_full_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : ℝ} {m : ℕ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      = ∑ i ∈ Finset.range D.n, (D.mult i : ℝ) := by
  rw [discreteCountingPrimitive_eq_clippedSum, W.hn]
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < m + 1 := Finset.mem_range.mp hi
  exact clippedWeight_eq_mult_of_orderedWindow W (by omega)

/-- **Per-`i` FTC integrand identity (analytic hypothesis).** For each
ordinate `Z_i` in the window, the indicator-against-kernel-derivative
integral equals the kernel boundary difference:

  `∫_T^X [Z_i ≤ u] · k'(u) du = k(X) − k(Z_i)`.

This is the genuine analytic content of the §CXCV bridge — it
encapsulates an interval split at `Z_i` plus FTC on `[Z_i, X]` for
`pairedCauchyImKernel` (the indicator vanishes on `[T, Z_i)`).
Packaged as a Prop so the bridge theorem itself stays algebraic. -/
def IndicatorKernelFTCHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (m : ℕ) : Prop :=
  ∀ i ∈ Finset.range D.n, i ≤ m →
    (∫ u in T..X,
        (if D.Z i ≤ u then (1 : ℝ) else 0) * pairedCauchyImKernelDeriv x y u)
      = pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)

/-- **Linearity hypothesis**: pulling the finite sum over `i ∈ range n`
out of the kernel-derivative integral. Mathlib's
`intervalIntegral.integral_finset_sum` discharges this given pointwise
integrability of each summand; packaged as a Prop to keep the algebraic
core focused. -/
def IntegralSumLinearityHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) : Prop :=
  (∫ u in T..X,
      (∑ i ∈ Finset.range D.n,
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0))
        * pairedCauchyImKernelDeriv x y u)
    =
  ∑ i ∈ Finset.range D.n,
    (D.mult i : ℝ) *
      ∫ u in T..X,
        (if D.Z i ≤ u then (1 : ℝ) else 0) * pairedCauchyImKernelDeriv x y u

/-- **N(u) decomposition hypothesis**: under `OrderedWindow`, the
clipped counting primitive at any inner `u ∈ [T, X]` agrees with the
unclipped indicator sum `∑_i mult_i · [Z_i ≤ u]`. Packaged as an
integrand-level equality so the integral can be congruenced. -/
def NDecompositionIntegrandHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) : Prop :=
  (∫ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
    =
  ∫ u in T..X,
    (∑ i ∈ Finset.range D.n,
      (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0))
      * pairedCauchyImKernelDeriv x y u

/-- ⭐ **PROVED — algebraic Abel-sum closed form** for `R + EC` under
`OrderedWindow`:

  `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
     = ∑_{i ≤ m} mult_i · (k(X) − k(Z_i))`.

Derivation: invoke the endpoint-corrected discrete IBP to convert the
LHS to `N(X) · k(X) − discreteKernelPartial`; expand both via
`OrderedWindow` and rearrange. -/
theorem discrete_remainder_plus_correction_eq_explicit_sum
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    ∑ i ∈ Finset.range D.n,
      (D.mult i : ℝ) *
        (pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)) := by
  -- Endpoint-corrected discrete IBP: partial = N·k(X) − R − EC.
  have h_ibp :=
    ordered_discrete_kernel_ibp_endpoint_corrected D x y T X W.hn
  -- Solve for R + EC: R + EC = N·k(X) − partial.
  have h_RE :
      discreteKernelAbelRemainder D x y T X m
        + discreteAbelEndpointCorrection D.toFluctuationMeasureData
            (fun u => pairedCauchyImKernel x y u) T X m
        = discreteCountingPrimitive D.toFluctuationMeasureData T X
            * pairedCauchyImKernel x y X
          - discreteKernelPartial D.toFluctuationMeasureData
              (fun u => pairedCauchyImKernel x y u) T X := by
    linarith [h_ibp]
  rw [h_RE]
  -- Now expand `partial` under OrderedWindow: clipping vanishes.
  have h_partial :
      discreteKernelPartial D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X
        = ∑ i ∈ Finset.range D.n,
            (D.mult i : ℝ) * pairedCauchyImKernel x y (D.Z i) := by
    unfold discreteKernelPartial
    rw [W.hn]
    apply Finset.sum_congr rfl
    intro i hi
    have hi_lt : i < m + 1 := Finset.mem_range.mp hi
    have hi_le_m : i ≤ m := by omega
    rw [if_pos (W.Z_mem_window hi_le_m)]
  rw [h_partial, discreteCountingPrimitive_full_of_orderedWindow W]
  -- N(X) · k(X) − ∑ mult_i · k(Z_i) = ∑ mult_i · (k(X) − k(Z_i))
  rw [Finset.sum_mul, ← Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro i _
  ring

/-- 🌟🌟🌟 **PROVED — FTC BRIDGE: discrete Abel + endpoint correction
= integral of `N · k'`** (under OrderedWindow + analytic hypotheses).

Identifies the discrete Abel remainder plus the endpoint correction
with the interval integral

  `∫_T^X N(u) · k'(u) du`,

routing the genuine analytic content through three Prop hypotheses:
the N-decomposition integrand rewrite, the integral-linearity swap,
and the per-`i` indicator-FTC identity. With all three discharged
(future work via Mathlib's `intervalIntegral.integral_finset_sum`,
`integral_congr`, and `integral_eq_sub_of_hasDerivAt`), this is the
first finite-window FTC bridge from Abel sums to step-function
integrals. -/
theorem discrete_corrected_remainder_eq_intervalIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m)
    (h_decomp : NDecompositionIntegrandHypothesis D x y T X)
    (h_linear : IntegralSumLinearityHypothesis D x y T X)
    (h_ftc : IndicatorKernelFTCHypothesis D x y T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    ∫ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
  -- Algebraic side: R + EC = ∑ mult_i · (k(X) − k(Z_i)).
  rw [discrete_remainder_plus_correction_eq_explicit_sum D x y T X W]
  -- Analytic side: rewrite the integral through the three hypotheses.
  rw [h_decomp, h_linear]
  -- Now the integral side is ∑ mult_i · (∫ indicator · k').
  -- Discharge each per-`i` via the FTC hypothesis.
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i ≤ m := by rw [W.hn] at hi_lt; omega
  rw [h_ftc i hi hi_le_m]

-- =====================================================================
-- §CXCVI-A. Discharge `NDecompositionIntegrandHypothesis`
-- =====================================================================
-- Under `OrderedWindow`, the clipping condition `T ≤ Z_i ∧ Z_i ≤ u`
-- collapses to `Z_i ≤ u` (the `T ≤ Z_i` part is automatic). The
-- counting primitive then equals `∑_i mult_i · [Z_i ≤ u]` pointwise
-- (for every `u`, not just `u ∈ [T, X]`), so the integrand rewrite
-- discharges via `intervalIntegral.integral_congr`.

/-- ⭐ **PROVED — pointwise decomposition of `N(u)`** under `OrderedWindow`:
  `discreteCountingPrimitive D T u
     = ∑_i mult_i · [Z_i ≤ u]`.
Holds for every `u : ℝ` because the `T ≤ Z_i` half of the clipping
condition is automatic from `OrderedWindow`. -/
lemma discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (T X u : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T u
      =
    ∑ i ∈ Finset.range D.n,
      (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0) := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i ≤ m := by rw [W.hn] at hi_lt; omega
  have hT_Zi : T ≤ D.Z i := (W.Z_mem_window hi_le_m).1
  by_cases hZi_u : D.Z i ≤ u
  · have hclip : T ≤ D.Z i ∧ D.Z i ≤ u := ⟨hT_Zi, hZi_u⟩
    rw [if_pos hclip, if_pos hZi_u, mul_one]
  · have hclip : ¬ (T ≤ D.Z i ∧ D.Z i ≤ u) := fun h => hZi_u h.2
    rw [if_neg hclip, if_neg hZi_u, mul_zero]

/-- 🌟 **PROVED — `NDecompositionIntegrandHypothesis` discharged**
under `OrderedWindow`. The pointwise lemma plus
`intervalIntegral.integral_congr` does the work. -/
theorem nDecompositionIntegrand_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) :
    NDecompositionIntegrandHypothesis D x y T X := by
  unfold NDecompositionIntegrandHypothesis
  refine intervalIntegral.integral_congr ?_
  intro u _
  show discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      = (∑ i ∈ Finset.range D.n, (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0))
          * pairedCauchyImKernelDeriv x y u
  rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W]

-- =====================================================================
-- §CXCVI-B-prep. FTC for the paired-Cauchy imaginary kernel derivative
-- =====================================================================
-- Pure FTC: `∫_a^b k'(u) du = k(b) − k(a)`. Independent of indicators.
-- Becomes the engine for `IndicatorKernelFTCHypothesis` once the
-- indicator split lemma lands (next patch).

/-- 🌟 **PROVED — FTC for `pairedCauchyImKernel`**:
  `∫_a^b k'(u) du = k(b) − k(a)`.
Direct application of `intervalIntegral.integral_eq_sub_of_hasDerivAt`
with the per-point derivative `pairedCauchyImKernel_hasDerivAt` and
the continuity-based integrability `pairedCauchyImKernelDeriv_intervalIntegrable`. -/
theorem pairedCauchyImKernelDeriv_integral_eq_sub
    {y : ℝ} (hy : 0 < y) (x a b : ℝ) :
    (∫ u in a..b, pairedCauchyImKernelDeriv x y u)
      =
    pairedCauchyImKernel x y b - pairedCauchyImKernel x y a := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  · intro u _
    exact pairedCauchyImKernel_hasDerivAt hy x u
  · exact pairedCauchyImKernelDeriv_intervalIntegrable hy x a b

-- =====================================================================
-- §CXCVI-B. Indicator splitting + `IndicatorKernelFTCHypothesis`
-- =====================================================================
-- Key analytic step: for `T ≤ a ≤ X`,
--   `∫_T^X [a ≤ u] · k'(u) du = ∫_a^X k'(u) du`.
-- Mathlib has `intervalIntegral.integral_indicator` for `Set.Ioi`; we
-- recast `[a ≤ u]` (i.e. `Set.Ici a`) to `Set.Ioi a` via an a.e.
-- equality (they differ only at the single point `{a}`, measure 0)
-- and then invoke Mathlib's lemma directly.

-- Strategy that AVOIDS `intervalIntegral.integral_indicator` entirely.
-- That theorem's general type drives the `whnf` budget to zero on the
-- explicit `pairedCauchyImKernelDeriv` rational body. The route below
-- closes the cutoff identity via:
--   1. closed cutoff `[a ≤ u]` = strict cutoff `[a < u]` (one AE step)
--   2. split `∫_T^X = ∫_T^a + ∫_a^X` (adjacent intervals)
--   3. left piece: pointwise zero  (no AE needed under strict cutoff)
--   4. right piece: AE-equal to `g`
--   5. assemble via calc.

/-- ⭐ **PROVED — a.e. on `volume`, every point differs from a fixed `a`.**
Volume-singleton triviality, packaged for use with `filter_upwards`. -/
lemma ae_ne_real (a : ℝ) :
    ∀ᵐ u : ℝ ∂MeasureTheory.volume, u ≠ a := by
  refine MeasureTheory.ae_iff.mpr ?_
  have h_eq : {u : ℝ | ¬ u ≠ a} = {a} := by
    ext u
    simp [Set.mem_setOf_eq, Set.mem_singleton_iff, not_not]
  rw [h_eq]
  exact Real.volume_singleton

/-- ⭐ **PROVED — closed cutoff equals strict cutoff in the
interval integral.** Single AE step using `ae_ne_real`. -/
lemma integral_if_le_eq_integral_if_lt
    (g : ℝ → ℝ) (a T X : ℝ) :
    (∫ u in T..X, (if a ≤ u then (1 : ℝ) else 0) * g u)
      =
    ∫ u in T..X, (if a < u then (1 : ℝ) else 0) * g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne _
  by_cases hle : a ≤ u
  · have hlt : a < u := lt_of_le_of_ne hle (Ne.symm hu_ne)
    rw [if_pos hle, if_pos hlt]
  · have hnlt : ¬ a < u := fun h => hle (le_of_lt h)
    rw [if_neg hle, if_neg hnlt]

/-- ⭐ **PROVED — strict cutoff left piece is zero** on `[T, a]`.
Pointwise: every `u ∈ [T, a]` has `a < u` false (since `u ≤ a`). -/
lemma integral_if_lt_left_zero
    (g : ℝ → ℝ) (T a : ℝ) (hTa : T ≤ a) :
    (∫ u in T..a, (if a < u then (1 : ℝ) else 0) * g u) = 0 := by
  have h_eq : ∀ u ∈ Set.uIcc T a,
      (if a < u then (1 : ℝ) else 0) * g u = 0 := by
    intro u hu
    rw [Set.uIcc_of_le hTa] at hu
    have hua : u ≤ a := hu.2
    have hnlt : ¬ a < u := not_lt.mpr hua
    rw [if_neg hnlt, zero_mul]
  calc (∫ u in T..a, (if a < u then (1 : ℝ) else 0) * g u)
      = ∫ _ in T..a, (0 : ℝ) := intervalIntegral.integral_congr h_eq
    _ = 0 := intervalIntegral.integral_zero

/-- ⭐ **PROVED — strict cutoff right piece equals `g`** on `[a, X]`.
Single AE step (since `a < u` fails only at `u = a`). -/
lemma integral_if_lt_right_eq
    (g : ℝ → ℝ) (a X : ℝ) (haX : a ≤ X) :
    (∫ u in a..X, (if a < u then (1 : ℝ) else 0) * g u)
      =
    ∫ u in a..X, g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne hu_mem
  rw [Set.uIoc_of_le haX] at hu_mem
  have hau_lt : a < u := hu_mem.1
  rw [if_pos hau_lt, one_mul]

/-- ⭐ **PROVED — strict cutoff × `g`** is interval-integrable on the
left sub-interval `[T, a]`. Integrand is pointwise zero on `(T, a]`
(since `u ≤ a → ¬(a < u)`); congruence with the constant-zero
integrable function discharges. -/
lemma intervalIntegrable_if_lt_mul_left
    (g : ℝ → ℝ) (a T : ℝ) (hTa : T ≤ a) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : ℝ) else 0) * g u)
      MeasureTheory.volume T a := by
  refine (intervalIntegrable_const (c := (0 : ℝ))).congr ?_
  rw [Set.uIoc_of_le hTa]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hua : u ≤ a := hu.2
  have hnlt : ¬ a < u := not_lt.mpr hua
  show (0 : ℝ) = (if a < u then (1 : ℝ) else 0) * g u
  rw [if_neg hnlt, zero_mul]

/-- ⭐ **PROVED — strict cutoff × `g`** is interval-integrable on the
right sub-interval `[a, X]` when `g` is. Integrand equals `g` for
`a < u`; congruence with `g` discharges. -/
lemma intervalIntegrable_if_lt_mul_right
    (g : ℝ → ℝ) (a X : ℝ) (haX : a ≤ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume a X) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : ℝ) else 0) * g u)
      MeasureTheory.volume a X := by
  refine hg_int.congr ?_
  rw [Set.uIoc_of_le haX]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hau : a < u := hu.1
  show g u = (if a < u then (1 : ℝ) else 0) * g u
  rw [if_pos hau, one_mul]

/-- ⭐ **PROVED — strict cutoff splits cleanly at `a`**:
  `∫_T^X [a < u] · g(u) du = ∫_a^X g(u) du`.
Uses adjacent-interval splitting, left zero, right `g`. No
`integral_indicator` invocation. -/
lemma integral_if_lt_eq_integral_from_cut
    (g : ℝ → ℝ) (T a X : ℝ)
    (hTa : T ≤ a) (haX : a ≤ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (∫ u in T..X, (if a < u then (1 : ℝ) else 0) * g u)
      =
    ∫ u in a..X, g u := by
  -- split `g`'s integrability to the right sub-interval
  have hTX : T ≤ X := le_trans hTa haX
  have h_sub_right : Set.uIcc a X ⊆ Set.uIcc T X := by
    rw [Set.uIcc_of_le haX, Set.uIcc_of_le hTX]
    exact Set.Icc_subset_Icc_left hTa
  have hg_right : IntervalIntegrable g MeasureTheory.volume a X :=
    hg_int.mono_set h_sub_right
  -- indicator-product integrability on each sub-interval
  have h_int_left := intervalIntegrable_if_lt_mul_left g a T hTa
  have h_int_right := intervalIntegrable_if_lt_mul_right g a X haX hg_right
  calc
    (∫ u in T..X, (if a < u then (1 : ℝ) else 0) * g u)
        =
      (∫ u in T..a, (if a < u then (1 : ℝ) else 0) * g u)
        + ∫ u in a..X, (if a < u then (1 : ℝ) else 0) * g u :=
        (intervalIntegral.integral_add_adjacent_intervals
          h_int_left h_int_right).symm
    _ = 0 + ∫ u in a..X, g u := by
          rw [integral_if_lt_left_zero g T a hTa,
              integral_if_lt_right_eq g a X haX]
    _ = ∫ u in a..X, g u := zero_add _

/-- 🌟 **PROVED — generic indicator cutoff identity**:
  `∫_T^X [a ≤ u] · g(u) du = ∫_a^X g(u) du`   for `T ≤ a ≤ X`.

Routes through strict cutoff to bypass `intervalIntegral.integral_indicator`. -/
theorem indicator_Ici_integral_eq_integral_from_cut
    (g : ℝ → ℝ) (T a X : ℝ)
    (hTa : T ≤ a) (haX : a ≤ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (∫ u in T..X, (if a ≤ u then (1 : ℝ) else 0) * g u)
      =
    ∫ u in a..X, g u := by
  rw [integral_if_le_eq_integral_if_lt g a T X,
      integral_if_lt_eq_integral_from_cut g T a X hTa haX hg_int]

/-- ⭐ **PROVED — kernel-specific indicator cutoff identity**, by
direct specialization of `indicator_Ici_integral_eq_integral_from_cut`.
The kernel-derivative is interval-integrable from continuity for any
`y > 0` (via `pairedCauchyImKernelDeriv_intervalIntegrable`). -/
theorem pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
    (x y T a X : ℝ) (hTa : T ≤ a) (haX : a ≤ X) (hy : 0 < y) :
    (∫ u in T..X,
        (if a ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      =
    ∫ u in a..X, pairedCauchyImKernelDeriv x y u :=
  indicator_Ici_integral_eq_integral_from_cut
    (pairedCauchyImKernelDeriv x y) T a X hTa haX
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X)

/-- 🌟🌟 **PROVED — `IndicatorKernelFTCHypothesis` discharged**
under `OrderedWindow`. Combines the indicator cutoff lemma with the
pure FTC for the kernel derivative. -/
theorem indicatorKernelFTC_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IndicatorKernelFTCHypothesis D x y T X m := by
  intro i hi hi_le_m
  have hZi := W.Z_mem_window hi_le_m
  rw [pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
        x y T (D.Z i) X hZi.1 hZi.2 hy]
  exact pairedCauchyImKernelDeriv_integral_eq_sub hy x (D.Z i) X

-- =====================================================================
-- §CXCVI-C. Discharge `IntegralSumLinearityHypothesis`
-- =====================================================================
-- The indicator × kernel-derivative term is interval-integrable
-- (it equals `Set.indicator (Set.Ici Z_i) (mult_i · k')`, where the
-- argument is continuous, hence integrable). Then
-- `intervalIntegral.integral_finset_sum` discharges the sum-linearity.

/-- ⭐ **PROVED — interval integrability of each indicator × kernel
derivative term.** -/
lemma indicator_kernel_deriv_term_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) (i : ℕ)
    (hy : 0 < y) :
    IntervalIntegrable
      (fun u : ℝ =>
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- The term equals `Set.indicator (Set.Ici (D.Z i)) (mult_i · k')`.
  have h_eq :
      (fun u : ℝ =>
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = Set.indicator (Set.Ici (D.Z i))
          (fun u : ℝ => (D.mult i : ℝ) * pairedCauchyImKernelDeriv x y u) := by
    funext u
    by_cases h : D.Z i ≤ u
    · have hmem : u ∈ Set.Ici (D.Z i) := h
      rw [if_pos h, mul_one, Set.indicator_of_mem hmem]
    · have hnmem : u ∉ Set.Ici (D.Z i) := h
      rw [if_neg h, mul_zero, zero_mul, Set.indicator_of_notMem hnmem]
  rw [h_eq]
  -- `IntervalIntegrable.indicator` isn't in Mathlib; build manually
  -- from the two `IntegrableOn` components.
  have h_const_mul : IntervalIntegrable
      (fun u : ℝ => (D.mult i : ℝ) * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X).const_mul (D.mult i : ℝ)
  exact ⟨h_const_mul.1.indicator measurableSet_Ici,
         h_const_mul.2.indicator measurableSet_Ici⟩

/-- 🌟 **PROVED — `IntegralSumLinearityHypothesis` discharged** under
`OrderedWindow` (well, just needs `hy : 0 < y` for the term
integrability). Three-step proof: pointwise distribute `(∑) · k'` to
`∑ ((·) · k')`; apply `intervalIntegral.integral_finset_sum`; pull
each `mult_i` constant out of the per-`i` integral. -/
theorem integralSumLinearity_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ)
    (hy : 0 < y) :
    IntegralSumLinearityHypothesis D x y T X := by
  unfold IntegralSumLinearityHypothesis
  -- Step 1: pointwise distribute the sum over k'(u).
  have h_distrib : ∀ u : ℝ,
      (∑ i ∈ Finset.range D.n,
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0))
        * pairedCauchyImKernelDeriv x y u
      =
      ∑ i ∈ Finset.range D.n,
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
    intro u
    rw [Finset.sum_mul]
  -- Step 2: rewrite the LHS integral using the pointwise distribution.
  have h_rewrite :
      (∫ u in T..X,
        (∑ i ∈ Finset.range D.n,
          (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0))
          * pairedCauchyImKernelDeriv x y u)
      =
      ∫ u in T..X,
        ∑ i ∈ Finset.range D.n,
          (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
            * pairedCauchyImKernelDeriv x y u := by
    refine intervalIntegral.integral_congr ?_
    intro u _
    exact h_distrib u
  rw [h_rewrite]
  -- Step 3: pull the finite sum out of the integral.
  have h_int : ∀ i ∈ Finset.range D.n,
      IntervalIntegrable
        (fun u : ℝ =>
          (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    fun i _ => indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  rw [intervalIntegral.integral_finset_sum h_int]
  -- Step 4: per-i, pull constant `mult_i` out of `∫`.
  apply Finset.sum_congr rfl
  intro i _
  have h_term :
      (fun u : ℝ =>
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = (fun u : ℝ =>
          (D.mult i : ℝ) *
            ((if D.Z i ≤ u then (1 : ℝ) else 0) * pairedCauchyImKernelDeriv x y u)) := by
    funext u; ring
  rw [h_term, intervalIntegral.integral_const_mul]

-- =====================================================================
-- §CXCVII. Unconditional FTC bridge + finite-window true IBP
-- =====================================================================
-- All three Prop hypotheses are now discharged. The FTC bridge and the
-- full finite-window IBP normal form become unconditional theorems.

/-- 🌟🌟🌟🌟 **PROVED — UNCONDITIONAL FTC BRIDGE** under `OrderedWindow`.
Combines the three discharged hypotheses with the algebraic bridge
`discrete_corrected_remainder_eq_intervalIntegral`. -/
theorem discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    ∫ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u :=
  discrete_corrected_remainder_eq_intervalIntegral D x y T X W
    (nDecompositionIntegrand_of_orderedWindow D x y T X W)
    (integralSumLinearity_of_orderedWindow D x y T X hy)
    (indicatorKernelFTC_of_orderedWindow D x y T X W hy)

-- =====================================================================
-- §CXCVIII. True finite-window fluctuation IBP (no analytic hypotheses)
-- =====================================================================
-- Combines the unconditional FTC bridge `discrete_corrected_remainder_eq_
-- intervalIntegral_of_orderedWindow` with the endpoint-corrected
-- finite-fluctuation IBP into the clean finite-window Stieltjes IBP:
--
--   `finiteFluctuationKernelPartial = k(X) · S(T,X) − ∫_T^X S(T,u) · k'(u) du`
--
-- where `S(T, ·) = finiteFluctuationPrimitive D T`. No Prop hypotheses.

/-- **Per-`i` indicator-kernel-derivative term**, top-level definition
to keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteKernelDerivIndicatorTerm
    (D : OrderedFluctuationMeasureData) (x y : ℝ) (i : ℕ) : ℝ → ℝ :=
  fun u =>
    (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- ⭐ **PROVED — `N(u) · k'(u)` is interval-integrable** on `[T, X]`
under `OrderedWindow`. Uses the indicator decomposition: `N` equals
`∑_i mult_i · [Z_i ≤ u]` (pointwise everywhere), and each term in the
sum is interval-integrable. The integrability of the sum is stated
as a **sum of functions**, not a `fun u => ∑ ... u`, to avoid the
function-vs-sum unification timeout. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IntervalIntegrable
      (fun u => discreteCountingPrimitive D.toFluctuationMeasureData T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun_int :
      IntervalIntegrable
        (∑ i ∈ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (by
      intro i _
      unfold discreteKernelDerivIndicatorTerm
      exact indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy)
  refine h_sum_fun_int.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (∑ i, term i) u = ∑ i, term i u  (Finset.sum_apply)
  -- = (∑ i, mult_i * indicator_i) * k'(u)  (Finset.sum_mul reverse)
  -- = N(u) * k'(u)  (decomposition lemma)
  calc
    (∑ i ∈ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i) u
        =
      ∑ i ∈ Finset.range D.n,
        (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
          simp only [Finset.sum_apply, discreteKernelDerivIndicatorTerm]
    _ =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
          symm
          rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W,
              Finset.sum_mul]

/-- ⭐ **PROVED — `S_smooth(u) · k'(u)` is interval-integrable** on
`[T, X]` for `0 < T ≤ X` and `0 < y`. Both factors are continuous on
`[T, X]`: `S_smooth` via the existing `HasDerivAt` (differentiable ⇒
continuous), and `k'` via `pairedCauchyImKernelDeriv_continuous`. -/
lemma smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    {T X : ℝ} (hT : 0 < T) (hTX : T ≤ X) (x : ℝ) {y : ℝ} (hy : 0 < y) :
    IntervalIntegrable
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- S_smooth is continuous on [T, X] via HasDerivAt → differentiableAt → continuousAt
  have h_S_cont : ContinuousOn (fun u => smoothCountingPrimitive T u)
      (Set.Icc T X) := by
    intro u hu
    have h_diff : DifferentiableAt ℝ (fun v => smoothCountingPrimitive T v) u :=
      (smoothCountingPrimitive_hasDerivAt hT hu.1).differentiableAt
    exact h_diff.continuousAt.continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    (pairedCauchyImKernelDeriv_continuous hy x).continuousOn
  have h_prod_cont : ContinuousOn
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    h_S_cont.mul h_k_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- **True derivative-side integral** for the finite fluctuation IBP:
  `∫_T^X S(T,u) · k'(u) du`  where `S(T, ·) = finiteFluctuationPrimitive D T`. -/
noncomputable def finiteFluctuationDerivativeIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) : ℝ :=
  ∫ u in T..X,
    finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u

/-- ⭐ **PROVED — derivative-side integral splits as difference of two
integrals**:
  `finiteFluctuationDerivativeIntegral = (∫ N·k') − (∫ S_smooth·k')`.
Uses `intervalIntegral.integral_sub` with the two integrability
helpers above. -/
lemma finiteFluctuationDerivativeIntegral_expand
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m) (hT : 0 < T) (hTX : T ≤ X) (hy : 0 < y) :
    finiteFluctuationDerivativeIntegral D x y T X
      =
    (∫ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
      -
    ∫ u in T..X,
      smoothCountingPrimitive T u
        * pairedCauchyImKernelDeriv x y u := by
  unfold finiteFluctuationDerivativeIntegral finiteFluctuationPrimitive
  have h_pointwise : ∀ u : ℝ,
      (discreteCountingPrimitive D.toFluctuationMeasureData T u
        - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u
      =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
    intro u; ring
  rw [show (fun u : ℝ =>
        (discreteCountingPrimitive D.toFluctuationMeasureData T u
          - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u)
      = (fun u : ℝ =>
        discreteCountingPrimitive D.toFluctuationMeasureData T u
          * pairedCauchyImKernelDeriv x y u
        - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u)
      from funext h_pointwise]
  exact intervalIntegral.integral_sub
    (discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable D x y T X W hy)
    (smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable hT hTX x hy)

/-- 🌟🌟🌟🌟🌟 **PROVED — TRUE FINITE-WINDOW FLUCTUATION IBP**
(no analytic Prop hypotheses):

  `finiteFluctuationKernelPartial D x y T X
     = k(X) · S(T,X) − ∫_T^X S(T,u) · k'(u) du`

where `S(T, ·) = finiteFluctuationPrimitive D T`.

This is the first unconditional finite-window Stieltjes IBP for the
xi fluctuation against the imaginary paired-Cauchy kernel. Combines:
* the endpoint-corrected fluctuation IBP (§CXCIV);
* the unconditional FTC bridge (§CXCVII);
* the derivative-integral expansion (above).

All three were unconditional, so this is too. -/
theorem finiteFluctuationKernelPartial_true_ibp
    (D : OrderedFluctuationMeasureData) (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T ≤ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
      -
    finiteFluctuationDerivativeIntegral D x y T X := by
  -- Step 1: invoke the endpoint-corrected IBP
  rw [finiteFluctuationKernelPartial_endpoint_corrected_ibp
        D x y T X W.hn hT hTX hy]
  -- Step 2: unfold rawRemainder + endpointCorrection
  unfold finiteFluctuationRawRemainder finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection discreteAbelEndpointCorrection
  -- Step 3: bridge `R + EC = ∫N·k'`
  have h_bridge :=
    discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow D x y T X W hy
  -- Step 4: derivative-side expansion
  have h_expand :=
    finiteFluctuationDerivativeIntegral_expand D x y T X W hT hTX hy
  -- Step 5: name abbreviations to dodge integral atoms inside `ring`.
  set N := discreteCountingPrimitive D.toFluctuationMeasureData T X with hN
  set ffP := finiteFluctuationPrimitive D T X with hffP
  set kX := pairedCauchyImKernel x y X with hkX
  set ffDI := finiteFluctuationDerivativeIntegral D x y T X with hffDI
  set R := discreteKernelAbelRemainder D x y T X m with hR
  set SI := ∫ u in T..X,
              smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u
    with hSI
  set NI := ∫ u in T..X,
              discreteCountingPrimitive D.toFluctuationMeasureData T u
                * pairedCauchyImKernelDeriv x y u
    with hNI
  -- `set ... with ...` already replaced occurrences in `h_bridge` and
  -- `h_expand`. We still need to unfold `discreteAbelEndpointCorrection`
  -- in `h_bridge` so it exposes `N * (kX - k(D.Z m))`.
  unfold discreteAbelEndpointCorrection at h_bridge
  show ffP * kX - (R - SI) - N * (kX - pairedCauchyImKernel x y (D.Z m))
       = kX * ffP - ffDI
  linarith

/-- ⭐ **PROVED — `finiteFluctuationPrimitive D T T = 0` when no zero
ordinate sits exactly at `T`.** Combines
`discreteCountingPrimitive_left_zero_of_no_atom` with
`smoothCountingPrimitive_self`. -/
lemma finiteFluctuationPrimitive_left_zero_of_no_atom
    (D : OrderedFluctuationMeasureData) (T : ℝ)
    (hnoT : ∀ j ∈ Finset.range D.n, D.Z j ≠ T) :
    finiteFluctuationPrimitive D T T = 0 := by
  unfold finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_left_zero_of_no_atom D.toFluctuationMeasureData T hnoT,
      smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- §CXCIX. Finite-window IBP packaging + tail-window eventual data
-- =====================================================================
-- (A) `FiniteWindowKernelStieltjesIBP`: a one-endpoint package recording
-- the finite-window Stieltjes IBP identity at a specific `X`. Makes
-- `finiteFluctuationKernelPartial_true_ibp` reusable by downstream
-- improper-limit records without reopening the Abel machinery.
-- (B) `OrderedTailWindowData` + `orderedWindow_eventually_atTop`: data
-- that's stable as `X → ∞`, with the eventual-window lemma that says
-- `OrderedWindow D T X m` holds for all sufficiently large `X`. This is
-- the bridge for building improper IBP packages from finite-window ones.

/-- **One-endpoint finite-window Stieltjes IBP record.** Records the
finite IBP identity at a specific cutoff `X`:

  `partialAtX = k(X)·S(X) − k(T)·S(T) − ∫_T^X S(u)·k'(u) du`.

Different from the global `FiniteKernelStieltjesIBP` (§CLXXXVIII), which
quantifies the identity over **all** `X`. This record is the natural
finite-window output of `finiteFluctuationKernelPartial_true_ibp`. -/
structure FiniteWindowKernelStieltjesIBP where
  S : ℝ → ℝ
  partialAtX : ℝ
  x : ℝ
  y : ℝ
  T : ℝ
  X : ℝ
  finite_ibp_at_X :
    partialAtX =
      pairedCauchyImKernel x y X * S X
        - pairedCauchyImKernel x y T * S T
        - ∫ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- 🌟 **PROVED — package `finiteFluctuationKernelPartial_true_ibp` as
a `FiniteWindowKernelStieltjesIBP`.** Requires `OrderedWindow` and the
no-atom-at-`T` convention (so the `k(T)·S(T)` term is correctly zero).
The output is the canonical finite-window IBP record. -/
noncomputable def orderedWindowFiniteWindowKernelStieltjesIBP
    (D : OrderedFluctuationMeasureData)
    (x y T X : ℝ) {m : ℕ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T ≤ X) (hy : 0 < y)
    (hnoT : ∀ j ∈ Finset.range D.n, D.Z j ≠ T) :
    FiniteWindowKernelStieltjesIBP where
  S := fun U => finiteFluctuationPrimitive D T U
  partialAtX := finiteFluctuationKernelPartial D x y T X
  x := x
  y := y
  T := T
  X := X
  finite_ibp_at_X := by
    have hmain :=
      finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
    have hleft :
        finiteFluctuationPrimitive D T T = 0 :=
      finiteFluctuationPrimitive_left_zero_of_no_atom D T hnoT
    rw [hmain, hleft]
    unfold finiteFluctuationDerivativeIntegral
    ring

/-- **Tail-window data** for the eventual-`X` form. Holds the
window-invariant pieces (`D.n = m + 1`, `T ≤ Z_0`, strict ordinates)
without committing to a specific upper cutoff `X`. Once `X` is large
enough — specifically, `X ≥ Z_m` — this lifts to a full
`OrderedWindow D T X m`. -/
structure OrderedTailWindowData
    (D : OrderedFluctuationMeasureData) (T : ℝ) (m : ℕ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T ≤ D.Z 0
  hstrict     : ∀ j, j < m → D.Z j < D.Z (j + 1)

/-- 🌟 **PROVED — `OrderedWindow D T X m` holds eventually as `X → ∞`.**
The discrete zero list `{Z_0, …, Z_m}` is fixed; once `X ≥ Z_m`, the
window inclusion `Z_m ≤ X` holds. Combined with the
window-invariant data in `OrderedTailWindowData`, this gives the
full `OrderedWindow` predicate for all sufficiently large `X`.

This is the key "finite windows become valid eventually" lemma,
enabling improper-limit packages to consume the finite IBP theorem. -/
lemma orderedWindow_eventually_atTop
    (D : OrderedFluctuationMeasureData) (T : ℝ) {m : ℕ}
    (Wtail : OrderedTailWindowData D T m) :
    ∀ᶠ X in Filter.atTop, OrderedWindow D T X m := by
  filter_upwards [Filter.eventually_ge_atTop (D.Z m)] with X hXm
  exact
    { hn := Wtail.hn
      hT_le_first := Wtail.hT_le_first
      hlast_le_X := hXm
      hstrict := Wtail.hstrict }

-- =====================================================================
-- §CC. Base paired-Cauchy kernel decay
-- =====================================================================
-- Pure algebraic decay bound for the boundary term `pairedCauchyImKernel x y X`
-- in the regime `|x| < X`:
--
--   `|k(X)| ≤ 2y / (X − |x|)²`.
--
-- Built in tiny algebraic pieces (positivity, denominator comparisons,
-- per-term Cauchy bounds) so each step has a small local goal. No
-- filter, no kernel-body unfolding in a single step.

/-- ⭐ **PROVED — positive tail gap** `X − |x| > 0` when `|x| < X`. -/
lemma tailGap_pos_of_abs_lt (x X : ℝ) (hX : |x| < X) :
    0 < X - |x| := by linarith

/-- ⭐ **PROVED — positive tail-gap square**. -/
lemma tailGap_sq_pos_of_abs_lt (x X : ℝ) (hX : |x| < X) :
    0 < (X - |x|)^2 := by
  have h : 0 < X - |x| := tailGap_pos_of_abs_lt x X hX
  positivity

/-- ⭐ **PROVED — `(X − |x|)² ≤ (X − x)²`.** Case split on sign of `x`. -/
lemma tailGap_sq_le_sub_sq (x X : ℝ) (hX : |x| < X) :
    (X - |x|)^2 ≤ (X - x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 ≤ x
  · rw [abs_of_nonneg hx]
  · have hxle : x ≤ 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle]
    -- goal: (X - -x)^2 ≤ (X - x)^2, i.e., (X + x)^2 ≤ (X - x)^2 when x ≤ 0
    have hXx_nonpos : X * x ≤ 0 :=
      mul_nonpos_of_nonneg_of_nonpos hX_pos.le hxle
    nlinarith [hXx_nonpos]

/-- ⭐ **PROVED — `(X − |x|)² ≤ (X + x)²`.** Same by_cases pattern. -/
lemma tailGap_sq_le_add_sq (x X : ℝ) (hX : |x| < X) :
    (X - |x|)^2 ≤ (X + x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 ≤ x
  · rw [abs_of_nonneg hx]
    -- goal: (X - x)^2 ≤ (X + x)^2 when x ≥ 0
    have hXx_nonneg : 0 ≤ X * x := mul_nonneg hX_pos.le hx
    nlinarith [hXx_nonneg]
  · have hxle : x ≤ 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle, sub_neg_eq_add]

/-- ⭐ **PROVED — denominator lower bound** with the `+ y²` term:
  `(X − |x|)² ≤ (X − x)² + y²`. -/
lemma tailGap_sq_le_sub_den (x y X : ℝ) (hX : |x| < X) :
    (X - |x|)^2 ≤ (X - x)^2 + y^2 := by
  have h1 := tailGap_sq_le_sub_sq x X hX
  have h2 : 0 ≤ y^2 := sq_nonneg y
  linarith

/-- ⭐ **PROVED — denominator lower bound** with the `+ y²` term, plus form. -/
lemma tailGap_sq_le_add_den (x y X : ℝ) (hX : |x| < X) :
    (X - |x|)^2 ≤ (X + x)^2 + y^2 := by
  have h1 := tailGap_sq_le_add_sq x X hX
  have h2 : 0 ≤ y^2 := sq_nonneg y
  linarith

/-- ⭐ **PROVED — bound on the `-` Cauchy term** (kernel uses `(x-X)`,
which squares to `(X-x)`, hence equivalent). -/
lemma cauchy_sub_term_le_tail
    (x y X : ℝ) (hy : 0 ≤ y) (hX : |x| < X) :
    y / ((x - X)^2 + y^2) ≤ y / (X - |x|)^2 := by
  have hsq_eq : (x - X)^2 = (X - x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_sub_den x y X hX)

/-- ⭐ **PROVED — bound on the `+` Cauchy term**. -/
lemma cauchy_add_term_le_tail
    (x y X : ℝ) (hy : 0 ≤ y) (hX : |x| < X) :
    y / ((x + X)^2 + y^2) ≤ y / (X - |x|)^2 := by
  have hsq_eq : (x + X)^2 = (X + x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_add_den x y X hX)

/-- ⭐ **PROVED — pointwise reciprocal Cauchy term is non-negative.** -/
lemma reciprocal_quadratic_nonneg (x X y : ℝ) :
    0 ≤ 1 / ((x - X)^2 + y^2) := by positivity

/-- ⭐ **PROVED — sum of reciprocal Cauchy terms is non-negative.** -/
lemma reciprocal_quadratic_sum_nonneg (x X y : ℝ) :
    0 ≤ 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) := by positivity

/-- 🌟 **PROVED — BASE KERNEL DECAY**:
  `|pairedCauchyImKernel x y X| ≤ 2y / (X − |x|)²`   when `0 ≤ y, |x| < X`.

The boundary-term inequality needed for the improper IBP limit. Pure
algebra: distribute `-y`, take abs, bound each Cauchy term by
`y/(X−|x|)²`, sum, factor `2`. -/
theorem abs_pairedCauchyImKernel_le_quadratic_tail
    (x y X : ℝ) (hy : 0 ≤ y) (hX : |x| < X) :
    |pairedCauchyImKernel x y X|
      ≤ 2 * y / (X - |x|)^2 := by
  unfold pairedCauchyImKernel
  -- Rewrite `-y * sum` as `-(y · sum)`, then `|−·| = |·|`.
  have h_neg_form :
      -y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = -(y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))) := by ring
  rw [h_neg_form, abs_neg]
  -- The non-negated product is non-negative.
  have h_sum_nn : 0 ≤ 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) :=
    reciprocal_quadratic_sum_nonneg x X y
  have h_prod_nn : 0 ≤ y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2)) :=
    mul_nonneg hy h_sum_nn
  rw [abs_of_nonneg h_prod_nn]
  -- Distribute `y · sum = y/A + y/B`.
  have h_distrib :
      y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = y / ((x - X)^2 + y^2) + y / ((x + X)^2 + y^2) := by
    rw [mul_add, mul_one_div, mul_one_div]
  rw [h_distrib]
  have h_sub := cauchy_sub_term_le_tail x y X hy hX
  have h_add := cauchy_add_term_le_tail x y X hy hX
  have h_double : y / (X - |x|)^2 + y / (X - |x|)^2
                = 2 * y / (X - |x|)^2 := by ring
  linarith

-- =====================================================================
-- §CCI. Boundary term decay → 0 (crude asymptotics + squeeze)
-- =====================================================================
-- Goal:
--   `Tendsto (fun X => k(X) · S(X)) atTop (𝓝 0)`
-- under the log-envelope hypothesis `|S X| ≤ C·log X + D` eventually.
--
-- Strategy (intentionally crude, to dodge the sharp asymptotic):
--   1. `(X − |x|)² ≥ X²/4` eventually (when `2|x| ≤ X`).
--   2. `log X ≤ X` eventually.
--   3. `C·log X + D ≤ (C + |D| + 1)·X` eventually.
--   4. `|k(X) · S X| ≤ (8y(C+|D|+1))/X` eventually.
--   5. Squeeze with `const/X → 0`.

/-- ⭐ **PROVED — `|x| < X` eventually.** -/
lemma eventually_abs_lt_atTop (x : ℝ) :
    ∀ᶠ X : ℝ in Filter.atTop, |x| < X :=
  Filter.eventually_gt_atTop |x|

/-- ⭐ **PROVED — `2 · |x| ≤ X` eventually.** -/
lemma eventually_two_abs_le_atTop (x : ℝ) :
    ∀ᶠ X : ℝ in Filter.atTop, 2 * |x| ≤ X :=
  Filter.eventually_ge_atTop (2 * |x|)

/-- ⭐ **PROVED — shifted square lower bound:**
  `X²/4 ≤ (X − |x|)²`   when `0 ≤ X` and `2|x| ≤ X`. -/
lemma shifted_sq_ge_quarter_sq
    (x X : ℝ) (hX : 0 ≤ X) (hx : 2 * |x| ≤ X) :
    X^2 / 4 ≤ (X - |x|)^2 := by
  have hhalf : X / 2 ≤ X - |x| := by linarith
  have hhalf_nonneg : 0 ≤ X / 2 := by linarith
  nlinarith [hhalf, hhalf_nonneg, abs_nonneg x]

/-- ⭐ **PROVED — `log X ≤ X`** eventually as `X → ∞`. -/
lemma eventually_log_le_self :
    ∀ᶠ X : ℝ in Filter.atTop, Real.log X ≤ X := by
  filter_upwards [Filter.eventually_gt_atTop (0 : ℝ)] with X hX
  have h := Real.log_le_sub_one_of_pos hX
  linarith

/-- ⭐ **PROVED — log envelope dominated by linear envelope** eventually:
  `C·log X + D ≤ (C + |D| + 1) · X`. -/
lemma log_envelope_le_linear_eventually
    (C D : ℝ) (hC : 0 ≤ C) :
    ∀ᶠ X : ℝ in Filter.atTop,
      C * Real.log X + D ≤ (C + |D| + 1) * X := by
  filter_upwards
    [eventually_log_le_self,
     Filter.eventually_ge_atTop (1 : ℝ)] with X hlog hXge1
  have hXnonneg : 0 ≤ X := by linarith
  have hClog_le : C * Real.log X ≤ C * X :=
    mul_le_mul_of_nonneg_left hlog hC
  have hD_le_abs : D ≤ |D| := le_abs_self D
  have habs_le_absX : |D| ≤ |D| * X := by
    have habs_nn : 0 ≤ |D| := abs_nonneg D
    nlinarith [habs_nn, hXge1]
  have h_one_X_nn : 0 ≤ 1 * X := by linarith
  nlinarith [hClog_le, hD_le_abs, habs_le_absX, hXnonneg]

/-- ⭐ **PROVED — `A / X → 0` as `X → ∞`** for any constant `A`. -/
lemma const_div_tendsto_zero_atTop (A : ℝ) :
    Tendsto (fun X : ℝ => A / X) Filter.atTop (𝓝 0) := by
  simpa [div_eq_mul_inv] using
    (tendsto_const_nhds (x := A)).mul tendsto_inv_atTop_zero

/-- ⭐ **PROVED — boundary term dominated by `const/X` eventually.**
Combines the kernel decay bound, the shifted-square lower bound, and
the log-envelope linear domination. -/
lemma boundary_abs_le_const_over_X_eventually
    {S : ℝ → ℝ} {C D : ℝ} (x y : ℝ)
    (hy : 0 ≤ y) (hC : 0 ≤ C) (_hD : 0 ≤ D)
    (hS : ∀ᶠ X in Filter.atTop, |S X| ≤ C * Real.log X + D) :
    ∀ᶠ X in Filter.atTop,
      |pairedCauchyImKernel x y X * S X|
        ≤ (8 * y * (C + |D| + 1)) / X := by
  filter_upwards
    [hS,
     eventually_abs_lt_atTop x,
     Filter.eventually_gt_atTop (0 : ℝ),
     eventually_two_abs_le_atTop x,
     log_envelope_le_linear_eventually C D hC]
    with X hSX hAbs hXpos h2abs hloglin
  have hk : |pairedCauchyImKernel x y X| ≤ 2 * y / (X - |x|)^2 :=
    abs_pairedCauchyImKernel_le_quadratic_tail x y X hy hAbs
  have hshift : X^2 / 4 ≤ (X - |x|)^2 :=
    shifted_sq_ge_quarter_sq x X hXpos.le h2abs
  have henv_nonneg : 0 ≤ C * Real.log X + D :=
    le_trans (abs_nonneg _) hSX
  have h_denom_pos : 0 < (X - |x|)^2 :=
    tailGap_sq_pos_of_abs_lt x X hAbs
  have h_quarter_pos : 0 < X^2 / 4 := by positivity
  have h_kbnd_nn : 0 ≤ 2 * y / (X - |x|)^2 :=
    div_nonneg (by linarith) h_denom_pos.le
  have h_quarter_inv_nn : 0 ≤ 2 * y / (X^2 / 4) :=
    div_nonneg (by linarith) h_quarter_pos.le
  -- Step 1: |k · S| = |k| · |S| ≤ (2y/(X-|x|)²) · env
  have h_step1 : |pairedCauchyImKernel x y X * S X|
              ≤ (2 * y / (X - |x|)^2) * (C * Real.log X + D) := by
    rw [abs_mul]
    exact mul_le_mul hk hSX (abs_nonneg _) h_kbnd_nn
  -- Step 2: (2y/(X-|x|)²) · env ≤ (2y/(X²/4)) · env
  have h_step2 : (2 * y / (X - |x|)^2) * (C * Real.log X + D)
              ≤ (2 * y / (X^2 / 4)) * (C * Real.log X + D) := by
    apply mul_le_mul_of_nonneg_right _ henv_nonneg
    exact div_le_div_of_nonneg_left (by linarith) h_quarter_pos hshift
  -- Step 3: (2y/(X²/4)) · env ≤ (2y/(X²/4)) · ((C+|D|+1)·X)
  have h_step3 : (2 * y / (X^2 / 4)) * (C * Real.log X + D)
              ≤ (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X) :=
    mul_le_mul_of_nonneg_left hloglin h_quarter_inv_nn
  -- Step 4: algebra — (2y/(X²/4)) · ((C+|D|+1)·X) = 8y(C+|D|+1)/X
  have h_step4 : (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X)
              = 8 * y * (C + |D| + 1) / X := by
    have hXne : X ≠ 0 := ne_of_gt hXpos
    field_simp
    ring
  linarith

/-- 🌟🌟 **PROVED — BOUNDARY TERM TENDS TO ZERO** under a log
envelope `|S X| ≤ C · log X + D`:

  `Tendsto (fun X => k(X) · S(X)) atTop (𝓝 0)`.

Squeeze on the absolute value via the
`boundary_abs_le_const_over_X_eventually` upper bound + `const/X → 0`. -/
theorem boundary_atTop_of_log_envelope
    {S : ℝ → ℝ} {C D : ℝ} (x y : ℝ)
    (hy : 0 ≤ y) (hC : 0 ≤ C) (hD : 0 ≤ D)
    (hS : ∀ᶠ X in Filter.atTop, |S X| ≤ C * Real.log X + D) :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (𝓝 0) := by
  -- Step 1: prove |·| → 0 via squeeze
  have h_abs_tendsto : Tendsto
      (fun X => |pairedCauchyImKernel x y X * S X|) Filter.atTop (𝓝 0) := by
    apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
      tendsto_const_nhds
      (const_div_tendsto_zero_atTop (8 * y * (C + |D| + 1)))
    · exact Filter.Eventually.of_forall (fun X => abs_nonneg _)
    · exact boundary_abs_le_const_over_X_eventually x y hy hC hD hS
  -- Step 2: |·| → 0 ⟹ · → 0
  rw [tendsto_zero_iff_abs_tendsto_zero]
  exact h_abs_tendsto

-- =====================================================================
-- §CCII. Derivative-side improper convergence: architecture + eventual bound
-- =====================================================================
-- Sets up the derivative-side improper limit lane:
--   • `derivativeSidePartial` — the partial integral as a function of `X`
--   • `ImproperIntervalIntegralConverges` — Prop wrapper around `Tendsto`
--   • `derivative_integral_tendsto_of_improperConverges` — bridge
--   • `derivative_integrand_abs_le_log_kernel_eventually` — combines log
--     envelope on `S` with the existing kernel decay
--     `abs_pairedCauchyImKernelDeriv_le_adaptive_18` to bound the
--     integrand by `(C·log u + D) · 18y/u³` eventually.
--
-- The actual convergence of the majorant integral (and hence the
-- derivative-side partial) is the analytic content; it's isolated here
-- as a Prop and inhabited in a follow-up patch (uses Mathlib's
-- absolute-convergence/DCT-for-improper-integrals machinery + the
-- explicit primitive of `log u / u³`).

/-- **Derivative-side partial integral**:
  `∫_T^X S(u) · k'(u) du`   where `k' = pairedCauchyImKernelDeriv x y`.
The variable side of the IBP whose limit as `X → ∞` is the open
analytic content of the improper IBP. -/
noncomputable def derivativeSidePartial
    (S : ℝ → ℝ) (x y T X : ℝ) : ℝ :=
  ∫ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Improper interval-integral convergence** for `f` at basepoint `T`:
there exists `L` such that `∫_T^X f(u) du → L` as `X → ∞`. Prop
wrapper around `Tendsto`. -/
def ImproperIntervalIntegralConverges (f : ℝ → ℝ) (T : ℝ) : Prop :=
  ∃ L : ℝ, Tendsto (fun X : ℝ => ∫ u in T..X, f u) Filter.atTop (𝓝 L)

/-- ⭐ **PROVED — derivative-side convergence bridge.** If the improper
integral of `S(u) · k'(u)` converges (as a Prop), then the
`derivativeSidePartial` tends to that limit. Direct unpacking. -/
lemma derivative_integral_tendsto_of_improperConverges
    {S : ℝ → ℝ} {x y T : ℝ}
    (h : ImproperIntervalIntegralConverges
          (fun u => S u * pairedCauchyImKernelDeriv x y u) T) :
    ∃ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (𝓝 J) := by
  obtain ⟨L, hL⟩ := h
  exact ⟨L, hL⟩

/-- 🌟 **PROVED — eventual bound on the derivative-side integrand.**
For `0 < y`, log envelope `|S u| ≤ C log u + D` eventually, and `u`
in the adaptive kernel regime `2(1 + |x| + y) ≤ u`:

  `|S(u) · k'(u)| ≤ (C·log u + D) · 18y/u³`   eventually.

Combines the existing kernel decay
`abs_pairedCauchyImKernelDeriv_le_adaptive_18` (giving the `18y/u³`
envelope) with the log envelope on `S`. -/
lemma derivative_integrand_abs_le_log_kernel_eventually
    {S : ℝ → ℝ} {C D : ℝ} (x y : ℝ)
    (hy : 0 < y) (_hC : 0 ≤ C) (_hD : 0 ≤ D)
    (hS : ∀ᶠ u in Filter.atTop, |S u| ≤ C * Real.log u + D) :
    ∀ᶠ u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        ≤ (C * Real.log u + D) * (18 * y / u^3) := by
  filter_upwards
    [hS,
     Filter.eventually_ge_atTop (2 * (1 + |x| + y))] with u hSu h_reg
  rw [abs_mul]
  -- Adaptive bound: T = u (the threshold itself), so hT = h_reg and hu = le_refl u.
  have hkernel : |pairedCauchyImKernelDeriv x y u| ≤ 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 (le_of_lt hy) h_reg (le_refl u)
  have henv_nn : 0 ≤ C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hkernel (abs_nonneg _) henv_nn

/-- **Headline target (Prop-staged): under log envelope + majorant
convergence, the derivative-side partial integral converges.**

Stated with the majorant `(C·log u + D) · 18y/u³` whose explicit
primitive shows finite convergence (`∫ log u / u³` and `∫ 1/u³` both
integrate to terms vanishing at `∞`). The Mathlib absolute-convergence
chase to actually inhabit the conclusion is the next analytic patch. -/
def DerivativeSideMajorantConverges
    (_x y T : ℝ) (C D : ℝ) : Prop :=
  ImproperIntervalIntegralConverges
    (fun u => (C * Real.log u + D) * (18 * y / u^3)) T

/-- 🌟🌟 **PROVED — `derivative_integral_tendsto_of_log_envelope` modulo
majorant convergence.** Given:

* `0 < y`, `0 ≤ C, 0 ≤ D`;
* log envelope `|S u| ≤ C·log u + D` eventually;
* the majorant integral `∫ (C·log u + D)·18y/u³ du` converges as
  `X → ∞` (Prop `DerivativeSideMajorantConverges`);

the bridge to convergence of `derivativeSidePartial S x y T` would
follow by the absolute-convergence comparison theorem (next patch).

The current statement isolates exactly what's left: an absolute
domination lemma + Mathlib's "absolutely-convergent improper integral
converges" theorem. -/
def DerivativeSideConvergesUnderLogEnvelope
    (S : ℝ → ℝ) (x y T C D : ℝ) : Prop :=
  (∀ᶠ u in Filter.atTop, |S u| ≤ C * Real.log u + D) →
  DerivativeSideMajorantConverges x y T C D →
  ∃ J, Tendsto (fun X => derivativeSidePartial S x y T X)
    Filter.atTop (𝓝 J)

-- =====================================================================
-- §CCIII. Majorant primitive + DerivativeSideMajorantConverges discharge
-- =====================================================================
-- Discharges `DerivativeSideMajorantConverges` via explicit primitive:
--   `M(u)  := (C · log u + D) · 18y/u³`     (the majorant)
--   `P(u)  := −9y · (C · log u + D + C/2) / u²`   (a primitive)
-- with `P'(u) = M(u)` for `u > 0`, and `P(X) → 0` as `X → ∞`.

/-- **Named majorant** for the derivative-side integrand. -/
noncomputable def derivativeSideMajorant
    (y C D : ℝ) (u : ℝ) : ℝ :=
  (C * Real.log u + D) * (18 * y / u^3)

/-- **Explicit primitive** of the majorant on `u > 0`:
  `P(u) = −9y · (C · log u + D + C/2) / u²`. -/
noncomputable def derivativeSideMajorantPrimitive
    (y C D : ℝ) (u : ℝ) : ℝ :=
  -9 * y * (C * Real.log u + D + C / 2) / u^2

/-- 🌟 **PROVED — `P'(u) = M(u)`** on `u > 0`. Calculus on
  `log`, `t^2`, and `HasDerivAt.div`, then `field_simp + ring` to
  reconcile the derivative shape. -/
lemma hasDerivAt_derivativeSideMajorantPrimitive
    (y C D u : ℝ) (hu : 0 < u) :
    HasDerivAt
      (fun t => derivativeSideMajorantPrimitive y C D t)
      (derivativeSideMajorant y C D u)
      u := by
  unfold derivativeSideMajorantPrimitive derivativeSideMajorant
  have hu_ne : u ≠ 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have hu_sq_ne : u^2 ≠ 0 := ne_of_gt hu_sq_pos
  have h_log : HasDerivAt Real.log u⁻¹ u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * Real.log t + D + C / 2) (C * u⁻¹) u := by
    have h1 := h_log.const_mul C
    have h2 := h1.add_const D
    exact h2.add_const (C / 2)
  have h_sq : HasDerivAt (fun t : ℝ => t^2) (2 * u) u := by
    have := (hasDerivAt_id u).pow 2
    simpa [pow_one] using this
  have h_div : HasDerivAt
      (fun t : ℝ => (C * Real.log t + D + C / 2) / t^2)
      ((C * u⁻¹ * u^2 - (C * Real.log u + D + C / 2) * (2 * u)) / (u^2)^2) u :=
    h_g.div h_sq hu_sq_ne
  have h_neg9y : HasDerivAt
      (fun t : ℝ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
      (-9 * y * ((C * u⁻¹ * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)) u :=
    h_div.const_mul (-9 * y)
  have h_fun_eq : (fun t : ℝ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
                = (fun t : ℝ => -9 * y * (C * Real.log t + D + C / 2) / t^2) := by
    funext t; ring
  rw [h_fun_eq] at h_neg9y
  have h_val :
      -9 * y * ((C * u⁻¹ * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)
        = (C * Real.log u + D) * (18 * y / u^3) := by
    field_simp
    ring
  rw [h_val] at h_neg9y
  exact h_neg9y

/-- ⭐ **PROVED — majorant is continuous on `[T, X]`** for `0 < T ≤ X`. -/
lemma derivativeSideMajorant_continuousOn_Icc
    (y C D T X : ℝ) (hT : 0 < T) (_hTX : T ≤ X) :
    ContinuousOn (fun u => derivativeSideMajorant y C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold derivativeSideMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.mul ?_ ?_
  · refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  · refine continuousAt_const.div ?_ ?_
    · exact continuousAt_id.pow 3
    · exact pow_ne_zero 3 (ne_of_gt hu_pos)

/-- ⭐ **PROVED — majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma derivativeSideMajorant_intervalIntegrable
    (y C D T X : ℝ) (hT : 0 < T) (hTX : T ≤ X) :
    IntervalIntegrable (fun u => derivativeSideMajorant y C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (derivativeSideMajorant_continuousOn_Icc y C D T X hT hTX)

/-- 🌟 **PROVED — FTC for the majorant**:
  `∫_T^X M(u) du = P(X) − P(T)`. -/
lemma derivativeSideMajorant_integral_eq_sub
    (y C D T X : ℝ) (hT : 0 < T) (hTX : T ≤ X) :
    (∫ u in T..X, derivativeSideMajorant y C D u)
      = derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  · intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_derivativeSideMajorantPrimitive y C D u hu_pos
  · exact derivativeSideMajorant_intervalIntegrable y C D T X hT hTX

/-- ⭐ **PROVED — `1/X² → 0`** as `X → ∞`. Via `Tendsto.mul` on `1/X · 1/X`. -/
lemma one_div_sq_tendsto_zero :
    Tendsto (fun X : ℝ => 1 / X^2) Filter.atTop (𝓝 0) := by
  have h_inv := const_div_tendsto_zero_atTop (1 : ℝ)
  have h_prod : Tendsto (fun X : ℝ => 1 / X * (1 / X)) Filter.atTop (𝓝 (0 * 0)) :=
    h_inv.mul h_inv
  rw [show (0 * 0 : ℝ) = 0 from by ring] at h_prod
  have h_eq : (fun X : ℝ => 1 / X * (1 / X)) = (fun X : ℝ => 1 / X^2) := by
    funext X; rw [pow_two]; ring
  rw [h_eq] at h_prod
  exact h_prod

/-- ⭐ **PROVED — `log X / X² → 0`** as `X → ∞`. Squeeze between `0`
(eventually, for `X ≥ 1`) and `1/X`. -/
lemma log_div_sq_tendsto_zero :
    Tendsto (fun X : ℝ => Real.log X / X^2) Filter.atTop (𝓝 0) := by
  apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
    (tendsto_const_nhds (x := (0 : ℝ)))
    (const_div_tendsto_zero_atTop (1 : ℝ))
  · -- 0 ≤ log X / X² eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : ℝ)] with X hX
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:ℝ) < 1) hX
    have hlog_nn : 0 ≤ Real.log X := Real.log_nonneg hX
    positivity
  · -- log X / X² ≤ 1/X eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : ℝ),
                    eventually_log_le_self] with X hX hlog
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:ℝ) < 1) hX
    have hX_sq_pos : 0 < X^2 := by positivity
    rw [div_le_div_iff₀ hX_sq_pos hX_pos]
    -- log X * X ≤ X^2 * 1, i.e., X · log X ≤ X²
    have h_mul : X * Real.log X ≤ X * X :=
      mul_le_mul_of_nonneg_left hlog hX_pos.le
    nlinarith [h_mul]

/-- 🌟 **PROVED — `P(X) → 0`** as `X → ∞`. The primitive splits as
two terms, each a constant times a vanishing piece (`log X / X²` and
`1/X²`). -/
lemma derivativeSideMajorantPrimitive_tendsto_zero
    (y C D : ℝ) :
    Tendsto (fun X : ℝ => derivativeSideMajorantPrimitive y C D X)
      Filter.atTop (𝓝 0) := by
  unfold derivativeSideMajorantPrimitive
  -- -9y · (C log X + D + C/2) / X² = (-9yC) · log X/X² + (-9y(D+C/2)) · 1/X²
  have h_logterm : Tendsto (fun X : ℝ => (-9 * y * C) * (Real.log X / X^2))
      Filter.atTop (𝓝 ((-9 * y * C) * 0)) :=
    log_div_sq_tendsto_zero.const_mul (-9 * y * C)
  have h_constterm : Tendsto (fun X : ℝ => (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (𝓝 ((-9 * y * (D + C/2)) * 0)) :=
    one_div_sq_tendsto_zero.const_mul (-9 * y * (D + C/2))
  have h_sum : Tendsto (fun X : ℝ =>
      (-9 * y * C) * (Real.log X / X^2) + (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (𝓝 ((-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  -- Rewrite our primitive to match the sum's form
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : ℝ)] with X hX
  have hX_sq_ne : X^2 ≠ 0 := pow_ne_zero 2 (ne_of_gt hX)
  field_simp
  ring

/-- 🌟🌟🌟 **PROVED — `DerivativeSideMajorantConverges`** for any `x`,
  `y`, `T > 0`, `C, D`. The limit is `−P(T)`. Combines FTC + primitive
  tending to 0. -/
theorem derivativeSideMajorantConverges
    (x y T C D : ℝ) (hT : 0 < T) :
    DerivativeSideMajorantConverges x y T C D := by
  refine ⟨-derivativeSideMajorantPrimitive y C D T, ?_⟩
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : ℝ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (𝓝 (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : ℝ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (𝓝 (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  -- Bridge to the integral form via FTC for X ≥ T
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

-- =====================================================================
-- §CCIV. Absolute-convergence comparison scaffolding
-- =====================================================================
-- The missing analytic ingredient for `derivative_integral_tendsto`:
--   `|f| ≤ M eventually + ∫_T^X M → LM  ⟹  ∃ J, ∫_T^X f → J`.
-- Built in stages:
--   A. named partial/tail integrals (keeps the elaborator cheap);
--   B. tail identity `∫_T^B − ∫_T^A = ∫_A^B`;
--   C. tail smallness: `Tendsto M_partial atTop (𝓝 LM) ⇒ tails eventually small`;
--   D. finite comparison: `|∫ f| ≤ ∫ M` (per-interval, given a pointwise bound).
-- The full comparison theorem (Cauchy criterion + completeness) is the
-- next analytic patch.

/-- **Named partial integral** at upper cutoff `X`. -/
noncomputable def intervalPartialIntegral
    (f : ℝ → ℝ) (T X : ℝ) : ℝ :=
  ∫ u in T..X, f u

/-- **Named tail integral** between `A` and `B`. -/
noncomputable def intervalTailIntegral
    (f : ℝ → ℝ) (A B : ℝ) : ℝ :=
  ∫ u in A..B, f u

/-- ⭐ **PROVED — tail identity for partial integrals.**
  `∫_T^B f − ∫_T^A f = ∫_A^B f`  for `T ≤ A ≤ B` with `f` integrable on `[T, B]`. -/
lemma intervalPartialIntegral_sub_eq_tail
    (f : ℝ → ℝ) (T A B : ℝ)
    (hTA : T ≤ A) (hAB : A ≤ B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume T B) :
    intervalPartialIntegral f T B - intervalPartialIntegral f T A
      = intervalTailIntegral f A B := by
  unfold intervalPartialIntegral intervalTailIntegral
  have hTB : T ≤ B := le_trans hTA hAB
  have h_T_A : IntervalIntegrable f MeasureTheory.volume T A :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hTA, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_right hAB)
  have h_A_B : IntervalIntegrable f MeasureTheory.volume A B :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hAB, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_left hTA)
  have h_split : (∫ u in T..B, f u) = (∫ u in T..A, f u) + ∫ u in A..B, f u :=
    (intervalIntegral.integral_add_adjacent_intervals h_T_A h_A_B).symm
  linarith

/-- 🌟 **PROVED — tail smallness from partial-integral convergence.**
If `∫_T^X M → LM` as `X → ∞`, then for any `ε > 0` the tail integral
`∫_A^B M` is `< ε` for all sufficiently large `A ≤ B`. Pure
filter-algebra epsilon argument: pick `ε/2` neighborhoods of `LM`, use
the triangle inequality on the tail identity. -/
lemma tail_integral_small_of_partial_tendsto
    {M : ℝ → ℝ} {T LM : ℝ}
    (hM_int_all : ∀ X, IntervalIntegrable M MeasureTheory.volume T X)
    (hM : Tendsto (fun X => intervalPartialIntegral M T X)
            Filter.atTop (𝓝 LM)) :
    ∀ ε > 0, ∀ᶠ A in Filter.atTop, ∀ᶠ B in Filter.atTop,
      A ≤ B → |intervalTailIntegral M A B| < ε := by
  intro ε hε
  have hε2 : 0 < ε / 2 := by linarith
  -- Tendsto in metric form: dist (partial X) LM < ε/2 eventually
  have hA_close : ∀ᶠ A in Filter.atTop,
      |intervalPartialIntegral M T A - LM| < ε/2 := by
    have h := (Metric.tendsto_nhds.mp hM) (ε/2) hε2
    filter_upwards [h] with A hdist
    rwa [Real.dist_eq] at hdist
  filter_upwards [hA_close, Filter.eventually_ge_atTop T] with A hAclose hTA
  filter_upwards [hA_close, Filter.eventually_ge_atTop A] with B hBclose hAB hABle
  -- Tail identity: ∫_A^B M = partial M T B − partial M T A
  have h_tail_eq : intervalTailIntegral M A B
                 = intervalPartialIntegral M T B
                   - intervalPartialIntegral M T A := by
    have := intervalPartialIntegral_sub_eq_tail M T A B hTA hABle (hM_int_all B)
    linarith
  rw [h_tail_eq]
  -- Triangle inequality: |pB − pA| ≤ |pB − LM| + |pA − LM| < ε
  have h_tri : |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
            ≤ |intervalPartialIntegral M T B - LM|
              + |intervalPartialIntegral M T A - LM| := by
    calc |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
        = |(intervalPartialIntegral M T B - LM)
            + -(intervalPartialIntegral M T A - LM)| := by ring_nf
      _ ≤ |intervalPartialIntegral M T B - LM|
          + |-(intervalPartialIntegral M T A - LM)| := abs_add _ _
      _ = |intervalPartialIntegral M T B - LM|
          + |intervalPartialIntegral M T A - LM| := by rw [abs_neg]
  linarith

/-- 🌟 **PROVED — finite-window absolute comparison**:
  `|∫_A^B f| ≤ ∫_A^B M`  when `|f u| ≤ M u` on `[A, B]`, both integrable. -/
lemma intervalIntegral_abs_le_intervalIntegral_majorant
    {f M : ℝ → ℝ} {A B : ℝ}
    (hAB : A ≤ B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume A B)
    (hM_int : IntervalIntegrable M MeasureTheory.volume A B)
    (hbound : ∀ u ∈ Set.Icc A B, |f u| ≤ M u) :
    |∫ u in A..B, f u| ≤ ∫ u in A..B, M u := by
  -- Step 1: |∫ f| ≤ ∫ |f|
  have h_abs_int : IntervalIntegrable (fun u => |f u|) MeasureTheory.volume A B :=
    hf_int.abs
  have h1 : |∫ u in A..B, f u| ≤ ∫ u in A..B, |f u| :=
    intervalIntegral.abs_integral_le_integral_abs hAB
  -- Step 2: ∫ |f| ≤ ∫ M via monotone
  have h2 : ∫ u in A..B, |f u| ≤ ∫ u in A..B, M u := by
    apply intervalIntegral.integral_mono_on hAB h_abs_int hM_int
    intro u hu
    exact hbound u hu
  linarith

-- =====================================================================
-- §CCV. Comparison theorem: Cauchy + complete-space convergence
-- =====================================================================
-- The headline analytic theorem for derivative-side improper convergence:
--
--   `|f u| ≤ M u eventually  +  ∫_T^X M → LM
--      ⟹  ∃ J, ∫_T^X f → J`.
--
-- Strategy:
--   1. Show `(fun X => ∫_T^X f)` is Cauchy at `atTop` via the finite
--      comparison applied to tails (using the M partial integrals'
--      ε/2 closeness to `LM`).
--   2. Conclude convergence via `CompleteSpace.complete` for `ℝ`.

/-- 🌟🌟 **PROVED — ABSOLUTE-CONVERGENCE COMPARISON THEOREM.**
For real-valued `f, M` with `f, M` interval-integrable on each `[T, X]`
for `X ≥ T`, `|f u| ≤ M u` eventually, and the M-partial integrals
converging:

  the f-partial integrals also converge.

The integrability hypothesis is restricted to `X ≥ T` because for many
natural majorants (e.g. `(C·log u + D)·18y/u³`) the integrand fails to
be integrable on `(0, T]` if `T < 0` etc. -/
theorem improperIntegralConverges_of_absMajorant
    {f M : ℝ → ℝ} {T LM : ℝ}
    (hf_int : ∀ X, T ≤ X → IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : ∀ X, T ≤ X → IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => intervalPartialIntegral M T X)
                    Filter.atTop (𝓝 LM))
    (hbound : ∀ᶠ u in Filter.atTop, |f u| ≤ M u) :
    ImproperIntervalIntegralConverges f T := by
  -- Step 1: show Cauchy of the f-partial integrals at `atTop`
  have h_cauchy : Cauchy
      (Filter.map (fun X => intervalPartialIntegral f T X) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine ⟨Filter.map_neBot, ?_⟩
    intro ε hε
    have hε2 : 0 < ε / 2 := by linarith
    -- M partial close to LM eventually
    have h_M_close : ∀ᶠ A in Filter.atTop,
        |intervalPartialIntegral M T A - LM| < ε / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (ε / 2) hε2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain ⟨N_M, hN_M⟩ := Filter.eventually_atTop.mp h_M_close
    obtain ⟨N0, hN0⟩ := Filter.eventually_atTop.mp hbound
    let N : ℝ := max T (max N0 N_M)
    refine ⟨(fun X => intervalPartialIntegral f T X) '' {X | N ≤ X}, ?_, ?_⟩
    · exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    -- Orientation-safe distance argument via key lemma
    suffices key :
        ∀ Y1 Y2 : ℝ, N ≤ Y1 → N ≤ Y2 → Y1 ≤ Y2 →
          |intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1| < ε by
      rintro _ ⟨X1, hX1, rfl⟩ _ ⟨X2, hX2, rfl⟩
      rw [Real.dist_eq]
      rcases le_total X1 X2 with hX12 | hX21
      · rw [abs_sub_comm]; exact key X1 X2 hX1 hX2 hX12
      · exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    -- Extract individual bounds from `N := max T (max N0 N_M)`
    have hT_Y1 : T ≤ Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T ≤ Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 ≤ Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M ≤ Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M ≤ Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    -- Tail identities for f and M
    have h_tail_f :
        intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1
          = intervalTailIntegral f Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail f T Y1 Y2 hT_Y1 hY12 (hf_int Y2 hT_Y2)
    have h_tail_M :
        intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1
          = intervalTailIntegral M Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail M T Y1 Y2 hT_Y1 hY12 (hM_int Y2 hT_Y2)
    rw [h_tail_f]
    -- Sub-interval integrability for the finite comparison
    have hsub_uIcc : Set.uIcc Y1 Y2 ⊆ Set.uIcc T Y2 := by
      rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
      exact Set.Icc_subset_Icc_left hT_Y1
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      (hf_int Y2 hT_Y2).mono_set hsub_uIcc
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      (hM_int Y2 hT_Y2).mono_set hsub_uIcc
    have hbound_Y1Y2 : ∀ u ∈ Set.Icc Y1 Y2, |f u| ≤ M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    -- Finite comparison: |tail f| ≤ tail M
    have h_comp : |intervalTailIntegral f Y1 Y2| ≤ intervalTailIntegral M Y1 Y2 := by
      unfold intervalTailIntegral
      exact intervalIntegral_abs_le_intervalIntegral_majorant
        hY12 hf_int_Y1Y2 hM_int_Y1Y2 hbound_Y1Y2
    -- M partial-difference triangle: |partial M Y2 - partial M Y1| < ε
    have h_M_partial_close : |intervalTailIntegral M Y1 Y2| < ε := by
      rw [← h_tail_M]
      have h1 := hN_M Y1 hN_M_Y1
      have h2 := hN_M Y2 hN_M_Y2
      calc |intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1|
          ≤ |intervalPartialIntegral M T Y2 - LM|
            + |LM - intervalPartialIntegral M T Y1| := abs_sub_le _ _ _
        _ = |intervalPartialIntegral M T Y2 - LM|
            + |intervalPartialIntegral M T Y1 - LM| := by
              rw [abs_sub_comm LM]
        _ < ε / 2 + ε / 2 := add_lt_add h2 h1
        _ = ε := by ring
    -- tail M ≥ 0 (from |tail f| ≤ tail M and abs ≥ 0)
    have h_tail_M_nn : 0 ≤ intervalTailIntegral M Y1 Y2 :=
      le_trans (abs_nonneg _) h_comp
    have h_abs_tail_M : |intervalTailIntegral M Y1 Y2|
                      = intervalTailIntegral M Y1 Y2 :=
      abs_of_nonneg h_tail_M_nn
    rw [h_abs_tail_M] at h_M_partial_close
    exact lt_of_le_of_lt h_comp h_M_partial_close
  -- Step 2: Cauchy + complete-space ⟹ convergence
  obtain ⟨L, hL⟩ := CompleteSpace.complete h_cauchy
  exact ⟨L, hL⟩

-- =====================================================================
-- §CCVI. Derivative-side improper integral converges (wiring)
-- =====================================================================
-- Wires the generic comparison theorem `improperIntegralConverges_of_absMajorant`
-- to the derivative-side integrand `S(u) · k'(u)`. The inputs are:
--   • `derivativeSideMajorantConverges`         (§CCIII)
--   • `derivativeSideMajorant_intervalIntegrable` (§CCIII)
--   • `derivative_integrand_abs_le_log_kernel_eventually` (§CCII)
-- The remaining open input is just integrability of `S · k'` on each
-- finite window `[T, X]` (`X ≥ T`), which is a local regularity
-- condition on `S` — for arbitrary `S` it must be supplied; for the
-- finite-fluctuation primitive it falls out of §CXCVIII's machinery.

/-- 🌟🌟🌟 **PROVED — DERIVATIVE-SIDE IMPROPER CONVERGENCE under a log
envelope.** Given `0 < y`, `0 < T`, `0 ≤ C`, `0 ≤ D`, a log envelope
`|S u| ≤ C·log u + D` eventually, and finite-window integrability of
`S · k'` on each `[T, X]` (`T ≤ X`):

  `∃ J, Tendsto (fun X => ∫_T^X S(u)·k'(u) du) atTop (𝓝 J)`. -/
theorem derivative_integral_tendsto_of_log_envelope
    {S : ℝ → ℝ} {C D x y T : ℝ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 ≤ C) (hD : 0 ≤ D)
    (hS : ∀ᶠ u in Filter.atTop, |S u| ≤ C * Real.log u + D)
    (hf_int : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    ∃ J, Tendsto (fun X : ℝ => derivativeSidePartial S x y T X)
      Filter.atTop (𝓝 J) := by
  -- Set up the majorant
  obtain ⟨LM, hLM⟩ := derivativeSideMajorantConverges x y T C D hT
  -- Integrability of the majorant on each `[T, X]` (`T ≤ X`)
  have hMint : ∀ X, T ≤ X →
      IntervalIntegrable (derivativeSideMajorant y C D)
        MeasureTheory.volume T X :=
    fun X hTX => derivativeSideMajorant_intervalIntegrable y C D T X hT hTX
  -- Eventual pointwise bound
  have hbound : ∀ᶠ u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        ≤ derivativeSideMajorant y C D u :=
    derivative_integrand_abs_le_log_kernel_eventually x y hy hC hD hS
  -- Apply the comparison theorem
  have hconv : ImproperIntervalIntegralConverges
      (fun u => S u * pairedCauchyImKernelDeriv x y u) T :=
    improperIntegralConverges_of_absMajorant
      (f := fun u => S u * pairedCauchyImKernelDeriv x y u)
      (M := derivativeSideMajorant y C D)
      (T := T) (LM := LM)
      hf_int hMint hLM hbound
  -- Bridge to derivativeSidePartial
  exact derivative_integral_tendsto_of_improperConverges
    (S := S) (x := x) (y := y) (T := T) hconv

-- =====================================================================
-- §CCVII. partialF_tendsto + concrete partial convergence
-- =====================================================================
-- The third improper-limit obligation: `partialF X → L` as `X → ∞`.
-- Falls out of the finite IBP identity once the boundary term and
-- derivative-side partial integral both converge.

/-- 🌟 **PROVED — generic partial-integral limit lemma** under the
**clean** finite IBP form (no `-k(T)·S(T)` term, e.g. when `S(T) = 0`):

  `partialF X = k(X)·S X − derivativeSidePartial S x y T X` eventually,
  `k(X)·S X → 0`,
  `derivativeSidePartial → J`
   ⟹ `partialF → −J`. -/
lemma partialF_tendsto_of_clean_finiteIBP_and_limits
    {S partialF : ℝ → ℝ} {x y T J : ℝ}
    (hfinite_eventually :
      ∀ᶠ X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (𝓝 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (𝓝 J)) :
    Tendsto partialF Filter.atTop (𝓝 (-J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
        Filter.atTop (𝓝 (0 - J)) := hboundary.sub hderiv
  have hzero : (0 - J : ℝ) = -J := by ring
  rw [← hzero]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - derivativeSidePartial S x y T X)
              =ᶠ[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- 🌟 **PROVED — generic partial-integral limit lemma** under the
**standard** finite IBP form (includes the `-k(T)·S(T)` term):

  `partialF X = k(X)·S X − k(T)·S T − derivativeSidePartial X` eventually,
   ⟹ `partialF → −k(T)·S T − J`. -/
lemma partialF_tendsto_of_standard_finiteIBP_and_limits
    {S partialF : ℝ → ℝ} {x y T J : ℝ}
    (hfinite_eventually :
      ∀ᶠ X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (𝓝 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (𝓝 J)) :
    Tendsto partialF Filter.atTop
      (𝓝 (-(pairedCauchyImKernel x y T * S T) - J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
        Filter.atTop
        (𝓝 (0 - pairedCauchyImKernel x y T * S T - J)) :=
    (hboundary.sub tendsto_const_nhds).sub hderiv
  have hconst :
      0 - pairedCauchyImKernel x y T * S T - J
        = -(pairedCauchyImKernel x y T * S T) - J := by ring
  rw [← hconst]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - pairedCauchyImKernel x y T * S T
                          - derivativeSidePartial S x y T X)
              =ᶠ[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- 🌟 **PROVED — finite IBP identity holds eventually under
`OrderedTailWindowData`.** Combines `orderedWindow_eventually_atTop`
with `finiteFluctuationKernelPartial_true_ibp` and converts
`finiteFluctuationDerivativeIntegral` to `derivativeSidePartial`. -/
lemma finiteFluctuationKernelPartial_true_ibp_eventually
    (D : OrderedFluctuationMeasureData) (x y T : ℝ) {m : ℕ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) :
    ∀ᶠ X in Filter.atTop,
      finiteFluctuationKernelPartial D x y T X =
        pairedCauchyImKernel x y X
          * finiteFluctuationPrimitive D T X
          - derivativeSidePartial
              (fun U => finiteFluctuationPrimitive D T U) x y T X := by
  filter_upwards [orderedWindow_eventually_atTop D T Wtail,
                  Filter.eventually_ge_atTop T] with X W hTX
  have h := finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
  -- `finiteFluctuationDerivativeIntegral = derivativeSidePartial` for `S = ffP D T`.
  show finiteFluctuationKernelPartial D x y T X
        = pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
          - ∫ u in T..X,
              finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u
  rw [h]
  rfl

/-- 🌟🌟🌟🌟 **PROVED — `finiteFluctuationKernelPartial` converges**
under a log envelope on `finiteFluctuationPrimitive D T` plus
finite-window integrability of `ffP · k'`. The limit is `−J` where
`J` is the limit of the derivative-side partial integral. -/
theorem finiteFluctuationKernelPartial_tendsto_of_logEnvelope
    (D : OrderedFluctuationMeasureData) (x y T C Dconst : ℝ) {m : ℕ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 ≤ C) (hD : 0 ≤ Dconst)
    (hS : ∀ᶠ X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| ≤ C * Real.log X + Dconst)
    (hInt : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    ∃ L, Tendsto (fun X => finiteFluctuationKernelPartial D x y T X)
      Filter.atTop (𝓝 L) := by
  obtain ⟨J, hJ⟩ :=
    derivative_integral_tendsto_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y) (T := T)
      hy hT hC hD hS hInt
  have hb :
      Tendsto (fun X => pairedCauchyImKernel x y X
                          * finiteFluctuationPrimitive D T X)
        Filter.atTop (𝓝 0) :=
    boundary_atTop_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y)
      (le_of_lt hy) hC hD hS
  have hfinite :=
    finiteFluctuationKernelPartial_true_ibp_eventually D x y T Wtail hT hy
  exact ⟨-J, partialF_tendsto_of_clean_finiteIBP_and_limits
              hfinite hb hJ⟩

-- =====================================================================
-- §CCVIII. EventualImproperKernelStieltjesIBP
-- =====================================================================
-- Eventual finite IBP variant of the §CLXXXVIII improper record.
-- The existing `ImproperKernelStieltjesIBP` requires `FiniteKernelStieltjesIBP`
-- with the per-`X` IBP identity holding for ALL `X`. Our finite IBP only
-- holds for `X` large enough (eventually under `OrderedWindow`). This
-- eventual-form record is mathematically sufficient for the improper
-- limit, since `partial_tendsto` only uses the eventual identity.

/-- **Eventual improper kernel Stieltjes IBP package.** Same as
`ImproperKernelStieltjesIBP` (§CLXXXVIII) but accepts the finite IBP
identity as an `atTop`-eventual equality rather than `∀ X`. -/
structure EventualImproperKernelStieltjesIBP where
  S          : ℝ → ℝ
  partialF   : ℝ → ℝ
  x          : ℝ
  y          : ℝ
  T          : ℝ
  L          : ℝ
  finiteIBP_eventually :
    ∀ᶠ X in Filter.atTop,
      partialF X =
        pairedCauchyImKernel x y X * S X
          - derivativeSidePartial S x y T X
  partial_tendsto :
    Tendsto partialF Filter.atTop (𝓝 L)
  boundary_atTop :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (𝓝 0)
  derivative_integral_tendsto :
    ∃ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (𝓝 J)

/-- ⭐ **PROVED — improper identity for the eventual record.**
The limit `L` equals `-J` where `J` is the limit of the derivative-side
partial integral. Uses `partialF_tendsto_of_clean_finiteIBP_and_limits`
to derive `Tendsto partialF (𝓝 (-J))`, then uniqueness pins `L = -J`. -/
theorem EventualImproperKernelStieltjesIBP.improper_identity
    (I : EventualImproperKernelStieltjesIBP) :
    ∃ J,
      Tendsto (fun X => derivativeSidePartial I.S I.x I.y I.T X)
        Filter.atTop (𝓝 J)
      ∧ I.L = -J := by
  rcases I.derivative_integral_tendsto with ⟨J, hJ⟩
  have hL' : Tendsto I.partialF Filter.atTop (𝓝 (-J)) :=
    partialF_tendsto_of_clean_finiteIBP_and_limits
      I.finiteIBP_eventually I.boundary_atTop hJ
  have huniq : I.L = -J := tendsto_nhds_unique I.partial_tendsto hL'
  exact ⟨J, hJ, huniq⟩

/-- 🌟🌟🌟🌟🌟 **PROVED — Eventual improper IBP from ordered-tail data
+ log envelope.** End-to-end constructor: given the window-invariant
zero-list data, `T > 0`, `y > 0`, a log envelope on the finite
fluctuation primitive, and finite-window integrability of `ffP · k'`,
produces the eventual improper IBP record. -/
noncomputable def eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : ℝ) {m : ℕ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 ≤ C) (hD : 0 ≤ Dconst)
    (hS : ∀ᶠ X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| ≤ C * Real.log X + Dconst)
    (hInt : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    EventualImproperKernelStieltjesIBP :=
  -- We pre-extract the `L` witness via `Classical.choose`. `obtain` is
  -- unavailable in a structure-building term because `Exists.casesOn` is
  -- restricted to elimination into `Prop`.
  let hL_exists :=
    finiteFluctuationKernelPartial_tendsto_of_logEnvelope
      D x y T C Dconst Wtail hT hy hC hD hS hInt
  { S := fun U => finiteFluctuationPrimitive D T U
    partialF := fun X => finiteFluctuationKernelPartial D x y T X
    x := x
    y := y
    T := T
    L := hL_exists.choose
    finiteIBP_eventually :=
      finiteFluctuationKernelPartial_true_ibp_eventually
        D x y T Wtail hT hy
    partial_tendsto := hL_exists.choose_spec
    boundary_atTop :=
      boundary_atTop_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y)
        (le_of_lt hy) hC hD hS
    derivative_integral_tendsto :=
      derivative_integral_tendsto_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y) (T := T)
        hy hT hC hD hS hInt }

-- =====================================================================
-- §CCIX. Bridge: EventualImproperKernelStieltjesIBP → ImaginaryStieltjesTailIBPBound
-- =====================================================================
-- Direct mirror of §CXC `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`,
-- consuming the eventual improper IBP record. Mathematically identical
-- — both versions only repack the data fields `S`, `T`, `x`, `y` plus
-- the user-supplied `B`, `integralBound`, `modelMargin`, `ibpMargin`.

/-- 🌟 **PROVED — bridge from `EventualImproperKernelStieltjesIBP` to
`ImaginaryStieltjesTailIBPBound`** (§13 / §CXC chain). Mirror of the
old `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`. -/
noncomputable def EventualImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : EventualImproperKernelStieltjesIBP)
    (B : ℝ → ℝ)
    (hS_bound : ∀ u : ℝ, I.T ≤ u → |I.S u| ≤ B u)
    (Jbound : ℝ)
    (modelMargin : ℝ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound ≤ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

-- =====================================================================
-- §CCX. Explicit `|J|` bound from the derivative-side majorant
-- =====================================================================
-- Pass the finite-window absolute comparison
--   `|∫_T^X S·k'| ≤ ∫_T^X M`
-- to the `X → ∞` limit using:
--   • `derivativeSidePartial → J`
--   • `∫_T^X M → −P(T)`  (explicit Tendsto via the majorant primitive)
-- Combined via `le_of_tendsto_of_tendsto'`.

/-- 🌟 **PROVED — explicit Tendsto for the majorant integral.**
The integral `∫_T^X M(u) du` tends to `−P(T)` as `X → ∞`. Explicit
form (the existence-only `derivativeSideMajorantConverges` is the
∃-wrapped version of this). -/
theorem derivativeSideMajorant_integral_tendsto_atTop
    (_x y T C D : ℝ) (hT : 0 < T) :
    Tendsto (fun X => ∫ u in T..X, derivativeSideMajorant y C D u)
      Filter.atTop (𝓝 (-derivativeSideMajorantPrimitive y C D T)) := by
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : ℝ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (𝓝 (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : ℝ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (𝓝 (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

/-- 🌟 **PROVED — finite-window absolute bound** for the derivative-side
partial integral. Requires:
* `T` already inside the adaptive regime (`2(1+|x|+y) ≤ T`);
* log envelope on `S` on `[T, ∞)`. -/
lemma derivativeSidePartial_abs_le_majorant_partial
    {S : ℝ → ℝ} (C D x y T X : ℝ)
    (hy : 0 < y) (hT : 0 < T) (_hC : 0 ≤ C) (_hD : 0 ≤ D)
    (hreg : 2 * (1 + |x| + y) ≤ T)
    (hS_T : ∀ u, T ≤ u → |S u| ≤ C * Real.log u + D)
    (hInt : IntervalIntegrable
      (fun u => S u * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X)
    (hTX : T ≤ X) :
    |derivativeSidePartial S x y T X|
      ≤ ∫ u in T..X, derivativeSideMajorant y C D u := by
  unfold derivativeSidePartial
  apply intervalIntegral_abs_le_intervalIntegral_majorant hTX hInt
    (derivativeSideMajorant_intervalIntegrable y C D T X hT hTX)
  intro u hu
  unfold derivativeSideMajorant
  rw [abs_mul]
  have hSu : |S u| ≤ C * Real.log u + D := hS_T u hu.1
  have hreg_u : 2 * (1 + |x| + y) ≤ u := le_trans hreg hu.1
  have hk : |pairedCauchyImKernelDeriv x y u| ≤ 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le hreg_u le_rfl
  have henv_nn : 0 ≤ C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hk (abs_nonneg _) henv_nn

/-- 🌟🌟🌟 **PROVED — EXPLICIT `|J|` BOUND from the majorant primitive.**

Under `T` in the adaptive regime + log envelope on `S` from `T` onward
+ derivative-side integral convergence, the limit `J` satisfies

  `|J| ≤ −derivativeSideMajorantPrimitive y C D T`.

This is the explicit closed-form bound needed by the §13 / §CXC
slab-chain (which currently consumes `closedFormSErrorBoundCD`-style
quantities). Combines the finite-window absolute comparison with
`le_of_tendsto_of_tendsto'` at the `X → ∞` limit. -/
theorem derivative_integral_limit_abs_le_majorant_tail
    {S : ℝ → ℝ} {C D x y T J : ℝ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 ≤ C) (hD : 0 ≤ D)
    (hreg : 2 * (1 + |x| + y) ≤ T)
    (hS_T : ∀ u, T ≤ u → |S u| ≤ C * Real.log u + D)
    (hInt : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hJ : Tendsto (fun X => derivativeSidePartial S x y T X)
            Filter.atTop (𝓝 J)) :
    |J| ≤ -derivativeSideMajorantPrimitive y C D T := by
  -- absolute limit
  have h_abs_J : Tendsto
      (fun X => |derivativeSidePartial S x y T X|) Filter.atTop (𝓝 |J|) :=
    hJ.abs
  -- explicit majorant limit
  have h_M_lim : Tendsto
      (fun X => ∫ u in T..X, derivativeSideMajorant y C D u) Filter.atTop
      (𝓝 (-derivativeSideMajorantPrimitive y C D T)) :=
    derivativeSideMajorant_integral_tendsto_atTop x y T C D hT
  -- eventually pointwise bound
  have h_eventually : ∀ᶠ X in Filter.atTop,
      |derivativeSidePartial S x y T X|
        ≤ ∫ u in T..X, derivativeSideMajorant y C D u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact derivativeSidePartial_abs_le_majorant_partial
      C D x y T X hy hT hC hD hreg hS_T (hInt X hTX) hTX
  -- combine via le_of_tendsto_of_tendsto (∀ᶠ form, no prime)
  exact le_of_tendsto_of_tendsto h_abs_J h_M_lim h_eventually

-- =====================================================================
-- §CCXI. Real tail adapter (parallel to §CLXXXV dummy; no deletion)
-- =====================================================================
-- Combines the §CCVIII eventual improper IBP record with the §CCX
-- explicit `|J|` bound and the §CCIX tail-bound bridge into a single
-- theorem producing an `ImaginaryStieltjesTailIBPBound` directly from
-- ordered-tail data + log envelope + regularity. This is the
-- *real* tail-model adapter; it sits parallel to §CLXXXV's dummy path
-- (`linearDensityTail100`) without replacing it yet.

/-- 🌟🌟🌟🌟 **PROVED — REAL TAIL MODEL ADAPTER**:
end-to-end constructor producing an `ImaginaryStieltjesTailIBPBound`
from local ordered-tail / log-envelope / adaptive-regime data.

Hypotheses:
* `OrderedTailWindowData D T m` — window-invariant zero data;
* `0 < T`, `0 < y`, `0 ≤ C`, `0 ≤ Dconst`;
* `2 (1 + |x| + y) ≤ T` — adaptive-regime threshold;
* `hS_T` — log envelope `|ffP D T u| ≤ C·log u + Dconst` on `[T, ∞)`;
* `hInt` — finite-window integrability of `ffP · k'` on `[T, X]`;
* `hBbound` — chosen `B : ℝ → ℝ` dominating `|ffP|` on `[T, ∞)`;
* `hmargin` — the IBP-margin inequality
   `|k(T)|·B(T) + (−P(T)) ≤ modelMargin`
  (the user-controlled "model margin" obligation).

Output: an `ImaginaryStieltjesTailIBPBound` with
`integralBound := −derivativeSideMajorantPrimitive y C Dconst T`. -/
noncomputable def imaginaryTailIBPBound_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : ℝ) (B : ℝ → ℝ)
    (modelMargin : ℝ) {m : ℕ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 ≤ C) (hD : 0 ≤ Dconst)
    (_hregime : 2 * (1 + |x| + y) ≤ T)
    (hS_T : ∀ u, T ≤ u →
      |finiteFluctuationPrimitive D T u| ≤ C * Real.log u + Dconst)
    (hInt : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hBbound : ∀ u, T ≤ u → |finiteFluctuationPrimitive D T u| ≤ B u)
    (hmargin :
      |pairedCauchyImKernel x y T| * B T
        + (-derivativeSideMajorantPrimitive y C Dconst T) ≤ modelMargin) :
    ImaginaryStieltjesTailIBPBound :=
  -- Derive the eventually form from the strong form
  let hS : ∀ᶠ X in Filter.atTop,
      |finiteFluctuationPrimitive D T X| ≤ C * Real.log X + Dconst := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact hS_T X hTX
  -- Build the eventual improper IBP record
  let I := eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    D x y T C Dconst Wtail hT hy hC hD hS hInt
  -- Apply the §CCIX bridge with Jbound := -P(T)
  I.toImaginaryTailIBPBound B hBbound
    (-derivativeSideMajorantPrimitive y C Dconst T)
    modelMargin hmargin

/-- ⭐ **PROVED — the `|J|` bound the adapter relies on.**
The `derivative_integral_limit_abs_le_majorant_tail` theorem applied
to the finite-fluctuation primitive: under the adapter's hypotheses,

  `|J| ≤ −derivativeSideMajorantPrimitive y C Dconst T`

where `J` is the derivative-side improper integral's limit.

This is the *honesty witness* that `integralBound := −P(T)` in the
adapter above is a valid bound on the actual `J`. (The adapter itself
doesn't enforce this — it just packages the data — but having this
theorem ensures the user-supplied `hmargin` is a real margin.) -/
theorem imaginaryTailIBPBound_jBound_is_valid
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : ℝ)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 ≤ C) (hD : 0 ≤ Dconst)
    (hregime : 2 * (1 + |x| + y) ≤ T)
    (hS_T : ∀ u, T ≤ u →
      |finiteFluctuationPrimitive D T u| ≤ C * Real.log u + Dconst)
    (hInt : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    {J : ℝ}
    (hJ : Tendsto (fun X => derivativeSidePartial
                              (fun u => finiteFluctuationPrimitive D T u)
                              x y T X)
            Filter.atTop (𝓝 J)) :
    |J| ≤ -derivativeSideMajorantPrimitive y C Dconst T :=
  derivative_integral_limit_abs_le_majorant_tail
    (S := fun u => finiteFluctuationPrimitive D T u)
    (C := C) (D := Dconst) (x := x) (y := y) (T := T)
    hy hT hC hD hregime hS_T hInt hJ

end Phase1IBP

-- =====================================================================
-- §CCXII. Real-tail bridge to the dummy chain (no deletion)
-- =====================================================================
-- Bridges the real IBP majorant bound `-P(T)` to the existing
-- `closedFormErrorControlledOnFiniteBand` predicate that the §CLXXXV
-- dummy chain consumes. Key algebraic fact:
--   `-P(T) ≤ closedFormSErrorBoundCD C D y T`   when `0 ≤ C, D, y`, `T ≥ 1`.
-- Both `-P` and `closedFormSErrorBoundCD` scale as `y/T²` with similar
-- `(log T)` and constant coefficients; the `closedForm` coefficients are
-- uniformly larger (`17C` vs `9C`, `17D` vs `9D`, same `9C/2`). Difference
-- equals `8y(C·log T + D)/T² ≥ 0`.

/-- 🌟 **PROVED — KEY ALGEBRAIC BOUND**:
  `-derivativeSideMajorantPrimitive y C D T  ≤  closedFormSErrorBoundCD C D y T`
when `0 ≤ C, D, y` and `T ≥ 1`. The difference is `8y(C·log T + D)/T²`. -/
lemma neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
    (C D y T : ℝ) (hC : 0 ≤ C) (hD : 0 ≤ D) (hT_ge_1 : 1 ≤ T) (hy : 0 ≤ y) :
    -Phase1IBP.derivativeSideMajorantPrimitive y C D T
      ≤ closedFormSErrorBoundCD C D y T := by
  have hT_pos : 0 < T := lt_of_lt_of_le zero_lt_one hT_ge_1
  have hT2_pos : 0 < T^2 := by positivity
  have hT2_ne : T^2 ≠ 0 := ne_of_gt hT2_pos
  have hlog_T : 0 ≤ Real.log T := Real.log_nonneg hT_ge_1
  have h_diff :
      closedFormSErrorBoundCD C D y T
        - (-Phase1IBP.derivativeSideMajorantPrimitive y C D T)
        = 8 * y * (C * Real.log T + D) / T^2 := by
    unfold Phase1IBP.derivativeSideMajorantPrimitive closedFormSErrorBoundCD
    field_simp
    ring
  have h_diff_nn : 0 ≤ 8 * y * (C * Real.log T + D) / T^2 := by
    apply div_nonneg _ hT2_pos.le
    have h1 : 0 ≤ C * Real.log T := mul_nonneg hC hlog_T
    have h2 : 0 ≤ C * Real.log T + D := by linarith
    have h3 : 0 ≤ 8 * y := by linarith
    exact mul_nonneg h3 h2
  linarith

/-- 🌟🌟 **PROVED — discharge `closedFormErrorControlledOnFiniteBand`
from a pointwise majorant-primitive bound on `Im(error z)`.**

Given `|Im(error z)| ≤ -P(z.im, (slabCD T).1, (slabCD T).2, T)` on the
`[10, 140]` adaptive region, the
`closedFormErrorControlledOnFiniteBand` predicate holds. Bridges real
IBP bounds into the existing dummy-chain infrastructure. -/
theorem closedFormErrorControlled_of_majorantPrimitive_bound
    (error : ℂ → ℂ)
    (hbound : ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
              2 * (1 + |z.re| + z.im) ≤ T →
              |(error z).im| ≤
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    closedFormErrorControlledOnFiniteBand error := by
  intro z T hT10 hT140 hy hreg
  have h_input := hbound hT10 hT140 hy hreg
  have hC_nn : 0 ≤ (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD_nn : 0 ≤ (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hT_ge_1 : 1 ≤ T := by linarith
  have hy_nn : 0 ≤ z.im := le_of_lt hy
  have h_alg :
      -Phase1IBP.derivativeSideMajorantPrimitive z.im
          (slabCD T).1 (slabCD T).2 T
        ≤ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T :=
    neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
      (slabCD T).1 (slabCD T).2 z.im T hC_nn hD_nn hT_ge_1 hy_nn
  linarith

/-- 🌟🌟 **PROVED — DUMMY-SPECIALIZED real-tail wrapper.**
Specializes the §CCXIII model-parametric
`localXiPackage_10_140_from_majorantBound` (below) to
`xiCloudDensityModel_zeros100ceil`. Preserved for backward
compatibility with the existing dummy chain — prefer the
model-parametric version for new code. -/
noncomputable def localXiPackage_10_140_from_majorantBound_zeros100ceil
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (hbound : ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
              2 * (1 + |z.re| + z.im) ≤ T →
              |(error z).im| ≤
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_10_140_zeros100ceil error hdecomp
    (closedFormErrorControlled_of_majorantPrimitive_bound error hbound)

-- =====================================================================
-- §CCXIII. Model-parametric local package + ActualDensityTailData
-- =====================================================================
-- The previous §CCXII `localXiPackage_10_140_from_majorantBound`
-- (now `..._zeros100ceil`) hardcoded the dummy
-- `xiCloudDensityModel_zeros100ceil`. This section breaks that
-- coupling at the local-package layer:
--   • New `localXiPackage_10_140_from_majorantBound` is model-parametric:
--     it takes any `M : CloudDensityTailModelDecomposition`
--     (with `M.zeros = zeros100ceil` and `AntiHerglotzUHP M.model`).
--   • Routes through the already-model-parametric
--     `localPackage_10_140_of_slabCD` (§CLXXXV, ~line 14159) — the
--     existing infrastructure was already parametric; the §CCXII
--     wrapper merely specialized it to the dummy.
--   • `ActualDensityTailData` provides the insertion point for the
--     forthcoming real complex-valued density tail
--     `∫ pairedCauchyKernel u z · ρ(u) du`. The complex integral
--     itself is a separate task — this structure just provides
--     the seat.
--
-- The dummy chain remains intact (no deletion). Any future real-tail
-- model `M_real` with the same finite-band predicate gives a package
-- without re-doing the IBP work.

/-- 🌟🌟🌟 **PROVED — MODEL-PARAMETRIC `LocalXiCloudDensityErrorPackage`
from a real majorant-primitive bound.**

Takes any `M : CloudDensityTailModelDecomposition` (with the standard
zeros-list compatibility + anti-Herglotz model), an IBP residual
`error`, the log-derivative decomposition `XiPullback = M.model + error`
on the `[10, 140]` adaptive region, and the majorant-primitive bound on
`|Im(error z)|`. Produces a `LocalXiCloudDensityErrorPackage`.

The dummy `xiCloudDensityModel_zeros100ceil` is no longer baked in;
any model satisfying the structural fields works. Routes through
`closedFormErrorControlled_of_majorantPrimitive_bound` + the existing
model-parametric `localPackage_10_140_of_slabCD`. -/
noncomputable def localXiPackage_10_140_from_majorantBound
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hbound : ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
              2 * (1 + |z.re| + z.im) ≤ T →
              |(error z).im| ≤
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_10_140_of_slabCD M hM_zeros hmodelAnti error hdecomp
    (closedFormErrorControlled_of_majorantPrimitive_bound error hbound)

/-- 📦 **`ActualDensityTailData`** — future insertion point for the real
complex-valued density tail.

Packages everything `localXiPackage_10_140_from_majorantBound` needs:
the model `M` (with `zeros100ceil` + anti-Herglotz model), the IBP
residual `error`, the log-derivative decomposition, and the
majorant-primitive `|Im(error z)|` bound.

**Status:** abstract field-style structure. The real complex tail
integral
  `densityTail(z) = ∫ u in T..∞, pairedCauchyKernel u z dS(u)`
is *not* constructed here — that requires complex-valued improper
integrals, real/imag-extraction commuting with limits, and the
complex kernel ↔ `pairedCauchyImKernel` identity (separate task).
Once that lands, an inhabitant of this structure provides the
real-tail-instantiated `LocalXiCloudDensityErrorPackage` via
`localXiPackage_of_actualTailData` below. -/
structure ActualDensityTailData where
  /-- The density-tail model (eventually the real complex tail
  integral; for now any compatible `CloudDensityTailModelDecomposition`,
  including the dummy). -/
  M            : CloudDensityTailModelDecomposition
  /-- Compatibility with the `zeros100ceil` finite-band setup. -/
  hM_zeros     : M.zeros = zeros100ceil
  /-- Anti-Herglotz model (upper-half-plane sign law). -/
  hmodelAnti   : AntiHerglotzUHP M.model
  /-- IBP residual error: `XiPullback = M.model + error` on `[10,140]`. -/
  error        : ℂ → ℂ
  /-- The log-derivative decomposition on the adaptive `[10,140]` region. -/
  hdecomp      :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
      logDerivativeResponse XiPullback z = M.model z + error z
  /-- Majorant-primitive control on `|Im(error z)|`. -/
  hbound       :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T

/-- 🌟 **PROVED — `LocalXiCloudDensityErrorPackage` from
`ActualDensityTailData`.** Convenience constructor: unpacks the
five fields and applies the §CCXIII model-parametric local-package
theorem. -/
noncomputable def localXiPackage_of_actualTailData
    (A : ActualDensityTailData) : LocalXiCloudDensityErrorPackage :=
  localXiPackage_10_140_from_majorantBound
    A.M A.hM_zeros A.hmodelAnti A.error A.hdecomp A.hbound

/-- ⭐ **PROVED — `ActualDensityTailData` is inhabited by the dummy
model.** Until the real complex tail integral lands, the existing
`xiCloudDensityModel_zeros100ceil` can be wrapped as an
`ActualDensityTailData` given the same `(error, hdecomp, hbound)`
data the §CCXII path used. Documents that the structure is honest:
it doesn't *require* the real integral, just provides a seat for it. -/
noncomputable def actualDensityTailData_zeros100ceil
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (hbound : ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
              2 * (1 + |z.re| + z.im) ≤ T →
              |(error z).im| ≤
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    ActualDensityTailData where
  M           := xiCloudDensityModel_zeros100ceil
  hM_zeros    := xiCloudDensityModel_zeros100ceil_zeros
  hmodelAnti  := xiCloudDensityModel_zeros100ceil_modelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound

-- =====================================================================
-- §CCXIV. Complex tail decomposition scaffold
-- =====================================================================
-- Mirrors the real `derivativeSidePartial` strategy from §CCII: define
-- finite-X partial integrals for a complex-valued density-tail kernel,
-- a convergence package, and the real/imag bridge. Does NOT prove the
-- actual paired-Cauchy convergence — that's the next step. The point
-- here is to lay down the abstract interface so the eventual real-tail
-- construction has a clear target:
--
--   complexDensityTailPartial               — finite [T,X] complex integral
--   ComplexDensityTailImproperConverges     — convergence package
--   complexTail_im_tendsto_of_partial_im    — generic ℂ → ℝ bridge
--   complexDensityTailPartial_im_tendsto    — specialization
--   ActualDensityTailData.ofComplexConvergence — bundling adapter
--
-- The convergence package does NOT automatically discharge `hdecomp`
-- or `hbound` (those depend on what the kernel / S actually are);
-- the constructor just provides a structured entry point ready for
-- the eventual paired-Cauchy kernel instantiation.

/-- **Complex-tail finite partial integral.** Complex analogue of the
real `Phase1IBP.derivativeSidePartial` from §CCII: a finite-window
`[T, X]` integral of a complex-valued kernel multiplied by a
real-valued density primitive `S`, evaluated at the complex point
`z`. Returns `ℂ`. -/
noncomputable def complexDensityTailPartial
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ) (T X : ℝ) (z : ℂ) : ℂ :=
  ∫ u in T..X, kernel u z * (S u : ℂ)

/-- **Convergence package for the complex tail integral.** Bundles a
candidate complex-valued `tail` together with pointwise convergence
of the finite partials at every `z`. Analogous to the real
`ImproperIntervalIntegralConverges` from §CCII. -/
structure ComplexDensityTailImproperConverges
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ) (T : ℝ) where
  /-- The candidate tail value at each `z`. -/
  tail     : ℂ → ℂ
  /-- The finite partials converge to `tail z` as `X → ∞`. -/
  tendsto  : ∀ z : ℂ,
    Tendsto
      (fun X : ℝ => complexDensityTailPartial kernel S T X z)
      Filter.atTop (𝓝 (tail z))

/-- 🌟 **PROVED — generic real/imag bridge for `ℂ`-valued `Tendsto`.**
If `F X → L` in `ℂ`, then `(F X).im → L.im` in `ℝ`. This is the
first genuinely necessary bridge from complex tail to the real IBP
machinery — `Complex.im` is continuous, hence commutes with limits. -/
lemma complexTail_im_tendsto_of_partial_im
    {F : ℝ → ℂ} {L : ℂ}
    (h : Tendsto F Filter.atTop (𝓝 L)) :
    Tendsto (fun X => (F X).im) Filter.atTop (𝓝 L.im) :=
  (Complex.continuous_im.tendsto L).comp h

/-- 🌟 **PROVED — specialization to the complex tail partial.** The
imaginary parts of the complex tail partials converge to the
imaginary part of the candidate tail at each `z`. This is what
ultimately feeds the IBP-derived `|Im error| ≤ -P(T)` bound: the
RHS of the bound lives on the real side, so the LHS (which comes
from the complex integral) must first be projected via `.im`. -/
lemma complexDensityTailPartial_im_tendsto
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ} {T : ℝ}
    (conv : ComplexDensityTailImproperConverges kernel S T) (z : ℂ) :
    Tendsto
      (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (𝓝 (conv.tail z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto z)

/-- 🌟🌟 **PROVED — `ActualDensityTailData` from a complex-tail
convergence package.**

Given a `ComplexDensityTailImproperConverges` providing the candidate
`tail`, a `CloudDensityTailModelDecomposition M` (with the standard
`zeros100ceil` + anti-Herglotz structural fields), and the IBP error
data (`error`, `hdecomp`, `hbound`), produces an `ActualDensityTailData`.

This is the second "seat" — closer to the real target than
`actualDensityTailData_zeros100ceil`, because it explicitly carries
the complex-tail convergence witness. The convergence package does
not yet discharge `hdecomp` or `hbound` — those remain user-supplied
until the IBP chain is wired to the specific paired-Cauchy kernel
(separate task). -/
noncomputable def ActualDensityTailData.ofComplexConvergence
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ} {T0 : ℝ}
    (_conv : ComplexDensityTailImproperConverges kernel S T0)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hbound : ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
              2 * (1 + |z.re| + z.im) ≤ T →
              |(error z).im| ≤
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound

-- =====================================================================
-- §CCXV. T-family complex tail bridge: Im(complex tail) ↔ real IBP
-- =====================================================================
-- §CCXIV's `ActualDensityTailData.ofComplexConvergence` kept the
-- convergence witness inert (`_conv`). This section turns it into a
-- machine that actually produces the `hbound` field once a real-kernel
-- identity is supplied:
--
--   upperHalfPoint, upperHalfPoint_re_im        — z = x + I·y helper
--   ComplexDensityTailFamilyConverges           — T-family convergence
--   complexDensityTailFamilyPartial_im_tendsto  — Im commutes with limit
--   ComplexTailImaginaryPartMatchesRealIBP      — eventual Im identity
--   complexTail_im_bound_from_realIBP           — pointwise bound theorem
--   ComplexTailIBPBoundData                     — z-indexed wrapper
--   hbound_of_complexTailIBPBoundData           — produces hbound field
--
-- Design note: §CCXIV's `ComplexDensityTailImproperConverges` fixed
-- one cutoff `T`. The `hbound` field quantifies over the adaptive
-- slab parameter `T`, so we add a T-family version alongside the
-- fixed-T one (which is preserved as the simpler special case).
-- The IBP bound here is delivered modulo the kernel-specific
-- imaginary-part identity, which still needs to be proven once the
-- specific `pairedCauchyKernel` is wired in (separate task).

/-- **`upperHalfPoint x y`** — convenience for the complex number
`x + I·y`, used as a uniform encoding so that the bridge theorems can
quantify cleanly over real coordinates `(x, y)` while landing in `ℂ`. -/
noncomputable def upperHalfPoint (x y : ℝ) : ℂ :=
  (x : ℂ) + Complex.I * (y : ℂ)

/-- ⭐ **PROVED — `upperHalfPoint` recovers any complex number from
its components.** Lets the bridge theorems written in `(x, y)`-form
specialize directly to a complex `z` via `z.re, z.im`. -/
lemma upperHalfPoint_re_im (z : ℂ) : upperHalfPoint z.re z.im = z := by
  unfold upperHalfPoint
  apply Complex.ext <;> simp

/-- **T-family convergence package for the complex tail integral.**
Generalizes §CCXIV's `ComplexDensityTailImproperConverges` from one
fixed lower cutoff `T` to a family indexed by `T : ℝ`. Required for
the adaptive `[10, 140]` band where `T` varies with `z`. -/
structure ComplexDensityTailFamilyConverges
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ) where
  /-- The candidate tail value at cutoff `T` and point `z`. -/
  tail     : ℝ → ℂ → ℂ
  /-- The finite partials over `[T, X]` converge to `tail T z` as `X → ∞`,
  for every cutoff `T` and every point `z`. -/
  tendsto  : ∀ T : ℝ, ∀ z : ℂ,
    Tendsto
      (fun X : ℝ => complexDensityTailPartial kernel S T X z)
      Filter.atTop (𝓝 (tail T z))

/-- 🌟 **PROVED — T-family specialization of `complexTail_im_tendsto`.**
For each `T` and `z`, the imaginary parts of the complex tail partials
converge to `(conv.tail T z).im`. -/
lemma complexDensityTailFamilyPartial_im_tendsto
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ}
    (conv : ComplexDensityTailFamilyConverges kernel S) (T : ℝ) (z : ℂ) :
    Tendsto
      (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (𝓝 (conv.tail T z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto T z)

/-- **`ComplexTailImaginaryPartMatchesRealIBP`** — eventual identity
between the imaginary part of the complex tail partial and the real
derivative-side partial. This is the kernel-specific obligation: once
the actual `pairedCauchyKernel` is plugged in, this identity should
follow from `Complex.im (a * b) = ...` plus the real definition of
`derivativeSidePartial` (a separate task). -/
structure ComplexTailImaginaryPartMatchesRealIBP
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ) (x y T : ℝ) : Prop where
  finite_im_eq :
    ∀ᶠ X in Filter.atTop,
      (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im
        = Phase1IBP.derivativeSidePartial S x y T X

/-- 🌟🌟 **PROVED — pointwise complex-tail Im bound from real IBP.**
Given a T-family complex convergence package, the kernel-specific
imaginary-part identity for finite partials, a convergence witness for
the real derivative-side partial, and the real `|J| ≤ -P(T)` bound from
the IBP machinery, concludes:

  `|(conv.tail T (upperHalfPoint x y)).im| ≤ -P(y, C, D, T)`.

Proof: `Im` commutes with limit; the finite identity transports the
real `Tendsto` to the complex Im `Tendsto`; uniqueness of limits
identifies the two limits; the real bound transfers. -/
theorem complexTail_im_bound_from_realIBP
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ}
    {x y T C D J : ℝ}
    (conv : ComplexDensityTailFamilyConverges kernel S)
    (hmatch : ComplexTailImaginaryPartMatchesRealIBP kernel S x y T)
    (hJ :
      Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S x y T X)
        Filter.atTop (𝓝 J))
    (hJbound : |J| ≤ -Phase1IBP.derivativeSideMajorantPrimitive y C D T) :
    |(conv.tail T (upperHalfPoint x y)).im|
      ≤ -Phase1IBP.derivativeSideMajorantPrimitive y C D T := by
  -- Im of complex partial tends to Im of tail
  have him_tail :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im)
        Filter.atTop
        (𝓝 (conv.tail T (upperHalfPoint x y)).im) :=
    complexDensityTailFamilyPartial_im_tendsto conv T (upperHalfPoint x y)
  -- Transport real Tendsto to complex Im via finite identity
  have him_real :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial kernel S T X (upperHalfPoint x y)).im)
        Filter.atTop (𝓝 J) := by
    apply Tendsto.congr' _ hJ
    filter_upwards [hmatch.finite_im_eq] with X heq
    exact heq.symm
  -- Limits agree → tail.im = J
  have huniq : (conv.tail T (upperHalfPoint x y)).im = J :=
    tendsto_nhds_unique him_tail him_real
  rw [huniq]
  exact hJbound

/-- **`ComplexTailIBPBoundData`** — z-indexed wrapper supplying all
ingredients needed to produce the `hbound` field of `ActualDensityTailData`
from a T-family complex convergence package.

Fields:
* `error_im_eq_tail_im` — in the adaptive band, the residual error's
  imaginary part equals the imaginary part of the tail at the
  corresponding adaptive `T` (kernel/error consistency obligation);
* `finite_im_match` — for each `(z, T)` in the band, the eventual
  finite Im identity (kernel-specific obligation);
* `derivative_tendsto` — for each `(z, T)` in the band, the real
  derivative-side partial converges (discharged by the §CCVI/CCVII
  IBP machinery once instantiated);
* `derivative_bound` — for each such limit, `|J| ≤ -P(...)`
  (discharged by §CCIX/CCX).

All four fields are propositional; the structure itself is a `Prop`. -/
structure ComplexTailIBPBoundData
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ)
    (conv : ComplexDensityTailFamilyConverges kernel S)
    (error : ℂ → ℂ) : Prop where
  error_im_eq_tail_im :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im = (conv.tail T z).im
  finite_im_match :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ComplexTailImaginaryPartMatchesRealIBP kernel S z.re z.im T
  derivative_tendsto :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ J : ℝ, Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (𝓝 J)
  derivative_bound :
    ∀ {z : ℂ} {T : ℝ} {J : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (𝓝 J) →
      |J| ≤ -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- 🌟🌟🌟 **PROVED — `hbound` field of `ActualDensityTailData` from a
`ComplexTailIBPBoundData`.** The end-to-end T-family bridge: a complex
convergence package, an Im-matching identity, real derivative-side
convergence, and the real IBP bound combine to produce the
`|(error z).im| ≤ -P(z.im, (slabCD T).1, (slabCD T).2, T)` predicate
that the local-package layer consumes. -/
theorem hbound_of_complexTailIBPBoundData
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ}
    {conv : ComplexDensityTailFamilyConverges kernel S}
    {error : ℂ → ℂ}
    (B : ComplexTailIBPBoundData kernel S conv error) :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain ⟨J, hJ⟩ := B.derivative_tendsto h10 h140 hy hregime
  have htail_bound :=
    complexTail_im_bound_from_realIBP
      (C := (slabCD T).1) (D := (slabCD T).2)
      conv
      (B.finite_im_match h10 h140 hy hregime)
      hJ
      (B.derivative_bound h10 h140 hy hregime hJ)
  -- Bridge: upperHalfPoint z.re z.im = z
  rw [upperHalfPoint_re_im z] at htail_bound
  rw [B.error_im_eq_tail_im h10 h140 hy hregime]
  exact htail_bound

-- =====================================================================
-- §CCXVI. Paired complex kernel and finite-X Im identity
-- =====================================================================
-- Discharges the kernel-specific obligation
-- `ComplexTailImaginaryPartMatchesRealIBP` from §CCXV for a concrete
-- complex kernel — the "wrapper" kernel
--   `kernel u z := (pairedCauchyImKernelDeriv z.re z.im u : ℂ) * I`
-- whose imaginary part at `(upperHalfPoint x y)` is exactly the real
-- `pairedCauchyImKernelDeriv x y u`. Proves:
--
--   pairedCauchyComplexKernelDeriv               — wrapper kernel
--   pairedCauchyComplexKernelDeriv_im            — pointwise Im of kernel
--   pairedComplexKernelDeriv_integrand_im        — pointwise Im of kernel · S
--   complexDensityTailPartial_im_eq_derivativeSidePartial
--   complexTailImaginaryPartMatchesRealIBP_pairedDeriv
--
-- Design note: this is the "wrapper" kernel, not the true analytic
-- rational complex kernel. We prove the bridge through the interface
-- here; the next step (separate task) is to replace the wrapper with
-- the actual rational complex kernel and prove the corresponding
-- `_im` lemma — the bridge above will then carry over unchanged.

/-- **Complex paired-Cauchy kernel derivative (wrapper).**
For now, the lift `realKernel x y u · I`. Its imaginary part at
`upperHalfPoint x y` is exactly `pairedCauchyImKernelDeriv x y u`,
which is what the §CCXV bridge requires. To be replaced by the true
rational complex kernel once that lands; the bridge theorems below
will keep working as long as the `_im` lemma still holds. -/
noncomputable def pairedCauchyComplexKernelDeriv (u : ℝ) (z : ℂ) : ℂ :=
  (pairedCauchyImKernelDeriv z.re z.im u : ℂ) * Complex.I

/-- ⭐ **PROVED — pointwise Im of the wrapper kernel at `upperHalfPoint`.** -/
lemma pairedCauchyComplexKernelDeriv_im (u x y : ℝ) :
    (pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)).im
      = pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  simp

/-- ⭐ **PROVED — pointwise Im of `kernel · (S : ℂ)`.** The integrand
of the complex partial, evaluated pointwise — its imaginary part is
the real integrand `S u · pairedCauchyImKernelDeriv x y u`. -/
lemma pairedComplexKernelDeriv_integrand_im (S : ℝ → ℝ) (u x y : ℝ) :
    (pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ)).im
      = S u * pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  simp [Complex.mul_im, Complex.mul_re]
  ring

/-- 🌟🌟 **PROVED — finite-X Im identity for the complex partial.**
For the wrapper kernel, the imaginary part of the complex partial
integral equals the real `derivativeSidePartial`:

  `Im (∫ u in T..X, kernel u (UHP) · (S u : ℂ))
      = ∫ u in T..X, S u · pairedCauchyImKernelDeriv x y u`.

Proof skeleton:
1. Pointwise: integrand = `((S u · realKernel : ℝ) : ℂ) · I`.
2. Pull `I` out via `intervalIntegral.integral_mul_const`.
3. Pull `ofReal` out via `intervalIntegral.integral_ofReal`.
4. `(((r : ℝ) : ℂ) · I).im = r` closes by `simp`. -/
lemma complexDensityTailPartial_im_eq_derivativeSidePartial
    (S : ℝ → ℝ) (x y T X : ℝ) :
    (complexDensityTailPartial
        pairedCauchyComplexKernelDeriv S T X (upperHalfPoint x y)).im
      = Phase1IBP.derivativeSidePartial S x y T X := by
  unfold complexDensityTailPartial Phase1IBP.derivativeSidePartial
  -- Step 1: pointwise simplification of integrand
  have hpoint : ∀ u : ℝ,
      pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ)
        = ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ)
          * Complex.I := by
    intro u
    unfold pairedCauchyComplexKernelDeriv
    have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
    have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
    rw [h1, h2]
    push_cast
    ring
  -- Step 2: rewrite the interval integral via pointwise equality
  have hint :
      (∫ u in T..X,
          pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ))
        = ∫ u in T..X,
            ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ)
              * Complex.I :=
    intervalIntegral.integral_congr (fun u _ => hpoint u)
  rw [hint]
  -- Step 3: pull `I` out via `integral_mul_const`
  rw [intervalIntegral.integral_mul_const]
  -- Step 4: pull `ofReal` out via `integral_ofReal`
  rw [intervalIntegral.integral_ofReal]
  -- Step 5: `(((r : ℝ) : ℂ) · I).im = r`
  simp

/-- 🌟🌟🌟 **PROVED — `ComplexTailImaginaryPartMatchesRealIBP` for the
wrapper paired-Cauchy kernel.** Discharges the §CCXV abstract
obligation for this concrete kernel: the eventual finite-X Im identity
holds (in fact, it holds for *all* X, not just eventually). -/
theorem complexTailImaginaryPartMatchesRealIBP_pairedDeriv
    (S : ℝ → ℝ) (x y T : ℝ) :
    ComplexTailImaginaryPartMatchesRealIBP
      pairedCauchyComplexKernelDeriv S x y T :=
  ⟨Filter.Eventually.of_forall fun X =>
    complexDensityTailPartial_im_eq_derivativeSidePartial S x y T X⟩

-- =====================================================================
-- §CCXVII. Wrapper-kernel adaptive complex convergence
-- =====================================================================
-- Builds the first concrete realization of the §CCXV / §CCXVI bridge:
-- given a packaged real-IBP family (real derivative-side convergence
-- + bound for every (z, T) in the adaptive band), produces an
-- adaptive-region complex convergence package for the wrapper kernel
-- of §CCXVI. Adds:
--
--   RealIBPFamilyData                          — Prop bundle of real IBP data
--   AdaptiveComplexDensityTailFamilyConverges  — adaptive Type structure
--   pairedDerivAdaptiveTail                    — wrapper tail (I · J)
--   complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
--                                              — full complex partial identity
--   adaptiveComplexConverges_pairedDeriv_of_realIBP
--
-- The wrapper kernel's complex integrand factors as `I · (real : ℂ)`,
-- so the complex partial is `I · (real partial : ℂ)`, so the limit at
-- ∞ exists with value `I · (J : ℂ)` whenever the real limit `J` exists.
-- §CCXVIII will complete the wiring to `ComplexTailIBPBoundData`.

/-- **`RealIBPFamilyData S`** — Prop bundle: for every `(z, T)` in the
adaptive band, the real derivative-side partial converges and the
limit satisfies the IBP majorant bound. Discharged by the §CCVI/CCVII
+ §CCIX/CCX machinery once instantiated for a specific `S`. -/
structure RealIBPFamilyData (S : ℝ → ℝ) : Prop where
  deriv_tendsto :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ J : ℝ,
        Tendsto
          (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          Filter.atTop (𝓝 J)
  deriv_bound :
    ∀ {z : ℂ} {T : ℝ} {J : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (𝓝 J) →
      |J| ≤ -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- **Adaptive-region complex tail family convergence.** Like §CCXV's
`ComplexDensityTailFamilyConverges` but only required to converge on
the adaptive `[10, 140]` band (matches the `hbound` quantifier shape).
The global version is preserved; this adds an adaptive variant. -/
structure AdaptiveComplexDensityTailFamilyConverges
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ) where
  tail     : ℝ → ℂ → ℂ
  tendsto  :
    ∀ {T : ℝ} {z : ℂ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      Tendsto
        (fun X : ℝ => complexDensityTailPartial kernel S T X z)
        Filter.atTop (𝓝 (tail T z))

/-- **Wrapper-kernel adaptive tail.** Inside the adaptive band, the
wrapper kernel's complex partial converges to `I · (J : ℂ)` where `J`
is the real-side IBP limit. Outside the band, defined as `0` for
totality (irrelevant for the bridge). -/
noncomputable def pairedDerivAdaptiveTail
    (S : ℝ → ℝ) (R : RealIBPFamilyData S) (T : ℝ) (z : ℂ) : ℂ :=
  if h : 10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ T then
    Complex.I *
      ((Classical.choose (R.deriv_tendsto h.1 h.2.1 h.2.2.1 h.2.2.2) : ℝ) : ℂ)
  else
    0

/-- 🌟🌟 **PROVED — full complex partial identity for the wrapper
kernel.** The complex partial equals `I · (real partial : ℂ)` —
strengthens §CCXVI's `_im_eq_derivativeSidePartial` from imaginary
parts alone to the full complex value, which is what we need to
transfer convergence (not just convergence of Im). -/
lemma complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
    (S : ℝ → ℝ) (x y T X : ℝ) :
    complexDensityTailPartial pairedCauchyComplexKernelDeriv
      S T X (upperHalfPoint x y)
      = Complex.I * ((Phase1IBP.derivativeSidePartial S x y T X : ℝ) : ℂ) := by
  unfold complexDensityTailPartial Phase1IBP.derivativeSidePartial
  have hpoint : ∀ u,
      pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ)
        = Complex.I * ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ) := by
    intro u
    unfold pairedCauchyComplexKernelDeriv
    have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
    have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
    rw [h1, h2]
    push_cast
    ring
  rw [intervalIntegral.integral_congr (fun u _ => hpoint u)]
  rw [intervalIntegral.integral_const_mul]
  congr 1
  exact intervalIntegral.integral_ofReal

/-- 🌟🌟🌟 **PROVED — wrapper kernel adaptive complex convergence
from real IBP family data.** End-to-end: the §CCXVI wrapper kernel
combined with a real-IBP family witness produces an adaptive complex
convergence package. The tail is `pairedDerivAdaptiveTail`; the
convergence proof routes the real `Tendsto` through `ofReal` and
multiplication by `I`, then bridges to the complex partial via the
`pairedDeriv_eq_I_mul_derivativeSidePartial` identity. -/
noncomputable def adaptiveComplexConverges_pairedDeriv_of_realIBP
    (S : ℝ → ℝ) (R : RealIBPFamilyData S) :
    AdaptiveComplexDensityTailFamilyConverges
      pairedCauchyComplexKernelDeriv S where
  tail := pairedDerivAdaptiveTail S R
  tendsto := by
    intro T z h10 h140 hy hregime
    -- Witness J from the real IBP family
    have hExists := R.deriv_tendsto h10 h140 hy hregime
    set J := Classical.choose hExists with hJdef
    have hReal :
        Tendsto
          (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          Filter.atTop (𝓝 J) :=
      Classical.choose_spec hExists
    -- Lift real → complex via ofReal
    have hOfReal :
        Tendsto
          (fun X : ℝ =>
            ((Phase1IBP.derivativeSidePartial S z.re z.im T X : ℝ) : ℂ))
          Filter.atTop (𝓝 ((J : ℝ) : ℂ)) :=
      (Complex.continuous_ofReal.tendsto J).comp hReal
    -- Multiply by I
    have hIComplex :
        Tendsto
          (fun X : ℝ =>
            Complex.I *
              ((Phase1IBP.derivativeSidePartial S z.re z.im T X : ℝ) : ℂ))
          Filter.atTop (𝓝 (Complex.I * ((J : ℝ) : ℂ))) :=
      tendsto_const_nhds.mul hOfReal
    -- Bridge complex partial to I · (real : ℂ) pointwise
    have hbridge : ∀ X : ℝ,
        complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X z
          = Complex.I *
              ((Phase1IBP.derivativeSidePartial S z.re z.im T X : ℝ) : ℂ) := by
      intro X
      conv_lhs => rw [← upperHalfPoint_re_im z]
      exact complexDensityTailPartial_pairedDeriv_eq_I_mul_derivativeSidePartial
        S z.re z.im T X
    -- Transfer Tendsto to the complex partial
    have hPartial :
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X z)
          Filter.atTop (𝓝 (Complex.I * ((J : ℝ) : ℂ))) :=
      hIComplex.congr (fun X => (hbridge X).symm)
    -- Identify the adaptive tail value with I · (J : ℂ)
    have hh : 10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
      ⟨h10, h140, hy, hregime⟩
    have htail_val :
        pairedDerivAdaptiveTail S R T z = Complex.I * ((J : ℝ) : ℂ) := by
      unfold pairedDerivAdaptiveTail
      rw [dif_pos hh]
    rw [htail_val]
    exact hPartial

-- =====================================================================
-- §CCXVIII. Adaptive bound data + wrapper-kernel ActualDensityTailData
-- =====================================================================
-- Closes the wiring loop: adaptive convergence (§CCXVII) plus the
-- finite-Im identity (§CCXVI) plus real IBP data give an
-- `AdaptiveComplexTailIBPBoundData`, which produces the `hbound`
-- field, which feeds `ActualDensityTailData`, which feeds the
-- `LocalXiCloudDensityErrorPackage` via the §CCXIII model-parametric
-- theorem. Adds:
--
--   AdaptiveComplexTailIBPBoundData                — adaptive Prop bundle
--   adaptiveComplexDensityTailFamilyPartial_im_tendsto
--   hbound_of_adaptiveComplexTailIBPBoundData      — produces hbound
--   adaptiveComplexTailIBPBoundData_pairedDeriv    — wrapper instantiation
--   actualDensityTailData_of_pairedDerivWrapper    — full ActualDensityTailData
--   localXiPackage_of_pairedDerivWrapper           — final local package
--
-- After this lands, the only remaining gap in the real-tail direction
-- is the mathematical identity `(error z).im = (pairedDerivAdaptiveTail
-- S R T z).im` (a property of the actual log-derivative decomposition),
-- and eventually the replacement of the wrapper kernel with the true
-- rational complex kernel.

/-- **Adaptive `ComplexTailIBPBoundData`.** Mirrors §CCXV's
`ComplexTailIBPBoundData` but consumes an adaptive convergence package
(`AdaptiveComplexDensityTailFamilyConverges`) — matches the §CCXVII
construction. -/
structure AdaptiveComplexTailIBPBoundData
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ)
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    (error : ℂ → ℂ) : Prop where
  error_im_eq_tail_im :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im = (conv.tail T z).im
  finite_im_match :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ComplexTailImaginaryPartMatchesRealIBP kernel S z.re z.im T
  derivative_tendsto :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ J : ℝ, Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (𝓝 J)
  derivative_bound :
    ∀ {z : ℂ} {T : ℝ} {J : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      Tendsto
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (𝓝 J) →
      |J| ≤ -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- ⭐ **PROVED — adaptive specialization of the Im-Tendsto lemma.**
For each adaptive `(T, z)`, the imaginary part of the complex partial
tends to the imaginary part of the adaptive tail. -/
lemma adaptiveComplexDensityTailFamilyPartial_im_tendsto
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ}
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    {T : ℝ} {z : ℂ}
    (h10 : 10 ≤ T) (h140 : T ≤ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T) :
    Tendsto
      (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im)
      Filter.atTop (𝓝 (conv.tail T z).im) :=
  complexTail_im_tendsto_of_partial_im (conv.tendsto h10 h140 hy hregime)

/-- 🌟🌟🌟 **PROVED — `hbound` field from `AdaptiveComplexTailIBPBoundData`.**
Adaptive analogue of §CCXV's `hbound_of_complexTailIBPBoundData`.
Combines the four `AdaptiveComplexTailIBPBoundData` fields into the
`|(error z).im| ≤ -P(...)` predicate that `ActualDensityTailData.hbound`
expects. -/
theorem hbound_of_adaptiveComplexTailIBPBoundData
    {kernel : ℝ → ℂ → ℂ} {S : ℝ → ℝ}
    {conv : AdaptiveComplexDensityTailFamilyConverges kernel S}
    {error : ℂ → ℂ}
    (B : AdaptiveComplexTailIBPBoundData kernel S conv error) :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain ⟨J, hJ⟩ := B.derivative_tendsto h10 h140 hy hregime
  -- Im of complex partial tends to Im of adaptive tail
  have htail_im :
      Tendsto
        (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im)
        Filter.atTop (𝓝 (conv.tail T z).im) :=
    adaptiveComplexDensityTailFamilyPartial_im_tendsto conv h10 h140 hy hregime
  -- Bridge the real Tendsto into Im-of-complex via finite_im_eq + UHP identity
  have hmatch :
      Tendsto
        (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im)
        Filter.atTop (𝓝 J) := by
    have hmatch_struct := B.finite_im_match h10 h140 hy hregime
    have heq :
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          =ᶠ[Filter.atTop]
        (fun X : ℝ => (complexDensityTailPartial kernel S T X z).im) := by
      filter_upwards [hmatch_struct.finite_im_eq] with X hX
      rw [upperHalfPoint_re_im z] at hX
      exact hX.symm
    exact Tendsto.congr' heq hJ
  -- Limits agree → tail.im = J
  have huniq : (conv.tail T z).im = J :=
    tendsto_nhds_unique htail_im hmatch
  -- Transfer to error.im, then apply derivative_bound
  rw [B.error_im_eq_tail_im h10 h140 hy hregime, huniq]
  exact B.derivative_bound h10 h140 hy hregime hJ

/-- 🌟🌟🌟 **PROVED — wrapper-kernel `AdaptiveComplexTailIBPBoundData`.**
Given real IBP family data `R` and an error-Im identity `herror`,
produces the adaptive bound data for the §CCXVI wrapper kernel via
the §CCXVII adaptive convergence package.

`herror` is the genuinely remaining mathematical input: it says the
residual error's imaginary part matches the wrapper adaptive tail's
imaginary part. Everything else is plumbing. -/
theorem adaptiveComplexTailIBPBoundData_pairedDeriv
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (error : ℂ → ℂ)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im = (pairedDerivAdaptiveTail S R T z).im) :
    AdaptiveComplexTailIBPBoundData
      pairedCauchyComplexKernelDeriv S
      (adaptiveComplexConverges_pairedDeriv_of_realIBP S R)
      error where
  error_im_eq_tail_im := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime
  finite_im_match := by
    intro z T h10 h140 hy hregime
    exact complexTailImaginaryPartMatchesRealIBP_pairedDeriv S z.re z.im T
  derivative_tendsto := by
    intro z T h10 h140 hy hregime
    exact R.deriv_tendsto h10 h140 hy hregime
  derivative_bound := by
    intro z T J h10 h140 hy hregime hJ
    exact R.deriv_bound h10 h140 hy hregime hJ

/-- 🌟🌟🌟🌟 **PROVED — full `ActualDensityTailData` from wrapper
real-IBP data.** End-to-end constructor: takes a real-IBP family `R`,
a model `M` with the standard structural fields, the IBP decomposition
`hdecomp`, and the error-Im identity `herror`. Produces an
`ActualDensityTailData`. All the §CCXIV–§CCXVIII plumbing collapses
into a single call site.

The only mathematical obligation beyond the §CC* IBP machinery is
`herror : (error z).im = (pairedDerivAdaptiveTail S R T z).im`. -/
noncomputable def actualDensityTailData_of_pairedDerivWrapper
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im = (pairedDerivAdaptiveTail S R T z).im) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      :=
    hbound_of_adaptiveComplexTailIBPBoundData
      (adaptiveComplexTailIBPBoundData_pairedDeriv S R error herror)

/-- 🌟🌟🌟🌟 **PROVED — `LocalXiCloudDensityErrorPackage` from wrapper
real-IBP data.** The final layer: feeds the wrapper-derived
`ActualDensityTailData` through the §CCXIII
`localXiPackage_of_actualTailData` constructor. The complete chain
from real-IBP family + error-Im identity → local package is one
function call. -/
noncomputable def localXiPackage_of_pairedDerivWrapper
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im = (pairedDerivAdaptiveTail S R T z).im) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_of_actualTailData
    (actualDensityTailData_of_pairedDerivWrapper
      S R M hM_zeros hmodelAnti error hdecomp herror)

-- =====================================================================
-- §CCXIX. Kernel replacement adapter
-- =====================================================================
-- The §CCXVI wrapper kernel
--   `pairedCauchyComplexKernelDeriv u z := (real x y u : ℂ) * I`
-- is purely imaginary-axis-aligned, which is artificial. The actual
-- analytic complex kernel is rational:
--   `pairedCauchyComplexKernelTrue u z := 1/(z - u)² - 1/(z + u)²`
-- (the u-derivative of `pairedCauchyKernel = 1/(z - u) + 1/(z + u)`).
-- This section provides an adapter so that any complex kernel sharing
-- the wrapper's imaginary part at UHP inherits the §CCXVI–§CCXVIII
-- bridge, and proves that `pairedCauchyComplexKernelTrue` qualifies.
--
-- Adds:
--   ComplexKernelImCompatible                              — Prop adapter
--   complexDensityTailPartial_im_eq_of_kernelImCompatible  — adapter for partials
--   complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
--   pairedCauchyComplexKernelTrue                          — true rational kernel
--   im_inv_sq_complex                                      — helper Im of 1/w²
--   pairedCauchyComplexKernelTrue_im                       — Im at UHP identity
--   pairedCauchyComplexKernelTrue_imCompatible             — adapter witness
--
-- The integral-Im commutation requires integrability hypotheses; we
-- thread them through the adapter theorems.

/-- **`ComplexKernelImCompatible kernel₁ kernel₂`** — pointwise
imaginary-part equality on UHP coordinates: the two complex kernels
agree on the imaginary axis where the bridge cares. -/
structure ComplexKernelImCompatible (kernel₁ kernel₂ : ℝ → ℂ → ℂ) : Prop where
  im_eq : ∀ (u x y : ℝ),
    (kernel₁ u (upperHalfPoint x y)).im
      = (kernel₂ u (upperHalfPoint x y)).im

/-- 🌟 **PROVED — Im of complex partial only depends on Im of kernel.**
Given pointwise Im compatibility and interval-integrability of both
integrands, the Im of their complex partials over `[T, X]` agree.
Proof: route through `Complex.imCLM.intervalIntegral_comp_comm`. -/
lemma complexDensityTailPartial_im_eq_of_kernelImCompatible
    {kernel₁ kernel₂ : ℝ → ℂ → ℂ}
    (H : ComplexKernelImCompatible kernel₁ kernel₂)
    (S : ℝ → ℝ) (x y T X : ℝ)
    (h_int₁ : IntervalIntegrable
                (fun u => kernel₁ u (upperHalfPoint x y) * (S u : ℂ))
                MeasureTheory.volume T X)
    (h_int₂ : IntervalIntegrable
                (fun u => kernel₂ u (upperHalfPoint x y) * (S u : ℂ))
                MeasureTheory.volume T X) :
    (complexDensityTailPartial kernel₁ S T X (upperHalfPoint x y)).im
      = (complexDensityTailPartial kernel₂ S T X (upperHalfPoint x y)).im := by
  unfold complexDensityTailPartial
  -- Convert (∫ ...).im into Complex.imCLM (∫ ...)
  rw [← Complex.imCLM_apply (∫ u in T..X,
        kernel₁ u (upperHalfPoint x y) * (S u : ℂ)),
      ← Complex.imCLM_apply (∫ u in T..X,
        kernel₂ u (upperHalfPoint x y) * (S u : ℂ))]
  -- Pull imCLM inside the integrals
  rw [← Complex.imCLM.intervalIntegral_comp_comm h_int₁,
      ← Complex.imCLM.intervalIntegral_comp_comm h_int₂]
  -- Pointwise: Im of integrands equal under H
  apply intervalIntegral.integral_congr
  intro u _
  show Complex.imCLM (kernel₁ u (upperHalfPoint x y) * (S u : ℂ))
     = Complex.imCLM (kernel₂ u (upperHalfPoint x y) * (S u : ℂ))
  rw [Complex.imCLM_apply, Complex.imCLM_apply]
  simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im, H.im_eq u x y]

/-- 🌟🌟 **PROVED — finite Im match transfers across kernel-Im-compatible
kernels.** Lets any kernel with the wrapper's UHP-Im profile inherit
`ComplexTailImaginaryPartMatchesRealIBP` (via §CCXVI's wrapper proof). -/
theorem complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
    {kernel : ℝ → ℂ → ℂ}
    (H : ComplexKernelImCompatible kernel pairedCauchyComplexKernelDeriv)
    (S : ℝ → ℝ) (x y T : ℝ)
    (h_int₁ : ∀ X, IntervalIntegrable
                (fun u => kernel u (upperHalfPoint x y) * (S u : ℂ))
                MeasureTheory.volume T X)
    (h_int₂ : ∀ X, IntervalIntegrable
                (fun u =>
                  pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)
                    * (S u : ℂ))
                MeasureTheory.volume T X) :
    ComplexTailImaginaryPartMatchesRealIBP kernel S x y T := by
  refine ⟨?_⟩
  filter_upwards
    [(complexTailImaginaryPartMatchesRealIBP_pairedDeriv S x y T).finite_im_eq]
    with X hwrap
  rw [complexDensityTailPartial_im_eq_of_kernelImCompatible
        H S x y T X (h_int₁ X) (h_int₂ X)]
  exact hwrap

/-- **True complex paired-Cauchy kernel derivative.** The u-derivative
of `pairedCauchyKernel u z = 1/(z - u) + 1/(z + u)`, i.e.
  `K'_u(z) = 1/(z - u)² - 1/(z + u)²`.
This is the genuine rational complex kernel; the §CCXVI wrapper was
a synthetic stand-in. -/
noncomputable def pairedCauchyComplexKernelTrue (u : ℝ) (z : ℂ) : ℂ :=
  1 / (z - (u : ℂ))^2 - 1 / (z + (u : ℂ))^2

/-- ⭐ **PROVED — Im of `1/(a + I·b)²`** when `a² + b² ≠ 0`:
  `Im(1/(a + I·b)²) = -2·a·b / (a² + b²)²`.
Direct algebra via `Complex.inv_im` + `Complex.normSq`. -/
lemma im_inv_sq_complex (a b : ℝ) (_h : a^2 + b^2 ≠ 0) :
    (((a : ℂ) + Complex.I * (b : ℂ))^2)⁻¹.im
      = -2 * a * b / (a^2 + b^2)^2 := by
  have hsq_re : (((a : ℂ) + Complex.I * (b : ℂ))^2).re = a^2 - b^2 := by
    rw [pow_two]
    simp [Complex.mul_re, Complex.mul_im, Complex.add_re, Complex.add_im,
          Complex.I_re, Complex.I_im, Complex.ofReal_re, Complex.ofReal_im]
    ring
  have hsq_im : (((a : ℂ) + Complex.I * (b : ℂ))^2).im = 2 * a * b := by
    rw [pow_two]
    simp [Complex.mul_re, Complex.mul_im, Complex.add_re, Complex.add_im,
          Complex.I_re, Complex.I_im, Complex.ofReal_re, Complex.ofReal_im]
    ring
  rw [Complex.inv_im, hsq_im, Complex.normSq_apply, hsq_re, hsq_im]
  have h_denom :
      (a^2 - b^2) * (a^2 - b^2) + 2 * a * b * (2 * a * b) = (a^2 + b^2)^2 := by
    ring
  rw [h_denom]
  ring

/-- 🌟🌟 **PROVED — Im of the true kernel at UHP equals the real
kernel derivative.** -/
lemma pairedCauchyComplexKernelTrue_im (u x y : ℝ) (hy : y ≠ 0) :
    (pairedCauchyComplexKernelTrue u (upperHalfPoint x y)).im
      = pairedCauchyImKernelDeriv x y u := by
  unfold pairedCauchyComplexKernelTrue
  rw [Complex.sub_im]
  have h1 : upperHalfPoint x y - (u : ℂ)
            = ((x - u : ℝ) : ℂ) + Complex.I * ((y : ℝ) : ℂ) := by
    unfold upperHalfPoint
    push_cast
    ring
  have h2 : upperHalfPoint x y + (u : ℂ)
            = ((x + u : ℝ) : ℂ) + Complex.I * ((y : ℝ) : ℂ) := by
    unfold upperHalfPoint
    push_cast
    ring
  rw [show ((1 : ℂ) / (upperHalfPoint x y - (u : ℂ))^2)
        = ((upperHalfPoint x y - (u : ℂ))^2)⁻¹ from one_div _]
  rw [show ((1 : ℂ) / (upperHalfPoint x y + (u : ℂ))^2)
        = ((upperHalfPoint x y + (u : ℂ))^2)⁻¹ from one_div _]
  rw [h1, h2]
  have hd1 : (x - u)^2 + y^2 ≠ 0 := by
    have h_pos : 0 < (x - u)^2 + y^2 := by
      have : 0 < y^2 := by positivity
      linarith [sq_nonneg (x - u)]
    exact ne_of_gt h_pos
  have hd2 : (x + u)^2 + y^2 ≠ 0 := by
    have h_pos : 0 < (x + u)^2 + y^2 := by
      have : 0 < y^2 := by positivity
      linarith [sq_nonneg (x + u)]
    exact ne_of_gt h_pos
  rw [im_inv_sq_complex (x - u) y hd1, im_inv_sq_complex (x + u) y hd2]
  unfold pairedCauchyImKernelDeriv
  ring

/-- 🌟🌟🌟 **PROVED — true kernel is Im-compatible with the wrapper.**
Discharges `ComplexKernelImCompatible` for the rational kernel against
the §CCXVI wrapper. Both have the same Im profile at every UHP point,
so any wrapper-based bridge result transfers to the true kernel via
the adapter theorems above.

Handles `y = 0` by direct simp (both sides collapse to `0`): the
wrapper Im is `pairedCauchyImKernelDeriv x 0 u = 2·0·(…) = 0`, and the
true kernel is purely real on the real axis. -/
theorem pairedCauchyComplexKernelTrue_imCompatible :
    ComplexKernelImCompatible
      pairedCauchyComplexKernelTrue
      pairedCauchyComplexKernelDeriv := by
  refine ⟨?_⟩
  intro u x y
  by_cases hy : y = 0
  · subst hy
    -- Show both .im = 0 independently
    have h_kw :
        (pairedCauchyComplexKernelDeriv u (upperHalfPoint x 0)).im = 0 := by
      unfold pairedCauchyComplexKernelDeriv pairedCauchyImKernelDeriv
      simp [upperHalfPoint]
    have h_kt :
        (pairedCauchyComplexKernelTrue u (upperHalfPoint x 0)).im = 0 := by
      have hUHP : upperHalfPoint x 0 = (x : ℂ) := by
        unfold upperHalfPoint; simp
      unfold pairedCauchyComplexKernelTrue
      rw [hUHP, Complex.sub_im]
      rw [show ((1 : ℂ) / ((x : ℂ) - (u : ℂ))^2 : ℂ)
            = (((x : ℂ) - (u : ℂ))^2)⁻¹ from one_div _]
      rw [show ((1 : ℂ) / ((x : ℂ) + (u : ℂ))^2 : ℂ)
            = (((x : ℂ) + (u : ℂ))^2)⁻¹ from one_div _]
      rw [Complex.inv_im, Complex.inv_im]
      have h_sub_im : (((x : ℂ) - (u : ℂ))^2).im = 0 := by
        rw [pow_two, Complex.mul_im]; simp
      have h_add_im : (((x : ℂ) + (u : ℂ))^2).im = 0 := by
        rw [pow_two, Complex.mul_im]; simp
      rw [h_sub_im, h_add_im]
      ring
    rw [h_kt, h_kw]
  · rw [pairedCauchyComplexKernelTrue_im u x y hy]
    rw [pairedCauchyComplexKernelDeriv_im u x y]

-- =====================================================================
-- §CCXX. True-kernel integrability + true-kernel bound data
-- =====================================================================
-- The §CCXIX kernel-replacement adapter requires interval integrability
-- of both kernels' integrands. The wrapper kernel is trivially integrable
-- (its real component is the standard `pairedCauchyImKernelDeriv`); for
-- the true kernel we need to know its denominators don't vanish on the
-- real `u`-axis (true when `y ≠ 0`) and that the kernel is continuous
-- in `u`.
--
-- Adds:
--   upperHalfPoint_sub_real_ne_zero / _add_real_ne_zero  — denominator non-zero
--   continuous_pairedCauchyComplexKernelTrue_u           — continuity in u
--   complexTailImaginaryPartMatchesRealIBP_trueKernel    — finite Im match for true kernel
--   adaptiveComplexTailIBPBoundData_trueKernel           — true-kernel bound data
--
-- Finite-window integrability is kept as an explicit hypothesis: it
-- requires `S` to be regular enough to combine with the bounded
-- continuous kernel on a compact interval. The continuity lemma here
-- is the building block; the actual integrability of `kernel · S`
-- is conjured by the caller from continuity + regularity of `S`.

/-- ⭐ **PROVED — UHP non-vanishing of `z - u`.** For `y ≠ 0`, the
denominator `upperHalfPoint x y - (u : ℂ)` is non-zero for every
real `u` (its imaginary part is `y ≠ 0`). -/
lemma upperHalfPoint_sub_real_ne_zero
    (x y u : ℝ) (hy : y ≠ 0) :
    upperHalfPoint x y - (u : ℂ) ≠ 0 := by
  intro h
  have him_eq : (upperHalfPoint x y - (u : ℂ)).im = 0 := by
    rw [h]; rfl
  have him_val : (upperHalfPoint x y - (u : ℂ)).im = y := by
    unfold upperHalfPoint
    simp
  rw [him_val] at him_eq
  exact hy him_eq

/-- ⭐ **PROVED — UHP non-vanishing of `z + u`.** -/
lemma upperHalfPoint_add_real_ne_zero
    (x y u : ℝ) (hy : y ≠ 0) :
    upperHalfPoint x y + (u : ℂ) ≠ 0 := by
  intro h
  have him_eq : (upperHalfPoint x y + (u : ℂ)).im = 0 := by
    rw [h]; rfl
  have him_val : (upperHalfPoint x y + (u : ℂ)).im = y := by
    unfold upperHalfPoint
    simp
  rw [him_val] at him_eq
  exact hy him_eq

/-- 🌟🌟 **PROVED — continuity of the true complex kernel in `u`.**
At fixed `z = upperHalfPoint x y` with `y ≠ 0`, the map
`u ↦ pairedCauchyComplexKernelTrue u z` is continuous on `ℝ`. The
denominators `(z ± u)²` never vanish (Im is `y ≠ 0`), so division is
well-defined and continuous. -/
lemma continuous_pairedCauchyComplexKernelTrue_u
    (x y : ℝ) (hy : y ≠ 0) :
    Continuous fun u : ℝ =>
      pairedCauchyComplexKernelTrue u (upperHalfPoint x y) := by
  unfold pairedCauchyComplexKernelTrue
  refine Continuous.sub ?_ ?_
  · apply Continuous.div₀ continuous_const
    · exact (continuous_const.sub Complex.continuous_ofReal).pow 2
    · intro u
      exact pow_ne_zero 2 (upperHalfPoint_sub_real_ne_zero x y u hy)
  · apply Continuous.div₀ continuous_const
    · exact (continuous_const.add Complex.continuous_ofReal).pow 2
    · intro u
      exact pow_ne_zero 2 (upperHalfPoint_add_real_ne_zero x y u hy)

/-- 🌟🌟 **PROVED — finite Im match for the true kernel.** Specializes
§CCXIX's `complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible`
to `pairedCauchyComplexKernelTrue` via
`pairedCauchyComplexKernelTrue_imCompatible`. Requires interval
integrability of both kernel-times-S integrands (carried by the
caller). -/
theorem complexTailImaginaryPartMatchesRealIBP_trueKernel
    (S : ℝ → ℝ) (x y T : ℝ)
    (htrue_int : ∀ X, IntervalIntegrable
                  (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint x y)
                              * (S u : ℂ))
                  MeasureTheory.volume T X)
    (hwrap_int : ∀ X, IntervalIntegrable
                  (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint x y)
                              * (S u : ℂ))
                  MeasureTheory.volume T X) :
    ComplexTailImaginaryPartMatchesRealIBP
      pairedCauchyComplexKernelTrue S x y T :=
  complexTailImaginaryPartMatchesRealIBP_of_kernelImCompatible
    pairedCauchyComplexKernelTrue_imCompatible
    S x y T htrue_int hwrap_int

/-- 🌟🌟🌟 **PROVED — true-kernel adaptive bound data.** Mirrors §CCXVIII's
`adaptiveComplexTailIBPBoundData_pairedDeriv` but for the true rational
kernel. Threads finite-window integrability through; everything else
delegates to the §CCXIX kernel-compatibility transfer + §CCXVII
real-IBP data. -/
theorem adaptiveComplexTailIBPBoundData_trueKernel
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (conv : AdaptiveComplexDensityTailFamilyConverges
              pairedCauchyComplexKernelTrue S)
    (error : ℂ → ℂ)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im = (conv.tail T z).im)
    (htrue_int :
      ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u z * (S u : ℂ))
          MeasureTheory.volume T X)
    (hwrap_int :
      ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u z * (S u : ℂ))
          MeasureTheory.volume T X) :
    AdaptiveComplexTailIBPBoundData
      pairedCauchyComplexKernelTrue S conv error where
  error_im_eq_tail_im := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime
  finite_im_match := by
    intro z T h10 h140 hy hregime
    have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
    have htrue_int_uhp :
        ∀ X, IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                      * (S u : ℂ))
          MeasureTheory.volume T X := by
      intro X
      rw [hz]
      exact htrue_int h10 h140 hy hregime
    have hwrap_int_uhp :
        ∀ X, IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                      * (S u : ℂ))
          MeasureTheory.volume T X := by
      intro X
      rw [hz]
      exact hwrap_int h10 h140 hy hregime
    exact complexTailImaginaryPartMatchesRealIBP_trueKernel
      S z.re z.im T htrue_int_uhp hwrap_int_uhp
  derivative_tendsto := by
    intro z T h10 h140 hy hregime
    exact R.deriv_tendsto h10 h140 hy hregime
  derivative_bound := by
    intro z T J h10 h140 hy hregime hJ
    exact R.deriv_bound h10 h140 hy hregime hJ

-- =====================================================================
-- §CCXXI. True-kernel tail data + final ActualDensityTailData constructor
-- =====================================================================
-- Packages the three remaining xi-specific analytic obligations
-- (true complex tail convergence, true/wrapper integrability, error-Im
-- match) into a single explicit `TrueKernelTailData` structure, then
-- emits the matching `ActualDensityTailData` and
-- `LocalXiCloudDensityErrorPackage` constructors. After this lands,
-- the file boundary is sharp: an inhabitant of `TrueKernelTailData`
-- + `RealIBPFamilyData` + the xi log-derivative decomposition is
-- enough to produce the local package — no further plumbing is
-- needed, only the analytic content.
--
-- Adds:
--   TrueKernelTailData                                  — explicit obligations
--   adaptiveComplexTailIBPBoundData_of_trueKernelTailData
--   actualDensityTailData_of_trueKernelTailData
--   localXiPackage_of_trueKernelTailData                — final entry point
--
-- The remaining "real work" beyond this section is:
--   1. prove `TrueKernelTailData` for the actual xi `S`
--      (true complex tail convergence; true/wrapper integrability;
--       error-Im = (conv.tail T z).im for the actual xi decomposition);
--   2. prove `RealIBPFamilyData` for the actual `S`
--      (Turing/log-envelope number-theory dependency);
--   3. prove `hdecomp` (xi log-derivative decomposition).
-- All three are explicit analytic statements about ξ; none requires
-- additional Lean plumbing.

/-- 📦 **`TrueKernelTailData`** — packaged xi-tail data for the true
rational complex kernel. Carries everything
`adaptiveComplexTailIBPBoundData_trueKernel` needs beyond a real-IBP
family witness:

* `conv` — adaptive complex tail convergence for the true kernel;
* `true_int` / `wrap_int` — interval integrability of `kernel · S` on
  every finite window in the adaptive band (true and wrapper kernel);
* `error_im_eq_tail_im` — the xi residual error's imaginary part
  equals the imaginary part of the true tail at every `(z, T)` in the
  adaptive band.

This is a `Type` (not `Prop`) because `conv` carries the data field
`tail : ℝ → ℂ → ℂ`. -/
structure TrueKernelTailData
    (S : ℝ → ℝ) (R : RealIBPFamilyData S) (error : ℂ → ℂ) where
  /-- Adaptive complex tail convergence for the true rational kernel. -/
  conv : AdaptiveComplexDensityTailFamilyConverges
            pairedCauchyComplexKernelTrue S
  /-- True-kernel finite-window interval integrability. -/
  true_int :
    ∀ {z : ℂ} {T X : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u z * (S u : ℂ))
        MeasureTheory.volume T X
  /-- Wrapper-kernel finite-window interval integrability. -/
  wrap_int :
    ∀ {z : ℂ} {T X : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u z * (S u : ℂ))
        MeasureTheory.volume T X
  /-- The xi residual error's imaginary part equals the true tail's. -/
  error_im_eq_tail_im :
    ∀ {z : ℂ} {T : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im = (conv.tail T z).im

/-- 🌟🌟🌟 **PROVED — `AdaptiveComplexTailIBPBoundData` from
`TrueKernelTailData`.** Pure assembly: routes the four
`TrueKernelTailData` fields through the §CCXX
`adaptiveComplexTailIBPBoundData_trueKernel`. -/
theorem adaptiveComplexTailIBPBoundData_of_trueKernelTailData
    (S : ℝ → ℝ) (R : RealIBPFamilyData S) (error : ℂ → ℂ)
    (D : TrueKernelTailData S R error) :
    AdaptiveComplexTailIBPBoundData
      pairedCauchyComplexKernelTrue S D.conv error :=
  adaptiveComplexTailIBPBoundData_trueKernel
    S R D.conv error D.error_im_eq_tail_im D.true_int D.wrap_int

/-- 🌟🌟🌟🌟 **PROVED — `ActualDensityTailData` from `TrueKernelTailData`.**
The final true-kernel constructor: takes the standard model fields
+ xi log-derivative decomposition + `TrueKernelTailData`, produces
an `ActualDensityTailData`. The `hbound` field is discharged via the
adaptive-bound machine. -/
noncomputable def actualDensityTailData_of_trueKernelTailData
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailData S R error) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      :=
    hbound_of_adaptiveComplexTailIBPBoundData
      (adaptiveComplexTailIBPBoundData_of_trueKernelTailData S R error D)

/-- 🌟🌟🌟🌟🌟 **PROVED — `LocalXiCloudDensityErrorPackage` from
`TrueKernelTailData`.** The final entry point of the true-kernel chain.
Combines a real-IBP family, a model, the xi log-derivative
decomposition, and the true-kernel tail data into a single
`LocalXiCloudDensityErrorPackage`.

After this theorem, the *only* remaining xi-specific obligations are:
* an inhabitant of `RealIBPFamilyData S` (real IBP family for the
  actual fluctuation `S` — Turing / log-envelope number theory),
* an inhabitant of `TrueKernelTailData S R error` (true complex tail
  convergence, integrability, error-Im match — xi analytic dependency),
* the xi log-derivative decomposition `hdecomp`.

No further Lean plumbing stands in the way. -/
noncomputable def localXiPackage_of_trueKernelTailData
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailData S R error) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_of_actualTailData
    (actualDensityTailData_of_trueKernelTailData
      S R M hM_zeros hmodelAnti error hdecomp D)

-- =====================================================================
-- §CCXXII. Conditional capstone — XiPullbackAntiHerglotzTarget from
--          TrueKernelTailData + outside-mid-band coverage
-- =====================================================================
-- The §CCXXI chain ends at `localXiPackage_of_trueKernelTailData`, a
-- LocalXiCloudDensityErrorPackage that covers UHP probes in the
-- adaptive `[10, 140]` mid-band only (the region predicate is
-- `∃ T ∈ [10, 140], 2(1 + |x| + y) ≤ T`). Since this fails for probes
-- with large `|x| + y`, additional packages are needed to cover the
-- low/high bands; together they form a `XiCloudDensityCoveringFamily`,
-- which §CXL discharges into `XiPullbackAntiHerglotzTarget`.
--
-- This section exposes that exact dependency boundary:
--
--   XiPullbackAntiHerglotzTarget_of_trueKernelTailData
--     — conditional capstone: TrueKernelTailData + RealIBPFamilyData
--       + xi decomposition + outside-mid-band cover ⟹ global target.
--
-- After §CCXXII, the project's front door is one theorem whose
-- hypotheses are precisely the remaining unformalized analytic content:
--   1. RealIBPFamilyData S            (Turing/log-envelope number theory)
--   2. TrueKernelTailData S R error   (xi complex tail convergence /
--                                      integrability / error-Im match)
--   3. hdecomp                        (xi log-derivative decomposition)
--   4. extras + covers                (low/high band coverage)

/-- 🌟🌟🌟🌟🌟🌟 **CONDITIONAL CAPSTONE — `XiPullbackAntiHerglotzTarget`
from `TrueKernelTailData`.**

Routes the §CCXXI true-kernel chain through the §CXL covering family
machinery to produce the global anti-Herglotz target.

Hypotheses (the project's final dependency boundary):
* `S, R` — real fluctuation and its `RealIBPFamilyData` (Turing /
  log-envelope number-theoretic dependency);
* `M, hM_zeros, hmodelAnti, error, hdecomp` — model + xi log-derivative
  decomposition (analytic dependency);
* `D : TrueKernelTailData S R error` — true complex tail convergence,
  integrability, error-Im match (analytic dependency);
* `extras, covers` — additional `LocalXiCloudDensityErrorPackage`s
  covering UHP probes outside the adaptive `[10, 140]` band.

Conclusion: `XiPullbackAntiHerglotzTarget`. -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailData
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailData S R error)
    (extras : ℕ → LocalXiCloudDensityErrorPackage)
    (covers : ∀ z : ℂ, 0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) ∨
      ∃ n : ℕ, (extras n).region z) :
    XiPullbackAntiHerglotzTarget := by
  -- The mid-band package from the §CCXXI true-kernel chain
  let midPackage : LocalXiCloudDensityErrorPackage :=
    localXiPackage_of_trueKernelTailData
      S R M hM_zeros hmodelAnti error hdecomp D
  -- Assemble a covering family: index 0 is the mid-band, others are extras
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n => if n = 0 then midPackage else extras (n - 1)
      covers := ?_ }
  intro z hz
  rcases covers z hz with hmid | ⟨n, hn⟩
  · -- z is in the mid-band; package 0 = midPackage covers it
    refine ⟨0, ?_⟩
    show midPackage.region z
    exact hmid
  · -- z is covered by extras n; package (n+1) = extras n covers it
    refine ⟨n + 1, ?_⟩
    show (if (n + 1) = 0 then midPackage else extras (n + 1 - 1)).region z
    simp
    exact hn

-- =====================================================================
-- §CCXXV. Bundled model / coverage data + restated capstone
-- =====================================================================
-- Replaces the loose `(M, hM_zeros, hmodelAnti)` and `(extras, covers)`
-- arguments of the §CCXXII capstone with named bundled structures.
-- Keeps the same logical content but exposes the project's final
-- dependency boundary in a cleaner, theorem-by-theorem readable form.
--
-- Adds:
--   ActualCloudDensityModelData              — bundled model fields
--   LowHighBandCoverData                     — bundled cover fields
--   XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
--     — front door restated using the two bundles.
--
-- The remaining inhabit theorem
-- `finiteFluctuationRegularityData_of_existing_integrability` requires
-- generalizing the existing §CXCVIII discrete/smooth-counting × kernel
-- integrability lemmas (currently OrderedWindow-restricted or aligned
-- to `T0 = T`). It is intentionally deferred — provable in pure Lean
-- without analytic input, but a non-trivial decomposition exercise
-- and not on the critical analytic path.

/-- 📦 **`ActualCloudDensityModelData`** — bundled model fields:
the cloud + density-tail model `M`, the `zeros100ceil` compatibility,
and the anti-Herglotz model property.

These are the three "model-shaped" arguments of the §CCXXII capstone;
bundling them here makes downstream theorems read cleanly. -/
structure ActualCloudDensityModelData where
  M           : CloudDensityTailModelDecomposition
  hM_zeros    : M.zeros = zeros100ceil
  hmodelAnti  : AntiHerglotzUHP M.model

/-- 📦 **`LowHighBandCoverData`** — bundled coverage of UHP probes
outside the adaptive `[10, 140]` band.

`extras` are additional `LocalXiCloudDensityErrorPackage`s, each
controlling some non-mid-band region. `covers` is the disjunction
that every UHP probe either lies in the mid-band or in some `extras n`
region. -/
structure LowHighBandCoverData where
  extras  : ℕ → LocalXiCloudDensityErrorPackage
  covers  : ∀ z : ℂ, 0 < z.im →
    (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) ∨
    ∃ n : ℕ, (extras n).region z

/-- 🌟🌟🌟🌟🌟🌟 **CONDITIONAL CAPSTONE (bundled form).** Restates
§CCXXII's `XiPullbackAntiHerglotzTarget_of_trueKernelTailData` using
`ActualCloudDensityModelData` and `LowHighBandCoverData` bundles in
place of loose arguments. Functionally equivalent — just the cleanest
possible statement of the project's front door.

After §CCXXV, the remaining unformalized obligations are exactly:
* `RealIBPFamilyData S` (or, via §CCXXIV, `FiniteFluctuationLogEnvelopeData D T0`),
* `TrueKernelTailData S R error`,
* `hdecomp` (xi log-derivative decomposition),
* `Model : ActualCloudDensityModelData`,
* `Cover : LowHighBandCoverData`.

All of these are explicit analytic statements about ξ. -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (Model : ActualCloudDensityModelData)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (D : TrueKernelTailData S R error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailData
    S R Model.M Model.hM_zeros Model.hmodelAnti error hdecomp D
    Cover.extras Cover.covers

-- =====================================================================
-- §CCXXIII. RealIBPFamilyData from explicit log-envelope assumptions
-- =====================================================================
-- Reduces the abstract `RealIBPFamilyData S` requirement of the §CCXXII
-- capstone to a concrete, named-assumption bundle `RealIBPLogEnvelopeData`
-- combining:
--   • a pointwise log envelope `|S u| ≤ (slabCD T).1·log u + (slabCD T).2`
--     on `[T, ∞)` for every adaptive `(z, T)` in the band;
--   • finite-window integrability of `S · pairedCauchyImKernelDeriv`.
--
-- Routes through the existing §CCVI / §CCX theorems:
--   • `derivative_integral_tendsto_of_log_envelope` for `deriv_tendsto`,
--   • `derivative_integral_limit_abs_le_majorant_tail` for `deriv_bound`.
--
-- Also extracts standalone slab-nonnegativity lemmas
-- (`slabCD_fst_nonneg`, `slabCD_snd_nonneg`) — previously inlined.

/-- ⭐ **PROVED — `slabCD T` first component is nonnegative.** -/
lemma slabCD_fst_nonneg (T : ℝ) : 0 ≤ (slabCD T).1 := by
  unfold slabCD; split_ifs <;> norm_num

/-- ⭐ **PROVED — `slabCD T` second component is nonnegative.** -/
lemma slabCD_snd_nonneg (T : ℝ) : 0 ≤ (slabCD T).2 := by
  unfold slabCD; split_ifs <;> norm_num

/-- 📦 **`RealIBPLogEnvelopeData S`** — named Prop bundle of the two
analytic obligations that produce a `RealIBPFamilyData S`:

* `log_envelope_from_T` — pointwise log envelope on `[T, ∞)` for every
  adaptive `(z, T)`. Strong enough to give both the `∀ᶠ` form needed
  by `derivative_integral_tendsto_of_log_envelope` and the pointwise
  `[T, ∞)` form needed by `derivative_integral_limit_abs_le_majorant_tail`.
* `derivative_integrable` — interval integrability of the integrand
  `S · pairedCauchyImKernelDeriv z.re z.im` on every `[T, X]` with `T ≤ X`.

Slab nonnegativity (`(slabCD T).1, (slabCD T).2`) is already free
via `slabCD_fst_nonneg` / `slabCD_snd_nonneg`. -/
structure RealIBPLogEnvelopeData (S : ℝ → ℝ) : Prop where
  log_envelope_from_T :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∀ u, T ≤ u →
        |S u| ≤ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- 🌟🌟🌟 **PROVED — `RealIBPFamilyData S` from `RealIBPLogEnvelopeData S`.**
Discharges both `deriv_tendsto` and `deriv_bound` from a single log
envelope + integrability bundle via the existing §CCVI/§CCX machinery. -/
theorem realIBPFamilyData_of_logEnvelope
    (S : ℝ → ℝ) (H : RealIBPLogEnvelopeData S) :
    RealIBPFamilyData S where
  deriv_tendsto := by
    intro z T h10 h140 hy hregime
    have hT_pos : (0 : ℝ) < T := lt_of_lt_of_le (by norm_num) h10
    have hS_ev : ∀ᶠ u in Filter.atTop,
        |S u| ≤ (slabCD T).1 * Real.log u + (slabCD T).2 := by
      filter_upwards [Filter.eventually_ge_atTop T] with u hu
      exact H.log_envelope_from_T h10 h140 hy hregime u hu
    exact Phase1IBP.derivative_integral_tendsto_of_log_envelope
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hS_ev
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
  deriv_bound := by
    intro z T J h10 h140 hy hregime hJ
    have hT_pos : (0 : ℝ) < T := lt_of_lt_of_le (by norm_num) h10
    exact Phase1IBP.derivative_integral_limit_abs_le_majorant_tail
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T) (J := J)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hregime
      (H.log_envelope_from_T h10 h140 hy hregime)
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
      hJ

-- =====================================================================
-- §CCXXIV. Concrete finite-fluctuation specialization
-- =====================================================================
-- Specializes §CCXXIII's `RealIBPLogEnvelopeData S` to the concrete
-- `S u := finiteFluctuationPrimitive D T0 u` of §CXCVII / §CXCIX.
-- Surfaces the exact remaining number-theoretic / regularity content
-- as two named structures:
--
--   FiniteFluctuationLogEnvelopeData D T0   — Turing-style log envelope
--   FiniteFluctuationRegularityData D T0    — split-by-component integrability
--
-- Adds:
--   FiniteFluctuationLogEnvelopeData                  — concrete obligations
--   realIBPLogEnvelopeData_of_finiteFluctuation       — concrete → abstract
--   realIBPFamilyData_of_finiteFluctuation            — concrete → RealIBPFamilyData
--   FiniteFluctuationRegularityData                   — finer split
--   finiteFluctuation_derivative_integrable_of_regular — reassemble integrability

/-- 📦 **`FiniteFluctuationLogEnvelopeData D T0`** — concrete analytic
obligations for the §CXCIX finite fluctuation primitive
`finiteFluctuationPrimitive D T0`. Two fields:

* `log_envelope_from_T` — the Turing/Backlund-style bound on the
  finite fluctuation primitive (real number theory).
* `derivative_integrable` — finite-window interval integrability of
  the IBP derivative-side integrand. -/
structure FiniteFluctuationLogEnvelopeData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) : Prop where
  log_envelope_from_T :
    ∀ {z : ℂ} {T u : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ u →
      |Phase1IBP.finiteFluctuationPrimitive D T0 u|
        ≤ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    ∀ {z : ℂ} {T X : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- 🌟 **PROVED — concrete → abstract log-envelope data.** -/
theorem realIBPLogEnvelopeData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPLogEnvelopeData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) where
  log_envelope_from_T := by
    intro z T h10 h140 hy hregime u hTu
    exact H.log_envelope_from_T h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact H.derivative_integrable h10 h140 hy hregime hTX

/-- 🌟🌟 **PROVED — `RealIBPFamilyData` for the concrete finite
fluctuation primitive.** Composes §CCXXIII's
`realIBPFamilyData_of_logEnvelope` with the concrete log-envelope
bundle. -/
theorem realIBPFamilyData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPFamilyData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) :=
  realIBPFamilyData_of_logEnvelope
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    (realIBPLogEnvelopeData_of_finiteFluctuation D T0 H)

/-- 📦 **`FiniteFluctuationRegularityData D T0`** — finer split of the
`derivative_integrable` field of `FiniteFluctuationLogEnvelopeData`,
separating the discrete-counting and smooth-counting parts of the
integrand. Either piece can in principle be discharged from existing
§CXCVIII work on the discrete sum decomposition and the explicit
smooth primitive. -/
structure FiniteFluctuationRegularityData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) : Prop where
  discrete_part_integrable :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X
  smooth_part_integrable :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- 🌟🌟 **PROVED — reassemble integrability from the regular split.**
Given finer per-component integrability, recovers the
`derivative_integrable` of `FiniteFluctuationLogEnvelopeData`. Uses
`(a - b) · c = a·c - b·c` pointwise + `IntervalIntegrable.sub`. -/
theorem finiteFluctuation_derivative_integrable_of_regular
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (R : FiniteFluctuationRegularityData D T0) :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hN := R.discrete_part_integrable h10 h140 hy hregime hTX
  have hS := R.smooth_part_integrable h10 h140 hy hregime hTX
  have hfunc_eq :
      (fun u =>
        Phase1IBP.finiteFluctuationPrimitive D T0 u
          * pairedCauchyImKernelDeriv z.re z.im u)
      = (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u
          - Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    ring
  rw [hfunc_eq]
  exact hN.sub hS

-- =====================================================================
-- §CCXXV. Inhabiting `FiniteFluctuationRegularityData` from existing
--         integrability lemmas (no extra analytic input)
-- =====================================================================
-- Provides:
--   discreteCountingKernelDerivTermAnyWindow            — per-i term def
--   discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
--   discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
--                                                       — generalizes the
--                                                         §CXCVIII lemma (drops
--                                                         the `OrderedWindow`
--                                                         requirement)
--   finiteFluctuationRegularityData_of_existing_integrability
--                                                       — produces the
--                                                         regularity bundle
--                                                         given `0 < T0` and
--                                                         `T0 ≤ 10`.
--
-- The discrete part is fully general (any `T0, T, X` work).
-- The smooth part reuses the existing §CXCVIII lemma via
-- `IntervalIntegrable.mono_set`, which requires `T0 ≤ T` over the
-- adaptive band (so `T0 ≤ 10` is sufficient since adaptive `T ≥ 10`).

/-- **Per-`i` indicator term for the any-window discrete primitive.**
Mirrors `Phase1IBP.discreteKernelDerivIndicatorTerm` but with the
two-condition indicator that appears in
`Phase1IBP.discreteCountingPrimitive D T0 u` for arbitrary `T0`. -/
noncomputable def discreteCountingKernelDerivTermAnyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 : ℝ) (i : ℕ) : ℝ → ℝ :=
  fun u =>
    (if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- ⭐ **PROVED — per-`i` term is interval-integrable on any window.**
Case-split on `T0 ≤ D.Z i`: in the `≤` case, the integrand reduces to
the §CXCVIII single-indicator pattern (use
`Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable`); in the
`>` case, the integrand is identically zero. -/
lemma discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : ℝ) (i : ℕ) (hy : 0 < y) :
    IntervalIntegrable
      (discreteCountingKernelDerivTermAnyWindow D x y T0 i)
      MeasureTheory.volume T X := by
  unfold discreteCountingKernelDerivTermAnyWindow
  by_cases h_T0 : T0 ≤ D.Z i
  · have hfun :
        (fun u =>
          (if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun u =>
          (D.mult i : ℝ) * (if D.Z i ≤ u then (1 : ℝ) else 0)
            * pairedCauchyImKernelDeriv x y u) := by
      funext u
      by_cases h_u : D.Z i ≤ u
      · have h_and : T0 ≤ D.Z i ∧ D.Z i ≤ u := ⟨h_T0, h_u⟩
        simp [h_and, h_u]
      · have h_nand : ¬ (T0 ≤ D.Z i ∧ D.Z i ≤ u) := fun ⟨_, h⟩ => h_u h
        simp [h_nand, h_u]
    rw [hfun]
    exact Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  · have hfun :
        (fun u =>
          (if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun _ : ℝ => (0 : ℝ)) := by
      funext u
      have h_nand : ¬ (T0 ≤ D.Z i ∧ D.Z i ≤ u) := fun ⟨h, _⟩ => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- 🌟🌟 **PROVED — `N_{T0}(u) · k'(u)` is interval-integrable on any
finite window**, without an `OrderedWindow` hypothesis. Generalizes
§CXCVIII's `Phase1IBP.discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
to the case where the primitive's lower cutoff `T0` is decoupled from
the integration window `[T, X]`. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : ℝ) (hy : 0 < y) :
    IntervalIntegrable
      (fun u =>
        Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun :
      IntervalIntegrable
        (∑ i ∈ Finset.range D.n,
          discreteCountingKernelDerivTermAnyWindow D x y T0 i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
        D x y T0 T X i hy)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (∑ i, term i) u = ∑ i, term i u (Finset.sum_apply)
  -- = (∑ i, (if ... then mult_i else 0)) * k'(u) (Finset.sum_mul reverse)
  -- = discreteCountingPrimitive D.toFluctuationMeasureData T0 u * k'(u) (def)
  simp only [Finset.sum_apply, discreteCountingKernelDerivTermAnyWindow]
  rw [← Finset.sum_mul]
  rfl

/-- 🌟🌟🌟 **PROVED — `FiniteFluctuationRegularityData` from existing
integrability.** Given `0 < T0 ≤ 10`, both regularity fields are
discharged from already-landed §CXCVIII lemmas:

* `discrete_part_integrable` — via the new
  `discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow`
  (no `OrderedWindow` needed).
* `smooth_part_integrable` — via existing
  `Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
  on `[T0, X]` plus `IntervalIntegrable.mono_set` to shrink to
  `[T, X] ⊆ [T0, X]` (the latter inclusion needs `T0 ≤ T`, which
  follows from `T0 ≤ 10 ≤ T`).

After this lands, the only field of `FiniteFluctuationLogEnvelopeData`
that remains unproved is `log_envelope_from_T` (the Turing/Backlund
bound). -/
theorem finiteFluctuationRegularityData_of_existing_integrability
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10) :
    FiniteFluctuationRegularityData D T0 := by
  refine ⟨?_, ?_⟩
  · intro z T X h10 h140 hy hregime hTX
    exact discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
      D z.re z.im T0 T X hy
  · intro z T X h10 h140 hy hregime hTX
    have hT0_le_T : T0 ≤ T := le_trans hT0_le_10 h10
    have hT0_le_X : T0 ≤ X := le_trans hT0_le_T hTX
    have h_big : IntervalIntegrable
        (fun u => Phase1IBP.smoothCountingPrimitive T0 u
                    * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T0 X :=
      Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
        hT0_pos hT0_le_X z.re hy
    have hsubset : Set.uIcc T X ⊆ Set.uIcc T0 X := by
      rw [Set.uIcc_of_le hTX, Set.uIcc_of_le hT0_le_X]
      intro u hu
      exact ⟨le_trans hT0_le_T hu.1, hu.2⟩
    exact h_big.mono_set hsubset

-- =====================================================================
-- §CCXXVI. Finite-fluctuation RealIBP from a Turing-style bound
-- =====================================================================
-- The handoff layer: composes §CCXXIV's `FiniteFluctuationLogEnvelopeData`
-- with §CCXXV's `finiteFluctuationRegularityData_of_existing_integrability`
-- so the only remaining xi-specific input is the Turing/Backlund log
-- envelope `hTuring`.
--
-- Adds:
--   finiteFluctuationLogEnvelopeData_of_turingBound      — assemble the bundle
--   realIBPFamilyData_of_finiteFluctuation_turingBound   — concrete RealIBPFamilyData
--   XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTail
--                                                        — bundled capstone with
--                                                          Turing slot exposed
--
-- After §CCXXVI, the project's front door reads:
--   `hTuring` + Model + xi `hdecomp` + `TrueKernelTailData` + `LowHighBandCoverData`
--   ⟹ `XiPullbackAntiHerglotzTarget`.
-- The `hTuring` slot is the only remaining hard analytic input on the
-- real-IBP side; the parallel agent owns it.

/-- 🌟🌟🌟 **PROVED — `FiniteFluctuationLogEnvelopeData` from a
Turing-style log envelope.** Assembles the bundle by passing
`hTuring` directly to the `log_envelope_from_T` field and discharging
`derivative_integrable` via §CCXXIV +
`finiteFluctuationRegularityData_of_existing_integrability`. -/
theorem finiteFluctuationLogEnvelopeData_of_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2) :
    FiniteFluctuationLogEnvelopeData D T0 where
  log_envelope_from_T := by
    intro z T u h10 h140 hy hregime hTu
    exact hTuring h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact finiteFluctuation_derivative_integrable_of_regular D T0
      (finiteFluctuationRegularityData_of_existing_integrability
        D T0 hT0_pos hT0_le_10)
      h10 h140 hy hregime hTX

/-- 🌟🌟🌟🌟 **PROVED — `RealIBPFamilyData` for the finite fluctuation
primitive, gated only by the Turing bound.** Composes §CCXXIV's
`realIBPFamilyData_of_finiteFluctuation` with
`finiteFluctuationLogEnvelopeData_of_turingBound`. -/
theorem realIBPFamilyData_of_finiteFluctuation_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2) :
    RealIBPFamilyData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) :=
  realIBPFamilyData_of_finiteFluctuation D T0
    (finiteFluctuationLogEnvelopeData_of_turingBound
      D T0 hT0_pos hT0_le_10 hTuring)

/-- 🌟🌟🌟🌟🌟🌟 **CONDITIONAL CAPSTONE (concrete finite-fluctuation
form).** The §CCXXII bundled capstone instantiated to
`S = finiteFluctuationPrimitive D T0`, with the `R` slot supplied
internally from the Turing bound.

Final dependency surface for the finite-fluctuation route:
* `hTuring` — the Turing/Backlund log envelope (parallel agent);
* `Model` — `ActualCloudDensityModelData` (actual xi cloud-density model);
* `hdecomp` — xi log-derivative decomposition;
* `Dtail` — `TrueKernelTailData` for the finite-fluctuation `S`;
* `Cover` — `LowHighBandCoverData` for non-mid-band probes.

Conclusion: `XiPullbackAntiHerglotzTarget`. -/
theorem XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTail
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (Dtail :
      TrueKernelTailData
        (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
        (realIBPFamilyData_of_finiteFluctuation_turingBound
          D T0 hT0_pos hT0_le_10 hTuring)
        error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    (realIBPFamilyData_of_finiteFluctuation_turingBound
      D T0 hT0_pos hT0_le_10 hTuring)
    Model error hdecomp Dtail Cover

-- =====================================================================
-- §CCXXVII. Wrapper-kernel integrability from real-derivative integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.wrap_int`:
-- The §CCXVI wrapper kernel `pairedCauchyComplexKernelDeriv u z` at
-- `z = upperHalfPoint x y` factors pointwise as
-- `pairedCauchyComplexKernelDeriv u (UHP) * (S u : ℂ)
--      = ((S u · pairedCauchyImKernelDeriv x y u : ℝ) : ℂ) * I`.
-- So interval integrability of the complex integrand follows from
-- interval integrability of the real integrand (via `Integrable.ofReal`
-- + multiplication by the constant `Complex.I`).
--
-- Adds:
--   pairedDerivWrapper_integrand_eq_ofReal_mul_I        — pointwise identity
--   intervalIntegrable_ofReal                           — local `IntervalIntegrable.ofReal`
--   wrapKernel_intervalIntegrable_of_real_derivative_integrable
--   wrap_int_of_finiteFluctuation                       — adaptive form

/-- ⭐ **PROVED — pointwise factorization of wrapper integrand.**
The §CCXVI wrapper kernel integrand at `upperHalfPoint x y` equals
`((real integrand : ℝ) : ℂ) · I`. -/
lemma pairedDerivWrapper_integrand_eq_ofReal_mul_I
    (S : ℝ → ℝ) (x y u : ℝ) :
    pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ)
      = ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ) * Complex.I := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  push_cast
  ring

/-- ⭐ **PROVED — `IntervalIntegrable.ofReal` for ℝ → ℂ.** Lifts real
interval integrability to ℂ via the pointwise coercion. Built from
Mathlib's `MeasureTheory.Integrable.ofReal` on each of the two
`IntegrableOn` halves of `IntervalIntegrable`. -/
lemma intervalIntegrable_ofReal
    {f : ℝ → ℝ} {a b : ℝ}
    (hf : IntervalIntegrable f MeasureTheory.volume a b) :
    IntervalIntegrable (fun u => ((f u : ℝ) : ℂ))
      MeasureTheory.volume a b :=
  ⟨hf.1.ofReal, hf.2.ofReal⟩

/-- 🌟🌟 **PROVED — wrapper-kernel integrand interval integrability
from real-derivative integrability.** Given that
`fun u => S u · pairedCauchyImKernelDeriv x y u` is interval-integrable
on `[T, X]`, the complex wrapper integrand
`fun u => pairedCauchyComplexKernelDeriv u (UHP x y) · (S u : ℂ)` is
interval-integrable on the same interval. -/
lemma wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (S : ℝ → ℝ) (x y T X : ℝ)
    (hreal : IntervalIntegrable
              (fun u => S u * pairedCauchyImKernelDeriv x y u)
              MeasureTheory.volume T X) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : ℂ))
      MeasureTheory.volume T X := by
  have hofReal : IntervalIntegrable
      (fun u => ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ))
      MeasureTheory.volume T X :=
    intervalIntegrable_ofReal hreal
  have hmul : IntervalIntegrable
      (fun u =>
        ((S u * pairedCauchyImKernelDeriv x y u : ℝ) : ℂ) * Complex.I)
      MeasureTheory.volume T X :=
    hofReal.mul_const Complex.I
  refine hmul.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  exact (pairedDerivWrapper_integrand_eq_ofReal_mul_I S x y u).symm

/-- 🌟🌟🌟 **PROVED — adaptive wrapper integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T ≤ X`, the wrapper-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `wrap_int` field of `TrueKernelTailData`
for the finite-fluctuation `S`.

Note: this does *not* depend on the Turing bound — only on
`0 < T0 ≤ 10` and the §CCXXV regularity inhabit theorem. -/
theorem wrap_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10) :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelDeriv u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ℝ) : ℂ))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hreg := finiteFluctuationRegularityData_of_existing_integrability
    D T0 hT0_pos hT0_le_10
  have hreal : IntervalIntegrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u
                  * pairedCauchyImKernelDeriv z.re z.im u)
      MeasureTheory.volume T X :=
    finiteFluctuation_derivative_integrable_of_regular D T0 hreg
      h10 h140 hy hregime hTX
  have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hwrap := wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    z.re z.im T X hreal
  rw [hz] at hwrap
  exact hwrap

-- =====================================================================
-- §CCXXVIII. True-kernel finite-window integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.true_int` for the finite-fluctuation
-- `S = Phase1IBP.finiteFluctuationPrimitive D T0` by:
--   1. defining a per-`i` true-kernel indicator term;
--   2. proving its interval integrability (indicator × continuous kernel);
--   3. summing for the discrete part;
--   4. proving smooth-part integrability via ContinuousOn;
--   5. reassembling the finite-fluctuation integrand by `sub`;
--   6. packaging the adaptive theorem `true_int_of_finiteFluctuation`.
--
-- Adds:
--   discreteCountingTrueKernelTerm                              — per-i term def
--   discreteCountingTrueKernelTerm_intervalIntegrable           — per-i integrability
--   discreteCountingPrimitive_trueKernel_intervalIntegrable     — discrete sum
--   smoothCountingPrimitive_trueKernel_intervalIntegrable       — smooth part
--   finiteFluctuationPrimitive_trueKernel_intervalIntegrable    — reassembled
--   true_int_of_finiteFluctuation                               — adaptive form

/-- **Per-`i` true-kernel indicator term.** Top-level definition to
keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteCountingTrueKernelTerm
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 : ℝ) (z : ℂ) (i : ℕ) : ℝ → ℂ :=
  fun u =>
    pairedCauchyComplexKernelTrue u z
      * ((if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0) : ℂ)

/-- ⭐ **PROVED — per-`i` true-kernel term is interval-integrable.**
Case-splits on `T0 ≤ D.Z i`: in the `≤` case, the integrand reduces to
an indicator × continuous-kernel pattern (built via `.indicator
measurableSet_Ici` on each `IntegrableOn` half); in the `>` case, the
integrand is identically zero. -/
lemma discreteCountingTrueKernelTerm_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ℝ) (z : ℂ) (i : ℕ) (hz : z.im ≠ 0) :
    IntervalIntegrable
      (discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X := by
  unfold discreteCountingTrueKernelTerm
  have hk_cont : Continuous fun u : ℝ => pairedCauchyComplexKernelTrue u z := by
    have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
    simpa [upperHalfPoint_re_im] using h
  by_cases h_T0 : T0 ≤ D.Z i
  · have hfun :
        (fun u : ℝ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0) : ℂ))
        = Set.indicator (Set.Ici (D.Z i))
            (fun u : ℝ =>
              pairedCauchyComplexKernelTrue u z * (D.mult i : ℂ)) := by
      funext u
      by_cases h_u : D.Z i ≤ u
      · have h_and : T0 ≤ D.Z i ∧ D.Z i ≤ u := ⟨h_T0, h_u⟩
        have hmem : u ∈ Set.Ici (D.Z i) := h_u
        simp [h_and, Set.indicator_of_mem hmem]
      · have h_nand : ¬ (T0 ≤ D.Z i ∧ D.Z i ≤ u) := fun ⟨_, h⟩ => h_u h
        have hnmem : u ∉ Set.Ici (D.Z i) := h_u
        simp [h_nand, Set.indicator_of_notMem hnmem]
    rw [hfun]
    have h_const_mul : IntervalIntegrable
        (fun u : ℝ => pairedCauchyComplexKernelTrue u z * (D.mult i : ℂ))
        MeasureTheory.volume T X :=
      (hk_cont.intervalIntegrable T X).mul_const (D.mult i : ℂ)
    exact ⟨h_const_mul.1.indicator measurableSet_Ici,
           h_const_mul.2.indicator measurableSet_Ici⟩
  · have hfun :
        (fun u : ℝ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 ≤ D.Z i ∧ D.Z i ≤ u then (D.mult i : ℝ) else 0) : ℂ))
        = (fun _ : ℝ => (0 : ℂ)) := by
      funext u
      have h_nand : ¬ (T0 ≤ D.Z i ∧ D.Z i ≤ u) := fun ⟨h, _⟩ => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- 🌟🌟 **PROVED — `N_{T0}(u) · trueKernel(u, z)` is interval-integrable
on any finite window.** Discrete counting primitive times true kernel.
Proof: sum of per-`i` indicator terms, then bridge via `Finset.mul_sum`
+ `push_cast` to identify with the primitive's defining sum. -/
lemma discreteCountingPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ℝ) (z : ℂ) (hz : z.im ≠ 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.discreteCountingPrimitive
              D.toFluctuationMeasureData T0 u : ℝ) : ℂ))
      MeasureTheory.volume T X := by
  have h_sum_fun : IntervalIntegrable
      (∑ i ∈ Finset.range D.n, discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingTrueKernelTerm_intervalIntegrable D T0 T X z i hz)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  simp only [Finset.sum_apply, discreteCountingTrueKernelTerm]
  rw [← Finset.mul_sum]
  congr 1
  unfold Phase1IBP.discreteCountingPrimitive
  push_cast
  refine Finset.sum_congr rfl (fun i _ => ?_)
  by_cases hc : T0 ≤ D.Z i ∧ D.Z i ≤ u
  · simp [hc]
  · simp [hc]

/-- 🌟🌟 **PROVED — `S_smooth(u) · trueKernel(u, z)` is interval-integrable
on `[T, X]`** for `0 < T0 ≤ T ≤ X` and `z.im ≠ 0`. Both factors are
continuous on `[T, X]`: `S_smooth` via FTC (since `T0 ≤ u` for every
`u ∈ [T, X]`), `trueKernel` via §CCXX. -/
lemma smoothCountingPrimitive_trueKernel_intervalIntegrable
    (T0 T X : ℝ) (z : ℂ)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 ≤ T) (hTX : T ≤ X) (hz : z.im ≠ 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : ℝ) : ℂ))
      MeasureTheory.volume T X := by
  have h_S_cont : ContinuousOn
      (fun u => ((Phase1IBP.smoothCountingPrimitive T0 u : ℝ) : ℂ))
      (Set.Icc T X) := by
    intro u hu
    have hT0_le_u : T0 ≤ u := le_trans hT0_le_T hu.1
    have h_deriv := Phase1IBP.smoothCountingPrimitive_hasDerivAt hT0_pos hT0_le_u
    have h_real_cont : ContinuousAt
        (fun v => Phase1IBP.smoothCountingPrimitive T0 v) u :=
      h_deriv.differentiableAt.continuousAt
    exact
      (Complex.continuous_ofReal.continuousAt.comp h_real_cont).continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyComplexKernelTrue u z)
      (Set.Icc T X) := by
    have hcont : Continuous fun u : ℝ => pairedCauchyComplexKernelTrue u z := by
      have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
      simpa [upperHalfPoint_re_im] using h
    exact hcont.continuousOn
  have h_prod_cont : ContinuousOn
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : ℝ) : ℂ))
      (Set.Icc T X) :=
    h_k_cont.mul h_S_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- 🌟🌟🌟 **PROVED — `finiteFluctuationPrimitive D T0 u · trueKernel(u, z)`
is interval-integrable.** Reassembles the discrete and smooth parts
via `IntervalIntegrable.sub` after distributing
`trueKernel · ((N - Ssmooth : ℝ) : ℂ)` pointwise. -/
lemma finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ℝ) (z : ℂ)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 ≤ T) (hTX : T ≤ X) (hz : z.im ≠ 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ℝ) : ℂ))
      MeasureTheory.volume T X := by
  have hdisc := discreteCountingPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hz
  have hsmooth := smoothCountingPrimitive_trueKernel_intervalIntegrable
    T0 T X z hT0_pos hT0_le_T hTX hz
  have hfunc_eq :
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ℝ) : ℂ))
      = (fun u =>
          pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.discreteCountingPrimitive
                D.toFluctuationMeasureData T0 u : ℝ) : ℂ)
          - pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.smoothCountingPrimitive T0 u : ℝ) : ℂ)) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    push_cast
    ring
  rw [hfunc_eq]
  exact hdisc.sub hsmooth

/-- 🌟🌟🌟 **PROVED — adaptive true-kernel integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T ≤ X`, the true-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `true_int` field of `TrueKernelTailData`
for the finite-fluctuation `S` (modulo the `T ≤ X` hypothesis).

Like §CCXXVII's `wrap_int_of_finiteFluctuation`, this version adds
`T ≤ X` as an explicit hypothesis — the structure's field allows
arbitrary `X`, but the practical use case (improper integral partial
sums) only ever uses `T ≤ X`. -/
theorem true_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10) :
    ∀ {z : ℂ} {T X : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelTrue u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ℝ) : ℂ))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hT0_le_T : T0 ≤ T := le_trans hT0_le_10 h10
  exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hT0_pos hT0_le_T hTX (ne_of_gt hy)

-- =====================================================================
-- §CCXXIX. Complex improper convergence from a real norm-majorant
-- =====================================================================
-- ℂ-valued analogue of §CCV's `improperIntegralConverges_of_absMajorant`.
-- Given a complex integrand `f : ℝ → ℂ`, a real majorant `M : ℝ → ℝ`
-- whose improper integral converges, and a pointwise eventual bound
-- `‖f u‖ ≤ M u`, the complex partial integrals `∫ T..X, f u` form a
-- Cauchy sequence in ℂ and hence converge (ℂ is complete).
--
-- This is the smallest reusable next building block for the `conv`
-- field of `TrueKernelTailData`: any concrete kernel × density tail
-- with a log-envelope bound yields convergence via this lemma.
--
-- Adds:
--   improperComplexIntegralConverges_of_normMajorant

/-- 🌟🌟🌟 **PROVED — complex improper convergence from a real
norm-majorant.** Mirrors §CCV's real-side comparison theorem. Proof:
Cauchy criterion via `Metric.cauchy_iff`, with the key step
`‖∫_{Y1}^{Y2} f‖ ≤ ∫_{Y1}^{Y2} ‖f u‖ du ≤ ∫_{Y1}^{Y2} M u du`
(combining `MeasureTheory.norm_integral_le_integral_norm` and
`intervalIntegral.integral_mono_on`) plus the M-tail smallness from
the M-partial Cauchy structure. -/
theorem improperComplexIntegralConverges_of_normMajorant
    {f : ℝ → ℂ} {M : ℝ → ℝ} {T LM : ℝ}
    (hf_int : ∀ X, T ≤ X → IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : ∀ X, T ≤ X → IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => ∫ u in T..X, M u)
                    Filter.atTop (𝓝 LM))
    (hbound : ∀ᶠ u in Filter.atTop, ‖f u‖ ≤ M u) :
    ∃ L : ℂ, Tendsto (fun X => ∫ u in T..X, f u) Filter.atTop (𝓝 L) := by
  have h_cauchy :
      Cauchy (Filter.map (fun X => ∫ u in T..X, f u) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine ⟨Filter.map_neBot, ?_⟩
    intro ε hε
    have hε2 : 0 < ε / 2 := by linarith
    have h_M_close : ∀ᶠ A in Filter.atTop,
        |(∫ u in T..A, M u) - LM| < ε / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (ε / 2) hε2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain ⟨N_M, hN_M⟩ := Filter.eventually_atTop.mp h_M_close
    obtain ⟨N0, hN0⟩ := Filter.eventually_atTop.mp hbound
    let N : ℝ := max T (max N0 N_M)
    refine ⟨(fun X => ∫ u in T..X, f u) '' {X | N ≤ X}, ?_, ?_⟩
    · exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    suffices key :
        ∀ Y1 Y2 : ℝ, N ≤ Y1 → N ≤ Y2 → Y1 ≤ Y2 →
          ‖(∫ u in T..Y2, f u) - (∫ u in T..Y1, f u)‖ < ε by
      rintro _ ⟨X1, hX1, rfl⟩ _ ⟨X2, hX2, rfl⟩
      rw [dist_eq_norm]
      rcases le_total X1 X2 with hX12 | hX21
      · rw [norm_sub_rev]; exact key X1 X2 hX1 hX2 hX12
      · exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    have hT_Y1 : T ≤ Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T ≤ Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 ≤ Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M ≤ Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M ≤ Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    have hf_int_TY2 := hf_int Y2 hT_Y2
    have hf_int_TY1 : IntervalIntegrable f MeasureTheory.volume T Y1 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have hM_int_TY2 := hM_int Y2 hT_Y2
    have hM_int_TY1 : IntervalIntegrable M MeasureTheory.volume T Y1 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have h_split_f : (∫ u in T..Y2, f u) =
        (∫ u in T..Y1, f u) + ∫ u in Y1..Y2, f u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hf_int_TY1 hf_int_Y1Y2).symm
    have h_tail_f :
        (∫ u in T..Y2, f u) - (∫ u in T..Y1, f u) = ∫ u in Y1..Y2, f u := by
      rw [h_split_f]; ring
    rw [h_tail_f]
    have hbound_Y1Y2 : ∀ u ∈ Set.Icc Y1 Y2, ‖f u‖ ≤ M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    have h_norm_int : ‖∫ u in Y1..Y2, f u‖ ≤ ∫ u in Y1..Y2, ‖f u‖ := by
      rw [intervalIntegral.integral_of_le hY12,
          intervalIntegral.integral_of_le hY12]
      exact MeasureTheory.norm_integral_le_integral_norm _
    have h_mono : ∫ u in Y1..Y2, ‖f u‖ ≤ ∫ u in Y1..Y2, M u :=
      intervalIntegral.integral_mono_on hY12 hf_int_Y1Y2.norm hM_int_Y1Y2
        hbound_Y1Y2
    have h_comp : ‖∫ u in Y1..Y2, f u‖ ≤ ∫ u in Y1..Y2, M u :=
      le_trans h_norm_int h_mono
    have h_split_M : (∫ u in T..Y2, M u) =
        (∫ u in T..Y1, M u) + ∫ u in Y1..Y2, M u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hM_int_TY1 hM_int_Y1Y2).symm
    have h_M_tail_eq : ∫ u in Y1..Y2, M u =
        (∫ u in T..Y2, M u) - (∫ u in T..Y1, M u) := by linarith
    have h_M_close_Y1 := hN_M Y1 hN_M_Y1
    have h_M_close_Y2 := hN_M Y2 hN_M_Y2
    have h_M_diff_lt :
        |(∫ u in T..Y2, M u) - (∫ u in T..Y1, M u)| < ε := by
      calc |(∫ u in T..Y2, M u) - (∫ u in T..Y1, M u)|
          ≤ |(∫ u in T..Y2, M u) - LM| + |LM - (∫ u in T..Y1, M u)| :=
              abs_sub_le _ _ _
        _ = |(∫ u in T..Y2, M u) - LM| + |(∫ u in T..Y1, M u) - LM| := by
              rw [abs_sub_comm LM]
        _ < ε / 2 + ε / 2 := add_lt_add h_M_close_Y2 h_M_close_Y1
        _ = ε := by ring
    rw [h_M_tail_eq] at h_comp
    have h_le_abs :
        (∫ u in T..Y2, M u) - (∫ u in T..Y1, M u)
          ≤ |(∫ u in T..Y2, M u) - (∫ u in T..Y1, M u)| := le_abs_self _
    linarith
  obtain ⟨L, hL⟩ := CompleteSpace.complete h_cauchy
  exact ⟨L, hL⟩

-- =====================================================================
-- §CCXXIX-3. True-kernel norm bound on UHP probes
-- =====================================================================
-- Crude `1/u²` decay bound on the true rational kernel at UHP probes
-- `(upperHalfPoint x y)`. For `u` larger than `2|x|`:
--   • `|x ± u| ≥ u/2`;
--   • hence `‖z ± u‖ ≥ u/2` (via `Complex.abs_re_le_norm`);
--   • hence `‖1/(z ± u)²‖ ≤ 4/u²`;
--   • triangle inequality on the difference gives ≤ 8/u².
-- The `1/u²` decay is enough (combined with a log envelope on `S`)
-- to apply §CCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   upperHalfPoint_sub_real_norm_ge_half
--   upperHalfPoint_add_real_norm_ge_half
--   norm_inv_sq_le_four_div_sq_of_norm_ge_half
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually

/-- ⭐ **PROVED — `‖UHP - u‖ ≥ u/2` when `u ≥ 2|x|`.** Lower bound on
the denominator of the first true-kernel term. -/
lemma upperHalfPoint_sub_real_norm_ge_half
    (x y u : ℝ) (hu : 2 * |x| ≤ u) :
    u / 2 ≤ ‖upperHalfPoint x y - (u : ℂ)‖ := by
  have h_re : (upperHalfPoint x y - (u : ℂ)).re = x - u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| ≤ u / 2 := by linarith
  have hu_nn : 0 ≤ u := by linarith [abs_nonneg x]
  have h_x_upper : x ≤ u / 2 := le_trans (le_abs_self x) h_abs_x
  have h_nonneg : 0 ≤ u - x := by linarith
  have h_abs_eq : |x - u| = u - x := by
    rw [abs_sub_comm]
    exact abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 ≤ |x - u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x - u| ≤ ‖upperHalfPoint x y - (u : ℂ)‖ := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y - (u : ℂ))
    rw [h_re] at this
    exact this
  linarith

/-- ⭐ **PROVED — `‖UHP + u‖ ≥ u/2` when `u ≥ 2|x|`.** Lower bound on
the denominator of the second true-kernel term. -/
lemma upperHalfPoint_add_real_norm_ge_half
    (x y u : ℝ) (hu : 2 * |x| ≤ u) :
    u / 2 ≤ ‖upperHalfPoint x y + (u : ℂ)‖ := by
  have h_re : (upperHalfPoint x y + (u : ℂ)).re = x + u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| ≤ u / 2 := by linarith
  have hu_nn : 0 ≤ u := by linarith [abs_nonneg x]
  have h_neg_x_le : -x ≤ |x| := neg_le_abs x
  have h_x_lower : -(u / 2) ≤ x := by linarith
  have h_nonneg : 0 ≤ x + u := by linarith
  have h_abs_eq : |x + u| = x + u := abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 ≤ |x + u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x + u| ≤ ‖upperHalfPoint x y + (u : ℂ)‖ := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y + (u : ℂ))
    rw [h_re] at this
    exact this
  linarith

/-- ⭐ **PROVED — reciprocal-square norm bound.** If `‖w‖ ≥ u/2 > 0`,
then `‖1/w²‖ ≤ 4/u²`. -/
lemma norm_inv_sq_le_four_div_sq_of_norm_ge_half
    {w : ℂ} {u : ℝ} (hu : 0 < u) (hw : u / 2 ≤ ‖w‖) :
    ‖(1 : ℂ) / w^2‖ ≤ 4 / u^2 := by
  have hu_half_pos : 0 < u / 2 := by linarith
  have hw_pos : 0 < ‖w‖ := lt_of_lt_of_le hu_half_pos hw
  have h_sq : (u / 2)^2 ≤ ‖w‖^2 :=
    sq_le_sq' (by linarith [norm_nonneg w]) hw
  have hw_sq_pos : 0 < ‖w‖^2 := by positivity
  have hu_sq_pos : 0 < u^2 := by positivity
  rw [norm_div, norm_one, norm_pow, div_le_div_iff₀ hw_sq_pos hu_sq_pos]
  nlinarith [h_sq]

/-- 🌟🌟 **PROVED — true-kernel `8/u²` bound for `u ≥ 2|x|`.**
Triangle inequality on `1/(z-u)² - 1/(z+u)²` plus the per-term `4/u²`
bound from `norm_inv_sq_le_four_div_sq_of_norm_ge_half`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    (x y u : ℝ) (hu_pos : 0 < u) (hu_large : 2 * |x| ≤ u) :
    ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y)‖
      ≤ 8 / u^2 := by
  unfold pairedCauchyComplexKernelTrue
  have hsub :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y - (u : ℂ)) hu_pos
      (upperHalfPoint_sub_real_norm_ge_half x y u hu_large)
  have hadd :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y + (u : ℂ)) hu_pos
      (upperHalfPoint_add_real_norm_ge_half x y u hu_large)
  calc
    ‖(1 : ℂ) / (upperHalfPoint x y - (u : ℂ))^2
        - (1 : ℂ) / (upperHalfPoint x y + (u : ℂ))^2‖
        ≤ ‖(1 : ℂ) / (upperHalfPoint x y - (u : ℂ))^2‖
          + ‖(1 : ℂ) / (upperHalfPoint x y + (u : ℂ))^2‖ := norm_sub_le _ _
    _ ≤ 4 / u^2 + 4 / u^2 := add_le_add hsub hadd
    _ = 8 / u^2 := by ring

/-- 🌟🌟 **PROVED — eventual `8/u²` bound on the true kernel.** For
each `(x, y)`, the bound holds for all sufficiently large `u` (i.e.
`u > 0` and `u ≥ 2|x|`). This is the form needed by
`improperComplexIntegralConverges_of_normMajorant`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually
    (x y : ℝ) :
    ∀ᶠ u in Filter.atTop,
      ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y)‖
        ≤ 8 / u^2 := by
  filter_upwards
    [Filter.eventually_gt_atTop (0 : ℝ),
     Filter.eventually_ge_atTop (2 * |x|)]
    with u hu_pos hu_large
  exact norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    x y u hu_pos hu_large

-- =====================================================================
-- §CCXXIX-4a. True-kernel log majorant and its convergence
-- =====================================================================
-- Defines the real majorant `(8/u²)(C log u + D)` for the true-kernel
-- integrand, computes its explicit primitive `-8(C(log u + 1) + D)/u`,
-- and proves convergence of `∫_T^X majorant → -primitive(T)`. The proof
-- mirrors §CCIII's `derivativeSideMajorantConverges` chain.
--
-- Adds:
--   trueKernelLogMajorant                     — `(8/u²)(C log u + D)`
--   trueKernelLogMajorantPrimitive            — explicit primitive
--   hasDerivAt_trueKernelLogMajorantPrimitive — derivative identity
--   trueKernelLogMajorant_continuousOn_Icc
--   trueKernelLogMajorant_intervalIntegrable
--   trueKernelLogMajorant_integral_eq_sub     — FTC
--   log_div_id_atTop_tendsto_zero             — `log x / x → 0`
--   trueKernelLogMajorantPrimitive_tendsto_zero
--   trueKernelLogMajorantConverges            — improper convergence

/-- **True-kernel log majorant**: `(8/u²) · (C log u + D)`. Real
upper bound for `‖trueKernel u z · S u‖` when `|S u| ≤ C log u + D`
and `u` is large enough that `‖trueKernel u z‖ ≤ 8/u²`. -/
noncomputable def trueKernelLogMajorant
    (C D : ℝ) (u : ℝ) : ℝ :=
  8 * (C * Real.log u + D) / u^2

/-- **Explicit primitive** of `trueKernelLogMajorant` on `u > 0`:
  `P(u) = -8(C(log u + 1) + D) / u`. -/
noncomputable def trueKernelLogMajorantPrimitive
    (C D : ℝ) (u : ℝ) : ℝ :=
  -8 * (C * (Real.log u + 1) + D) / u

/-- 🌟 **PROVED — `P'(u) = M(u)`** for `u > 0`. -/
lemma hasDerivAt_trueKernelLogMajorantPrimitive
    (C D u : ℝ) (hu : 0 < u) :
    HasDerivAt
      (fun t => trueKernelLogMajorantPrimitive C D t)
      (trueKernelLogMajorant C D u)
      u := by
  unfold trueKernelLogMajorantPrimitive trueKernelLogMajorant
  have hu_ne : u ≠ 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have h_log : HasDerivAt Real.log u⁻¹ u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * (Real.log t + 1) + D) (C * u⁻¹) u := by
    have h1 := h_log.add_const (1 : ℝ)
    have h2 := h1.const_mul C
    exact h2.add_const D
  have h_id : HasDerivAt (fun t : ℝ => t) (1 : ℝ) u := hasDerivAt_id u
  have h_div : HasDerivAt
      (fun t : ℝ => (C * (Real.log t + 1) + D) / t)
      ((C * u⁻¹ * u - (C * (Real.log u + 1) + D) * 1) / u^2) u :=
    h_g.div h_id hu_ne
  have h_neg8 : HasDerivAt
      (fun t : ℝ => -8 * ((C * (Real.log t + 1) + D) / t))
      (-8 * ((C * u⁻¹ * u - (C * (Real.log u + 1) + D) * 1) / u^2)) u :=
    h_div.const_mul (-8)
  have h_fun_eq :
      (fun t : ℝ => -8 * ((C * (Real.log t + 1) + D) / t))
      = (fun t : ℝ => -8 * (C * (Real.log t + 1) + D) / t) := by
    funext t; ring
  rw [h_fun_eq] at h_neg8
  have h_val :
      -8 * ((C * u⁻¹ * u - (C * (Real.log u + 1) + D) * 1) / u^2)
        = 8 * (C * Real.log u + D) / u^2 := by
    field_simp
    ring
  rw [h_val] at h_neg8
  exact h_neg8

/-- ⭐ **PROVED — majorant is continuous on `[T, X]`** for `0 < T ≤ X`. -/
lemma trueKernelLogMajorant_continuousOn_Icc
    (C D T X : ℝ) (hT : 0 < T) (_hTX : T ≤ X) :
    ContinuousOn (fun u => trueKernelLogMajorant C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold trueKernelLogMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.div ?_ ?_ ?_
  · refine continuousAt_const.mul ?_
    refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  · exact continuousAt_id.pow 2
  · exact pow_ne_zero 2 (ne_of_gt hu_pos)

/-- ⭐ **PROVED — majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma trueKernelLogMajorant_intervalIntegrable
    (C D T X : ℝ) (hT : 0 < T) (hTX : T ≤ X) :
    IntervalIntegrable (fun u => trueKernelLogMajorant C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (trueKernelLogMajorant_continuousOn_Icc C D T X hT hTX)

/-- 🌟 **PROVED — FTC for the majorant**:
  `∫_T^X M(u) du = P(X) − P(T)`. -/
lemma trueKernelLogMajorant_integral_eq_sub
    (C D T X : ℝ) (hT : 0 < T) (hTX : T ≤ X) :
    (∫ u in T..X, trueKernelLogMajorant C D u)
      = trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  · intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_trueKernelLogMajorantPrimitive C D u hu_pos
  · exact trueKernelLogMajorant_intervalIntegrable C D T X hT hTX

/-- ⭐ **PROVED — `log X / X → 0`** as `X → ∞`. Via Mathlib's
`Real.tendsto_pow_log_div_mul_add_atTop` specialized to `n = 1, a = 1,
b = 0`. -/
lemma log_div_id_atTop_tendsto_zero :
    Tendsto (fun X : ℝ => Real.log X / X) Filter.atTop (𝓝 0) := by
  have := Real.tendsto_pow_log_div_mul_add_atTop (1 : ℝ) (0 : ℝ) 1
    (by norm_num : (1 : ℝ) ≠ 0)
  simpa using this

/-- 🌟 **PROVED — `P(X) → 0`** as `X → ∞`. The primitive splits as
constant multiples of `log X / X` and `1/X`, both vanishing. -/
lemma trueKernelLogMajorantPrimitive_tendsto_zero
    (C D : ℝ) :
    Tendsto (fun X : ℝ => trueKernelLogMajorantPrimitive C D X)
      Filter.atTop (𝓝 0) := by
  unfold trueKernelLogMajorantPrimitive
  have h_logterm : Tendsto (fun X : ℝ => (-8 * C) * (Real.log X / X))
      Filter.atTop (𝓝 ((-8 * C) * 0)) :=
    log_div_id_atTop_tendsto_zero.const_mul (-8 * C)
  have h_constterm : Tendsto (fun X : ℝ => (-8 * (C + D)) * (1 / X))
      Filter.atTop (𝓝 ((-8 * (C + D)) * 0)) :=
    (Phase1IBP.const_div_tendsto_zero_atTop (1 : ℝ)).const_mul (-8 * (C + D))
  have h_sum : Tendsto (fun X : ℝ =>
      (-8 * C) * (Real.log X / X) + (-8 * (C + D)) * (1 / X))
      Filter.atTop (𝓝 ((-8 * C) * 0 + (-8 * (C + D)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-8 * C) * 0 + (-8 * (C + D)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : ℝ)] with X hX
  have hX_ne : X ≠ 0 := ne_of_gt hX
  field_simp
  ring

/-- 🌟🌟🌟 **PROVED — `trueKernelLogMajorantConverges`** for any `C, D,
T > 0`. The limit is `-P(T)`. -/
theorem trueKernelLogMajorantConverges
    (C D T : ℝ) (hT : 0 < T) :
    Tendsto (fun X : ℝ => ∫ u in T..X, trueKernelLogMajorant C D u)
      Filter.atTop (𝓝 (-trueKernelLogMajorantPrimitive C D T)) := by
  have hprim0 := trueKernelLogMajorantPrimitive_tendsto_zero C D
  have hconst : Tendsto (fun _ : ℝ => trueKernelLogMajorantPrimitive C D T)
      Filter.atTop (𝓝 (trueKernelLogMajorantPrimitive C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : ℝ =>
      trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T) Filter.atTop
      (𝓝 (0 - trueKernelLogMajorantPrimitive C D T)) :=
    hprim0.sub hconst
  rw [show (0 - trueKernelLogMajorantPrimitive C D T
            = -trueKernelLogMajorantPrimitive C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  exact (trueKernelLogMajorant_integral_eq_sub C D T X hT hTX).symm

-- =====================================================================
-- §CCXXIX-4b. True-kernel adaptive complex convergence (`conv` field)
-- =====================================================================
-- Combines §CCXXIX (Cauchy comparison) + §CCXXIX-3 (kernel norm bound)
-- + §CCXXIX-4a (log majorant convergence) + §CCXXVI Turing log envelope
-- into the `conv` field of `TrueKernelTailData` for the finite-fluctuation
-- `S = finiteFluctuationPrimitive Dzero T0`.
--
-- Adds:
--   trueKernel_integrand_norm_le_logMajorant_eventually
--   trueKernelComplexTail_converges_at
--   trueKernelAdaptiveTail
--   adaptiveComplexConverges_trueKernel_of_turingBound

/-- 🌟🌟 **PROVED — true-kernel integrand norm-majorant.** Given an
eventual log envelope on `|S u|`, the complex integrand
`‖trueKernel u (UHP x y) · (S u : ℂ)‖` is eventually bounded by
`trueKernelLogMajorant C D u`. -/
lemma trueKernel_integrand_norm_le_logMajorant_eventually
    {S : ℝ → ℝ} {C D x y : ℝ}
    (hS : ∀ᶠ u in Filter.atTop, |S u| ≤ C * Real.log u + D) :
    ∀ᶠ u in Filter.atTop,
      ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : ℂ)‖
        ≤ trueKernelLogMajorant C D u := by
  filter_upwards
    [norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually x y, hS]
    with u hk hSu
  have hS_norm : ‖(S u : ℂ)‖ = |S u| := by simp
  have hS_bound : ‖(S u : ℂ)‖ ≤ C * Real.log u + D := by
    rw [hS_norm]; exact hSu
  have henv_nonneg : 0 ≤ C * Real.log u + D :=
    le_trans (norm_nonneg ((S u : ℂ))) hS_bound
  have h_eight_nn : 0 ≤ (8 : ℝ) / u^2 := by
    have hnn : 0 ≤ ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y)‖ :=
      norm_nonneg _
    linarith [hnn]
  calc
    ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : ℂ)‖
        = ‖pairedCauchyComplexKernelTrue u (upperHalfPoint x y)‖
            * ‖(S u : ℂ)‖ := by rw [norm_mul]
    _ ≤ (8 / u^2) * (C * Real.log u + D) :=
          mul_le_mul hk hS_bound (norm_nonneg _) h_eight_nn
    _ = trueKernelLogMajorant C D u := by
          unfold trueKernelLogMajorant
          ring

/-- 🌟🌟🌟 **PROVED — pointwise complex convergence at adaptive `(z, T)`.**
For each `(z, T)` in the adaptive band, the complex partial integrals
of `trueKernel · finiteFluctuation` over `[T, X]` converge as `X → ∞`.
Routes through `improperComplexIntegralConverges_of_normMajorant` with
the log majorant from §CCXXIX-4a and the integrability from §CCXXVIII. -/
theorem trueKernelComplexTail_converges_at
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : ℂ} {T : ℝ}
    (h10 : 10 ≤ T) (h140 : T ≤ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T) :
    ∃ L : ℂ,
      Tendsto
        (fun X : ℝ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop (𝓝 L) := by
  have hTpos : 0 < T := lt_of_lt_of_le (by norm_num : (0 : ℝ) < 10) h10
  have hMconv :
      Tendsto (fun X : ℝ =>
          ∫ u in T..X,
            trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u)
        Filter.atTop
        (𝓝 (-trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)) :=
    trueKernelLogMajorantConverges (slabCD T).1 (slabCD T).2 T hTpos
  have hS_eventual :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hTu
    exact hTuring h10 h140 hy hregime hTu
  have hbound_uhp :=
    trueKernel_integrand_norm_le_logMajorant_eventually
      (S := fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) hS_eventual
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hbound :
      ∀ᶠ u in Filter.atTop,
        ‖pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ)‖
          ≤ trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u := by
    filter_upwards [hbound_uhp] with u hu
    rw [hzUHP] at hu
    exact hu
  apply improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      pairedCauchyComplexKernelTrue u z *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
    (M := trueKernelLogMajorant (slabCD T).1 (slabCD T).2)
    (T := T)
    (LM := -trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)
  · intro X hTX
    exact true_int_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 h10 h140 hy hregime hTX
  · intro X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      (slabCD T).1 (slabCD T).2 T X hTpos hTX
  · exact hMconv
  · exact hbound

/-- **Adaptive tail value for the true kernel.** Uses `Classical.choose`
to extract the limit guaranteed by `trueKernelComplexTail_converges_at`
inside the adaptive band; outside the band, defined as 0. -/
noncomputable def trueKernelAdaptiveTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (T : ℝ) (z : ℂ) : ℂ :=
  if h : 10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧
      2 * (1 + |z.re| + z.im) ≤ T then
    Classical.choose
      (trueKernelComplexTail_converges_at
        Dzero T0 hT0_pos hT0_le_10 hTuring
        h.1 h.2.1 h.2.2.1 h.2.2.2)
  else
    0

/-- 🌟🌟🌟🌟 **PROVED — true-kernel adaptive complex convergence.**
The full `conv` field of `TrueKernelTailData` for the finite-fluctuation
`S`. Uses `Classical.choose_spec` to identify the tail value with the
guaranteed limit, then transports via `dif_pos` for the adaptive band. -/
noncomputable def adaptiveComplexConverges_trueKernel_of_turingBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2) :
    AdaptiveComplexDensityTailFamilyConverges
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) where
  tail := trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring
  tendsto := by
    intro T z h10 h140 hy hregime
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
    have hregion :
        10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
      ⟨h10, h140, hy, hregime⟩
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists

-- =====================================================================
-- §CCXXX. atTop-oriented `TrueKernelTailDataAtTop` + concrete inhabitation
-- =====================================================================
-- Resolves the `T ≤ X` mismatch: the §CCXXVII / §CCXXVIII integrability
-- proofs require `T ≤ X`, but `TrueKernelTailData.true_int / wrap_int`
-- quantify over all `X`. Since improper tails only use `X → ∞`, we
-- introduce an atTop-oriented data structure and build the
-- `ActualDensityTailData` / capstone chain from it directly,
-- bypassing the unnatural `X < T` case.
--
-- Adds:
--   TrueKernelTailDataAtTop                        — atTop-oriented Type bundle
--   trueKernel_im_eq_realPartial_eventually        — eventual Im match (atTop)
--   hbound_of_TrueKernelTailDataAtTop              — produces hbound field
--   actualDensityTailData_of_trueKernelTailDataAtTop
--   localXiPackage_of_TrueKernelTailDataAtTop
--   trueKernelTailDataAtTop_of_finiteFluctuation   — concrete instantiation
--   XiPullbackAntiHerglotzTarget_of_trueKernelTailDataAtTop
--                                                  — final capstone
--   XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTailDataAtTop

/-- 📦 **`TrueKernelTailDataAtTop`** — atTop-oriented true-kernel tail
data. Mirrors `TrueKernelTailData` but with `true_int` / `wrap_int`
restricted to `T ≤ X` (matching the §CCXXVII–§CCXXVIII signatures and
the actual improper-tail use case `X → ∞`). -/
structure TrueKernelTailDataAtTop
    (S : ℝ → ℝ) (R : RealIBPFamilyData S) (error : ℂ → ℂ) where
  conv : AdaptiveComplexDensityTailFamilyConverges
            pairedCauchyComplexKernelTrue S
  true_int_atTop :
    ∀ {z : ℂ} {T X : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u z * (S u : ℂ))
        MeasureTheory.volume T X
  wrap_int_atTop :
    ∀ {z : ℂ} {T X : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u z * (S u : ℂ))
        MeasureTheory.volume T X
  error_im_eq_tail_im :
    ∀ {z : ℂ} {T : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im = (conv.tail T z).im

/-- 🌟🌟 **PROVED — eventual Im match for true kernel, atTop form.**
For each `(z, T)` in the adaptive band and atTop-restricted true/wrap
integrability, the imaginary part of the true-kernel complex partial
eventually equals the real derivative-side partial. -/
lemma trueKernel_im_eq_realPartial_eventually
    (S : ℝ → ℝ) (T : ℝ) (z : ℂ)
    (htrue_int : ∀ X, T ≤ X →
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u z * (S u : ℂ))
          MeasureTheory.volume T X)
    (hwrap_int : ∀ X, T ≤ X →
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u z * (S u : ℂ))
          MeasureTheory.volume T X) :
    ∀ᶠ X in Filter.atTop,
      (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im
        =
      Phase1IBP.derivativeSidePartial S z.re z.im T X := by
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have htrue_int_uhp : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                    * (S u : ℂ))
        MeasureTheory.volume T X := by
    intro X hTX; rw [hzUHP]; exact htrue_int X hTX
  have hwrap_int_uhp : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                    * (S u : ℂ))
        MeasureTheory.volume T X := by
    intro X hTX; rw [hzUHP]; exact hwrap_int X hTX
  have hwrap_match :=
    complexTailImaginaryPartMatchesRealIBP_pairedDeriv S z.re z.im T
  filter_upwards [hwrap_match.finite_im_eq, Filter.eventually_ge_atTop T]
    with X hwrap hTX
  have h_eq_partials :
      (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X
          (upperHalfPoint z.re z.im)).im
        =
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X
          (upperHalfPoint z.re z.im)).im :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible S z.re z.im T X
      (htrue_int_uhp X hTX) (hwrap_int_uhp X hTX)
  rw [hzUHP] at h_eq_partials hwrap
  rw [h_eq_partials]
  exact hwrap

/-- 🌟🌟🌟 **PROVED — `hbound` from `TrueKernelTailDataAtTop`.** Mirrors
`hbound_of_adaptiveComplexTailIBPBoundData` but using the eventual
finite-Im match `trueKernel_im_eq_realPartial_eventually` directly. -/
theorem hbound_of_TrueKernelTailDataAtTop
    {S : ℝ → ℝ} {R : RealIBPFamilyData S} {error : ℂ → ℂ}
    (D : TrueKernelTailDataAtTop S R error) :
    ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain ⟨J, hJ⟩ := R.deriv_tendsto h10 h140 hy hregime
  have htail_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im)
        Filter.atTop (𝓝 (D.conv.tail T z).im) :=
    adaptiveComplexDensityTailFamilyPartial_im_tendsto D.conv h10 h140 hy hregime
  have hmatch_ev := trueKernel_im_eq_realPartial_eventually S T z
    (fun X hTX => D.true_int_atTop h10 h140 hy hregime hTX)
    (fun X hTX => D.wrap_int_atTop h10 h140 hy hregime hTX)
  have hmatch : Tendsto
      (fun X : ℝ =>
        (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im)
      Filter.atTop (𝓝 J) := by
    have heq :
        (fun X : ℝ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          =ᶠ[Filter.atTop]
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im) := by
      filter_upwards [hmatch_ev] with X hX
      exact hX.symm
    exact Tendsto.congr' heq hJ
  have huniq : (D.conv.tail T z).im = J :=
    tendsto_nhds_unique htail_im hmatch
  rw [D.error_im_eq_tail_im h10 h140 hy hregime, huniq]
  exact R.deriv_bound h10 h140 hy hregime hJ

/-- 🌟🌟🌟🌟 **PROVED — `ActualDensityTailData` from
`TrueKernelTailDataAtTop`.** Threads the atTop data into the local
package chain via `hbound_of_TrueKernelTailDataAtTop`. -/
noncomputable def actualDensityTailData_of_trueKernelTailDataAtTop
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailDataAtTop S R error) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound_of_TrueKernelTailDataAtTop D

/-- 🌟🌟🌟🌟🌟 **PROVED — local package from
`TrueKernelTailDataAtTop`.** -/
noncomputable def localXiPackage_of_TrueKernelTailDataAtTop
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailDataAtTop S R error) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_of_actualTailData
    (actualDensityTailData_of_trueKernelTailDataAtTop
      S R M hM_zeros hmodelAnti error hdecomp D)

/-- 🌟🌟🌟🌟🌟🌟 **CONDITIONAL CAPSTONE (atTop form).** -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailDataAtTop
    (S : ℝ → ℝ) (R : RealIBPFamilyData S)
    (Model : ActualCloudDensityModelData)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (D : TrueKernelTailDataAtTop S R error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget := by
  let midPackage : LocalXiCloudDensityErrorPackage :=
    localXiPackage_of_TrueKernelTailDataAtTop
      S R Model.M Model.hM_zeros Model.hmodelAnti error hdecomp D
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n => if n = 0 then midPackage else Cover.extras (n - 1)
      covers := ?_ }
  intro z hz
  rcases Cover.covers z hz with hmid | ⟨n, hn⟩
  · refine ⟨0, ?_⟩
    show midPackage.region z
    exact hmid
  · refine ⟨n + 1, ?_⟩
    show (if (n + 1) = 0 then midPackage
          else Cover.extras (n + 1 - 1)).region z
    simp
    exact hn

/-- 🌟🌟🌟 **PROVED — `TrueKernelTailDataAtTop` for the concrete finite
fluctuation primitive (Turing-gated).** Assembles `conv` from §CCXXIX-4b,
`true_int_atTop` from §CCXXVIII, `wrap_int_atTop` from §CCXXVII; the
`error_im_eq_tail_im` field remains user-supplied (xi-specific). -/
noncomputable def trueKernelTailDataAtTop_of_finiteFluctuation
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : ℂ → ℂ)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im =
          ((adaptiveComplexConverges_trueKernel_of_turingBound
              Dzero T0 hT0_pos hT0_le_10 hTuring).tail T z).im) :
    TrueKernelTailDataAtTop
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (realIBPFamilyData_of_finiteFluctuation_turingBound
        Dzero T0 hT0_pos hT0_le_10 hTuring)
      error where
  conv := adaptiveComplexConverges_trueKernel_of_turingBound
    Dzero T0 hT0_pos hT0_le_10 hTuring
  true_int_atTop := by
    intro z T X h10 h140 hy hregime hTX
    exact true_int_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 h10 h140 hy hregime hTX
  wrap_int_atTop := by
    intro z T X h10 h140 hy hregime hTX
    exact wrap_int_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 h10 h140 hy hregime hTX
  error_im_eq_tail_im := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime

/-- 🌟🌟🌟🌟🌟🌟🌟 **FINAL CAPSTONE for the finite-fluctuation atTop
chain.** Combines `trueKernelTailDataAtTop_of_finiteFluctuation` with
the atTop capstone. The only xi-specific obligations remaining are
`hTuring` (Turing bound), `Model`, `hdecomp`, `herror`, and `Cover`. -/
theorem XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTailDataAtTop
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (herror :
      ∀ {z : ℂ} {T : ℝ}, 10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im =
          ((adaptiveComplexConverges_trueKernel_of_turingBound
              Dzero T0 hT0_pos hT0_le_10 hTuring).tail T z).im)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailDataAtTop
    (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
    (realIBPFamilyData_of_finiteFluctuation_turingBound
      Dzero T0 hT0_pos hT0_le_10 hTuring)
    Model error hdecomp
    (trueKernelTailDataAtTop_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 hTuring error herror)
    Cover

-- =====================================================================
-- §CCXXXI. Xi actual tail decomposition package
-- =====================================================================
-- Bundles the `Model + hdecomp + herror` cluster of the finite-fluctuation
-- atTop capstone into a single named structure, so the front door
-- exposes just three objects: Turing bound, decomposition data, cover.
--
-- Adds:
--   XiActualTailDecompositionData
--   XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData

/-- 📦 **`XiActualTailDecompositionData`** — bundles the xi-specific
analytic decomposition obligations for the finite-fluctuation atTop
chain:

* `Model` — the actual cloud + density-tail model (`zeros = zeros100ceil`,
  `AntiHerglotzUHP M.model`);
* `error` — the IBP residual error;
* `hdecomp` — xi log-derivative decomposition
  `Λ[Ξ] z = Model.M.model z + error z` on the adaptive band;
* `herror` — the residual's imaginary part matches the true-kernel
  adaptive tail's imaginary part.

This is a `Type` (not `Prop`) because `Model.M` carries data.
Parameterized by the Turing-bound hypothesis so `herror` can reference
the constructed tail `trueKernelAdaptiveTail`. -/
structure XiActualTailDecompositionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2) where
  Model   : ActualCloudDensityModelData
  error   : ℂ → ℂ
  hdecomp :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
      logDerivativeResponse XiPullback z = Model.M.model z + error z
  herror :
    ∀ {z : ℂ} {T : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im =
        (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im

/-- 🌟🌟🌟🌟🌟🌟🌟 **CLEAN FRONT DOOR — `XiPullbackAntiHerglotzTarget`
from `XiActualTailDecompositionData`.** Three explicit inputs:

* `hTuring` — Turing/Backlund log envelope (parallel agent);
* `X : XiActualTailDecompositionData …` — bundled xi decomposition;
* `Cover : LowHighBandCoverData` — low/high band coverage.

⟹ `XiPullbackAntiHerglotzTarget`.

This is the cleanest possible final dependency surface for the
finite-fluctuation Route B. The decomposition's `herror` is the only
xi-specific obligation in `XiActualTailDecompositionData` that isn't
forced by the model fields. -/
theorem XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (X : XiActualTailDecompositionData Dzero T0 hT0_pos hT0_le_10 hTuring)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTailDataAtTop
    Dzero T0 hT0_pos hT0_le_10 hTuring
    X.Model X.error X.hdecomp X.herror Cover

-- =====================================================================
-- §CCXXXII. Modular `ActualCloudDensityModelData` constructor
-- =====================================================================
-- Reduces `ActualCloudDensityModelData` to a smaller analytic surface:
-- a CloudTailDecomposition (cloud + tail anti-Herglotz) + the zeros
-- compatibility. The finite-cloud anti-Herglotz piece is discharged by
-- the §12-C `positive_paired_cloud_antiHerglotz` theorem; the tail
-- anti-Herglotz piece is exposed as a separate named structure
-- `SmoothDensityTailModelData`.
--
-- Adds:
--   actualCloudDensityModelData_of_cloudTailDecomposition
--     — bundles `CloudTailDecomposition` + zeros compatibility
--   pairedFiniteCloudFromZeros                     — concrete finite cloud
--   pairedFiniteCloudFromZeros_antiHerglotz        — wrapper around §12-C
--   SmoothDensityTailModelData                     — abstracts the tail
--   actualCloudDensityModelData_of_smoothTail
--     — combines finite cloud + smooth tail + zeros + model equation

/-- 🌟🌟🌟 **PROVED — `ActualCloudDensityModelData` from
`CloudTailDecomposition`.** The cloud+tail bundle plus the zeros
compatibility gives the full model bundle. `hmodelAnti` is discharged
by `CloudTailDecomposition.antiHerglotz`. -/
noncomputable def actualCloudDensityModelData_of_cloudTailDecomposition
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (D : CloudTailDecomposition M.model) :
    ActualCloudDensityModelData where
  M           := M
  hM_zeros    := hzeros
  hmodelAnti  := D.antiHerglotz

/-- **Paired finite cloud from a real-zero list.** Same shape as the
sum proved anti-Herglotz by `positive_paired_cloud_antiHerglotz`. -/
noncomputable def pairedFiniteCloudFromZeros
    (us : List ℝ) : ℂ → ℂ :=
  fun z : ℂ =>
    (us.map (fun u : ℝ =>
      (1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).sum

/-- ⭐ **PROVED — finite cloud anti-Herglotz.** Direct wrapper around
`positive_paired_cloud_antiHerglotz`. -/
theorem pairedFiniteCloudFromZeros_antiHerglotz (us : List ℝ) :
    AntiHerglotzUHP (pairedFiniteCloudFromZeros us) :=
  positive_paired_cloud_antiHerglotz us

/-- 📦 **`SmoothDensityTailModelData`** — abstracts the smooth/density
tail part of the model as a function with the anti-Herglotz property.
Lets the model-data constructor expose tail anti-Herglotz as a single
explicit field, decoupled from the cloud. -/
structure SmoothDensityTailModelData where
  tailModel : ℂ → ℂ
  tailAnti  : AntiHerglotzUHP tailModel

/-- 🌟🌟🌟🌟 **PROVED — `ActualCloudDensityModelData` from finite cloud
+ smooth tail + model equation.** End-to-end constructor:

* `us` — the finite zero list (will typically be the support of
  `zeros100ceil`);
* `M` — the cloud + density-tail model decomposition;
* `hzeros : M.zeros = zeros100ceil` — zeros compatibility;
* `Tail` — smooth/density tail with anti-Herglotz property;
* `hmodel` — `M.model z = pairedFiniteCloudFromZeros us z + Tail.tailModel z`
  on UHP.

Produces `ActualCloudDensityModelData`. The remaining analytic content
is `Tail` (smooth tail anti-Herglotz — separate construction) and
`hmodel` (model = finite cloud + smooth tail equation). -/
noncomputable def actualCloudDensityModelData_of_smoothTail
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tail : SmoothDensityTailModelData)
    (hmodel : ∀ z : ℂ,
      M.model z = pairedFiniteCloudFromZeros us z + Tail.tailModel z) :
    ActualCloudDensityModelData :=
  actualCloudDensityModelData_of_cloudTailDecomposition M hzeros
    { cloud      := pairedFiniteCloudFromZeros us
      tail       := Tail.tailModel
      decomp     := hmodel
      cloudAnti  := pairedFiniteCloudFromZeros_antiHerglotz us
      tailAnti   := Tail.tailAnti }

-- =====================================================================
-- §CCXXXIII. Explicit `LowHighBandData` (low + high band cover)
-- =====================================================================
-- Replaces the opaque `LowHighBandCoverData.extras : ℕ → ...` with a
-- two-named-package structure (`lowPackage`, `highPackage`) and a
-- three-way UHP cover (mid / low / high). Functionally equivalent —
-- bridges to `LowHighBandCoverData` via `toCoverData`.
--
-- Adds:
--   LowHighBandData                                    — two named packages
--   LowHighBandData.toCoverData                        — bridge
--   XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData_lowHigh
--                                                      — clean front door

/-- 📦 **`LowHighBandData`** — explicit low/high band coverage.
Replaces the abstract `extras : ℕ → LocalXiCloudDensityErrorPackage`
with two named packages and a three-way cover (mid / low / high). -/
structure LowHighBandData where
  lowPackage  : LocalXiCloudDensityErrorPackage
  highPackage : LocalXiCloudDensityErrorPackage
  covers :
    ∀ z : ℂ, 0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) ∨
      lowPackage.region z ∨
      highPackage.region z

/-- 🌟 **PROVED — `LowHighBandData.toCoverData`.** Bridge to the existing
abstract `LowHighBandCoverData`. Uses `extras 0 := lowPackage`,
`extras (n+1) := highPackage`. -/
noncomputable def LowHighBandData.toCoverData
    (B : LowHighBandData) : LowHighBandCoverData where
  extras := fun n => if n = 0 then B.lowPackage else B.highPackage
  covers := by
    intro z hz
    rcases B.covers z hz with hmid | hlow | hhigh
    · exact Or.inl hmid
    · refine Or.inr ⟨0, ?_⟩
      show (if (0 : ℕ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hlow
    · refine Or.inr ⟨1, ?_⟩
      show (if (1 : ℕ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hhigh

/-- 🌟🌟🌟🌟🌟🌟🌟 **CLEAN FRONT DOOR (explicit low/high cover).**
Final form using `XiActualTailDecompositionData` and `LowHighBandData`.
The cleanest possible statement of Route B's conditional capstone:

```
hTuring + XiActualTailDecompositionData + LowHighBandData
⟹ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData_lowHigh
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (X : XiActualTailDecompositionData Dzero T0 hT0_pos hT0_le_10 hTuring)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData
    Dzero T0 hT0_pos hT0_le_10 hTuring X B.toCoverData

-- =====================================================================
-- §CCXXXIV. Xi log-derivative decomposition packaging
-- =====================================================================
-- Splits the opaque `hdecomp` field of `XiActualTailDecompositionData`
-- into the three analytic pieces actually expected from the xi
-- log-derivative formula:
--   • finite real-zero cloud
--   • smooth density tail model
--   • fluctuation/error tail
-- The model `M.model` equals (cloud + smooth tail), and `error` equals
-- the fluctuation tail. The unpacked `xi_decomp` field is exactly the
-- theorem an analytic prover wants to discharge.
--
-- Adds:
--   XiLogDerivativeDecompositionPieces                  — three-piece bundle
--   hdecomp_of_XiLogDerivativeDecompositionPieces       — bridge to hdecomp
--   XiActualTailDecompositionData.ofPieces              — clean constructor

/-- 📦 **`XiLogDerivativeDecompositionPieces M error`** — three-piece
unpacking of the xi log-derivative decomposition:

* `finiteCloudPart` — the finite real-zero cloud sum;
* `smoothTailPart` — the smooth density-tail model;
* `fluctTailPart` — the residual fluctuation tail;
* `model_eq` — `M.model = finiteCloudPart + smoothTailPart`;
* `error_eq` — `error = fluctTailPart`;
* `xi_decomp` — `Λ[Ξ] z = finiteCloudPart z + smoothTailPart z + fluctTailPart z`
  on the adaptive band.

This is the natural shape produced by an actual xi log-derivative
formula. The `hdecomp` field of `XiActualTailDecompositionData` then
follows by associativity (see `hdecomp_of_XiLogDerivativeDecompositionPieces`). -/
structure XiLogDerivativeDecompositionPieces
    (M : CloudDensityTailModelDecomposition)
    (error : ℂ → ℂ) where
  finiteCloudPart : ℂ → ℂ
  smoothTailPart  : ℂ → ℂ
  fluctTailPart   : ℂ → ℂ
  model_eq :
    ∀ z : ℂ, M.model z = finiteCloudPart z + smoothTailPart z
  error_eq :
    ∀ z : ℂ, error z = fluctTailPart z
  xi_decomp :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
      logDerivativeResponse XiPullback z =
        finiteCloudPart z + smoothTailPart z + fluctTailPart z

/-- 🌟🌟 **PROVED — `hdecomp` from three-piece decomposition.**
Combines `model_eq`, `error_eq`, `xi_decomp` via associativity. -/
theorem hdecomp_of_XiLogDerivativeDecompositionPieces
    {M : CloudDensityTailModelDecomposition} {error : ℂ → ℂ}
    (P : XiLogDerivativeDecompositionPieces M error) :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
      logDerivativeResponse XiPullback z = M.model z + error z := by
  intro z hz
  rw [P.model_eq z, P.error_eq z]
  exact P.xi_decomp z hz

/-- 🌟🌟🌟🌟 **PROVED — `XiActualTailDecompositionData` from the
three-piece decomposition.** End-to-end constructor: takes the
`Model`, `error`, three-piece `P`, and the `herror` Im-identity;
produces the full `XiActualTailDecompositionData`. Discharges
`hdecomp` automatically via `hdecomp_of_XiLogDerivativeDecompositionPieces`. -/
noncomputable def XiActualTailDecompositionData.ofPieces
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : ℂ → ℂ)
    (P : XiLogDerivativeDecompositionPieces Model.M error)
    (herror :
      ∀ {z : ℂ} {T : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        (error z).im =
          (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im) :
    XiActualTailDecompositionData Dzero T0 hT0_pos hT0_le_10 hTuring where
  Model   := Model
  error   := error
  hdecomp := hdecomp_of_XiLogDerivativeDecompositionPieces P
  herror  := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime

-- =====================================================================
-- §CCXXXV. Smooth density tail model + anti-Herglotz closure
-- =====================================================================
-- Reduces `SmoothDensityTailModelData.tailAnti` to: a partial-integral
-- definition of the smooth tail at finite cutoffs `[T, X]`, an eventual
-- anti-Herglotz property of those partials, and pointwise convergence
-- of the partials to a candidate tail. The limit closure follows from
-- the fact that `AntiHerglotzUHP R := ∀ z (hz : 0 < z.im), (R z).im ≤ 0`
-- is a pointwise sign condition closed under pointwise limits.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto     — reusable closure
--   smoothDensityTailModelPartial                     — finite partial def
--   SmoothDensityTailModelConverges                   — convergence package
--   SmoothDensityTailFiniteAntiData                   — finite anti-Herglotz
--   smoothDensityTailModelData_of_converges           — assembled tailModel

/-- 🌟🌟 **PROVED — `AntiHerglotzUHP` closes under eventual pointwise
limits.** If `F X` is eventually anti-Herglotz and `F X z → f z`
pointwise, then `f` is anti-Herglotz. This is a pure order/topology
lemma: the imaginary part is continuous, so `(F X z).im ≤ 0`
eventually transfers to `(f z).im ≤ 0` via `le_of_tendsto_of_tendsto`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto
    {F : ℝ → ℂ → ℂ} {f : ℂ → ℂ}
    (hF : ∀ᶠ X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : ∀ z, Tendsto (fun X => F X z) Filter.atTop (𝓝 (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto : Tendsto (fun X => (F X z).im) Filter.atTop (𝓝 (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z)
  have hF_im_le : ∀ᶠ X in Filter.atTop, (F X z).im ≤ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **Smooth density tail partial.** Finite `[T, X]` integral of
`ρ(u) · (1/(z-u) + 1/(z+u))`. -/
noncomputable def smoothDensityTailModelPartial
    (ρ : ℝ → ℝ) (T X : ℝ) : ℂ → ℂ :=
  fun z : ℂ =>
    ∫ u in T..X,
      ((ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) +
         (1 : ℂ) / (z + (u : ℂ))))

/-- **Smooth density tail convergence package.** Bundles a candidate
`tailModel : ℂ → ℂ` with pointwise convergence of the finite partials
as `X → ∞`. -/
structure SmoothDensityTailModelConverges
    (ρ : ℝ → ℝ) (T : ℝ) where
  tailModel : ℂ → ℂ
  tendsto   : ∀ z : ℂ,
    Tendsto
      (fun X : ℝ => smoothDensityTailModelPartial ρ T X z)
      Filter.atTop (𝓝 (tailModel z))

/-- **Smooth density tail finite-window anti-Herglotz data.** Asserts
that each finite partial `smoothDensityTailModelPartial ρ T X` is
anti-Herglotz (for `X ≥ T`). This is the analytic obligation a Lean
proof of the integral identity must discharge — for a nonnegative
density `ρ` and a paired Cauchy kernel, this follows by linearity of
the integral and pointwise anti-Herglotz of each `(1/(z-u) + 1/(z+u))`. -/
structure SmoothDensityTailFiniteAntiData
    (ρ : ℝ → ℝ) (T : ℝ) : Prop where
  finiteAnti :
    ∀ X, T ≤ X → AntiHerglotzUHP (smoothDensityTailModelPartial ρ T X)

/-- 🌟🌟🌟 **PROVED — `SmoothDensityTailModelData` from finite-partial
data + convergence.** Composes the §CCXXXV closure theorem with the
finite-anti-Herglotz hypothesis (restricted to `X ≥ T` via
`Filter.eventually_ge_atTop`). -/
noncomputable def smoothDensityTailModelData_of_converges
    (ρ : ℝ → ℝ) (T : ℝ)
    (C : SmoothDensityTailModelConverges ρ T)
    (Hfinite : SmoothDensityTailFiniteAntiData ρ T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto
      (F := fun X => smoothDensityTailModelPartial ρ T X)
    · filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    · exact C.tendsto

-- =====================================================================
-- §CCXXXVI. Finite smooth-density partial anti-Herglotz from ρ ≥ 0
-- =====================================================================
-- Discharges `SmoothDensityTailFiniteAntiData` for any nonnegative
-- density `ρ`:
--   • each `(1/(z-u) + 1/(z+u))` has Im ≤ 0 on UHP (existing
--     `pairedCauchyKernel_im_nonpos_at` from §12-C);
--   • multiplied by `(ρ u : ℂ)` with `ρ u ≥ 0`, the integrand Im ≤ 0;
--   • integrating preserves the sign (Im commutes with the integral
--     via `Complex.imCLM.intervalIntegral_comp_comm`, then
--     `intervalIntegral.integral_nonneg` applied to the negation).
--
-- Adds:
--   smoothDensityTail_integrand_im_nonpos
--   smoothDensityTailModelPartial_im_nonpos
--   smoothDensityTailFiniteAntiData_of_nonneg

/-- ⭐ **PROVED — smooth density integrand has Im ≤ 0 on UHP.**
For `ρ u ≥ 0` and `z.im > 0`:
  `Im[(ρ u : ℂ) · (1/(z-u) + 1/(z+u))] = ρ u · Im[…] ≤ 0`. -/
lemma smoothDensityTail_integrand_im_nonpos
    (ρ : ℝ → ℝ) (T u : ℝ) {z : ℂ}
    (hTu : T ≤ u)
    (hρ : ∀ v, T ≤ v → 0 ≤ ρ v)
    (hz : 0 < z.im) :
    (((ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im) ≤ 0 := by
  have hρu : 0 ≤ ρ u := hρ u hTu
  -- The paired kernel at z is exactly `pairedCauchyKernel u z`.
  have hk_eq : (1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))
             = pairedCauchyKernel u z := rfl
  have hk : ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))).im ≤ 0 := by
    rw [hk_eq]
    exact pairedCauchyKernel_im_nonpos_at z u hz
  -- Im of (real : ℂ) · w = real · w.im
  have him_eq :
      (((ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im)
        = ρ u * ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))).im := by
    simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
  rw [him_eq]
  exact mul_nonpos_of_nonneg_of_nonpos hρu hk

/-- 🌟🌟 **PROVED — `(smoothDensityTailModelPartial ρ T X z).im ≤ 0`**
for `T ≤ X`, `0 < z.im`, and `ρ ≥ 0` on `[T, ∞)`. Routes Im through
the integral via `Complex.imCLM.intervalIntegral_comp_comm`, then
applies `intervalIntegral.integral_nonneg` to the negation. -/
lemma smoothDensityTailModelPartial_im_nonpos
    (ρ : ℝ → ℝ) (T X : ℝ) {z : ℂ}
    (hTX : T ≤ X) (hz : 0 < z.im)
    (hρ_nonneg : ∀ u, T ≤ u → 0 ≤ ρ u)
    (hInt :
      IntervalIntegrable
        (fun u =>
          (ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
        MeasureTheory.volume T X) :
    (smoothDensityTailModelPartial ρ T X z).im ≤ 0 := by
  unfold smoothDensityTailModelPartial
  -- Pull `.im` inside the integral via Complex.imCLM commutation
  have h_imCLM_comm := Complex.imCLM.intervalIntegral_comp_comm
    (μ := MeasureTheory.volume) (a := T) (b := X) hInt
  -- Both sides written with Complex.imCLM, then simp to .im
  have him_eq :
      (∫ u in T..X,
        (ρ u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im
        =
      ∫ u in T..X,
        ((ρ u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im := by
    simpa [Complex.imCLM_apply] using h_imCLM_comm.symm
  rw [him_eq]
  -- Apply nonnegativity to the negation
  have h_neg_nonneg :
      0 ≤ ∫ u in T..X,
        -(((ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im) := by
    apply intervalIntegral.integral_nonneg hTX
    intro u hu
    have hTu : T ≤ u := hu.1
    have hpt := smoothDensityTail_integrand_im_nonpos ρ T u hTu hρ_nonneg hz
    linarith
  have h_int_neg :
      (∫ u in T..X,
        -(((ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im))
        =
      -(∫ u in T..X,
        ((ρ u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im) :=
    intervalIntegral.integral_neg
  linarith

/-- 🌟🌟🌟 **PROVED — `SmoothDensityTailFiniteAntiData` from
nonnegative ρ + finite-window integrability.** Each finite partial
`smoothDensityTailModelPartial ρ T X` is anti-Herglotz on UHP. -/
theorem smoothDensityTailFiniteAntiData_of_nonneg
    (ρ : ℝ → ℝ) (T : ℝ)
    (hρ_nonneg : ∀ u, T ≤ u → 0 ≤ ρ u)
    (hInt :
      ∀ X z, T ≤ X → 0 < z.im →
        IntervalIntegrable
          (fun u =>
            (ρ u : ℂ) *
              ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailFiniteAntiData ρ T where
  finiteAnti := by
    intro X hTX z hz
    exact smoothDensityTailModelPartial_im_nonpos
      ρ T X hTX hz hρ_nonneg (hInt X z hTX hz)

-- =====================================================================
-- §CCXXXVII. Smooth density tail convergence from a norm majorant
-- =====================================================================
-- Discharges `SmoothDensityTailModelConverges ρ T` from a real-valued
-- pointwise majorant whose improper integral converges. Routes through
-- §CCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   SmoothDensityTailMajorantData                       — majorant bundle
--   smoothDensityTailModel_converges_at                 — pointwise existence
--   smoothDensityTailModelConverges_of_majorant         — adaptive package
--   smoothDensityTailModelData_of_majorant_nonneg       — full SmoothTail data

/-- 📦 **`SmoothDensityTailMajorantData ρ T`** — bundles the analytic
input needed to apply `improperComplexIntegralConverges_of_normMajorant`
to the smooth density integrand `(ρ u : ℂ) · (1/(z-u) + 1/(z+u))`:

* `majorant z u` — real majorant function (typically `O(log u / u²)`);
* `majorant_intervalIntegrable` — finite-window integrability;
* `majorant_converges` — improper integral converges;
* `integrand_intervalIntegrable` — finite-window integrability of the
  complex integrand;
* `norm_bound_eventually` — `‖integrand‖ ≤ majorant z u` eventually. -/
structure SmoothDensityTailMajorantData
    (ρ : ℝ → ℝ) (T : ℝ) where
  majorant : ℂ → ℝ → ℝ
  majorant_intervalIntegrable :
    ∀ z X, T ≤ X →
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    ∀ z, ∃ L : ℝ,
      Tendsto (fun X : ℝ => ∫ u in T..X, majorant z u)
        Filter.atTop (𝓝 L)
  integrand_intervalIntegrable :
    ∀ z X, T ≤ X →
      IntervalIntegrable
        (fun u =>
          (ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    ∀ z, ∀ᶠ u in Filter.atTop,
      ‖(ρ u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))‖
        ≤ majorant z u

/-- 🌟🌟 **PROVED — pointwise smooth tail convergence from majorant.**
At each `z`, the smooth density partials converge as `X → ∞`. -/
theorem smoothDensityTailModel_converges_at
    (ρ : ℝ → ℝ) (T : ℝ)
    (H : SmoothDensityTailMajorantData ρ T) (z : ℂ) :
    ∃ L : ℂ,
      Tendsto
        (fun X : ℝ => smoothDensityTailModelPartial ρ T X z)
        Filter.atTop (𝓝 L) := by
  rcases H.majorant_converges z with ⟨LM, hLM⟩
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hTX)
    hLM
    (H.norm_bound_eventually z)

/-- 🌟🌟🌟 **PROVED — `SmoothDensityTailModelConverges` from majorant
data.** Uses `Classical.choose` on the pointwise existence theorem. -/
noncomputable def smoothDensityTailModelConverges_of_majorant
    (ρ : ℝ → ℝ) (T : ℝ)
    (H : SmoothDensityTailMajorantData ρ T) :
    SmoothDensityTailModelConverges ρ T where
  tailModel := fun z =>
    Classical.choose (smoothDensityTailModel_converges_at ρ T H z)
  tendsto := fun z =>
    Classical.choose_spec (smoothDensityTailModel_converges_at ρ T H z)

/-- 🌟🌟🌟🌟 **PROVED — `SmoothDensityTailModelData` from `ρ ≥ 0` +
norm majorant.** End-to-end constructor: nonnegative density + complex
majorant data ⟹ full smooth-tail model data (including
anti-Herglotz). Composes §CCXXXVI's finite-anti discharger with
§CCXXXVII's convergence theorem. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg
    (ρ : ℝ → ℝ) (T : ℝ)
    (hρ_nonneg : ∀ u, T ≤ u → 0 ≤ ρ u)
    (H : SmoothDensityTailMajorantData ρ T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges ρ T
    (smoothDensityTailModelConverges_of_majorant ρ T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ρ T hρ_nonneg
      (fun X z hTX _hz => H.integrand_intervalIntegrable z X hTX))

-- =====================================================================
-- §CCXXXVIII. Smooth density majorant from log-growth + paired kernel
-- =====================================================================
-- Provides a real theorem-producing bridge: a log-growth bound on `|ρ|`
-- plus the paired-Cauchy kernel cancellation `1/(z-u) + 1/(z+u) =
-- 2z/(z² - u²)` gives a `1/u²` decay on the kernel norm, hence a
-- log-over-`u²` majorant for the smooth density integrand. Combined
-- with §CCXXIX-4a's `trueKernelLogMajorant` machinery, this discharges
-- `SmoothDensityTailMajorantData ρ T`.
--
-- Adds:
--   norm_pairedCauchyKernel_le_const_div_sq_eventually
--     — `‖1/(z-u) + 1/(z+u)‖ ≤ 4(‖z‖+1)/u²` for `u` eventually large
--   smoothDensityTailMajorantData_of_logGrowth
--     — full constructor with explicit log envelope on `|ρ|`

/-- 🌟🌟 **PROVED — paired Cauchy kernel norm `1/u²` decay.** For each
fixed `z`, eventually `‖1/(z-u) + 1/(z+u)‖ ≤ 4(‖z‖+1)/u²`. Proof: use
the cancellation identity `1/(z-u) + 1/(z+u) = 2z/(z²-u²)` (existing
`pairedCauchyKernel_eq_two_mul`), bound `‖z² - u²‖ ≥ u²/2` for `u`
large via reverse triangle, and conclude. -/
lemma norm_pairedCauchyKernel_le_const_div_sq_eventually
    (z : ℂ) :
    ∀ᶠ u : ℝ in Filter.atTop,
      ‖(1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))‖
        ≤ 4 * (‖z‖ + 1) / u^2 := by
  filter_upwards
    [Filter.eventually_ge_atTop (2 * (‖z‖ + 1)),
     Filter.eventually_gt_atTop (0 : ℝ)]
    with u hu_large hu_pos
  have h_z_nn : 0 ≤ ‖z‖ := norm_nonneg z
  have h_u_pos_sq : 0 < u^2 := by positivity
  have h_2_zp1_nn : (0 : ℝ) ≤ 2 * (‖z‖ + 1) := by linarith
  have h_u_sq_ge : (2 * (‖z‖ + 1))^2 ≤ u^2 := by
    have := mul_self_le_mul_self h_2_zp1_nn hu_large
    nlinarith [this]
  have h_diff_bound : u^2 / 2 ≤ u^2 - ‖z‖^2 := by
    nlinarith [h_u_sq_ge, h_z_nn]
  have h_norm_u_sq : ‖((u : ℂ))^2‖ = u^2 := by
    have h_pow : ((u : ℂ))^2 = ((u^2 : ℝ) : ℂ) := by push_cast; ring
    rw [h_pow, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (sq_nonneg u)]
  have h_norm_z_sq : ‖z^2‖ = ‖z‖^2 := by
    rw [pow_two, pow_two, norm_mul]
  have h_rev_tri : u^2 - ‖z‖^2 ≤ ‖z^2 - (u : ℂ)^2‖ := by
    have h := norm_sub_norm_le ((u : ℂ)^2) (z^2)
    rw [h_norm_u_sq, h_norm_z_sq, ← norm_sub_rev] at h
    exact h
  have h_diff_lower : u^2 / 2 ≤ ‖z^2 - (u : ℂ)^2‖ :=
    le_trans h_diff_bound h_rev_tri
  have h_u_half_pos : 0 < u^2 / 2 := by linarith
  have h_diff_norm_pos : 0 < ‖z^2 - (u : ℂ)^2‖ :=
    lt_of_lt_of_le h_u_half_pos h_diff_lower
  have h_diff_ne : z^2 - (u : ℂ)^2 ≠ 0 := norm_pos_iff.mp h_diff_norm_pos
  have h_z_sq_ne : z^2 ≠ (u : ℂ)^2 := sub_ne_zero.mp h_diff_ne
  have h_kernel_eq :
      (1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))
        = 2 * z / (z^2 - (u : ℂ)^2) := by
    have := pairedCauchyKernel_eq_two_mul u z h_z_sq_ne
    unfold pairedCauchyKernel at this
    exact this
  rw [h_kernel_eq, norm_div]
  have h_num_norm : ‖(2 : ℂ) * z‖ = 2 * ‖z‖ := by
    rw [norm_mul]; simp
  rw [h_num_norm]
  have h_2z_nn : 0 ≤ 2 * ‖z‖ := by linarith
  calc 2 * ‖z‖ / ‖z^2 - (u : ℂ)^2‖
      ≤ 2 * ‖z‖ / (u^2 / 2) :=
        div_le_div_of_nonneg_left h_2z_nn h_u_half_pos h_diff_lower
    _ = 4 * ‖z‖ / u^2 := by field_simp; ring
    _ ≤ 4 * (‖z‖ + 1) / u^2 := by
        gcongr
        linarith

/-- 🌟🌟🌟🌟 **PROVED — `SmoothDensityTailMajorantData` from log growth.**
Given a log envelope `|ρ u| ≤ A log u + B` and finite-window
integrability of the integrand, produces the full majorant bundle.
The constructed majorant is
`majorant z u := trueKernelLogMajorant ((‖z‖+1)·A/2) ((‖z‖+1)·B/2) u`
= `4(‖z‖+1)·(A log u + B)/u²`. -/
noncomputable def smoothDensityTailMajorantData_of_logGrowth
    (ρ : ℝ → ℝ) (T : ℝ) (A B : ℝ)
    (_hA_nn : 0 ≤ A) (_hB_nn : 0 ≤ B)
    (hTpos : 0 < T)
    (hρ_bound : ∀ᶠ u in Filter.atTop, |ρ u| ≤ A * Real.log u + B)
    (hρ_int :
      ∀ z X, T ≤ X →
        IntervalIntegrable
          (fun u =>
            (ρ u : ℂ) *
              ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantData ρ T where
  majorant := fun z u =>
    trueKernelLogMajorant ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z
    refine ⟨-trueKernelLogMajorantPrimitive
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T, ?_⟩
    exact trueKernelLogMajorantConverges
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := hρ_int
  norm_bound_eventually := by
    intro z
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, hρ_bound] with u hk hρu
    rw [norm_mul]
    have h_norm_ofReal : ‖(ρ u : ℂ)‖ = |ρ u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 ≤ A * Real.log u + B :=
      le_trans (abs_nonneg _) hρu
    calc |ρ u| * ‖(1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))‖
        ≤ (A * Real.log u + B) * (4 * (‖z‖ + 1) / u^2) :=
          mul_le_mul hρu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- §CCXXXIX. `zeroDensityRho` log-growth bound
-- =====================================================================
-- Concrete deliverable for the `zeroDensityRho` density:
-- `|zeroDensityRho u| ≤ (1/(2π)) · log u` for `u ≥ 2π` (the positivity
-- threshold). This is exactly the `hρ_bound` field shape required by
-- §CCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`.
--
-- Note: the full `SmoothDensityTailMajorantData` for `zeroDensityRho`
-- additionally requires per-`(z, X)` integrability of the integrand
-- `(zeroDensityRho u : ℂ) · (1/(z-u) + 1/(z+u))`. That field is
-- universally quantified over `z` in the structure, but the kernel
-- has poles for real `z` lying in `[T, X]`, so integrability genuinely
-- fails there. A full instantiation would require either restricting
-- the structure to UHP `z` or providing the integrability as an
-- additional explicit hypothesis (deferred).
--
-- Adds:
--   zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
--   zeroDensityRho_log_growth_eventually

/-- ⭐ **PROVED — `|zeroDensityRho u| ≤ (1/(2π)) · log u` for `u ≥ 2π`.**
For `u ≥ 2π`, `ρ u = (1/(2π))·(log u - log(2π)) ≥ 0` and `log(2π) ≥ 0`
(since `2π ≥ 1`), so `|ρ u| = ρ u ≤ (1/(2π)) log u`. -/
lemma zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
    {u : ℝ} (hu : 2 * Real.pi ≤ u) :
    |zeroDensityRho u| ≤ (1 / (2 * Real.pi)) * Real.log u := by
  have h_nn : 0 ≤ zeroDensityRho u := zeroDensityRho_nonneg_of_ge_two_pi hu
  rw [abs_of_nonneg h_nn]
  unfold zeroDensityRho
  have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : ℝ) ≤ 1 / (2 * Real.pi) := by positivity
  have h2pi_ge_one : (1 : ℝ) ≤ 2 * Real.pi := by
    have := Real.pi_gt_three
    linarith
  have h_log_2pi_nn : 0 ≤ Real.log (2 * Real.pi) := Real.log_nonneg h2pi_ge_one
  have h_log_eq : Real.log (u / (2 * Real.pi))
                  = Real.log u - Real.log (2 * Real.pi) := by
    have h_u_pos : 0 < u := lt_of_lt_of_le h2pi_pos hu
    rw [Real.log_div (ne_of_gt h_u_pos) (ne_of_gt h2pi_pos)]
  rw [h_log_eq]
  -- (1/(2π)) * (log u - log(2π)) ≤ (1/(2π)) * log u
  -- since -(1/(2π)) * log(2π) ≤ 0
  have h_diff_nn :
      (1 / (2 * Real.pi)) * Real.log u -
        (1 / (2 * Real.pi)) * (Real.log u - Real.log (2 * Real.pi))
        = (1 / (2 * Real.pi)) * Real.log (2 * Real.pi) := by ring
  nlinarith [mul_nonneg h2pi_inv_nn h_log_2pi_nn]

/-- ⭐ **PROVED — eventual log-growth bound for `zeroDensityRho`.**
For `A := 1/(2π)`, `B := 0`, eventually `|ρ u| ≤ A · log u + B`. Direct
form for plugging into §CCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`. -/
lemma zeroDensityRho_log_growth_eventually :
    ∀ᶠ u : ℝ in Filter.atTop,
      |zeroDensityRho u| ≤ (1 / (2 * Real.pi)) * Real.log u + 0 := by
  filter_upwards [Filter.eventually_ge_atTop (2 * Real.pi)] with u hu
  have := zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi hu
  linarith

-- =====================================================================
-- §CCXL. UHP-restricted smooth density majorant chain
-- =====================================================================
-- Compatibility refinement: the existing §CCXXXV / §CCXXXVII universal-`z`
-- structures `SmoothDensityTailModelConverges` and
-- `SmoothDensityTailMajorantData` are too strong for densities like
-- `zeroDensityRho` whose paired-kernel integrand has poles at real
-- `z ∈ [T, X]`. This section adds UHP-restricted siblings that quantify
-- the convergence / integrability fields over `0 < z.im` only — which
-- is what the downstream `AntiHerglotzUHP` actually consumes.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
--   SmoothDensityTailModelConvergesUHP
--   SmoothDensityTailMajorantDataUHP
--   smoothDensityTailModel_converges_at_UHP
--   smoothDensityTailModelConvergesUHP_of_majorant
--   smoothDensityTailModelData_of_converges_UHP
--   smoothDensityTailModelData_of_majorant_nonneg_UHP
--   smoothDensityTailMajorantDataUHP_of_logGrowth

/-- 🌟🌟 **PROVED — UHP-restricted closure for `AntiHerglotzUHP`.**
If `F X` is eventually anti-Herglotz and `F X z → f z` pointwise *only
on UHP*, then `f` is anti-Herglotz. Same proof structure as
`AntiHerglotzUHP.of_eventual_pointwise_tendsto` (§CCXXXV), just
restricting the convergence hypothesis to `0 < z.im`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
    {F : ℝ → ℂ → ℂ} {f : ℂ → ℂ}
    (hF : ∀ᶠ X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : ∀ z, 0 < z.im →
      Tendsto (fun X => F X z) Filter.atTop (𝓝 (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto :
      Tendsto (fun X => (F X z).im) Filter.atTop (𝓝 (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z hz)
  have hF_im_le : ∀ᶠ X in Filter.atTop, (F X z).im ≤ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **UHP-restricted convergence package.** Like
`SmoothDensityTailModelConverges` but with convergence required only
for `z` with `0 < z.im`. Outside UHP, `tailModel` is free (typically 0). -/
structure SmoothDensityTailModelConvergesUHP
    (ρ : ℝ → ℝ) (T : ℝ) where
  tailModel : ℂ → ℂ
  tendsto   : ∀ z : ℂ, 0 < z.im →
    Tendsto
      (fun X : ℝ => smoothDensityTailModelPartial ρ T X z)
      Filter.atTop (𝓝 (tailModel z))

/-- 📦 **`SmoothDensityTailMajorantDataUHP ρ T`** — UHP-restricted
sibling of `SmoothDensityTailMajorantData`. All four fields are
quantified over `0 < z.im` to avoid the real-`z` pole non-integrability. -/
structure SmoothDensityTailMajorantDataUHP
    (ρ : ℝ → ℝ) (T : ℝ) where
  majorant : ℂ → ℝ → ℝ
  majorant_intervalIntegrable :
    ∀ z X, 0 < z.im → T ≤ X →
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    ∀ z, 0 < z.im → ∃ L : ℝ,
      Tendsto (fun X : ℝ => ∫ u in T..X, majorant z u)
        Filter.atTop (𝓝 L)
  integrand_intervalIntegrable :
    ∀ z X, 0 < z.im → T ≤ X →
      IntervalIntegrable
        (fun u =>
          (ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    ∀ z, 0 < z.im → ∀ᶠ u in Filter.atTop,
      ‖(ρ u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))‖
        ≤ majorant z u

/-- 🌟🌟 **PROVED — UHP pointwise smooth tail convergence from
majorant.** Sibling of §CCXXXVII's `smoothDensityTailModel_converges_at`
restricted to UHP `z`. -/
theorem smoothDensityTailModel_converges_at_UHP
    (ρ : ℝ → ℝ) (T : ℝ)
    (H : SmoothDensityTailMajorantDataUHP ρ T)
    (z : ℂ) (hz : 0 < z.im) :
    ∃ L : ℂ,
      Tendsto
        (fun X : ℝ => smoothDensityTailModelPartial ρ T X z)
        Filter.atTop (𝓝 L) := by
  rcases H.majorant_converges z hz with ⟨LM, hLM⟩
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hz hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hz hTX)
    hLM
    (H.norm_bound_eventually z hz)

/-- 🌟🌟🌟 **PROVED — `SmoothDensityTailModelConvergesUHP` from
majorant data.** Uses `Classical.choose` on the UHP pointwise
existence theorem, with `tailModel z := 0` outside UHP. -/
noncomputable def smoothDensityTailModelConvergesUHP_of_majorant
    (ρ : ℝ → ℝ) (T : ℝ)
    (H : SmoothDensityTailMajorantDataUHP ρ T) :
    SmoothDensityTailModelConvergesUHP ρ T where
  tailModel := fun z =>
    if hz : 0 < z.im then
      Classical.choose (smoothDensityTailModel_converges_at_UHP ρ T H z hz)
    else 0
  tendsto := by
    intro z hz
    have hExists := smoothDensityTailModel_converges_at_UHP ρ T H z hz
    have htail_val :
        (if hz' : 0 < z.im then
            Classical.choose
              (smoothDensityTailModel_converges_at_UHP ρ T H z hz')
          else 0)
          = Classical.choose hExists := by
      rw [dif_pos hz]
    rw [htail_val]
    exact Classical.choose_spec hExists

/-- 🌟🌟🌟 **PROVED — `SmoothDensityTailModelData` from UHP convergence
+ finite anti.** UHP-friendly sibling of §CCXXXV's
`smoothDensityTailModelData_of_converges`. -/
noncomputable def smoothDensityTailModelData_of_converges_UHP
    (ρ : ℝ → ℝ) (T : ℝ)
    (C : SmoothDensityTailModelConvergesUHP ρ T)
    (Hfinite : SmoothDensityTailFiniteAntiData ρ T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
      (F := fun X => smoothDensityTailModelPartial ρ T X)
    · filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    · exact C.tendsto

/-- 🌟🌟🌟🌟 **PROVED — `SmoothDensityTailModelData` from `ρ ≥ 0` + UHP
norm majorant.** End-to-end UHP-restricted constructor. Mirrors
§CCXXXVII's `smoothDensityTailModelData_of_majorant_nonneg`. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg_UHP
    (ρ : ℝ → ℝ) (T : ℝ)
    (hρ_nonneg : ∀ u, T ≤ u → 0 ≤ ρ u)
    (H : SmoothDensityTailMajorantDataUHP ρ T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges_UHP ρ T
    (smoothDensityTailModelConvergesUHP_of_majorant ρ T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ρ T hρ_nonneg
      (fun X z hTX hz => H.integrand_intervalIntegrable z X hz hTX))

/-- 🌟🌟🌟🌟 **PROVED — UHP `SmoothDensityTailMajorantDataUHP` from log
growth.** Sibling of §CCXXXVIII restricted to UHP `z`. -/
noncomputable def smoothDensityTailMajorantDataUHP_of_logGrowth
    (ρ : ℝ → ℝ) (T : ℝ) (A B : ℝ)
    (_hA_nn : 0 ≤ A) (_hB_nn : 0 ≤ B)
    (hTpos : 0 < T)
    (hρ_bound : ∀ᶠ u in Filter.atTop, |ρ u| ≤ A * Real.log u + B)
    (hρ_int :
      ∀ z X, 0 < z.im → T ≤ X →
        IntervalIntegrable
          (fun u =>
            (ρ u : ℂ) *
              ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantDataUHP ρ T where
  majorant := fun z u =>
    trueKernelLogMajorant ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X _hz hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z _hz
    refine ⟨-trueKernelLogMajorantPrimitive
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T, ?_⟩
    exact trueKernelLogMajorantConverges
      ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := hρ_int
  norm_bound_eventually := by
    intro z _hz
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, hρ_bound] with u hk hρu
    rw [norm_mul]
    have h_norm_ofReal : ‖(ρ u : ℂ)‖ = |ρ u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 ≤ A * Real.log u + B :=
      le_trans (abs_nonneg _) hρu
    calc |ρ u| * ‖(1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))‖
        ≤ (A * Real.log u + B) * (4 * (‖z‖ + 1) / u^2) :=
          mul_le_mul hρu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((‖z‖ + 1) * A / 2) ((‖z‖ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- §CCXLI. `zeroDensityRho` smooth-tail UHP integrability + concrete data
-- =====================================================================
-- Final piece needed to fully discharge `SmoothDensityTailModelData` for
-- `zeroDensityRho`: continuity-based interval integrability of the
-- integrand `(zeroDensityRho u : ℂ) · (1/(z-u) + 1/(z+u))` on `[T, X]`
-- for UHP `z`, then composition with §CCXL's UHP majorant chain.
--
-- Adds:
--   complex_sub_real_ne_zero_of_im_pos
--   complex_add_real_ne_zero_of_im_pos
--   continuous_pairedCauchyKernel_u_of_im_pos
--   zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
--   smoothDensityTailModelData_zeroDensityRho

/-- ⭐ **PROVED — `z - (u : ℂ) ≠ 0` when `0 < z.im`.** -/
lemma complex_sub_real_ne_zero_of_im_pos
    {z : ℂ} (hz : 0 < z.im) (u : ℝ) :
    z - (u : ℂ) ≠ 0 := by
  intro h
  have him : (z - (u : ℂ)).im = 0 := by rw [h]; rfl
  have him' : (z - (u : ℂ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- ⭐ **PROVED — `z + (u : ℂ) ≠ 0` when `0 < z.im`.** -/
lemma complex_add_real_ne_zero_of_im_pos
    {z : ℂ} (hz : 0 < z.im) (u : ℝ) :
    z + (u : ℂ) ≠ 0 := by
  intro h
  have him : (z + (u : ℂ)).im = 0 := by rw [h]; rfl
  have him' : (z + (u : ℂ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- 🌟🌟 **PROVED — paired Cauchy kernel continuous in `u` for UHP `z`.**
For `0 < z.im`, the map `u ↦ 1/(z - u) + 1/(z + u)` is continuous on ℝ,
since both denominators are non-vanishing. -/
lemma continuous_pairedCauchyKernel_u_of_im_pos
    {z : ℂ} (hz : 0 < z.im) :
    Continuous fun u : ℝ =>
      (1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)) := by
  refine Continuous.add ?_ ?_
  · apply Continuous.div₀ continuous_const
    · exact continuous_const.sub Complex.continuous_ofReal
    · intro u
      exact complex_sub_real_ne_zero_of_im_pos hz u
  · apply Continuous.div₀ continuous_const
    · exact continuous_const.add Complex.continuous_ofReal
    · intro u
      exact complex_add_real_ne_zero_of_im_pos hz u

/-- 🌟🌟🌟 **PROVED — UHP interval integrability of
`zeroDensityRho × paired Cauchy kernel`.** For `0 < T ≤ X` and
`0 < z.im`, the integrand is continuous on `[T, X]` (both factors
continuous + denominators non-vanishing), hence interval-integrable. -/
theorem zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
    (T X : ℝ) {z : ℂ}
    (hTpos : 0 < T) (hTX : T ≤ X) (hz : 0 < z.im) :
    IntervalIntegrable
      (fun u =>
        (zeroDensityRho u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
      MeasureTheory.volume T X := by
  -- ρ continuous on Icc T X (subset of Ioi 0)
  have hρ_real : ContinuousOn zeroDensityRho (Set.Icc T X) := by
    apply Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    intro u hu
    exact lt_of_lt_of_le hTpos hu.1
  have hρ : ContinuousOn (fun u : ℝ => (zeroDensityRho u : ℂ))
      (Set.Icc T X) :=
    Complex.continuous_ofReal.comp_continuousOn hρ_real
  -- Kernel continuous on UHP for fixed z
  have hk : ContinuousOn
      (fun u : ℝ =>
        (1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))
      (Set.Icc T X) :=
    (continuous_pairedCauchyKernel_u_of_im_pos hz).continuousOn
  have hprod : ContinuousOn
      (fun u =>
        (zeroDensityRho u : ℂ) *
          ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ))))
      (Set.Icc T X) :=
    hρ.mul hk
  exact ContinuousOn.intervalIntegrable_of_Icc hTX hprod

/-- 🌟🌟🌟🌟 **PROVED — `SmoothDensityTailModelData` for the concrete
`zeroDensityRho` density.** Given `T ≥ 2π`, produces a full
`SmoothDensityTailModelData` by composing §CCXLI's integrability
discharger with §CCXL's UHP majorant chain and §CCXXXIX's log-growth
bound. -/
noncomputable def smoothDensityTailModelData_zeroDensityRho
    (T : ℝ) (hT_ge : 2 * Real.pi ≤ T) :
    SmoothDensityTailModelData := by
  have hTpos : 0 < T := by
    have hpi : (0 : ℝ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hT_ge
  have h2pi_inv_nn : (0 : ℝ) ≤ 1 / (2 * Real.pi) := by positivity
  exact smoothDensityTailModelData_of_majorant_nonneg_UHP
    zeroDensityRho T
    (fun u hTu =>
      zeroDensityRho_nonneg_of_ge_two_pi (le_trans hT_ge hTu))
    (smoothDensityTailMajorantDataUHP_of_logGrowth
      zeroDensityRho T
      (1 / (2 * Real.pi)) 0
      h2pi_inv_nn le_rfl hTpos
      zeroDensityRho_log_growth_eventually
      (fun z X hz hTX =>
        zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
          T X hTpos hTX hz))

