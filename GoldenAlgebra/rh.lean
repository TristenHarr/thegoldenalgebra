/-- Ô¡É **PROVED ÔÇö Helper 4: affine LB for `log(T/(2¤Ç))` on `[12, 13]`.**
Combines endpoint bounds with `Real.secant_le_log` applied to `log`.
The expression `(2/5) + (T-12)/10` equals `(T-8)/10` algebraically and
is exactly the secant connecting the endpoint LB values. -/
lemma log_T_over_2pi_ge_affine_12_13
    {T : ÔäØ} (hT12 : 12 Ôëñ T) (hT13 : T Ôëñ 13) :
    (2 / 5 : ÔäØ) + (T - 12) / 10
      Ôëñ Real.log (T / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h_2pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  -- secant_le_log on [12, 13] applied to log T
  have h12pos : (0 : ÔäØ) < 12 := by norm_num
  have h_12_lt_13 : (12 : ÔäØ) < 13 := by norm_num
  have h_secant := Real.secant_le_log h12pos h_12_lt_13 hT12 hT13
  -- Simplify coefficients: 13 - 12 = 1
  have h_secant' :
      (13 - T) * Real.log 12 + (T - 12) * Real.log 13 Ôëñ Real.log T := by
    have h_div_1a : (13 - T) / (13 - 12) = 13 - T := by norm_num
    have h_div_1b : (T - 12) / (13 - 12) = T - 12 := by norm_num
    rw [h_div_1a, h_div_1b] at h_secant
    exact h_secant
  -- log(12/(2¤Ç)) = log 12 - log(2¤Ç), log(13/(2¤Ç)) = log 13 - log(2¤Ç)
  have h_log_T_div : Real.log (T / (2 * Real.pi)) = Real.log T - Real.log (2 * Real.pi) :=
    Real.log_div hT_ne h_2pi_ne
  have h_log_12_div : Real.log (12 / (2 * Real.pi)) = Real.log 12 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (12 : ÔäØ) Ôëá 0) h_2pi_ne
  have h_log_13_div : Real.log (13 / (2 * Real.pi)) = Real.log 13 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (13 : ÔäØ) Ôëá 0) h_2pi_ne
  -- Use endpoint LBs
  have h12 := log_12_div_2pi_ge_2_5
  have h13 := log_13_div_2pi_ge_1_2
  rw [h_log_12_div] at h12
  rw [h_log_13_div] at h13
  have h13mT_nn : 0 Ôëñ 13 - T := by linarith
  have hTm12_nn : 0 Ôëñ T - 12 := by linarith
  rw [h_log_T_div]
  -- (13-T)┬À(log 12 - log(2¤Ç)) + (T-12)┬À(log 13 - log(2¤Ç))
  -- = (13-T)┬Àlog 12 + (T-12)┬Àlog 13 - log(2¤Ç)┬À(13-T + T-12)
  -- = (13-T)┬Àlog 12 + (T-12)┬Àlog 13 - log(2¤Ç) Ôëñ log T - log(2¤Ç)
  -- And LHS ÔëÑ (13-T)┬À(2/5) + (T-12)┬À(1/2) (using endpoint bounds applied via h12, h13)
  -- (13-T)┬À(2/5) + (T-12)┬À(1/2) = 2(13-T)/5 + (T-12)/2 = (T - 8)/10 (algebra)
  -- which equals (2/5) + (T-12)/10.
  nlinarith [h_secant', h12, h13, h13mT_nn, hTm12_nn]

/-- Ô¡É **PROVED ÔÇö Helper 5: affine LB for `zeroDensityRho` on `[12, 13]`.**
Direct division of the log bound by `2¤Ç`. -/
lemma zeroDensityRho_ge_affine_12_13
    {T : ÔäØ} (hT12 : 12 Ôëñ T) (hT13 : T Ôëñ 13) :
    ((2 / 5 : ÔäØ) + (T - 12) / 10) / (2 * Real.pi)
      Ôëñ zeroDensityRho T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_log_ge := log_T_over_2pi_ge_affine_12_13 hT12 hT13
  -- Goal: ((2/5) + (T-12)/10) / (2¤Ç) Ôëñ (1/(2¤Ç)) ┬À log(T/(2¤Ç))
  rw [show (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
