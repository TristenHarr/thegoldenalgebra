/-- Ô¡É **PROVED ÔÇö `log T Ôëñ 4` for `T Ôëñ 54`.**
Chain: `2.718 < exp 1` (from `exp_one_gt_d9`), `2.718^4 ÔëÑ 54` (norm_num),
so `54 Ôëñ (exp 1)^4 = exp 4`, hence `log T Ôëñ log 54 Ôëñ 4` by monotonicity. -/
theorem log_T_le_4_of_le_54 {T : ÔäØ} (hT_pos : 0 < T) (hT : T Ôëñ 54) :
    Real.log T Ôëñ 4 := by
  have h_2718_lt_exp_1 : (2.718 : ÔäØ) < Real.exp 1 :=
    lt_trans (by norm_num : (2.718 : ÔäØ) < 2.7182818283) Real.exp_one_gt_d9
  have h_2718_nn : (0 : ÔäØ) Ôëñ 2.718 := by norm_num
  have h_pow_le : (2.718 : ÔäØ)^4 Ôëñ (Real.exp 1)^4 :=
    pow_le_pow_leftÔéÇ h_2718_nn (le_of_lt h_2718_lt_exp_1) 4
  have h_exp_4_eq : Real.exp 4 = (Real.exp 1)^4 := by
    have := Real.exp_one_pow 4
    have h_cast : ((4 : Ôäò) : ÔäØ) = (4 : ÔäØ) := by norm_num
    rw [ÔåÉ h_cast]; exact this.symm
  have h_54_le_pow : (54 : ÔäØ) Ôëñ (2.718 : ÔäØ)^4 := by norm_num
  have h_54_le_exp_4 : (54 : ÔäØ) Ôëñ Real.exp 4 := by
    rw [h_exp_4_eq]; linarith
  have h_T_le : T Ôëñ Real.exp 4 := le_trans hT h_54_le_exp_4
  have h := Real.log_le_log hT_pos h_T_le
  rwa [Real.log_exp] at h

/-- Ô¡É **PROVED ÔÇö Endpoint bound: `log(48/(2¤Ç)) ÔëÑ 2`.**
Chain: `(exp 1)┬▓ Ôëñ 7.4` (from `exp_one_lt_d9`) and `7.4┬À(2¤Ç) Ôëñ 48` via
`¤Ç < 3.1416`. Tighter than the [80,140] chain because `8┬À(2¤Ç) > 48`. -/
lemma log_48_div_2pi_ge_2 :
    (2 : ÔäØ) Ôëñ Real.log (48 / (2 * Real.pi)) := by
  have h_pi_lt : Real.pi < 3.1416 := Real.pi_lt_d4
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_sq_lt : (Real.exp 1)^2 < (2.7182818286 : ÔäØ)^2 :=
    pow_lt_pow_leftÔéÇ h_exp_1_lt (le_of_lt h_exp_1_pos) (n := 2) (by norm_num)
  have h_27_sq_le : (2.7182818286 : ÔäØ)^2 Ôëñ 7.4 := by norm_num
  have h_exp_1_sq_le : (Real.exp 1)^2 Ôëñ 7.4 := by linarith
  have h_exp_2_eq : Real.exp 2 = (Real.exp 1)^2 := by
    have := Real.exp_one_pow 2
    have h_cast : ((2 : Ôäò) : ÔäØ) = (2 : ÔäØ) := by norm_num
    rw [ÔåÉ h_cast]; exact this.symm
  have h_exp_2_le : Real.exp 2 Ôëñ 7.4 := h_exp_2_eq Ôû© h_exp_1_sq_le
  have h_74_le : (7.4 : ÔäØ) Ôëñ 48 / (2 * Real.pi) := by
    rw [le_div_iffÔéÇ h_2pi_pos]
    nlinarith
  have h_exp_2_le_ratio : Real.exp 2 Ôëñ 48 / (2 * Real.pi) :=
    le_trans h_exp_2_le h_74_le
  have h_exp_pos : 0 < Real.exp 2 := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_2_le_ratio
  rwa [Real.log_exp] at h

/-- Ô¡É **PROVED ÔÇö `log(T/(2¤Ç)) ÔëÑ 2` for `T ÔëÑ 48`** via monotonicity. -/
lemma log_T_over_2pi_ge_2_of_ge_48
    {T : ÔäØ} (hT48 : 48 Ôëñ T) :
    (2 : ÔäØ) Ôëñ Real.log (T / (2 * Real.pi)) := by
