/-- **Parameterized low residual explicit bound** —
`closedFormFirstZeroErrorBound` at user-supplied first-zero parameters
`(T, γ₁, D)`. The §CCLXXVII constant-parameter `lowResidualExplicitBound`
is the `(2π, 14, 1/2)` specialization (definitionally). -/
noncomputable def lowResidualExplicitBoundAt
    (T gamma1 D : ℝ) (z : ℂ) : ℝ :=
  closedFormFirstZeroErrorBound z.im T gamma1 D

/-- ⭐ **PROVED — `lowResidualExplicitBound` is the `(2π, 14, 1/2)`
specialization of the parameterized form.** -/
lemma lowResidualExplicitBound_eq_At (z : ℂ) :
    lowResidualExplicitBound z
      = lowResidualExplicitBoundAt (2 * Real.pi) 14 (1 / 2) z := rfl

/-- 📦 **`XiLowResidualExplicitDataAt T γ₁ D M`** — parameterized
analogue of §CCLXXVII `XiLowResidualExplicitData`: on the compact low
region, the canonical residual's `Im` is bounded by the parameterized
explicit bound. -/
structure XiLowResidualExplicitDataAt
    (T gamma1 D : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_bound :
    ∀ z : ℂ,
      lowCompactRegion z →
      |(xiResidualError M z).im| ≤ lowResidualExplicitBoundAt T gamma1 D z

/-- 📦 **`LowMarginDominatesExplicitBoundAt T γ₁ D M`** —
parameterized analogue of §CCLXXVII `LowMarginDominatesExplicitBound`. -/
def LowMarginDominatesExplicitBoundAt
    (T gamma1 D : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowResidualExplicitBoundAt T gamma1 D z ≤ -(M.model z).im

/-- 📦 **`LowExplicitArithmeticBoundAt T γ₁ D`** — parameterized
analogue of §CCLXXVIII `LowExplicitArithmeticBound`. Pure arithmetic
inequality between the parameterized closed-form residual bound and
the model-side `simpleCloudSum + smoothTailRationalLowerBoundAbs(...,10)`
lower bound. The smooth inner cutoff is fixed at `10`, the forced
choice on the low compact region. -/
def LowExplicitArithmeticBoundAt (T gamma1 D : ℝ) : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowResidualExplicitBoundAt T gamma1 D z
      ≤ simpleCloudSum zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbs z.re z.im 10

/-- 🌟🌟 **PROVED — `XiLowResidualMargin` from the parameterized
two-piece split.** -/
theorem XiLowResidualMargin_of_explicitAt_and_marginAt
    {T gamma1 D : ℝ}
    (Hexplicit : XiLowResidualExplicitDataAt T gamma1 D honestZeroDensityModelTwoPi)
    (Hmargin : LowMarginDominatesExplicitBoundAt T gamma1 D honestZeroDensityModelTwoPi) :
    XiLowResidualMargin honestZeroDensityModelTwoPi := by
  intro z hz
  exact le_trans (Hexplicit.residual_bound z hz) (Hmargin z hz)

/-- 🌟🌟🌟🌟 **PROVED — parameterized `LowMarginDominatesExplicitBoundAt`
from the parameterized arithmetic Prop.** Same structural decomposition
as §CCLXXVIII, parameterized over `(T, γ₁, D)`: cloud LB via
`simpleCloudSum`, smooth LB at `T_smooth = 10`. -/
theorem LowMarginDominatesExplicitBoundAt_twoPi_of_arithAt
    {T gamma1 D : ℝ}
    (harith : LowExplicitArithmeticBoundAt T gamma1 D) :
    LowMarginDominatesExplicitBoundAt T gamma1 D honestZeroDensityModelTwoPi := by
  intro z hz
  have hcloud := honestZeroDensityModelTwoPi_cloud_simpleLB hz.1
  have hsmooth := honestZeroDensityModelTwoPi_smooth_LB_at_10 hz
  have harith_z := harith z hz
  rw [honestZeroDensityModelTwoPi_neg_im_eq]
  linarith

