/-- ⭐ **PROVED — Uniform piece lift for `[19, 32]`.**
Given a numerical check at one piece `[a, b]`, lifts to all `T ∈ [a, b]`. -/
lemma scalar_19_32_piece_lift
    {T a b : ℝ}
    (h_a_19 : 19 ≤ a) (h_b_32 : b ≤ 32) (_h_a_le_b : a ≤ b)
    (h_T_lo : a ≤ T) (h_T_hi : T ≤ b)
