theorem isZetaZeroUpToHeight_mem_closedCriticalRectangle
    {T : ÔäØ} {s : Ôäé}
    (hs : IsZetaZeroUpToHeight T s) :
    s Ôêê closedCriticalRectangle T := by
  rcases hs with Ôƒ¿hzero, him_pos, him_leÔƒ®
  rcases hzero with Ôƒ¿_, hre_pos, hre_ltÔƒ®
  exact Ôƒ¿le_of_lt hre_pos, le_of_lt hre_lt, le_of_lt him_pos, him_leÔƒ®

