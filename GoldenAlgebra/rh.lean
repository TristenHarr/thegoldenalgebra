-- ---------------------------------------------------------------------
-- CL-A: Bound functions from the S-bound structures
-- ---------------------------------------------------------------------
-- Turn the `TuringStyleSBound` / `HalfLogPlusHalfSBound` data into the
-- explicit bound function `B(u)` expected by
-- `ImaginaryStieltjesTailIBPBound`.

/-- The bound function from a `TuringStyleSBound`:
  `B(u) := C┬Àlog u + D`. -/
noncomputable def turingStyleBoundFunction
    (H : TuringStyleSBound) : ÔäØ ÔåÆ ÔäØ :=
  fun u => H.C * Real.log u + H.D

/-- Ô¡É **PROVED ÔÇö bound function spec.** -/
theorem TuringStyleSBound.boundFunction_spec
    (H : TuringStyleSBound)
    {u : ÔäØ} (hu : H.lower Ôëñ u) :
    |H.S u| Ôëñ turingStyleBoundFunction H u := by
  simpa [turingStyleBoundFunction] using H.bound u hu

/-- The bound function for the half-log-plus-half S-bound:
  `B(u) := (1/2)┬Àlog u + 1/2`. -/
noncomputable def halfLogPlusHalfBoundFunction : ÔäØ ÔåÆ ÔäØ :=
  fun u => (1 / 2 : ÔäØ) * Real.log u + 1 / 2

/-- Ô¡É **PROVED ÔÇö half-log-plus-half bound function spec.** -/
theorem HalfLogPlusHalfSBound.boundFunction_spec
    (H : HalfLogPlusHalfSBound)
    {u : ÔäØ} (hu : H.lower Ôëñ u) :
    |H.S u| Ôëñ halfLogPlusHalfBoundFunction u := by
  simpa [halfLogPlusHalfBoundFunction] using H.bound u hu

-- ---------------------------------------------------------------------
-- CL-B: IBP package constructor from closed-form data
-- ---------------------------------------------------------------------
-- Inhabit `ImaginaryStieltjesTailIBPBound` from a `TuringStyleSBound`
-- plus the boundary, integral, and closed-form margin inputs. The
-- ibpMargin field is closed by the chain
--   |k(T)|┬ÀB(T) + integralBound
--     Ôëñ 8y(C┬ÀlogT + D)/T┬▓ + 18y(...)             (hboundary + hintegral)
--     = closedFormSErrorBoundCD H.C H.D y T      (rfl)
--     Ôëñ modelMargin                              (hclosed)

/-- Ô¡É **PROVED ÔÇö IBP package constructor from a general
`TuringStyleSBound`.** Given a `TuringStyleSBound`, an adaptive cutoff
`T ÔëÑ H.lower`, probe coordinates `(x, y)`, a boundary term satisfying
`|k_z(T)|┬ÀB(T) Ôëñ 8y(C┬Àlog T + D)/T┬▓`, an integral upper bound
matching the IBP integral term, and a closed-form Ôëñ modelMargin
inequality, produce an `ImaginaryStieltjesTailIBPBound` whose
`ibpMargin` field is exactly the required headline IBP inequality. -/
noncomputable def ImaginaryStieltjesTailIBPBound.of_closedFormCD
    (H : TuringStyleSBound)
    (T x y integralBound modelMargin : ÔäØ)
    (hTlower : H.lower Ôëñ T)
    (hboundary :
      |pairedCauchyImKernel x y T| * turingStyleBoundFunction H T
        Ôëñ 8 * y * (H.C * Real.log T + H.D) / T^2)
    (hintegral :
      integralBound Ôëñ
        18 * y *
          (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
            + H.D / (2 * T^2)))
    (hclosed :
      closedFormSErrorBoundCD H.C H.D y T Ôëñ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S := H.S
  B := turingStyleBoundFunction H
  T := T
  x := x
  y := y
  hS_bound := fun u hu =>
    H.boundFunction_spec (le_trans hTlower hu)
  integralBound := integralBound
  modelMargin := modelMargin
  ibpMargin := by
    -- Chain: |k(T)|┬ÀB(T) + integralBound
    --       Ôëñ 8y(C┬ÀlogT + D)/T┬▓ + 18y(...)
    --       = closedFormSErrorBoundCD H.C H.D y T (defn)
    --       Ôëñ modelMargin
    have h_sum_le :
        |pairedCauchyImKernel x y T| * turingStyleBoundFunction H T
            + integralBound
          Ôëñ 8 * y * (H.C * Real.log T + H.D) / T^2
              + 18 * y *
                  (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
                    + H.D / (2 * T^2)) := by
      linarith
    have h_eq :
        8 * y * (H.C * Real.log T + H.D) / T^2
            + 18 * y *
                (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
                  + H.D / (2 * T^2))
          = closedFormSErrorBoundCD H.C H.D y T := rfl
    linarith [h_sum_le, h_eq, hclosed]

/-- Ô¡É **PROVED ÔÇö IBP package constructor specialized to
`HalfLogPlusHalfSBound`** (the realistic `(C = 1/2, D = 1/2)`
hypothesis). One-liner via the general constructor. -/
noncomputable def ImaginaryStieltjesTailIBPBound.of_halfLogPlusHalf
    (H : HalfLogPlusHalfSBound)
    (T x y integralBound modelMargin : ÔäØ)
    (hTlower : H.lower Ôëñ T)
    (hboundary :
      |pairedCauchyImKernel x y T|
            * turingStyleBoundFunction H.toTuringStyleSBound T
        Ôëñ 8 * y * ((1 / 2 : ÔäØ) * Real.log T + 1 / 2) / T^2)
    (hintegral :
      integralBound Ôëñ
        18 * y *
          ((1 / 2 : ÔäØ) * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
            + (1 / 2 : ÔäØ) / (2 * T^2)))
    (hclosed :
      closedFormSErrorBoundCD (1 / 2 : ÔäØ) (1 / 2 : ÔäØ) y T Ôëñ modelMargin) :
    ImaginaryStieltjesTailIBPBound :=
  ImaginaryStieltjesTailIBPBound.of_closedFormCD
    H.toTuringStyleSBound T x y integralBound modelMargin
    hTlower hboundary hintegral hclosed

-- ---------------------------------------------------------------------
-- CLI: Per-window closed-form IBP data aggregator
-- ---------------------------------------------------------------------
-- Bundles everything an `of_closedFormCD` invocation needs into a
-- single per-window structure, plus the model / error / region /
-- modelAnti / Schwarz-symmetry-side fields needed to project onto a
-- `ZeroCountingFluctuationBound`. The intent: one inhabitant per
-- adaptive window `n`, then sequence + coverage build the family
-- structures downstream.

/-- **Per-window closed-form IBP data.** Aggregates a
`TuringStyleSBound` with the per-window decomposition data and the
analytic ingredients of an `of_closedFormCD` call. Fields:

* `S`, `model`, `error`, `region` ÔÇö the per-window decomp + zero-counting
  fluctuation;
* `z`, `T` ÔÇö the probe point and adaptive cutoff;
* `turing` + `hTlower` ÔÇö the Turing-style `S`-bound and `T ÔëÑ lower`;
* `integralBound`, `modelMargin` ÔÇö the abstract integral and margin
  placeholders;
* `hboundary`, `hintegral`, `hclosed` ÔÇö the three analytic inputs to
  `of_closedFormCD`;
* `modelMargin_eq` ÔÇö names the equality `modelMargin = ÔêÆ(model z).im`;
* `modelAnti` ÔÇö the model is anti-Herglotz globally;
* `error_eq_S_tail` ÔÇö abstract `StieltjesTailIdentity`: the `error`
  contribution equals some named `tail` on the region. Refines
  what was previously the placeholder `True`.
-/
structure PerWindowClosedFormIBPData where
  S : ÔäØ ÔåÆ ÔäØ
  model : Ôäé ÔåÆ Ôäé
  error : Ôäé ÔåÆ Ôäé
  region : Ôäé ÔåÆ Prop
  z : Ôäé
  T : ÔäØ
  turing : TuringStyleSBound
  hTlower : turing.lower Ôëñ T
  integralBound : ÔäØ
  modelMargin : ÔäØ
  hboundary :
    |pairedCauchyImKernel z.re z.im T| *
        turingStyleBoundFunction turing T
      Ôëñ 8 * z.im * (turing.C * Real.log T + turing.D) / T^2
  hintegral :
    integralBound Ôëñ
      18 * z.im *
        (turing.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
          + turing.D / (2 * T^2))
  hclosed :
    closedFormSErrorBoundCD turing.C turing.D z.im T Ôëñ modelMargin
  modelMargin_eq : modelMargin = -(model z).im
  modelAnti : AntiHerglotzUHP model
  error_eq_S_tail : StieltjesTailIdentity error region

/-- Ô¡É **PROVED ÔÇö project per-window closed-form IBP data to an
`ImaginaryStieltjesTailIBPBound`.** One-line via CL-B
`of_closedFormCD`. -/
noncomputable def PerWindowClosedFormIBPData.toImaginaryStieltjesTailIBPBound
    (P : PerWindowClosedFormIBPData) :
    ImaginaryStieltjesTailIBPBound :=
  ImaginaryStieltjesTailIBPBound.of_closedFormCD
    P.turing P.T P.z.re P.z.im P.integralBound P.modelMargin
    P.hTlower P.hboundary P.hintegral P.hclosed

/-- Ô¡É **PROVED ÔÇö project per-window closed-form IBP data to a
`ZeroCountingFluctuationBound`.** The `margin` field of the
fluctuation bound is the bridge hypothesis `hmargin_from_ibp` ÔÇö the
inequality `|Im(error z)| Ôëñ ÔêÆIm(model z)` on the region that the IBP
machinery is meant to certify analytically. Until the explicit
Stieltjes-integral identification of `error` lands, this bridge stays
as a hypothesis. -/
noncomputable def PerWindowClosedFormIBPData.toZeroCountingFluctuationBound
    (P : PerWindowClosedFormIBPData)
    (hmargin_from_ibp :
      ÔêÇ z : Ôäé, P.region z ÔåÆ 0 < z.im ÔåÆ
        |(P.error z).im| Ôëñ -(P.model z).im) :
    ZeroCountingFluctuationBound where
  S := P.S
  model := P.model
  error := P.error
  region := P.region
  modelAnti := P.modelAnti
  error_eq_S_tail := P.error_eq_S_tail
  margin := hmargin_from_ibp

-- ---------------------------------------------------------------------
-- CLII-A: Model-margin lower-bound package
-- ---------------------------------------------------------------------
-- Separates "prove a lower bound for the model margin at the probe `z`"
-- from "use that bound to close the IBP chain's `hclosed` hypothesis".

/-- **Model-margin lower bound.** Records that some explicit
`lowerBound : ÔäØ` is dominated by `ÔêÆIm(model z)` at the probe point. -/
structure ModelMarginLowerBound where
  model : Ôäé ÔåÆ Ôäé
  z : Ôäé
  T : ÔäØ
  lowerBound : ÔäØ
  lowerBound_le : lowerBound Ôëñ -(model z).im

/-- Ô¡É **PROVED ÔÇö lower bound on the model margin closes `hclosed`.**
If the closed-form S-error bound is dominated by the named lower bound,
it is dominated by the actual model margin `ÔêÆIm(model z)` by transitivity. -/
theorem ModelMarginLowerBound.closes_hclosed
    (M : ModelMarginLowerBound)
    {C D : ÔäØ}
    (hclosed : closedFormSErrorBoundCD C D M.z.im M.T Ôëñ M.lowerBound) :
    closedFormSErrorBoundCD C D M.z.im M.T Ôëñ -(M.model M.z).im :=
  le_trans hclosed M.lowerBound_le

-- ---------------------------------------------------------------------
-- CLII-B: Smooth-tail-only margin (model = cloud + densityTail)
-- ---------------------------------------------------------------------
-- The model splits as `cloud + densityTail` with both pieces
-- anti-Herglotz. Since `(cloud z).im Ôëñ 0`, the negative imaginary
-- margin satisfies `ÔêÆIm(model z) ÔëÑ ÔêÆIm(densityTail z)`. So it suffices
-- to lower-bound the smooth density tail alone.

/-- **Standalone smooth-tail margin lower bound.** Records that some
explicit `lowerBound` is dominated by `ÔêÆIm(densityTail z)`. -/
structure SmoothTailMarginLowerBound where
  densityTail : Ôäé ÔåÆ Ôäé
  z : Ôäé
  T : ÔäØ
  lowerBound : ÔäØ
  tailMargin : lowerBound Ôëñ -(densityTail z).im

/-- **Model + density-tail margin.** Aggregates a `cloud + densityTail`
decomposition with a smooth-tail-only lower bound. The cloud
contribution is allowed to be anti-Herglotz at `z` (its imaginary part
nonpositive), so the lower bound transfers from the tail to the full
model. -/
structure ModelWithDensityTailMargin where
  model : Ôäé ÔåÆ Ôäé
  cloud : Ôäé ÔåÆ Ôäé
  densityTail : Ôäé ÔåÆ Ôäé
  z : Ôäé
  T : ÔäØ
  lowerBound : ÔäØ
  decomp : model z = cloud z + densityTail z
  cloudAntiAt : (cloud z).im Ôëñ 0
  tailMargin : lowerBound Ôëñ -(densityTail z).im

/-- Ô¡É **PROVED ÔÇö smooth-tail-only lower bound + cloud anti-Herglotz at
`z` Ôƒ╣ model-margin lower bound.**

  `ÔêÆIm(model z) = ÔêÆIm(cloud z) ÔêÆ Im(densityTail z)
                ÔëÑ 0 + (ÔêÆIm(densityTail z))
                ÔëÑ lowerBound`. -/
noncomputable def ModelWithDensityTailMargin.toModelMarginLowerBound
    (P : ModelWithDensityTailMargin) :
    ModelMarginLowerBound where
  model := P.model
  z := P.z
  T := P.T
  lowerBound := P.lowerBound
  lowerBound_le := by
    have h_im : (P.model P.z).im = (P.cloud P.z).im + (P.densityTail P.z).im := by
      rw [P.decomp, Complex.add_im]
    have h_cloud := P.cloudAntiAt
    have h_tail := P.tailMargin
    linarith

-- ---------------------------------------------------------------------
-- CLII-C: Asymptotic smooth-density-tail lower-bound skeleton
-- ---------------------------------------------------------------------

/-- **Asymptotic smooth-density-tail lower bound (named target).**
A candidate lower-bound function `bound : x y T Ôåª ÔäØ` that dominates
`ÔêÆIm(densityTail(x + i┬Ày))` for all `T ÔëÑ T0` on the canonical adaptive
`A = 2` region. Concretely, candidate forms are
  `AÔéÇ ┬À y ┬À log T / T┬▓`  or  `AÔéÇ ┬À y ┬À log T / T┬▓ + AÔéü ┬À y / T┬▓`.
The Python large-`T` tests put the candidate `AÔéÇ` in the regime where
this bound dominates the closed-form error envelope, leaving small-`T`
to a separate finite/certificate handling.

This structure carries the candidate `bound` and a hypothesis that it
analytically lower-bounds `ÔêÆIm densityTail` on the region. Inhabiting
it for a specific `bound` is the analytic next step. -/
structure AsymptoticSmoothDensityTailLowerBound where
  densityTail : Ôäé ÔåÆ Ôäé
  T0 : ÔäØ
  bound : ÔäØ ÔåÆ ÔäØ ÔåÆ ÔäØ ÔåÆ ÔäØ
  hbound :
    ÔêÇ x y T : ÔäØ,
      T0 Ôëñ T ÔåÆ 0 < y ÔåÆ 2 * (1 + |x| + y) Ôëñ T ÔåÆ
        bound x y T Ôëñ -(densityTail ((x : Ôäé) + (y : Ôäé) * Complex.I)).im

/-- **Projection to a per-probe `SmoothTailMarginLowerBound`** at a
specific `z = x + i┬Ày` and cutoff `T` satisfying the asymptotic
hypothesis. -/
noncomputable def AsymptoticSmoothDensityTailLowerBound.atProbe
    (A : AsymptoticSmoothDensityTailLowerBound)
    (x y T : ÔäØ)
    (hT0 : A.T0 Ôëñ T) (hy : 0 < y) (hreg : 2 * (1 + |x| + y) Ôëñ T) :
    SmoothTailMarginLowerBound where
  densityTail := A.densityTail
  z := (x : Ôäé) + (y : Ôäé) * Complex.I
  T := T
  lowerBound := A.bound x y T
  tailMargin := A.hbound x y T hT0 hy hreg

-- ---------------------------------------------------------------------
-- CLII-D: Rational analytic lower bound for the smooth density tail
-- ---------------------------------------------------------------------
-- The Python tests identify the rational lower bound (from
-- `Ôê½_T^Ôê× y/((uÔêÆx)┬▓+y┬▓) du = arctan(y/(TÔêÆx))` and `arctan s ÔëÑ s/(1+s┬▓)`):
--   ÔêÆIm D_T(z)
--     ÔëÑ ¤ü(T) ┬À ( y(TÔêÆ|x|)/((TÔêÆ|x|)┬▓+y┬▓)  +  y(T+|x|)/((T+|x|)┬▓+y┬▓) ).
-- This stays log-free inside the integral and is Lean-friendly.

/-- **Rational analytic lower bound** for `ÔêÆIm(smooth density tail)`
at probe `(x, y)` with cutoff `T`:
  `¤ü(T) ┬À ( y(T ÔêÆ |x|)/((T ÔêÆ |x|)┬▓ + y┬▓) + y(T + |x|)/((T + |x|)┬▓ + y┬▓) )`
where `¤ü(T) = (1/(2¤Ç))┬Àlog(T/(2¤Ç))`. Pulled from
`arctan s ÔëÑ s/(1 + s┬▓)` applied to the elementary
`Ôê½ y/((u ┬▒ x)┬▓ + y┬▓) du = arctan(y/(T Ôêô x))`. -/
noncomputable def smoothTailRationalLowerBoundAbs (x y T : ÔäØ) : ÔäØ :=
  zeroDensityRho T *
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))

-- ---------------------------------------------------------------------
-- CLII-E: Smooth-tail rational margin bound package
-- ---------------------------------------------------------------------

/-- **Smooth-tail rational margin bound.** Records that the rational
lower bound dominates `ÔêÆIm(densityTail z)` for the given probe `z` and
cutoff `T` on the canonical adaptive `A = 2` region. The analytic
content is the `lower_le_tail` field; this structure isolates it as a
single hypothesis to be discharged. -/
structure SmoothTailRationalMarginBound where
  densityTail : Ôäé ÔåÆ Ôäé
  z : Ôäé
  T : ÔäØ
  hT : 2 * Real.pi Ôëñ T
  hy : 0 < z.im
  hsep : |z.re| < T
  lower_le_tail :
    smoothTailRationalLowerBoundAbs z.re z.im T Ôëñ -(densityTail z).im

/-- **Projection to a per-probe `SmoothTailMarginLowerBound`.** -/
noncomputable def SmoothTailRationalMarginBound.toSmoothTailMarginLowerBound
    (P : SmoothTailRationalMarginBound) :
    SmoothTailMarginLowerBound where
  densityTail := P.densityTail
  z := P.z
  T := P.T
  lowerBound := smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T
  tailMargin := P.lower_le_tail

-- ---------------------------------------------------------------------
-- CLII-F: Closed-form S-error dominated by the rational tail
-- ---------------------------------------------------------------------

/-- **Closed-form S-error dominated by the rational smooth-tail bound.**
Records the headline numerical inequality
  `closedFormSErrorBoundCD C D z.im T Ôëñ smoothTailRationalLowerBoundAbs z.re z.im T`
at the probe `z` and cutoff `T`. The Python adaptive sweep validates
this for `(C, D) = (1/2, 49/20)` with `T ÔëÑ 100` in tested regions. -/
structure ClosedFormDominatedBySmoothTail where
  z : Ôäé
  T : ÔäØ
  C : ÔäØ
  D : ÔäØ
  hdom :
    closedFormSErrorBoundCD C D z.im T
      Ôëñ smoothTailRationalLowerBoundAbs z.re z.im T

/-- Ô¡É **PROVED ÔÇö closed-form dominated by rational smooth-tail bound +
model-with-density-tail margin Ôƒ╣ hclosed closes for the full model.**
Chain:
  `closedFormSErrorBoundCD C D z.im T`
    `Ôëñ smoothTailRationalLowerBoundAbs z.re z.im T`  (hdom)
    `Ôëñ ÔêÆIm(densityTail z)`                            (P.tailMargin)
    `Ôëñ ÔêÆIm(model z)`                                  (cloud anti-Herglotz at z). -/
theorem ClosedFormDominatedBySmoothTail.closes_hclosed_via_model_decomp
    (Q : ClosedFormDominatedBySmoothTail)
    (P : SmoothTailRationalMarginBound)
    (h_z : Q.z = P.z) (h_T : Q.T = P.T)
    (cloud : Ôäé ÔåÆ Ôäé) (model : Ôäé ÔåÆ Ôäé)
    (decomp : model Q.z = cloud Q.z + P.densityTail P.z)
    (cloudAntiAt : (cloud Q.z).im Ôëñ 0) :
    closedFormSErrorBoundCD Q.C Q.D Q.z.im Q.T Ôëñ -(model Q.z).im := by
  have step1 :
      closedFormSErrorBoundCD Q.C Q.D Q.z.im Q.T
        Ôëñ smoothTailRationalLowerBoundAbs Q.z.re Q.z.im Q.T := Q.hdom
  have step2 :
      smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T
        Ôëñ -(P.densityTail P.z).im := P.lower_le_tail
  -- Identify the probes via h_z and h_T
  have h_eq : smoothTailRationalLowerBoundAbs Q.z.re Q.z.im Q.T
            = smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T := by
    rw [h_z, h_T]
  have step3 :
      -(P.densityTail P.z).im Ôëñ -(model Q.z).im := by
    rw [decomp, Complex.add_im]
    linarith
  linarith [step1, step2.trans step3, h_eq]

-- ---------------------------------------------------------------------
-- CLII-G: Large-T closed-form domination target
-- ---------------------------------------------------------------------

/-- **Large-`T` closed-form domination skeleton.** Names the final
asymptotic target: for `T ÔëÑ T0` and the canonical adaptive `A = 2`
region, the closed-form S-error bound is dominated by the rational
smooth-tail lower bound at the same probe.

The Python evidence puts a conservative `T0 = 100` in regime where this
holds for `(C, D) = (1/2, 49/20)` and `Kd = 18`. -/
structure LargeTClosedFormDomination where
  T0 : ÔäØ
  C : ÔäØ
  D : ÔäØ
  hdom :
    ÔêÇ x y T : ÔäØ,
      T0 Ôëñ T ÔåÆ 0 < y ÔåÆ 2 * (1 + |x| + y) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD C D y T
          Ôëñ smoothTailRationalLowerBoundAbs x y T

/-- Ô¡É **PROVED ÔÇö large-`T` domination Ôƒ╣ per-probe
`ClosedFormDominatedBySmoothTail`** for any `z = x + i┬Ày` with `T ÔëÑ T0`
on the canonical region. -/
noncomputable def LargeTClosedFormDomination.atProbe
    (L : LargeTClosedFormDomination)
    (x y T : ÔäØ)
    (hT0 : L.T0 Ôëñ T) (hy : 0 < y) (hreg : 2 * (1 + |x| + y) Ôëñ T) :
    ClosedFormDominatedBySmoothTail where
  z := (x : Ôäé) + (y : Ôäé) * Complex.I
  T := T
  C := L.C
  D := L.D
  hdom := by
    have h_re : ((x : Ôäé) + (y : Ôäé) * Complex.I).re = x := by
      simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    have h_im : ((x : Ôäé) + (y : Ôäé) * Complex.I).im = y := by
      simp [Complex.add_im, Complex.mul_im, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    rw [h_re, h_im]
    exact L.hdom x y T hT0 hy hreg

-- ---------------------------------------------------------------------
-- CLIII-A: Algebraic identity for the (C, D) = (1/2, 49/20) closed form
-- ---------------------------------------------------------------------
-- Computing
--   8┬Ày┬À((1/2)┬Àlog T + 49/20)/T┬▓ + 18┬Ày┬À((1/2)┬À(log T/(2T┬▓) + 1/(4T┬▓)) + (49/20)/(2T┬▓))
--   = (4 + 9/2)┬Ày┬Àlog T/T┬▓ + (8┬À49/20 + 9/4 + 9┬À49/20)┬Ày/T┬▓
--   = (17/2)┬Ày┬Àlog T/T┬▓ + (98/5 + 9/4 + 441/20)┬Ày/T┬▓
--   = (17/2)┬Ày┬Àlog T/T┬▓ + (392 + 45 + 441)/20 ┬À y/T┬▓
--   = (17/2)┬Ày┬Àlog T/T┬▓ + (878/20)┬Ày/T┬▓
--   = (y/T┬▓) ┬À ((17/2)┬Àlog T + 439/10).

/-- **Closed-form S-error bound at the pinned constants `(C, D) = (1/2, 49/20)`.**
The Python validation candidate; constants chosen to match the Trudgian
envelope `|S(u)| Ôëñ (1/2)┬Àlog u + 49/20` plus the `Kd = 18` derivative
kernel. -/
noncomputable def closedFormSErrorBoundHalf4920 (y T : ÔäØ) : ÔäØ :=
  (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)

/-- Ô¡É **PROVED ÔÇö `(C, D) = (1/2, 49/20)` collapse.** -/
theorem closedFormSErrorBoundCD_half_4920_eq
    {T : ÔäØ} (hT : T Ôëá 0) (y : ÔäØ) :
    closedFormSErrorBoundCD (1 / 2 : ÔäØ) (49 / 20 : ÔäØ) y T
      = closedFormSErrorBoundHalf4920 y T := by
  unfold closedFormSErrorBoundCD closedFormSErrorBoundHalf4920
  have hT2 : T^2 Ôëá 0 := pow_ne_zero 2 hT
  field_simp
  ring

-- ---------------------------------------------------------------------
-- CLIII-B: Geometric lower bound  rationalTail ÔëÑ (2/5)┬À¤ü(T)┬Ày/T
-- ---------------------------------------------------------------------
-- Discard the second term (nonnegative) and use the adaptive region:
--   |x| Ôëñ T/2,  y Ôëñ T/2,  T ÔêÆ |x| ÔëÑ T/2,
--   (T ÔêÆ |x|)┬▓ + y┬▓ Ôëñ T┬▓ + T┬▓/4 = (5/4)┬ÀT┬▓.
-- Then  y┬À(T ÔêÆ |x|) / ((T ÔêÆ |x|)┬▓ + y┬▓)  ÔëÑ  y┬À(T/2) / ((5/4)┬ÀT┬▓)  =  2y/(5T).

/-- Ô¡É **PROVED ÔÇö rational tail dominates the elementary `(2/5)┬À¤ü(T)┬Ày/T`
lower bound** on the canonical adaptive `A = 2` region with `T ÔëÑ 2¤Ç`.

This is the Lean translation of the user's "discard the second term,
bound the first" argument. -/
theorem smoothTailRationalLowerBoundAbs_ge_geometric
    {x y T : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) Ôëñ T) :
    (2 / 5) * zeroDensityRho T * y / T
      Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  -- ¤ü(T) ÔëÑ 0 from T ÔëÑ 2¤Ç
  have h¤ü_nn : 0 Ôëñ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_nn : 0 Ôëñ T := le_of_lt hT_pos
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  -- Adaptive ÔçÆ |x| Ôëñ T/2 and y Ôëñ T/2
  have hx_le : |x| Ôëñ T / 2 := by linarith
  have hy_le : y Ôëñ T / 2 := by linarith
  -- T ÔêÆ |x| ÔëÑ T/2 > 0, T + |x| > 0
  have h_tmx_ge_half : T / 2 Ôëñ T - |x| := by linarith
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 Ôëñ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 Ôëñ T + |x| := le_of_lt h_tpx_pos
  have h_tmx_le_T : T - |x| Ôëñ T := by linarith
  -- Denominators positive
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- Second term ÔëÑ 0
  have h_term2_nn :
      0 Ôëñ y * (T + |x|) / ((T + |x|)^2 + y^2) :=
    div_nonneg (mul_nonneg hy_nn h_tpx_nn) (le_of_lt h_denom2_pos)
  -- Numerator bound: y┬À(T/2) Ôëñ y┬À(T ÔêÆ |x|)
  have h_num_ge : y * (T / 2) Ôëñ y * (T - |x|) :=
    mul_le_mul_of_nonneg_left h_tmx_ge_half hy_nn
  -- Denominator bound: (T ÔêÆ |x|)┬▓ + y┬▓ Ôëñ (5/4)┬ÀT┬▓
  have h_tmx_sq_le : (T - |x|)^2 Ôëñ T^2 :=
    pow_le_pow_leftÔéÇ h_tmx_nn h_tmx_le_T 2
  have hy_sq_le : y^2 Ôëñ T^2 / 4 := by
    have h := pow_le_pow_leftÔéÇ hy_nn hy_le 2
    calc y^2 Ôëñ (T / 2)^2 := h
      _ = T^2 / 4 := by ring
  have h_denom1_le : (T - |x|)^2 + y^2 Ôëñ (5 / 4) * T^2 := by
    have : T^2 + T^2 / 4 = (5 / 4) * T^2 := by ring
    linarith [h_tmx_sq_le, hy_sq_le]
  -- First term ÔëÑ y(T/2) / ((5/4)┬ÀT┬▓) via div_le_divÔéÇ
  have h_term1_ge_raw :
      y * (T / 2) / ((5 / 4) * T^2)
        Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    apply div_le_divÔéÇ
    ┬À exact mul_nonneg hy_nn h_tmx_nn
    ┬À exact h_num_ge
    ┬À exact h_denom1_pos
    ┬À exact h_denom1_le
  -- Simplify  y(T/2) / ((5/4)┬ÀT┬▓)  =  2y/(5T)
  have h_simp :
      y * (T / 2) / ((5 / 4) * T^2) = 2 * y / (5 * T) := by
    have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
    field_simp
    ring
  rw [h_simp] at h_term1_ge_raw
  -- Combine: 2y/(5T) Ôëñ term1 Ôëñ term1 + term2
  have h_sum_ge :
      2 * y / (5 * T)
        Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    linarith
  -- Multiply by ¤ü(T) ÔëÑ 0
  have h_mul_le :
      zeroDensityRho T * (2 * y / (5 * T))
        Ôëñ zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge h¤ü_nn
  -- Final reshuffle: (2/5)┬À¤ü(T)┬Ày/T = ¤ü(T)┬À(2y/(5T))
  have h_eq :
      (2 / 5) * zeroDensityRho T * y / T
        = zeroDensityRho T * (2 * y / (5 * T)) := by
    have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
    field_simp
    ring
  rw [h_eq]
  exact h_mul_le

-- ---------------------------------------------------------------------
-- CLIII-C: Scalar sufficient condition + bridge
-- ---------------------------------------------------------------------

/-- **Scalar large-`T` margin condition.** The one-variable inequality
that, on the adaptive `A = 2` region with `T ÔëÑ 2¤Ç`, implies the full
three-variable closed-form domination at `(C, D) = (1/2, 49/20)`. -/
noncomputable def largeTScalarMarginCondition (T : ÔäØ) : Prop :=
  (17 / 2) * Real.log T + 439 / 10
    Ôëñ (T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi))

/-- Ô¡É **PROVED ÔÇö scalar condition Ôƒ╣ three-variable closed-form
domination at `(C, D) = (1/2, 49/20)`.**

Chain (cancelling `y > 0` and `T > 0`):
  `(y/T┬▓) ┬À ((17/2)┬Àlog T + 439/10)`
    `Ôëñ (y/T┬▓) ┬À (T/(5¤Ç)) ┬À log(T/(2¤Ç))   (scalar condition)`
    `= (2/5) ┬À ¤ü(T) ┬À y / T              (since (T/(5¤Ç))┬Àlog(T/(2¤Ç)) = (2/5)┬À¤ü(T)┬ÀT)`
    `Ôëñ smoothTailRationalLowerBoundAbs x y T   (CLIII-B). -/
theorem largeTScalarCondition_implies_domination
    {x y T : ÔäØ}
    (hT100 : 100 Ôëñ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) Ôëñ T)
    (hscalar : largeTScalarMarginCondition T) :
    closedFormSErrorBoundCD (1 / 2 : ÔäØ) (49 / 20 : ÔäØ) y T
      Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  -- Numerical: 2¤Ç < 100
  have h_2pi_lt_100 : 2 * Real.pi < 100 := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hT2pi : 2 * Real.pi Ôëñ T := le_trans (le_of_lt h_2pi_lt_100) hT100
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have hT2_pos : 0 < T^2 := by positivity
  have hT2_ne : T^2 Ôëá 0 := ne_of_gt hT2_pos
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  -- Step 1: rewrite LHS at the pinned constants
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  -- Step 2: scalar bound ÔçÆ (y/T┬▓)┬ÀLHS Ôëñ (y/T┬▓)┬ÀRHS
  have h_yT2_nn : 0 Ôëñ y / T^2 :=
    div_nonneg hy_nn (le_of_lt hT2_pos)
  have h_step2 :
      (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)
        Ôëñ (y / T^2) * ((T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi))) :=
    mul_le_mul_of_nonneg_left hscalar h_yT2_nn
  -- Step 3: (y/T┬▓)┬À(T/(5¤Ç))┬Àlog(T/(2¤Ç)) = (2/5)┬À¤ü(T)┬Ày/T
  have h_step3 :
      (y / T^2) * ((T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi)))
        = (2 / 5) * zeroDensityRho T * y / T := by
    unfold zeroDensityRho
    have hpi_ne : (Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h_pi_pos
    field_simp
    ring
  rw [h_step3] at h_step2
  -- Step 4: chain with CLIII-B
  have h_geom :
      (2 / 5) * zeroDensityRho T * y / T
        Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_geometric hT2pi hy hadapt
  linarith

-- ---------------------------------------------------------------------
-- CLIII-D: LargeTClosedFormDomination from the scalar hypothesis
-- ---------------------------------------------------------------------

/-- **Scalar large-`T` margin hypothesis.** Names the single
1-variable inequality that has to be established (by hand or numerically)
to discharge `LargeTClosedFormDomination` at the pinned constants. -/
structure LargeTScalarMarginHypothesis where
  T0 : ÔäØ
  T0_ge : 100 Ôëñ T0
  scalar : ÔêÇ T : ÔäØ, T0 Ôëñ T ÔåÆ largeTScalarMarginCondition T

/-- Ô¡É **PROVED ÔÇö `LargeTScalarMarginHypothesis` Ôƒ╣ `LargeTClosedFormDomination`
at `(C, D) = (1/2, 49/20)`.**

This is the final scalar-reduction constructor: every hypothesis on the
three-variable closed-form domination is now traceable to the named
scalar inequality. -/
noncomputable def LargeTClosedFormDomination.of_scalarHypothesis
    (H : LargeTScalarMarginHypothesis) :
    LargeTClosedFormDomination where
  T0 := H.T0
  C := 1 / 2
  D := 49 / 20
  hdom := fun x y T hT0le hy hreg => by
    have hT100 : 100 Ôëñ T := le_trans H.T0_ge hT0le
    exact largeTScalarCondition_implies_domination
            hT100 hy hreg (H.scalar T hT0le)

-- ---------------------------------------------------------------------
-- CLIV-A: Sharper geometric lower bound ÔÇö constant 2/3
-- ---------------------------------------------------------------------
-- The Python sweep shows the true universal constant on the adaptive
-- region is Ôëê 8/5 (worst case at r = 0, s = 1/2). The 2/5 bound is
-- extremely conservative. The 2/3 bound is still safe and drops the
-- scalar threshold from ~364 to ~236.
--
-- Decomposition via YÔéü/YÔéé:
--   YÔéü = y(TÔêÆ|x|)/((TÔêÆ|x|)┬▓ + y┬▓) ÔëÑ y/(2T)
--     Ôƒ║ T┬▓ ÔëÑ |x|┬▓ + y┬▓  (since 2T(T-|x|) ÔêÆ ((T-|x|)┬▓ + y┬▓) = T┬▓ ÔêÆ |x|┬▓ ÔêÆ y┬▓),
--     which holds because (|x| + y)┬▓ Ôëñ T┬▓/4 Ôëñ T┬▓.
--   YÔéé = y(T+|x|)/((T+|x|)┬▓ + y┬▓) ÔëÑ y/(6T)
--     via (T+|x|)┬▓ + y┬▓ Ôëñ 9T┬▓/4 + T┬▓/4 = 5T┬▓/2 Ôëñ 6T┬▓ Ôëñ 6T(T+|x|).
--   Sum:  YÔéü + YÔéé ÔëÑ y/(2T) + y/(6T) = 2y/(3T).

/-- Ô¡É **PROVED ÔÇö sharper rational tail lower bound, constant 2/3.**

On the canonical adaptive `A = 2` region with `T ÔëÑ 2¤Ç`:
  `smoothTailRationalLowerBoundAbs x y T ÔëÑ (2/3) ┬À ¤ü(T) ┬À y / T`.

Drops the scalar threshold from ~364 to ~236. -/
theorem smoothTailRationalLowerBoundAbs_ge_twoThirds
    {x y T : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) Ôëñ T) :
    (2 / 3) * zeroDensityRho T * y / T
      Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  have h¤ü_nn : 0 Ôëñ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have hT_nn : 0 Ôëñ T := le_of_lt hT_pos
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  have hx_le : |x| Ôëñ T / 2 := by linarith
  have hy_le : y Ôëñ T / 2 := by linarith
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 Ôëñ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 Ôëñ T + |x| := le_of_lt h_tpx_pos
  have h_tpx_le : T + |x| Ôëñ 3 * T / 2 := by linarith
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- (|x| + y) Ôëñ T/2, hence (|x|+y)┬▓ Ôëñ T┬▓/4, hence |x|┬▓ + y┬▓ Ôëñ T┬▓/4 Ôëñ T┬▓
  have h_xy_sum_le : |x| + y Ôëñ T / 2 := by linarith
  have h_xy_sum_nn : 0 Ôëñ |x| + y := by positivity
  have h_xy_sum_sq_le : (|x| + y)^2 Ôëñ (T / 2)^2 :=
    pow_le_pow_leftÔéÇ h_xy_sum_nn h_xy_sum_le 2
  have h_xy_sq_le : |x|^2 + y^2 Ôëñ T^2 / 4 := by
    have hexp : (|x| + y)^2 = |x|^2 + 2 * |x| * y + y^2 := by ring
    have hxy_prod_nn : 0 Ôëñ 2 * |x| * y := by positivity
    have h_halfT_sq : (T / 2)^2 = T^2 / 4 := by ring
    nlinarith [h_xy_sum_sq_le, hxy_prod_nn, hexp, h_halfT_sq]
  have h_T_sq_nn : 0 Ôëñ T^2 := sq_nonneg T
  have h_x_sq_y_sq_le_T_sq : |x|^2 + y^2 Ôëñ T^2 := by nlinarith
  -- Step 1: YÔéü ÔëÑ y/(2T) via 2T(T-|x|) ÔêÆ ((T-|x|)┬▓+y┬▓) = T┬▓ ÔêÆ |x|┬▓ ÔêÆ y┬▓ ÔëÑ 0
  have h_alg1 : 2 * T * (T - |x|) - ((T - |x|)^2 + y^2)
              = T^2 - |x|^2 - y^2 := by ring
  have h_alg1_nn : 0 Ôëñ 2 * T * (T - |x|) - ((T - |x|)^2 + y^2) := by
    rw [h_alg1]; linarith
  have h_2T_pos : 0 < 2 * T := by linarith
  have h_Y1_ge :
      y / (2 * T) Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    rw [div_le_div_iffÔéÇ h_2T_pos h_denom1_pos]
    have h_calc :
        y * (T - |x|) * (2 * T) - y * ((T - |x|)^2 + y^2)
          = y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) := by ring
    have h_nn :
        0 Ôëñ y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg1_nn
    linarith
  -- Step 2: YÔéé ÔëÑ y/(6T) via (T+|x|)┬▓ + y┬▓ Ôëñ 5T┬▓/2 Ôëñ 6T┬▓ Ôëñ 6T(T+|x|)
  have h_y_sq_le : y^2 Ôëñ T^2 / 4 := by
    have h := pow_le_pow_leftÔéÇ hy_nn hy_le 2
    calc y^2 Ôëñ (T / 2)^2 := h
      _ = T^2 / 4 := by ring
  have h_tpx_sq_le : (T + |x|)^2 Ôëñ 9 * T^2 / 4 := by
    have h := pow_le_pow_leftÔéÇ h_tpx_nn h_tpx_le 2
    calc (T + |x|)^2 Ôëñ (3 * T / 2)^2 := h
      _ = 9 * T^2 / 4 := by ring
  have h_alg2_bound : (T + |x|)^2 + y^2 Ôëñ 5 * T^2 / 2 := by
    have h_id : 9 * T^2 / 4 + T^2 / 4 = 5 * T^2 / 2 := by ring
    linarith
  have h_6T_tpx_ge_6T_sq : 6 * T^2 Ôëñ 6 * T * (T + |x|) := by
    have h_diff_id : 6 * T * (T + |x|) - 6 * T^2 = 6 * T * |x| := by ring
    have h_diff_nn : 0 Ôëñ 6 * T * |x| := by positivity
    linarith
  have h_alg2_ineq : (T + |x|)^2 + y^2 Ôëñ 6 * T * (T + |x|) := by
    have h_52_le_6 : 5 * T^2 / 2 Ôëñ 6 * T^2 := by nlinarith [h_T_sq_nn]
    linarith
  have h_6T_pos : 0 < 6 * T := by linarith
  have h_Y2_ge :
      y / (6 * T) Ôëñ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    rw [div_le_div_iffÔéÇ h_6T_pos h_denom2_pos]
    have h_calc :
        y * (T + |x|) * (6 * T) - y * ((T + |x|)^2 + y^2)
          = y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) := by ring
    have h_nn :
        0 Ôëñ y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) :=
      mul_nonneg hy_nn (by linarith)
    linarith
  -- Step 3: Combine ÔÇö y/(2T) + y/(6T) = 2y/(3T)
  have h_sum_eq : y / (2 * T) + y / (6 * T) = 2 * y / (3 * T) := by
    field_simp; ring
  have h_sum_ge :
      2 * y / (3 * T)
        Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h := add_le_add h_Y1_ge h_Y2_ge
    rw [h_sum_eq] at h
    exact h
  -- Multiply by ¤ü(T) ÔëÑ 0
  have h_mul :
      zeroDensityRho T * (2 * y / (3 * T))
        Ôëñ zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge h¤ü_nn
  -- Reshuffle: (2/3) ┬À ¤ü(T) ┬À y / T = ¤ü(T) ┬À (2y / (3T))
  have h_eq :
      (2 / 3) * zeroDensityRho T * y / T
        = zeroDensityRho T * (2 * y / (3 * T)) := by
    field_simp; ring
  rw [h_eq]
  exact h_mul

