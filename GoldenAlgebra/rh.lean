/-! ### CW16: numerical-extraction reformulation of `combination` -/

/-- Purely numerical data extracted from Backlund's argument at a single
good height `T`.  Existential form, suitable for use inside `Prop`
structures.  The three nonnegative contributions sum to the
`(1/2)¬Јlog T + 1/2` budget and dominate `|concreteS T|`. -/
def BacklundNumericalDataAt (T : вДЭ) : Prop :=
  вИГ Jc Rc Hc : вДЭ,
    0 вЙ§ Jc вИІ 0 вЙ§ Rc вИІ 0 вЙ§ Hc вИІ
    Jc + Rc + Hc вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 вИІ
    |concreteS T| вЙ§ Jc + Rc + Hc

/-- Classical Backlund estimates produce numerical data at every good
height.  This is where the sharp constants of Backlund's proof live. -/
structure BacklundNumericalExtractionInput : Prop where
  extract :
    вИА T : вДЭ, RvMGoodHeight T вЖТ (140 : вДЭ) вЙ§ T вЖТ
      BacklundJensenRectangleEstimate T вЖТ
      BacklundRightSideArgumentVariationEstimate T вЖТ
      BacklundHorizontalBoundaryEstimate T вЖТ
        BacklundNumericalDataAt T

/-- Bridge: numerical extraction implies the classical combination input. -/
noncomputable def BacklundNumericalExtractionInput.toCombination
    (E : BacklundNumericalExtractionInput) :
    BacklundClassicalCombinationInput where
  combine := by
    intro T hgood hT hJ hR hH
    obtain вЯ®_Jc, _Rc, _Hc, _hJc, _hRc, _hHc, htotal, hcontrolвЯ© :=
      E.extract T hgood hT hJ hR hH
    exact le_trans hcontrol htotal

/-- Final theorem from numerical extraction + count local-constancy. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction_and_countLC
    (E : BacklundNumericalExtractionInput)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_combination_and_countLC
    E.toCombination LC hT

