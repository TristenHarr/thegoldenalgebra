theorem XiPullbackAntiHerglotzTarget_of_concreteHadamard_midHigh_cloudTailLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {ι : Type}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
