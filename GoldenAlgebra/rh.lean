-- ┬зCCXXXIII. Explicit `LowHighBandData` (low + high band cover)
-- =====================================================================
-- Replaces the opaque `LowHighBandCoverData.extras : тДХ тЖТ ...` with a
-- two-named-package structure (`lowPackage`, `highPackage`) and a
-- three-way UHP cover (mid / low / high). Functionally equivalent тАФ
-- bridges to `LowHighBandCoverData` via `toCoverData`.
--
-- Adds:
--   LowHighBandData                                    тАФ two named packages
--   LowHighBandData.toCoverData                        тАФ bridge
--   XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData_lowHigh
--                                                      тАФ clean front door

/-- ЁЯУж **`LowHighBandData`** тАФ explicit low/high band coverage.
Replaces the abstract `extras : тДХ тЖТ LocalXiCloudDensityErrorPackage`
with two named packages and a three-way cover (mid / low / high). -/
structure LowHighBandData where
  lowPackage  : LocalXiCloudDensityErrorPackage
  highPackage : LocalXiCloudDensityErrorPackage
  covers :
    тИА z : тДВ, 0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) тИи
      lowPackage.region z тИи
      highPackage.region z

/-- ЁЯМЯ **PROVED тАФ `LowHighBandData.toCoverData`.** Bridge to the existing
abstract `LowHighBandCoverData`. Uses `extras 0 := lowPackage`,
`extras (n+1) := highPackage`. -/
noncomputable def LowHighBandData.toCoverData
    (B : LowHighBandData) : LowHighBandCoverData where
  extras := fun n => if n = 0 then B.lowPackage else B.highPackage
  covers := by
    intro z hz
    rcases B.covers z hz with hmid | hlow | hhigh
    ┬╖ exact Or.inl hmid
    ┬╖ refine Or.inr тЯи0, ?_тЯй
      show (if (0 : тДХ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hlow
    ┬╖ refine Or.inr тЯи1, ?_тЯй
      show (if (1 : тДХ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hhigh

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **CLEAN FRONT DOOR (explicit low/high cover).**
Final form using `XiActualTailDecompositionData` and `LowHighBandData`.
The cleanest possible statement of Route B's conditional capstone:

```
