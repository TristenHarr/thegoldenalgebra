-- =====================================================================
-- ┬зCCLXXIX. Parameterized low residual explicit bound at `(T, ╬│тВБ, D)`
-- =====================================================================
-- The ┬зCCLXXVII pair hardcoded `(T, ╬│тВБ, D) := (2╧А, 14, 1/2)`, but the
-- numerical audit shows this is infeasible at the worst point
-- `(x, y) = (0, 4)`: residual bound тЙИ 0.77 vs model lower bound тЙИ 0.20.
-- This section parameterizes the low explicit bound and the
-- arithmetic obligation over `(T, ╬│тВБ, D)` so a feasible combination
-- can be plugged in (current numerical candidate: `(10, 14, 2/5)`,
-- worst-point margin тЙИ 3.6├Ч10тБ╗тБ┤; safer fallback: `(11, 14, 1/2)`,
-- worst-point margin тЙИ 9.7├Ч10тБ╗┬│).
--
-- Adds:
--   lowResidualExplicitBoundAt                          тАФ parameterized closed form
--   lowResidualExplicitBound_eq_At                      тАФ specialization rfl
--   XiLowResidualExplicitDataAt                         тАФ residual тЙд explicit bound
--   LowMarginDominatesExplicitBoundAt                   тАФ explicit bound тЙд model margin
--   LowExplicitArithmeticBoundAt                        тАФ pure arithmetic obligation
--   XiLowResidualMargin_of_explicitAt_and_marginAt      тАФ bridge to XiLowResidualMargin
--   LowMarginDominatesExplicitBoundAt_twoPi_of_arithAt  тАФ _of_arith reduction
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicitAt
--                                                       тАФ front door consuming named At Props
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicitAt_arith
--                                                       тАФ front door consuming At-arith directly

/-- **Parameterized low residual explicit bound** тАФ
`closedFormFirstZeroErrorBound` at user-supplied first-zero parameters
`(T, ╬│тВБ, D)`. The ┬зCCLXXVII constant-parameter `lowResidualExplicitBound`
is the `(2╧А, 14, 1/2)` specialization (definitionally). -/
noncomputable def lowResidualExplicitBoundAt
    (T gamma1 D : тДЭ) (z : тДВ) : тДЭ :=
  closedFormFirstZeroErrorBound z.im T gamma1 D

/-- тнР **PROVED тАФ `lowResidualExplicitBound` is the `(2╧А, 14, 1/2)`
specialization of the parameterized form.** -/
lemma lowResidualExplicitBound_eq_At (z : тДВ) :
    lowResidualExplicitBound z
      = lowResidualExplicitBoundAt (2 * Real.pi) 14 (1 / 2) z := rfl

/-- ЁЯУж **`XiLowResidualExplicitDataAt T ╬│тВБ D M`** тАФ parameterized
analogue of ┬зCCLXXVII `XiLowResidualExplicitData`: on the compact low
region, the canonical residual's `Im` is bounded by the parameterized
explicit bound. -/
structure XiLowResidualExplicitDataAt
    (T gamma1 D : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_bound :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      |(xiResidualError M z).im| тЙд lowResidualExplicitBoundAt T gamma1 D z

/-- ЁЯУж **`LowMarginDominatesExplicitBoundAt T ╬│тВБ D M`** тАФ
parameterized analogue of ┬зCCLXXVII `LowMarginDominatesExplicitBound`. -/
def LowMarginDominatesExplicitBoundAt
    (T gamma1 D : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop :=
  тИА z : тДВ,
    lowCompactRegion z тЖТ
    lowResidualExplicitBoundAt T gamma1 D z тЙд -(M.model z).im

/-- ЁЯУж **`LowExplicitArithmeticBoundAt T ╬│тВБ D`** тАФ parameterized
analogue of ┬зCCLXXVIII `LowExplicitArithmeticBound`. Pure arithmetic
inequality between the parameterized closed-form residual bound and
the model-side `simpleCloudSum + smoothTailRationalLowerBoundAbs(...,10)`
lower bound. The smooth inner cutoff is fixed at `10`, the forced
choice on the low compact region. -/
def LowExplicitArithmeticBoundAt (T gamma1 D : тДЭ) : Prop :=
  тИА z : тДВ,
    lowCompactRegion z тЖТ
    lowResidualExplicitBoundAt T gamma1 D z
      тЙд simpleCloudSum zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbs z.re z.im 10

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `XiLowResidualMargin` from the parameterized
two-piece split.** -/
theorem XiLowResidualMargin_of_explicitAt_and_marginAt
