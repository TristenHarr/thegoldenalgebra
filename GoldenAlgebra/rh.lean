/-! ### CE2: Backlund-Turing analytic inputs from the RvM package + extensions -/

/-- Build `BacklundTuringAnalyticInputs` from the master RvM analytic input
package plus the good-height extension and the Backlund bound + extension. -/
noncomputable def BacklundTuringAnalyticInputs.of_rvMGoodHeightInputs
    (I : RvMGoodHeightAnalyticInputs)
    (Ext : RvMGoodHeightExtension
            I.toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BGood : BacklundArgumentBoundOnGoodHeights I.Sarg)
    (BExt : BacklundGoodHeightBoundExtension BGood) :
    BacklundTuringAnalyticInputs where
  goodHeightFamily := I.toSafeRectangleFamily.toConcreteRectangleFamily.toRectangleFamily
  goodHeightExtension := Ext
  backlundGood := BGood
  backlundExtension := BExt

/-! ### CE3: concrete-`S` half-log-plus-half bound from the analytic package -/

/-- Final headline-style theorem from the RvM analytic input package +
extensions + Backlund bounds. -/
theorem RvMGoodHeightAnalyticInputs.to_concreteS_halfLogPlusHalf
    (I : RvMGoodHeightAnalyticInputs)
    (Ext : RvMGoodHeightExtension
            I.toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BGood : BacklundArgumentBoundOnGoodHeights I.Sarg)
    (BExt : BacklundGoodHeightBoundExtension BGood)
    {T : ℝ} (hT : BGood.lower ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  (BacklundTuringAnalyticInputs.of_rvMGoodHeightInputs I Ext BGood BExt
    ).concreteS_halfLogPlusHalf hT

/-! ## CF: Global zeta-zero classification → safe-height data -/

/-! ### CF1: zeta-zero classification input -/

/-- Global zeta-zero classification facts (proved from the functional
equation + standard zero theory):

* `left_edge_zero_free`: `ζ ≠ 0` on the vertical line `Re = -1`.
* `zeros_nontrivial_of_pos_im`: every zeta zero with positive imaginary
  part is a nontrivial zero (rules out trivial and exotic zeros). -/
structure ZetaZeroClassificationInput : Prop where
  left_edge_zero_free :
    ∀ y : ℝ, riemannZeta ⟨-1, y⟩ ≠ 0
  zeros_nontrivial_of_pos_im :
    ∀ z : ℂ, 0 < z.im → riemannZeta z = 0 → IsNontrivialZetaZero z

/-! ### CF2: safe-height data from zero classification + good height -/

/-- Given the global zero-classification facts plus a good height
`T > 0`, build the safe-height data: pick a good bottom in `(0, T)` via
CB7, and discharge every classification field of `zeroClass` from `ZC`. -/
noncomputable def rvmSafeHeightDataOfZeroClassification
    (ZC : ZetaZeroClassificationInput)
    {T : ℝ} (hT : RvMGoodHeight T) (hTpos : 0 < T) :
    ZetaRectangle.RvMSafeHeightData T :=
  let hexists := ZetaRectangle.existsSafeBottomHeight hTpos
  let B := Classical.choose hexists
  let hspec := Classical.choose_spec hexists
  { B := B
    B_pos := hspec.1
    B_lt_T := hspec.2.1
    goodBottom := hspec.2.2
    goodTop := hT.good
    zeroClass :=
      { left_edge := ZC.left_edge_zero_free
        bottom_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; exact hspec.1) hzeta
        top_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; linarith [hspec.1, hspec.2.1]) hzeta
        interior_zeros_nontrivial := fun z hzOpen hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by
              have hB_lt : B < z.im := hzOpen.2.2.1
              linarith [hspec.1])
            hzeta } }

/-! ## CG: Split `ZetaZeroClassificationInput` into Mathlib-facing targets -/

/-! ### CG1: split into vertical-line and positive-im classification -/

/-- No zeta zero on the vertical line `Re s = -1`.  Functional-equation
target. -/
def ZetaLeftEdgeZeroFree : Prop :=
  ∀ y : ℝ, riemannZeta ⟨-1, y⟩ ≠ 0

/-- Every zeta zero with positive imaginary part is a nontrivial zero. -/
def ZetaZeroPositiveImaginaryNontrivial : Prop :=
  ∀ z : ℂ, 0 < z.im → riemannZeta z = 0 → IsNontrivialZetaZero z

/-! ### CG2a: proven half of CG2 — `z.re < 1` from `riemannZeta_ne_zero_of_one_le_re` -/

/-- Every zeta zero satisfies `Re z < 1` — immediate from
`riemannZeta_ne_zero_of_one_le_re`. -/
theorem zetaZero_re_lt_one {z : ℂ} (hzeta : riemannZeta z = 0) :
    z.re < 1 := by
  by_contra h
  push_neg at h
  exact riemannZeta_ne_zero_of_one_le_re h hzeta

/-! ### CG2b: sub-target — `0 < z.re` for zeros with positive imaginary part -/

/-- Sub-target: every zeta zero with positive imaginary part satisfies
`0 < Re z`.  Functional-equation content (zeros with `Re z ≤ 0` are the
trivial zeros, which are real). -/
def ZetaZeroPosImagPosRe : Prop :=
  ∀ z : ℂ, 0 < z.im → riemannZeta z = 0 → 0 < z.re

/-- Combine the sub-target `0 < Re z` with the proved upper bound
`Re z < 1` to discharge `ZetaZeroPositiveImaginaryNontrivial`. -/
theorem ZetaZeroPositiveImaginaryNontrivial.of_posRe
    (H : ZetaZeroPosImagPosRe) :
    ZetaZeroPositiveImaginaryNontrivial :=
  fun z hzIm hzeta =>
    ⟨hzeta, H z hzIm hzeta, zetaZero_re_lt_one hzeta⟩

/-! ### CG4: split combinator for the full classification input -/

/-- Inhabit `ZetaZeroClassificationInput` from the two split targets. -/
def ZetaZeroClassificationInput.of_split
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPositiveImaginaryNontrivial) :
    ZetaZeroClassificationInput where
  left_edge_zero_free := Hleft
  zeros_nontrivial_of_pos_im := Hpos

/-- Two-level split: a left-edge target plus the proved upper bound plus
the lower-bound sub-target. -/
def ZetaZeroClassificationInput.of_three_targets
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPosImagPosRe) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_split Hleft
    (ZetaZeroPositiveImaginaryNontrivial.of_posRe Hpos)

/-! ## CH: Functional-equation zero-transfer wrapper -/

/-- Functional-equation zero transfer package: bundles the two
functional-equation consequences `ZetaLeftEdgeZeroFree` and
`ZetaZeroPosImagPosRe`.  Either field is a direct consequence of
`riemannZeta_one_sub` plus nonvanishing of the trig/Γ/cpow/ζ(2-iy)
factors. -/
structure ZetaFunctionalEquationZeroTransferInput : Prop where
  left_edge : ZetaLeftEdgeZeroFree
  pos_im_pos_re : ZetaZeroPosImagPosRe

/-- Inhabit `ZetaZeroClassificationInput` from the functional-equation
zero-transfer package — closes the entire zero-classification side
modulo two functional-equation Props. -/
def ZetaZeroClassificationInput.of_functionalEquationTransfer
    (F : ZetaFunctionalEquationZeroTransferInput) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_three_targets F.left_edge F.pos_im_pos_re

/-! ### CH (extended): standard functional-equation zero-free facts -/

/-- The standard functional-equation consequence: `ζ` has no zeros in the
left half-plane (`Re ≤ 0`) at positive imaginary heights.  Equivalent to
the classical statement that `ζ` zeros outside the critical strip are
exactly the real trivial zeros. -/
def ZetaNoZerosLeftHalfPlaneUpper : Prop :=
  ∀ z : ℂ, z.re ≤ 0 → 0 < z.im → riemannZeta z ≠ 0

/-- The functional-equation no-zero fact in the left half-plane upper
half implies the sub-target `ZetaZeroPosImagPosRe`.  Contrapositive: a
zero with `Im > 0` and `Re ≤ 0` would contradict the no-zero fact. -/
theorem ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper
    (H : ZetaNoZerosLeftHalfPlaneUpper) :
    ZetaZeroPosImagPosRe := by
  intro z hzIm hzeta
  by_contra hzre_not
  have hzre : z.re ≤ 0 := le_of_not_gt hzre_not
  exact H z hzre hzIm hzeta

/-- Bundled standard functional-equation zero-free facts: the no-zero
property in the left half-plane upper half + the (broader) no-zero
property on the vertical line `Re = -1`. -/
structure ZetaFunctionalEquationStandardZeroFacts : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeZeroFree : ZetaLeftEdgeZeroFree

/-- The standard zero-free facts inhabit the transfer input package — only
the two named functional-equation Props remain. -/
def ZetaFunctionalEquationStandardZeroFacts.toTransferInput
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaFunctionalEquationZeroTransferInput where
  left_edge := F.leftEdgeZeroFree
  pos_im_pos_re :=
    ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper F.noZerosLeftHalfPlaneUpper

/-- Top-level: inhabit `ZetaZeroClassificationInput` directly from the
standard functional-equation facts. -/
def ZetaZeroClassificationInput.of_standardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_functionalEquationTransfer F.toTransferInput

/-! ## CL: Functional-equation transfer on the line `Re = -1` -/

/-! ### CL1: easy right-half nonzero + transfer Prop -/

/-- For real `y`, `(1 - ⟨-1, y⟩).re = 2`, so `ζ ≠ 0` there via
`riemannZeta_ne_zero_of_one_lt_re`. -/
theorem zeta_one_sub_leftEdge_ne_zero (y : ℝ) :
    riemannZeta ((1 : ℂ) - ⟨(-1 : ℝ), y⟩) ≠ 0 := by
  apply riemannZeta_ne_zero_of_one_lt_re
  show (1 : ℝ) < ((1 : ℂ) - ⟨(-1 : ℝ), y⟩).re
  simp [Complex.sub_re, Complex.one_re]

/-- Functional-equation nonzero transfer on the line `Re s = -1`: if
`ζ(1 - z) ≠ 0`, then `ζ(z) ≠ 0`, for `z = ⟨-1, y⟩`.  This is the precise
Mathlib-facing analytic obligation underlying `ZetaLeftEdgeZeroFree`. -/
def ZetaFunctionalEquationLeftEdgeTransfer : Prop :=
  ∀ y : ℝ,
    riemannZeta ((1 : ℂ) - ⟨(-1 : ℝ), y⟩) ≠ 0 →
      riemannZeta ⟨(-1 : ℝ), y⟩ ≠ 0

/-- `ZetaLeftEdgeZeroFree` follows from the functional-equation transfer
plus the easy right-half nonzero fact `zeta_one_sub_leftEdge_ne_zero`. -/
theorem ZetaLeftEdgeZeroFree.of_functionalEquationTransfer
    (H : ZetaFunctionalEquationLeftEdgeTransfer) :
    ZetaLeftEdgeZeroFree := fun y =>
  H y (zeta_one_sub_leftEdge_ne_zero y)

/-! ### CL4: standard zero facts via the transfer Prop -/

/-- Variant of `ZetaFunctionalEquationStandardZeroFacts` that takes the
functional-equation transfer (CL1) instead of the assembled
`leftEdgeZeroFree`.  This reduces the left-edge obligation to a single
precise FE transfer lemma. -/
structure ZetaFunctionalEquationStandardZeroFactsViaTransfer : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeTransfer : ZetaFunctionalEquationLeftEdgeTransfer

/-- The transfer-based standard facts package inhabits the original
assembled package. -/
def ZetaFunctionalEquationStandardZeroFactsViaTransfer.toStandardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer) :
    ZetaFunctionalEquationStandardZeroFacts where
  noZerosLeftHalfPlaneUpper := F.noZerosLeftHalfPlaneUpper
  leftEdgeZeroFree :=
    ZetaLeftEdgeZeroFree.of_functionalEquationTransfer F.leftEdgeTransfer

/-! ## CI: Tautological `mainEval` via `concreteS` as `Sarg` -/

/-! ### CI3: build `RvMGoodHeightAnalyticInputs` from safe-data, with `Sarg := concreteS` -/

/-- Build `RvMGoodHeightAnalyticInputs` using `concreteS` as the
correction term `Sarg`.  The `mainEval` field is then immediate from
`concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm`. -/
noncomputable def RvMGoodHeightAnalyticInputs.of_concreteS_safeData
    (safe :
      ∀ T : ℝ, RvMGoodHeight T → ZetaRectangle.RvMSafeHeightData T) :
    RvMGoodHeightAnalyticInputs where
  Sarg := concreteS
  safeData := safe
  mainEval := fun T hT => by
    have h := concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm hT.nonneg
    linarith

/-! ### CI4: top-level pipeline from zero-classification + height-positivity -/

/-- The final pipeline assembler: given the zeta-zero classification
package (closing the rectangle-side analytic content), build the full
`RvMGoodHeightAnalyticInputs` — `RvMGoodHeight T` now bakes in the
required positivity, so no extra hypothesis is needed. -/
noncomputable def RvMGoodHeightAnalyticInputs.of_zeroClassification
    (ZC : ZetaZeroClassificationInput) :
    RvMGoodHeightAnalyticInputs :=
  RvMGoodHeightAnalyticInputs.of_concreteS_safeData
    (fun _ hT => rvmSafeHeightDataOfZeroClassification ZC hT hT.pos)

/-! ## CM: Concrete `concreteS` Backlund estimate on good heights -/

/-! ### CM1: data package -/

/-- The concrete Backlund estimate for `concreteS` on good heights.
Bundles a threshold `lower ≥ 2π` and the half-log-plus-half bound
above the threshold.  This is the analytic estimate that remains after
all rectangle/contour/RvM plumbing. -/
structure ConcreteSBacklundEstimateOnGoodHeights where
  lower : ℝ
  lower_ge_two_pi : 2 * Real.pi ≤ lower
  bound :
    ∀ T : ℝ, RvMGoodHeight T → lower ≤ T →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-! ### CM2: conversion to existing `BacklundArgumentBoundOnGoodHeights` -/

/-- The concrete-S estimate inhabits the existing
`BacklundArgumentBoundOnGoodHeights concreteS` package by promoting the
`GoodHeight T + lower ≤ T` pair to `RvMGoodHeight T` via the positivity
`0 < lower`. -/
noncomputable def
    ConcreteSBacklundEstimateOnGoodHeights.toBacklundArgumentBoundOnGoodHeights
    (E : ConcreteSBacklundEstimateOnGoodHeights) :
    BacklundArgumentBoundOnGoodHeights concreteS where
  lower := E.lower
  lower_ge_two_pi := E.lower_ge_two_pi
  bound := fun T hlower hgood => by
    refine E.bound T ⟨?_, hgood⟩ hlower
    have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
    linarith [E.lower_ge_two_pi]

/-! ### CM3: 140-threshold version -/

/-- The classical Backlund-style 140-threshold estimate for `concreteS`
on good heights.  Plain `Prop` of `∀`, since the threshold is fixed. -/
def ConcreteSBacklundEstimateFrom140OnGoodHeights : Prop :=
  ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- The 140-threshold estimate inhabits the data package with
`lower := 140` (since `2π < 8 < 140`). -/
noncomputable def ConcreteSBacklundEstimateFrom140OnGoodHeights.toEstimate
    (H : ConcreteSBacklundEstimateFrom140OnGoodHeights) :
    ConcreteSBacklundEstimateOnGoodHeights where
  lower := 140
  lower_ge_two_pi := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  bound := H

/-! ### CM4: final headline theorem from the 140-threshold + extension package -/

/-- **CM4 — FINAL ASSEMBLER:** the classical 140-threshold estimate plus
the four other analytic inputs yields the headline half-log-plus-half
bound on `concreteS` for every `T ≥ 140`. -/
theorem ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (Ext : RvMGoodHeightExtension
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BExt : BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 := by
  let ZC := ZetaZeroClassificationInput.of_standardZeroFacts F.toStandardZeroFacts
  let I := RvMGoodHeightAnalyticInputs.of_zeroClassification ZC
  exact I.to_concreteS_halfLogPlusHalf Ext
    H140.toEstimate.toBacklundArgumentBoundOnGoodHeights BExt hT

/-! ## CN: `BacklundGoodHeightBoundExtension` from good-height closure -/

/-! ### CN1: closure/continuity input package -/

/-- Continuity-style closure for the concrete Backlund bound: if at every
height above the threshold there is an arbitrarily-close good-height
witness of the bound, then the bound holds at that height. -/
structure ConcreteSBoundGoodHeightClosure (lower : ℝ) : Prop where
  closure :
    ∀ T : ℝ, lower ≤ T →
      (∀ ε : ℝ, 0 < ε →
        ∃ U : ℝ, RvMGoodHeight U ∧ lower ≤ U ∧ |U - T| < ε ∧
          |concreteS U| ≤ (1 / 2 : ℝ) * Real.log U + 1 / 2) →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-! ### CN2: good-height density right-approximation above a positive threshold -/

/-- Right-approximation: for `T` at or above a positive `lower`, every
positive `ε` produces a good height `U ∈ (T, T + ε)` with `lower ≤ U`. -/
theorem exists_goodHeight_near_right_ge_lower
    {lower T ε : ℝ}
    (hLower_pos : 0 < lower) (hLT : lower ≤ T) (hε : 0 < ε) :
    ∃ U : ℝ, RvMGoodHeight U ∧ lower ≤ U ∧ |U - T| < ε := by
  have hTpos : 0 < T := lt_of_lt_of_le hLower_pos hLT
  obtain ⟨U, hTU, hUeps, hUgood⟩ :=
    exists_goodHeight_between_self_add hTpos hε
  have hUpos : 0 < U := lt_trans hTpos hTU
  refine ⟨U, { pos := hUpos, good := hUgood }, ?_, ?_⟩
  · linarith
  · rw [abs_of_pos (by linarith : (0 : ℝ) < U - T)]
    linarith

/-! ### CN3: build `BacklundGoodHeightBoundExtension` from closure + estimate -/

/-- The closure principle (CN1) plus the good-height Backlund estimate
(CM3) yields the `BacklundGoodHeightBoundExtension`. -/
noncomputable def BacklundGoodHeightBoundExtension.of_closure
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (C : ConcreteSBoundGoodHeightClosure 140) :
    BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights where
  bound_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ε hε
    have h140_pos : (0 : ℝ) < 140 := by norm_num
    obtain ⟨U, hUgood, hUlower, hdist⟩ :=
      exists_goodHeight_near_right_ge_lower
        (lower := 140) h140_pos hT hε
    exact ⟨U, hUgood, hUlower, hdist, H140 U hUgood hUlower⟩

/-! ### CN4: final theorem using the closure principle instead of `BExt` -/

/-- **CN4 — alternate final assembler:** uses the closure principle
(CN1) in place of the `BacklundGoodHeightBoundExtension` field. -/
theorem ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf_of_closure
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (Ext : RvMGoodHeightExtension
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (C : ConcreteSBoundGoodHeightClosure 140)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  H140.to_concreteS_halfLogPlusHalf F Ext
    (BacklundGoodHeightBoundExtension.of_closure H140 C) hT

/-! ## CO: `RvMGoodHeightExtension` from RvM-formula closure -/

/-! ### CO1: density of good heights near any nonnegative `T` -/

/-- For every nonnegative `T` and every `ε > 0`, there is a good RvM
height `U` with `|U - T| < ε`.  Uses `exists_goodHeight_between` for
the boundary case `T = 0` and `exists_goodHeight_between_self_add`
for `T > 0`. -/
theorem exists_goodHeight_near
    {T ε : ℝ} (hT : 0 ≤ T) (hε : 0 < ε) :
    ∃ U : ℝ, RvMGoodHeight U ∧ |U - T| < ε := by
  rcases eq_or_lt_of_le hT with hT_eq | hT_pos
  · -- T = 0: pick U ∈ (ε/2, ε)
    have hε_half_pos : (0 : ℝ) < ε / 2 := by linarith
    have hε_half_lt : ε / 2 < ε := by linarith
    obtain ⟨U, hAU, hUB, hUgood⟩ :=
      exists_goodHeight_between hε_half_pos hε_half_lt
    refine ⟨U, ⟨lt_trans hε_half_pos hAU, hUgood⟩, ?_⟩
    rw [← hT_eq, sub_zero, abs_of_pos (lt_trans hε_half_pos hAU)]
    exact hUB
  · -- T > 0: pick U ∈ (T, T+ε)
    obtain ⟨U, hTU, hUeps, hUgood⟩ :=
      exists_goodHeight_between_self_add hT_pos hε
    refine ⟨U, ⟨lt_trans hT_pos hTU, hUgood⟩, ?_⟩
    rw [abs_of_pos (by linarith : (0 : ℝ) < U - T)]
    linarith

/-! ### CO2: closure principle for the RvM formula -/

/-- Closure/continuity principle for extending the RvM formula from
good heights to all nonnegative heights: if at every nonnegative `T`
there is an arbitrarily-close good-height witness of the formula, then
the formula holds at `T`. -/
structure RvMFormulaGoodHeightClosure
    (Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights) : Prop where
  closure :
    ∀ T : ℝ, ∀ hT : 0 ≤ T,
      (∀ ε : ℝ, 0 < ε →
        ∃ U : ℝ, ∃ hU : RvMGoodHeight U, |U - T| < ε ∧
          (zetaWeightedZeroCountUpToHeight U hU.nonneg : ℝ) =
            riemannVonMangoldtMainTerm U + Fgood.Sarg U) →
      (zetaWeightedZeroCountUpToHeight T hT : ℝ) =
        riemannVonMangoldtMainTerm T + Fgood.Sarg T

/-! ### CO3: build `RvMGoodHeightExtension` from the closure principle -/

/-- The RvM-formula closure principle inhabits `RvMGoodHeightExtension`:
for any `T ≥ 0`, produce a nearby good height (CO1) and use the closure
plus `Fgood.formula` at the witness. -/
noncomputable def RvMGoodHeightExtension.of_closure
    {Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights}
    (C : RvMFormulaGoodHeightClosure Fgood) :
    RvMGoodHeightExtension Fgood where
  formula_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ε hε
    obtain ⟨U, hUgood, hdist⟩ := exists_goodHeight_near hT hε
    exact ⟨U, hUgood, hdist, Fgood.formula U hUgood⟩

/-! ### CO4: final theorem using both closure principles -/

/-- **CO4 — FINAL ASSEMBLER WITH BOTH CLOSURES:** the headline bound
on `concreteS` for all `T ≥ 140`, derived from exactly four analytic
inputs: functional-equation zero facts, the good-height Backlund
estimate from 140, the RvM-formula closure, and the Backlund-bound
closure. -/
theorem ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf_of_closures
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (RvMC : RvMFormulaGoodHeightClosure
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BC : ConcreteSBoundGoodHeightClosure 140)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  H140.to_concreteS_halfLogPlusHalf_of_closure F
    (RvMGoodHeightExtension.of_closure RvMC) BC hT

/-! ## CP: Right-sided closure for the `concreteS` bound -/

/-! ### CP1: right-sided closure principle -/

/-- Right-sided closure: if every threshold-respecting `T` admits good-
height witnesses on the right (`T ≤ U < T + ε`) where the bound holds,
then the bound holds at `T`.  Strictly stronger usage than the symmetric
`ConcreteSBoundGoodHeightClosure` because the witness lies on the right
of `T`. -/
structure ConcreteSRightClosure (lower : ℝ) : Prop where
  closure :
    ∀ T : ℝ, lower ≤ T →
      (∀ ε : ℝ, 0 < ε →
        ∃ U : ℝ, RvMGoodHeight U ∧ lower ≤ U ∧ T ≤ U ∧ U < T + ε ∧
          |concreteS U| ≤ (1 / 2 : ℝ) * Real.log U + 1 / 2) →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-! ### CP2: right-sided good-height density above a positive threshold -/

/-- Right-sided refinement of `exists_goodHeight_near_right_ge_lower`:
extracts `T ≤ U < T + ε` directly. -/
theorem exists_goodHeight_right_near
    {lower T ε : ℝ}
    (hLower_pos : 0 < lower) (hLT : lower ≤ T) (hε : 0 < ε) :
    ∃ U : ℝ, RvMGoodHeight U ∧ lower ≤ U ∧ T ≤ U ∧ U < T + ε := by
  have hTpos : 0 < T := lt_of_lt_of_le hLower_pos hLT
  obtain ⟨U, hTU, hUeps, hUgood⟩ :=
    exists_goodHeight_between_self_add hTpos hε
  have hUpos : 0 < U := lt_trans hTpos hTU
  exact ⟨U, ⟨hUpos, hUgood⟩, by linarith, le_of_lt hTU, hUeps⟩

/-! ### CP3: `BacklundGoodHeightBoundExtension` from right closure + H140 -/

/-- The right closure principle plus the good-height Backlund estimate
yields `BacklundGoodHeightBoundExtension`.  Compared with CN3 the
witness now lies on the right of `T`, matching the right-continuity
structure of the analytic limit. -/
noncomputable def BacklundGoodHeightBoundExtension.of_rightClosure
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (C : ConcreteSRightClosure 140) :
    BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights where
  bound_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ε hε
    have h140_pos : (0 : ℝ) < 140 := by norm_num
    obtain ⟨U, hUgood, hUlower, hTU, hUeps⟩ :=
      exists_goodHeight_right_near h140_pos hT hε
    exact ⟨U, hUgood, hUlower, hTU, hUeps, H140 U hUgood hUlower⟩

/-! ### CP4: final theorem using right closure for the Backlund side -/

/-- **CP4 — final theorem with right-sided Backlund closure:** uses the
right-sided closure (CP1) for the Backlund bound side, alongside the
RvM-formula closure (CO2). -/
theorem
    ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf_of_rightClosures
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (RvMC : RvMFormulaGoodHeightClosure
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BC : ConcreteSRightClosure 140)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  H140.to_concreteS_halfLogPlusHalf F
    (RvMGoodHeightExtension.of_closure RvMC)
    (BacklundGoodHeightBoundExtension.of_rightClosure H140 BC) hT

/-! ## CQ: Direct extension package for the Backlund bound -/

/-! ### CQ1: direct extension structure -/

/-- Direct extension of the good-height Backlund estimate to all heights
above the threshold.  This packages the zero-count jump/right-limit
analysis in exactly the form needed — extending an inequality from a
dense subset of heights is not a pure-continuity fact; it requires the
zero-count regularity argument. -/
structure ConcreteSBacklundEstimateExtensionFrom140
    (_ : ConcreteSBacklundEstimateFrom140OnGoodHeights) : Prop where
  extension :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-! ### CQ2: derive `ConcreteSRightClosure 140` from the direct extension -/

/-- Once the direct extension is supplied, every threshold-respecting
`T` already satisfies the bound — so the closure principle holds
trivially. -/
noncomputable def ConcreteSRightClosure.of_directExtension
    {H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights}
    (E : ConcreteSBacklundEstimateExtensionFrom140 H140) :
    ConcreteSRightClosure 140 where
  closure := fun T hT _ => E.extension T hT

/-! ### CQ3: final headline theorem using the direct extension -/

/-- **CQ3 — FINAL THEOREM WITH DIRECT EXTENSION:** the headline bound
on `concreteS` for all `T ≥ 140`, derived from exactly four analytic
inputs — the zero classification, the Backlund estimate on good heights,
the RvM-formula closure, and the direct Backlund-estimate extension. -/
theorem
    ConcreteSBacklundEstimateFrom140OnGoodHeights.to_concreteS_halfLogPlusHalf_of_directExtension
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (_RvMC : RvMFormulaGoodHeightClosure
      (RvMGoodHeightAnalyticInputs.of_zeroClassification
        (ZetaZeroClassificationInput.of_standardZeroFacts
          F.toStandardZeroFacts)).toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (E : ConcreteSBacklundEstimateExtensionFrom140 H140)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  E.extension T hT

/-! ## CR: Functional-equation left-edge zero transfer (proof attempt) -/

/-- `cos(π * ⟨2, -y⟩ / 2) = -cosh(πy/2)`.  Decomposes the argument as
`π + (-πy/2)·I` and uses the angle-addition formula + `cos(x·I) = cosh x`. -/
theorem cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh (y : ℝ) :
    Complex.cos ((Real.pi : ℂ) * (⟨2, -y⟩ : ℂ) / 2) =
      -((Real.cosh (Real.pi * y / 2) : ℝ) : ℂ) := by
  have h_decomp :
      ((Real.pi : ℂ) * (⟨2, -y⟩ : ℂ) / 2) =
        (Real.pi : ℂ) + (-((Real.pi * y / 2 : ℝ) : ℂ)) * Complex.I := by
    apply Complex.ext
    · simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_re,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
    · simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_im,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
      ring
  rw [h_decomp, Complex.cos_add]
  have h_cos_pi : Complex.cos (Real.pi : ℂ) = -1 := by
    rw [← Complex.ofReal_cos, Real.cos_pi]; push_cast; rfl
  have h_sin_pi : Complex.sin (Real.pi : ℂ) = 0 := by
    rw [← Complex.ofReal_sin, Real.sin_pi]; push_cast; rfl
  rw [h_cos_pi, h_sin_pi]
  rw [Complex.cos_mul_I]
  rw [show -((Real.pi * y / 2 : ℝ) : ℂ) = -(((Real.pi * y / 2 : ℝ) : ℂ)) from rfl,
      Complex.cosh_neg]
  rw [Complex.ofReal_cosh]
  ring

/-- Nonvanishing of the cosine factor in the FE at `s = ⟨2, -y⟩`. -/
theorem cos_pi_mul_twoMinusYI_div_two_ne_zero (y : ℝ) :
    Complex.cos ((Real.pi : ℂ) * (⟨2, -y⟩ : ℂ) / 2) ≠ 0 := by
  rw [cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh]
  rw [neg_ne_zero, Complex.ofReal_ne_zero]
  exact (Real.cosh_pos _).ne'

/-- **CR — PROVED:** the functional-equation left-edge nonzero transfer.
At `s = ⟨2, -y⟩` we apply `riemannZeta_one_sub` and show every factor on
the right is nonzero. -/
theorem zetaFunctionalEquationLeftEdgeTransfer :
    ZetaFunctionalEquationLeftEdgeTransfer := by
  intro y _hright
  set s : ℂ := ⟨2, -y⟩ with hs_def
  have h_s_re : s.re = 2 := by simp [hs_def]
  have h_one_sub_s : (1 : ℂ) - s = ⟨(-1 : ℝ), y⟩ := by
    apply Complex.ext
    · show (1 - s).re = -1
      simp [hs_def, Complex.sub_re, Complex.one_re]
      norm_num
    · show (1 - s).im = y
      simp [hs_def, Complex.sub_im, Complex.one_im]
  have h_s_ne_neg_n : ∀ n : ℕ, s ≠ -↑n := by
    intro n h
    have h_re : s.re = (-(n : ℂ)).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (α := ℝ) n]
  have h_s_ne_one : s ≠ 1 := by
    intro h
    have h_re : s.re = (1 : ℂ).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
  rw [← h_one_sub_s, riemannZeta_one_sub h_s_ne_neg_n h_s_ne_one]
  have h_2pi_ne_C : ((2 : ℂ) * (Real.pi : ℂ)) ≠ 0 := by
    have hπ : (Real.pi : ℂ) ≠ 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) hπ
  have h_2pi_pow : ((2 * (Real.pi : ℂ)) ^ (-s)) ≠ 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s ≠ 0 := by
    apply Complex.Gamma_ne_zero_of_re_pos
    rw [h_s_re]; norm_num
  have h_zeta_ne : riemannZeta s ≠ 0 := by
    apply riemannZeta_ne_zero_of_one_lt_re
    rw [h_s_re]; norm_num
  have h_cos_ne : Complex.cos ((Real.pi : ℂ) * s / 2) ≠ 0 := by
    rw [hs_def]
    exact cos_pi_mul_twoMinusYI_div_two_ne_zero y
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  · norm_num
  · exact h_2pi_pow
  · exact h_gamma_ne
  · exact h_cos_ne
  · exact h_zeta_ne

/-! ## CS: No zeros of `ζ` in the left half-plane upper half -/

/-- `Complex.cos w ≠ 0` whenever `w.im ≠ 0`.  Zeros of `cos` are real
half-odd-integer multiples of `π`, so any complex `w` with nonzero
imaginary part avoids them. -/
theorem Complex.cos_ne_zero_of_im_ne_zero
    {w : ℂ} (hw : w.im ≠ 0) :
    Complex.cos w ≠ 0 := by
  rw [Complex.cos_ne_zero_iff]
  intro k heq
  have h_im_eq :
      w.im = ((2 * (k : ℂ) + 1) * (Real.pi : ℂ) / 2).im :=
    congrArg Complex.im heq
  have h_rhs_im : ((2 * (k : ℂ) + 1) * (Real.pi : ℂ) / 2).im = 0 := by
    simp [Complex.div_im, Complex.mul_im, Complex.add_im, Complex.intCast_im,
          Complex.ofReal_re, Complex.ofReal_im, Complex.one_im,
          Complex.normSq_apply]
  rw [h_rhs_im] at h_im_eq
  exact hw h_im_eq

/-- **CS — PROVED:** `ζ` has no zeros at points with `Re ≤ 0` and `Im > 0`.
Functional equation: ζ(1-s) = factors · ζ(s), at `s = 1 - z` (so `Re s ≥ 1`,
`Im s = -Im z < 0`).  RHS factors are all nonzero (`Γ(s) ≠ 0` since
`Re s > 0`; `ζ(s) ≠ 0` since `Re s ≥ 1`; `cos(πs/2) ≠ 0` since `Im s ≠ 0`;
`(2π)^(-s) ≠ 0`; `2 ≠ 0`).  Contradicts `ζ z = ζ(1-s) = 0`. -/
theorem zetaNoZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper := by
  intro z hzRe hzIm hzeta
  set s : ℂ := 1 - z with hs_def
  have hs_re : s.re = 1 - z.re := by simp [hs_def]
  have hs_im : s.im = -z.im := by simp [hs_def]
  have hs_re_ge_one : 1 ≤ s.re := by rw [hs_re]; linarith
  have hs_re_pos : 0 < s.re := by linarith
  have hs_im_neg : s.im < 0 := by rw [hs_im]; linarith
  have hs_im_ne : s.im ≠ 0 := ne_of_lt hs_im_neg
  have h_zeta_s_ne : riemannZeta s ≠ 0 :=
    riemannZeta_ne_zero_of_one_le_re hs_re_ge_one
  have hs_ne_neg_n : ∀ n : ℕ, s ≠ -↑n := by
    intro n h
    have h_re : s.re = (-(n : ℂ)).re := congrArg Complex.re h
    rw [hs_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (α := ℝ) n]
  have hs_ne_one : s ≠ 1 := by
    intro h
    have h_im : s.im = (1 : ℂ).im := congrArg Complex.im h
    simp at h_im
    linarith
  have h_1s_z : (1 : ℂ) - s = z := by simp [hs_def]
  have hFE := riemannZeta_one_sub hs_ne_neg_n hs_ne_one
  rw [h_1s_z, hzeta] at hFE
  apply absurd hFE.symm
  have h_2pi_ne_C : ((2 : ℂ) * (Real.pi : ℂ)) ≠ 0 := by
    have hπ : (Real.pi : ℂ) ≠ 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) hπ
  have h_2pi_pow : ((2 * (Real.pi : ℂ)) ^ (-s)) ≠ 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s ≠ 0 :=
    Complex.Gamma_ne_zero_of_re_pos hs_re_pos
  have h_cos_ne : Complex.cos ((Real.pi : ℂ) * s / 2) ≠ 0 := by
    apply Complex.cos_ne_zero_of_im_ne_zero
    have h_arg_im : ((Real.pi : ℂ) * s / 2).im = Real.pi * s.im / 2 := by
      simp [Complex.div_im, Complex.mul_im, Complex.ofReal_re,
            Complex.ofReal_im, Complex.normSq_apply]
    rw [h_arg_im]
    have hpi_pos : 0 < Real.pi := Real.pi_pos
    intro h
    have : Real.pi * s.im = 0 := by linarith
    rcases mul_eq_zero.mp this with h1 | h2
    · exact absurd h1 hpi_pos.ne'
    · exact hs_im_ne h2
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  · norm_num
  · exact h_2pi_pow
  · exact h_gamma_ne
  · exact h_cos_ne
  · exact h_zeta_s_ne

