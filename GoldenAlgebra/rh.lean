      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-- Inhabit `ConcreteSBacklundEstimateFrom140OnGoodHeights` from the
named Backlund counting estimate. -/
noncomputable def BacklundGoodHeightCountingEstimate.toH140
    (B : BacklundGoodHeightCountingEstimate) :
    ConcreteSBacklundEstimateFrom140OnGoodHeights :=
  B.bound

/-! ### CW2: named jump-extension input for `E` -/

/-- Named structure for the zero-count jump / right-limit regularity needed
to extend the good-height Backlund estimate (H140) to all heights `T тЙе 140`.
This is the second classical analytic obligation; placing it in a named
structure provides a fixed anchor for future refinement into right-
continuity + density-of-good-heights lemmas. -/
structure ConcreteSBacklundJumpExtensionInput
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights) : Prop where
  extension : ConcreteSBacklundEstimateExtensionFrom140 H140

/-- Inhabit `ConcreteSBacklundEstimateExtensionFrom140 H140` from the
named jump-extension package. -/
noncomputable def ConcreteSBacklundJumpExtensionInput.toExtension
    {H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights}
    (J : ConcreteSBacklundJumpExtensionInput H140) :
    ConcreteSBacklundEstimateExtensionFrom140 H140 :=
  J.extension

/-! ### CW3: final theorem using H140 + jump-extension inputs -/

/-- **CW3 тАФ FINAL THEOREM via Backlund + jump-extension inputs:** takes the
Backlund good-height counting estimate (anchored by CW1) and the zero-count
jump-extension input (anchored by CW2), producing the headline bound. -/
theorem concreteS_halfLogPlusHalf_of_backlundAndJumpInputs
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (J : ConcreteSBacklundJumpExtensionInput H140)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundInputs H140 J.toExtension hT

/-! ### CW4: split `J` into a real-analysis bridge and a right-continuity input -/

/-- Right-continuity input for `concreteS` at heights `T тЙе 140`.  This is
the genuine zero-count regularity content behind extending the Backlund
bound from good heights to all heights. -/
structure ConcreteSRightContinuityInput : Prop where
  right_continuous_at :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      Filter.Tendsto concreteS (nhdsWithin T (Set.Ioi T)) (nhds (concreteS T))

/-- Density/right-continuity bridge: if the good-height Backlund estimate
holds and `concreteS` is right-continuous on `[140, тИЮ)`, then the estimate
extends to all `T тЙе 140`.  This packages the bridge so that future code
can specialize either the analytic content (`RC`) or the discharging
proof. -/
structure ConcreteSBacklundRightContinuityBridge
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (_RC : ConcreteSRightContinuityInput) : Prop where
  extension : ConcreteSBacklundEstimateExtensionFrom140 H140

/-- Inhabit the jump-extension input from the right-continuity bridge. -/
noncomputable def ConcreteSBacklundRightContinuityBridge.toJumpExtension
    {H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights}
    {RC : ConcreteSRightContinuityInput}
    (B : ConcreteSBacklundRightContinuityBridge H140 RC) :
    ConcreteSBacklundJumpExtensionInput H140 where
  extension := B.extension

/-- **CW4 тАФ FINAL THEOREM via Backlund + right-continuity inputs:** uses the
right-continuity-based bridge. -/
theorem concreteS_halfLogPlusHalf_of_backlundAndRightContinuity
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (RC : ConcreteSRightContinuityInput)
    (B : ConcreteSBacklundRightContinuityBridge H140 RC)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundAndJumpInputs
    H140 B.toJumpExtension hT

/-- **CW4 тАФ proof of the bridge from right-continuity alone.**  Given
`RC` (right-continuity of `concreteS` at every `T тЙе 140`) and the
good-height Backlund estimate `H140`, the estimate extends to all
`T тЙе 140`.  Proof: at every `T тЙе 140`, the existing good-height density
lemma `exists_goodHeight_between_self_add` builds a sequence
`u_n тИИ (T, T + 1/(n+1))` of good heights `тЙе 140`; `H140` bounds the
inequality at each `u_n`; right-continuity of `concreteS` plus continuity
of `(1/2)┬╖log u + 1/2` lets us pass to the limit as `u_n тЖТ TтБ║`. -/
noncomputable def ConcreteSRightContinuityInput.toBacklundExtension
    (RC : ConcreteSRightContinuityInput)
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights) :
    ConcreteSBacklundEstimateExtensionFrom140 H140 where
  extension := by
    intro T hT
    have h140_pos : (0 : тДЭ) < 140 := by norm_num
    have hT_pos : (0 : тДЭ) < T := lt_of_lt_of_le h140_pos hT
    -- Sequence of good heights u_n тИИ (T, T + 1/(n+1)), with u_n тЙе 140.
    have hseq : тИА n : тДХ, тИГ U : тДЭ,
        RvMGoodHeight U тИз (140 : тДЭ) тЙд U тИз T < U тИз
          U < T + 1 / ((n : тДЭ) + 1) := by
      intro n
      have h╬╡ : (0 : тДЭ) < 1 / ((n : тДЭ) + 1) := by positivity
      obtain тЯиU, hTU, hUeps, hUgoodтЯй :=
        exists_goodHeight_between_self_add hT_pos h╬╡
      have hUpos : (0 : тДЭ) < U := lt_trans hT_pos hTU
      have hUlower : (140 : тДЭ) тЙд U := le_trans hT (le_of_lt hTU)
      exact тЯиU, тЯиhUpos, hUgoodтЯй, hUlower, hTU, hUepsтЯй
    choose u hugood hulower hu_strict hu_lt using hseq
    -- u_n тЖТ T from above.
    have h_one_div :
        Filter.Tendsto (fun n : тДХ => (1 : тДЭ) / ((n : тДЭ) + 1))
          Filter.atTop (nhds 0) :=
      tendsto_one_div_add_atTop_nhds_zero_nat
    have h_upper :
        Filter.Tendsto (fun n : тДХ => T + 1 / ((n : тДЭ) + 1))
          Filter.atTop (nhds T) := by
      have := h_one_div.const_add T
      simpa using this
    have hu_to_T :
        Filter.Tendsto u Filter.atTop (nhds T) := by
      refine tendsto_of_tendsto_of_tendsto_of_le_of_le
        (tendsto_const_nhds (x := T)) h_upper ?_ ?_
      ┬╖ exact fun n => le_of_lt (hu_strict n)
      ┬╖ exact fun n => le_of_lt (hu_lt n)
    have hu_in_Ioi :
        тИАс╢а n in Filter.atTop, u n тИИ Set.Ioi T :=
      Filter.Eventually.of_forall (fun n => hu_strict n)
    have hu_nhdsRight :
        Filter.Tendsto u Filter.atTop (nhdsWithin T (Set.Ioi T)) :=
      tendsto_nhdsWithin_iff.mpr тЯиhu_to_T, hu_in_IoiтЯй
    -- |concreteS u_n| тЖТ |concreteS T|.
    have hAbsLim :
        Filter.Tendsto (fun n => |concreteS (u n)|)
          Filter.atTop (nhds |concreteS T|) :=
      ((RC.right_continuous_at T hT).comp hu_nhdsRight).abs
    -- (1/2) log u_n + 1/2 тЖТ (1/2) log T + 1/2.
    have hLogContAt :
        Filter.Tendsto Real.log (nhds T) (nhds (Real.log T)) :=
      (Real.continuousAt_log hT_pos.ne').tendsto
    have hLogAtTop :
        Filter.Tendsto (fun n => Real.log (u n))
          Filter.atTop (nhds (Real.log T)) :=
      hLogContAt.comp hu_to_T
    have hLogLim :
        Filter.Tendsto (fun n => (1 / 2 : тДЭ) * Real.log (u n) + 1 / 2)
          Filter.atTop (nhds ((1 / 2 : тДЭ) * Real.log T + 1 / 2)) :=
      (hLogAtTop.const_mul ((1 : тДЭ) / 2)).add_const ((1 : тДЭ) / 2)
    -- H140 applies at each good u_n (which is тЙе 140).
    have hPerTerm :
        тИА n, |concreteS (u n)| тЙд (1 / 2 : тДЭ) * Real.log (u n) + 1 / 2 :=
      fun n => H140 (u n) (hugood n) (hulower n)
    exact le_of_tendsto_of_tendsto' hAbsLim hLogLim hPerTerm

/-! ### CW5: split `RC` into smooth-term continuity + count right-continuity -/

/-- Real-valued lift of the natural-number weighted zero count
`zetaWeightedZeroCountUpToHeight`.  Coerces to `0` on negative heights to
yield a total function `тДЭ тЖТ тДЭ`. -/
noncomputable def zetaWeightedZeroCountUpToHeightReal (T : тДЭ) : тДЭ :=
  if hT : 0 тЙд T then (zetaWeightedZeroCountUpToHeight T hT : тДЭ) else 0

/-- Pointwise on all of `тДЭ`: `concreteS = count_тДЭ тИТ smoothMainTerm`. -/
theorem concreteS_eq_real_count_sub_smoothMainTerm (T : тДЭ) :
    concreteS T =
      zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T := by
  unfold concreteS zetaWeightedZeroCountUpToHeightReal
  split_ifs with h
  ┬╖ rfl
  ┬╖ simp

/-- Continuity input for the smooth RiemannтАУvon Mangoldt main term at
right-neighborhoods of heights `T тЙе 140`.  Real-analysis only тАФ no
zero-counting content. -/
structure SmoothMainTermContinuityInput : Prop where
  continuous_at :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      Filter.Tendsto smoothMainTerm
        (nhdsWithin T (Set.Ioi T)) (nhds (smoothMainTerm T))

/-- Right-continuity input for the weighted zero count.  Because the count
uses `Im(s) тЙд T`, zeros exactly at `T` are already included, so the right
limit equals the value at `T`. -/
structure ZetaWeightedZeroCountRightContinuityInput : Prop where
  right_continuous_at :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      Filter.Tendsto zetaWeightedZeroCountUpToHeightReal
        (nhdsWithin T (Set.Ioi T))
        (nhds (zetaWeightedZeroCountUpToHeightReal T))

/-- Right-continuity of `concreteS` is the difference of count right-
continuity and smooth-main continuity. -/
noncomputable def ConcreteSRightContinuityInput.of_count_and_smooth
    (ZC : ZetaWeightedZeroCountRightContinuityInput)
    (SM : SmoothMainTermContinuityInput) :
    ConcreteSRightContinuityInput where
  right_continuous_at := by
    intro T hT
    have hZ := ZC.right_continuous_at T hT
    have hM := SM.continuous_at T hT
    have hSub :
        Filter.Tendsto
          (fun u => zetaWeightedZeroCountUpToHeightReal u - smoothMainTerm u)
          (nhdsWithin T (Set.Ioi T))
          (nhds (zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T)) :=
      hZ.sub hM
    have h_fn : тИА u,
        zetaWeightedZeroCountUpToHeightReal u - smoothMainTerm u = concreteS u :=
      fun u => (concreteS_eq_real_count_sub_smoothMainTerm u).symm
    have h_pt :
        zetaWeightedZeroCountUpToHeightReal T - smoothMainTerm T = concreteS T :=
      h_fn T
    rw [h_pt] at hSub
    exact hSub.congr h_fn

/-! ### CW6: discharge `SmoothMainTermContinuityInput` outright -/

/-- `smoothZeroCountingN0` is continuous at every positive `u`.  The
function is `(u/2╧А)┬╖log(u/2╧А) тИТ u/2╧А + 7/8`. -/
theorem continuousAt_smoothZeroCountingN0 {T : тДЭ} (hT_pos : 0 < T) :
    ContinuousAt smoothZeroCountingN0 T := by
  unfold smoothZeroCountingN0
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h_arg_pos : (0 : тДЭ) < T / (2 * Real.pi) :=
    div_pos hT_pos h2pi_pos
  have h_arg_ne : T / (2 * Real.pi) тЙа 0 := h_arg_pos.ne'
  have h_div_id : ContinuousAt (fun u : тДЭ => u / (2 * Real.pi)) T :=
    continuousAt_id.div_const (2 * Real.pi)
  have h_log_inner :
      ContinuousAt (fun u : тДЭ => Real.log (u / (2 * Real.pi))) T :=
    h_div_id.log h_arg_ne
  have h_mul :
      ContinuousAt (fun u : тДЭ =>
          (u / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))) T :=
    h_div_id.mul h_log_inner
  exact (h_mul.sub h_div_id).add continuousAt_const

/-- `smoothMainTerm` is continuous at every positive `T`. -/
theorem continuousAt_smoothMainTerm {T : тДЭ} (hT_pos : 0 < T) :
    ContinuousAt smoothMainTerm T := by
  unfold smoothMainTerm
  exact continuousAt_smoothZeroCountingN0 hT_pos

/-- **CW6 тАФ `SmoothMainTermContinuityInput` is unconditionally provable.**
The main term is built from `Real.log` and arithmetic; continuity at
every `T тЙе 140` follows from continuity of `Real.log` at positive
arguments. -/
noncomputable def smoothMainTermContinuityInput :
    SmoothMainTermContinuityInput where
  continuous_at := by
    intro T hT
    have hT_pos : (0 : тДЭ) < T :=
      lt_of_lt_of_le (by norm_num : (0 : тДЭ) < 140) hT
    exact (continuousAt_smoothMainTerm hT_pos).mono_left nhdsWithin_le_nhds

/-! ### CW7: split `ZC` into a zero-gap input and a local-constancy input -/

/-- No nontrivial zeta zero has imaginary part in `(T, T + ╬╡]` for some
`╬╡ > 0`, at every height `T тЙе 140`.  This is the discreteness /
no-accumulation content of zeta zeros, packaged as a named input.

Because the zero count uses `Im(s) тЙд T`, a strict right gap of any size
suffices to make the count locally constant immediately to the right of
`T`. -/
structure ZetaNoZerosImmediatelyRightInput : Prop where
  exists_gap_right :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      тИГ ╬╡ : тДЭ, 0 < ╬╡ тИз
        тИА ╧Б : тДВ,
          IsNontrivialZetaZero ╧Б тЖТ
          T < ╧Б.im тЖТ
          ╧Б.im тЙд T + ╬╡ тЖТ
          False

/-- Local constancy of the (real-lifted) weighted zero count immediately
to the right of every `T тЙе 140`.  Follows from any nonempty right gap on
nontrivial-zero heights. -/
structure ZetaWeightedZeroCountRightLocalConstancyInput : Prop where
  eventually_eq_right :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      тИАс╢а u in nhdsWithin T (Set.Ioi T),
        zetaWeightedZeroCountUpToHeightReal u =
          zetaWeightedZeroCountUpToHeightReal T

/-- **CW7 тАФ local constancy тЗТ right-continuity of the weighted count.**
Eventually-constant functions trivially tend to the constant value. -/
noncomputable def
    ZetaWeightedZeroCountRightLocalConstancyInput.toZC
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput) :
    ZetaWeightedZeroCountRightContinuityInput where
  right_continuous_at := by
    intro T hT
    have hLC := LC.eventually_eq_right T hT
    have hLC_sym :
        тИАс╢а u in nhdsWithin T (Set.Ioi T),
          zetaWeightedZeroCountUpToHeightReal T =
            zetaWeightedZeroCountUpToHeightReal u :=
      hLC.mono (fun _ h => h.symm)
    have hconst :
        Filter.Tendsto
          (fun _ : тДЭ => zetaWeightedZeroCountUpToHeightReal T)
          (nhdsWithin T (Set.Ioi T))
          (nhds (zetaWeightedZeroCountUpToHeightReal T)) :=
      tendsto_const_nhds
    exact hconst.congr' hLC_sym

/-! ### CW8: public Backlund argument bound + final 2-input theorem -/

/-- Classical Backlund/Jensen good-height argument bound for `concreteS`.
This is the public-facing name for the genuine analytic obligation: at
every good height `T тЙе 140`, the argument-variation term satisfies
`|concreteS T| тЙд (1/2)┬╖log T + 1/2`.

Structurally identical to `BacklundGoodHeightCountingEstimate` (CW1) but
named to align with the classical Backlund/Jensen terminology. -/
structure BacklundGoodHeightArgumentBound : Prop where
  bound :
    тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-- Inhabit `ConcreteSBacklundEstimateFrom140OnGoodHeights` from the
Backlund argument bound. -/
noncomputable def BacklundGoodHeightArgumentBound.toH140
    (B : BacklundGoodHeightArgumentBound) :
    ConcreteSBacklundEstimateFrom140OnGoodHeights :=
  B.bound

/-- Convert between the internal counting-estimate name (CW1) and the
public Backlund-argument name. -/
noncomputable def BacklundGoodHeightCountingEstimate.toArgumentBound
    (B : BacklundGoodHeightCountingEstimate) :
    BacklundGoodHeightArgumentBound :=
  тЯиB.boundтЯй

/-- **CW8 тАФ FINAL THEOREM from the cleanest 2-input frontier.**

Given the Backlund/Jensen good-height argument bound `B` and the
right-local-constancy fact for the weighted zero count `LC`, the
headline bound `|concreteS T| тЙд (1/2)┬╖log T + 1/2` holds for every
`T тЙе 140`.

Pipeline:
- `LC тЖТ ZC` via `ZetaWeightedZeroCountRightLocalConstancyInput.toZC`.
- `ZC + SM тЖТ RC` via `ConcreteSRightContinuityInput.of_count_and_smooth`,
  using the unconditionally-proved `smoothMainTermContinuityInput` for `SM`.
- `RC + H140 тЖТ ExtensionFrom140` via
  `ConcreteSRightContinuityInput.toBacklundExtension`.
- Final bound via `concreteS_halfLogPlusHalf_of_backlundInputs`. -/
theorem concreteS_halfLogPlusHalf_of_backlundArgument_and_countLC
    (B : BacklundGoodHeightArgumentBound)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 := by
  set H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights := B.toH140
  set RC : ConcreteSRightContinuityInput :=
    ConcreteSRightContinuityInput.of_count_and_smooth
      LC.toZC smoothMainTermContinuityInput
  exact concreteS_halfLogPlusHalf_of_backlundInputs
    H140 (RC.toBacklundExtension H140) hT

/-! ### CW9: classical Backlund decomposition of `B` -/

/-- Jensen/rectangle zero-counting estimate used in Backlund's argument:
the weighted number of nontrivial ╬╢-zeros in the short height window
`(T, T + 1]` is `O(log(T + 2))`.  This is the heavy Jensen-theoretic
input in Backlund's good-height proof. -/
def BacklundJensenRectangleEstimate (T : тДЭ) : Prop :=
  тИГ C : тДЭ, 0 тЙд C тИз
    zetaWeightedZeroCountUpToHeightReal (T + 1)
        - zetaWeightedZeroCountUpToHeightReal T
      тЙд C * Real.log (T + 2)

/-- Constructor: assemble `BacklundJensenRectangleEstimate T` from a
window-bound on the weighted count. -/
theorem BacklundJensenRectangleEstimate.of_window_bound
    {T C : тДЭ}
    (hC : 0 тЙд C)
    (hbound :
      zetaWeightedZeroCountUpToHeightReal (T + 1)
          - zetaWeightedZeroCountUpToHeightReal T
        тЙд C * Real.log (T + 2)) :
    BacklundJensenRectangleEstimate T :=
  тЯиC, hC, hboundтЯй

/-- Analytic input supplying Jensen/rectangle zero-counting control for
Backlund, across every good height `T тЙе 140`. -/
structure BacklundJensenRectangleInput : Prop where
  bound :
    тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
      BacklundJensenRectangleEstimate T

/-- Bridge: the Jensen window input supplies the corresponding field of
`BacklundGoodHeightClassicalInputs`. -/
noncomputable def BacklundJensenRectangleInput.toJensenField
    (J : BacklundJensenRectangleInput) :
    тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
      BacklundJensenRectangleEstimate T :=
  J.bound

/-- Argument-variation estimate on the right vertical side of Backlund's
rectangle.  Records the classical control on the change of argument of
`╬╢(s)` along `Re s = 2` between heights `T` and `T + 1`: nonvanishing on
that segment plus a `log`-scale bound on the logarithmic derivative. -/
def BacklundRightSideArgumentVariationEstimate (T : тДЭ) : Prop :=
  (тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
      riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 0)
  тИз
  тИГ C : тДЭ, 0 тЙд C тИз
    тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
      тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
          riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд
        C * Real.log (T + 2)

/-- Constructor: assemble `BacklundRightSideArgumentVariationEstimate T`
from a nonvanishing fact on the right segment plus a uniform
`log(T + 2)`-scale bound on the logarithmic derivative. -/
theorem BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound
    {T C : тДЭ}
    (hnonzero :
      тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
        riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 0)
    (hC : 0 тЙд C)
    (hbound :
      тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
        тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
            riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд
          C * Real.log (T + 2)) :
    BacklundRightSideArgumentVariationEstimate T :=
  тЯиhnonzero, C, hC, hboundтЯй

/-- Analytic input supplying right-side argument-variation control on
Backlund's rectangle, across every good height `T тЙе 140`. -/
structure BacklundRightSideArgumentVariationInput : Prop where
  bound :
    тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
      BacklundRightSideArgumentVariationEstimate T

/-- Bridge: the right-side argument-variation input supplies the
corresponding field of `BacklundGoodHeightClassicalInputs`. -/
noncomputable def BacklundRightSideArgumentVariationInput.toRightSideField
    (R : BacklundRightSideArgumentVariationInput) :
    тИА T : тДЭ, RvMGoodHeight T тЖТ (140 : тДЭ) тЙд T тЖТ
      BacklundRightSideArgumentVariationEstimate T :=
  R.bound

/-- Horizontal/trivial boundary estimate used in Backlund's rectangle
argument.  Records the elementary uniform bound on `riemannZeta` along
the horizontal segment `{╧Г + iT : -1 тЙд ╧Г тЙд 2}` needed to control the
top/bottom edges of Backlund's contour.  The bound is allowed to grow
at most linearly in `T`. -/
def BacklundHorizontalBoundaryEstimate (T : тДЭ) : Prop :=
  тИГ C : тДЭ, 0 тЙд C тИз
    тИА ╧Г : тДЭ,
      (-1 : тДЭ) тЙд ╧Г тЖТ
      ╧Г тЙд 2 тЖТ
        тАЦriemannZeta ((╧Г : тДВ) + (T : тДВ) * Complex.I)тАЦ тЙд C * (T + 1)

/-- Constructor: inhabit `BacklundHorizontalBoundaryEstimate T` from a
uniform bound `тАЦ╬╢(╧Г + iT)тАЦ тЙд C┬╖(T + 1)` on the horizontal strip
`╧Г тИИ [-1, 2]`. -/
theorem BacklundHorizontalBoundaryEstimate.of_uniform_bound
    {T C : тДЭ}
    (hC : 0 тЙд C)
    (hbound :
      тИА ╧Г : тДЭ,
        (-1 : тДЭ) тЙд ╧Г тЖТ
        ╧Г тЙд 2 тЖТ
          тАЦriemannZeta ((╧Г : тДВ) + (T : тДВ) * Complex.I)тАЦ тЙд C * (T + 1)) :
    BacklundHorizontalBoundaryEstimate T :=
  тЯиC, hC, hboundтЯй

/-- Uniform zeta bound on Backlund horizontal segments, packaged for
every good height `T тЙе 140`.  This is the analytic input that supplies
