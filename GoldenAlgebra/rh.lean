    refine вЯ®L, hL, ?_вЯ©
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]
  ¬Ј intro z T hT hy hr
    obtain вЯ®L, hL, hZвЯ© := Htail.high_tail hT hy hr
    refine вЯ®L, hL, ?_вЯ©
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]

/-- рЯУ¶ **`StieltjesMidHighTailEquality`** вАФ Stieltjes equality only,
