theorem hclosed_on_10_140_of_polyineqs
    (M : CloudDensityTailModelDecomposition)
    (poly_10_12 : SlabPolyIneq M.zeros 10 12 0 (21/100))
    (poly_12_13 : SlabPolyIneq M.zeros 12 13 0 (31/100))
