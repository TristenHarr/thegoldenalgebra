/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ
**PROVED ÔÇö final Hadamard assembly.**

```
HadamardZeroInvSqSummability (╬ú 1/ÔÇû¤üÔÇû┬▓ + escape)
+ HadamardProductLUCLogDerivData (LUC log-deriv interchange)
+ ╬¥ Hadamard factorization (prefactor ┬À ÔêÅ EÔéü)
+ prefactor AFZ (differentiable + non-vanishing)
Ôƒ╣ CompletedXiHadamardProductWithZeros ╬╣
``` -/
noncomputable def CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    {╬╣ : Type} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    {prefactor : Ôäé ÔåÆ Ôäé}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : ÔêÇ s : Ôäé, completedXiFunction s Ôëá 0 ÔåÆ s Ôêê Hluc.region)
    (HnonzeroRegion : ÔêÇ s Ôêê Hluc.region, ÔêÇ i, s Ôëá zeroLoc i)
    (Hfact :
      ÔêÇ s : Ôäé,
        completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s)
    (Hpref_diff :
      ÔêÇ s : Ôäé,
        completedXiFunction s Ôëá 0 ÔåÆ DifferentiableAt Ôäé prefactor s)
    (Hpref_ne :
      ÔêÇ s : Ôäé,
        completedXiFunction s Ôëá 0 ÔåÆ prefactor s Ôëá 0) :
    CompletedXiHadamardProductWithZeros ╬╣ := by
  refine
    { zeroLoc := zeroLoc
      prefactor := prefactor
      prefactor_differentiable_at := Hpref_diff
      prefactor_ne_zero := Hpref_ne
      xi_eq_product := Hfact
      product_data := ?_ }
  exact
    HadamardLocallyUniformProductData.of_logDerivLimitData
      Hinv.product_multipliable
      (HadamardLogDerivLimitData.of_productLUC_and_invSq
        Hluc Hinv HnonzeroRegion)
      Hregion

