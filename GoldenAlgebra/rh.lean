-- CLX-helpers: denominator positivity + evenness in x
-- ---------------------------------------------------------------------
-- Boilerplate used by the SDP-to-Lean certificate compiler to clear
-- denominators safely and reduce each slab cert to its `x ÔëÑ 0` form.

/-- Ô¡É **PROVED ÔÇö `(x ÔêÆ g)┬▓ + y┬▓ > 0` for `y > 0`.** -/
theorem denom_cloud_pos (x y g : ÔäØ) (hy : 0 < y) :
    0 < (x - g)^2 + y^2 := by positivity

/-- Ô¡É **PROVED ÔÇö `(x + g)┬▓ + y┬▓ > 0` for `y > 0`.** -/
theorem denom_cloud_plus_pos (x y g : ÔäØ) (hy : 0 < y) :
    0 < (x + g)^2 + y^2 := by positivity

/-- Ô¡É **PROVED ÔÇö `(T ÔêÆ |x|)┬▓ + y┬▓ > 0` for `y > 0`.** -/
theorem smooth_tail_denom_minus_pos (x y T : ÔäØ) (hy : 0 < y) :
    0 < (T - |x|)^2 + y^2 := by positivity

/-- Ô¡É **PROVED ÔÇö `(T + |x|)┬▓ + y┬▓ > 0` for `y > 0`.** -/
theorem smooth_tail_denom_plus_pos (x y T : ÔäØ) (hy : 0 < y) :
    0 < (T + |x|)^2 + y^2 := by positivity

/-- Ô¡É **PROVED ÔÇö `cloudImNegSum` is even in `x`.**
Per-term `((-x) ÔêÆ g)┬▓ = (x + g)┬▓` and `((-x) + g)┬▓ = (x ÔêÆ g)┬▓`, then
swap by commutativity of `+`. -/
theorem cloudImNegSum_neg_x (zeros : List ÔäØ) (x y : ÔäØ) :
    cloudImNegSum zeros (-x) y = cloudImNegSum zeros x y := by
  unfold cloudImNegSum
  congr 1
  apply List.map_congr_left
  intro g _
  have h1 : ((-x) - g)^2 = (x + g)^2 := by ring
  have h2 : ((-x) + g)^2 = (x - g)^2 := by ring
  rw [h1, h2]; ring

/-- Ô¡É **PROVED ÔÇö `smoothTailRationalLowerBoundAbs` is even in `x`** (via `|ÔêÆx| = |x|`). -/
theorem smoothTailRationalLowerBoundAbs_neg_x (x y T : ÔäØ) :
    smoothTailRationalLowerBoundAbs (-x) y T
      = smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  rw [abs_neg]

/-- Ô¡É **PROVED ÔÇö slab cert reduction to `x ÔëÑ 0`.** Halves SDP certificate
complexity: it suffices to discharge the polynomial inequality for
nonneg `x`, since both `cloudImNegSum` and
`smoothTailRationalLowerBoundAbs` are even in `x`. -/
theorem slabPolyIneq_of_nonneg_x
    {zeros : List ÔäØ} {Tmin Tmax C D : ÔäØ}
    (H : ÔêÇ x y T : ÔäØ,
        0 Ôëñ x ÔåÆ
        Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ 0 < y ÔåÆ
        2 * (1 + x + y) Ôëñ T ÔåÆ
          closedFormSErrorBoundCD C D y T
            Ôëñ cloudImNegSum zeros x y
              + smoothTailRationalLowerBoundAbs x y T) :
    SlabPolyIneq zeros Tmin Tmax C D := by
  intro x y T hTmin hTmax hy hreg
  by_cases hx : 0 Ôëñ x
  ┬À have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at hreg
    exact H x y T hx hTmin hTmax hy hreg
  ┬À push_neg at hx
    have hxneg : 0 Ôëñ -x := by linarith
    have habs : |x| = -x := abs_of_neg hx
    rw [habs] at hreg
    have Hneg := H (-x) y T hxneg hTmin hTmax hy hreg
    -- Hneg : closedFormSErrorBoundCD Ôëñ cloudImNegSum zeros (-x) y + smoothTail (-x) y T
    rw [ÔåÉ cloudImNegSum_neg_x zeros x y,
        ÔåÉ smoothTailRationalLowerBoundAbs_neg_x x y T]
    exact Hneg

