    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ : тДЭ}
    (Hstarts : DzeroStartsAfter Dzero ╬│)
    (hT0_pos : 0 < T0)
    (hT0_le_2pi : T0 тЙд 2 * Real.pi) :
    FirstZeroGapForDzeroAdjusted Dzero T0 ╬│ := by
  refine тЯи?_тЯй
  intro u hu_2pi hu_╬│
