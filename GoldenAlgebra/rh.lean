    I.toBacklundArgumentBound

/-! ### AW5: concrete-`S` half-log-plus-half bound -/

/-- From the analytic input package, `concreteS` satisfies the
half-log-plus-half bound for all heights past the Backlund threshold. -/
theorem BacklundTuringAnalyticInputs.concreteS_halfLogPlusHalf
    (I : BacklundTuringAnalyticInputs)
    {T : ℝ}
    (hT : I.backlundGood.lower ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  I.toProvenBacklundTuringBound.halfLogPlusHalf T hT

/-! ### AW6: final theorem target.

Once an inhabitant of `BacklundTuringAnalyticInputs` is constructed by
discharging the remaining analytic obligations:

```
noncomputable def provenBacklundTuringInputs :
    BacklundTuringAnalyticInputs := ...
```

the headline theorem becomes a one-liner:

```
theorem concreteS_halfLogPlusHalf_bound_from_140 :
    ∀ T : ℝ, 140 ≤ T →
      |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  fun T hT =>
    provenBacklundTuringInputs.concreteS_halfLogPlusHalf
      (by linarith [provenBacklundTuringInputs.backlundGood.lower_ge_two_pi,
                    Real.pi_pos] : provenBacklundTuringInputs.backlundGood.lower ≤ T)
```

Remaining analytic obligations to inhabit `BacklundTuringAnalyticInputs`:

1. `PuncturedRectangleCauchyGoursat` (per zeta singularity inside rectangle)
2. `RectanglePrincipalPartContourDecomposition` (per rectangle)
3. `RvMRectangleMainTermEvaluation` / per-T main-term identity
4. `RvMGoodHeightExtension` (extend from good heights to all heights)
5. `BacklundArgumentBoundOnGoodHeights`
6. `BacklundGoodHeightBoundExtension`

Items 1+2 together inhabit `CanonicalResidueFreeArgumentPrincipleData` for
each good height, which is the per-rectangle Lean-level analytic input. -/

/-! ## CE: Final RvM analytic-input package + Backlund-Turing wrapper -/

/-! ### CE1: master RvM analytic-input package -/

/-- The remaining analytic inputs to drive the Riemann–von Mangoldt formula
on good heights via safe rectangles.  Concretely: a correction function
`Sarg`, the per-height safe-rectangle data (CD2/CD5), and the actual
main-term identity per good height. -/
structure RvMGoodHeightAnalyticInputs where
  Sarg : ℝ → ℝ
  safeData :
    ∀ T : ℝ, RvMGoodHeight T → ZetaRectangle.RvMSafeHeightData T
  mainEval :
    ∀ T : ℝ, (hT : RvMGoodHeight T) →
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : ℝ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Bridge into the existing `RvMGoodHeightSafeRectangleFamily`. -/
noncomputable def RvMGoodHeightAnalyticInputs.toSafeRectangleFamily
    (I : RvMGoodHeightAnalyticInputs) :
    ZetaRectangle.RvMGoodHeightSafeRectangleFamily where
  Sarg := I.Sarg
  safeData := I.safeData
  mainEval := I.mainEval

/-- The all-good-height RvM formula package directly from the analytic
input package — composes CE1, CD6, CA5, AV7. -/
noncomputable def
    RvMGoodHeightAnalyticInputs.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (I : RvMGoodHeightAnalyticInputs) :
