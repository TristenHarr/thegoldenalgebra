theorem XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        140 Ôëñ T ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (1 / 2 : ÔäØ) * Real.log u + (49 / 20 : ÔäØ))
    (us : List ÔäØ)
    (Tsmooth : ÔäØ) (hTsmooth_ge : 2 * Real.pi Ôëñ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
