    {s : Ôäé} (hs : IsNontrivialZetaZero s) :
    AnalyticAt Ôäé riemannZeta s :=
  riemannZeta_analyticAt_of_ne_one (isNontrivialZetaZero_ne_one hs)

/-- **Step 2 (generalized).** The Riemann zeta function is not locally
identically zero at any point off its pole.  Proof: if it were
eventually zero near `p`, then by the analytic identity theorem on the
preconnected open set `Ôäé \ {1}` (╬Â is analytic there, Ôäé \ {pt} has
real-rank > 1 hence preconnected), ╬Â would vanish on all of `Ôäé \ {1}` ÔÇö
contradicting `riemannZeta 2 Ôëá 0`. -/
theorem riemannZeta_not_eventuallyEq_zero_of_ne_one
    {p : Ôäé} (hp : p Ôëá 1) :
    ┬¼ riemannZeta =ßÂá[­ØôØ p] 0 := by
  intro hlocal
  have hp_mem : p Ôêê ({1}ßÂ£ : Set Ôäé) := hp
  have hOpen : IsOpen ({1}ßÂ£ : Set Ôäé) := isClosed_singleton.isOpen_compl
  have hPre : IsPreconnected ({(1 : Ôäé)}ßÂ£ : Set Ôäé) :=
    (isConnected_compl_singleton_of_one_lt_rank (by simp) (1 : Ôäé)).isPreconnected
  have hAnalytic : AnalyticOnNhd Ôäé riemannZeta ({1}ßÂ£ : Set Ôäé) := by
    intro z hz
    have hDiff : DifferentiableOn Ôäé riemannZeta ({1}ßÂ£ : Set Ôäé) :=
      fun w hw => (differentiableAt_riemannZeta hw).differentiableWithinAt
    exact hDiff.analyticAt (hOpen.mem_nhds hz)
  have hZero_on : Set.EqOn riemannZeta 0 ({1}ßÂ£ : Set Ôäé) :=
    hAnalytic.eqOn_zero_of_preconnected_of_eventuallyEq_zero hPre hp_mem hlocal
  have htwo_ne_one : (2 : Ôäé) Ôëá 1 := by
    intro h
    have hre : (2 : Ôäé).re = (1 : Ôäé).re := congrArg Complex.re h
    simp at hre
  have htwo_mem : (2 : Ôäé) Ôêê ({1}ßÂ£ : Set Ôäé) := htwo_ne_one
  have hZeta_two_zero : riemannZeta (2 : Ôäé) = 0 := by
