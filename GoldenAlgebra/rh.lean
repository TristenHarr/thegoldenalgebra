-- Mellin transform of a real-valued function. The keystone is:
--
--   `mellin_star_ofReal : тИА (f : тДЭ тЖТ тДЭ) (s : тДВ),
--      mellin (fun t => (f t : тДВ)) (star s)
--        = star (mellin (fun t => (f t : тДВ)) s)`.
--
-- Once this lemma lands, it propagates up the FE-pair definition chain
-- (`completedHurwitzZetaEvenтВА 0 = (hurwitzEvenFEPair 0).╬ЫтВА (s/2) / 2`,
--  whose underlying kernel `evenKernel` is `тДЭ тЖТ тДЭ`) to a Schwarz
-- symmetry on `completedRiemannZetaтВА`, then on `entireRiemannXi`.
--
-- This section proves the keystone. The FE-pair lift and final
-- discharge of `entireRiemannXi_schwarz_target` are deferred to ┬з17.C
-- (mechanical algebraic chain).

/-- тнР **PROVED тАФ Mellin transform of an `тДЭ тЖТ тДВ`-lifted real function
commutes with conjugation.** For any real-valued `f : тДЭ тЖТ тДЭ`,
`mellin (ofReal тИШ f) (star s) = star (mellin (ofReal тИШ f) s)`.

Proof: pull `star` (= complex conjugation) outside the integral via
`MeasureTheory.integral_conj`, then verify the per-point identity
`(t : тДВ) ^ (star s тИТ 1) тАв (f t : тДВ) = conj((t : тДВ) ^ (s тИТ 1) тАв (f t : тДВ))`
on `t тИИ Ioi 0` using:
* `Complex.cpow_conj` (with `(t : тДВ).arg = 0 тЙа ╧А` for `t > 0`),
* `Complex.conj_ofReal` (for the real `f t`),
* `Complex.star_def` (`star = conj` on `тДВ`).

This is the *single* analytic content the ┬з17.C `entireRiemannXi`
Schwarz proof needs тАФ everything else is algebraic chain through the
`hurwitzEvenFEPair` definition. -/
theorem mellin_star_ofReal (f : тДЭ тЖТ тДЭ) (s : тДВ) :
    mellin (fun t : тДЭ => ((f t : тДЭ) : тДВ)) (star s)
      = star (mellin (fun t : тДЭ => ((f t : тДЭ) : тДВ)) s) := by
  unfold mellin
  -- Move star inside the RHS integral via integral_conj.
  rw [show star (тИл t in Set.Ioi (0 : тДЭ),
        ((t : тДВ) ^ (s - 1) тАв ((f t : тДЭ) : тДВ)))
      = тИл t in Set.Ioi (0 : тДЭ),
        star ((t : тДВ) ^ (s - 1) тАв ((f t : тДЭ) : тДВ))
      from (integral_conj
        (f := fun t : тДЭ => (t : тДВ) ^ (s - 1) тАв ((f t : тДЭ) : тДВ))
        (╬╝ := MeasureTheory.volume.restrict (Set.Ioi 0))).symm]
  -- Match integrands pointwise on Ioi 0.
  refine MeasureTheory.setIntegral_congr_fun measurableSet_Ioi ?_
  intro t ht
  -- Beta-reduce the lambda-wrapped goal.
  show (t : тДВ) ^ (star s - 1) тАв ((f t : тДЭ) : тДВ)
        = star ((t : тДВ) ^ (s - 1) тАв ((f t : тДЭ) : тДВ))
  have htpos : 0 < t := ht
  have h_arg : ((t : тДВ)).arg тЙа Real.pi := by
    rw [Complex.arg_ofReal_of_nonneg htpos.le]
    exact (Real.pi_pos.ne').symm
  rw [Complex.star_def, smul_eq_mul, smul_eq_mul, map_mul, Complex.conj_ofReal]
  congr 1
  -- (t : тДВ) ^ (star s - 1) = conj((t : тДВ) ^ (s - 1))
  have h_cpow := Complex.cpow_conj (t : тДВ) (s - 1) h_arg
  rw [Complex.conj_ofReal] at h_cpow
  have h_sub : (starRingEnd тДВ) (s - 1) = (starRingEnd тДВ) s - 1 := by
    rw [map_sub, map_one]
  rw [тЖР h_sub]
  exact h_cpow

