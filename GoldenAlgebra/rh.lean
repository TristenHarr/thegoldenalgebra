  bottom_log_lower :=
    log_ratio_lower_of_ratio_lower
      S.bottom_ratio_pos
      S.bottom_ratio_lower
      S.bottom_log_lower
  top_log_upper := by
    have hbottom_pos : 0 < S.R.bottom :=
