/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `Ôê½_T^X` dominated by `Ôê½_{2¤Ç}^X` for nonneg integrand.**
Via interval additivity `Ôê½_{2¤Ç}^X = Ôê½_{2¤Ç}^T + Ôê½_T^X` plus
nonnegativity of `Ôê½_{2¤Ç}^T ¤ü┬ÀK`. -/
lemma zeroDensity_realIntegral_mono_lower_limit
    {x y T X : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hTX : T Ôëñ X)
    (hy : 0 < y) :
    (Ôê½ u in T..X, zeroDensityRho u * positiveSmoothKernel x y u)
      Ôëñ Ôê½ u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel x y u := by
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have hy_ne : y Ôëá 0 := ne_of_gt hy
  have h_int_left :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) h2pi_pos hT hy_ne
  have h_int_right :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) (lt_of_lt_of_le h2pi_pos hT) hTX hy_ne
  have hadd := intervalIntegral.integral_add_adjacent_intervals
    h_int_left h_int_right
  have h_nn :
      0 Ôëñ Ôê½ u in (2 * Real.pi)..T,
            zeroDensityRho u * positiveSmoothKernel x y u := by
    apply intervalIntegral.integral_nonneg hT
    intro u hu
    exact zeroDensity_mul_positiveSmoothKernel_nonneg hu.1 hy
  linarith

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö KEY CLV BRIDGE.** The constant-density `¤ü(T)`
times the paired arctan-tail integral target is dominated by
`-(zeroDensitySmoothTailModel (2¤Ç) z).im` for any adaptive `(z, T)`.

Composes:
* ┬ºCCLXXII-D's `constDensity_positiveSmoothKernel_tail_tendsto`
  (LHS Tendsto);
* ┬ºCCLXXI's `zeroDensitySmoothTailModel_neg_im_tendsto_real_integral`
  (RHS Tendsto);
* eventual finite-`X` chain: ┬ºCCLXXII-B (`¤ü(T) Ôê½_T^X K Ôëñ Ôê½_T^X ¤ü┬ÀK`)
  followed by ┬ºCCLXXII-F3-3 (`Ôê½_T^X ¤ü┬ÀK Ôëñ Ôê½_{2¤Ç}^X ¤ü┬ÀK`);
* `le_of_tendsto_of_tendsto'` to pass through the limits. -/
theorem constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im
    {z : Ôäé} {T : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hy : 0 < z.im) :
    zeroDensityRho T *
      ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
        + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
      Ôëñ -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  have hy_ne : z.im Ôëá 0 := ne_of_gt hy
  -- LHS Tendsto (┬ºCCLXXII-D)
  have h_lhs := constDensity_positiveSmoothKernel_tail_tendsto z.re T hy
  -- RHS Tendsto, rewritten using `positiveSmoothKernel` (┬ºCCLXXI + integral_congr)
  have h_rhs_raw :=
    zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
      (2 * Real.pi) le_rfl hy
  have h_rhs : Tendsto
      (fun X : ÔäØ =>
        Ôê½ u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel z.re z.im u)
      Filter.atTop
      (­ØôØ (-(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im)) := by
    refine h_rhs_raw.congr' ?_
    refine Filter.Eventually.of_forall (fun X => ?_)
    apply intervalIntegral.integral_congr
    intro u _
    show zeroDensityRho u
            * (z.im * (1 / ((z.re - u) ^ 2 + z.im ^ 2)
                + 1 / ((z.re + u) ^ 2 + z.im ^ 2)))
          = zeroDensityRho u * positiveSmoothKernel z.re z.im u
    unfold positiveSmoothKernel
    ring
  -- Eventually `X ÔëÑ T`: LHS Ôëñ RHS finite
  have h_ev :
      ÔêÇßÂá X : ÔäØ in Filter.atTop,
        zeroDensityRho T *
            (Ôê½ u in T..X, positiveSmoothKernel z.re z.im u)
          Ôëñ Ôê½ u in (2 * Real.pi)..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    have h_kInt :=
      positiveSmoothKernel_intervalIntegrable (x := z.re) (y := z.im) hy_ne T X
    have h_rInt :=
      zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
        (x := z.re) (y := z.im)
        (lt_of_lt_of_le (by positivity : (0 : ÔäØ) < 2 * Real.pi) hT)
        hTX hy_ne
    have h_step1 :
        zeroDensityRho T *
            (Ôê½ u in T..X, positiveSmoothKernel z.re z.im u)
          Ôëñ Ôê½ u in T..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u :=
      zeroDensity_realIntegral_ge_constDensity_finite
        (x := z.re) (y := z.im) hT hTX hy h_kInt h_rInt
    have h_step2 :=
      zeroDensity_realIntegral_mono_lower_limit
        (x := z.re) (y := z.im) hT hTX hy
    linarith
  -- Pass through the limits (eventual form)
  exact le_of_tendsto_of_tendsto_of_frequently h_lhs h_rhs h_ev.frequently

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `HonestSmoothTailRationalLB` at the
canonical basepoint `Tsmooth := 2¤Ç`.** Final composition:
* `smoothTailRationalLowerBoundAbs` unfolds to `¤ü(T) ┬À rational(T)`;
* ┬ºCCLXXII-F2 (`paired_arctan_tail_lower_rational`) replaces
  `rational(T)` by the arctan-sum;
* ┬ºCCLXXII-F3 bridge dominates the arctan-sum by the honest tail. -/
theorem HonestSmoothTailRationalLB_twoPi :
    HonestSmoothTailRationalLB (2 * Real.pi) le_rfl := by
  intro z T hT hy hregime
  -- Geometry: 2(1 + |z.re| + z.im) Ôëñ T Ôƒ╣ |z.re| < T/2 < T, so T - |z.re| > 0.
  have habs_nn : (0 : ÔäØ) Ôëñ |z.re| := abs_nonneg _
  have hminus : 0 < T - |z.re| := by
    have hy_nn : (0 : ÔäØ) Ôëñ z.im := le_of_lt hy
    nlinarith
  have hplus : 0 < T + |z.re| := by
    have h_pi_pos : (0 : ÔäØ) < Real.pi := Real.pi_pos
    have : (0 : ÔäØ) < 2 * Real.pi := by positivity
    linarith
  -- Unfold `smoothTailRationalLowerBoundAbs`
  have h_unfold :
      smoothTailRationalLowerBoundAbs z.re z.im T
        = zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2)) := rfl
  rw [h_unfold]
  -- Apply paired arctan rational bound
  have h_paired := paired_arctan_tail_lower_rational
    (x := z.re) (y := z.im) (T := T) hy hminus hplus
  have h¤ü_nn : 0 Ôëñ zeroDensityRho T :=
    zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_chain1 :
      zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2))
        Ôëñ zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T + z.re) / z.im))) :=
    mul_le_mul_of_nonneg_left h_paired h¤ü_nn
  -- Bridge: arctan-sum Ôëñ honest tail neg-Im
  have h_chain2 :
      zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
        Ôëñ -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im :=
    constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im hT hy
  -- Align `T - (-z.re)` with `T + z.re`
  have hT_neg_re : T - (-z.re) = T + z.re := by ring
  rw [hT_neg_re] at h_chain2
  linarith

