noncomputable def totalAllowanceOf
    (K : BacklundNumericalConstants) (T : тДЭ) : тДЭ :=
  jensenAllowanceOf K T +
    rightSideAllowanceOf K T +
    horizontalAllowanceOf K T

end BacklundNumerics

/-- Pure arithmetic admissibility: the chosen Backlund constants give
nonnegative allowances at every `T тЙе 140` and the total fits under the
target `(1/2)┬╖log T + 1/2`. -/
structure BacklundNumericalConstantsAdmissible
    (K : BacklundNumericalConstants) : Prop where
  jensen_nonneg :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      0 тЙд BacklundNumerics.jensenAllowanceOf K T
  right_nonneg :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      0 тЙд BacklundNumerics.rightSideAllowanceOf K T
  horizontal_nonneg :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      0 тЙд BacklundNumerics.horizontalAllowanceOf K T
  total_le :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      BacklundNumerics.totalAllowanceOf K T
        тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-- Arithmetic helper for the final Backlund constants.  Once the
historical constants are inserted, admissibility reduces to checking
nonnegativity of the six individual scalars and the two summed budget
inequalities. -/
theorem BacklundNumericalConstantsAdmissible.of_nonneg_coeffs_and_budget
    {K : BacklundNumericalConstants}
    (hJlog : 0 тЙд K.jensenLogCoeff)
    (hRlog : 0 тЙд K.rightLogCoeff)
    (hHlog : 0 тЙд K.horizontalLogCoeff)
    (hJconst : 0 тЙд K.jensenConst)
    (hRconst : 0 тЙд K.rightConst)
    (hHconst : 0 тЙд K.horizontalConst)
    (hLogBudget :
      K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff
        тЙд (1 / 2 : тДЭ))
    (hConstBudget :
      K.jensenConst + K.rightConst + K.horizontalConst
        тЙд (1 / 2 : тДЭ)) :
    BacklundNumericalConstantsAdmissible K where
  jensen_nonneg := by
    intro T hT
    have hT_one : (1 : тДЭ) тЙд T := by linarith
    have hlog : 0 тЙд Real.log T := Real.log_nonneg hT_one
    have hmul : 0 тЙд K.jensenLogCoeff * Real.log T :=
      mul_nonneg hJlog hlog
    dsimp [BacklundNumerics.jensenAllowanceOf]
    nlinarith
  right_nonneg := by
    intro T hT
    have hT_one : (1 : тДЭ) тЙд T := by linarith
    have hlog : 0 тЙд Real.log T := Real.log_nonneg hT_one
    have hmul : 0 тЙд K.rightLogCoeff * Real.log T :=
      mul_nonneg hRlog hlog
    dsimp [BacklundNumerics.rightSideAllowanceOf]
    nlinarith
  horizontal_nonneg := by
    intro T hT
    have hT_one : (1 : тДЭ) тЙд T := by linarith
    have hlog : 0 тЙд Real.log T := Real.log_nonneg hT_one
    have hmul : 0 тЙд K.horizontalLogCoeff * Real.log T :=
      mul_nonneg hHlog hlog
    dsimp [BacklundNumerics.horizontalAllowanceOf]
    nlinarith
  total_le := by
    intro T hT
    have hT_one : (1 : тДЭ) тЙд T := by linarith
    have hlog : 0 тЙд Real.log T := Real.log_nonneg hT_one
    have hLogTerm :
        (K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff)
            * Real.log T
          тЙд (1 / 2 : тДЭ) * Real.log T :=
      mul_le_mul_of_nonneg_right hLogBudget hlog
    calc
      BacklundNumerics.totalAllowanceOf K T
          = (K.jensenLogCoeff + K.rightLogCoeff + K.horizontalLogCoeff)
              * Real.log T
            + (K.jensenConst + K.rightConst + K.horizontalConst) := by
              simp [BacklundNumerics.totalAllowanceOf,
                BacklundNumerics.jensenAllowanceOf,
                BacklundNumerics.rightSideAllowanceOf,
                BacklundNumerics.horizontalAllowanceOf]
              ring
      _ тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 := by
            linarith

