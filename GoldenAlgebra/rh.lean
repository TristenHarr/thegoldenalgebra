    (cert_13_14 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 13 Ôëñ T ÔåÆ T Ôëñ 14 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD 0 (44/100 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_14_19 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 14 Ôëñ T ÔåÆ T Ôëñ 19 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD 0 (1/2 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_19_32 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 19 Ôëñ T ÔåÆ T Ôëñ 32 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD 0 (1 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_32_36 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 32 Ôëñ T ÔåÆ T Ôëñ 36 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD (1/2 : ÔäØ) (1/2 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_36_48 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 36 Ôëñ T ÔåÆ T Ôëñ 48 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD (1/2 : ÔäØ) (1 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_48_80 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 48 Ôëñ T ÔåÆ T Ôëñ 80 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD (1/2 : ÔäØ) (49/20 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_80_140 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 80 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD (1/2 : ÔäØ) (49/20 : ÔäØ) z.im T Ôëñ -(model z).im)
    {z : Ôäé} {T : ÔäØ}
    (hT10 : 10 Ôëñ T) (hT140 : T Ôëñ 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    Ôêâ C D : ÔäØ, closedFormSErrorBoundCD C D z.im T Ôëñ -(model z).im :=
