/-- в≠Р **PROVED вАФ `z - (u : вДВ) вЙ† 0` when `0 < z.im`.** -/
lemma complex_sub_real_ne_zero_of_im_pos
    {z : вДВ} (hz : 0 < z.im) (u : вДЭ) :
    z - (u : вДВ) вЙ† 0 := by
  intro h
  have him : (z - (u : вДВ)).im = 0 := by rw [h]; rfl
  have him' : (z - (u : вДВ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- в≠Р **PROVED вАФ `z + (u : вДВ) вЙ† 0` when `0 < z.im`.** -/
lemma complex_add_real_ne_zero_of_im_pos
    {z : вДВ} (hz : 0 < z.im) (u : вДЭ) :
    z + (u : вДВ) вЙ† 0 := by
  intro h
  have him : (z + (u : вДВ)).im = 0 := by rw [h]; rfl
  have him' : (z + (u : вДВ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- рЯМЯрЯМЯ **PROVED вАФ paired Cauchy kernel continuous in `u` for UHP `z`.**
For `0 < z.im`, the map `u вЖ¶ 1/(z - u) + 1/(z + u)` is continuous on вДЭ,
since both denominators are non-vanishing. -/
lemma continuous_pairedCauchyKernel_u_of_im_pos
    {z : вДВ} (hz : 0 < z.im) :
    Continuous fun u : вДЭ =>
      (1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)) := by
  refine Continuous.add ?_ ?_
  ¬Ј apply Continuous.divвВА continuous_const
    ¬Ј exact continuous_const.sub Complex.continuous_ofReal
    ¬Ј intro u
      exact complex_sub_real_ne_zero_of_im_pos hz u
  ¬Ј apply Continuous.divвВА continuous_const
    ¬Ј exact continuous_const.add Complex.continuous_ofReal
    ¬Ј intro u
      exact complex_add_real_ne_zero_of_im_pos hz u

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ UHP interval integrability of
`zeroDensityRho √Ч paired Cauchy kernel`.** For `0 < T вЙ§ X` and
`0 < z.im`, the integrand is continuous on `[T, X]` (both factors
continuous + denominators non-vanishing), hence interval-integrable. -/
theorem zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
    (T X : вДЭ) {z : вДВ}
    (hTpos : 0 < T) (hTX : T вЙ§ X) (hz : 0 < z.im) :
    IntervalIntegrable
      (fun u =>
        (zeroDensityRho u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
      MeasureTheory.volume T X := by
  -- ѕБ continuous on Icc T X (subset of Ioi 0)
  have hѕБ_real : ContinuousOn zeroDensityRho (Set.Icc T X) := by
    apply Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    intro u hu
    exact lt_of_lt_of_le hTpos hu.1
  have hѕБ : ContinuousOn (fun u : вДЭ => (zeroDensityRho u : вДВ))
      (Set.Icc T X) :=
    Complex.continuous_ofReal.comp_continuousOn hѕБ_real
  -- Kernel continuous on UHP for fixed z
  have hk : ContinuousOn
      (fun u : вДЭ =>
        (1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))
      (Set.Icc T X) :=
    (continuous_pairedCauchyKernel_u_of_im_pos hz).continuousOn
  have hprod : ContinuousOn
      (fun u =>
        (zeroDensityRho u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
      (Set.Icc T X) :=
    hѕБ.mul hk
  exact ContinuousOn.intervalIntegrable_of_Icc hTX hprod

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelData` for the concrete
`zeroDensityRho` density.** Given `T вЙ• 2ѕА`, produces a full
`SmoothDensityTailModelData` by composing ¬ІCCXLI's integrability
discharger with ¬ІCCXL's UHP majorant chain and ¬ІCCXXXIX's log-growth
bound. -/
noncomputable def smoothDensityTailModelData_zeroDensityRho
    (T : вДЭ) (hT_ge : 2 * Real.pi вЙ§ T) :
    SmoothDensityTailModelData := by
  have hTpos : 0 < T := by
    have hpi : (0 : вДЭ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hT_ge
  have h2pi_inv_nn : (0 : вДЭ) вЙ§ 1 / (2 * Real.pi) := by positivity
  exact smoothDensityTailModelData_of_majorant_nonneg_UHP
    zeroDensityRho T
    (fun u hTu =>
      zeroDensityRho_nonneg_of_ge_two_pi (le_trans hT_ge hTu))
    (smoothDensityTailMajorantDataUHP_of_logGrowth
      zeroDensityRho T
      (1 / (2 * Real.pi)) 0
      h2pi_inv_nn le_rfl hTpos
      zeroDensityRho_log_growth_eventually
      (fun z X hz hTX =>
        zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
          T X hTpos hTX hz))

