/-- тнР **PROVED тАФ `tailK19_rat T тЙд tailK_19_32 T` on `[19, 32]`.** -/
lemma tailK19_rat_le_tailK_19_32
    {T : тДЭ} (hT19 : 19 тЙд T) (_hT32 : T тЙд 32) :
    tailK19_rat T тЙд tailK_19_32 T := by
  unfold tailK19_rat tailK_19_32 logAffine_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have h_pi_inv : (7 / 44 : тДЭ) тЙд 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_aff_nn : (0 : тДЭ) тЙд (11 / 10 : тДЭ) + (T - 19) / 26 := by linarith
  have h_factor_nn : (0 : тДЭ) тЙд (22 / 15 : тДЭ) * ((11 / 10 : тДЭ) + (T - 19) / 26) := by
    positivity
  have h_step1 :
      (22 / 15 : тДЭ) * ((11 / 10 : тДЭ) + (T - 19) / 26) * (7 / 44)
        тЙд (22 / 15 : тДЭ) * ((11 / 10 : тДЭ) + (T - 19) / 26) * (1 / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_pi_inv h_factor_nn
  have h_form_eq :
      (22 / 15 : тДЭ) * (((11 / 10 : тДЭ) + (T - 19) / 26) / (2 * Real.pi)) / T
        = (22 / 15 : тДЭ) * ((11 / 10 : тДЭ) + (T - 19) / 26) * (1 / (2 * Real.pi)) / T := by
    ring
  rw [h_form_eq]
  apply div_le_div_of_nonneg_right h_step1 (le_of_lt hT_pos)

/-- тнР **PROVED тАФ smooth-tail LB on `[19, 32]`** via affine ╧Б. -/
lemma smoothTail_ge_affine_19_32
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hT19 : 19 тЙд T) (hT32 : T тЙд 32)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T) :
    y * tailK_19_32 T тЙд smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hT_2pi : 2 * Real.pi тЙд T := by linarith
  have hreg' : 2 * (1 + |x| + y) тЙд T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : logAffine_19_32 T / (2 * Real.pi) тЙд zeroDensityRho T :=
    zeroDensityRho_ge_affine_19_32 hT19 hT32
  have h_22_15_nn : (0 : тДЭ) тЙд 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi))
      тЙд (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : тДЭ) тЙд y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T
        тЙд (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) * (y / T)
          = (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : тДЭ) * zeroDensityRho T * (y / T)
          = (22 / 15 : тДЭ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : тДЭ) * zeroDensityRho T * y / T
                тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) / T)
      = (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T := by ring
  rw [h_y_form]
  exact le_trans h_chain h_base

/-- тнР **PROVED тАФ `cloudK_T` is anti-monotone in `T`** on positive box. -/
lemma cloudK_T_antitone_T (zeros : List тДЭ) {TтВБ TтВВ : тДЭ}
    (h_TтВБ_pos : 0 < TтВБ / 2 - 1) (h_T_le : TтВБ тЙд TтВВ) :
    cloudK_T zeros TтВВ тЙд cloudK_T zeros TтВБ := by
  unfold cloudK_T
  apply List.sum_le_sum
  intro ╬│ _h╬│
  have h_TтВВ_pos : 0 < TтВВ / 2 - 1 := by linarith
  have h_sq_le : (TтВБ / 2 - 1)^2 тЙд (TтВВ / 2 - 1)^2 :=
    sq_le_sq' (by linarith) (by linarith)
  have h_den_le : (TтВБ / 2 - 1)^2 + ╬│^2 тЙд (TтВВ / 2 - 1)^2 + ╬│^2 := by linarith
  have h_TтВБ_box_pos : 0 < (TтВБ / 2 - 1)^2 + ╬│^2 := by
    have hsq : 0 < (TтВБ / 2 - 1)^2 := pow_pos h_TтВБ_pos 2
    nlinarith [sq_nonneg ╬│]
  exact one_div_le_one_div_of_le h_TтВБ_box_pos h_den_le

/-- тнР **PROVED тАФ `tailK19_rat` is anti-monotone in `T`** on `[19, 32]`. -/
