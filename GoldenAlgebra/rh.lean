/-- `exp (24/5) < 140`, used to show the target half-log budget already
dominates `2.5167` at `T = 140`. -/
theorem backlund_exp_24_5_lt_140 : Real.exp (24 / 5 : ℝ) < 140 := by
  have h_e_lt : Real.exp 1 < 2.72 :=
    lt_trans Real.exp_one_lt_d9 (by norm_num)
