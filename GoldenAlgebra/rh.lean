-- ---------------------------------------------------------------------
-- CLVI: Finite-band model-margin certificate
-- ---------------------------------------------------------------------
-- The smooth density tail bound has a structural floor: ¤ü(T) ÔåÆ 0 as
-- T ÔåÆ 2¤Ç. No constant `c` (even the sharp 8/5) can close the finite
-- band [2¤Ç, TÔéÇ] using density-tail alone. The full model margin
-- `ÔêÆIm(cloud + densityTail)` carries cloud margin that *is* finite at
-- `T = 2¤Ç`, so the residual band must be discharged at the model level,
-- typically via an interval-arithmetic / SOS certificate.
--
-- This is the named target where that certificate lands.

/-- **Finite-band model-margin certificate.** Captures the small-`T`
discharge: on the closed interval `[Tmin, Tmax]` (typically `[2¤Ç, 140]`
for the (22/15) route or `[2¤Ç, 125]` for the sharp (8/5) route) and the
canonical adaptive `A = 2` region, the closed-form `S`-error bound at
`(C, D)` is dominated by `ÔêÆIm(model z)`.

This structure is the named slot for an interval-arithmetic certificate
or SOS proof; nothing in the file claims this is proved. Combining a
`LargeTClosedFormDomination` (large-`T` analytic discharge) with a
`FiniteBandModelMarginCertificate` (small-`T` certified discharge)
gives the full unconditional `hclosed` chain at every `T ÔëÑ 2¤Ç`. -/
structure FiniteBandModelMarginCertificate where
  Tmin : ÔäØ
  Tmax : ÔäØ
  Tmin_ge_two_pi : 2 * Real.pi Ôëñ Tmin
  Tmin_le_Tmax : Tmin Ôëñ Tmax
  model : Ôäé ÔåÆ Ôäé
  C : ÔäØ
  D : ÔäØ
  cert :
    ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
      Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ
      0 < z.im ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD C D z.im T Ôëñ -(model z).im

/-- Ô¡É **PROVED ÔÇö certificate Ôƒ╣ `ModelMarginLowerBound` at every probe
in the certified band.** Mirrors the per-probe projection used for the
large-`T` route. -/
noncomputable def FiniteBandModelMarginCertificate.atProbe
    (F : FiniteBandModelMarginCertificate)
    (z : Ôäé) (T : ÔäØ)
    (hTmin : F.Tmin Ôëñ T) (hTmax : T Ôëñ F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

-- ---------------------------------------------------------------------
-- CLVIII: Per-slab S-bound and stitched coverage of [2¤Ç, T0]
-- ---------------------------------------------------------------------
-- Python feasibility scan with 50 zeros shows the global Turing-style
-- bound C=1/2, D=49/20 cannot certify slabs below T Ôëê 48, even with
-- arbitrarily many cloud zeros (the cloud margin saturates as ╬ú y/╬│_k┬▓
-- converges). The actual S-fluctuation on small slabs is much smaller
-- than the global envelope. Per-slab (C, D) drops the lower edge:
--   (C=1/2, D=49/20) ÔåÆ feasible from T Ôëê 48
--   (C=1/2, D=1)     ÔåÆ feasible from T Ôëê 36
--   (C=1/2, D=1/2)   ÔåÆ feasible from T Ôëê 32
--   (C=0,   D=1)     ÔåÆ feasible from T Ôëê 19
--   (C=0,   D=1/2)   ÔåÆ feasible from T Ôëê 14
--   (C=0,   D=1/4)   ÔåÆ feasible from T Ôëê 10
-- Each `(C, D)` choice must be justified by a slab-specific S bound.

/-- **Single-slab model-margin certificate at per-slab (C, D).**
Identical shape to `FiniteBandModelMarginCertificate`, but emphasises
that each slab in a piecewise covering of `[2¤Ç, T0]` may choose its own
`(C, D)` pair backed by a slab-specific S envelope. -/
structure FiniteSlabModelMarginCertificate where
  Tmin : ÔäØ
  Tmax : ÔäØ
  Tmin_ge_two_pi : 2 * Real.pi Ôëñ Tmin
  Tmin_le_Tmax : Tmin Ôëñ Tmax
  model : Ôäé ÔåÆ Ôäé
  C : ÔäØ
  D : ÔäØ
  cert :
    ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
      Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ
      0 < z.im ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD C D z.im T Ôëñ -(model z).im

/-- Ô¡É **PROVED ÔÇö per-probe `ModelMarginLowerBound` from a single slab
certificate.** Same shape as the band-wide projection but works for any
`(C, D)` chosen by the slab. -/
noncomputable def FiniteSlabModelMarginCertificate.atProbe
    (F : FiniteSlabModelMarginCertificate)
    (z : Ôäé) (T : ÔäØ)
    (hTmin : F.Tmin Ôëñ T) (hTmax : T Ôëñ F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

/-- **Piecewise cover of `[Tmin_total, Tmax_total]` by a list of
slab certificates.** The list must be non-overlapping in `T` and cover
the full interval; each slab supplies its own `(C, D)`.

This package isolates the combinatorial "find the right slab for `T`"
step from the analytic content (each slab's `cert`). For the rh.lean
finite-band discharge, the typical instantiation covers `[2¤Ç, 140]` with
a handful of slabs, each chosen so the local S envelope is tight. -/
structure PiecewiseFiniteBandCertificate where
  slabs : List FiniteSlabModelMarginCertificate
  model : Ôäé ÔåÆ Ôäé
  /-- All slabs share the model under consideration. -/
  model_shared : ÔêÇ s Ôêê slabs, s.model = model
  Tmin_total : ÔäØ
  Tmax_total : ÔäØ
  Tmin_ge_two_pi : 2 * Real.pi Ôëñ Tmin_total
  /-- For every probe in the band, some slab covers it. -/
  cover :
    ÔêÇ T : ÔäØ, Tmin_total Ôëñ T ÔåÆ T Ôëñ Tmax_total ÔåÆ
      Ôêâ s Ôêê slabs, s.Tmin Ôëñ T Ôêº T Ôëñ s.Tmax

/-- Ô¡É **PROVED ÔÇö piecewise cover Ôƒ╣ per-probe `ModelMarginLowerBound`.**
For any `T` in the covered band, locate the right slab and apply its
`atProbe`. Both `ÔêÆIm(model z)` bounds (each slab's) translate through
`model_shared`. -/
noncomputable def PiecewiseFiniteBandCertificate.atProbe
    (P : PiecewiseFiniteBandCertificate)
    (z : Ôäé) (T : ÔäØ)
    (hTmin : P.Tmin_total Ôëñ T) (hTmax : T Ôëñ P.Tmax_total)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    Ôêâ C D : ÔäØ,
      closedFormSErrorBoundCD C D z.im T Ôëñ -(P.model z).im := by
  obtain Ôƒ¿s, hs_mem, hsTmin, hsTmaxÔƒ® := P.cover T hTmin hTmax
  refine Ôƒ¿s.C, s.D, ?_Ôƒ®
  have hmodel : s.model = P.model := P.model_shared s hs_mem
  have h := s.cert z T hsTmin hsTmax hy hreg
  rw [hmodel] at h
  exact h

-- ---------------------------------------------------------------------
-- CLIX-A: Slab-local Turing-style S-bound
-- ---------------------------------------------------------------------
-- The source of per-slab (C, D) pairs. Each `SlabTuringStyleSBound`
-- asserts `|S u| Ôëñ C┬Àlog u + D` on a finite interval `[A, B]`, in
-- contrast to the global `TuringStyleSBound` (defined elsewhere in
-- the file) which asserts the bound on the lower-unbounded tail
-- `u ÔëÑ some lower`.

/-- **Slab-local Turing-style S-bound.** Asserts that the
zero-counting fluctuation `S(u)` is dominated by `C┬Àlog u + D` on a
compact interval `[A, B]`. Each slab in a `PiecewiseFiniteBandCertificate`
typically chooses its own `(C, D)` justified by such a slab bound. -/
structure SlabTuringStyleSBound where
  S : ÔäØ ÔåÆ ÔäØ
  A : ÔäØ
  B : ÔäØ
  C : ÔäØ
  D : ÔäØ
  bound :
    ÔêÇ u : ÔäØ, A Ôëñ u ÔåÆ u Ôëñ B ÔåÆ |S u| Ôëñ C * Real.log u + D

-- ---------------------------------------------------------------------
-- CLIX-B: First-zero direct package ÔÇö N(u) = 0 on [2¤Ç, ╬│Ôéü)
-- ---------------------------------------------------------------------
-- For `u < ╬│Ôéü` (first nontrivial Riemann zero, ╬│Ôéü Ôëê 14.13), the
-- zero-counting function satisfies `N(u) = 0`, so `S(u) = -NÔéÇ(u)`
-- is *explicitly known*, not just envelope-bounded. The error
-- contribution from this slab can be evaluated exactly rather than
-- bounded via the generic `closedFormSErrorBoundCD`.

/-- **First-zero gap formula.** Records the structural fact that
`N(u) = 0` on `[2¤Ç, ╬│Ôéü)`, hence `S(u) = -NÔéÇ(u)` is concretely
computable on this interval. -/
structure FirstZeroGapSFormula where
  N : ÔäØ ÔåÆ ÔäØ
  S : ÔäØ ÔåÆ ÔäØ
  NÔéÇ : ÔäØ ÔåÆ ÔäØ
  gamma1 : ÔäØ
  hgamma1_pos : 0 < gamma1
  noZerosBefore :
    ÔêÇ u : ÔäØ, 2 * Real.pi Ôëñ u ÔåÆ u < gamma1 ÔåÆ N u = 0
  S_eq_neg_N0 :
    ÔêÇ u : ÔäØ, 2 * Real.pi Ôëñ u ÔåÆ u < gamma1 ÔåÆ S u = -(NÔéÇ u)

/-- **First-zero S envelope.** A concrete numerical bound
`|NÔéÇ(u)| Ôëñ D` on `[2¤Ç, ╬│Ôéü]`, used to feed `closedFormSErrorBoundCD`
with `(C, D) = (0, D)` in the very small slab.

Python (CLVII findings): on `[2¤Ç, 14]`, `|NÔéÇ(u)| Ôëñ Ôëê 0.45` (the value
`|NÔéÇ(╬│Ôéü)|` just before the first-zero count jumps from 0 to 1). So
`D Ôëê 1/2` is a realistic rigorous choice. -/
structure FirstZeroGapSBound where
  NÔéÇ : ÔäØ ÔåÆ ÔäØ
  gamma1 : ÔäØ
  D : ÔäØ
  bound :
    ÔêÇ u : ÔäØ, 2 * Real.pi Ôëñ u ÔåÆ u Ôëñ gamma1 ÔåÆ |NÔéÇ u| Ôëñ D

/-- **First-zero-band model-margin certificate.** Mirrors
`FiniteSlabModelMarginCertificate` but ties the slab to the first-zero
gap `[Tmin, Tmax] Ôèå [2¤Ç, ╬│Ôéü]` and uses a placeholder
`closedFormFirstZeroErrorBound` that is sharper than the generic
`closedFormSErrorBoundCD` because it exploits the known `S = -NÔéÇ`.

For the rh.lean discharge this is the *only* irreducible piece below
the piecewise SDP coverage, since the generic envelope (even with
small `D`) is inflated by the `8 + 18` IBP constants in the closed
form. -/
structure FirstZeroBandCertificate where
  Tmin : ÔäØ
  Tmax : ÔäØ
  gamma1 : ÔäØ
  Tmin_ge_two_pi : 2 * Real.pi Ôëñ Tmin
  Tmin_le_Tmax : Tmin Ôëñ Tmax
  Tmax_le_gamma1 : Tmax Ôëñ gamma1
  model : Ôäé ÔåÆ Ôäé
  /-- The sharper error bound exploiting `S = -NÔéÇ` on this slab.
  Left as a function field rather than a hard-coded formula since the
  exact polynomial form depends on the integral evaluation
  technique used. -/
  errorBound : ÔäØ ÔåÆ ÔäØ ÔåÆ ÔäØ
  cert :
    ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
      Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ
      0 < z.im ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        errorBound z.im T Ôëñ -(model z).im

-- ---------------------------------------------------------------------
-- CLIX-C: Closed-form first-zero error bound
-- ---------------------------------------------------------------------
-- The generic `closedFormSErrorBoundCD 0 D y T = 17┬Ày┬ÀD / T┬▓` bounds the
-- IBP integral over `[T, Ôê×)` using `|k_z'(u)| Ôëñ 18y / u┬│` and
-- `Ôê½_T^Ôê× du/u┬│ = 1/(2 T┬▓)`. On the first-zero slab (`Tmin ÔëÑ 2¤Ç`,
-- `Tmax Ôëñ ╬│Ôéü`) the zero-counting fluctuation factors as `S = ÔêÆNÔéÇ` and
-- the *substantive* IBP integral runs only over `[T, ╬│Ôéü]`, since the
-- `[╬│Ôéü, Ôê×)` tail is folded into the explicit cloud model rather than
-- into the envelope.  The integral becomes
--
--   Ôê½_T^{╬│Ôéü} |k_z'(u)| ┬À D du
--      Ôëñ 18 y D ┬À Ôê½_T^{╬│Ôéü} du / u┬│
--      = 18 y D ┬À (1/(2 T┬▓) ÔêÆ 1/(2 ╬│Ôéü┬▓))
--      = 9 y D / T┬▓  ÔêÆ  9 y D / ╬│Ôéü┬▓,
--
-- saving exactly `9 y D / ╬│Ôéü┬▓` over the generic bound. The closed-form
-- error bound is the algebraic sum
--
--   boundary  +  slabIntegral
--      = 8 y D / T┬▓  +  (9 y D / T┬▓ ÔêÆ 9 y D / ╬│Ôéü┬▓)
--      = 17 y D / T┬▓  ÔêÆ  9 y D / ╬│Ôéü┬▓.

/-- **Closed-form first-zero error bound.** The sharper analogue of
`closedFormSErrorBoundCD 0 D y T` valid on `[T, ╬│Ôéü]`, obtained by
replacing the `Ôê½_T^Ôê× du/u┬│` integral with `Ôê½_T^{╬│Ôéü} du/u┬│`.

Concretely:
  `closedFormFirstZeroErrorBound y T ╬│Ôéü D := 17┬Ày┬ÀD/T┬▓ ÔêÆ 9┬Ày┬ÀD/╬│Ôéü┬▓`. -/
noncomputable def closedFormFirstZeroErrorBound
    (y T gamma1 D : ÔäØ) : ÔäØ :=
  17 * y * D / T^2 - 9 * y * D / gamma1^2

/-- Ô¡É **PROVED ÔÇö algebraic equivalence: first-zero bound = generic bound ÔêÆ
╬│Ôéü-correction.** Makes the "subtract the [╬│Ôéü,Ôê×) contribution"
interpretation a syntactic identity. -/
theorem closedFormFirstZeroErrorBound_eq_sub
    {T : ÔäØ} (hT : T Ôëá 0) (y gamma1 D : ÔäØ) :
    closedFormFirstZeroErrorBound y T gamma1 D
      = closedFormSErrorBoundCD 0 D y T - 9 * y * D / gamma1^2 := by
  unfold closedFormFirstZeroErrorBound closedFormSErrorBoundCD
  have hT2 : T^2 Ôëá 0 := pow_ne_zero 2 hT
  field_simp
  ring

/-- Ô¡É **PROVED ÔÇö sharpness: first-zero bound dominates generic bound.**
On non-negative `(y, D)` and `╬│Ôéü Ôëá 0`, the first-zero bound is at most
the generic bound ÔÇö by exactly the saving `9┬Ày┬ÀD/╬│Ôéü┬▓ ÔëÑ 0`. -/
theorem closedFormFirstZeroErrorBound_le_closedFormSErrorBoundCD_zero
    {T y D gamma1 : ÔäØ}
    (hT : T Ôëá 0) (hy : 0 Ôëñ y) (hD : 0 Ôëñ D) (hgamma1 : gamma1 Ôëá 0) :
    closedFormFirstZeroErrorBound y T gamma1 D
      Ôëñ closedFormSErrorBoundCD 0 D y T := by
  rw [closedFormFirstZeroErrorBound_eq_sub hT]
  have hg2 : 0 < gamma1^2 := by positivity
  have h_sav : 0 Ôëñ 9 * y * D / gamma1^2 := by positivity
  linarith

/-- Ô¡É **PROVED ÔÇö closed-form first-zero bound dominates a slab-IBP sum.**
Given closed-form upper bounds on the boundary term (`8 y D / T┬▓`) and on
the slab-restricted integral (`9 y D / T┬▓ ÔêÆ 9 y D / ╬│Ôéü┬▓`), their sum is
Ôëñ `closedFormFirstZeroErrorBound y T ╬│Ôéü D`. This is the algebraic core
of the analytic claim "first-zero IBP envelope Ôëñ closed-form bound";
the actual IBP integral inequalities are produced by CXLIV-CL applied
on `[T, ╬│Ôéü]` instead of `[T, Ôê×)`. -/
theorem slabIBP_sum_le_closedFormFirstZeroErrorBound
    {y T gamma1 D boundaryTerm slabIntegralBound : ÔäØ}
    (hbdy : boundaryTerm Ôëñ 8 * y * D / T^2)
    (hslabInt : slabIntegralBound Ôëñ 9 * y * D / T^2 - 9 * y * D / gamma1^2) :
    boundaryTerm + slabIntegralBound
      Ôëñ closedFormFirstZeroErrorBound y T gamma1 D := by
  unfold closedFormFirstZeroErrorBound
  have h_split :
      17 * y * D / T^2 = 8 * y * D / T^2 + 9 * y * D / T^2 := by ring
  linarith

/-- Ô¡É **PROVED ÔÇö first-zero band certificate from a per-probe closed-form
domination.** Wraps the per-probe `closedFormFirstZeroErrorBound Ôëñ
ÔêÆIm(model z)` proof (the slab-restricted certificate the
SDP/Schm├╝dgen step produces) into a fully populated
`FirstZeroBandCertificate`. The cover-the-band closure proof is the
identity. -/
noncomputable def FirstZeroBandCertificate.ofClosedFormFirstZero
    (Tmin Tmax gamma1 D : ÔäØ)
    (hTmin_ge_two_pi : 2 * Real.pi Ôëñ Tmin)
    (hTmin_le_Tmax : Tmin Ôëñ Tmax)
    (hTmax_le_gamma1 : Tmax Ôëñ gamma1)
    (model : Ôäé ÔåÆ Ôäé)
    (hprobe :
      ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
        Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ
        0 < z.im ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
          closedFormFirstZeroErrorBound z.im T gamma1 D Ôëñ -(model z).im) :
    FirstZeroBandCertificate where
  Tmin := Tmin
  Tmax := Tmax
  gamma1 := gamma1
  Tmin_ge_two_pi := hTmin_ge_two_pi
  Tmin_le_Tmax := hTmin_le_Tmax
  Tmax_le_gamma1 := hTmax_le_gamma1
  model := model
  errorBound := fun y T => closedFormFirstZeroErrorBound y T gamma1 D
  cert := hprobe

-- ---------------------------------------------------------------------
-- CLX-A: HasDerivAt + MonotoneOn for smoothZeroCountingN0 on [2¤Ç, Ôê×)
-- ---------------------------------------------------------------------

/-- Ô¡É **PROVED ÔÇö `HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u` for
`u > 0`.** The `HasDerivAt`-flavoured version of the existing
`deriv_smoothZeroCountingN0`. Needed to apply
`monotoneOn_of_deriv_nonneg`. -/
theorem hasDerivAt_smoothZeroCountingN0
    {u : ÔäØ} (hu : 0 < u) :
    HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u := by
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h2pi_pos
  have hu_ne : u Ôëá 0 := ne_of_gt hu
  have hq_pos : (0 : ÔäØ) < u / (2 * Real.pi) := div_pos hu h2pi_pos
  have hq_ne : u / (2 * Real.pi) Ôëá 0 := ne_of_gt hq_pos
  have h_lin : HasDerivAt (fun u : ÔäØ => u / (2 * Real.pi)) (1 / (2 * Real.pi)) u := by
    simpa using (hasDerivAt_id u).div_const (2 * Real.pi)
  have h_log_inner :
      HasDerivAt (fun u : ÔäØ => Real.log (u / (2 * Real.pi))) (1 / u) u := by
    have hlog := Real.hasDerivAt_log hq_ne
    have h_comp := hlog.comp u h_lin
    have h_simp : (u / (2 * Real.pi))Ôü╗┬╣ * (1 / (2 * Real.pi)) = 1 / u := by
      field_simp; ring
    rw [h_simp] at h_comp
    simpa [Function.comp_def] using h_comp
  have h_prod := h_lin.mul h_log_inner
  have h_sub := h_prod.sub h_lin
  have h_final := h_sub.add_const (7 / 8)
  -- Match function form to smoothZeroCountingN0 and simplify derivative.
  have h_func_eq :
      (fun u : ÔäØ => (u / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
                    - u / (2 * Real.pi) + 7 / 8)
        = smoothZeroCountingN0 := by
    funext v; rfl
  have h_deriv_eq :
      (1 / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
        + (u / (2 * Real.pi)) * (1 / u) - 1 / (2 * Real.pi)
      = zeroDensityRho u := by
    unfold zeroDensityRho
    field_simp
    ring
  rw [ÔåÉ h_func_eq, ÔåÉ h_deriv_eq]
  exact h_final

/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0` is monotone on `[2¤Ç, Ôê×)`.**

Direct from `monotoneOn_of_deriv_nonneg`:
* continuity and differentiability on the interior follow from
  `hasDerivAt_smoothZeroCountingN0`;
* the derivative `zeroDensityRho u` is `ÔëÑ 0` for `u ÔëÑ 2¤Ç`
  (`zeroDensityRho_nonneg_of_ge_two_pi`). -/
theorem smoothZeroCountingN0_monotoneOn_Ici_two_pi :
    MonotoneOn smoothZeroCountingN0 (Set.Ici (2 * Real.pi)) := by
  apply monotoneOn_of_deriv_nonneg (convex_Ici _)
  ┬À intro x hx
    have hx_ge : 2 * Real.pi Ôëñ x := hx
    have hx_pos : 0 < x := lt_of_lt_of_le (by positivity) hx_ge
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).continuousAt.continuousWithinAt
  ┬À intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).differentiableAt.differentiableWithinAt
  ┬À intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    rw [(hasDerivAt_smoothZeroCountingN0 hx_pos).deriv]
    exact zeroDensityRho_nonneg_of_ge_two_pi (le_of_lt hx_2pi)

-- ---------------------------------------------------------------------
-- CLX-B: Endpoint bounds for smoothZeroCountingN0 on [2¤Ç, 10]
-- ---------------------------------------------------------------------

/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0(2¤Ç) = -1/8`.**

Direct evaluation: `NÔéÇ(2¤Ç) = 1 ┬À log(1) ÔêÆ 1 + 7/8 = -1/8`. -/
theorem smoothZeroCountingN0_at_two_pi :
    smoothZeroCountingN0 (2 * Real.pi) = -(1 / 8) := by
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h2pi_pos
  unfold smoothZeroCountingN0
  have h_div_one : (2 * Real.pi) / (2 * Real.pi) = 1 := div_self h2pi_ne
  rw [h_div_one, Real.log_one]
  ring

/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0(10) Ôëñ 1/2`.**

Chain: `5/¤Ç ÔëÑ 5/3.15 > 1.58` (since `¤Ç < 3.15`), `5/¤Ç < 2` (since
`¤Ç > 2.5`), so `log(5/¤Ç) Ôëñ log 2 Ôëñ 0.7` (Mathlib `Real.log_two_lt_d9`),
giving `NÔéÇ(10) = (5/¤Ç)┬Àlog(5/¤Ç) ÔêÆ 5/¤Ç + 7/8 Ôëñ 1.58┬À0.7 ÔêÆ 1.58 + 7/8 Ôëê 0.40 Ôëñ 1/2`. -/
theorem smoothZeroCountingN0_at_10_le_half :
    smoothZeroCountingN0 10 Ôëñ 1 / 2 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  -- 10/(2¤Ç) = 5/¤Ç
  have h_eq : (10 : ÔäØ) / (2 * Real.pi) = 5 / Real.pi := by ring
  rw [h_eq]
  have h_5_pi_pos : 0 < 5 / Real.pi := by positivity
  have h_5_pi_nn : 0 Ôëñ 5 / Real.pi := le_of_lt h_5_pi_pos
  -- 5/¤Ç > 1.58 (from ¤Ç < 3.15)
  have h_5_pi_gt : (1.58 : ÔäØ) < 5 / Real.pi := by
    rw [lt_div_iffÔéÇ h_pi_pos]; linarith
  -- 5/¤Ç < 2 (from ¤Ç > 5/2)
  have h_5_pi_lt_2 : 5 / Real.pi < 2 := by
    rw [div_lt_iffÔéÇ h_pi_pos]; linarith
  -- log(5/¤Ç) Ôëñ log 2
  have h_log_le_log2 : Real.log (5 / Real.pi) Ôëñ Real.log 2 :=
    Real.log_le_log h_5_pi_pos (le_of_lt h_5_pi_lt_2)
  -- log 2 Ôëñ 0.7
  have h_log2_lt : Real.log 2 Ôëñ 0.7 := by
    have := Real.log_two_lt_d9
    linarith
  have h_log_le : Real.log (5 / Real.pi) Ôëñ 0.7 :=
    le_trans h_log_le_log2 h_log2_lt
  -- log(5/¤Ç) ÔëÑ 0 since 5/¤Ç ÔëÑ 1
  have h_5_pi_ge_1 : (1 : ÔäØ) Ôëñ 5 / Real.pi := by
    rw [le_div_iffÔéÇ h_pi_pos]; linarith
  have h_log_nn : 0 Ôëñ Real.log (5 / Real.pi) := Real.log_nonneg h_5_pi_ge_1
  -- (5/¤Ç)┬Àlog(5/¤Ç) Ôëñ (5/¤Ç)┬À0.7
  have h_mul_le : (5 / Real.pi) * Real.log (5 / Real.pi)
                Ôëñ (5 / Real.pi) * 0.7 :=
    mul_le_mul_of_nonneg_left h_log_le h_5_pi_nn
  -- Combine: closedForm Ôëñ -0.3┬À(5/¤Ç) + 7/8 Ôëñ 1/2 since 0.3┬À(5/¤Ç) > 0.474 ÔëÑ 3/8
  nlinarith [h_mul_le, h_5_pi_gt]

/-- Ô¡É **PROVED ÔÇö `|NÔéÇ(u)| Ôëñ 1/2` for `u Ôêê [2¤Ç, 10]`.**

By `smoothZeroCountingN0_monotoneOn_Ici_two_pi`:
  `-1/8 = NÔéÇ(2¤Ç) Ôëñ NÔéÇ(u) Ôëñ NÔéÇ(10) Ôëñ 1/2`,
so `|NÔéÇ(u)| Ôëñ 1/2`. -/
theorem abs_smoothZeroCountingN0_le_half_on_first_band
    {u : ÔäØ} (hlo : 2 * Real.pi Ôëñ u) (hhi : u Ôëñ 10) :
    |smoothZeroCountingN0 u| Ôëñ 1 / 2 := by
  have h_mono := smoothZeroCountingN0_monotoneOn_Ici_two_pi
  have h_2pi_mem : (2 * Real.pi : ÔäØ) Ôêê Set.Ici (2 * Real.pi) := Set.left_mem_Ici
  have h_u_mem : u Ôêê Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hlo
  have h_10_mem : (10 : ÔäØ) Ôêê Set.Ici (2 * Real.pi) := by
    rw [Set.mem_Ici]
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_low : smoothZeroCountingN0 (2 * Real.pi) Ôëñ smoothZeroCountingN0 u :=
    h_mono h_2pi_mem h_u_mem hlo
  have h_high : smoothZeroCountingN0 u Ôëñ smoothZeroCountingN0 10 :=
    h_mono h_u_mem h_10_mem hhi
  rw [smoothZeroCountingN0_at_two_pi] at h_low
  have h_high' : smoothZeroCountingN0 u Ôëñ 1 / 2 :=
    le_trans h_high smoothZeroCountingN0_at_10_le_half
  rw [abs_le]
  refine Ôƒ¿?_, h_high'Ôƒ®
  linarith

-- ---------------------------------------------------------------------
-- CLX-C: FirstZeroCertified ÔÇö concrete first-zero assumption package
-- ---------------------------------------------------------------------

/-- **First-zero certification.** Bundles `╬│Ôéü > 10` together with the
no-zero-counted property `N(u) = 0` on `[2¤Ç, ╬│Ôéü)`. Numerically `╬│Ôéü Ôëê
14.13`. -/
structure FirstZeroCertified where
  N : ÔäØ ÔåÆ ÔäØ
  gamma1 : ÔäØ
  gamma1_gt_10 : 10 < gamma1
  noZerosBelow_gamma1 :
    ÔêÇ u : ÔäØ, 2 * Real.pi Ôëñ u ÔåÆ u < gamma1 ÔåÆ N u = 0

/-- Ô¡É **PROVED ÔÇö `N(u) = 0` on `[2¤Ç, 10]` from `FirstZeroCertified`.** -/
theorem FirstZeroCertified.noZeros_on_2pi_10
    (H : FirstZeroCertified)
    {u : ÔäØ} (hlo : 2 * Real.pi Ôëñ u) (hhi : u Ôëñ 10) :
    H.N u = 0 :=
  H.noZerosBelow_gamma1 u hlo (lt_of_le_of_lt hhi H.gamma1_gt_10)

/-- Ô¡É **PROVED ÔÇö `S(u) = -NÔéÇ(u)` on `[2¤Ç, 10]` from `FirstZeroCertified`,**
since `S(u) = N(u) - NÔéÇ(u)` and `N(u) = 0` there. The caller supplies
the `S = N - NÔéÇ` definition as the `hS` argument. -/
theorem FirstZeroCertified.S_eq_neg_N0_on_2pi_10
    (H : FirstZeroCertified)
    (S : ÔäØ ÔåÆ ÔäØ)
    (hS : ÔêÇ u : ÔäØ, S u = H.N u - smoothZeroCountingN0 u)
    {u : ÔäØ} (hlo : 2 * Real.pi Ôëñ u) (hhi : u Ôëñ 10) :
    S u = -(smoothZeroCountingN0 u) := by
  rw [hS u, H.noZeros_on_2pi_10 hlo hhi]
  ring

-- ---------------------------------------------------------------------
-- CLX-D + CLX-E: FirstZeroDirectBandCertificate (slot)
-- ---------------------------------------------------------------------
-- Bypasses the `closedFormSErrorBoundCD` envelope (whose `8 + 18` IBP
-- constants inflate any `D` by ~17├ù, blocking even `D = 0.125` on
-- `[2¤Ç, 10]`). The `errorBound` field is a function `Ôäé ÔåÆ ÔäØ` so the
-- closed-form can target a concrete integral against `-NÔéÇ(u)` rather
-- than the generic `(C┬Àlog u + D)`-envelope expression.

/-- **First-zero direct-band model-margin certificate.** A slot for a
sharper error formula on a slab `[A, B] Ôèå [2¤Ç, ╬│Ôéü)`. The crucial
difference from `FiniteSlabModelMarginCertificate` is the
function-valued `errorBound : Ôäé ÔåÆ ÔäØ`, which can target a concrete
integral expression against `-NÔéÇ(u)` rather than the generic
`(C┬Àlog u + D)`-envelope. -/
structure FirstZeroDirectBandCertificate where
  A : ÔäØ
  B : ÔäØ
  gamma1 : ÔäØ
  A_ge_two_pi : 2 * Real.pi Ôëñ A
  A_le_B : A Ôëñ B
  B_lt_gamma1 : B < gamma1
  model : Ôäé ÔåÆ Ôäé
  errorBound : Ôäé ÔåÆ ÔäØ
  cert :
    ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
      A Ôëñ T ÔåÆ T Ôëñ B ÔåÆ
      0 < z.im ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        errorBound z Ôëñ -(model z).im

/-- Ô¡É **PROVED ÔÇö `FirstZeroDirectBandCertificate Ôƒ╣ ModelMarginLowerBound`**
for any probe in the certified slab. Same shape as the per-probe
projections on the other certificate structures. -/
noncomputable def FirstZeroDirectBandCertificate.atProbe
    (F : FirstZeroDirectBandCertificate)
    (z : Ôäé) (T : ÔäØ)
    (hAT : F.A Ôëñ T) (hTB : T Ôëñ F.B)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := F.errorBound z
  lowerBound_le := F.cert z T hAT hTB hy hreg

