/-! ### CW17: strip-restricted gap + local-finiteness layer -/

/-- Right gap for zeta zero heights inside the Backlund standard strip
`-1 вЙ§ Re ѕБ вЙ§ 2`.  Strip restriction makes the statement honest. -/
structure ZetaZeroHeightRightGapInBacklundStripInput : Prop where
  exists_gap :
    вИА T : вДЭ, (140 : вДЭ) вЙ§ T вЖТ
      вИГ ќµ : вДЭ, 0 < ќµ вИІ
        вИА ѕБ : вДВ,
          riemannZeta ѕБ = 0 вЖТ
          (-1 : вДЭ) вЙ§ ѕБ.re вЖТ
          ѕБ.re вЙ§ 2 вЖТ
          T < ѕБ.im вЖТ
          ѕБ.im вЙ§ T + ќµ вЖТ
          False

/-- Local finiteness of zeta zeros inside a Backlund strip window
`{ѕБ : -1 вЙ§ Re ѕБ вЙ§ 2, T < Im ѕБ вЙ§ T + 1}`. -/
structure ZetaZerosLocallyFiniteInBacklundStripInput : Prop where
  finite_window :
    вИА T : вДЭ, (140 : вДЭ) вЙ§ T вЖТ
      {ѕБ : вДВ |
        riemannZeta ѕБ = 0 вИІ
        (-1 : вДЭ) вЙ§ ѕБ.re вИІ ѕБ.re вЙ§ 2 вИІ
        T < ѕБ.im вИІ ѕБ.im вЙ§ T + 1}.Finite

/-- **CW17 вАФ local finiteness вЗТ right gap in the strip.**  Take the
minimum positive distance from `T` to any zero height in the finite
window; halve it (and cap at `1`) to produce an open right gap. -/
noncomputable def
    ZetaZerosLocallyFiniteInBacklundStripInput.toRightGapInStrip
    (F : ZetaZerosLocallyFiniteInBacklundStripInput) :
    ZetaZeroHeightRightGapInBacklundStripInput where
  exists_gap := by
    classical
    intro T hT
    set S : Set вДВ :=
      {ѕБ : вДВ | riemannZeta ѕБ = 0 вИІ (-1 : вДЭ) вЙ§ ѕБ.re вИІ ѕБ.re вЙ§ 2 вИІ
        T < ѕБ.im вИІ ѕБ.im вЙ§ T + 1} with hS_def
    have hfin : S.Finite := F.finite_window T hT
    by_cases hS_ne : S.Nonempty
    ¬Ј set gaps : Finset вДЭ :=
        hfin.toFinset.image (fun ѕБ : вДВ => ѕБ.im - T) with hgaps_def
      have hgaps_ne : gaps.Nonempty := by
        rcases hS_ne with вЯ®ѕБ, hѕБвЯ©
        refine вЯ®ѕБ.im - T, ?_вЯ©
        exact Finset.mem_image.mpr вЯ®ѕБ, hfin.mem_toFinset.mpr hѕБ, rflвЯ©
      set ќі : вДЭ := gaps.min' hgaps_ne with hќі_def
      have hќі_pos : 0 < ќі := by
        have hmem : ќі вИИ gaps := gaps.min'_mem hgaps_ne
        rcases Finset.mem_image.mp hmem with вЯ®ѕБ, hѕБmem, hѕБeqвЯ©
        have hѕБS : ѕБ вИИ S := hfin.mem_toFinset.mp hѕБmem
        have hT_lt : T < ѕБ.im := hѕБS.2.2.2.1
        linarith [hѕБeq]
      refine вЯ®min ќі 1 / 2, by positivity, ?_вЯ©
      intro ѕБ hzero hre1 hre2 him him_upper
      have hќµ_le_ќіhalf : min ќі 1 / 2 вЙ§ ќі / 2 := by
        have hm : min ќі 1 вЙ§ ќі := min_le_left _ _
        linarith
      have hќµ_le_one : min ќі 1 / 2 вЙ§ 1 := by
        have hm : min ќі 1 вЙ§ 1 := min_le_right _ _
        linarith
      have him_le_one : ѕБ.im вЙ§ T + 1 := by linarith
      have hѕБS : ѕБ вИИ S := вЯ®hzero, hre1, hre2, him, him_le_oneвЯ©
      have hgap_mem : ѕБ.im - T вИИ gaps :=
        Finset.mem_image.mpr вЯ®ѕБ, hfin.mem_toFinset.mpr hѕБS, rflвЯ©
      have hќі_le : ќі вЙ§ ѕБ.im - T := gaps.min'_le _ hgap_mem
      linarith
    ¬Ј refine вЯ®1, by norm_num, ?_вЯ©
      intro ѕБ hzero hre1 hre2 him him_upper
      exact hS_ne вЯ®ѕБ, hzero, hre1, hre2, him, him_upperвЯ©

/-- Strip-restricted gap вЖТ LC bridge.  Named anchor: turning a strip
gap into the count's right local constancy still requires unfolding the
certificate-based count machinery. -/
structure ZetaStripGapToLocalConstancyInput : Prop where
  bridge :
    ZetaZeroHeightRightGapInBacklundStripInput вЖТ
      ZetaWeightedZeroCountRightLocalConstancyInput

/-- **CW17 вАФ final theorem from numerical extraction + local finiteness
+ strip-gap вЖТ LC bridge.**

The count-side obligation is now reduced to:
- `F` : local finiteness of ќґ-zeros in a compact strip window
  (analytic isolated-zeros theorem specialized to a compact rectangle);
- `StripGapToLC` : certificate-count bridge from a geometric strip gap
  to right-local-constancy of the weighted count. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction_and_localFiniteZeros
    (E : BacklundNumericalExtractionInput)
    (F : ZetaZerosLocallyFiniteInBacklundStripInput)
    (StripGapToLC : ZetaStripGapToLocalConstancyInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
