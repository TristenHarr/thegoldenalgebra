/-- тнР **PROVED тАФ `smoothZeroCountingN0(14) тЙд 9/20`** (tightening of
┬зCCLXXXI's `_le_half` bound). Same proof technique: tangent at
`q = 2` via `Real.log_le_sub_one_of_pos` on `q/2`. The ┬зCCLXXXI proof
actually shows `NтВА(14) тЙд тИТ0.1918┬╖(7/╧А) + 7/8 < 0.4487`, which is
`< 9/20 = 0.45` (margin тЙИ 0.0013). -/
theorem smoothZeroCountingN0_at_14_le_nine_twentieth :
    smoothZeroCountingN0 14 тЙд (9 / 20 : тДЭ) := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  have h_eq : (14 : тДЭ) / (2 * Real.pi) = 7 / Real.pi := by ring
  rw [h_eq]
  have h_7pi_pos : 0 < 7 / Real.pi := by positivity
  have h_7pi_nn : 0 тЙд 7 / Real.pi := le_of_lt h_7pi_pos
  have h_7pi_lt : 7 / Real.pi < 2.23 := by
    rw [div_lt_iffтВА h_pi_pos]; linarith
  have h_7pi_gt : (2.222 : тДЭ) < 7 / Real.pi := by
    rw [lt_div_iffтВА h_pi_pos]; linarith
  have h_7pi_half_pos : 0 < 7 / Real.pi / 2 := by linarith
  have h_log_qhalf_le : Real.log (7 / Real.pi / 2) тЙд 7 / Real.pi / 2 - 1 :=
    Real.log_le_sub_one_of_pos h_7pi_half_pos
  have h_log_div : Real.log (7 / Real.pi / 2)
                = Real.log (7 / Real.pi) - Real.log 2 :=
    Real.log_div (ne_of_gt h_7pi_pos) (by norm_num : (2 : тДЭ) тЙа 0)
  have h_log_q_bound :
      Real.log (7 / Real.pi) тЙд Real.log 2 + 7 / Real.pi / 2 - 1 := by
    linarith
  have h_log2_lt : Real.log 2 тЙд 0.6932 := by
    have := Real.log_two_lt_d9
    linarith
  have h_mul1 : (7 / Real.pi) * Real.log (7 / Real.pi)
              тЙд (7 / Real.pi) * (Real.log 2 + 7 / Real.pi / 2 - 1) :=
    mul_le_mul_of_nonneg_left h_log_q_bound h_7pi_nn
  have h_mul2 : (7 / Real.pi) * Real.log 2 тЙд (7 / Real.pi) * 0.6932 :=
    mul_le_mul_of_nonneg_left h_log2_lt h_7pi_nn
  have h_qsq : (7 / Real.pi) * (7 / Real.pi) тЙд (7 / Real.pi) * 2.23 :=
    mul_le_mul_of_nonneg_left h_7pi_lt.le h_7pi_nn
  nlinarith [h_mul1, h_mul2, h_qsq, h_7pi_lt, h_7pi_gt, h_7pi_pos]

/-- тнР **PROVED тАФ `smoothZeroCountingN0(10) тЙе -1/20`** via the Pad├й
lower bound `Real.le_log_one_add_of_nonneg`:
`2x/(x+2) тЙд log(1+x)` with `x := (5-╧А)/╧А тЙе 0` gives
`log(5/╧А) тЙе 2(5-╧А)/(5+╧А)`, hence
`(5/╧А)┬╖log(5/╧А) тЙе 10(5-╧А)/(╧А(5+╧А))`. Clearing denominators reduces
to `37╧А┬▓ тИТ 415╧А + 1000 тЙе 0` on `╧А тИИ (3.14, 3.15)`, which holds with
margin тЙИ 60. Numerically `NтВА(10) тЙИ 0.023 тЙе -0.05`. -/
theorem smoothZeroCountingN0_at_10_ge_neg_one_twentieth :
    -(1 / 20 : тДЭ) тЙд smoothZeroCountingN0 10 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  have h_eq : (10 : тДЭ) / (2 * Real.pi) = 5 / Real.pi := by ring
  rw [h_eq]
  have h_5_lt_pi : Real.pi < 5 := by linarith
  have h_5pi_pos : 0 < 5 / Real.pi := by positivity
  -- x := (5 - ╧А) / ╧А тЙе 0
  have h_x_nn : (0 : тДЭ) тЙд (5 - Real.pi) / Real.pi := by
    apply div_nonneg
    ┬╖ linarith
    ┬╖ exact le_of_lt h_pi_pos
  -- 1 + x = 5/╧А
  have h_one_add : 1 + (5 - Real.pi) / Real.pi = 5 / Real.pi := by
    field_simp
  -- Pad├й: log(5/╧А) тЙе 2x/(x+2) = 2(5-╧А)/(5+╧А)
  have h_pade_raw :
      2 * ((5 - Real.pi) / Real.pi) / ((5 - Real.pi) / Real.pi + 2)
        тЙд Real.log (1 + (5 - Real.pi) / Real.pi) :=
    Real.le_log_one_add_of_nonneg h_x_nn
  rw [h_one_add] at h_pade_raw
  -- Setup nonzero hypotheses and the polynomial-form Pad├й bound
  have h_5_plus_pi_pos : (0 : тДЭ) < 5 + Real.pi := by linarith
  have h╧А_ne : Real.pi тЙа 0 := ne_of_gt h_pi_pos
  have h5p╧А_ne : (5 + Real.pi : тДЭ) тЙа 0 := ne_of_gt h_5_plus_pi_pos
  have h_inner_pos : (0 : тДЭ) < (5 - Real.pi) / Real.pi + 2 := by positivity
  have h_inner_ne : ((5 - Real.pi) / Real.pi + 2) тЙа 0 := ne_of_gt h_inner_pos
  -- Step 1: clear outer division by multiplying by ((5-╧А)/╧А + 2)
  have h_pade_step1 :
      2 * ((5 - Real.pi) / Real.pi)
        тЙд ((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_right h_pade_raw (le_of_lt h_inner_pos)
    rw [div_mul_cancelтВА _ h_inner_ne] at h
    linarith
  -- Step 2: multiply by ╧А to clear inner /╧А
  -- ╧А ┬╖ 2((5-╧А)/╧А) = 2(5-╧А); ╧А ┬╖ ((5-╧А)/╧А + 2) = (5-╧А) + 2╧А = 5+╧А
  have h_pade_poly :
      2 * (5 - Real.pi) тЙд (5 + Real.pi) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_left h_pade_step1 (le_of_lt h_pi_pos)
    have hl : Real.pi * (2 * ((5 - Real.pi) / Real.pi)) = 2 * (5 - Real.pi) := by
      field_simp
    have h_factor :
        Real.pi * ((5 - Real.pi) / Real.pi + 2) = 5 + Real.pi := by
      field_simp; ring
    have hr :
        Real.pi * (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
          = (5 + Real.pi) * Real.log (5 / Real.pi) := by
      rw [show Real.pi *
            (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
            = (Real.pi * ((5 - Real.pi) / Real.pi + 2))
                * Real.log (5 / Real.pi) from by ring,
          h_factor]
    linarith [h, hl.symm.le, hl.le, hr.le, hr.symm.le]
  -- Step 3: polynomial inequality from ╧А bounds тАФ `(200-37╧А)(5+╧А) тЙд 400(5-╧А)`
  -- equivalently `37╧А┬▓ - 415╧А + 1000 тЙе 0` (margin тЙИ 60 on (3.14, 3.15))
  have h_polyq :
      (200 - 37 * Real.pi) * (5 + Real.pi) тЙд 400 * (5 - Real.pi) := by
    nlinarith [h_pi_lt, h_pi_gt, sq_nonneg (Real.pi - 3.14),
               sq_nonneg (3.15 - Real.pi)]
  -- Step 4: chain via h_pade_poly ┬╖ 200: 200┬╖(5+╧А)┬╖log(5/╧А) тЙе 400(5-╧А) тЙе (200-37╧А)(5+╧А)
  have h_chain :
      (200 - 37 * Real.pi) * (5 + Real.pi)
        тЙд 200 * ((5 + Real.pi) * Real.log (5 / Real.pi)) := by
    have := mul_le_mul_of_nonneg_left h_pade_poly (by norm_num : (0 : тДЭ) тЙд 200)
    linarith
  -- Step 5: divide by (5+╧А) > 0: 200 - 37╧А тЙд 200┬╖log(5/╧А)
  have h_200_log :
      200 - 37 * Real.pi тЙд 200 * Real.log (5 / Real.pi) := by
    by_contra hneg
    push_neg at hneg
    have h_mul := mul_lt_mul_of_pos_right hneg h_5_plus_pi_pos
    have h_assoc :
        200 * Real.log (5 / Real.pi) * (5 + Real.pi)
          = 200 * ((5 + Real.pi) * Real.log (5 / Real.pi)) := by ring
    rw [h_assoc] at h_mul
    linarith
  -- Step 6: derive goal by multiplying 1/(40╧А) to scale to (5/╧А)┬╖log(5/╧А)
  -- Equivalently: 0 тЙд 200┬╖log(5/╧А) - 200 + 37╧А (from h_200_log + linarith)
  have h_target_poly :
      (0 : тДЭ) тЙд 200 * Real.log (5 / Real.pi) - 200 + 37 * Real.pi := by
    linarith
  -- Scale by 1/(40╧А) > 0 to convert to goal form
  have h_inv_pos : (0 : тДЭ) < 1 / (40 * Real.pi) := by positivity
  have h_scaled := mul_le_mul_of_nonneg_left h_target_poly (le_of_lt h_inv_pos)
  rw [mul_zero] at h_scaled
  -- Simplify 1/(40╧А) ┬╖ (200┬╖log(5/╧А) - 200 + 37╧А) = (5/╧А)┬╖log(5/╧А) - 5/╧А + 37/40
  have h_lhs_eq :
      (1 / (40 * Real.pi))
        * (200 * Real.log (5 / Real.pi) - 200 + 37 * Real.pi)
        = (5 / Real.pi) * Real.log (5 / Real.pi) - 5 / Real.pi + 37 / 40 := by
    field_simp
    ring
  rw [h_lhs_eq] at h_scaled
  -- 37/40 = 7/8 + 1/20, so the goal follows by linarith
  linarith

