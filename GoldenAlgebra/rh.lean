--   LowHighBandData.toCoverData                        вАФ bridge
--   XiPullbackAntiHerglotzTarget_of_XiActualTailDecompositionData_lowHigh
--                                                      вАФ clean front door

/-- рЯУ¶ **`LowHighBandData`** вАФ explicit low/high band coverage.
Replaces the abstract `extras : вДХ вЖТ LocalXiCloudDensityErrorPackage`
with two named packages and a three-way cover (mid / low / high). -/
structure LowHighBandData where
  lowPackage  : LocalXiCloudDensityErrorPackage
  highPackage : LocalXiCloudDensityErrorPackage
  covers :
    вИА z : вДВ, 0 < z.im вЖТ
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вИ®
      lowPackage.region z вИ®
      highPackage.region z

/-- рЯМЯ **PROVED вАФ `LowHighBandData.toCoverData`.** Bridge to the existing
abstract `LowHighBandCoverData`. Uses `extras 0 := lowPackage`,
`extras (n+1) := highPackage`. -/
noncomputable def LowHighBandData.toCoverData
    (B : LowHighBandData) : LowHighBandCoverData where
  extras := fun n => if n = 0 then B.lowPackage else B.highPackage
  covers := by
    intro z hz
    rcases B.covers z hz with hmid | hlow | hhigh
    ¬Ј exact Or.inl hmid
    ¬Ј refine Or.inr вЯ®0, ?_вЯ©
      show (if (0 : вДХ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hlow
    ¬Ј refine Or.inr вЯ®1, ?_вЯ©
      show (if (1 : вДХ) = 0 then B.lowPackage else B.highPackage).region z
      simp
      exact hhigh

