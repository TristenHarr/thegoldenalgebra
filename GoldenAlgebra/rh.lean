/-- рЯУ¶ **`EntireXiToCompletedXiLogDerivBridge`** вАФ quarantines the
ќУ-pole/zero cancellation in a single named Prop. -/
structure EntireXiToCompletedXiLogDerivBridge : Prop where
  entire_nonzero_of_completed_nonzero :
    вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ entireRiemannXi s вЙ† 0
  completed_differentiable_at_nonzero :
    вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ
      DifferentiableAt вДВ completedXiFunction s
  logDeriv_completed_eq_entire :
    вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ
