-- =====================================================================
-- ¬ІCCXXXIV. Xi log-derivative decomposition packaging
-- =====================================================================
-- Splits the opaque `hdecomp` field of `XiActualTailDecompositionData`
-- into the three analytic pieces actually expected from the xi
-- log-derivative formula:
--   вАҐ finite real-zero cloud
--   вАҐ smooth density tail model
--   вАҐ fluctuation/error tail
-- The model `M.model` equals (cloud + smooth tail), and `error` equals
-- the fluctuation tail. The unpacked `xi_decomp` field is exactly the
-- theorem an analytic prover wants to discharge.
--
-- Adds:
--   XiLogDerivativeDecompositionPieces                  вАФ three-piece bundle
--   hdecomp_of_XiLogDerivativeDecompositionPieces       вАФ bridge to hdecomp
--   XiActualTailDecompositionData.ofPieces              вАФ clean constructor

/-- рЯУ¶ **`XiLogDerivativeDecompositionPieces M error`** вАФ three-piece
unpacking of the xi log-derivative decomposition:

* `finiteCloudPart` вАФ the finite real-zero cloud sum;
* `smoothTailPart` вАФ the smooth density-tail model;
* `fluctTailPart` вАФ the residual fluctuation tail;
* `model_eq` вАФ `M.model = finiteCloudPart + smoothTailPart`;
* `error_eq` вАФ `error = fluctTailPart`;
* `xi_decomp` вАФ `ќЫ[ќЮ] z = finiteCloudPart z + smoothTailPart z + fluctTailPart z`
  on the adaptive band.

This is the natural shape produced by an actual xi log-derivative
formula. The `hdecomp` field of `XiActualTailDecompositionData` then
follows by associativity (see `hdecomp_of_XiLogDerivativeDecompositionPieces`). -/
structure XiLogDerivativeDecompositionPieces
    (M : CloudDensityTailModelDecomposition)
    (error : вДВ вЖТ вДВ) where
  finiteCloudPart : вДВ вЖТ вДВ
  smoothTailPart  : вДВ вЖТ вДВ
  fluctTailPart   : вДВ вЖТ вДВ
  model_eq :
    вИА z : вДВ, M.model z = finiteCloudPart z + smoothTailPart z
  error_eq :
    вИА z : вДВ, error z = fluctTailPart z
  xi_decomp :
    вИА z : вДВ,
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
      logDerivativeResponse XiPullback z =
        finiteCloudPart z + smoothTailPart z + fluctTailPart z

/-- рЯМЯрЯМЯ **PROVED вАФ `hdecomp` from three-piece decomposition.**
Combines `model_eq`, `error_eq`, `xi_decomp` via associativity. -/
theorem hdecomp_of_XiLogDerivativeDecompositionPieces
    {M : CloudDensityTailModelDecomposition} {error : вДВ вЖТ вДВ}
    (P : XiLogDerivativeDecompositionPieces M error) :
    вИА z : вДВ,
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
      logDerivativeResponse XiPullback z = M.model z + error z := by
  intro z hz
  rw [P.model_eq z, P.error_eq z]
  exact P.xi_decomp z hz

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `XiActualTailDecompositionData` from the
three-piece decomposition.** End-to-end constructor: takes the
`Model`, `error`, three-piece `P`, and the `herror` Im-identity;
produces the full `XiActualTailDecompositionData`. Discharges
`hdecomp` automatically via `hdecomp_of_XiLogDerivativeDecompositionPieces`. -/
noncomputable def XiActualTailDecompositionData.ofPieces
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : вДВ вЖТ вДВ)
    (P : XiLogDerivativeDecompositionPieces Model.M error)
    (herror :
      вИА {z : вДВ} {T : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        (error z).im =
          (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im) :
    XiActualTailDecompositionData Dzero T0 hT0_pos hT0_le_10 hTuring where
  Model   := Model
  error   := error
  hdecomp := hdecomp_of_XiLogDerivativeDecompositionPieces P
  herror  := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime

-- =====================================================================
-- ¬ІCCXXXV. Smooth density tail model + anti-Herglotz closure
-- =====================================================================
-- Reduces `SmoothDensityTailModelData.tailAnti` to: a partial-integral
-- definition of the smooth tail at finite cutoffs `[T, X]`, an eventual
-- anti-Herglotz property of those partials, and pointwise convergence
-- of the partials to a candidate tail. The limit closure follows from
-- the fact that `AntiHerglotzUHP R := вИА z (hz : 0 < z.im), (R z).im вЙ§ 0`
-- is a pointwise sign condition closed under pointwise limits.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto     вАФ reusable closure
--   smoothDensityTailModelPartial                     вАФ finite partial def
--   SmoothDensityTailModelConverges                   вАФ convergence package
--   SmoothDensityTailFiniteAntiData                   вАФ finite anti-Herglotz
--   smoothDensityTailModelData_of_converges           вАФ assembled tailModel

/-- рЯМЯрЯМЯ **PROVED вАФ `AntiHerglotzUHP` closes under eventual pointwise
limits.** If `F X` is eventually anti-Herglotz and `F X z вЖТ f z`
pointwise, then `f` is anti-Herglotz. This is a pure order/topology
lemma: the imaginary part is continuous, so `(F X z).im вЙ§ 0`
eventually transfers to `(f z).im вЙ§ 0` via `le_of_tendsto_of_tendsto`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto
    {F : вДЭ вЖТ вДВ вЖТ вДВ} {f : вДВ вЖТ вДВ}
    (hF : вИАбґ† X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : вИА z, Tendsto (fun X => F X z) Filter.atTop (рЭУЭ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto : Tendsto (fun X => (F X z).im) Filter.atTop (рЭУЭ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z)
  have hF_im_le : вИАбґ† X in Filter.atTop, (F X z).im вЙ§ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **Smooth density tail partial.** Finite `[T, X]` integral of
`ѕБ(u) ¬Ј (1/(z-u) + 1/(z+u))`. -/
noncomputable def smoothDensityTailModelPartial
    (ѕБ : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДВ вЖТ вДВ :=
  fun z : вДВ =>
    вИЂ u in T..X,
      ((ѕБ u : вДВ) *
        ((1 : вДВ) / (z - (u : вДВ)) +
         (1 : вДВ) / (z + (u : вДВ))))

/-- **Smooth density tail convergence package.** Bundles a candidate
`tailModel : вДВ вЖТ вДВ` with pointwise convergence of the finite partials
as `X вЖТ вИЮ`. -/
structure SmoothDensityTailModelConverges
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) where
  tailModel : вДВ вЖТ вДВ
  tendsto   : вИА z : вДВ,
    Tendsto
      (fun X : вДЭ => smoothDensityTailModelPartial ѕБ T X z)
      Filter.atTop (рЭУЭ (tailModel z))

/-- **Smooth density tail finite-window anti-Herglotz data.** Asserts
that each finite partial `smoothDensityTailModelPartial ѕБ T X` is
anti-Herglotz (for `X вЙ• T`). This is the analytic obligation a Lean
proof of the integral identity must discharge вАФ for a nonnegative
density `ѕБ` and a paired Cauchy kernel, this follows by linearity of
the integral and pointwise anti-Herglotz of each `(1/(z-u) + 1/(z+u))`. -/
structure SmoothDensityTailFiniteAntiData
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) : Prop where
  finiteAnti :
    вИА X, T вЙ§ X вЖТ AntiHerglotzUHP (smoothDensityTailModelPartial ѕБ T X)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelData` from finite-partial
data + convergence.** Composes the ¬ІCCXXXV closure theorem with the
finite-anti-Herglotz hypothesis (restricted to `X вЙ• T` via
`Filter.eventually_ge_atTop`). -/
noncomputable def smoothDensityTailModelData_of_converges
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (C : SmoothDensityTailModelConverges ѕБ T)
    (Hfinite : SmoothDensityTailFiniteAntiData ѕБ T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto
      (F := fun X => smoothDensityTailModelPartial ѕБ T X)
    ¬Ј filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ¬Ј exact C.tendsto

-- =====================================================================
-- ¬ІCCXXXVI. Finite smooth-density partial anti-Herglotz from ѕБ вЙ• 0
-- =====================================================================
-- Discharges `SmoothDensityTailFiniteAntiData` for any nonnegative
-- density `ѕБ`:
--   вАҐ each `(1/(z-u) + 1/(z+u))` has Im вЙ§ 0 on UHP (existing
--     `pairedCauchyKernel_im_nonpos_at` from ¬І12-C);
--   вАҐ multiplied by `(ѕБ u : вДВ)` with `ѕБ u вЙ• 0`, the integrand Im вЙ§ 0;
--   вАҐ integrating preserves the sign (Im commutes with the integral
--     via `Complex.imCLM.intervalIntegral_comp_comm`, then
--     `intervalIntegral.integral_nonneg` applied to the negation).
--
-- Adds:
--   smoothDensityTail_integrand_im_nonpos
--   smoothDensityTailModelPartial_im_nonpos
--   smoothDensityTailFiniteAntiData_of_nonneg

/-- в≠Р **PROVED вАФ smooth density integrand has Im вЙ§ 0 on UHP.**
For `ѕБ u вЙ• 0` and `z.im > 0`:
  `Im[(ѕБ u : вДВ) ¬Ј (1/(z-u) + 1/(z+u))] = ѕБ u ¬Ј Im[вА¶] вЙ§ 0`. -/
lemma smoothDensityTail_integrand_im_nonpos
    (ѕБ : вДЭ вЖТ вДЭ) (T u : вДЭ) {z : вДВ}
    (hTu : T вЙ§ u)
    (hѕБ : вИА v, T вЙ§ v вЖТ 0 вЙ§ ѕБ v)
    (hz : 0 < z.im) :
    (((ѕБ u : вДВ) *
        ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im) вЙ§ 0 := by
  have hѕБu : 0 вЙ§ ѕБ u := hѕБ u hTu
  -- The paired kernel at z is exactly `pairedCauchyKernel u z`.
  have hk_eq : (1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))
             = pairedCauchyKernel u z := rfl
  have hk : ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))).im вЙ§ 0 := by
    rw [hk_eq]
    exact pairedCauchyKernel_im_nonpos_at z u hz
  -- Im of (real : вДВ) ¬Ј w = real ¬Ј w.im
  have him_eq :
      (((ѕБ u : вДВ) *
        ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im)
        = ѕБ u * ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))).im := by
    simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
  rw [him_eq]
  exact mul_nonpos_of_nonneg_of_nonpos hѕБu hk

/-- рЯМЯрЯМЯ **PROVED вАФ `(smoothDensityTailModelPartial ѕБ T X z).im вЙ§ 0`**
for `T вЙ§ X`, `0 < z.im`, and `ѕБ вЙ• 0` on `[T, вИЮ)`. Routes Im through
the integral via `Complex.imCLM.intervalIntegral_comp_comm`, then
applies `intervalIntegral.integral_nonneg` to the negation. -/
lemma smoothDensityTailModelPartial_im_nonpos
    (ѕБ : вДЭ вЖТ вДЭ) (T X : вДЭ) {z : вДВ}
    (hTX : T вЙ§ X) (hz : 0 < z.im)
    (hѕБ_nonneg : вИА u, T вЙ§ u вЖТ 0 вЙ§ ѕБ u)
    (hInt :
      IntervalIntegrable
        (fun u =>
          (ѕБ u : вДВ) *
            ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
        MeasureTheory.volume T X) :
    (smoothDensityTailModelPartial ѕБ T X z).im вЙ§ 0 := by
  unfold smoothDensityTailModelPartial
  -- Pull `.im` inside the integral via Complex.imCLM commutation
  have h_imCLM_comm := Complex.imCLM.intervalIntegral_comp_comm
    (ќЉ := MeasureTheory.volume) (a := T) (b := X) hInt
  -- Both sides written with Complex.imCLM, then simp to .im
  have him_eq :
      (вИЂ u in T..X,
        (ѕБ u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im
        =
      вИЂ u in T..X,
        ((ѕБ u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im := by
    simpa [Complex.imCLM_apply] using h_imCLM_comm.symm
  rw [him_eq]
  -- Apply nonnegativity to the negation
  have h_neg_nonneg :
      0 вЙ§ вИЂ u in T..X,
        -(((ѕБ u : вДВ) *
            ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im) := by
    apply intervalIntegral.integral_nonneg hTX
    intro u hu
    have hTu : T вЙ§ u := hu.1
    have hpt := smoothDensityTail_integrand_im_nonpos ѕБ T u hTu hѕБ_nonneg hz
    linarith
  have h_int_neg :
      (вИЂ u in T..X,
        -(((ѕБ u : вДВ) *
            ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im))
        =
      -(вИЂ u in T..X,
        ((ѕБ u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))).im) :=
    intervalIntegral.integral_neg
  linarith

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailFiniteAntiData` from
nonnegative ѕБ + finite-window integrability.** Each finite partial
`smoothDensityTailModelPartial ѕБ T X` is anti-Herglotz on UHP. -/
theorem smoothDensityTailFiniteAntiData_of_nonneg
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (hѕБ_nonneg : вИА u, T вЙ§ u вЖТ 0 вЙ§ ѕБ u)
    (hInt :
      вИА X z, T вЙ§ X вЖТ 0 < z.im вЖТ
        IntervalIntegrable
          (fun u =>
            (ѕБ u : вДВ) *
              ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailFiniteAntiData ѕБ T where
  finiteAnti := by
    intro X hTX z hz
    exact smoothDensityTailModelPartial_im_nonpos
      ѕБ T X hTX hz hѕБ_nonneg (hInt X z hTX hz)

-- =====================================================================
-- ¬ІCCXXXVII. Smooth density tail convergence from a norm majorant
-- =====================================================================
-- Discharges `SmoothDensityTailModelConverges ѕБ T` from a real-valued
-- pointwise majorant whose improper integral converges. Routes through
-- ¬ІCCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   SmoothDensityTailMajorantData                       вАФ majorant bundle
--   smoothDensityTailModel_converges_at                 вАФ pointwise existence
--   smoothDensityTailModelConverges_of_majorant         вАФ adaptive package
--   smoothDensityTailModelData_of_majorant_nonneg       вАФ full SmoothTail data

/-- рЯУ¶ **`SmoothDensityTailMajorantData ѕБ T`** вАФ bundles the analytic
input needed to apply `improperComplexIntegralConverges_of_normMajorant`
to the smooth density integrand `(ѕБ u : вДВ) ¬Ј (1/(z-u) + 1/(z+u))`:

* `majorant z u` вАФ real majorant function (typically `O(log u / u¬≤)`);
* `majorant_intervalIntegrable` вАФ finite-window integrability;
* `majorant_converges` вАФ improper integral converges;
* `integrand_intervalIntegrable` вАФ finite-window integrability of the
  complex integrand;
* `norm_bound_eventually` вАФ `вАЦintegrandвАЦ вЙ§ majorant z u` eventually. -/
structure SmoothDensityTailMajorantData
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) where
  majorant : вДВ вЖТ вДЭ вЖТ вДЭ
  majorant_intervalIntegrable :
    вИА z X, T вЙ§ X вЖТ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    вИА z, вИГ L : вДЭ,
      Tendsto (fun X : вДЭ => вИЂ u in T..X, majorant z u)
        Filter.atTop (рЭУЭ L)
  integrand_intervalIntegrable :
    вИА z X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          (ѕБ u : вДВ) *
            ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    вИА z, вИАбґ† u in Filter.atTop,
      вАЦ(ѕБ u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))вАЦ
        вЙ§ majorant z u

/-- рЯМЯрЯМЯ **PROVED вАФ pointwise smooth tail convergence from majorant.**
At each `z`, the smooth density partials converge as `X вЖТ вИЮ`. -/
theorem smoothDensityTailModel_converges_at
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (H : SmoothDensityTailMajorantData ѕБ T) (z : вДВ) :
    вИГ L : вДВ,
      Tendsto
        (fun X : вДЭ => smoothDensityTailModelPartial ѕБ T X z)
        Filter.atTop (рЭУЭ L) := by
  rcases H.majorant_converges z with вЯ®LM, hLMвЯ©
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (ѕБ u : вДВ) *
        ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hTX)
    hLM
    (H.norm_bound_eventually z)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelConverges` from majorant
data.** Uses `Classical.choose` on the pointwise existence theorem. -/
noncomputable def smoothDensityTailModelConverges_of_majorant
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (H : SmoothDensityTailMajorantData ѕБ T) :
    SmoothDensityTailModelConverges ѕБ T where
  tailModel := fun z =>
    Classical.choose (smoothDensityTailModel_converges_at ѕБ T H z)
  tendsto := fun z =>
    Classical.choose_spec (smoothDensityTailModel_converges_at ѕБ T H z)

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelData` from `ѕБ вЙ• 0` +
norm majorant.** End-to-end constructor: nonnegative density + complex
majorant data вЯє full smooth-tail model data (including
anti-Herglotz). Composes ¬ІCCXXXVI's finite-anti discharger with
¬ІCCXXXVII's convergence theorem. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (hѕБ_nonneg : вИА u, T вЙ§ u вЖТ 0 вЙ§ ѕБ u)
    (H : SmoothDensityTailMajorantData ѕБ T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges ѕБ T
    (smoothDensityTailModelConverges_of_majorant ѕБ T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ѕБ T hѕБ_nonneg
      (fun X z hTX _hz => H.integrand_intervalIntegrable z X hTX))

-- =====================================================================
-- ¬ІCCXXXVIII. Smooth density majorant from log-growth + paired kernel
-- =====================================================================
-- Provides a real theorem-producing bridge: a log-growth bound on `|ѕБ|`
-- plus the paired-Cauchy kernel cancellation `1/(z-u) + 1/(z+u) =
-- 2z/(z¬≤ - u¬≤)` gives a `1/u¬≤` decay on the kernel norm, hence a
-- log-over-`u¬≤` majorant for the smooth density integrand. Combined
-- with ¬ІCCXXIX-4a's `trueKernelLogMajorant` machinery, this discharges
-- `SmoothDensityTailMajorantData ѕБ T`.
--
-- Adds:
--   norm_pairedCauchyKernel_le_const_div_sq_eventually
--     вАФ `вАЦ1/(z-u) + 1/(z+u)вАЦ вЙ§ 4(вАЦzвАЦ+1)/u¬≤` for `u` eventually large
--   smoothDensityTailMajorantData_of_logGrowth
--     вАФ full constructor with explicit log envelope on `|ѕБ|`

/-- рЯМЯрЯМЯ **PROVED вАФ paired Cauchy kernel norm `1/u¬≤` decay.** For each
fixed `z`, eventually `вАЦ1/(z-u) + 1/(z+u)вАЦ вЙ§ 4(вАЦzвАЦ+1)/u¬≤`. Proof: use
the cancellation identity `1/(z-u) + 1/(z+u) = 2z/(z¬≤-u¬≤)` (existing
`pairedCauchyKernel_eq_two_mul`), bound `вАЦz¬≤ - u¬≤вАЦ вЙ• u¬≤/2` for `u`
large via reverse triangle, and conclude. -/
lemma norm_pairedCauchyKernel_le_const_div_sq_eventually
    (z : вДВ) :
    вИАбґ† u : вДЭ in Filter.atTop,
      вАЦ(1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))вАЦ
        вЙ§ 4 * (вАЦzвАЦ + 1) / u^2 := by
  filter_upwards
    [Filter.eventually_ge_atTop (2 * (вАЦzвАЦ + 1)),
     Filter.eventually_gt_atTop (0 : вДЭ)]
    with u hu_large hu_pos
  have h_z_nn : 0 вЙ§ вАЦzвАЦ := norm_nonneg z
  have h_u_pos_sq : 0 < u^2 := by positivity
  have h_2_zp1_nn : (0 : вДЭ) вЙ§ 2 * (вАЦzвАЦ + 1) := by linarith
  have h_u_sq_ge : (2 * (вАЦzвАЦ + 1))^2 вЙ§ u^2 := by
    have := mul_self_le_mul_self h_2_zp1_nn hu_large
    nlinarith [this]
  have h_diff_bound : u^2 / 2 вЙ§ u^2 - вАЦzвАЦ^2 := by
    nlinarith [h_u_sq_ge, h_z_nn]
  have h_norm_u_sq : вАЦ((u : вДВ))^2вАЦ = u^2 := by
    have h_pow : ((u : вДВ))^2 = ((u^2 : вДЭ) : вДВ) := by push_cast; ring
    rw [h_pow, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (sq_nonneg u)]
  have h_norm_z_sq : вАЦz^2вАЦ = вАЦzвАЦ^2 := by
    rw [pow_two, pow_two, norm_mul]
  have h_rev_tri : u^2 - вАЦzвАЦ^2 вЙ§ вАЦz^2 - (u : вДВ)^2вАЦ := by
    have h := norm_sub_norm_le ((u : вДВ)^2) (z^2)
    rw [h_norm_u_sq, h_norm_z_sq, вЖР norm_sub_rev] at h
    exact h
  have h_diff_lower : u^2 / 2 вЙ§ вАЦz^2 - (u : вДВ)^2вАЦ :=
    le_trans h_diff_bound h_rev_tri
  have h_u_half_pos : 0 < u^2 / 2 := by linarith
  have h_diff_norm_pos : 0 < вАЦz^2 - (u : вДВ)^2вАЦ :=
    lt_of_lt_of_le h_u_half_pos h_diff_lower
  have h_diff_ne : z^2 - (u : вДВ)^2 вЙ† 0 := norm_pos_iff.mp h_diff_norm_pos
  have h_z_sq_ne : z^2 вЙ† (u : вДВ)^2 := sub_ne_zero.mp h_diff_ne
  have h_kernel_eq :
      (1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))
        = 2 * z / (z^2 - (u : вДВ)^2) := by
    have := pairedCauchyKernel_eq_two_mul u z h_z_sq_ne
    unfold pairedCauchyKernel at this
    exact this
  rw [h_kernel_eq, norm_div]
  have h_num_norm : вАЦ(2 : вДВ) * zвАЦ = 2 * вАЦzвАЦ := by
    rw [norm_mul]; simp
  rw [h_num_norm]
  have h_2z_nn : 0 вЙ§ 2 * вАЦzвАЦ := by linarith
  calc 2 * вАЦzвАЦ / вАЦz^2 - (u : вДВ)^2вАЦ
      вЙ§ 2 * вАЦzвАЦ / (u^2 / 2) :=
        div_le_div_of_nonneg_left h_2z_nn h_u_half_pos h_diff_lower
    _ = 4 * вАЦzвАЦ / u^2 := by field_simp; ring
    _ вЙ§ 4 * (вАЦzвАЦ + 1) / u^2 := by
        gcongr
        linarith

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailMajorantData` from log growth.**
Given a log envelope `|ѕБ u| вЙ§ A log u + B` and finite-window
integrability of the integrand, produces the full majorant bundle.
The constructed majorant is
`majorant z u := trueKernelLogMajorant ((вАЦzвАЦ+1)¬ЈA/2) ((вАЦzвАЦ+1)¬ЈB/2) u`
= `4(вАЦzвАЦ+1)¬Ј(A log u + B)/u¬≤`. -/
noncomputable def smoothDensityTailMajorantData_of_logGrowth
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) (A B : вДЭ)
    (_hA_nn : 0 вЙ§ A) (_hB_nn : 0 вЙ§ B)
    (hTpos : 0 < T)
    (hѕБ_bound : вИАбґ† u in Filter.atTop, |ѕБ u| вЙ§ A * Real.log u + B)
    (hѕБ_int :
      вИА z X, T вЙ§ X вЖТ
        IntervalIntegrable
          (fun u =>
            (ѕБ u : вДВ) *
              ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantData ѕБ T where
  majorant := fun z u =>
    trueKernelLogMajorant ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z
    refine вЯ®-trueKernelLogMajorantPrimitive
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T, ?_вЯ©
    exact trueKernelLogMajorantConverges
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := hѕБ_int
  norm_bound_eventually := by
    intro z
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, hѕБ_bound] with u hk hѕБu
    rw [norm_mul]
    have h_norm_ofReal : вАЦ(ѕБ u : вДВ)вАЦ = |ѕБ u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 вЙ§ A * Real.log u + B :=
      le_trans (abs_nonneg _) hѕБu
    calc |ѕБ u| * вАЦ(1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))вАЦ
        вЙ§ (A * Real.log u + B) * (4 * (вАЦzвАЦ + 1) / u^2) :=
          mul_le_mul hѕБu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- ¬ІCCXXXIX. `zeroDensityRho` log-growth bound
-- =====================================================================
-- Concrete deliverable for the `zeroDensityRho` density:
-- `|zeroDensityRho u| вЙ§ (1/(2ѕА)) ¬Ј log u` for `u вЙ• 2ѕА` (the positivity
-- threshold). This is exactly the `hѕБ_bound` field shape required by
-- ¬ІCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`.
--
-- Note: the full `SmoothDensityTailMajorantData` for `zeroDensityRho`
-- additionally requires per-`(z, X)` integrability of the integrand
-- `(zeroDensityRho u : вДВ) ¬Ј (1/(z-u) + 1/(z+u))`. That field is
-- universally quantified over `z` in the structure, but the kernel
-- has poles for real `z` lying in `[T, X]`, so integrability genuinely
-- fails there. A full instantiation would require either restricting
-- the structure to UHP `z` or providing the integrability as an
-- additional explicit hypothesis (deferred).
--
-- Adds:
--   zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
--   zeroDensityRho_log_growth_eventually

/-- в≠Р **PROVED вАФ `|zeroDensityRho u| вЙ§ (1/(2ѕА)) ¬Ј log u` for `u вЙ• 2ѕА`.**
For `u вЙ• 2ѕА`, `ѕБ u = (1/(2ѕА))¬Ј(log u - log(2ѕА)) вЙ• 0` and `log(2ѕА) вЙ• 0`
(since `2ѕА вЙ• 1`), so `|ѕБ u| = ѕБ u вЙ§ (1/(2ѕА)) log u`. -/
lemma zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
    {u : вДЭ} (hu : 2 * Real.pi вЙ§ u) :
    |zeroDensityRho u| вЙ§ (1 / (2 * Real.pi)) * Real.log u := by
  have h_nn : 0 вЙ§ zeroDensityRho u := zeroDensityRho_nonneg_of_ge_two_pi hu
  rw [abs_of_nonneg h_nn]
  unfold zeroDensityRho
  have h2pi_pos : (0 : вДЭ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : вДЭ) вЙ§ 1 / (2 * Real.pi) := by positivity
  have h2pi_ge_one : (1 : вДЭ) вЙ§ 2 * Real.pi := by
    have := Real.pi_gt_three
    linarith
  have h_log_2pi_nn : 0 вЙ§ Real.log (2 * Real.pi) := Real.log_nonneg h2pi_ge_one
  have h_log_eq : Real.log (u / (2 * Real.pi))
                  = Real.log u - Real.log (2 * Real.pi) := by
    have h_u_pos : 0 < u := lt_of_lt_of_le h2pi_pos hu
    rw [Real.log_div (ne_of_gt h_u_pos) (ne_of_gt h2pi_pos)]
  rw [h_log_eq]
  -- (1/(2ѕА)) * (log u - log(2ѕА)) вЙ§ (1/(2ѕА)) * log u
  -- since -(1/(2ѕА)) * log(2ѕА) вЙ§ 0
  have h_diff_nn :
      (1 / (2 * Real.pi)) * Real.log u -
        (1 / (2 * Real.pi)) * (Real.log u - Real.log (2 * Real.pi))
        = (1 / (2 * Real.pi)) * Real.log (2 * Real.pi) := by ring
  nlinarith [mul_nonneg h2pi_inv_nn h_log_2pi_nn]

/-- в≠Р **PROVED вАФ eventual log-growth bound for `zeroDensityRho`.**
For `A := 1/(2ѕА)`, `B := 0`, eventually `|ѕБ u| вЙ§ A ¬Ј log u + B`. Direct
form for plugging into ¬ІCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`. -/
lemma zeroDensityRho_log_growth_eventually :
    вИАбґ† u : вДЭ in Filter.atTop,
      |zeroDensityRho u| вЙ§ (1 / (2 * Real.pi)) * Real.log u + 0 := by
  filter_upwards [Filter.eventually_ge_atTop (2 * Real.pi)] with u hu
  have := zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi hu
  linarith

-- =====================================================================
-- ¬ІCCXL. UHP-restricted smooth density majorant chain
-- =====================================================================
-- Compatibility refinement: the existing ¬ІCCXXXV / ¬ІCCXXXVII universal-`z`
-- structures `SmoothDensityTailModelConverges` and
-- `SmoothDensityTailMajorantData` are too strong for densities like
-- `zeroDensityRho` whose paired-kernel integrand has poles at real
-- `z вИИ [T, X]`. This section adds UHP-restricted siblings that quantify
-- the convergence / integrability fields over `0 < z.im` only вАФ which
-- is what the downstream `AntiHerglotzUHP` actually consumes.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
--   SmoothDensityTailModelConvergesUHP
--   SmoothDensityTailMajorantDataUHP
--   smoothDensityTailModel_converges_at_UHP
