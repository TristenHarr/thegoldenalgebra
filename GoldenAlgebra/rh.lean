/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö per-factor log-derivative of the genus-1
Hadamard factor.** `logDeriv ((1 - ┬À/¤ü) ┬À exp(┬À/¤ü)) s = 1/(s-¤ü) + 1/¤ü`. -/
theorem logDeriv_hadamardGenus1Factor {¤ü s : Ôäé} (h¤ü : ¤ü Ôëá 0) (hs : s Ôëá ¤ü) :
    logDeriv (hadamardGenus1Factor ¤ü) s = 1 / (s - ¤ü) + 1 / ¤ü := by
  have h_left_diff : DifferentiableAt Ôäé (fun y : Ôäé => 1 - y/¤ü) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner_diff : DifferentiableAt Ôäé (fun y : Ôäé => y/¤ü) s :=
    differentiableAt_id'.div_const _
  have h_right_diff : DifferentiableAt Ôäé (fun y : Ôäé => Complex.exp (y/¤ü)) s :=
    h_inner_diff.cexp
  have hsm¤ü : s - ¤ü Ôëá 0 := sub_ne_zero.mpr hs
  have h_left_ne : (1 : Ôäé) - s/¤ü Ôëá 0 := by
    intro h
    have h1 : s/¤ü = 1 := by linear_combination -h
    apply hs
    field_simp at h1
    exact h1
  have h_exp_ne : Complex.exp (s/¤ü) Ôëá 0 := Complex.exp_ne_zero _
  have h_deriv_inner : deriv (fun y : Ôäé => y/¤ü) s = 1/¤ü := by
    rw [deriv_div_const, deriv_id'']
  have h_deriv_left : deriv (fun y : Ôäé => 1 - y/¤ü) s = -(1/¤ü) := by
    rw [deriv_sub (differentiableAt_const _) (differentiableAt_id'.div_const _),
        deriv_const, h_deriv_inner]
    ring
  have h_deriv_right : deriv (fun y : Ôäé => Complex.exp (y/¤ü)) s
      = Complex.exp (s/¤ü) * (1/¤ü) := by
    rw [deriv_cexp h_inner_diff, h_deriv_inner]
  have h¤üs : ¤ü - s Ôëá 0 := sub_ne_zero.mpr (Ne.symm hs)
  rw [logDeriv_apply]
  unfold hadamardGenus1Factor
  rw [deriv_mul h_left_diff h_right_diff, h_deriv_left, h_deriv_right]
  -- Factor `Complex.exp (s/¤ü)` out of numerator and cancel with denominator
  rw [show -(1 / ¤ü) * Complex.exp (s / ¤ü)
            + (1 - s / ¤ü) * (Complex.exp (s / ¤ü) * (1 / ¤ü))
          = Complex.exp (s / ¤ü) * (-(1 / ¤ü) + (1 - s / ¤ü) * (1 / ¤ü)) from by ring,
      show (1 - s / ¤ü) * Complex.exp (s / ¤ü)
          = Complex.exp (s / ¤ü) * (1 - s / ¤ü) from by ring,
      mul_div_mul_left _ _ h_exp_ne]
  -- Now: (-(1/¤ü) + (1 - s/¤ü) * (1/¤ü)) / (1 - s/¤ü) = 1/(s-¤ü) + 1/¤ü
  -- Simplify numerator to -s/¤ü┬▓
  rw [show -(1 / ¤ü) + (1 - s / ¤ü) * (1 / ¤ü) = -s / ¤ü ^ 2 from by
        field_simp; ring]
  -- Now: (-s/¤ü┬▓) / (1 - s/¤ü) = 1/(s-¤ü) + 1/¤ü
  rw [show (1 : Ôäé) - s / ¤ü = (¤ü - s) / ¤ü from by field_simp]
  -- Now: (-s/¤ü┬▓) / ((¤ü - s)/¤ü) = 1/(s-¤ü) + 1/¤ü
  field_simp
  ring

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö per-factor `logDerivativeResponse` of the genus-1
Hadamard factor.** Same identity under the definitional bridge. -/
theorem logDerivativeResponse_hadamardGenus1Factor
    {¤ü s : Ôäé} (h¤ü : ¤ü Ôëá 0) (hs : s Ôëá ¤ü) :
    logDerivativeResponse (hadamardGenus1Factor ¤ü) s = 1 / (s - ¤ü) + 1 / ¤ü := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_hadamardGenus1Factor h¤ü hs

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö regularized form of the finite Hadamard product
log-derivative.** `logDeriv (finiteHadamardProduct zeros) s =
╬ú_{¤ü Ôêê zeros} (1/(s-¤ü) + 1/¤ü)`. The classical paired/regularized zero
sum. -/
theorem logDeriv_finiteHadamardProduct_regularized
    {zeros : Finset Ôäé} {s : Ôäé}
    (h¤ü_ne : ÔêÇ ¤ü Ôêê zeros, ¤ü Ôëá 0)
    (hs_ne : ÔêÇ ¤ü Ôêê zeros, s Ôëá ¤ü) :
    logDeriv (finiteHadamardProduct zeros) s
      = Ôêæ ¤ü Ôêê zeros, (1 / (s - ¤ü) + 1 / ¤ü) := by
  rw [logDeriv_finiteHadamardProduct h¤ü_ne hs_ne]
  apply Finset.sum_congr rfl
  intro ¤ü h¤ümem
  exact logDeriv_hadamardGenus1Factor (h¤ü_ne ¤ü h¤ümem) (hs_ne ¤ü h¤ümem)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö regularized form of the finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_finiteHadamardProduct_regularized
    {zeros : Finset Ôäé} {s : Ôäé}
    (h¤ü_ne : ÔêÇ ¤ü Ôêê zeros, ¤ü Ôëá 0)
    (hs_ne : ÔêÇ ¤ü Ôêê zeros, s Ôëá ¤ü) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = Ôêæ ¤ü Ôêê zeros, (1 / (s - ¤ü) + 1 / ¤ü) := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct_regularized h¤ü_ne hs_ne

-- =====================================================================
-- ┬ºCCCXXIII. Mathlib infinite-product / series API audit
-- =====================================================================
-- Located in `Mathlib/Topology/Algebra/InfiniteSum/Defs.lean`:
--   * `HasProd f a := Tendsto (ÔêÅ b Ôêê s, f b) atTop (­ØôØ a)` (Finset net).
--   * `Multipliable f := Ôêâ a, HasProd f a`.
--   * `tprod f`, notation `ÔêÅ' i, f i` (irreducible_def, falls back to 1).
--   * Additive analogues via `@[to_additive]`: `HasSum`, `Summable`, `tsum`,
--     `Ôêæ' i, f i`.
--
-- For locally uniform convergence (needed for product = entire function):
--   `Mathlib/Topology/Algebra/InfiniteSum/UniformOn.lean`:
--     * `HasProdLocallyUniformlyOn`, `MultipliableLocallyUniformlyOn`.
--   `Mathlib/Analysis/NormedSpace/MultipliableUniformlyOn.lean`:
--     * normed-space adapted lemmas.
--
-- These are the right APIs for the infinite Hadamard product. Use
-- `HasProd` / `tprod` for the product value; `HasSum` / `tsum` for the
-- regularized log-derivative series.

-- =====================================================================
-- ┬ºCCCXXIV. Infinite Hadamard product + regularized log-deriv series
-- =====================================================================
-- Lifts the finite Hadamard products to the indexed/infinite setting.
-- Introduces the named target series so the analytic agent can prove
-- the convergence/equality statements directly.

/-- **Indexed infinite Hadamard product** over an arbitrary index set
of zero ordinates. Falls back to `1` when not multipliable (Mathlib's
`tprod` convention). -/
noncomputable def infiniteHadamardProduct
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) (s : Ôäé) : Ôäé :=
  ÔêÅ' i : ╬╣, hadamardGenus1Factor (zeroLoc i) s

/-- **Indexed regularized log-derivative series**: the term-wise sum
`╬ú (1/(s-¤üßÁó) + 1/¤üßÁó)` that the infinite Hadamard log-derivative should
converge to. Falls back to `0` when not summable. -/
noncomputable def hadamardRegularizedLogDerivSeries
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) (s : Ôäé) : Ôäé :=
  Ôêæ' i : ╬╣, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Finite regularized log-derivative sum** over a Finset. -/
noncomputable def finiteHadamardRegularizedSum
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) (F : Finset ╬╣) (s : Ôäé) : Ôäé :=
  Ôêæ i Ôêê F, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Indexed finite Hadamard product**: the partial product over a
Finset, used for finite truncations of `infiniteHadamardProduct`. -/
noncomputable def indexedFiniteHadamardProduct
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) (F : Finset ╬╣) (s : Ôäé) : Ôäé :=
  ÔêÅ i Ôêê F, hadamardGenus1Factor (zeroLoc i) s

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö indexed finite Hadamard product log-derivative.**
The log-derivative of the indexed finite product equals the
indexed regularized sum. -/
theorem logDeriv_indexedFiniteHadamardProduct
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {F : Finset ╬╣} {s : Ôäé}
    (h¤ü : ÔêÇ i Ôêê F, zeroLoc i Ôëá 0)
    (hs : ÔêÇ i Ôêê F, s Ôëá zeroLoc i) :
    logDeriv (fun s' : Ôäé => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  unfold indexedFiniteHadamardProduct finiteHadamardRegularizedSum
  rw [logDeriv_prod F (fun i s' => hadamardGenus1Factor (zeroLoc i) s') s
        (fun i hi => hadamardGenus1Factor_ne_zero (h¤ü i hi) (hs i hi))
        (fun i _ => hadamardGenus1Factor_differentiableAt (zeroLoc i) s)]
  apply Finset.sum_congr rfl
  intro i hi
  exact logDeriv_hadamardGenus1Factor (h¤ü i hi) (hs i hi)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö indexed finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {F : Finset ╬╣} {s : Ôäé}
    (h¤ü : ÔêÇ i Ôêê F, zeroLoc i Ôëá 0)
    (hs : ÔêÇ i Ôêê F, s Ôëá zeroLoc i) :
    logDerivativeResponse
        (fun s' : Ôäé => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_indexedFiniteHadamardProduct h¤ü hs

-- =====================================================================
-- ┬ºCCCXXV. Locally-uniform Hadamard product analytic data
-- =====================================================================
-- The data structure that says: "this genus-1 infinite product is
-- analytically legitimate on the points where ╬¥ is non-zero, and its
-- log-derivative equals the regularized zero-sum series."
--
-- The Mathlib `MultipliableLocallyUniformlyOn` Prop is the natural
-- analytic-agent target for inhabiting `product_differentiable_at_xi_nonzero`
-- and `logDeriv_eq_tsum_at_xi_nonzero`; we expose those AFZ-projected
-- consequences directly rather than threading the universe-quantified
-- LUC predicate through the bundle.

/-- ­ƒôª **`HadamardLocallyUniformProductData`** ÔÇö the analytic
legitimacy package for the infinite genus-1 Hadamard product. -/
structure HadamardLocallyUniformProductData
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) : Type where
  product_multipliable :
    ÔêÇ s : Ôäé,
      Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s
  product_differentiable_at_xi_nonzero :
    ÔêÇ s : Ôäé,
      completedXiFunction s Ôëá 0 ÔåÆ
      DifferentiableAt Ôäé (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at_xi_nonzero :
    ÔêÇ s : Ôäé,
      completedXiFunction s Ôëá 0 ÔåÆ
      Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at_xi_nonzero :
    ÔêÇ s : Ôäé,
      completedXiFunction s Ôëá 0 ÔåÆ
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- ┬ºCCCXXVI. Hadamard product with zeros + bridge to ╬¥-side AFZ source
-- =====================================================================

/-- ­ƒôª **`CompletedXiHadamardProductWithZeros`** ÔÇö the classical
Hadamard product representation of `completedXiFunction` with a
possible analytic prefactor. Parameterized by the zero index type `╬╣`. -/
structure CompletedXiHadamardProductWithZeros (╬╣ : Type) : Type where
  zeroLoc : ╬╣ ÔåÆ Ôäé
  prefactor : Ôäé ÔåÆ Ôäé
  prefactor_differentiable_at :
    ÔêÇ s : Ôäé,
      completedXiFunction s Ôëá 0 ÔåÆ
      DifferentiableAt Ôäé prefactor s
  prefactor_ne_zero :
    ÔêÇ s : Ôäé,
      completedXiFunction s Ôëá 0 ÔåÆ
      prefactor s Ôëá 0
  xi_eq_product :
    ÔêÇ s : Ôäé,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s
  product_data : HadamardLocallyUniformProductData zeroLoc

/-- **Zero contribution from a Hadamard-with-zeros bundle**:
`logDeriv prefactor + tsum regularized`. -/
noncomputable def xiZeroContributionFromHadamard
    {╬╣ : Type} (H : CompletedXiHadamardProductWithZeros ╬╣) : Ôäé ÔåÆ Ôäé :=
  fun s =>
    logDerivativeResponse H.prefactor s
      + hadamardRegularizedLogDerivSeries H.zeroLoc s

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `CompletedXiLogDerivativeSourceAFZ` from
Hadamard-with-zeros bundle.** Uses `logDeriv_mul` (Mathlib) to split
the log-derivative of `prefactor ┬À product`, then identifies the
product's log-derivative with the regularized series via
`product_data.logDeriv_eq_tsum_at_xi_nonzero`. -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    {╬╣ : Type} (H : CompletedXiHadamardProductWithZeros ╬╣) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := xiZeroContributionFromHadamard H
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  ┬À intro s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    rw [hxi_eq_fun]
    exact (H.prefactor_differentiable_at s hs).mul
      (H.product_data.product_differentiable_at_xi_nonzero s hs)
  ┬À intro s hs
    have h_pref_ne : H.prefactor s Ôëá 0 := H.prefactor_ne_zero s hs
    have h_prod_ne : infiniteHadamardProduct H.zeroLoc s Ôëá 0 := by
      intro h
      apply hs
      rw [H.xi_eq_product s, h, mul_zero]
    have h_pref_diff := H.prefactor_differentiable_at s hs
    have h_prod_diff := H.product_data.product_differentiable_at_xi_nonzero s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    calc logDerivativeResponse completedXiFunction s
        = logDeriv completedXiFunction s := rfl
      _ = logDeriv (H.prefactor * infiniteHadamardProduct H.zeroLoc) s := by
          rw [hxi_eq_fun]
      _ = logDeriv H.prefactor s
            + logDeriv (infiniteHadamardProduct H.zeroLoc) s :=
          logDeriv_mul s h_pref_ne h_prod_ne h_pref_diff h_prod_diff
      _ = logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroLoc s := by
          rw [ÔåÉ logDerivativeResponse_eq_logDeriv (f := H.prefactor),
              ÔåÉ logDerivativeResponse_eq_logDeriv
                  (f := infiniteHadamardProduct H.zeroLoc),
              H.product_data.logDeriv_eq_tsum_at_xi_nonzero s hs]
      _ = xiZeroContributionFromHadamard H s := rfl

-- =====================================================================
-- ┬ºCCCXXVII. Log-derivative limit data (separate from convergence)
-- =====================================================================
-- The product-convergence content (`Multipliable`) is independent of
-- the log-derivative content (differentiability + summability + log-deriv
-- equal to tsum). Isolate the latter into its own data bundle, keyed by
-- an arbitrary `region : Set Ôäé`. The bridge to
-- `HadamardLocallyUniformProductData` then takes a region-coverage
-- hypothesis (AFZ Ôèå region).

/-- ­ƒôª **`HadamardLogDerivLimitData`** ÔÇö the log-derivative-of-limit
content, packaged on an arbitrary `region : Set Ôäé`. The genuine
analytic theorem (log-deriv interchanges with locally uniform
convergence) inhabits this bundle on the AFZ region of `╬¥`. -/
structure HadamardLogDerivLimitData
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) : Type where
  region : Set Ôäé
  product_differentiable_at :
    ÔêÇ s Ôêê region,
      DifferentiableAt Ôäé (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at :
    ÔêÇ s Ôêê region,
      Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at :
    ÔêÇ s Ôêê region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `HadamardLocallyUniformProductData` from
log-derivative limit data + region coverage.** -/
noncomputable def HadamardLocallyUniformProductData.of_logDerivLimitData
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (Hprod :
      ÔêÇ s : Ôäé,
        Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s)
    (Hlim : HadamardLogDerivLimitData zeroLoc)
    (h_region :
      ÔêÇ s : Ôäé, completedXiFunction s Ôëá 0 ÔåÆ s Ôêê Hlim.region) :
    HadamardLocallyUniformProductData zeroLoc :=
  { product_multipliable := Hprod
    product_differentiable_at_xi_nonzero := fun s hs =>
      Hlim.product_differentiable_at s (h_region s hs)
    regularized_summable_at_xi_nonzero := fun s hs =>
      Hlim.regularized_summable_at s (h_region s hs)
    logDeriv_eq_tsum_at_xi_nonzero := fun s hs =>
      Hlim.logDeriv_eq_tsum_at s (h_region s hs) }

-- =====================================================================
-- ┬ºCCCXXVIII. Finite exhaustion interface
-- =====================================================================
-- The natural finite-to-infinite convergence interface: a sequence of
-- Finsets that exhausts the index type, with the partial products
-- converging to the infinite product and the partial regularized sums
-- converging to the regularized series.

/-- ­ƒôª **`HadamardFiniteExhaustion`** ÔÇö finite-truncation convergence
interface for the genus-1 Hadamard product. -/
structure HadamardFiniteExhaustion
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) where
  exhaust : Ôäò ÔåÆ Finset ╬╣
  exhaust_mono :
    ÔêÇ {n m : Ôäò}, n Ôëñ m ÔåÆ exhaust n Ôèå exhaust m
  product_tendsto :
    ÔêÇ s : Ôäé,
      Tendsto
        (fun n => indexedFiniteHadamardProduct zeroLoc (exhaust n) s)
        Filter.atTop
        (­ØôØ (infiniteHadamardProduct zeroLoc s))
  regularized_sum_tendsto :
    ÔêÇ s : Ôäé,
      Tendsto
        (fun n => finiteHadamardRegularizedSum zeroLoc (exhaust n) s)
        Filter.atTop
        (­ØôØ (hadamardRegularizedLogDerivSeries zeroLoc s))

/-- Ô¡É **PROVED ÔÇö finite-truncation log-derivative identity at every
exhaustion stage.** Direct specialization of ┬ºCCCXXIV's
`logDerivativeResponse_indexedFiniteHadamardProduct`. -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct_at_exhaustion
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (Hex : HadamardFiniteExhaustion zeroLoc)
    {s : Ôäé} {n : Ôäò}
    (h¤ü : ÔêÇ i Ôêê Hex.exhaust n, zeroLoc i Ôëá 0)
    (hs : ÔêÇ i Ôêê Hex.exhaust n, s Ôëá zeroLoc i) :
    logDerivativeResponse
        (fun s' : Ôäé => indexedFiniteHadamardProduct zeroLoc (Hex.exhaust n) s') s
      = finiteHadamardRegularizedSum zeroLoc (Hex.exhaust n) s :=
  logDerivativeResponse_indexedFiniteHadamardProduct h¤ü hs

-- =====================================================================
-- ┬ºCCCXXIX. Regularized Hadamard term ÔÇö algebraic identity + norm
-- =====================================================================

/-- Ô¡É **PROVED ÔÇö paired/regularized identity.** The combined term
collapses to `s / ((s - ¤ü) ┬À ¤ü)`. -/
lemma hadamard_regularized_term_eq {s ¤ü : Ôäé} (h¤ü : ¤ü Ôëá 0) (hs¤ü : s Ôëá ¤ü) :
    1 / (s - ¤ü) + 1 / ¤ü = s / ((s - ¤ü) * ¤ü) := by
  have hs¤ü' : s - ¤ü Ôëá 0 := sub_ne_zero.mpr hs¤ü
  field_simp

/-- Ô¡É **PROVED ÔÇö norm form of the regularized identity.** -/
lemma norm_hadamard_regularized_term_eq
    {s ¤ü : Ôäé} (h¤ü : ¤ü Ôëá 0) (hs¤ü : s Ôëá ¤ü) :
    ÔÇû1 / (s - ¤ü) + 1 / ¤üÔÇû = ÔÇûsÔÇû / (ÔÇûs - ¤üÔÇû * ÔÇû¤üÔÇû) := by
  rw [hadamard_regularized_term_eq h¤ü hs¤ü, norm_div, norm_mul]

-- =====================================================================
-- ┬ºCCCXXX. Large-zero bound for the regularized term
-- =====================================================================

/-- Ô¡É **PROVED ÔÇö reverse-triangle large-zero bound.** When
`2 ÔÇûsÔÇû Ôëñ ÔÇû¤üÔÇû`, we have `ÔÇûs ÔêÆ ¤üÔÇû ÔëÑ ÔÇû¤üÔÇû/2`. -/
lemma norm_sub_ge_half_of_two_norm_le {s ¤ü : Ôäé}
    (hlarge : 2 * ÔÇûsÔÇû Ôëñ ÔÇû¤üÔÇû) :
    ÔÇû¤üÔÇû / 2 Ôëñ ÔÇûs - ¤üÔÇû := by
  have htriangle : ÔÇû¤üÔÇû Ôëñ ÔÇûsÔÇû + ÔÇûs - ¤üÔÇû := by
    have h_sub := norm_sub_le s (s - ¤ü)
    have h_eq : s - (s - ¤ü) = ¤ü := by ring
    rw [h_eq] at h_sub
    exact h_sub
  linarith

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö large-zero bound on the regularized Hadamard
term.** `ÔÇû1/(sÔêÆ¤ü) + 1/¤üÔÇû Ôëñ 2 ÔÇûsÔÇû / ÔÇû¤üÔÇû┬▓` for `ÔÇû¤üÔÇû ÔëÑ 2 ÔÇûsÔÇû`. -/
lemma norm_hadamard_regularized_term_le_large {s ¤ü : Ôäé}
    (h¤ü : ¤ü Ôëá 0) (hs¤ü : s Ôëá ¤ü) (hlarge : 2 * ÔÇûsÔÇû Ôëñ ÔÇû¤üÔÇû) :
    ÔÇû1 / (s - ¤ü) + 1 / ¤üÔÇû Ôëñ 2 * ÔÇûsÔÇû / ÔÇû¤üÔÇû ^ 2 := by
  rw [norm_hadamard_regularized_term_eq h¤ü hs¤ü]
  have h¤ü_pos : 0 < ÔÇû¤üÔÇû := norm_pos_iff.mpr h¤ü
  have h_s¤ü_pos : 0 < ÔÇûs - ¤üÔÇû := norm_pos_iff.mpr (sub_ne_zero.mpr hs¤ü)
  have h_denom_pos : 0 < ÔÇûs - ¤üÔÇû * ÔÇû¤üÔÇû := mul_pos h_s¤ü_pos h¤ü_pos
  have h_¤ü_sq_pos : 0 < ÔÇû¤üÔÇû ^ 2 := by positivity
  have h_s¤ü_ge : ÔÇû¤üÔÇû / 2 Ôëñ ÔÇûs - ¤üÔÇû := norm_sub_ge_half_of_two_norm_le hlarge
  have h_s_nn : 0 Ôëñ ÔÇûsÔÇû := norm_nonneg _
  rw [div_le_div_iffÔéÇ h_denom_pos h_¤ü_sq_pos]
  have h_¤ü_le : ÔÇû¤üÔÇû Ôëñ 2 * ÔÇûs - ¤üÔÇû := by linarith
  have h_mul : ÔÇû¤üÔÇû * ÔÇû¤üÔÇû Ôëñ 2 * ÔÇûs - ¤üÔÇû * ÔÇû¤üÔÇû :=
    mul_le_mul_of_nonneg_right h_¤ü_le h¤ü_pos.le
  have h_¤ü_sq : ÔÇû¤üÔÇû ^ 2 = ÔÇû¤üÔÇû * ÔÇû¤üÔÇû := by ring
  nlinarith [h_mul, h_s_nn, h_¤ü_sq]

-- =====================================================================
-- ┬ºCCCXXXI. Summability of regularized terms via inv-sq summability
-- =====================================================================

/-- ­ƒôª **`HadamardZeroInvSqSummability`** ÔÇö the classical analytic
hypothesis on a zero set: `╬ú 1/ÔÇû¤üÔÇû┬▓ < Ôê×` (genus Ôëñ 1) and for every
`s`, eventually `ÔÇû¤üÔÇû ÔëÑ 2ÔÇûsÔÇû`. -/
structure HadamardZeroInvSqSummability
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) : Prop where
  zero_ne : ÔêÇ i, zeroLoc i Ôëá 0
  inv_sq_summable :
    Summable fun i : ╬╣ => (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣
  eventually_large :
    ÔêÇ s : Ôäé, ÔêÇßÂá i in Filter.cofinite, 2 * ÔÇûsÔÇû Ôëñ ÔÇûzeroLoc iÔÇû

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö regularized series is summable from inv-sq
summability + eventually-large.** -/
theorem summable_hadamard_regularized_terms_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {s : Ôäé}
    (hzero_ne : ÔêÇ i, zeroLoc i Ôëá 0)
    (hs_ne : ÔêÇ i, s Ôëá zeroLoc i)
    (hinv_sq : Summable fun i : ╬╣ => (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
    (heventual_large :
      ÔêÇßÂá i in Filter.cofinite, 2 * ÔÇûsÔÇû Ôëñ ÔÇûzeroLoc iÔÇû) :
    Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 2 * ÔÇûsÔÇû * (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
  ┬À exact hinv_sq.mul_left (2 * ÔÇûsÔÇû)
  ┬À filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_hadamard_regularized_term_le_large (hzero_ne i) (hs_ne i) hi
    have h_eq :
        (2 : ÔäØ) * ÔÇûsÔÇû / ÔÇûzeroLoc iÔÇû ^ 2
          = 2 * ÔÇûsÔÇû * (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣ := by
      rw [div_eq_mul_inv]
    linarith [h_eq Ôû© h_bound]

/-- Ô¡É **PROVED ÔÇö regularized summability from the data bundle
`HadamardZeroInvSqSummability`.** -/
theorem HadamardZeroInvSqSummability.summable_regularized
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (H : HadamardZeroInvSqSummability zeroLoc)
    {s : Ôäé} (hs_ne : ÔêÇ i, s Ôëá zeroLoc i) :
    Summable fun i : ╬╣ => 1 / (s - zeroLoc i) + 1 / zeroLoc i :=
  summable_hadamard_regularized_terms_of_inv_sq
    H.zero_ne hs_ne H.inv_sq_summable (H.eventually_large s)

-- =====================================================================
-- ┬ºCCCXXXII. Genus-one Taylor bound (data + specialization)
-- =====================================================================

/-- ­ƒôª **`GenusOneTaylorBoundData`** ÔÇö quantitative form of
`1 - (1-w)┬Àexp(w) = O(w┬▓)`. Standard genus-one decay; `C = 4` is
unsharp but suffices for convergence. -/
structure GenusOneTaylorBoundData : Prop where
  bound :
    ÔêÇ w : Ôäé, ÔÇûwÔÇû Ôëñ 1 ÔåÆ
      ÔÇû1 - (1 - w) * Complex.exp wÔÇû Ôëñ 4 * ÔÇûwÔÇû ^ 2

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö specialization to `hadamardGenus1Factor` with
`ÔÇûsÔÇû Ôëñ ÔÇû¤üÔÇû`.** -/
lemma norm_one_sub_hadamardGenus1Factor_le_large
    {¤ü s : Ôäé} (h¤ü : ¤ü Ôëá 0) (hlarge : ÔÇûsÔÇû Ôëñ ÔÇû¤üÔÇû)
    (Hbound : GenusOneTaylorBoundData) :
    ÔÇû1 - hadamardGenus1Factor ¤ü sÔÇû Ôëñ 4 * (ÔÇûsÔÇû ^ 2 / ÔÇû¤üÔÇû ^ 2) := by
  unfold hadamardGenus1Factor
  have h¤ü_pos : 0 < ÔÇû¤üÔÇû := norm_pos_iff.mpr h¤ü
  have hw : ÔÇûs / ¤üÔÇû Ôëñ 1 := by
    rw [norm_div]
    exact div_le_one_of_leÔéÇ hlarge (norm_nonneg _)
  have h := Hbound.bound (s / ¤ü) hw
  rw [norm_div, div_pow] at h
  exact h

-- =====================================================================
-- ┬ºCCCXXXIII. Product convergence from inverse-square zero summability
-- =====================================================================

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö norm-summability of `1 - EÔéü(s/¤üßÁó)`.** -/
theorem summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {s : Ôäé}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ÔêÇ i, zeroLoc i Ôëá 0)
    (hinv_sq : Summable fun i : ╬╣ => (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
    (heventual_large :
      ÔêÇßÂá i in Filter.cofinite, ÔÇûsÔÇû Ôëñ ÔÇûzeroLoc iÔÇû) :
    Summable fun i : ╬╣ => ÔÇû1 - hadamardGenus1Factor (zeroLoc i) sÔÇû := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 4 * ÔÇûsÔÇû ^ 2 * (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
  ┬À exact hinv_sq.mul_left (4 * ÔÇûsÔÇû ^ 2)
  ┬À filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_one_sub_hadamardGenus1Factor_le_large (hzero_ne i) hi Hbound
    have h_eq : (4 : ÔäØ) * ÔÇûsÔÇû ^ 2 * (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣
              = 4 * (ÔÇûsÔÇû ^ 2 / ÔÇûzeroLoc iÔÇû ^ 2) := by
      rw [div_eq_mul_inv]; ring
    rw [Real.norm_of_nonneg (norm_nonneg _)]
    linarith [h_eq Ôû© h_bound]

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö Ôäé-valued `Summable (1 - EÔéü(s/¤üßÁó))` from norm.** -/
theorem summable_one_sub_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {s : Ôäé}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ÔêÇ i, zeroLoc i Ôëá 0)
    (hinv_sq : Summable fun i : ╬╣ => (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
    (heventual_large :
      ÔêÇßÂá i in Filter.cofinite, ÔÇûsÔÇû Ôëñ ÔÇûzeroLoc iÔÇû) :
    Summable fun i : ╬╣ => 1 - hadamardGenus1Factor (zeroLoc i) s :=
  Summable.of_norm
    (summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `Multipliable (hadamardGenus1Factor Ôêÿ zeroLoc)`
from inverse-square zero summability + Taylor bound.** Uses Mathlib's
`Complex.multipliable_one_add_of_summable`. -/
theorem multipliable_hadamardGenus1Factor_of_inv_sq
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé} {s : Ôäé}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ÔêÇ i, zeroLoc i Ôëá 0)
    (hinv_sq : Summable fun i : ╬╣ => (ÔÇûzeroLoc iÔÇû ^ 2)Ôü╗┬╣)
    (heventual_large :
      ÔêÇßÂá i in Filter.cofinite, ÔÇûsÔÇû Ôëñ ÔÇûzeroLoc iÔÇû) :
    Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s := by
  have h_sum :=
    summable_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large
  have h_sum_neg :
      Summable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s - 1 := by
    have := h_sum.neg
    simpa [neg_sub] using this
  have h_mul := Complex.multipliable_one_add_of_summable h_sum_neg
  simpa using h_mul

/-- Ô¡É **PROVED ÔÇö `Multipliable` from the `HadamardZeroInvSqSummability`
bundle + Taylor bound.** -/
theorem HadamardZeroInvSqSummability.multipliable_genus1
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (H : HadamardZeroInvSqSummability zeroLoc)
    (Hbound : GenusOneTaylorBoundData) (s : Ôäé) :
    Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s := by
  apply multipliable_hadamardGenus1Factor_of_inv_sq
    Hbound H.zero_ne H.inv_sq_summable
  filter_upwards [H.eventually_large s] with i hi
  have h_s_nn : 0 Ôëñ ÔÇûsÔÇû := norm_nonneg s
  linarith

-- =====================================================================
-- ┬ºCCCXXXIV. Prove `GenusOneTaylorBoundData`
-- =====================================================================
-- Inhabits the genus-one Taylor bound via Mathlib's
-- `Complex.norm_exp_sub_one_le` and `Complex.norm_exp_sub_one_sub_id_le`.
-- Decomposition:
--   `1 - (1-w)┬Àexp(w) = -(exp(w) - 1 - w) + w┬À(exp(w) - 1)`
-- Triangle inequality + the two Mathlib bounds give `ÔÇû┬ÀÔÇû Ôëñ 3┬ÀÔÇûwÔÇû┬▓`,
-- which dominates `4┬ÀÔÇûwÔÇû┬▓` for free.

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `GenusOneTaylorBoundData` inhabited.** -/
theorem genusOneTaylorBoundData : GenusOneTaylorBoundData := by
  refine Ôƒ¿?_Ôƒ®
  intro w hw
  have h_decomp :
      (1 : Ôäé) - (1 - w) * Complex.exp w
        = -(Complex.exp w - 1 - w) + w * (Complex.exp w - 1) := by
    ring
  rw [h_decomp]
  have h_exp_sub_1_sub_id := Complex.norm_exp_sub_one_sub_id_le hw
  have h_exp_sub_1 := Complex.norm_exp_sub_one_le hw
  have h_w_nn : 0 Ôëñ ÔÇûwÔÇû := norm_nonneg _
  calc ÔÇû-(Complex.exp w - 1 - w) + w * (Complex.exp w - 1)ÔÇû
      Ôëñ ÔÇû-(Complex.exp w - 1 - w)ÔÇû + ÔÇûw * (Complex.exp w - 1)ÔÇû :=
        norm_add_le _ _
    _ = ÔÇûComplex.exp w - 1 - wÔÇû + ÔÇûwÔÇû * ÔÇûComplex.exp w - 1ÔÇû := by
        rw [norm_neg, norm_mul]
    _ Ôëñ ÔÇûwÔÇû ^ 2 + ÔÇûwÔÇû * (2 * ÔÇûwÔÇû) := by
        gcongr
    _ = 3 * ÔÇûwÔÇû ^ 2 := by ring
    _ Ôëñ 4 * ÔÇûwÔÇû ^ 2 := by nlinarith [sq_nonneg ÔÇûwÔÇû]

-- =====================================================================
-- ┬ºCCCXXXV. Hypothesis-free product-convergence convenience
-- =====================================================================

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `Multipliable (hadamardGenus1Factor Ôêÿ zeroLoc)`
from `HadamardZeroInvSqSummability` alone** (no Taylor hypothesis). -/
theorem HadamardZeroInvSqSummability.product_multipliable
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (H : HadamardZeroInvSqSummability zeroLoc) :
    ÔêÇ s : Ôäé,
      Multipliable fun i : ╬╣ => hadamardGenus1Factor (zeroLoc i) s :=
  fun s => H.multipliable_genus1 genusOneTaylorBoundData s

-- =====================================================================
-- ┬ºCCCXXXVI. LUC log-derivative interchange scaffold
-- =====================================================================
-- The genuine analytic content of "log-derivative interchanges with
-- locally uniform convergence." Packaged as data on a region.

/-- ­ƒôª **`HadamardProductLUCLogDerivData`** ÔÇö the LUC + log-derivative
interchange data on `region : Set Ôäé`. -/
structure HadamardProductLUCLogDerivData
    {╬╣ : Type*} (zeroLoc : ╬╣ ÔåÆ Ôäé) where
  region : Set Ôäé
  locally_uniform_product :
    TendstoLocallyUniformlyOn
      (fun F : Finset ╬╣ => fun s : Ôäé =>
        indexedFiniteHadamardProduct zeroLoc F s)
      (infiniteHadamardProduct zeroLoc)
      Filter.atTop
      region
  infinite_differentiable_at :
    ÔêÇ s Ôêê region,
      DifferentiableAt Ôäé (infiniteHadamardProduct zeroLoc) s
  logDeriv_eq_tsum :
    ÔêÇ s Ôêê region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- ┬ºCCCXXXVII. Bridge LUC + invSq ÔåÆ HadamardLogDerivLimitData
-- =====================================================================

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `HadamardLogDerivLimitData` from LUC + inv-sq +
no-collision in region.** -/
noncomputable def HadamardLogDerivLimitData.of_productLUC_and_invSq
    {╬╣ : Type*} {zeroLoc : ╬╣ ÔåÆ Ôäé}
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (HnonzeroRegion : ÔêÇ s Ôêê Hluc.region, ÔêÇ i, s Ôëá zeroLoc i) :
    HadamardLogDerivLimitData zeroLoc :=
  { region := Hluc.region
    product_differentiable_at := Hluc.infinite_differentiable_at
    regularized_summable_at := fun s hs =>
      Hinv.summable_regularized (HnonzeroRegion s hs)
    logDeriv_eq_tsum_at := Hluc.logDeriv_eq_tsum }

