    E zetaZeroPosImagPosRe StripGapToLC hT

/-! ### CW20: split strip-gap вЖТ LC into filter bridge + pointwise count constancy -/

/-- Pointwise count constancy under a strip zero gap: at every height
`u вИИ (T, T + ќµ]` such that no ќґ-zero in the standard strip lies in
`(T, T + ќµ]`, the weighted count at `u` equals the count at `T`.  This
isolates the count-machinery/certificate content of the strip-gap bridge. -/
structure ZetaStripGapPointwiseCountConstancyInput : Prop where
  const_on_gap :
    вИА T u ќµ : вДЭ,
      (140 : вДЭ) вЙ§ T вЖТ T < u вЖТ u вЙ§ T + ќµ вЖТ 0 < ќµ вЖТ
      (вИА ѕБ : вДВ,
        riemannZeta ѕБ = 0 вЖТ
        (-1 : вДЭ) вЙ§ ѕБ.re вЖТ ѕБ.re вЙ§ 2 вЖТ
        T < ѕБ.im вЖТ ѕБ.im вЙ§ T + ќµ вЖТ False) вЖТ
      zetaWeightedZeroCountUpToHeightReal u =
        zetaWeightedZeroCountUpToHeightReal T

/-- **CW20 вАФ filter bridge:** pointwise count constancy under a strip
zero gap implies the strip-gap вЖТ LC bridge.  Pure real-filter content;
the actual count-extensionality work is concentrated in `const_on_gap`. -/
noncomputable def
    ZetaStripGapPointwiseCountConstancyInput.toStripGapToLC
    (P : ZetaStripGapPointwiseCountConstancyInput) :
    ZetaStripGapToLocalConstancyInput where
  bridge := by
    intro G
    refine вЯ®?_вЯ©
    intro T hT
    rcases G.exists_gap T hT with вЯ®ќµ, hќµpos, hgapвЯ©
    have hIoi :
        вИАбґ† u in nhdsWithin T (Set.Ioi T), T < u :=
      self_mem_nhdsWithin
    have hIio :
        вИАбґ† u in nhdsWithin T (Set.Ioi T), u < T + ќµ :=
      nhdsWithin_le_nhds (Iio_mem_nhds (by linarith : T < T + ќµ))
    have hEventually :
        вИАбґ† u in nhdsWithin T (Set.Ioi T), T < u вИІ u вЙ§ T + ќµ := by
      filter_upwards [hIoi, hIio] with u h1 h2
      exact вЯ®h1, le_of_lt h2вЯ©
    filter_upwards [hEventually] with u hu
    exact P.const_on_gap T u ќµ hT hu.1 hu.2 hќµpos hgap

/-- **CW20 вАФ sharper final theorem.**  Replaces the strip-gap вЖТ LC bridge
with the more focused pointwise count-constancy obligation. -/
theorem
    concreteS_halfLogPlusHalf_of_numericalExtraction_and_pointwiseCountConstancy
    (E : BacklundNumericalExtractionInput)
    (P : ZetaStripGapPointwiseCountConstancyInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction_and_stripGapBridge
    E P.toStripGapToLC hT

/-! ### CW21: reduce pointwise count constancy to set equality + count extensionality -/

/-- Pure-logic lemma: the set of nontrivial ќґ-zeros up to height `u` agrees
with the set up to height `T` whenever `T < u вЙ§ T + ќµ` and no ќґ-zero in
the Backlund strip slab `(T, T + ќµ]` exists.  Uses the nontriviality
conditions `0 < ѕБ.re < 1` to deduce the strip inclusion `-1 вЙ§ ѕБ.re вЙ§ 2`
needed by the gap hypothesis. -/
theorem zetaZerosUpToHeightSet_eq_of_strip_gap
    {T u ќµ : вДЭ}
    (_hT : (140 : вДЭ) вЙ§ T)
    (huT : T < u)
    (huќµ : u вЙ§ T + ќµ)
    (_hќµ : 0 < ќµ)
    (hgap :
      вИА ѕБ : вДВ,
        riemannZeta ѕБ = 0 вЖТ
        (-1 : вДЭ) вЙ§ ѕБ.re вЖТ
        ѕБ.re вЙ§ 2 вЖТ
        T < ѕБ.im вЖТ
        ѕБ.im вЙ§ T + ќµ вЖТ
        False) :
    zetaZerosUpToHeightSet u = zetaZerosUpToHeightSet T := by
  ext ѕБ
  constructor
  ¬Ј intro hѕБu
    obtain вЯ®вЯ®hzero, hre_pos, hre_lt_oneвЯ©, him_pos, him_le_uвЯ© := hѕБu
    by_cases hle : ѕБ.im вЙ§ T
    ¬Ј exact вЯ®вЯ®hzero, hre_pos, hre_lt_oneвЯ©, him_pos, hleвЯ©
    ¬Ј push_neg at hle
      have him_le_eps : ѕБ.im вЙ§ T + ќµ := le_trans him_le_u huќµ
      have hre_low : (-1 : вДЭ) вЙ§ ѕБ.re := by linarith
      have hre_high : ѕБ.re вЙ§ 2 := by linarith
      exact (hgap ѕБ hzero hre_low hre_high hle him_le_eps).elim
  ¬Ј intro hѕБT
    obtain вЯ®nontriv, him_pos, him_le_TвЯ© := hѕБT
    exact вЯ®nontriv, him_pos, le_trans him_le_T (le_of_lt huT)вЯ©

/-- Extensionality input for the real-valued weighted zero count: if the
geometric zero set up to two heights is the same, then the counts agree.
Named anchor вАФ proving it requires unfolding the certificate-based
`weightedZeroCountFromCertificate` chain (via `weightedZeroSetOfGlobalMultiplicity`
and `truncatedMultiplicity`). -/
structure ZetaWeightedCountExtensionalityInput : Prop where
  count_eq_of_set_eq :
    вИА T U : вДЭ,
      zetaZerosUpToHeightSet T = zetaZerosUpToHeightSet U вЖТ
        zetaWeightedZeroCountUpToHeightReal T =
          zetaWeightedZeroCountUpToHeightReal U

/-- **CW21 вАФ bridge from count extensionality:** combining the strip-gap
set-equality lemma with the count-extensionality input discharges the
pointwise count-constancy obligation. -/
noncomputable def ZetaStripGapPointwiseCountConstancyInput.of_set_ext
    (Ext : ZetaWeightedCountExtensionalityInput) :
    ZetaStripGapPointwiseCountConstancyInput where
  const_on_gap := by
    intro T u ќµ hT huT huќµ hќµ hgap
    exact Ext.count_eq_of_set_eq u T
      (zetaZerosUpToHeightSet_eq_of_strip_gap hT huT huќµ hќµ hgap)

/-- **CW21 вАФ sharper final theorem.**  Replaces the pointwise count
constancy obligation with the more focused count-extensionality input. -/
theorem
    concreteS_halfLogPlusHalf_of_numericalExtraction_and_countExtensionality
    (E : BacklundNumericalExtractionInput)
    (Ext : ZetaWeightedCountExtensionalityInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction_and_pointwiseCountConstancy
    E (ZetaStripGapPointwiseCountConstancyInput.of_set_ext Ext) hT

/-! ### CW22: discharge count extensionality from `truncatedMultiplicity_eq_global` -/

/-- **CW22 вАФ `ZetaWeightedCountExtensionalityInput` DISCHARGED.**  Unfolds
the count to a sum over a `toFinset`; the underlying finset is determined
by the set, and `truncatedMultiplicity` agrees on the common support
because both reduce to the global multiplicity on the (equal) zero sets.
Case analysis on the `0 вЙ§ T` guards. -/
theorem zetaWeightedCountExtensionalityInput :
    ZetaWeightedCountExtensionalityInput where
  count_eq_of_set_eq := by
    intro T U hset
    classical
    have hempty_neg : вИА V : вДЭ, V < 0 вЖТ zetaZerosUpToHeightSet V = вИЕ := by
      intro V hV
      ext s
      refine вЯ®fun h => ?_, fun h => h.elimвЯ©
      obtain вЯ®_, him_pos, him_leвЯ© := h
      linarith
    have hcount_zero_of_empty :
        вИА {V : вДЭ} (hV : 0 вЙ§ V),
          zetaZerosUpToHeightSet V = вИЕ вЖТ
          zetaWeightedZeroCountUpToHeight V hV = 0 := by
      intro V hV hVempty
      change (zetaZerosUpToHeightSet_finite V hV).toFinset.sum
          (truncatedMultiplicity zetaGlobalZeroMultiplicity V) = 0
      have htofin_eq :
          (zetaZerosUpToHeightSet_finite V hV).toFinset = вИЕ :=
        Set.Finite.toFinset_eq_empty.mpr hVempty
      rw [htofin_eq, Finset.sum_empty]
    unfold zetaWeightedZeroCountUpToHeightReal
    by_cases hT_nn : (0 : вДЭ) вЙ§ T
    ¬Ј by_cases hU_nn : (0 : вДЭ) вЙ§ U
      ¬Ј rw [dif_pos hT_nn, dif_pos hU_nn]
        simp only [Nat.cast_inj]
        change (zetaZerosUpToHeightSet_finite T hT_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity T) =
          (zetaZerosUpToHeightSet_finite U hU_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity U)
        have hfin_eq :
            (zetaZerosUpToHeightSet_finite T hT_nn).toFinset =
              (zetaZerosUpToHeightSet_finite U hU_nn).toFinset := by
          ext ѕБ
          rw [Set.Finite.mem_toFinset, Set.Finite.mem_toFinset, hset]
        refine Finset.sum_congr hfin_eq ?_
        intro ѕБ hѕБmem
        have hѕБU : ѕБ вИИ zetaZerosUpToHeightSet U :=
          (Set.Finite.mem_toFinset _).mp hѕБmem
        have hѕБT : ѕБ вИИ zetaZerosUpToHeightSet T := hset вЦЄ hѕБU
        rw [truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity hѕБT,
            truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity hѕБU]
      ¬Ј push_neg at hU_nn
        rw [dif_pos hT_nn, dif_neg hU_nn.not_ge]
        have hU_empty : zetaZerosUpToHeightSet U = вИЕ := hempty_neg U hU_nn
        have hT_empty : zetaZerosUpToHeightSet T = вИЕ := hset.trans hU_empty
        have h0 : zetaWeightedZeroCountUpToHeight T hT_nn = 0 :=
          hcount_zero_of_empty hT_nn hT_empty
        rw [h0]
        norm_num
    ¬Ј push_neg at hT_nn
      rw [dif_neg hT_nn.not_ge]
      by_cases hU_nn : (0 : вДЭ) вЙ§ U
      ¬Ј rw [dif_pos hU_nn]
        have hT_empty : zetaZerosUpToHeightSet T = вИЕ := hempty_neg T hT_nn
        have hU_empty : zetaZerosUpToHeightSet U = вИЕ := by
          rw [вЖР hset]; exact hT_empty
        have h0 : zetaWeightedZeroCountUpToHeight U hU_nn = 0 :=
          hcount_zero_of_empty hU_nn hU_empty
        rw [h0]
        symm; norm_num
      ¬Ј push_neg at hU_nn
        rw [dif_neg hU_nn.not_ge]

/-- **CW22 вАФ strongest 1-input final theorem.**  After CW22, the entire
extension / count / continuity / compactness / classification side is
discharged.  The headline bound is reduced to the single classical
analytic obligation `BacklundNumericalExtractionInput`. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction
    (E : BacklundNumericalExtractionInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction_and_countExtensionality
    E zetaWeightedCountExtensionalityInput hT

/-! ### CW23: parameterized Backlund numerical budget + pointwise extraction -/

/-- Parameterized numerical budget for Backlund's good-height estimate at
a single height `T`.  `Type`-valued so the named contributions `J`, `R`,
`H` are directly accessible; the bridge `toData` recovers the existential
`BacklundNumericalDataAt T`. -/
structure BacklundNumericalBudgetAt (T : вДЭ) where
  J : вДЭ
  R : вДЭ
  H : вДЭ
  hJ_nonneg : 0 вЙ§ J
  hR_nonneg : 0 вЙ§ R
  hH_nonneg : 0 вЙ§ H
  hcontrol : |concreteS T| вЙ§ J + R + H
  hbudget : J + R + H вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2

/-- Bridge: parameterized budget вЖТ existential numerical data. -/
noncomputable def BacklundNumericalBudgetAt.toData {T : вДЭ}
    (B : BacklundNumericalBudgetAt T) :
    BacklundNumericalDataAt T :=
  вЯ®B.J, B.R, B.H, B.hJ_nonneg, B.hR_nonneg, B.hH_nonneg,
    B.hbudget, B.hcontrolвЯ©

/-- Pointwise Backlund numerical extraction at every good height: given
the three classical estimates at `T`, produce explicit nonnegative
contributions `J`, `R`, `H` summing to at most `(1/2)¬Јlog T + 1/2` and
dominating `|concreteS T|`. -/
structure BacklundPointwiseNumericalExtractionInput where
  extract_at :
    вИА T : вДЭ, RvMGoodHeight T вЖТ (140 : вДЭ) вЙ§ T вЖТ
      BacklundJensenRectangleEstimate T вЖТ
      BacklundRightSideArgumentVariationEstimate T вЖТ
      BacklundHorizontalBoundaryEstimate T вЖТ
        BacklundNumericalBudgetAt T

/-- Bridge: pointwise budget extraction вЖТ existential numerical
extraction input. -/
noncomputable def
    BacklundPointwiseNumericalExtractionInput.toNumericalExtraction
    (P : BacklundPointwiseNumericalExtractionInput) :
    BacklundNumericalExtractionInput where
  extract := fun T hgood hT hJ hR hH =>
    (P.extract_at T hgood hT hJ hR hH).toData

/-- **CW23 вАФ final theorem from pointwise Backlund numerics.**  The
genuine remaining obligation is now expressed with named accessors
`J`, `R`, `H` for the three classical contributions at every good
height `T вЙ• 140`. -/
theorem concreteS_halfLogPlusHalf_of_pointwiseBacklundNumerics
    (P : BacklundPointwiseNumericalExtractionInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction
    P.toNumericalExtraction hT

