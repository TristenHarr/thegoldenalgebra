  xi_diff_at :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ completedXiFunction s
  logDeriv_eq :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      logDerivativeResponse completedXiFunction s = xiZeroContribution s

/-- ⭐ **PROVED — `CompletedXiLogDerivativeSourceAFZ` from Hadamard
product data.** -/
def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductData
