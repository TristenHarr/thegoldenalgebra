structure FirstZeroBandCertInputs (model : Ôäé ÔåÆ Ôäé) (errorBound : ÔäØ ÔåÆ ÔäØ ÔåÆ ÔäØ) where
  cert_2pi_7 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ,
