/-! ### Bridges: guarded Tendsto тЖТ guarded formula data -/

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ guarded mid formula data from guarded Tendsto.**
The proof copies `xiResidualCanonicalTailIdentity_of_complex_tendsto` but
threads the `XiPullback z тЙа 0` guard through. The guard is consumed at
the call to `hResTendsto`, not at the analysis step. -/
def XiResidualCanonicalFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hResTendsto :
      тИА {z : тДВ},
        0 < z.im тЖТ
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        XiPullback z тЙа 0 тЖТ
        Tendsto
          (fun X : тДЭ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop (ЁЭУЭ (xiResidualError M z))) :
    XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring M := by
  refine тЯи?_тЯй
  intro z hy hmid hne
  have hc := canonicalAdaptiveT_spec hmid
  have h_res_im :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop (ЁЭУЭ (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp (hResTendsto hy hmid hne)
  have h_tail_tendsto :=
    trueKernelAdaptiveTail_tendsto
      Dzero T0 hT0_pos hT0_le_10 hTuring
      hc.1 hc.2.1 hy hc.2.2
  have h_tail_im :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop
        (ЁЭУЭ (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ guarded high formula data from guarded Tendsto.**
Same chain as `xiHighResidualTailIdentity_of_complex_tendsto`, with the
`XiPullback z тЙа 0` guard threaded through. -/
def XiHighResidualFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 тЙд 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (H : XiHighResidualAsTailLimitAwayFromZeros Dzero T0 M) :
    XiHighResidualFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_140 M hHighLog := by
  refine тЯи?_тЯй
  intro z T hT140 hy hregime hne
  have hSlogEnv : тИАс╢а u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  have h_res_im :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop (ЁЭУЭ (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp
      (H.tendsto_high hT140 hy hregime hne)
  have h_tail_tendsto :=
    trueKernelTailOfLogEnvelope_tendsto
      Dzero T0 hT0_pos
      (le_trans hT0_le_140 hT140)
      (by linarith : (0 : тДЭ) < T) hy hSlogEnv
  have h_tail_im :
      Tendsto
        (fun X : тДЭ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop
        (ЁЭУЭ (trueKernelTailOfLogEnvelope
          Dzero T0 hT0_pos
          (le_trans hT0_le_140 hT140)
          (by linarith : (0 : тДЭ) < T) hy hSlogEnv).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

