theorem smoothKernelNormFactor_ge_five_div_twentyNine
    {x y : ÔäØ} (hy : 0 < y) (hbox : x ^ 2 + y ^ 2 Ôëñ 16) :
    (5 / 29 : ÔäØ)
      Ôëñ (10 - |x|) / ((10 - |x|) ^ 2 + y ^ 2)
