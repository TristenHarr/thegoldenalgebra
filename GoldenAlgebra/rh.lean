-- ┬ºCCXCII. `HlowArith` normalization (factor out `y > 0`)
-- =====================================================================
-- Both sides of `LowExplicitArithmeticBound_11_14_half` are linear in
-- `y := z.im`:
--   LHS  `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ┬À CÔéÇ`
--          where `CÔéÇ := 17/242 ÔêÆ 9/392 Ôëê 0.0473`,
--   RHS  `simpleCloudSum zeros100ceil x y = y ┬À simpleCloudSumNorm ...`
--   RHS  `smoothTailRationalLowerBoundAbs x y 10 = y ┬À smoothTailRationalLowerBoundAbsNorm x y 10`.
-- Since `y > 0` on `lowCompactRegion`, dividing both sides by `y`
-- removes the y-scaling and reduces the inequality to a single
-- constant `CÔéÇ Ôëñ simpleCloudSumNorm + smoothTailRationalLowerBoundAbsNorm`
-- ÔÇö independent of the small-y regime and easier to attack via
-- regional decomposition.
--
-- Adds:
--   simpleCloudSumNorm                            ÔÇö `╬ú 2/(x┬▓+╬│┬▓+y┬▓)`
--   smoothTailRationalLowerBoundAbsNorm           ÔÇö smooth LB / y
--   lowArithConst_11_14_half                       ÔÇö `17/242 ÔêÆ 9/392`
--   simpleCloudSum_eq_y_mul_norm                   ÔÇö y-factorization
--   smoothTailRationalLowerBoundAbs_eq_y_mul_norm  ÔÇö y-factorization
--   closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const  ÔÇö y-factorization
--   LowExplicitArithmeticBoundNorm_11_14_half      ÔÇö normalized Prop
--   LowExplicitArithmeticBound_11_14_half_of_norm  ÔÇö bridge from normalized

/-- **Normalized `simpleCloudSum`** ÔÇö divide out the leading `y` factor:
`╬ú 2/(x┬▓+╬│┬▓+y┬▓)`. -/
noncomputable def simpleCloudSumNorm (zeros : List ÔäØ) (x y : ÔäØ) : ÔäØ :=
  (zeros.map fun g => 2 / (x ^ 2 + g ^ 2 + y ^ 2)).sum

/-- **Normalized `smoothTailRationalLowerBoundAbs`** ÔÇö divide out the
leading `y` factor:
`¤ü(T) ┬À ((T ÔêÆ |x|)/((T ÔêÆ |x|)┬▓ + y┬▓) + (T + |x|)/((T + |x|)┬▓ + y┬▓))`. -/
noncomputable def smoothTailRationalLowerBoundAbsNorm (x y T : ÔäØ) : ÔäØ :=
  zeroDensityRho T *
    ((T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + (T + |x|) / ((T + |x|) ^ 2 + y ^ 2))

/-- **Path B arithmetic constant**: `closedFormFirstZeroErrorBound y 11 14 (1/2) = y ┬À lowArithConst_11_14_half`.
Equals `17/242 ÔêÆ 9/392 Ôëê 0.0473`. -/
noncomputable def lowArithConst_11_14_half : ÔäØ := 17 / 242 - 9 / 392

/-- Ô¡É **PROVED ÔÇö `simpleCloudSum` y-factorization.** -/
lemma simpleCloudSum_eq_y_mul_norm (zeros : List ÔäØ) (x y : ÔäØ) :
    simpleCloudSum zeros x y = y * simpleCloudSumNorm zeros x y := by
  unfold simpleCloudSum simpleCloudSumNorm
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    rw [ih]
    ring

/-- Ô¡É **PROVED ÔÇö `smoothTailRationalLowerBoundAbs` y-factorization.** -/
lemma smoothTailRationalLowerBoundAbs_eq_y_mul_norm (x y T : ÔäØ) :
    smoothTailRationalLowerBoundAbs x y T
      = y * smoothTailRationalLowerBoundAbsNorm x y T := by
  unfold smoothTailRationalLowerBoundAbs smoothTailRationalLowerBoundAbsNorm
