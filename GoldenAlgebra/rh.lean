-- =====================================================================
-- ┬зCDXXXVI. Completed-zeta off-pole raw formula source
-- =====================================================================

/-- ЁЯУж **`CompletedRiemannZetaRawOffPoleFormula`** тАФ Mathlib's
`completedRiemannZeta s = ╧А^(-s/2) ┬╖ ╬У(s/2) ┬╖ ╬╢(s)` away from ╬У poles. -/
structure CompletedRiemannZetaRawOffPoleFormula : Prop where
  eq_raw :
    тИА s : тДВ,
      s / 2 тИЙ gammaPoleSet тЖТ
      completedRiemannZeta s
        = Complex.exp (-(s / 2) * (Real.log Real.pi : тДВ))
          * Complex.Gamma (s / 2) * riemannZeta s

/-- тнР **PROVED тАФ off ╬У-poles implies `s тЙа 0`.** -/
theorem ne_zero_of_half_not_gammaPole
    {s : тДВ} (hsPole : s / 2 тИЙ gammaPoleSet) :
    s тЙа 0 := by
  intro hs
  apply hsPole
  rw [hs]
  exact тЯи0, by simpтЯй

/-- тнР **PROVED тАФ off ╬У-poles implies the Deligne ╬У-factor is nonzero.** -/
theorem GammaReal_ne_zero_of_half_not_gammaPole
    {s : тДВ} (hsPole : s / 2 тИЙ gammaPoleSet) :
    GammaтДЭ s тЙа 0 := by
  intro hG
  rcases Complex.GammaтДЭ_eq_zero_iff.mp hG with тЯиn, hnтЯй
  apply hsPole
  exact тЯиn, by rw [hn]; ringтЯй

/-- тнР **PROVED тАФ `GammaтДЭ` as the explicit exponential ╬У-factor.** -/
theorem GammaReal_eq_exp_gamma (s : тДВ) :
    GammaтДЭ s =
      Complex.exp (-(s / 2) * (Real.log Real.pi : тДВ))
        * Complex.Gamma (s / 2) := by
  rw [GammaтДЭ_def]
  congr 1
  rw [Complex.cpow_def_of_ne_zero]
  ┬╖ congr 1
    rw [Complex.ofReal_log Real.pi_pos.le]
    ring
  ┬╖ exact Complex.ofReal_ne_zero.mpr Real.pi_ne_zero

/-- ЁЯМЯЁЯМЯ **PROVED unconditionally** тАФ Mathlib's completed zeta is the
raw ╬У┬╖╬╢ expression off ╬У-poles. -/
theorem completedRiemannZetaRawOffPoleFormula :
    CompletedRiemannZetaRawOffPoleFormula := by
  refine тЯи?_тЯй
  intro s hsPole
  have hs0 : s тЙа 0 := ne_zero_of_half_not_gammaPole hsPole
  have hG : GammaтДЭ s тЙа 0 := GammaReal_ne_zero_of_half_not_gammaPole hsPole
  calc
    completedRiemannZeta s
        = GammaтДЭ s * riemannZeta s := by
            have hz := riemannZeta_def_of_ne_zero (s := s) hs0
            rw [hz]
            field_simp [hG]
    _ = Complex.exp (-(s / 2) * (Real.log Real.pi : тДВ))
          * Complex.Gamma (s / 2) * riemannZeta s := by
            rw [GammaReal_eq_exp_gamma]

