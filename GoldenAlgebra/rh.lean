  exact mul_le_mul_of_nonneg_left hinv h_pos_factor

/-- тнР **PROVED тАФ smooth-tail LB on `[32, 36]`** via constant ╧Б. -/
lemma smoothTail_ge_const_32_36
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hT32 : 32 тЙд T) (hT36 : T тЙд 36)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T) :
    y * tailK_32_36 T тЙд smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_32_36
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hT_2pi : 2 * Real.pi тЙд T := by linarith
  have hreg' : 2 * (1 + |x| + y) тЙд T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : ((8/5 : тДЭ) / (2 * Real.pi)) тЙд zeroDensityRho T :=
    zeroDensityRho_ge_const_32_36 hT32 hT36
  have h_22_15_nn : (0 : тДЭ) тЙд 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi))
      тЙд (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : тДЭ) тЙд y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi)) * y / T
        тЙд (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi)) * (y / T)
          = (22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : тДЭ) * zeroDensityRho T * (y / T)
          = (22 / 15 : тДЭ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : тДЭ) * zeroDensityRho T * y / T
                тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi)) / T)
      = (22 / 15 : тДЭ) * ((8/5 : тДЭ) / (2 * Real.pi)) * y / T := by ring
  rw [h_y_form]
  exact le_trans h_chain h_base

/-- тнР **PROVED тАФ closed-form upper bound on `[32, 36]`** at `(C, D) = (1/2, 1/2)`.
Collapses to `closedFormSErrorBoundHalfPlusHalf = (y/T┬▓)┬╖((17/2)┬╖log T + 43/4)`,
then bounds `log T тЙд 18/5` to get `(17/2)┬╖(18/5) + 43/4 = 827/20`. -/
lemma closedFormSErrorBoundCD_32_36_le_const
    {y T : тДЭ}
    (hy : 0 тЙд y) (hT32 : 32 тЙд T) (hT36 : T тЙд 36) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) (1 / 2 : тДЭ) y T
      тЙд y * ((827 / 20 : тДЭ) / T^2) := by
  have hTpos : 0 < T := by linarith
  have hT_ne : T тЙа 0 := ne_of_gt hTpos
  have hT2pos : 0 < T^2 := by positivity
  have hT_ge_one : (1 : тДЭ) тЙд T := by linarith
  have hlogT_nn : 0 тЙд Real.log T := Real.log_nonneg hT_ge_one
  have hlog_le : Real.log T тЙд 18/5 := log_T_le_18_5_on_32_36 hT32 hT36
  have hcoeff_le : (17/2 : тДЭ) * Real.log T + 43/4 тЙд 827/20 := by nlinarith
  rw [closedFormSErrorBoundCD_half_half_eq hT_ne]
  unfold closedFormSErrorBoundHalfPlusHalf
  have hz_nn : 0 тЙд y / T^2 := div_nonneg hy (le_of_lt hT2pos)
  calc (y / T^2) * ((17/2 : тДЭ) * Real.log T + 43/4)
        тЙд (y / T^2) * (827/20 : тДЭ) :=
          mul_le_mul_of_nonneg_left hcoeff_le hz_nn
      _ = y * ((827/20 : тДЭ) / T^2) := by ring

