/-! ### CW20: split strip-gap → LC into filter bridge + pointwise count constancy -/

/-- Pointwise count constancy under a strip zero gap: at every height
`u ∈ (T, T + ε]` such that no ζ-zero in the standard strip lies in
`(T, T + ε]`, the weighted count at `u` equals the count at `T`.  This
isolates the count-machinery/certificate content of the strip-gap bridge. -/
structure ZetaStripGapPointwiseCountConstancyInput : Prop where
  const_on_gap :
    ∀ T u ε : ℝ,
      (140 : ℝ) ≤ T → T < u → u ≤ T + ε → 0 < ε →
      (∀ ρ : ℂ,
        riemannZeta ρ = 0 →
        (-1 : ℝ) ≤ ρ.re → ρ.re ≤ 2 →
        T < ρ.im → ρ.im ≤ T + ε → False) →
      zetaWeightedZeroCountUpToHeightReal u =
        zetaWeightedZeroCountUpToHeightReal T

/-- **CW20 — filter bridge:** pointwise count constancy under a strip
zero gap implies the strip-gap → LC bridge.  Pure real-filter content;
the actual count-extensionality work is concentrated in `const_on_gap`. -/
noncomputable def
    ZetaStripGapPointwiseCountConstancyInput.toStripGapToLC
    (P : ZetaStripGapPointwiseCountConstancyInput) :
    ZetaStripGapToLocalConstancyInput where
  bridge := by
    intro G
    refine ⟨?_⟩
    intro T hT
    rcases G.exists_gap T hT with ⟨ε, hεpos, hgap⟩
    have hIoi :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), T < u :=
      self_mem_nhdsWithin
    have hIio :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), u < T + ε :=
      nhdsWithin_le_nhds (Iio_mem_nhds (by linarith : T < T + ε))
    have hEventually :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), T < u ∧ u ≤ T + ε := by
      filter_upwards [hIoi, hIio] with u h1 h2
      exact ⟨h1, le_of_lt h2⟩
    filter_upwards [hEventually] with u hu
    exact P.const_on_gap T u ε hT hu.1 hu.2 hεpos hgap

/-- **CW20 — sharper final theorem.**  Replaces the strip-gap → LC bridge
with the more focused pointwise count-constancy obligation. -/
theorem
    concreteS_halfLogPlusHalf_of_numericalExtraction_and_pointwiseCountConstancy
    (E : BacklundNumericalExtractionInput)
    (P : ZetaStripGapPointwiseCountConstancyInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction_and_stripGapBridge
    E P.toStripGapToLC hT

/-! ### CW21: reduce pointwise count constancy to set equality + count extensionality -/

/-- Pure-logic lemma: the set of nontrivial ζ-zeros up to height `u` agrees
with the set up to height `T` whenever `T < u ≤ T + ε` and no ζ-zero in
the Backlund strip slab `(T, T + ε]` exists.  Uses the nontriviality
conditions `0 < ρ.re < 1` to deduce the strip inclusion `-1 ≤ ρ.re ≤ 2`
needed by the gap hypothesis. -/
theorem zetaZerosUpToHeightSet_eq_of_strip_gap
    {T u ε : ℝ}
    (_hT : (140 : ℝ) ≤ T)
    (huT : T < u)
    (huε : u ≤ T + ε)
    (_hε : 0 < ε)
    (hgap :
      ∀ ρ : ℂ,
        riemannZeta ρ = 0 →
        (-1 : ℝ) ≤ ρ.re →
        ρ.re ≤ 2 →
        T < ρ.im →
        ρ.im ≤ T + ε →
        False) :
    zetaZerosUpToHeightSet u = zetaZerosUpToHeightSet T := by
  ext ρ
  constructor
  · intro hρu
    obtain ⟨⟨hzero, hre_pos, hre_lt_one⟩, him_pos, him_le_u⟩ := hρu
    by_cases hle : ρ.im ≤ T
    · exact ⟨⟨hzero, hre_pos, hre_lt_one⟩, him_pos, hle⟩
    · push_neg at hle
      have him_le_eps : ρ.im ≤ T + ε := le_trans him_le_u huε
      have hre_low : (-1 : ℝ) ≤ ρ.re := by linarith
      have hre_high : ρ.re ≤ 2 := by linarith
      exact (hgap ρ hzero hre_low hre_high hle him_le_eps).elim
  · intro hρT
    obtain ⟨nontriv, him_pos, him_le_T⟩ := hρT
    exact ⟨nontriv, him_pos, le_trans him_le_T (le_of_lt huT)⟩

/-- Extensionality input for the real-valued weighted zero count: if the
geometric zero set up to two heights is the same, then the counts agree.
Named anchor — proving it requires unfolding the certificate-based
`weightedZeroCountFromCertificate` chain (via `weightedZeroSetOfGlobalMultiplicity`
and `truncatedMultiplicity`). -/
structure ZetaWeightedCountExtensionalityInput : Prop where
  count_eq_of_set_eq :
    ∀ T U : ℝ,
      zetaZerosUpToHeightSet T = zetaZerosUpToHeightSet U →
        zetaWeightedZeroCountUpToHeightReal T =
          zetaWeightedZeroCountUpToHeightReal U

/-- **CW21 — bridge from count extensionality:** combining the strip-gap
set-equality lemma with the count-extensionality input discharges the
pointwise count-constancy obligation. -/
noncomputable def ZetaStripGapPointwiseCountConstancyInput.of_set_ext
    (Ext : ZetaWeightedCountExtensionalityInput) :
    ZetaStripGapPointwiseCountConstancyInput where
  const_on_gap := by
    intro T u ε hT huT huε hε hgap
    exact Ext.count_eq_of_set_eq u T
      (zetaZerosUpToHeightSet_eq_of_strip_gap hT huT huε hε hgap)

/-- **CW21 — sharper final theorem.**  Replaces the pointwise count
constancy obligation with the more focused count-extensionality input. -/
theorem
    concreteS_halfLogPlusHalf_of_numericalExtraction_and_countExtensionality
    (E : BacklundNumericalExtractionInput)
    (Ext : ZetaWeightedCountExtensionalityInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
