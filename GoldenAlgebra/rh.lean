/-- Ô¡É **PROVED ÔÇö Endpoint bound: `log(19/(2¤Ç)) ÔëÑ 11/10`.**
Chain: `exp 1 < 2.7182818286` ÔåÆ `(exp 1)^11 < 2.7182818286^11 Ôëñ (301/100)^10`
ÔåÆ `exp(11/10)^10 Ôëñ (301/100)^10` ÔåÆ `exp(11/10) Ôëñ 301/100`
ÔåÆ `301/100 Ôëñ 19/(2¤Ç)` via `¤Ç < 3.1416`. -/
lemma log_19_div_2pi_ge_11_10 :
    (11 / 10 : ÔäØ) Ôëñ Real.log (19 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.1416 := Real.pi_lt_d4
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_nn : 0 Ôëñ Real.exp 1 := le_of_lt h_exp_1_pos
  have h_exp_1_11_lt : (Real.exp 1)^11 < (2.7182818286 : ÔäØ)^11 :=
    pow_lt_pow_leftÔéÇ h_exp_1_lt h_exp_1_nn (by norm_num)
  have h_27_le_301 : (2.7182818286 : ÔäØ)^11 Ôëñ (301/100 : ÔäØ)^10 := by norm_num
  have h_exp_1_11_le : (Real.exp 1)^11 Ôëñ (301/100 : ÔäØ)^10 := by linarith
  have h_exp_11_eq : Real.exp 11 = (Real.exp 1)^11 := by
    have h := Real.exp_one_pow 11
    have h_cast : ((11 : Ôäò) : ÔäØ) = (11 : ÔäØ) := by norm_num
    rw [ÔåÉ h_cast]; exact h.symm
  have h_exp_11_10_pow : (Real.exp (11/10 : ÔäØ))^10 = Real.exp 11 := by
    have h := Real.exp_nat_mul (11/10 : ÔäØ) 10
    have h_eq : ((10 : Ôäò) : ÔäØ) * (11/10 : ÔäØ) = 11 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_exp_11_le : Real.exp 11 Ôëñ (301/100 : ÔäØ)^10 := h_exp_11_eq Ôû© h_exp_1_11_le
  have h_exp_11_10_le : Real.exp (11/10 : ÔäØ) Ôëñ 301/100 := by
    have h_pow_10_le : (Real.exp (11/10 : ÔäØ))^10 Ôëñ (301/100 : ÔäØ)^10 :=
      h_exp_11_10_pow Ôû© h_exp_11_le
    have h_exp_pos : 0 Ôëñ Real.exp (11/10 : ÔäØ) := le_of_lt (Real.exp_pos _)
    have h_301_pos : (0 : ÔäØ) Ôëñ 301/100 := by norm_num
    exact (pow_le_pow_iff_leftÔéÇ h_exp_pos h_301_pos
              (by norm_num : (10 : Ôäò) Ôëá 0)).mp h_pow_10_le
  have h_301_le_192pi : (301/100 : ÔäØ) Ôëñ 19 / (2 * Real.pi) := by
    rw [le_div_iffÔéÇ h_2pi_pos]
    nlinarith
  have h_exp_11_10_le_192pi : Real.exp (11/10 : ÔäØ) Ôëñ 19 / (2 * Real.pi) :=
    le_trans h_exp_11_10_le h_301_le_192pi
  have h_exp_pos : 0 < Real.exp (11/10 : ÔäØ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_11_10_le_192pi
  rwa [Real.log_exp] at h

/-- Ô¡É **PROVED ÔÇö Endpoint bound: `log(32/(2¤Ç)) ÔëÑ 8/5`.**
Chain: `(exp 1)^8 < 2.7182818286^8 Ôëñ 5^5` ÔåÆ `exp(8/5) Ôëñ 5`
ÔåÆ `5 Ôëñ 32/(2¤Ç)` via `¤Ç < 3.15`. -/
lemma log_32_div_2pi_ge_8_5 :
    (8 / 5 : ÔäØ) Ôëñ Real.log (32 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_nn : 0 Ôëñ Real.exp 1 := le_of_lt h_exp_1_pos
  have h_exp_1_8_lt : (Real.exp 1)^8 < (2.7182818286 : ÔäØ)^8 :=
    pow_lt_pow_leftÔéÇ h_exp_1_lt h_exp_1_nn (by norm_num)
  have h_27_le_5 : (2.7182818286 : ÔäØ)^8 Ôëñ (5 : ÔäØ)^5 := by norm_num
  have h_exp_1_8_le : (Real.exp 1)^8 Ôëñ (5 : ÔäØ)^5 := by linarith
  have h_exp_8_eq : Real.exp 8 = (Real.exp 1)^8 := by
    have h := Real.exp_one_pow 8
    have h_cast : ((8 : Ôäò) : ÔäØ) = (8 : ÔäØ) := by norm_num
    rw [ÔåÉ h_cast]; exact h.symm
  have h_exp_8_5_pow : (Real.exp (8/5 : ÔäØ))^5 = Real.exp 8 := by
    have h := Real.exp_nat_mul (8/5 : ÔäØ) 5
    have h_eq : ((5 : Ôäò) : ÔäØ) * (8/5 : ÔäØ) = 8 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_exp_8_le : Real.exp 8 Ôëñ (5 : ÔäØ)^5 := h_exp_8_eq Ôû© h_exp_1_8_le
  have h_exp_8_5_le : Real.exp (8/5 : ÔäØ) Ôëñ 5 := by
    have h_pow_5_le : (Real.exp (8/5 : ÔäØ))^5 Ôëñ (5 : ÔäØ)^5 :=
      h_exp_8_5_pow Ôû© h_exp_8_le
    have h_exp_pos : 0 Ôëñ Real.exp (8/5 : ÔäØ) := le_of_lt (Real.exp_pos _)
    have h_5_pos : (0 : ÔäØ) Ôëñ 5 := by norm_num
    exact (pow_le_pow_iff_leftÔéÇ h_exp_pos h_5_pos
              (by norm_num : (5 : Ôäò) Ôëá 0)).mp h_pow_5_le
  have h_5_le_322pi : (5 : ÔäØ) Ôëñ 32 / (2 * Real.pi) := by
    rw [le_div_iffÔéÇ h_2pi_pos]
    nlinarith
  have h_exp_8_5_le_322pi : Real.exp (8/5 : ÔäØ) Ôëñ 32 / (2 * Real.pi) :=
    le_trans h_exp_8_5_le h_5_le_322pi
  have h_exp_pos : 0 < Real.exp (8/5 : ÔäØ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_8_5_le_322pi
  rwa [Real.log_exp] at h

/-- **Helper def**: affine log lower bound on `[19, 32]`. -/
noncomputable def logAffine_19_32 (T : ÔäØ) : ÔäØ :=
  (11 / 10 : ÔäØ) + (T - 19) / 26

/-- Ô¡É **PROVED ÔÇö Affine LB for `log(T/(2¤Ç))` on `[19, 32]`.**
At T=19 gives 11/10; at T=32 gives 11/10 + 13/26 = 8/5. Via `Real.secant_le_log`. -/
lemma log_T_over_2pi_ge_affine_19_32
    {T : ÔäØ} (hT19 : 19 Ôëñ T) (hT32 : T Ôëñ 32) :
    logAffine_19_32 T Ôëñ Real.log (T / (2 * Real.pi)) := by
  unfold logAffine_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h_2pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have h19pos : (0 : ÔäØ) < 19 := by norm_num
  have h_19_lt_32 : (19 : ÔäØ) < 32 := by norm_num
  have h_secant := Real.secant_le_log h19pos h_19_lt_32 hT19 hT32
  have h_div_19 : ((32 - T) / (32 - 19) : ÔäØ) = (32 - T) / 13 := by norm_num
  have h_div_T19 : ((T - 19) / (32 - 19) : ÔäØ) = (T - 19) / 13 := by norm_num
  rw [h_div_19, h_div_T19] at h_secant
  have h_log_T_div : Real.log (T / (2 * Real.pi)) = Real.log T - Real.log (2 * Real.pi) :=
    Real.log_div hT_ne h_2pi_ne
  have h_log_19_div : Real.log (19 / (2 * Real.pi)) = Real.log 19 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (19 : ÔäØ) Ôëá 0) h_2pi_ne
  have h_log_32_div : Real.log (32 / (2 * Real.pi)) = Real.log 32 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (32 : ÔäØ) Ôëá 0) h_2pi_ne
  have h19 := log_19_div_2pi_ge_11_10
  have h32 := log_32_div_2pi_ge_8_5
  rw [h_log_19_div] at h19
  rw [h_log_32_div] at h32
  have h32mT_nn : 0 Ôëñ 32 - T := by linarith
  have hTm19_nn : 0 Ôëñ T - 19 := by linarith
  rw [h_log_T_div]
  nlinarith [h_secant, h19, h32, h32mT_nn, hTm19_nn]

/-- Ô¡É **PROVED ÔÇö Affine LB for `zeroDensityRho` on `[19, 32]`.** -/
lemma zeroDensityRho_ge_affine_19_32
    {T : ÔäØ} (hT19 : 19 Ôëñ T) (hT32 : T Ôëñ 32) :
    logAffine_19_32 T / (2 * Real.pi) Ôëñ zeroDensityRho T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_log_ge := log_T_over_2pi_ge_affine_19_32 hT19 hT32
  rw [show (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        = Real.log (T / (2 * Real.pi)) / (2 * Real.pi) by ring]
  apply div_le_div_of_nonneg_right h_log_ge (le_of_lt h_2pi_pos)

/-- **Helper def**: `tailK_19_32 T = (22/15) ┬À (logAffine/(2¤Ç)) / T`. -/
noncomputable def tailK_19_32 (T : ÔäØ) : ÔäØ :=
  (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) / T

/-- **Helper def**: rational tail using `1/(2¤Ç) ÔëÑ 7/44`. -/
noncomputable def tailK19_rat (T : ÔäØ) : ÔäØ :=
  (22 / 15 : ÔäØ) * logAffine_19_32 T * (7 / 44) / T

/-- Ô¡É **PROVED ÔÇö `tailK19_rat T Ôëñ tailK_19_32 T` on `[19, 32]`.** -/
lemma tailK19_rat_le_tailK_19_32
    {T : ÔäØ} (hT19 : 19 Ôëñ T) (_hT32 : T Ôëñ 32) :
    tailK19_rat T Ôëñ tailK_19_32 T := by
  unfold tailK19_rat tailK_19_32 logAffine_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have h_pi_inv : (7 / 44 : ÔäØ) Ôëñ 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_aff_nn : (0 : ÔäØ) Ôëñ (11 / 10 : ÔäØ) + (T - 19) / 26 := by linarith
  have h_factor_nn : (0 : ÔäØ) Ôëñ (22 / 15 : ÔäØ) * ((11 / 10 : ÔäØ) + (T - 19) / 26) := by
    positivity
  have h_step1 :
      (22 / 15 : ÔäØ) * ((11 / 10 : ÔäØ) + (T - 19) / 26) * (7 / 44)
        Ôëñ (22 / 15 : ÔäØ) * ((11 / 10 : ÔäØ) + (T - 19) / 26) * (1 / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_pi_inv h_factor_nn
  have h_form_eq :
      (22 / 15 : ÔäØ) * (((11 / 10 : ÔäØ) + (T - 19) / 26) / (2 * Real.pi)) / T
        = (22 / 15 : ÔäØ) * ((11 / 10 : ÔäØ) + (T - 19) / 26) * (1 / (2 * Real.pi)) / T := by
    ring
  rw [h_form_eq]
  apply div_le_div_of_nonneg_right h_step1 (le_of_lt hT_pos)

/-- Ô¡É **PROVED ÔÇö smooth-tail LB on `[19, 32]`** via affine ¤ü. -/
lemma smoothTail_ge_affine_19_32
    {x y T : ÔäØ}
    (hx : 0 Ôëñ x) (hT19 : 19 Ôëñ T) (hT32 : T Ôëñ 32)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) Ôëñ T) :
    y * tailK_19_32 T Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hT_2pi : 2 * Real.pi Ôëñ T := by linarith
  have hreg' : 2 * (1 + |x| + y) Ôëñ T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : logAffine_19_32 T / (2 * Real.pi) Ôëñ zeroDensityRho T :=
    zeroDensityRho_ge_affine_19_32 hT19 hT32
  have h_22_15_nn : (0 : ÔäØ) Ôëñ 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi))
      Ôëñ (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : ÔäØ) Ôëñ y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T
        Ôëñ (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) * (y / T)
          = (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : ÔäØ) * zeroDensityRho T * (y / T)
          = (22 / 15 : ÔäØ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : ÔäØ) * zeroDensityRho T * y / T
                Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) / T)
      = (22 / 15 : ÔäØ) * (logAffine_19_32 T / (2 * Real.pi)) * y / T := by ring
  rw [h_y_form]
  exact le_trans h_chain h_base

/-- Ô¡É **PROVED ÔÇö `cloudK_T` is anti-monotone in `T`** on positive box. -/
lemma cloudK_T_antitone_T (zeros : List ÔäØ) {TÔéü TÔéé : ÔäØ}
    (h_TÔéü_pos : 0 < TÔéü / 2 - 1) (h_T_le : TÔéü Ôëñ TÔéé) :
    cloudK_T zeros TÔéé Ôëñ cloudK_T zeros TÔéü := by
  unfold cloudK_T
  apply List.sum_le_sum
  intro ╬│ _h╬│
  have h_TÔéé_pos : 0 < TÔéé / 2 - 1 := by linarith
  have h_sq_le : (TÔéü / 2 - 1)^2 Ôëñ (TÔéé / 2 - 1)^2 :=
    sq_le_sq' (by linarith) (by linarith)
  have h_den_le : (TÔéü / 2 - 1)^2 + ╬│^2 Ôëñ (TÔéé / 2 - 1)^2 + ╬│^2 := by linarith
  have h_TÔéü_box_pos : 0 < (TÔéü / 2 - 1)^2 + ╬│^2 := by
    have hsq : 0 < (TÔéü / 2 - 1)^2 := pow_pos h_TÔéü_pos 2
    nlinarith [sq_nonneg ╬│]
  exact one_div_le_one_div_of_le h_TÔéü_box_pos h_den_le

/-- Ô¡É **PROVED ÔÇö `tailK19_rat` is anti-monotone in `T`** on `[19, 32]`. -/
lemma tailK19_rat_antitone_T {TÔéü TÔéé : ÔäØ}
    (hTÔéü_19 : 19 Ôëñ TÔéü) (_hTÔéé_32 : TÔéé Ôëñ 32) (h_T_le : TÔéü Ôëñ TÔéé) :
    tailK19_rat TÔéé Ôëñ tailK19_rat TÔéü := by
