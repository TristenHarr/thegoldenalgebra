    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (ZC : вДВ вЖТ вДВ) : Prop where
  low_value :
    вИА z : вДВ,
      lowCompactRegion z вЖТ
      (ZC z -
          (cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- рЯМЯрЯМЯ **PROVED вАФ `ZeroContributionStieltjesFormula` from tail + low
data.** -/
theorem ZeroContributionStieltjesFormula_of_tail_low_data
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : вДЭ} {ZC : вДВ вЖТ вДВ}
