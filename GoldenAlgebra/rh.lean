  have hlogT_nn : 0 ≤ Real.log T := Real.log_nonneg hT_ge_one
  have hlog_le : Real.log T ≤ 5 := log_T_le_5_of_le_140 hTpos hT140
  have hcoeff_le : (17/2 : ℝ) * Real.log T + 439/10 ≤ 432/5 := by nlinarith
