-- =====================================================================
-- CLXXXVb: Per-window global error control + 3-band dispatcher
-- =====================================================================
-- Following the file's `[2¤Ç,10] / [10,140] / [140,Ôê×)` band structure,
-- this section defines `PerWindowGlobalErrorControl` (bundle of low/mid/high
-- hypotheses) and proves the dispatcher `errorMargin_of_globalErrorControl`
-- that picks the right band by case-splitting on `T`. The mid band is
-- the slab cert (already proved); low and high are still hypothesis
-- placeholders for the Phase1IBP / first-zero / large-T analytic work.

/-- **Per-window global error control.** Bundles the three band-specific
error-margin hypotheses needed for global covering:
- `low`: `[2¤Ç, 10]` band ÔÇö first-zero / `NÔéÇ` control;
- `mid`: `[10, 140]` band ÔÇö the slab cert via `closedFormErrorControlledOnFiniteBand`;
- `high`: `[140, Ôê×)` band ÔÇö large-T smooth-tail domination. -/
structure PerWindowGlobalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (error : Ôäé ÔåÆ Ôäé) where
  low : ÔêÇ {z : Ôäé} {T : ÔäØ},
    2 * Real.pi Ôëñ T ÔåÆ T Ôëñ 10 ÔåÆ
    0 < z.im ÔåÆ
    2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      |(error z).im| Ôëñ -(M.model z).im
  mid : closedFormErrorControlledOnFiniteBand error
  high : ÔêÇ {z : Ôäé} {T : ÔäØ},
    140 Ôëñ T ÔåÆ
    0 < z.im ÔåÆ
    2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      |(error z).im| Ôëñ -(M.model z).im

/-- ­ƒÄ» **PROVED ÔÇö Per-window dispatcher.** From the bundled
`PerWindowGlobalErrorControl`, picks the right band by case-splitting
on `T`. Uses `finiteBand_errorMargin_of_slabCD` in the mid band. -/
theorem errorMargin_of_globalErrorControl
    {M : CloudDensityTailModelDecomposition}
    {error : Ôäé ÔåÆ Ôäé}
    (hzeros : M.zeros = zeros100ceil)
    (H : PerWindowGlobalErrorControl M error)
    {z : Ôäé} {T : ÔäØ}
    (hT2pi : 2 * Real.pi Ôëñ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    |(error z).im| Ôëñ -(M.model z).im := by
  by_cases hT10 : T Ôëñ 10
  ┬À exact H.low hT2pi hT10 hy hreg
  ┬À push_neg at hT10
    have hT10_le : (10 : ÔäØ) Ôëñ T := le_of_lt hT10
    by_cases hT140 : T Ôëñ 140
    ┬À exact finiteBand_errorMargin_of_slabCD
        (M := M) (error := error)
        hzeros H.mid hT10_le hT140 hy hreg
    ┬À push_neg at hT140
      have hT140_le : (140 : ÔäØ) Ôëñ T := le_of_lt hT140
      exact H.high hT140_le hy hreg

/-- ­ƒÄ» **PROVED ÔÇö Per-window local-package constructor.** Given a chosen
region containing only points admissible at some `T`, produces a
`LocalXiCloudDensityErrorPackage`. The dispatched error-margin proof
comes from `errorMargin_of_globalErrorControl`. -/
noncomputable def localPackage_of_globalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : Ôäé ÔåÆ Ôäé)
    (region : Ôäé ÔåÆ Prop)
    (hregT : ÔêÇ z : Ôäé, region z ÔåÆ
        Ôêâ T : ÔäØ, 2 * Real.pi Ôëñ T Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T)
    (hdecomp : ÔêÇ z : Ôäé, region z ÔåÆ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (H : PerWindowGlobalErrorControl M error) :
    LocalXiCloudDensityErrorPackage :=
  { model := M.model
    error := error
    region := region
    decomp := hdecomp
    modelAnti := hmodelAnti
    errorMargin := by
      intro z hreg hz
      obtain Ôƒ¿T, hT2pi, hregT_valÔƒ® := hregT z hreg
      exact errorMargin_of_globalErrorControl
        (M := M) (error := error)
        hM_zeros H hT2pi hz hregT_val }

-- =====================================================================
-- CLXXXVc: High-range `[140, Ôê×)` margin bridge
-- =====================================================================
-- The high-T analogue of `slabCD`. Uses the existing `proved_numerics_22_15_at_140`
-- + `largeTScalarConditionTwentyTwoFifteenths_implies_domination` chain.
-- Output: a deterministic closed-form bound + `le_trans`-style adapter so
-- the high field of `PerWindowGlobalErrorControl` has a clean landing pad.

/-- **Deterministic high-`T` closed-form bound.** At all `T ÔëÑ 140` we know
the closed form at `(C, D) = (1/2, 49/20)` is dominated by
`smoothTailRationalLowerBoundAbs`, which in turn is bounded by `-Im(densityTail)`. -/
noncomputable def highTClosedFormBound (y T : ÔäØ) : ÔäØ :=
  closedFormSErrorBoundCD (1 / 2) (49 / 20) y T

/-- Ô¡É **PROVED ÔÇö High-`T` closed-form bound dominates `-Im(M.model)`** for
`T ÔëÑ 140` and `M.zeros = zeros100ceil`. Chain:

`highTClosedFormBound = closedFormSErrorBoundCD (1/2) (49/20)`
  `Ôëñ smoothTailRationalLowerBoundAbs`  (via `largeTScalarÔÇª_implies_domination`
                                          + `proved_numerics_22_15_at_140`)
  `Ôëñ -(densityTail).im`                (via `M.densityTailRationalLB`)
  `Ôëñ -(densityTail).im + -(cloud).im = -(model).im` (cloud anti-Herglotz). -/
theorem highTClosedFormBound_le_neg_model_im
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    {z : Ôäé} {T : ÔäØ}
    (hT140 : 140 Ôëñ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    highTClosedFormBound z.im T Ôëñ -(M.model z).im := by
  unfold highTClosedFormBound
  have hscalar : largeTScalarMarginConditionTwentyTwoFifteenths T :=
    largeTScalarMarginConditionTwentyTwoFifteenths_of_ge_140_from_numerics
      proved_numerics_22_15_at_140 hT140
  have h_dom :
      closedFormSErrorBoundCD (1 / 2 : ÔäØ) (49 / 20 : ÔäØ) z.im T
        Ôëñ smoothTailRationalLowerBoundAbs z.re z.im T :=
    largeTScalarConditionTwentyTwoFifteenths_implies_domination hT140 hy hreg hscalar
  have hT_2pi : 2 * Real.pi Ôëñ T := by
    have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_tail_lb :
      smoothTailRationalLowerBoundAbs z.re z.im T Ôëñ -(M.densityTail z).im :=
    M.densityTailRationalLB z T hT_2pi hy hreg
  have h_model : M.model z = cloudModel M.zeros z + M.densityTail z := rfl
  have h_model' : M.model z = cloudModel zeros100ceil z + M.densityTail z := by
    rw [h_model, hM_zeros]
  have h_cloud_im_nonpos : (cloudModel zeros100ceil z).im Ôëñ 0 :=
    cloudModel_im_nonpos _ hy
  have h_model_im :
      -(M.model z).im = -(cloudModel zeros100ceil z).im + -(M.densityTail z).im := by
    rw [h_model', Complex.add_im]; ring
  linarith [h_dom, h_tail_lb, h_cloud_im_nonpos, h_model_im]

/-- **High-`T` closed-form error control.** The IBP/large-T-side
hypothesis: `|Im(error z)| Ôëñ highTClosedFormBound z.im T` on `[140, Ôê×)`. -/
def highTErrorControlled (error : Ôäé ÔåÆ Ôäé) : Prop :=
  ÔêÇ {z : Ôäé} {T : ÔäØ},
    140 Ôëñ T ÔåÆ
