/-- A local count/main-term slab certificate for the remaining concrete
finite band.  On one slab `[A, B]`, the weighted zero count is fixed at
`count`, while the smooth Riemann--von Mangoldt main term is squeezed
between `mainLower` and `mainUpper`.  The two endpoint inequalities are
exactly the arithmetic needed to prove the uniform `2.5167` bound for
`concreteS`. -/
structure BacklundCountMainSlabCertificate where
  A : вДЭ
  B : вДЭ
  count : вДХ
  mainLower : вДЭ
  mainUpper : вДЭ
  count_eq :
    вИА (T : вДЭ) (hT0 : 0 вЙ§ T), A вЙ§ T вЖТ T вЙ§ B вЖТ
      zetaWeightedZeroCountUpToHeight T hT0 = count
  main_bounds :
    вИА T : вДЭ, A вЙ§ T вЖТ T вЙ§ B вЖТ
      mainLower вЙ§ smoothMainTerm T вИІ smoothMainTerm T вЙ§ mainUpper
  count_minus_lower_le :
    (count : вДЭ) - mainLower вЙ§ (25167 / 10000 : вДЭ)
  upper_minus_count_le :
    mainUpper - (count : вДЭ) вЙ§ (25167 / 10000 : вДЭ)

/-- A count/main-term slab certificate gives the uniform `2.5167` bound
on its slab. -/
theorem BacklundCountMainSlabCertificate.uniform25167
    (S : BacklundCountMainSlabCertificate)
    {T : вДЭ} (hT0 : 0 вЙ§ T) (hA : S.A вЙ§ T) (hB : T вЙ§ S.B) :
    |concreteS T| вЙ§ (25167 / 10000 : вДЭ) := by
  have hcount := S.count_eq T hT0 hA hB
  have hcount_real :
      (zetaWeightedZeroCountUpToHeight T hT0 : вДЭ) = (S.count : вДЭ) := by
    exact_mod_cast hcount
  have hmain := S.main_bounds T hA hB
  have h_upper :
      smoothMainTerm T - (S.count : вДЭ) вЙ§ (25167 / 10000 : вДЭ) := by
    linarith [hmain.2, S.upper_minus_count_le]
  have h_lower :
      (S.count : вДЭ) - smoothMainTerm T вЙ§ (25167 / 10000 : вДЭ) := by
    linarith [hmain.1, S.count_minus_lower_le]
  rw [concreteS_eq_weighted_count_sub_smoothMainTerm hT0, hcount_real]
  rw [abs_le]
  constructor
  ¬Ј linarith
  ¬Ј exact h_lower

/-- A count-range/main-term slab certificate for the remaining concrete
finite band.  Unlike `BacklundCountMainSlabCertificate`, this version
allows zero jumps inside the slab by bounding the cumulative weighted
zero count between two endpoint counts. -/
structure BacklundCountRangeMainSlabCertificate where
  A : вДЭ
  B : вДЭ
  countLower : вДХ
  countUpper : вДХ
  mainLower : вДЭ
  mainUpper : вДЭ
  count_bounds :
    вИА (T : вДЭ) (hT0 : 0 вЙ§ T), A вЙ§ T вЖТ T вЙ§ B вЖТ
      countLower вЙ§ zetaWeightedZeroCountUpToHeight T hT0 вИІ
        zetaWeightedZeroCountUpToHeight T hT0 вЙ§ countUpper
  main_bounds :
    вИА T : вДЭ, A вЙ§ T вЖТ T вЙ§ B вЖТ
      mainLower вЙ§ smoothMainTerm T вИІ smoothMainTerm T вЙ§ mainUpper
  upperCount_minus_lowerMain_le :
    (countUpper : вДЭ) - mainLower вЙ§ (25167 / 10000 : вДЭ)
  upperMain_minus_lowerCount_le :
    mainUpper - (countLower : вДЭ) вЙ§ (25167 / 10000 : вДЭ)

/-- A count-range/main-term slab certificate gives the uniform `2.5167`
bound on its slab. -/
theorem BacklundCountRangeMainSlabCertificate.uniform25167
    (S : BacklundCountRangeMainSlabCertificate)
    {T : вДЭ} (hT0 : 0 вЙ§ T) (hA : S.A вЙ§ T) (hB : T вЙ§ S.B) :
    |concreteS T| вЙ§ (25167 / 10000 : вДЭ) := by
  have hcount := S.count_bounds T hT0 hA hB
  have hmain := S.main_bounds T hA hB
  have h_upper :
      (zetaWeightedZeroCountUpToHeight T hT0 : вДЭ) - smoothMainTerm T
        вЙ§ (25167 / 10000 : вДЭ) := by
    have hcount_upper :
        (zetaWeightedZeroCountUpToHeight T hT0 : вДЭ)
          вЙ§ (S.countUpper : вДЭ) := by
      exact_mod_cast hcount.2
    linarith [hcount_upper, hmain.1, S.upperCount_minus_lowerMain_le]
  have h_lower :
      smoothMainTerm T - (zetaWeightedZeroCountUpToHeight T hT0 : вДЭ)
        вЙ§ (25167 / 10000 : вДЭ) := by
    have hcount_lower :
        (S.countLower : вДЭ)
          вЙ§ (zetaWeightedZeroCountUpToHeight T hT0 : вДЭ) := by
      exact_mod_cast hcount.1
    linarith [hcount_lower, hmain.2, S.upperMain_minus_lowerCount_le]
  rw [concreteS_eq_weighted_count_sub_smoothMainTerm hT0]
  rw [abs_le]
  constructor
  ¬Ј linarith
  ¬Ј exact h_upper

