`u z тЙа 0`, `u` is differentiable at `z`, then `logDeriv f z` splits into the
pole term `m / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_factorization
    {f u : тДВ тЖТ тДВ} {s z : тДВ} {m : тДХ}
    (hm : 0 < m)
    (hz : z тЙа s)
    (hu : u z тЙа 0)
    (hu_diff : DifferentiableAt тДВ u z)
    (hf : f =с╢а[ЁЭУЭ z] fun w : тДВ => (w - s) ^ m * u w) :
    logDeriv f z = (m : тДВ) / (z - s) + logDeriv u z := by
  have h_pow_diff : DifferentiableAt тДВ (fun w : тДВ => (w - s) ^ m) z := by
    fun_prop
  have h_pow_ne : (z - s) ^ m тЙа 0 := pow_ne_zero m (sub_ne_zero.mpr hz)
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : тДВ => (w - s) ^ m * u w) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_mul z h_pow_ne hu h_pow_diff hu_diff,
      logDeriv_pow_sub hm hz]

/-! ### AK1: continuous principal part from analytic zero factorization -/

/-- A local analytic zero factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = m/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_factorization
    {f : тДВ тЖТ тДВ} {s : тДВ} {m : тДХ}
    (hm_pos : 0 < m)
    (H : HasAnalyticZeroFactorization f s m) :
    HasLogDerivPrincipalPartContinuous f s (m : тДд) := by
  set u : тДВ тЖТ тДВ := H.unit with hu_def
  have hu_an : AnalyticAt тДВ u s := H.unit_analytic
  have hu_ne_s : u s тЙа 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : тИАс╢а z in ЁЭУЭ s, u z тЙа 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : тИАс╢а z in ЁЭУЭ s, DifferentiableAt тДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hfac_eventually_nhds :
      тИАс╢а z in ЁЭУЭ s, f =с╢а[ЁЭУЭ z] fun w : тДВ => (w - s) ^ m * u w :=
    H.factorization.eventually_nhds
  have hu_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, u z тЙа 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, DifferentiableAt тДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hfac_punct :
      тИАс╢а z in ЁЭУЭ[тЙа] s, f =с╢а[ЁЭУЭ z] fun w : тДВ => (w - s) ^ m * u w :=
    hfac_eventually_nhds.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, z тЙа s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine тЯиlogDeriv u, ?_, ?_тЯй
  ┬╖ show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  ┬╖ filter_upwards [hfac_punct, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (m : тДВ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_factorization hm_pos hz_ne_z huz hu_diff_z hfz
    have hcast : ((m : тДд) : тДВ) = (m : тДВ) := by push_cast; rfl
    rw [hcast]
    exact hmain

/-- At a nontrivial zeta zero, `╬╢'/╬╢` has principal coefficient equal to the
analytic multiplicity, with continuous remainder. -/
theorem zetaLogDeriv_principalPartContinuous_at_nontrivial_zero
    {s : тДВ} (hs : IsNontrivialZetaZero s) :
    HasLogDerivPrincipalPartContinuous
      riemannZeta s
      (zetaGlobalZeroMultiplicity.mult s : тДд) :=
  hasLogDerivPrincipalPartContinuous_of_factorization
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaAnalyticZeroFactorization hs)

/-! ### AL1: simple-pole factorization interface -/

/-- Local factorization of a function with a simple pole at `s`:
on a punctured neighborhood of `s`, the function equals `unit z / (z - s)`
where `unit` is analytic and nonzero at `s`.

The factorization is stated in the *local* form so that derivative
identities (which need `=с╢а[ЁЭУЭ z]`) compose cleanly without an extra
upgrade lemma. -/
structure HasSimplePoleFactorization (f : тДВ тЖТ тДВ) (s : тДВ) where
  unit : тДВ тЖТ тДВ
  unit_analytic : AnalyticAt тДВ unit s
  unit_ne_zero : unit s тЙа 0
  factorization_local :
    тИАс╢а z in ЁЭУЭ[тЙа] s,
      f =с╢а[ЁЭУЭ z] fun w : тДВ => unit w / (w - s)

/-! ### AL2: log-derivative under simple-pole product factorization -/

/-- If `f` agrees with `u w / (w - s)` on a neighborhood of `z`, and
`z тЙа s`, `u z тЙа 0`, `u` is differentiable at `z`, then the logarithmic
derivative splits into the pole term `-1 / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_simplePoleFactorization
    {f u : тДВ тЖТ тДВ} {s z : тДВ}
    (hz : z тЙа s)
    (hu : u z тЙа 0)
    (hu_diff : DifferentiableAt тДВ u z)
    (hf : f =с╢а[ЁЭУЭ z] fun w : тДВ => u w / (w - s)) :
    logDeriv f z = (-1 : тДВ) / (z - s) + logDeriv u z := by
  have hzs_ne : z - s тЙа 0 := sub_ne_zero.mpr hz
  have hsub_diff : DifferentiableAt тДВ (fun w : тДВ => w - s) z := by fun_prop
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : тДВ => u w / (w - s)) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_div z hu hzs_ne hu_diff hsub_diff]
  have h_sub_log :
      logDeriv (fun w : тДВ => w - s) z = (1 : тДВ) / (z - s) := by
    have h := logDeriv_pow_sub (m := 1) (s := s) (z := z) (by norm_num) hz
    simpa [pow_one] using h
  rw [h_sub_log]
  ring

/-! ### AL3: continuous principal part from simple-pole factorization -/

/-- A local simple-pole factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = -1/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization
    {f : тДВ тЖТ тДВ} {s : тДВ}
    (H : HasSimplePoleFactorization f s) :
    HasLogDerivPrincipalPartContinuous f s (-1) := by
  set u : тДВ тЖТ тДВ := H.unit with hu_def
  have hu_an : AnalyticAt тДВ u s := H.unit_analytic
  have hu_ne_s : u s тЙа 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : тИАс╢а z in ЁЭУЭ s, u z тЙа 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : тИАс╢а z in ЁЭУЭ s, DifferentiableAt тДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hu_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, u z тЙа 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, DifferentiableAt тДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, z тЙа s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine тЯиlogDeriv u, ?_, ?_тЯй
  ┬╖ show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  ┬╖ filter_upwards
      [H.factorization_local, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (-1 : тДВ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_simplePoleFactorization
        hz_ne_z huz hu_diff_z hfz
    have hcast : ((-1 : тДд) : тДВ) = (-1 : тДВ) := by push_cast; rfl
    rw [hcast]
    exact hmain

/-- Conditional theorem: if `riemannZeta` admits a simple-pole factorization
at `1`, then `╬╢'/╬╢` has principal-part `-1 / (z - 1)` with continuous
remainder. -/
theorem zetaLogDeriv_principalPartContinuous_at_one
    (H : HasSimplePoleFactorization riemannZeta (1 : тДВ)) :
    HasLogDerivPrincipalPartContinuous riemannZeta (1 : тДВ) (-1) :=
  hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization H

/-! ### AM1: removable extension of `(z-1)┬╖╬╢(z)` at the pole -/

/-- The removable extension of `(z - 1) * ╬╢(z)` at the pole `z = 1`.
Away from `1`, equal to `(z - 1) * ╬╢(z)`; at `1`, defined to be `1`,
matching `riemannZeta_residue_one`. -/
noncomputable def riemannZetaPoleUnit (z : тДВ) : тДВ :=
  if z = (1 : тДВ) then 1 else (z - 1) * riemannZeta z

@[simp] theorem riemannZetaPoleUnit_one :
    riemannZetaPoleUnit (1 : тДВ) = 1 := by
  unfold riemannZetaPoleUnit; simp

theorem riemannZetaPoleUnit_eq_of_ne_one
    {z : тДВ} (hz : z тЙа (1 : тДВ)) :
    riemannZetaPoleUnit z = (z - 1) * riemannZeta z := by
  unfold riemannZetaPoleUnit; simp [hz]

/-! ### AM2: punctured-neighborhood factorization -/

/-- On the punctured neighborhood of `1`, `riemannZeta z = riemannZetaPoleUnit z / (z - 1)`. -/
theorem riemannZeta_eventuallyEq_poleUnit_div :
    riemannZeta =с╢а[ЁЭУЭ[тЙа] (1 : тДВ)]
      fun z : тДВ => riemannZetaPoleUnit z / (z - 1) := by
  filter_upwards [self_mem_nhdsWithin] with z hz
  have hz_ne : z тЙа (1 : тДВ) := hz
  rw [riemannZetaPoleUnit_eq_of_ne_one hz_ne]
  have hsub : z - 1 тЙа 0 := sub_ne_zero.mpr hz_ne
  field_simp

/-! ### AM3: local-at-each-point factorization -/

/-- The pole-unit factorization is locally available at each point of the
punctured neighborhood of `1`. -/
theorem riemannZeta_eventuallyEq_poleUnit_div_local :
    тИАс╢а z in ЁЭУЭ[тЙа] (1 : тДВ),
      riemannZeta =с╢а[ЁЭУЭ z]
        fun w : тДВ => riemannZetaPoleUnit w / (w - 1) := by
  filter_upwards [self_mem_nhdsWithin] with z hz
  have hz_ne : z тЙа (1 : тДВ) := hz
  have h_mem : ({(1 : тДВ)}с╢Ь : Set тДВ) тИИ ЁЭУЭ z :=
    isOpen_compl_singleton.mem_nhds hz_ne
  filter_upwards [h_mem] with w hw
  have hw_ne : w тЙа (1 : тДВ) := hw
  rw [riemannZetaPoleUnit_eq_of_ne_one hw_ne]
  have hsub : w - 1 тЙа 0 := sub_ne_zero.mpr hw_ne
  field_simp

/-! ### AM4: removable singularity тАФ pole unit is analytic at `1` -/

/-- The pole unit `riemannZetaPoleUnit` is analytic at `1`.

Proof: `(z - 1) * ╬╢(z)` is bounded near `1` (by `riemannZeta_residue_one`),
analytic away from `1`, and the update at `1` equals `1`
(again by `riemannZeta_residue_one`).  Mathlib's removable singularity
theorem then gives differentiability on a neighborhood of `1`, which
upgrades to analyticity. -/
theorem riemannZetaPoleUnit_analyticAt_one :
    AnalyticAt тДВ riemannZetaPoleUnit (1 : тДВ) := by
  set f : тДВ тЖТ тДВ := fun z => (z - 1) * riemannZeta z with hf_def
  have h_tend : Tendsto f (ЁЭУЭ[тЙа] (1 : тДВ)) (ЁЭУЭ 1) := riemannZeta_residue_one
  have h_lim_one : limUnder (ЁЭУЭ[тЙа] (1 : тДВ)) f = 1 := h_tend.limUnder_eq
  -- тАЦf zтАЦ < 2 eventually on ЁЭУЭ[тЙа] 1
  have h_norm_tend : Tendsto (fun z => тАЦf zтАЦ) (ЁЭУЭ[тЙа] (1 : тДВ)) (ЁЭУЭ (1 : тДЭ)) := by
    have := h_tend.norm
    simpa using this
  have h_bd_event : тИАс╢а z in ЁЭУЭ[тЙа] (1 : тДВ), тАЦf zтАЦ < 2 :=
    h_norm_tend.eventually (eventually_lt_nhds (by norm_num : (1 : тДЭ) < 2))
  -- Extract open V тИЛ 1 such that тАЦfтАЦ < 2 on V \ {1}
  rw [eventually_iff_exists_mem] at h_bd_event
  obtain тЯиE, hE_mem, hEтЯй := h_bd_event
  rw [mem_nhdsWithin] at hE_mem
  obtain тЯиV, hV_open, hV_mem_self, hV_subтЯй := hE_mem
  have hV_nhds : V тИИ ЁЭУЭ (1 : тДВ) := hV_open.mem_nhds hV_mem_self
  have h_bdd : BddAbove (norm тИШ f '' (V \ {1})) := by
    refine тЯи2, ?_тЯй
    rintro x тЯиz, тЯиhz_V, hz_ne_oneтЯй, rflтЯй
    have hz_in_E : z тИИ E := hV_sub тЯиhz_V, hz_ne_oneтЯй
    exact le_of_lt (hE z hz_in_E)
  -- f is differentiable on V \ {1}
  have h_diff_on : DifferentiableOn тДВ f (V \ {1}) := by
    intro z hz
    obtain тЯи_, hz_ne_oneтЯй := hz
    have hz_ne : z тЙа 1 := hz_ne_one
    have h_zeta : DifferentiableAt тДВ riemannZeta z := differentiableAt_riemannZeta hz_ne
    have h_sub : DifferentiableAt тДВ (fun w : тДВ => w - 1) z := by fun_prop
    exact (h_sub.mul h_zeta).differentiableWithinAt
  -- Apply removable singularity
  have h_diff_update :
      DifferentiableOn тДВ (Function.update f 1 (limUnder (ЁЭУЭ[тЙа] (1 : тДВ)) f)) V :=
    differentiableOn_update_limUnder_of_bddAbove hV_nhds h_diff_on h_bdd
  -- The updated function equals riemannZetaPoleUnit
  have h_eq : Function.update f 1 (limUnder (ЁЭУЭ[тЙа] (1 : тДВ)) f) = riemannZetaPoleUnit := by
    rw [h_lim_one]
    funext z
    by_cases hz : z = 1
    ┬╖ subst hz; simp [riemannZetaPoleUnit]
    ┬╖ rw [riemannZetaPoleUnit_eq_of_ne_one hz, Function.update_of_ne hz]
  rw [тЖР h_eq]
  exact h_diff_update.analyticAt hV_nhds

/-! ### AM5: unconditional construction of the simple-pole factorization -/

/-- The simple-pole factorization of `riemannZeta` at `1`. -/
noncomputable def riemannZeta_simplePoleFactorizationAtOne :
    HasSimplePoleFactorization riemannZeta (1 : тДВ) where
  unit := riemannZetaPoleUnit
  unit_analytic := riemannZetaPoleUnit_analyticAt_one
  unit_ne_zero := by simp [riemannZetaPoleUnit_one]
  factorization_local := riemannZeta_eventuallyEq_poleUnit_div_local

/-- Unconditional pole principal part for `riemannZeta` at `z = 1`. -/
theorem zetaLogDeriv_principalPartContinuous_at_one_unconditional :
    HasLogDerivPrincipalPartContinuous riemannZeta (1 : тДВ) (-1) :=
  zetaLogDeriv_principalPartContinuous_at_one
    riemannZeta_simplePoleFactorizationAtOne

/-! ## BX: Analytic-remainder upgrades of the local principal-part theorems -/

/-! ### BX1: `logDeriv u` is analytic at a nonzero analytic point -/

/-- If `u` is analytic at `s` and `u s тЙа 0`, then `logDeriv u` is analytic
at `s`.  Pure `AnalyticAt.div` on `deriv u / u`. -/
theorem analyticAt_logDeriv_of_analyticAt_ne_zero
    {u : тДВ тЖТ тДВ} {s : тДВ}
    (hu : AnalyticAt тДВ u s) (hu0 : u s тЙа 0) :
    AnalyticAt тДВ (logDeriv u) s :=
  hu.deriv.div hu hu0

/-! ### BX2: analytic-remainder zero-factorization principal part -/

/-- Analytic version of `hasLogDerivPrincipalPartContinuous_of_factorization`:
the chosen remainder `logDeriv u` is analytic at `s`, not merely continuous. -/
theorem hasLogDerivPrincipalPart_of_factorization
    {f : тДВ тЖТ тДВ} {s : тДВ} {m : тДХ}
    (hm_pos : 0 < m) (H : HasAnalyticZeroFactorization f s m) :
    HasLogDerivPrincipalPart f s m := by
  set u : тДВ тЖТ тДВ := H.unit with hu_def
  have hu_an : AnalyticAt тДВ u s := H.unit_analytic
  have hu_ne_s : u s тЙа 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : тИАс╢а z in ЁЭУЭ s, u z тЙа 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : тИАс╢а z in ЁЭУЭ s, DifferentiableAt тДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hfac_eventually_nhds :
      тИАс╢а z in ЁЭУЭ s, f =с╢а[ЁЭУЭ z] fun w : тДВ => (w - s) ^ m * u w :=
    H.factorization.eventually_nhds
  have hu_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, u z тЙа 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, DifferentiableAt тДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hfac_punct :
      тИАс╢а z in ЁЭУЭ[тЙа] s, f =с╢а[ЁЭУЭ z] fun w : тДВ => (w - s) ^ m * u w :=
    hfac_eventually_nhds.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, z тЙа s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine тЯиlogDeriv u, analyticAt_logDeriv_of_analyticAt_ne_zero hu_an hu_ne_s, ?_тЯй
  filter_upwards [hfac_punct, hu_ne_punct, hu_diff_punct, hz_ne_punct]
    with z hfz huz hu_diff_z hz_ne_z
  exact logDeriv_eq_of_eventual_factorization hm_pos hz_ne_z huz hu_diff_z hfz

/-! ### BX3: zeta nontrivial-zero analytic principal part -/

/-- Nat-valued analytic principal part for `╬╢'/╬╢` at a nontrivial zero. -/
theorem zetaLogDeriv_principalPart_at_nontrivial_zero_nat
    {s : тДВ} (hs : IsNontrivialZetaZero s) :
    ZetaHasLogDerivPrincipalPart s :=
  hasLogDerivPrincipalPart_of_factorization
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaAnalyticZeroFactorization hs)

/-- Integer-valued analytic principal part for `╬╢'/╬╢` at a nontrivial zero. -/
theorem zetaLogDeriv_principalPart_at_nontrivial_zero
    {s : тДВ} (hs : IsNontrivialZetaZero s) :
    ZetaHasIntegerLogDerivPrincipalPartAtZero s :=
  (zetaLogDeriv_principalPart_at_nontrivial_zero_nat hs).toInteger

/-! ### BX4: analytic-remainder simple-pole-factorization principal part -/

/-- Analytic version of
`hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization`. -/
theorem hasLogDerivIntegerPrincipalPart_of_simplePoleFactorization
    {f : тДВ тЖТ тДВ} {s : тДВ} (H : HasSimplePoleFactorization f s) :
    HasLogDerivIntegerPrincipalPart f s (-1) := by
  set u : тДВ тЖТ тДВ := H.unit with hu_def
  have hu_an : AnalyticAt тДВ u s := H.unit_analytic
  have hu_ne_s : u s тЙа 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : тИАс╢а z in ЁЭУЭ s, u z тЙа 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : тИАс╢а z in ЁЭУЭ s, DifferentiableAt тДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hu_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, u z тЙа 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, DifferentiableAt тДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : тИАс╢а z in ЁЭУЭ[тЙа] s, z тЙа s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine тЯиlogDeriv u, analyticAt_logDeriv_of_analyticAt_ne_zero hu_an hu_ne_s, ?_тЯй
  filter_upwards
    [H.factorization_local, hu_ne_punct, hu_diff_punct, hz_ne_punct]
    with z hfz huz hu_diff_z hz_ne_z
  have hmain :
      logDeriv f z = (-1 : тДВ) / (z - s) + logDeriv u z :=
    logDeriv_eq_of_eventual_simplePoleFactorization hz_ne_z huz hu_diff_z hfz
  have hcast : ((-1 : тДд) : тДВ) = (-1 : тДВ) := by push_cast; rfl
  rw [hcast]
  exact hmain

/-! ### BX5: zeta pole analytic principal part (unconditional) -/

/-- Unconditional analytic pole principal part for `╬╢'/╬╢` at `z = 1`. -/
theorem zetaLogDeriv_principalPart_at_one_unconditional :
    HasLogDerivIntegerPrincipalPart riemannZeta (1 : тДВ) (-1) :=
  hasLogDerivIntegerPrincipalPart_of_simplePoleFactorization
    riemannZeta_simplePoleFactorizationAtOne

/-! ## AN: Rectangle principal-part data (residue-free) -/

namespace ZetaRectangle

/-! ### AN1: counted-singularity predicate -/

/-- Singularities of `╬╢'/╬╢` that the Backlund/Turing rectangle counts:
either a nontrivial zero of `╬╢` strictly inside the rectangle, or the pole
at `s = 1` if it lies strictly inside. -/
def IsCountedZetaSingularityInside (R : ZetaRectangle) (s : тДВ) : Prop :=
  R.IsNontrivialZeroInside s тИи (R.PoleInside тИз s = 1)

/-! ### AN1 (continued): rectangle principal-part data -/

/-- Residue-free local principal-part data on a rectangle: a finite list of
singularities, each with an integer coefficient, each carrying a continuous
log-derivative principal-part certificate. -/
structure RectanglePrincipalPartData (R : ZetaRectangle) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  singularities : Finset тДВ
  principalCoeff : тДВ тЖТ тДд
  localPrincipalPart :
    тИА s : тДВ, s тИИ singularities тЖТ
      HasLogDerivPrincipalPartContinuous
        riemannZeta s (principalCoeff s)
  singularities_complete :
    тИА s : тДВ, s тИИ singularities тЖФ R.IsCountedZetaSingularityInside s

/-! ### AN2: principal-part integral identity (residue-theorem replacement) -/

/-- The residue-free rectangle argument principle: the normalized contour
integral of `╬╢'/╬╢` equals the sum of integer principal coefficients of the
counted singularities. -/
structure RectanglePrincipalPartIntegralTheorem (R : ZetaRectangle) where
  ppData : R.RectanglePrincipalPartData
  normalizedIntegral_eq_sum :
    R.normalizedRectangleLogDerivIntegral =
      ((ppData.singularities.sum ppData.principalCoeff : тДд) : тДВ)

/-! ### AN4: canonical principal coefficient for `╬╢'/╬╢` -/

/-- Canonical principal coefficient function for `╬╢'/╬╢`: equal to the
analytic zero multiplicity at nontrivial zeros, `-1` at the pole `s = 1`,
and `0` elsewhere. -/
noncomputable def zetaLogDerivPrincipalCoeff (s : тДВ) : тДд :=
  zetaLogDerivExpectedResidueIndex s

theorem zetaLogDerivPrincipalCoeff_of_zero
    {s : тДВ} (hs : IsNontrivialZetaZero s) :
    zetaLogDerivPrincipalCoeff s = (zetaGlobalZeroMultiplicity.mult s : тДд) :=
  zetaLogDerivExpectedResidueIndex_of_zero hs

theorem zetaLogDerivPrincipalCoeff_one :
    zetaLogDerivPrincipalCoeff (1 : тДВ) = -1 :=
  zetaLogDerivExpectedResidueIndex_one

theorem zetaLogDerivPrincipalCoeff_elsewhere
    {s : тДВ} (hs : ┬м IsNontrivialZetaZero s) (hs1 : s тЙа 1) :
    zetaLogDerivPrincipalCoeff s = 0 :=
  zetaLogDerivExpectedResidueIndex_elsewhere hs hs1

/-! ### AN5: counted principal-part data from zero-set + admissibility -/

/-- Bundle the local zero/pole principal parts into rectangle-level data
indexed by the canonical singularity set. -/
noncomputable def countedPrincipalPartData
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) :
    R.RectanglePrincipalPartData where
  stronglyAdmissible := hAdm
  singularities := R.canonicalSingularities Z
  principalCoeff := zetaLogDerivPrincipalCoeff
  localPrincipalPart := by
    intro s hs
    unfold canonicalSingularities at hs
    by_cases hpole : R.PoleInside
    ┬╖ rw [if_pos hpole] at hs
      rw [Finset.mem_insert] at hs
      rcases hs with rfl | hsZ
      ┬╖ rw [zetaLogDerivPrincipalCoeff_one]
        exact zetaLogDeriv_principalPartContinuous_at_one_unconditional
      ┬╖ have hsInside : R.IsNontrivialZeroInside s := (Z.complete s).mp hsZ
        have hsNT : IsNontrivialZetaZero s := hsInside.1
        rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
        exact zetaLogDeriv_principalPartContinuous_at_nontrivial_zero hsNT
    ┬╖ rw [if_neg hpole] at hs
      have hsInside : R.IsNontrivialZeroInside s := (Z.complete s).mp hs
      have hsNT : IsNontrivialZetaZero s := hsInside.1
      rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
      exact zetaLogDeriv_principalPartContinuous_at_nontrivial_zero hsNT
  singularities_complete := by
    intro s
    unfold IsCountedZetaSingularityInside canonicalSingularities
    by_cases hpole : R.PoleInside
    ┬╖ rw [if_pos hpole]
      constructor
      ┬╖ intro hs
        rw [Finset.mem_insert] at hs
        rcases hs with rfl | hsZ
        ┬╖ exact Or.inr тЯиhpole, rflтЯй
        ┬╖ exact Or.inl ((Z.complete s).mp hsZ)
      ┬╖ intro hs
        rcases hs with hsInside | тЯи_, hs1тЯй
        ┬╖ rw [Finset.mem_insert]
          exact Or.inr ((Z.complete s).mpr hsInside)
        ┬╖ rw [Finset.mem_insert]
          exact Or.inl hs1
    ┬╖ rw [if_neg hpole]
      constructor
      ┬╖ intro hs
        exact Or.inl ((Z.complete s).mp hs)
      ┬╖ intro hs
        rcases hs with hsInside | тЯиhpole', _тЯй
        ┬╖ exact (Z.complete s).mpr hsInside
        ┬╖ exact absurd hpole' hpole

/-! ## AO: Principal-part contour integral decomposition -/

/-! ### AO1: principal kernel and its rectangle integral -/

/-- The principal kernel `k / (z - a)` at singularity `a` with coefficient `k`. -/
noncomputable def principalKernel (k : тДд) (a z : тДВ) : тДВ :=
  (k : тДВ) / (z - a)

/-- Integral of the principal kernel `k/(z-a)` around the rectangle's four
edges. -/
noncomputable def principalKernelRectangleIntegral
    (R : ZetaRectangle) (k : тДд) (a : тДВ) : тДВ :=
  (тИл t in (0 : тДЭ)..1,
      principalKernel k a (R.bottomEdge t) * deriv R.bottomEdge t)
  + (тИл t in (0 : тДЭ)..1,
      principalKernel k a (R.rightEdge t) * deriv R.rightEdge t)
  + (тИл t in (0 : тДЭ)..1,
      principalKernel k a (R.topEdge t) * deriv R.topEdge t)
  + (тИл t in (0 : тДЭ)..1,
      principalKernel k a (R.leftEdge t) * deriv R.leftEdge t)

/-- Normalized principal-kernel integral `(1/2╧Аi) тИо k/(z-a) dz`. -/
noncomputable def normalizedPrincipalKernelRectangleIntegral
    (R : ZetaRectangle) (k : тДд) (a : тДВ) : тДВ :=
  (twoPiI)тБ╗┬╣ * R.principalKernelRectangleIntegral k a

/-! ### AO2: single-kernel Cauchy-index theorem target -/

/-- For a singularity `a` strictly inside the rectangle (and not on the
boundary), the normalized principal-kernel integral equals its coefficient.
This is the residue-free Cauchy-index statement. -/
structure PrincipalKernelIntegralTheorem
    (R : ZetaRectangle) (k : тДд) (a : тДВ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : тИА z : тДВ, R.ContainsBoundary z тЖТ z тЙа a
  normalized_integral_eq_coeff :
    R.normalizedPrincipalKernelRectangleIntegral k a = (k : тДВ)

/-! ### AO3: vanishing-remainder integral target -/

/-- The normalized contour integral of `╬╢'/╬╢` minus the sum of normalized
principal-kernel integrals тАФ i.e. the "holomorphic remainder" part of the
residue-theorem decomposition. -/
noncomputable def rectangleRemainderIntegral
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : тДВ :=
  R.normalizedRectangleLogDerivIntegral -
    P.singularities.sum
      (fun s => R.normalizedPrincipalKernelRectangleIntegral
        (P.principalCoeff s) s)

/-- After subtracting all principal kernels, the remaining contour integrand
has zero normalized integral.  This is the residue-free replacement for the
holomorphic-remainder part of the residue theorem. -/
def RectangleRemainderIntegralVanishes
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop :=
  R.rectangleRemainderIntegral P = 0

/-! ### AO4: contour decomposition + assembled integral theorem -/

/-- Contour decomposition: the normalized `╬╢'/╬╢` integral splits into the
sum of normalized principal-kernel integrals. -/
structure RectanglePrincipalPartContourDecomposition
    (R : ZetaRectangle)
    (P : R.RectanglePrincipalPartData) : Prop where
  integral_decomposition :
    R.normalizedRectangleLogDerivIntegral =
      P.singularities.sum
        (fun s => R.normalizedPrincipalKernelRectangleIntegral
          (P.principalCoeff s) s)

/-- Assemble the contour decomposition + per-kernel Cauchy index into the
full residue-free rectangle argument principle. -/
noncomputable def RectanglePrincipalPartContourDecomposition.toIntegralTheorem
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (D : R.RectanglePrincipalPartContourDecomposition P)
    (HK :
      тИА s : тДВ, s тИИ P.singularities тЖТ
        R.normalizedPrincipalKernelRectangleIntegral
          (P.principalCoeff s) s =
        (P.principalCoeff s : тДВ)) :
    R.RectanglePrincipalPartIntegralTheorem where
  ppData := P
  normalizedIntegral_eq_sum := by
    rw [D.integral_decomposition]
    push_cast
    exact Finset.sum_congr rfl (fun s hs => HK s hs)

/-! ### AO5: canonical rectangle theorem target -/

/-- Final residue-free rectangle argument principle target: the normalized
contour integral equals the sum of canonical principal coefficients over
the canonical singularity set. -/
def CanonicalRectanglePrincipalPartIntegralTheorem
    (R : ZetaRectangle) (Z : R.ZeroSetInside) : Prop :=
  R.normalizedRectangleLogDerivIntegral =
    (((R.canonicalSingularities Z).sum zetaLogDerivPrincipalCoeff : тДд) : тДВ)

/-! ## AP: single-kernel Cauchy index targets -/

/-! ### AP1: unnormalized kernel theorem + adapter to normalized -/

/-- Unnormalized Cauchy index for a single principal kernel:
`тИо k / (z - a) dz = 2╧Аi ┬╖ k` for `a` strictly inside the rectangle. -/
structure PrincipalKernelUnnormalizedIntegralTheorem
    (R : ZetaRectangle) (k : тДд) (a : тДВ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : тИА z : тДВ, R.ContainsBoundary z тЖТ z тЙа a
  integral_eq :
    R.principalKernelRectangleIntegral k a = twoPiI * (k : тДВ)

/-- The unnormalized Cauchy-index theorem implies the normalized one. -/
noncomputable def PrincipalKernelUnnormalizedIntegralTheorem.toNormalized
    {R : ZetaRectangle} {k : тДд} {a : тДВ}
    (H : R.PrincipalKernelUnnormalizedIntegralTheorem k a) :
    R.PrincipalKernelIntegralTheorem k a where
  inside := H.inside
  boundary_avoids := H.boundary_avoids
  normalized_integral_eq_coeff := by
    unfold normalizedPrincipalKernelRectangleIntegral
    rw [H.integral_eq]
    field_simp [twoPiI_ne_zero]

/-! ### AP2: unit kernel and its rectangle integral -/

/-- Unit principal kernel `1 / (z - a)`. -/
noncomputable def unitPrincipalKernel (a z : тДВ) : тДВ :=
  1 / (z - a)

/-- Integral of the unit kernel around the rectangle's four edges, defined
as the `k = 1` specialization of `principalKernelRectangleIntegral`. -/
noncomputable def unitPrincipalKernelRectangleIntegral
    (R : ZetaRectangle) (a : тДВ) : тДВ :=
  R.principalKernelRectangleIntegral 1 a

/-! ### AP3: Cauchy index theorem target for the unit kernel -/

/-- Cauchy index for the unit kernel around a rectangle:
`тИо dz / (z - a) = 2╧Аi` for `a` strictly inside the rectangle.

This is the smallest remaining analytic theorem in the residue-free
argument-principle chain; once proved, general-`k` and the full rectangle
theorem follow by linearity and the contour decomposition. -/
structure UnitPrincipalKernelIntegralTheorem
    (R : ZetaRectangle) (a : тДВ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : тИА z : тДВ, R.ContainsBoundary z тЖТ z тЙа a
  integral_eq :
    R.unitPrincipalKernelRectangleIntegral a = twoPiI

