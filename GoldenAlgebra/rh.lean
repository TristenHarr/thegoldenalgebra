/-! ## AX: Small-square route for the punctured Cauchy-Goursat -/

/-! ### AX1: small axis-aligned square inside the rectangle -/

/-- A small axis-aligned closed square centered at `a` whose interior lies
strictly inside the open rectangle.  The square uses half-side `r` in both
real and imaginary directions. -/
structure SmallSquareInsideRectangle
    (R : ZetaRectangle) (a : вДВ) where
  r : вДЭ
  r_pos : 0 < r
  square_subset_open :
    {z : вДВ | |z.re - a.re| вЙ§ r вИІ |z.im - a.im| вЙ§ r} вКЖ
      {z : вДВ | R.ContainsOpen z}

/-! ### AX2: existence from `ContainsOpen a` -/

/-- A point strictly inside the rectangle admits a small interior square. -/
theorem exists_smallSquareInsideRectangle
    {R : ZetaRectangle} {a : вДВ}
    (ha : R.ContainsOpen a) :
    Nonempty (R.SmallSquareInsideRectangle a) := by
  obtain вЯ®hL, hRt, hB, hTвЯ© := ha
  set r : вДЭ :=
    min (min ((a.re - R.left) / 2) ((R.right - a.re) / 2))
      (min ((a.im - R.bottom) / 2) ((R.top - a.im) / 2)) with hr_def
  have hr_pos : 0 < r := by
    refine lt_min (lt_min ?_ ?_) (lt_min ?_ ?_) <;> linarith
  refine вЯ®вЯ®r, hr_pos, ?_вЯ©вЯ©
  intro z hz
  obtain вЯ®hre_abs, him_absвЯ© := hz
  obtain вЯ®hre_low, hre_highвЯ© := abs_le.mp hre_abs
  obtain вЯ®him_low, him_highвЯ© := abs_le.mp him_abs
  have hr_le_left : r вЙ§ (a.re - R.left) / 2 :=
    (min_le_left _ _).trans (min_le_left _ _)
  have hr_le_right : r вЙ§ (R.right - a.re) / 2 :=
    (min_le_left _ _).trans (min_le_right _ _)
  have hr_le_bottom : r вЙ§ (a.im - R.bottom) / 2 :=
    (min_le_right _ _).trans (min_le_left _ _)
  have hr_le_top : r вЙ§ (R.top - a.im) / 2 :=
    (min_le_right _ _).trans (min_le_right _ _)
  refine вЯ®?_, ?_, ?_, ?_вЯ© <;> linarith

/-! ### AX3: the small square as its own `ZetaRectangle` and its unit-kernel
integral -/

/-- The small square viewed as a `ZetaRectangle`. -/
def SmallSquareInsideRectangle.toRectangle
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := a.re - S.r
  right := a.re + S.r
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by linarith [S.r_pos]
  hbottom_lt_top := by linarith [S.r_pos]

/-- Unit-kernel rectangle integral over the inner square. -/
noncomputable def smallSquareUnitKernelIntegral
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : вДВ :=
  S.toRectangle.unitPrincipalKernelRectangleIntegral a

/-! ### AX4: outer-rectangle = inner-square deformation target -/

/-- Cauchy-Goursat deformation from the outer rectangle to the small inner
square around `a`.  Splits the punctured-rectangle theorem into two halves;
this half decomposes the annular region into ordinary holomorphic rectangles. -/
structure UnitKernelRectangleToSquareDeformation
    (R : ZetaRectangle) (a : вДВ)
    (S : R.SmallSquareInsideRectangle a) : Prop where
  rectangle_eq_square :
    R.unitPrincipalKernelRectangleIntegral a =
      R.smallSquareUnitKernelIntegral S

/-! ### AX5: inner-square = circle deformation target -/

/-- Cauchy-Goursat deformation from the inner square to the small circle
around `a`. -/
structure UnitKernelSquareToCircleDeformation
    (R : ZetaRectangle) (a : вДВ)
    (S : R.SmallSquareInsideRectangle a)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  square_eq_circle :
    R.smallSquareUnitKernelIntegral S =
      unitKernelCircleIntegral a C.r

/-! ### AX6: assemble punctured CG from square deformations -/

/-- Composing the two square-staged deformations gives the punctured-rectangle
Cauchy-Goursat theorem. -/
noncomputable def PuncturedRectangleCauchyGoursat.of_square_deformations
    {R : ZetaRectangle} {a : вДВ}
    {C : R.SmallCircleInsideRectangle a}
    {S : R.SmallSquareInsideRectangle a}
    (DвВБ : R.UnitKernelRectangleToSquareDeformation a S)
    (DвВВ : R.UnitKernelSquareToCircleDeformation a S C) :
    R.PuncturedRectangleCauchyGoursat a C where
  boundary_integral_eq := by
    rw [DвВБ.rectangle_eq_square, DвВВ.square_eq_circle]

/-! ## AY: Four-strip decomposition for rectangle вЖТ inner square -/

/-! ### AY1: the four strip rectangles -/

/-- Top strip: above the inner square, full width of the outer rectangle. -/
def SmallSquareInsideRectangle.topStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := R.right
  bottom := a.im + S.r
  top := R.top
  hleft_lt_right := R.hleft_lt_right
  hbottom_lt_top := by
    have hcorner : R.ContainsOpen вЯ®a.re, a.im + S.rвЯ© := by
      apply S.square_subset_open
      refine вЯ®?_, ?_вЯ©
      ¬Ј show |a.re - a.re| вЙ§ S.r
        simp; exact S.r_pos.le
      ¬Ј show |(a.im + S.r) - a.im| вЙ§ S.r
        rw [add_sub_cancel_left]
        exact (abs_of_pos S.r_pos).le
    exact hcorner.2.2.2

/-- Bottom strip: below the inner square, full width of the outer rectangle. -/
def SmallSquareInsideRectangle.bottomStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := R.right
  bottom := R.bottom
  top := a.im - S.r
  hleft_lt_right := R.hleft_lt_right
  hbottom_lt_top := by
    have hcorner : R.ContainsOpen вЯ®a.re, a.im - S.rвЯ© := by
      apply S.square_subset_open
      refine вЯ®?_, ?_вЯ©
      ¬Ј show |a.re - a.re| вЙ§ S.r
        simp; exact S.r_pos.le
      ¬Ј show |(a.im - S.r) - a.im| вЙ§ S.r
        have h : (a.im - S.r) - a.im = -S.r := by ring
        rw [h, abs_neg, abs_of_pos S.r_pos]
    exact hcorner.2.2.1

/-- Left strip: to the left of the inner square, vertical extent of the square. -/
def SmallSquareInsideRectangle.leftStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := a.re - S.r
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by
    have hcorner : R.ContainsOpen вЯ®a.re - S.r, a.imвЯ© := by
      apply S.square_subset_open
      refine вЯ®?_, ?_вЯ©
      ¬Ј show |(a.re - S.r) - a.re| вЙ§ S.r
        have h : (a.re - S.r) - a.re = -S.r := by ring
        rw [h, abs_neg, abs_of_pos S.r_pos]
      ¬Ј show |a.im - a.im| вЙ§ S.r
        simp; exact S.r_pos.le
    exact hcorner.1
  hbottom_lt_top := by linarith [S.r_pos]

/-- Right strip: to the right of the inner square, vertical extent of the square. -/
def SmallSquareInsideRectangle.rightStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := a.re + S.r
  right := R.right
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by
    have hcorner : R.ContainsOpen вЯ®a.re + S.r, a.imвЯ© := by
      apply S.square_subset_open
      refine вЯ®?_, ?_вЯ©
      ¬Ј show |(a.re + S.r) - a.re| вЙ§ S.r
        rw [add_sub_cancel_left]
        exact (abs_of_pos S.r_pos).le
      ¬Ј show |a.im - a.im| вЙ§ S.r
        simp; exact S.r_pos.le
    exact hcorner.2.1
  hbottom_lt_top := by linarith [S.r_pos]

/-! ### AY2: `a` is not in any strip вАФ unit kernel is analytic on each -/

theorem unitKernel_analyticOn_topStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    вИА z вИИ {z : вДВ | S.topStrip.ContainsClosed z},
      AnalyticAt вДВ (fun w : вДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hbot : a.im + S.r вЙ§ a.im := hz.2.2.1
  linarith [S.r_pos]

theorem unitKernel_analyticOn_bottomStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    вИА z вИИ {z : вДВ | S.bottomStrip.ContainsClosed z},
      AnalyticAt вДВ (fun w : вДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have htop : a.im вЙ§ a.im - S.r := hz.2.2.2
  linarith [S.r_pos]

theorem unitKernel_analyticOn_leftStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    вИА z вИИ {z : вДВ | S.leftStrip.ContainsClosed z},
      AnalyticAt вДВ (fun w : вДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hright : a.re вЙ§ a.re - S.r := hz.2.1
  linarith [S.r_pos]

theorem unitKernel_analyticOn_rightStrip
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    вИА z вИИ {z : вДВ | S.rightStrip.ContainsClosed z},
      AnalyticAt вДВ (fun w : вДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hleft : a.re + S.r вЙ§ a.re := hz.1
  linarith [S.r_pos]

/-! ### AY3: generic rectangle integral + Cauchy-Goursat target -/

/-- Generic boundary integral of `f` around a rectangle, summing the four
edge interval integrals. -/
noncomputable def rectangleIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  (вИЂ t in (0 : вДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t)
  + (вИЂ t in (0 : вДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t)
  + (вИЂ t in (0 : вДЭ)..1, f (R.topEdge t) * deriv R.topEdge t)
  + (вИЂ t in (0 : вДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t)

/-- The generic rectangle integral specialized to the unit kernel agrees
with `unitPrincipalKernelRectangleIntegral`. -/
theorem rectangleIntegral_unitPrincipalKernel_eq
    (R : ZetaRectangle) (a : вДВ) :
    R.rectangleIntegral (unitPrincipalKernel a) =
      R.unitPrincipalKernelRectangleIntegral a := by
  unfold rectangleIntegral unitPrincipalKernelRectangleIntegral
    principalKernelRectangleIntegral principalKernel unitPrincipalKernel
  push_cast
  ring

/-- Rectangle Cauchy-Goursat: boundary integral of a holomorphic function
on the closed rectangle is zero.  Target structure. -/
structure RectangleCauchyGoursat
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : Prop where
  integral_eq_zero : R.rectangleIntegral f = 0

/-! ## BP: Function-form principal-part decomposition (linearity + remainder vanishing) -/

/-! ### BP1: principal-part sum and log-derivative remainder as `вДВ вЖТ вДВ` -/

/-- The pointwise principal-part sum: `ќ£_s principalCoeff(s) / (z вИТ s)` summed
over the counted singularity set in `P`.  Its rectangle integral equals the
sum of per-singularity principal-kernel integrals by linearity. -/
noncomputable def principalPartSum
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : вДВ) : вДВ :=
  P.singularities.sum (fun s => principalKernel (P.principalCoeff s) s z)

/-- The log-derivative remainder: `ќґ'/ќґ вИТ principalPartSum`.  Holomorphic on
the closed rectangle by construction once strong admissibility separates the
counted singularities from the boundary. -/
noncomputable def logDerivRemainder
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : вДВ) : вДВ :=
  zetaLogDeriv z - R.principalPartSum P z

/-! ### BP2: Linear-decomposition target (algebra of integrals) -/

/-- Linear decomposition: the normalized `ќґ'/ќґ` rectangle integral equals
the sum of normalized principal-kernel integrals plus a `(twoPiI)вБї¬є`-scaled
unnormalized rectangle integral of the remainder.  Pure linearity of
integration over the contour; no analyticity is used. -/
structure RectangleLogDerivContourLinearDecomposition
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  decomposition :
    R.normalizedRectangleLogDerivIntegral =
      P.singularities.sum
        (fun s =>
          R.normalizedPrincipalKernelRectangleIntegral
            (P.principalCoeff s) s)
        + (twoPiI)вБї¬є * R.rectangleIntegral (R.logDerivRemainder P)

/-! ### BP3: Remainder integral vanishing (Cauchy-Goursat content) -/

/-- The unnormalized rectangle integral of the holomorphic remainder
`ќґ'/ќґ вИТ principalPartSum` vanishes.  This is the Cauchy-Goursat statement
for the function-form remainder: subtracting the local principal part at
every counted singularity yields a function analytic on the closed
rectangle, whose boundary integral is zero. -/
structure RectangleLogDerivRemainderIntegralVanishes
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  integral_eq_zero :
    R.rectangleIntegral (R.logDerivRemainder P) = 0

/-! ### BP4: Assembler вАФ linearity + vanishing вЗТ contour decomposition -/

/-- Combine the linear decomposition (BP2) with the remainder-vanishing
fact (BP3) to discharge the contour decomposition target. -/
noncomputable def RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (L : R.RectangleLogDerivContourLinearDecomposition P)
    (V : R.RectangleLogDerivRemainderIntegralVanishes P) :
    R.RectanglePrincipalPartContourDecomposition P where
  integral_decomposition := by
    rw [L.decomposition, V.integral_eq_zero, mul_zero, add_zero]

/-! ## BQ: Linearity assembler for the contour decomposition -/

/-! ### BQ1: Pointwise log-derivative split вАФ `ќґ'/ќґ = principalPartSum + remainder` -/

/-- By definition of the remainder, `ќґ'/ќґ(z) = principalPartSum(z) + remainder(z)`. -/
theorem zetaLogDeriv_eq_principalPartSum_add_remainder
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : вДВ) :
    zetaLogDeriv z =
      R.principalPartSum P z + R.logDerivRemainder P z := by
  unfold logDerivRemainder
  ring

/-! ### BQ2: Rectangle-integral version of the log-derivative -/

/-- Rewriting `rectangleLogDerivIntegral` as the generic `rectangleIntegral`
applied to `zetaLogDeriv`.  Pure unfolding of edge integrals. -/
theorem rectangleLogDerivIntegral_eq_rectangleIntegral
    (R : ZetaRectangle) :
    R.rectangleLogDerivIntegral = R.rectangleIntegral zetaLogDeriv := by
  unfold rectangleLogDerivIntegral rectangleIntegral
    bottomLogDerivIntegral rightLogDerivIntegral
    topLogDerivIntegral leftLogDerivIntegral
  rfl

/-! ### BQ3: Linearity-input package + assembler to BP2 -/

/-- The two purely-algebraic linearity inputs needed to inhabit
`RectangleLogDerivContourLinearDecomposition` from contour-integral
additivity.  Decoupled from analyticity / Cauchy-Goursat. -/
structure RectanglePrincipalPartLinearityData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  add :
    R.rectangleIntegral
      (fun z => R.principalPartSum P z + R.logDerivRemainder P z)
    =
      R.rectangleIntegral (R.principalPartSum P)
        + R.rectangleIntegral (R.logDerivRemainder P)
  sum :
    R.rectangleIntegral (R.principalPartSum P) =
      P.singularities.sum
        (fun s => R.principalKernelRectangleIntegral
          (P.principalCoeff s) s)

/-- **BQ4 вАФ ASSEMBLER:** Given the rectangle-integral addition and finite-sum
linearity facts, inhabit the BP2 linear-decomposition target. -/
noncomputable def RectangleLogDerivContourLinearDecomposition.of_linearityData
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (L : R.RectanglePrincipalPartLinearityData P) :
    R.RectangleLogDerivContourLinearDecomposition P where
  decomposition := by
    unfold normalizedRectangleLogDerivIntegral
      normalizedPrincipalKernelRectangleIntegral
    rw [rectangleLogDerivIntegral_eq_rectangleIntegral R]
    have hpoint : zetaLogDeriv =
        fun z => R.principalPartSum P z + R.logDerivRemainder P z := by
      funext z
      exact zetaLogDeriv_eq_principalPartSum_add_remainder R P z
    rw [hpoint, L.add, mul_add, L.sum, Finset.mul_sum]

/-! ## BR: Rectangle-integral linearity from boundary integrability -/

/-! ### BR1: generic rectangle-integral additivity from edge integrability -/

/-- Additivity of the rectangle integral, conditional on integrability of
both integrands along each of the four edges.  Pure linearity of the
interval integral. -/
theorem rectangleIntegral_add_of_integrable
    (R : ZetaRectangle) (f g : вДВ вЖТ вДВ)
    (hf_bottom :
      IntervalIntegrable
        (fun t : вДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t)
        MeasureTheory.volume 0 1)
    (hg_bottom :
      IntervalIntegrable
        (fun t : вДЭ => g (R.bottomEdge t) * deriv R.bottomEdge t)
        MeasureTheory.volume 0 1)
    (hf_right :
      IntervalIntegrable
        (fun t : вДЭ => f (R.rightEdge t) * deriv R.rightEdge t)
        MeasureTheory.volume 0 1)
    (hg_right :
      IntervalIntegrable
        (fun t : вДЭ => g (R.rightEdge t) * deriv R.rightEdge t)
        MeasureTheory.volume 0 1)
    (hf_top :
      IntervalIntegrable
        (fun t : вДЭ => f (R.topEdge t) * deriv R.topEdge t)
        MeasureTheory.volume 0 1)
    (hg_top :
      IntervalIntegrable
        (fun t : вДЭ => g (R.topEdge t) * deriv R.topEdge t)
        MeasureTheory.volume 0 1)
    (hf_left :
      IntervalIntegrable
        (fun t : вДЭ => f (R.leftEdge t) * deriv R.leftEdge t)
        MeasureTheory.volume 0 1)
    (hg_left :
      IntervalIntegrable
        (fun t : вДЭ => g (R.leftEdge t) * deriv R.leftEdge t)
        MeasureTheory.volume 0 1) :
    R.rectangleIntegral (fun z => f z + g z) =
      R.rectangleIntegral f + R.rectangleIntegral g := by
  unfold rectangleIntegral
  simp only [add_mul]
  rw [intervalIntegral.integral_add hf_bottom hg_bottom,
      intervalIntegral.integral_add hf_right hg_right,
      intervalIntegral.integral_add hf_top hg_top,
      intervalIntegral.integral_add hf_left hg_left]
  abel

/-! ### BR2: integrability package -/

/-- Integrability of a function along the four rectangle edges. -/
structure RectangleIntegralIntegrable
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : Prop where
  bottom :
    IntervalIntegrable
      (fun t : вДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t)
      MeasureTheory.volume 0 1
  right :
    IntervalIntegrable
      (fun t : вДЭ => f (R.rightEdge t) * deriv R.rightEdge t)
      MeasureTheory.volume 0 1
  top :
    IntervalIntegrable
      (fun t : вДЭ => f (R.topEdge t) * deriv R.topEdge t)
      MeasureTheory.volume 0 1
  left :
    IntervalIntegrable
      (fun t : вДЭ => f (R.leftEdge t) * deriv R.leftEdge t)
      MeasureTheory.volume 0 1

/-- Packaged BR1 that consumes the integrability data structurally. -/
theorem rectangleIntegral_add_of_integrable_package
    (R : ZetaRectangle) (f g : вДВ вЖТ вДВ)
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.rectangleIntegral (fun z => f z + g z) =
      R.rectangleIntegral f + R.rectangleIntegral g :=
  rectangleIntegral_add_of_integrable R f g
    hf.bottom hg.bottom
    hf.right hg.right
    hf.top hg.top
    hf.left hg.left

/-! ### BR3: zero / add closures for `RectangleIntegralIntegrable` -/

/-- The constant zero function is rectangle-integrable. -/
theorem RectangleIntegralIntegrable.zero (R : ZetaRectangle) :
    R.RectangleIntegralIntegrable (fun _ : вДВ => 0) where
  bottom := by simp
  right := by simp
  top := by simp
  left := by simp

/-- Sum of rectangle-integrable functions is rectangle-integrable. -/
theorem RectangleIntegralIntegrable.add
    {R : ZetaRectangle} {f g : вДВ вЖТ вДВ}
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.RectangleIntegralIntegrable (fun z => f z + g z) where
  bottom := by simpa [add_mul] using hf.bottom.add hg.bottom
  right := by simpa [add_mul] using hf.right.add hg.right
  top := by simpa [add_mul] using hf.top.add hg.top
  left := by simpa [add_mul] using hf.left.add hg.left

/-! ### BR4: finite-sum closures + finite-sum linearity -/

/-- A finite sum of rectangle-integrable functions is rectangle-integrable. -/
theorem rectangleIntegralIntegrable_finset_sum
    (R : ZetaRectangle) (F : вДВ вЖТ вДВ вЖТ вДВ) (S : Finset вДВ)
    (hF : вИА s вИИ S, R.RectangleIntegralIntegrable (F s)) :
    R.RectangleIntegralIntegrable (fun z => S.sum (fun s => F s z)) := by
  classical
  revert hF
  induction S using Finset.induction_on with
  | empty =>
    intro _
    have h : (fun z : вДВ => (вИЕ : Finset вДВ).sum (fun s => F s z)) = (fun _ : вДВ => 0) := by
      funext z; exact Finset.sum_empty
    rw [h]
    exact RectangleIntegralIntegrable.zero R
  | insert a S' ha ih =>
    intro hF
    have hFa : R.RectangleIntegralIntegrable (F a) :=
      hF a (Finset.mem_insert_self a S')
    have hF' : вИА t вИИ S', R.RectangleIntegralIntegrable (F t) := fun t ht =>
      hF t (Finset.mem_insert_of_mem ht)
    have h_rest := ih hF'
    have h_eq : (fun z : вДВ => (insert a S').sum (fun t => F t z))
              = fun z => F a z + S'.sum (fun t => F t z) := by
      funext z
      exact Finset.sum_insert ha
    rw [h_eq]
    exact hFa.add h_rest

/-- Rectangle integral of a finite sum equals the finite sum of rectangle
integrals, given integrability of each summand. -/
theorem rectangleIntegral_finset_sum
    (R : ZetaRectangle) (F : вДВ вЖТ вДВ вЖТ вДВ) (S : Finset вДВ)
    (hF : вИА s вИИ S, R.RectangleIntegralIntegrable (F s)) :
    R.rectangleIntegral (fun z => S.sum (fun s => F s z)) =
      S.sum (fun s => R.rectangleIntegral (F s)) := by
  classical
  revert hF
  induction S using Finset.induction_on with
  | empty =>
    intro _
    simp only [Finset.sum_empty]
    unfold rectangleIntegral
    simp
  | insert a S' ha ih =>
    intro hF
    have hFa : R.RectangleIntegralIntegrable (F a) :=
      hF a (Finset.mem_insert_self a S')
    have hF' : вИА t вИИ S', R.RectangleIntegralIntegrable (F t) := fun t ht =>
      hF t (Finset.mem_insert_of_mem ht)
    have hSumInt :
        R.RectangleIntegralIntegrable (fun z => S'.sum (fun t => F t z)) :=
      rectangleIntegralIntegrable_finset_sum R F S' hF'
    have h_eq : (fun z : вДВ => (insert a S').sum (fun t => F t z))
              = fun z => F a z + S'.sum (fun t => F t z) := by
      funext z
      exact Finset.sum_insert ha
    rw [h_eq]
    rw [rectangleIntegral_add_of_integrable_package R (F a)
        (fun z => S'.sum (fun t => F t z)) hFa hSumInt]
    rw [Finset.sum_insert ha, ih hF']

/-! ### BR5: integrability-data package + linearity-data assembler -/

/-- Integrability data for a principal-part package: each per-singularity
principal kernel and the log-derivative remainder are rectangle-integrable. -/
structure RectanglePrincipalPartIntegrabilityData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  kernels :
    вИА s вИИ P.singularities,
      R.RectangleIntegralIntegrable
        (fun z => principalKernel (P.principalCoeff s) s z)
  remainder :
    R.RectangleIntegralIntegrable (R.logDerivRemainder P)

/-- **BR5 вАФ ASSEMBLER:** Integrability data implies the linearity inputs
needed to inhabit `RectangleLogDerivContourLinearDecomposition` via BQ4. -/
noncomputable def RectanglePrincipalPartIntegrabilityData.toLinearityData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectanglePrincipalPartIntegrabilityData P) :
    R.RectanglePrincipalPartLinearityData P where
  add := by
    have hsumInt :
        R.RectangleIntegralIntegrable (R.principalPartSum P) := by
      unfold principalPartSum
      exact rectangleIntegralIntegrable_finset_sum R
        (fun s z => principalKernel (P.principalCoeff s) s z)
        P.singularities I.kernels
    exact rectangleIntegral_add_of_integrable_package R
      (R.principalPartSum P) (R.logDerivRemainder P)
      hsumInt I.remainder
  sum := by
    unfold principalPartSum
    exact rectangleIntegral_finset_sum R
      (fun s z => principalKernel (P.principalCoeff s) s z)
      P.singularities I.kernels

/-! ## BS: Inhabit `RectanglePrincipalPartIntegrabilityData` from continuity -/

/-! ### BS1: counted singularities avoid the boundary -/

/-- Every counted principal-part singularity lies off the rectangle
boundary.  Combines `singularities_complete` with strong admissibility's
`noZetaZerosOnBoundary` / `poleNotOnBoundary`. -/
theorem boundary_ne_of_mem_principalPart_singularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s z : вДВ}
    (hs : s вИИ P.singularities) (hz : R.ContainsBoundary z) :
    z вЙ† s := by
  have hsCounted : R.IsCountedZetaSingularityInside s :=
    (P.singularities_complete s).mp hs
  intro hzs
  subst z
  rcases hsCounted with hsZero | hsPole
  ¬Ј exact P.stronglyAdmissible.noZetaZerosOnBoundary s hsZero.1.1 hz
  ¬Ј obtain вЯ®_, hs_eqвЯ© := hsPole
    subst hs_eq
    exact P.stronglyAdmissible.poleNotOnBoundary hz

/-! ### BS2: continuity of `principalKernel` off the singularity -/

/-- `principalKernel k s` is continuous at every point `z вЙ† s`. -/
theorem continuousAt_principalKernel_of_ne
    {k : вД§} {s z : вДВ} (hz : z вЙ† s) :
    ContinuousAt (fun w : вДВ => principalKernel k s w) z := by
  unfold principalKernel
  refine continuousAt_const.div (continuousAt_id.sub continuousAt_const) ?_
  simpa [sub_eq_zero] using hz

/-! ### BS3: per-edge interval-integrability of `principalKernel вИШ ќ≥ * deriv ќ≥` -/

/-- Per-edge integrability of the principal-kernel integrand, for any
continuous parametrization `ќ≥ : вДЭ вЖТ вДВ` of a rectangle edge that stays on
the rectangle boundary (so it stays off every counted singularity). -/
theorem intervalIntegrable_principalKernel_on_edge
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s : вДВ}
    (hs : s вИИ P.singularities) (ќ≥ : вДЭ вЖТ вДВ)
    (hќ≥_cont : Continuous ќ≥)
    (hќ≥_deriv_cont : ContinuousOn (fun t : вДЭ => deriv ќ≥ t) (Set.Icc 0 1))
    (hќ≥_boundary :
      вИА t : вДЭ, 0 вЙ§ t вЖТ t вЙ§ 1 вЖТ R.ContainsBoundary (ќ≥ t)) :
    IntervalIntegrable
      (fun t : вДЭ =>
        principalKernel (P.principalCoeff s) s (ќ≥ t) * deriv ќ≥ t)
      MeasureTheory.volume 0 1 := by
  have hkernel :
      ContinuousOn
        (fun t : вДЭ => principalKernel (P.principalCoeff s) s (ќ≥ t))
        (Set.Icc 0 1) := by
    intro t ht
    have hzbd : R.ContainsBoundary (ќ≥ t) := hќ≥_boundary t ht.1 ht.2
    have hz_ne : ќ≥ t вЙ† s :=
      boundary_ne_of_mem_principalPart_singularities hs hzbd
    exact
      ((continuousAt_principalKernel_of_ne hz_ne).comp
        hќ≥_cont.continuousAt).continuousWithinAt
  exact (hkernel.mul hќ≥_deriv_cont).intervalIntegrable_of_Icc
    (by norm_num : (0 : вДЭ) вЙ§ 1)

/-- Each per-singularity principal kernel is rectangle-integrable. -/
theorem rectangleIntegralIntegrable_principalKernel
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s : вДВ}
    (hs : s вИИ P.singularities) :
    R.RectangleIntegralIntegrable
      (fun z => principalKernel (P.principalCoeff s) s z) where
  bottom :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.bottomEdge R.continuous_bottomEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).bottom
      (fun _ ht0 ht1 => R.bottomEdge_mem_boundary ht0 ht1)
  right :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.rightEdge R.continuous_rightEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).right
      (fun _ ht0 ht1 => R.rightEdge_mem_boundary ht0 ht1)
  top :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.topEdge R.continuous_topEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).top
      (fun _ ht0 ht1 => R.topEdge_mem_boundary ht0 ht1)
  left :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.leftEdge R.continuous_leftEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).left
      (fun _ ht0 ht1 => R.leftEdge_mem_boundary ht0 ht1)

/-! ### BS4: integrability of the principal-part sum -/

/-- The principal-part sum `ќ£_s principalKernel (P.coeff s) s` is
rectangle-integrable, by finite-sum closure on the per-kernel case. -/
theorem rectangleIntegralIntegrable_principalPartSum
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleIntegralIntegrable (R.principalPartSum P) := by
  unfold principalPartSum
  exact rectangleIntegralIntegrable_finset_sum R
    (fun s z => principalKernel (P.principalCoeff s) s z)
    P.singularities
    (fun s hs => rectangleIntegralIntegrable_principalKernel hs)

/-! ### BS5: integrability of the log-derivative remainder via negation / subtraction -/

/-- Bridge from `ZetaRectangleLogDerivIntegrable` (existing) to
`RectangleIntegralIntegrable zetaLogDeriv` (new package). -/
theorem rectangleIntegralIntegrable_zetaLogDeriv
    {R : ZetaRectangle} (hAdm : R.StronglyAdmissibleForZeta) :
    R.RectangleIntegralIntegrable zetaLogDeriv :=
  let H := ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine hAdm
  вЯ®H.bottom, H.right, H.top, H.leftвЯ©

/-- Negation closure for rectangle-integrability. -/
theorem RectangleIntegralIntegrable.neg
    {R : ZetaRectangle} {f : вДВ вЖТ вДВ}
    (hf : R.RectangleIntegralIntegrable f) :
    R.RectangleIntegralIntegrable (fun z => -f z) where
  bottom := by simpa [neg_mul] using hf.bottom.neg
  right := by simpa [neg_mul] using hf.right.neg
  top := by simpa [neg_mul] using hf.top.neg
  left := by simpa [neg_mul] using hf.left.neg

/-- Subtraction closure for rectangle-integrability. -/
theorem RectangleIntegralIntegrable.sub
    {R : ZetaRectangle} {f g : вДВ вЖТ вДВ}
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.RectangleIntegralIntegrable (fun z => f z - g z) := by
  simpa [sub_eq_add_neg] using hf.add hg.neg

/-- The log-derivative remainder is rectangle-integrable, via
`zetaLogDeriv вИТ principalPartSum`. -/
theorem rectangleIntegralIntegrable_logDerivRemainder
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleIntegralIntegrable (R.logDerivRemainder P) := by
  unfold logDerivRemainder
  exact
    (rectangleIntegralIntegrable_zetaLogDeriv P.stronglyAdmissible).sub
      (rectangleIntegralIntegrable_principalPartSum P)

/-! ### BS6: final integrability-data construction -/

/-- **BS6 вАФ INHABITED:** the principal-part integrability data is built
unconditionally from the local kernel-continuity proof (BS3) and the
log-derivative remainder integrability (BS5). -/
noncomputable def rectanglePrincipalPartIntegrabilityData
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectanglePrincipalPartIntegrabilityData P where
  kernels := fun _ hs => rectangleIntegralIntegrable_principalKernel hs
  remainder := rectangleIntegralIntegrable_logDerivRemainder P

/-- **BS6 вАФ DOWNSTREAM:** the linear-decomposition target (BP2) is now
inhabited unconditionally for any `RectanglePrincipalPartData`. -/
noncomputable def rectangleLogDerivContourLinearDecomposition
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleLogDerivContourLinearDecomposition P :=
  RectangleLogDerivContourLinearDecomposition.of_linearityData
    ((rectanglePrincipalPartIntegrabilityData P).toLinearityData)

/-! ### AY4: four-strip boundary-cancellation target -/

/-- Algebraic boundary cancellation: if all four annular strip integrals
of `1/(z - a)` are zero (Cauchy-Goursat) and the edge-integrals over shared
interior edges cancel, then the outer rectangle integral equals the inner
square integral. -/
structure FourStripBoundaryCancellation
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  rectangle_eq_square :
    R.unitPrincipalKernelRectangleIntegral a =
      R.smallSquareUnitKernelIntegral S

/-- Boundary cancellation yields the rectangle-to-square deformation. -/
noncomputable def FourStripBoundaryCancellation.toRectangleToSquare
    {R : ZetaRectangle} {a : вДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripBoundaryCancellation S) :
    R.UnitKernelRectangleToSquareDeformation a S where
  rectangle_eq_square := H.rectangle_eq_square

/-! ## AZ: Mathlib rectangle Cauchy-Goursat adapter -/

/-! ### AZ1 вАФ probe results.

Mathlib's relevant theorem:

```
theorem Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn
    (f : вДВ вЖТ E) (z w : вДВ)
    (Hc : ContinuousOn f ([[z.re, w.re]] √ЧвДВ [[z.im, w.im]]))
    (Hd : DifferentiableOn вДВ f
      (Ioo (min z.re w.re) (max z.re w.re) √ЧвДВ
       Ioo (min z.im w.im) (max z.im w.im))) :
    (вИЂ x : вДЭ in z.re..w.re, f (x + z.im * I)) -
      (вИЂ x : вДЭ in z.re..w.re, f (x + w.im * I)) +
      I вАҐ (вИЂ y : вДЭ in z.im..w.im, f (w.re + y * I)) -
      I вАҐ (вИЂ y : вДЭ in z.im..w.im, f (z.re + y * I)) = 0
```

It uses opposite-corner coordinates `z, w : вДВ` and integrates over straight
real-axis (or imaginary-axis) intervals at fixed `z.im` / `w.im` / `z.re`
/ `w.re`, with explicit `IвАҐ` weights for vertical edges.

Our `rectangleIntegral R f` parameterizes each edge over `t вИИ [0,1]` via
`R.bottomEdge`, `R.rightEdge`, `R.topEdge`, `R.leftEdge` and multiplies by
the path derivative.  Equivalence holds termwise after change of variable
`x := R.left + t¬Ј(R.right вИТ R.left)` (etc.), but the proof crosses several
Mathlib API surfaces (`intervalIntegral.integral_comp_mul_add`, realвЖФcomplex
casting, `Complex.mk = re + im¬ЈI`) and is a substantial bookkeeping proof.

We package the resulting equality as the target structure
`RectangleCauchyGoursatBridge` below.  Once inhabited, every strip's
Cauchy-Goursat follows by AZ4. -/

/-! ### AZ2 вАФ Mathlib rectangle Cauchy-Goursat bridge target -/

/-- The analytic bridge from Mathlib's rectangle Cauchy-Goursat theorem to
our 4-edge `rectangleIntegral` form.  Inhabiting this single target
discharges Cauchy-Goursat for every rectangle and every analytic function. -/
structure RectangleCauchyGoursatBridge : Prop where
  cauchyGoursat :
    вИА (R : ZetaRectangle) (f : вДВ вЖТ вДВ),
      (вИА z вИИ {z : вДВ | R.ContainsClosed z}, AnalyticAt вДВ f z) вЖТ
      R.rectangleIntegral f = 0

/-! ### AZ3 вАФ generic rectangle Cauchy-Goursat (conditional on the bridge) -/

/-- Generic rectangle Cauchy-Goursat: analytic on closed rectangle вЗТ
boundary integral is zero.  Conditional on `RectangleCauchyGoursatBridge`. -/
noncomputable def rectangleCauchyGoursat_of_analyticOn_closed
    (B : RectangleCauchyGoursatBridge)
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ)
    (hf : вИА z вИИ {z : вДВ | R.ContainsClosed z}, AnalyticAt вДВ f z) :
    R.RectangleCauchyGoursat f where
  integral_eq_zero := B.cauchyGoursat R f hf

/-! ### AZ4 вАФ the four strip Cauchy-Goursat specializations -/

/-- Top-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_topStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.topStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_topStrip S)

/-- Bottom-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_bottomStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.bottomStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_bottomStrip S)

/-- Left-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_leftStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.leftStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_leftStrip S)

/-- Right-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_rightStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.rightStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_rightStrip S)

/-! ## BA: Coordinate-form bridge for the Mathlib rectangle theorem -/

/-! ### BA1: direct-coordinate edge integrals -/

/-- Bottom horizontal edge integral, parameterized by real `x` at fixed
imaginary `R.bottom`. -/
noncomputable def bottomHorizontalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  вИЂ x in R.left..R.right, f вЯ®x, R.bottomвЯ©

/-- Top horizontal edge integral oriented right-to-left as in the positive
rectangle boundary. -/
noncomputable def topHorizontalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  вИЂ x in R.right..R.left, f вЯ®x, R.topвЯ©

/-- Right vertical edge integral, parameterized by real `y` at fixed real
`R.right`, with the `I` weight built in. -/
noncomputable def rightVerticalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  вИЂ y in R.bottom..R.top, f вЯ®R.right, yвЯ© * Complex.I

/-- Left vertical edge integral oriented top-to-bottom. -/
noncomputable def leftVerticalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  вИЂ y in R.top..R.bottom, f вЯ®R.left, yвЯ© * Complex.I

/-- Direct-coordinate rectangle boundary integral (sum of four edge
integrals above). -/
noncomputable def coordinateBoundaryIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : вДВ :=
  R.bottomHorizontalIntegral f
    + R.rightVerticalIntegral f
    + R.topHorizontalIntegral f
    + R.leftVerticalIntegral f

/-! ### BA2: per-rectangle edge-bridge target -/

/-- Per-rectangle equality between our `t`-parametrized edge integrals and
the direct-coordinate edge integrals.  Each component is a one-line affine
change-of-variable that we factor out as a separate target. -/
structure RectangleEdgeIntegralCoordinateBridge
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) : Prop where
  bottom :
    (вИЂ t in (0 : вДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t)
      = R.bottomHorizontalIntegral f
  right :
    (вИЂ t in (0 : вДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t)
      = R.rightVerticalIntegral f
  top :
    (вИЂ t in (0 : вДЭ)..1, f (R.topEdge t) * deriv R.topEdge t)
      = R.topHorizontalIntegral f
  left :
    (вИЂ t in (0 : вДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t)
      = R.leftVerticalIntegral f

/-- The four edge equalities assemble into `rectangleIntegral = coordinateBoundaryIntegral`. -/
theorem rectangleIntegral_eq_coordinateBoundaryIntegral
    {R : ZetaRectangle} {f : вДВ вЖТ вДВ}
    (E : R.RectangleEdgeIntegralCoordinateBridge f) :
    R.rectangleIntegral f = R.coordinateBoundaryIntegral f := by
  unfold rectangleIntegral coordinateBoundaryIntegral
  rw [E.bottom, E.right, E.top, E.left]

/-! ### BA3: coordinate-to-Mathlib bridge + combiner to AZ2 -/

/-- Per-rectangle bridge connecting the direct-coordinate boundary integral
to whatever specific expression Mathlib's rectangle Cauchy-Goursat returns. -/
structure CoordinateBoundaryIntegralMathlibBridge
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) where
  mathlibBoundaryIntegral : вДВ
  coordinate_eq_mathlib :
    R.coordinateBoundaryIntegral f = mathlibBoundaryIntegral

/-- If per-(R, f) coordinate adapters and per-(R, f) Mathlib bridges exist,
and Mathlib's boundary integral is zero whenever `f` is analytic on the
closed rectangle, then the global `RectangleCauchyGoursatBridge` follows. -/
noncomputable def RectangleCauchyGoursatBridge.of_coordinate_adapters
    (edgeBridge :
      вИА (R : ZetaRectangle) (f : вДВ вЖТ вДВ),
        R.RectangleEdgeIntegralCoordinateBridge f)
    (mathlibBridge :
      вИА (R : ZetaRectangle) (f : вДВ вЖТ вДВ),
        R.CoordinateBoundaryIntegralMathlibBridge f)
    (mathlibCauchyGoursat :
      вИА (R : ZetaRectangle) (f : вДВ вЖТ вДВ),
        (вИА z вИИ {z : вДВ | R.ContainsClosed z}, AnalyticAt вДВ f z) вЖТ
        (mathlibBridge R f).mathlibBoundaryIntegral = 0) :
    RectangleCauchyGoursatBridge where
  cauchyGoursat R f hf := by
    rw [rectangleIntegral_eq_coordinateBoundaryIntegral (edgeBridge R f)]
    rw [(mathlibBridge R f).coordinate_eq_mathlib]
    exact mathlibCauchyGoursat R f hf

/-! ## BB: Affine change-of-variable lemmas + four edge bridges -/

/-! ### BB1: generic horizontal affine substitution for вДВ-valued integrands -/

/-- Affine change of variable for a вДВ-valued integrand:
`вИЂ t in 0..1, g((b-a)*t + a) * ((b-a):вДВ) = вИЂ x in a..b, g x`.

The integrand has an explicit `(b-a):вДВ` factor (the Jacobian as a real cast
into вДВ).  This is the core affine substitution used by each of the four
edge bridges. -/
theorem intervalIntegral_affine_horizontal_complex
    (g : вДЭ вЖТ вДВ) (a b : вДЭ) :
    (вИЂ t in (0 : вДЭ)..1, g ((b - a) * t + a) * ((b - a : вДЭ) : вДВ)) =
      вИЂ x in a..b, g x := by
  have h_smul :
      (fun t : вДЭ => g ((b - a) * t + a) * ((b - a : вДЭ) : вДВ)) =
        (fun t : вДЭ => (b - a : вДЭ) вАҐ g ((b - a) * t + a)) := by
    funext t
    rw [Complex.real_smul, mul_comm]
  rw [h_smul, intervalIntegral.integral_smul,
      intervalIntegral.smul_integral_comp_mul_add]
  simp only [mul_zero, mul_one, zero_add, sub_add_cancel]

/-! ### BB2: bottom edge bridge -/

/-- Bottom-edge change-of-variable from `t вИИ [0, 1]` to `x вИИ [R.left, R.right]`. -/
theorem bottomEdgeIntegral_eq_bottomHorizontalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    (вИЂ t in (0 : вДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t) =
      R.bottomHorizontalIntegral f := by
  unfold bottomHorizontalIntegral
  have h_pointwise :
      (fun t : вДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t) =
        (fun t : вДЭ =>
          (fun x : вДЭ => f вЯ®x, R.bottomвЯ©) ((R.right - R.left) * t + R.left) *
            ((R.right - R.left : вДЭ) : вДВ)) := by
    funext t
    rw [R.deriv_bottomEdge t]
    have he : R.bottomEdge t = вЯ®(R.right - R.left) * t + R.left, R.bottomвЯ© := by
      unfold ZetaRectangle.bottomEdge
      congr 1
      ring
    rw [he]
  rw [h_pointwise]
  exact intervalIntegral_affine_horizontal_complex
    (fun x : вДЭ => f вЯ®x, R.bottomвЯ©) R.left R.right

/-! ### BB3: generic vertical affine substitution + right edge bridge -/

/-- Vertical affine substitution: same as `intervalIntegral_affine_horizontal_complex`
but with an extra `* Complex.I` weight, matching vertical edge integrals. -/
theorem intervalIntegral_affine_vertical_complex
    (g : вДЭ вЖТ вДВ) (a b : вДЭ) :
    (вИЂ t in (0 : вДЭ)..1,
      g ((b - a) * t + a) * (((b - a : вДЭ) : вДВ) * Complex.I)) =
      вИЂ y in a..b, g y * Complex.I := by
  have h := intervalIntegral_affine_horizontal_complex
    (fun y : вДЭ => g y * Complex.I) a b
  have h_eq :
      (fun t : вДЭ =>
        g ((b - a) * t + a) * (((b - a : вДЭ) : вДВ) * Complex.I)) =
      (fun t : вДЭ =>
        (fun y : вДЭ => g y * Complex.I) ((b - a) * t + a) *
          ((b - a : вДЭ) : вДВ)) := by
    funext t; ring
  rw [h_eq]
  exact h

/-- Right-edge change-of-variable from `t вИИ [0, 1]` to `y вИИ [R.bottom, R.top]`. -/
theorem rightEdgeIntegral_eq_rightVerticalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    (вИЂ t in (0 : вДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t) =
      R.rightVerticalIntegral f := by
  unfold rightVerticalIntegral
  have h_pointwise :
      (fun t : вДЭ => f (R.rightEdge t) * deriv R.rightEdge t) =
        (fun t : вДЭ =>
          (fun y : вДЭ => f вЯ®R.right, yвЯ©)
            ((R.top - R.bottom) * t + R.bottom) *
            (((R.top - R.bottom : вДЭ) : вДВ) * Complex.I)) := by
    funext t
    rw [R.deriv_rightEdge t]
    have he : R.rightEdge t = вЯ®R.right, (R.top - R.bottom) * t + R.bottomвЯ© := by
      unfold ZetaRectangle.rightEdge
      congr 1
      ring
    rw [he]
  rw [h_pointwise]
  exact intervalIntegral_affine_vertical_complex
    (fun y : вДЭ => f вЯ®R.right, yвЯ©) R.bottom R.top

/-! ### BB4: top + left edges via the horizontal/vertical affine lemmas -/

/-- Top-edge change-of-variable; uses reversed orientation `R.right..R.left`. -/
theorem topEdgeIntegral_eq_topHorizontalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    (вИЂ t in (0 : вДЭ)..1, f (R.topEdge t) * deriv R.topEdge t) =
      R.topHorizontalIntegral f := by
  unfold topHorizontalIntegral
  have h_pointwise :
      (fun t : вДЭ => f (R.topEdge t) * deriv R.topEdge t) =
        (fun t : вДЭ =>
          (fun x : вДЭ => f вЯ®x, R.topвЯ©) ((R.left - R.right) * t + R.right) *
            ((R.left - R.right : вДЭ) : вДВ)) := by
    funext t
    rw [R.deriv_topEdge t]
    have he : R.topEdge t = вЯ®(R.left - R.right) * t + R.right, R.topвЯ© := by
      unfold ZetaRectangle.topEdge
      congr 1
      ring
    rw [he]
    push_cast
    ring
  rw [h_pointwise]
  exact intervalIntegral_affine_horizontal_complex
    (fun x : вДЭ => f вЯ®x, R.topвЯ©) R.right R.left

/-- Left-edge change-of-variable; uses reversed orientation `R.top..R.bottom`. -/
theorem leftEdgeIntegral_eq_leftVerticalIntegral
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    (вИЂ t in (0 : вДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t) =
      R.leftVerticalIntegral f := by
  unfold leftVerticalIntegral
  have h_pointwise :
      (fun t : вДЭ => f (R.leftEdge t) * deriv R.leftEdge t) =
        (fun t : вДЭ =>
          (fun y : вДЭ => f вЯ®R.left, yвЯ©) ((R.bottom - R.top) * t + R.top) *
            (((R.bottom - R.top : вДЭ) : вДВ) * Complex.I)) := by
    funext t
    rw [R.deriv_leftEdge t]
    have he : R.leftEdge t = вЯ®R.left, (R.bottom - R.top) * t + R.topвЯ© := by
      unfold ZetaRectangle.leftEdge
      congr 1
      ring
    rw [he]
    push_cast
    ring
  rw [h_pointwise]
  exact intervalIntegral_affine_vertical_complex
    (fun y : вДЭ => f вЯ®R.left, yвЯ©) R.top R.bottom

/-! ### BB5: assembler вАФ `RectangleEdgeIntegralCoordinateBridge` is inhabited -/

/-- The four per-edge change-of-variable equalities assemble into the
per-(R, f) edge bridge.  This is the analytic discharge needed by AZ's
combiner for the global Cauchy-Goursat bridge. -/
theorem rectangleEdgeIntegralCoordinateBridge
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    R.RectangleEdgeIntegralCoordinateBridge f where
  bottom := bottomEdgeIntegral_eq_bottomHorizontalIntegral R f
  right := rightEdgeIntegral_eq_rightVerticalIntegral R f
  top := topEdgeIntegral_eq_topHorizontalIntegral R f
  left := leftEdgeIntegral_eq_leftVerticalIntegral R f

/-! ## BC: Coordinate вЖТ Mathlib boundary bridge + final hook -/

/-! ### BC2: trivial coordinate вЖФ Mathlib bridge -/

/-- Trivial coordinate-to-Mathlib bridge: define the "Mathlib boundary
integral" as our `coordinateBoundaryIntegral`.  This makes the bridge a
pure renaming. -/
noncomputable def coordinateBoundaryIntegralMathlibBridge
    (R : ZetaRectangle) (f : вДВ вЖТ вДВ) :
    R.CoordinateBoundaryIntegralMathlibBridge f where
  mathlibBoundaryIntegral := R.coordinateBoundaryIntegral f
  coordinate_eq_mathlib := rfl

/-! ### BC3: Mathlib Cauchy-Goursat hook (target) -/

/-- Final analytic obligation: for every rectangle and every function analytic
on its closed rectangle, the coordinate boundary integral vanishes.  This is
the direct invocation of `Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn`
plus the algebraic rearrangement matching our coordinate form. -/
structure MathlibCauchyGoursatHook : Prop where
  vanishes :
    вИА (R : ZetaRectangle) (f : вДВ вЖТ вДВ),
      (вИА z вИИ {z : вДВ | R.ContainsClosed z}, AnalyticAt вДВ f z) вЖТ
      R.coordinateBoundaryIntegral f = 0

/-! ### BC4: from hook to global `RectangleCauchyGoursatBridge` -/

/-- The Mathlib Cauchy-Goursat hook plus the proved edge/coordinate adapters
gives the global `RectangleCauchyGoursatBridge`.  Once `MathlibCauchyGoursatHook`
is inhabited, every rectangle/function CG follows mechanically. -/
noncomputable def RectangleCauchyGoursatBridge.of_mathlibHook
    (M : MathlibCauchyGoursatHook) :
    RectangleCauchyGoursatBridge :=
  RectangleCauchyGoursatBridge.of_coordinate_adapters
    (fun R f => rectangleEdgeIntegralCoordinateBridge R f)
    (fun R f => coordinateBoundaryIntegralMathlibBridge R f)
    (fun R f hf => M.vanishes R f hf)

/-! ### BC5: inhabit `MathlibCauchyGoursatHook` from Mathlib's theorem -/

/-- The Mathlib Cauchy-Goursat hook is inhabited by direct invocation of
`Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn`
plus the per-edge coordinate rewrites. -/
theorem mathlibCauchyGoursatHook : MathlibCauchyGoursatHook where
  vanishes R f hf := by
    have hLR : R.left вЙ§ R.right := R.hleft_lt_right.le
    have hBT : R.bottom вЙ§ R.top := R.hbottom_lt_top.le
    set zвВА : вДВ := вЯ®R.left, R.bottomвЯ©
    set wвВА : вДВ := вЯ®R.right, R.topвЯ©
    have hz_re : zвВА.re = R.left := rfl
    have hz_im : zвВА.im = R.bottom := rfl
    have hw_re : wвВА.re = R.right := rfl
    have hw_im : wвВА.im = R.top := rfl
    -- Continuity on Mathlib's closed rectangle
    have hcont : ContinuousOn f
        (Set.uIcc zвВА.re wвВА.re √ЧвДВ Set.uIcc zвВА.im wвВА.im) := by
      intro p hp
      have hp_mem := mem_reProdIm.mp hp
      have hp_re : p.re вИИ Set.uIcc zвВА.re wвВА.re := hp_mem.1
      have hp_im : p.im вИИ Set.uIcc zвВА.im wвВА.im := hp_mem.2
      rw [show zвВА.re = R.left from rfl, show wвВА.re = R.right from rfl,
          Set.uIcc_of_le hLR, Set.mem_Icc] at hp_re
      rw [show zвВА.im = R.bottom from rfl, show wвВА.im = R.top from rfl,
          Set.uIcc_of_le hBT, Set.mem_Icc] at hp_im
      have hp_closed : R.ContainsClosed p :=
        вЯ®hp_re.1, hp_re.2, hp_im.1, hp_im.2вЯ©
      exact (hf p hp_closed).continuousAt.continuousWithinAt
    -- Differentiability on Mathlib's open rectangle
    have hdiff : DifferentiableOn вДВ f
        (Set.Ioo (min zвВА.re wвВА.re) (max zвВА.re wвВА.re) √ЧвДВ
         Set.Ioo (min zвВА.im wвВА.im) (max zвВА.im wвВА.im)) := by
      intro p hp
      have hp_mem := mem_reProdIm.mp hp
      have hp_re : p.re вИИ Set.Ioo (min zвВА.re wвВА.re) (max zвВА.re wвВА.re) :=
        hp_mem.1
      have hp_im : p.im вИИ Set.Ioo (min zвВА.im wвВА.im) (max zвВА.im wвВА.im) :=
        hp_mem.2
      rw [show zвВА.re = R.left from rfl, show wвВА.re = R.right from rfl,
          min_eq_left hLR, max_eq_right hLR, Set.mem_Ioo] at hp_re
      rw [show zвВА.im = R.bottom from rfl, show wвВА.im = R.top from rfl,
          min_eq_left hBT, max_eq_right hBT, Set.mem_Ioo] at hp_im
      have hp_closed : R.ContainsClosed p :=
        вЯ®hp_re.1.le, hp_re.2.le, hp_im.1.le, hp_im.2.leвЯ©
      exact (hf p hp_closed).differentiableAt.differentiableWithinAt
    -- Apply Mathlib's rectangle Cauchy-Goursat theorem
    have h_mathlib :=
      Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn
        f zвВА wвВА hcont hdiff
    rw [hz_re, hz_im, hw_re, hw_im] at h_mathlib
    -- Convert each of our four edge integrals
    have h_bot_eq :
        R.bottomHorizontalIntegral f =
          вИЂ x in R.left..R.right, f (вЖСx + вЖСR.bottom * Complex.I) := by
      unfold bottomHorizontalIntegral
      apply intervalIntegral.integral_congr
      intro x _
      show f вЯ®x, R.bottomвЯ© = f (вЖСx + вЖСR.bottom * Complex.I)
      rw [Complex.mk_eq_add_mul_I]
    have h_top_eq :
        R.topHorizontalIntegral f =
          -(вИЂ x in R.left..R.right, f (вЖСx + вЖСR.top * Complex.I)) := by
      unfold topHorizontalIntegral
      rw [intervalIntegral.integral_symm]
      congr 1
      apply intervalIntegral.integral_congr
      intro x _
      show f вЯ®x, R.topвЯ© = f (вЖСx + вЖСR.top * Complex.I)
      rw [Complex.mk_eq_add_mul_I]
    have h_right_eq :
        R.rightVerticalIntegral f =
          Complex.I вАҐ (вИЂ y in R.bottom..R.top, f (вЖСR.right + вЖСy * Complex.I)) := by
      unfold rightVerticalIntegral
      rw [intervalIntegral.integral_mul_const]
      have h_inner :
          (вИЂ y in R.bottom..R.top, f вЯ®R.right, yвЯ©) =
            вИЂ y in R.bottom..R.top, f (вЖСR.right + вЖСy * Complex.I) := by
        apply intervalIntegral.integral_congr
        intro y _
        show f вЯ®R.right, yвЯ© = f (вЖСR.right + вЖСy * Complex.I)
        rw [Complex.mk_eq_add_mul_I]
      rw [h_inner, smul_eq_mul]
      exact mul_comm _ _
    have h_left_eq :
        R.leftVerticalIntegral f =
          -(Complex.I вАҐ (вИЂ y in R.bottom..R.top, f (вЖСR.left + вЖСy * Complex.I))) := by
      unfold leftVerticalIntegral
      rw [intervalIntegral.integral_symm]
      rw [intervalIntegral.integral_mul_const]
      have h_inner :
          (вИЂ y in R.bottom..R.top, f вЯ®R.left, yвЯ©) =
            вИЂ y in R.bottom..R.top, f (вЖСR.left + вЖСy * Complex.I) := by
        apply intervalIntegral.integral_congr
        intro y _
        show f вЯ®R.left, yвЯ© = f (вЖСR.left + вЖСy * Complex.I)
        rw [Complex.mk_eq_add_mul_I]
      rw [h_inner, smul_eq_mul]
      ring
    -- Assemble
    have h_sum : R.coordinateBoundaryIntegral f =
        (вИЂ x in R.left..R.right, f (вЖСx + вЖСR.bottom * Complex.I)) -
          (вИЂ x in R.left..R.right, f (вЖСx + вЖСR.top * Complex.I)) +
          Complex.I вАҐ (вИЂ y in R.bottom..R.top, f (вЖСR.right + вЖСy * Complex.I)) -
          Complex.I вАҐ (вИЂ y in R.bottom..R.top, f (вЖСR.left + вЖСy * Complex.I)) := by
      unfold coordinateBoundaryIntegral
      rw [h_bot_eq, h_right_eq, h_top_eq, h_left_eq]
      ring
    rw [h_sum]
    exact h_mathlib

/-! ## BD: Four-strip boundary cancellation -/

/-! ### BD0: unconditional global rectangle Cauchy-Goursat bridge -/

/-- The global rectangle Cauchy-Goursat bridge, now unconditional via
`mathlibCauchyGoursatHook`. -/
noncomputable def globalRectangleCauchyGoursatBridge : RectangleCauchyGoursatBridge :=
  RectangleCauchyGoursatBridge.of_mathlibHook mathlibCauchyGoursatHook

/-! ## BT: Cauchy-Goursat closure of the principal-part contour decomposition -/

/-! ### BT1: vanishing of the remainder integral from analyticity -/

/-- If the log-derivative remainder is analytic at every point of the closed
rectangle, then its rectangle boundary integral vanishes (Mathlib
Cauchy-Goursat via the unconditional global bridge). -/
noncomputable def rectangleLogDerivRemainderIntegralVanishes_of_analyticOn
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (hAn : вИА z вИИ {z : вДВ | R.ContainsClosed z},
      AnalyticAt вДВ (R.logDerivRemainder P) z) :
    R.RectangleLogDerivRemainderIntegralVanishes P where
  integral_eq_zero :=
    globalRectangleCauchyGoursatBridge.cauchyGoursat R
      (R.logDerivRemainder P) hAn

/-! ### BT2: analytic-remainder data package -/

/-- The analytic content needed for the remainder: after subtracting all
local principal parts, `ќґ'/ќґ` is analytic at every closed-rectangle point. -/
structure RectangleLogDerivRemainderAnalyticData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  analytic_remainder :
    вИА z вИИ {z : вДВ | R.ContainsClosed z},
      AnalyticAt вДВ (R.logDerivRemainder P) z

/-- Analytic-remainder data discharges the remainder-vanishing target. -/
noncomputable def RectangleLogDerivRemainderAnalyticData.toVanishes
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleLogDerivRemainderAnalyticData P) :
    R.RectangleLogDerivRemainderIntegralVanishes P :=
  rectangleLogDerivRemainderIntegralVanishes_of_analyticOn A.analytic_remainder

/-! ### BT3: analyticity of remainder closes the contour decomposition -/

/-- **BT3 вАФ UNCONDITIONAL ASSEMBLER:** linearity (BS6) + analyticity of the
remainder (BT2) вЗТ principal-part contour decomposition.  The remainder
analytic-data field is the only outstanding analytic obligation. -/
noncomputable def RectangleLogDerivRemainderAnalyticData.toPrincipalPartContourDecomposition
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleLogDerivRemainderAnalyticData P) :
    R.RectanglePrincipalPartContourDecomposition P :=
  RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    (rectangleLogDerivContourLinearDecomposition P) A.toVanishes


/-- Bundles the four strip Cauchy-Goursat facts. -/
structure FourStripCauchyGoursatData
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  topCG : S.topStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  bottomCG : S.bottomStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  leftCG : S.leftStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  rightCG : S.rightStrip.RectangleCauchyGoursat (unitPrincipalKernel a)

/-- The four strip Cauchy-Goursat facts are now unconditional. -/
theorem fourStripCauchyGoursatData
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripCauchyGoursatData S where
  topCG :=
    rectangleCauchyGoursat_topStrip_unitKernel globalRectangleCauchyGoursatBridge S
  bottomCG :=
    rectangleCauchyGoursat_bottomStrip_unitKernel globalRectangleCauchyGoursatBridge S
  leftCG :=
    rectangleCauchyGoursat_leftStrip_unitKernel globalRectangleCauchyGoursatBridge S
  rightCG :=
    rectangleCauchyGoursat_rightStrip_unitKernel globalRectangleCauchyGoursatBridge S

/-! ### BD2: boundary-sum identity (target) -/

/-- Algebraic boundary-sum identity: the sum of the four strip boundary
integrals equals the outer rectangle integral minus the inner square integral.

The proof requires expanding each strip integral, splitting at shared interior
edges, and pairwise-cancelling reversed-orientation edge contributions.
Substantial pure-algebra step, left as a target. -/
structure FourStripBoundarySumIdentity
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  sum_eq :
    S.topStrip.unitPrincipalKernelRectangleIntegral a
      + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
      + S.leftStrip.unitPrincipalKernelRectangleIntegral a
      + S.rightStrip.unitPrincipalKernelRectangleIntegral a =
    R.unitPrincipalKernelRectangleIntegral a -
      R.smallSquareUnitKernelIntegral S

/-! ### BD4: four-strip CG + sum identity вЗТ boundary cancellation -/

/-- Combining the four strip Cauchy-Goursat facts with the boundary-sum
identity yields the rectangle-equals-square cancellation. -/
theorem fourStripBoundaryCancellation_of_sumIdentity
    {R : ZetaRectangle} {a : вДВ}
    {S : R.SmallSquareInsideRectangle a}
    (CG : FourStripCauchyGoursatData S)
    (H : FourStripBoundarySumIdentity S) :
    FourStripBoundaryCancellation S where
  rectangle_eq_square := by
    have h_top : S.topStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.topCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_bot : S.bottomStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.bottomCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_left : S.leftStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.leftCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_right : S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.rightCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have hsum_zero :
        S.topStrip.unitPrincipalKernelRectangleIntegral a
          + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
          + S.leftStrip.unitPrincipalKernelRectangleIntegral a
          + S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      rw [h_top, h_bot, h_left, h_right]; ring
    have hsub :
        R.unitPrincipalKernelRectangleIntegral a -
          R.smallSquareUnitKernelIntegral S = 0 := by
      rw [вЖР H.sum_eq]; exact hsum_zero
    exact sub_eq_zero.mp hsub

/-! ### BD5: rectangle-to-square deformation (conditional on sum identity) -/

/-- Once the boundary-sum identity is inhabited, the rectangle-to-square
deformation follows mechanically. -/
noncomputable def unitKernelRectangleToSquareDeformation_of_sumIdentity
    {R : ZetaRectangle} {a : вДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripBoundarySumIdentity S) :
    R.UnitKernelRectangleToSquareDeformation a S :=
  (fourStripBoundaryCancellation_of_sumIdentity
      (fourStripCauchyGoursatData S) H).toRectangleToSquare

/-! ## BE: Coordinate-form boundary cancellation -/

/-! ### BE1: coordinate-form sum identity (target) -/

/-- Coordinate-form four-strip boundary cancellation: in the
`coordinateBoundaryIntegral` form, the sum of strip boundary integrals equals
the outer rectangle integral minus the inner square integral.

This is the pure-algebra step: 16 strip-edge integrals cancel pairwise at
shared interior edges, leaving the outer boundary minus the inner. -/
structure FourStripCoordinateBoundarySumIdentity
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  coordinate_sum_eq :
    S.topStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.bottomStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.leftStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.rightStrip.coordinateBoundaryIntegral (unitPrincipalKernel a) =
    R.coordinateBoundaryIntegral (unitPrincipalKernel a)
      - S.toRectangle.coordinateBoundaryIntegral (unitPrincipalKernel a)

/-! ### BE2: coordinate identity вЗТ existing `FourStripBoundarySumIdentity` -/

/-- Conversion: a coordinate-form sum identity inhabits the existing unit-kernel
sum-identity target.  Uses the rectangle-integral / coordinate-integral bridge
for each of the six rectangles involved. -/
theorem FourStripCoordinateBoundarySumIdentity.toBoundarySumIdentity
    {R : ZetaRectangle} {a : вДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripCoordinateBoundarySumIdentity S) :
    FourStripBoundarySumIdentity S where
  sum_eq := by
    -- Convert each unit-kernel rectangle integral to coordinate form
    have h_to_coord : вИА (R' : ZetaRectangle),
        R'.unitPrincipalKernelRectangleIntegral a =
          R'.coordinateBoundaryIntegral (unitPrincipalKernel a) := by
      intro R'
      rw [вЖР rectangleIntegral_unitPrincipalKernel_eq]
      exact rectangleIntegral_eq_coordinateBoundaryIntegral
        (rectangleEdgeIntegralCoordinateBridge R' (unitPrincipalKernel a))
    have h_inner :
        R.smallSquareUnitKernelIntegral S =
          S.toRectangle.coordinateBoundaryIntegral (unitPrincipalKernel a) := by
      unfold smallSquareUnitKernelIntegral
      exact h_to_coord S.toRectangle
    rw [h_to_coord S.topStrip, h_to_coord S.bottomStrip,
        h_to_coord S.leftStrip, h_to_coord S.rightStrip,
        h_to_coord R, h_inner]
    exact H.coordinate_sum_eq

/-! ### BE3: target вАФ actual proof of coordinate cancellation.

The substantial pure-algebra step.  Sketched but left as a target structure;
proof requires:
1. unfolding `coordinateBoundaryIntegral` and the four strip definitions;
2. splitting outer-edge integrals at the inner-square corners using
   `intervalIntegral.integral_add_adjacent_intervals`;
3. using `intervalIntegral.integral_symm` to flip reversed-orientation
   internal edges;
4. matching the 16 strip-edge integrals with the 4 outer-edge + 4 inner-edge
   (negated) contributions by `abel`.

Deferred. -/

/-! ### BE5: unconditional rectangle-to-square deformation (conditional on BE3) -/

/-- Once the coordinate-form sum identity is inhabited, the unit-kernel
rectangle-to-square deformation is unconditional. -/
noncomputable def unitKernelRectangleToSquareDeformation_of_coordinateIdentity
    {R : ZetaRectangle} {a : вДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripCoordinateBoundarySumIdentity S) :
    R.UnitKernelRectangleToSquareDeformation a S :=
  unitKernelRectangleToSquareDeformation_of_sumIdentity
    H.toBoundarySumIdentity

/-! ## BF: Interval helper lemmas for boundary cancellation -/

/-- Reverse-pair cancellation: `вИЂ a..b g + вИЂ b..a g = 0` for вДВ-valued
integrands.  Pure reversal вАФ no integrability needed. -/
theorem intervalIntegral_add_reverse_eq_zero
    (g : вДЭ вЖТ вДВ) (a b : вДЭ) :
    (вИЂ x in a..b, g x) + (вИЂ x in b..a, g x) = 0 := by
  rw [intervalIntegral.integral_symm]
  ring

/-- Reverse-pair cancellation with `* Complex.I` weight (for vertical
edges). -/
theorem intervalIntegral_add_reverse_eq_zero_with_I
    (g : вДЭ вЖТ вДВ) (a b : вДЭ) :
    (вИЂ x in a..b, g x * Complex.I) +
      (вИЂ x in b..a, g x * Complex.I) = 0 :=
  intervalIntegral_add_reverse_eq_zero (fun x => g x * Complex.I) a b

/-- Three-piece adjacent concatenation:
`вИЂ a..b g + вИЂ b..c g + вИЂ c..d g = вИЂ a..d g`, given integrability across the
three sub-intervals. -/
theorem intervalIntegral_add_three_adjacent_eq
    {g : вДЭ вЖТ вДВ} {a b c d : вДЭ}
    (hab : IntervalIntegrable g MeasureTheory.volume a b)
    (hbc : IntervalIntegrable g MeasureTheory.volume b c)
    (hcd : IntervalIntegrable g MeasureTheory.volume c d) :
    (вИЂ x in a..b, g x) + (вИЂ x in b..c, g x) + (вИЂ x in c..d, g x) =
      вИЂ x in a..d, g x := by
  rw [intervalIntegral.integral_add_adjacent_intervals hab hbc]
  exact intervalIntegral.integral_add_adjacent_intervals (hab.trans hbc) hcd

/-! ## BG: Named edge integrals + symbolic boundary identity -/

/-! ### BG1: named coordinate edge integrals -/

/-- Horizontal edge integral of the unit kernel: integrate `1/(вЯ®x, yвЯ© - a)`
along `x` from `xвВА` to `xвВБ` at fixed imaginary part `y`. -/
noncomputable def hEdge (y xвВА xвВБ : вДЭ) (a : вДВ) : вДВ :=
  вИЂ x in xвВА..xвВБ, unitPrincipalKernel a вЯ®x, yвЯ©

/-- Vertical edge integral of the unit kernel with `* Complex.I` weight. -/
noncomputable def vEdge (x yвВА yвВБ : вДЭ) (a : вДВ) : вДВ :=
  вИЂ y in yвВА..yвВБ, unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I

theorem bottomHorizontalIntegral_eq_hEdge
    (R : ZetaRectangle) (a : вДВ) :
    R.bottomHorizontalIntegral (unitPrincipalKernel a) =
      hEdge R.bottom R.left R.right a := rfl

theorem topHorizontalIntegral_eq_hEdge
    (R : ZetaRectangle) (a : вДВ) :
    R.topHorizontalIntegral (unitPrincipalKernel a) =
      hEdge R.top R.right R.left a := rfl

theorem rightVerticalIntegral_eq_vEdge
    (R : ZetaRectangle) (a : вДВ) :
    R.rightVerticalIntegral (unitPrincipalKernel a) =
      vEdge R.right R.bottom R.top a := rfl

theorem leftVerticalIntegral_eq_vEdge
    (R : ZetaRectangle) (a : вДВ) :
    R.leftVerticalIntegral (unitPrincipalKernel a) =
      vEdge R.left R.top R.bottom a := rfl

/-! ### BG2: reverse-edge cancellation in named form -/

theorem hEdge_add_reverse_eq_zero
    (y xвВА xвВБ : вДЭ) (a : вДВ) :
    hEdge y xвВА xвВБ a + hEdge y xвВБ xвВА a = 0 := by
  unfold hEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©) xвВА xвВБ

theorem vEdge_add_reverse_eq_zero
    (x yвВА yвВБ : вДЭ) (a : вДВ) :
    vEdge x yвВА yвВБ a + vEdge x yвВБ yвВА a = 0 := by
  unfold vEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I) yвВА yвВБ

theorem hEdge_reverse_eq_neg
    (y xвВА xвВБ : вДЭ) (a : вДВ) :
    hEdge y xвВБ xвВА a = -hEdge y xвВА xвВБ a := by
  unfold hEdge
  exact intervalIntegral.integral_symm xвВА xвВБ

theorem vEdge_reverse_eq_neg
    (x yвВА yвВБ : вДЭ) (a : вДВ) :
    vEdge x yвВБ yвВА a = -vEdge x yвВА yвВБ a := by
  unfold vEdge
  exact intervalIntegral.integral_symm yвВА yвВБ

/-! ### BG3: three-piece adjacency in named form (with integrability) -/

theorem hEdge_add_three_adjacent_eq
    {y xвВА xвВБ xвВВ xвВГ : вДЭ} {a : вДВ}
    (h01 : IntervalIntegrable
            (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©)
            MeasureTheory.volume xвВА xвВБ)
    (h12 : IntervalIntegrable
            (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©)
            MeasureTheory.volume xвВБ xвВВ)
    (h23 : IntervalIntegrable
            (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©)
            MeasureTheory.volume xвВВ xвВГ) :
    hEdge y xвВА xвВБ a + hEdge y xвВБ xвВВ a + hEdge y xвВВ xвВГ a =
      hEdge y xвВА xвВГ a := by
  unfold hEdge
  exact intervalIntegral_add_three_adjacent_eq h01 h12 h23

theorem vEdge_add_three_adjacent_eq
    {x yвВА yвВБ yвВВ yвВГ : вДЭ} {a : вДВ}
    (h01 : IntervalIntegrable
            (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I)
            MeasureTheory.volume yвВА yвВБ)
    (h12 : IntervalIntegrable
            (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I)
            MeasureTheory.volume yвВБ yвВВ)
    (h23 : IntervalIntegrable
            (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I)
            MeasureTheory.volume yвВВ yвВГ) :
    vEdge x yвВА yвВБ a + vEdge x yвВБ yвВВ a + vEdge x yвВВ yвВГ a =
      vEdge x yвВА yвВГ a := by
  unfold vEdge
  exact intervalIntegral_add_three_adjacent_eq h01 h12 h23

/-! ## BH: Symbolic four-strip boundary identity -/

/-- Symbolic four-strip boundary cancellation: a pure additive-group identity
in 24 named edge integrals.  The eight hypotheses are the only analytic
facts needed (three-piece concatenations and reverse-orientation negations);
once supplied, the rest is `abel`. -/
theorem fourStripBoundarySymbolic
    (L Rgt B T xl xr yb yt : вДЭ) (a : вДВ)
    (hRight :
      vEdge Rgt B yb a + vEdge Rgt yb yt a + vEdge Rgt yt T a =
        vEdge Rgt B T a)
    (hLeft :
      vEdge L T yt a + vEdge L yt yb a + vEdge L yb B a =
        vEdge L T B a)
    (hInnerBottomJoin :
      hEdge yb L xl a + hEdge yb xl xr a + hEdge yb xr Rgt a =
        hEdge yb L Rgt a)
    (hInnerTopJoin :
      hEdge yt Rgt xr a + hEdge yt xr xl a + hEdge yt xl L a =
        hEdge yt Rgt L a)
    (hInnerBottomReverse :
      hEdge yb Rgt L a = -hEdge yb L Rgt a)
    (hInnerTopReverse :
      hEdge yt L Rgt a = -hEdge yt Rgt L a)
    (hInnerLeftReverse :
      vEdge xl yb yt a = -vEdge xl yt yb a)
    (hInnerRightReverse :
      vEdge xr yt yb a = -vEdge xr yb yt a) :
    ((hEdge B L Rgt a + vEdge Rgt B yb a
        + hEdge yb Rgt L a + vEdge L yb B a)
      +
      (hEdge yt L Rgt a + vEdge Rgt yt T a
        + hEdge T Rgt L a + vEdge L T yt a)
      +
      (hEdge yb L xl a + vEdge xl yb yt a
        + hEdge yt xl L a + vEdge L yt yb a)
      +
      (hEdge yb xr Rgt a + vEdge Rgt yb yt a
        + hEdge yt Rgt xr a + vEdge xr yt yb a)) =
    (hEdge B L Rgt a + vEdge Rgt B T a
      + hEdge T Rgt L a + vEdge L T B a) -
    (hEdge yb xl xr a + vEdge xr yb yt a
      + hEdge yt xr xl a + vEdge xl yt yb a) := by
  rw [вЖР hRight, вЖР hLeft]
  rw [hInnerBottomReverse, hInnerTopReverse,
      hInnerLeftReverse, hInnerRightReverse]
  rw [вЖР hInnerBottomJoin, вЖР hInnerTopJoin]
  abel

/-! ## BI: Integrability primitives for the unit kernel -/

/-- `(fun x => вЯ®x, yвЯ© : вДЭ вЖТ вДВ)` is continuous. -/
theorem continuous_complex_mk_real_horizontal (y : вДЭ) :
    Continuous (fun x : вДЭ => (вЯ®x, yвЯ© : вДВ)) := by
  have h_eq :
      (fun x : вДЭ => (вЯ®x, yвЯ© : вДВ)) =
        fun x : вДЭ => ((x : вДВ) + (y : вДВ) * Complex.I) := by
    funext x; exact Complex.mk_eq_add_mul_I x y
  rw [h_eq]
  exact Complex.continuous_ofReal.add continuous_const

/-- `(fun y => вЯ®x, yвЯ© : вДЭ вЖТ вДВ)` is continuous. -/
theorem continuous_complex_mk_real_vertical (x : вДЭ) :
    Continuous (fun y : вДЭ => (вЯ®x, yвЯ© : вДВ)) := by
  have h_eq :
      (fun y : вДЭ => (вЯ®x, yвЯ© : вДВ)) =
        fun y : вДЭ => ((x : вДВ) + (y : вДВ) * Complex.I) := by
    funext y; exact Complex.mk_eq_add_mul_I x y
  rw [h_eq]
  exact continuous_const.add (Complex.continuous_ofReal.mul continuous_const)

/-- The unit kernel `1/(z-a)` is continuous along the horizontal line at fixed
imaginary part `y вЙ† a.im`. -/
theorem continuous_unitPrincipalKernel_horizontal
    (a : вДВ) {y : вДЭ} (hy : y вЙ† a.im) :
    Continuous (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©) := by
  unfold unitPrincipalKernel
  refine Continuous.div continuous_const
    ((continuous_complex_mk_real_horizontal y).sub continuous_const) ?_
  intro x heq
  have h_eq : (вЯ®x, yвЯ© : вДВ) = a := sub_eq_zero.mp heq
  have hyeq : y = a.im := by
    have := congrArg Complex.im h_eq
    simpa using this
  exact hy hyeq

/-- The unit kernel `1/(z-a)` is integrable along the horizontal line at fixed
imaginary part `y вЙ† a.im` over any interval. -/
theorem intervalIntegrable_unitPrincipalKernel_horizontal
    (a : вДВ) {y : вДЭ} (hy : y вЙ† a.im) (xвВА xвВБ : вДЭ) :
    IntervalIntegrable
      (fun x : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©)
      MeasureTheory.volume xвВА xвВБ :=
  (continuous_unitPrincipalKernel_horizontal a hy).intervalIntegrable xвВА xвВБ

/-- The unit kernel times `I` is continuous along the vertical line at fixed
real part `x вЙ† a.re`. -/
theorem continuous_unitPrincipalKernel_vertical_with_I
    (a : вДВ) {x : вДЭ} (hx : x вЙ† a.re) :
    Continuous (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I) := by
  have h_inner : Continuous (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ©) := by
    unfold unitPrincipalKernel
    refine Continuous.div continuous_const
      ((continuous_complex_mk_real_vertical x).sub continuous_const) ?_
    intro y heq
    have h_eq : (вЯ®x, yвЯ© : вДВ) = a := sub_eq_zero.mp heq
    have hxeq : x = a.re := by
      have := congrArg Complex.re h_eq
      simpa using this
    exact hx hxeq
  exact h_inner.mul continuous_const

/-- The unit kernel times `I` is integrable along the vertical line. -/
theorem intervalIntegrable_unitPrincipalKernel_vertical_with_I
    (a : вДВ) {x : вДЭ} (hx : x вЙ† a.re) (yвВА yвВБ : вДЭ) :
    IntervalIntegrable
      (fun y : вДЭ => unitPrincipalKernel a вЯ®x, yвЯ© * Complex.I)
      MeasureTheory.volume yвВА yвВБ :=
  (continuous_unitPrincipalKernel_vertical_with_I a hx).intervalIntegrable yвВА yвВБ

/-! ## BJ: Final coordinate cancellation вАФ `FourStripCoordinateBoundarySumIdentity` -/

theorem fourStripCoordinateBoundarySumIdentity
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripCoordinateBoundarySumIdentity S := by
  refine вЯ®?_вЯ©
  have haOpen : R.ContainsOpen a := by
    apply S.square_subset_open
    refine вЯ®?_, ?_вЯ©
    ¬Ј show |a.re - a.re| вЙ§ S.r; simp; exact S.r_pos.le
    ¬Ј show |a.im - a.im| вЙ§ S.r; simp; exact S.r_pos.le
  have hright_ne : R.right вЙ† a.re := fun h => by linarith [haOpen.2.1]
  have hleft_ne : R.left вЙ† a.re := fun h => by linarith [haOpen.1]
  have hyb_ne : a.im - S.r вЙ† a.im := fun h => by linarith [S.r_pos]
  have hyt_ne : a.im + S.r вЙ† a.im := fun h => by linarith [S.r_pos]
  have h_sym :=
    fourStripBoundarySymbolic
      R.left R.right R.bottom R.top
      (a.re - S.r) (a.re + S.r)
      (a.im - S.r) (a.im + S.r) a
      (vEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne R.bottom (a.im - S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne (a.im - S.r) (a.im + S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne (a.im + S.r) R.top))
      (vEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne R.top (a.im + S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne (a.im + S.r) (a.im - S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne (a.im - S.r) R.bottom))
      (hEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne R.left (a.re - S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne (a.re - S.r) (a.re + S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne (a.re + S.r) R.right))
      (hEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne R.right (a.re + S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne (a.re + S.r) (a.re - S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne (a.re - S.r) R.left))
      (hEdge_reverse_eq_neg (a.im - S.r) R.left R.right a)
      (hEdge_reverse_eq_neg (a.im + S.r) R.right R.left a)
      (vEdge_reverse_eq_neg (a.re - S.r) (a.im + S.r) (a.im - S.r) a)
      (vEdge_reverse_eq_neg (a.re + S.r) (a.im - S.r) (a.im + S.r) a)
  unfold coordinateBoundaryIntegral bottomHorizontalIntegral
    topHorizontalIntegral rightVerticalIntegral leftVerticalIntegral
    SmallSquareInsideRectangle.topStrip
    SmallSquareInsideRectangle.bottomStrip
    SmallSquareInsideRectangle.leftStrip
    SmallSquareInsideRectangle.rightStrip
    SmallSquareInsideRectangle.toRectangle
  unfold hEdge vEdge at h_sym
  linear_combination h_sym

/-- The existing unit-kernel sum identity, now unconditional. -/
noncomputable def fourStripBoundarySumIdentity
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripBoundarySumIdentity S :=
  (fourStripCoordinateBoundarySumIdentity S).toBoundarySumIdentity

/-- Unconditional unit-kernel rectangle-to-square deformation. -/
noncomputable def unitKernelRectangleToSquareDeformation
    {R : ZetaRectangle} {a : вДВ}
    (S : R.SmallSquareInsideRectangle a) :
    R.UnitKernelRectangleToSquareDeformation a S :=
  unitKernelRectangleToSquareDeformation_of_coordinateIdentity
    (fourStripCoordinateBoundarySumIdentity S)

/-! ## BK: Square-from-circle construction + canonical inner target -/

/-! ### BK1: quarter-radius square sits inside the closed ball -/

/-- Geometry: if `|z.re - a.re| вЙ§ r/4` and `|z.im - a.im| вЙ§ r/4`, then
`z вИИ closedBall a r`.  Uses the triangle inequality
`вАЦz - aвАЦ вЙ§ |(z-a).re| + |(z-a).im|`. -/
theorem square_subset_closedBall_of_radius_quarter
    (a z : вДВ) {r : вДЭ}
    (hz : |z.re - a.re| вЙ§ r / 4 вИІ |z.im - a.im| вЙ§ r / 4) :
    z вИИ Metric.closedBall a r := by
  obtain вЯ®hx, hyвЯ© := hz
  rw [Metric.mem_closedBall, dist_eq_norm]
  have h_bound : вАЦz - aвАЦ вЙ§ |(z - a).re| + |(z - a).im| :=
    Complex.norm_le_abs_re_add_abs_im (z - a)
  have h_re : (z - a).re = z.re - a.re := Complex.sub_re z a
  have h_im : (z - a).im = z.im - a.im := Complex.sub_im z a
  rw [h_re, h_im] at h_bound
  have h_re_nn : 0 вЙ§ |z.re - a.re| := abs_nonneg _
  have h_im_nn : 0 вЙ§ |z.im - a.im| := abs_nonneg _
  linarith

/-! ### BK2: small square from a small circle (radius `r/4`) -/

/-- Given a small circle of radius `r` inside the rectangle, build a small
square of side `r/4` also inside the rectangle.  The square lies inside the
closed ball of radius `r` (by BK1), which is inside the open rectangle. -/
noncomputable def SmallCircleInsideRectangle.toSmallSquare
    {R : ZetaRectangle} {a : вДВ}
    (C : R.SmallCircleInsideRectangle a) :
    R.SmallSquareInsideRectangle a where
  r := C.r / 4
  r_pos := by
    have := C.r_pos
    positivity
  square_subset_open := by
    intro z hz
    apply C.closedBall_subset_open
    exact square_subset_closedBall_of_radius_quarter a z hz

/-! ### BK3: canonical squareвЖТcircle deformation target -/

/-- Square-to-circle deformation specialized to the canonical square chosen
inside the circle.  This is the analytic obligation that closes the
unit-kernel punctured-CG chain. -/
structure UnitKernelCanonicalSquareToCircleDeformation
    (R : ZetaRectangle) (a : вДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  square_eq_circle :
    R.smallSquareUnitKernelIntegral C.toSmallSquare =
      unitKernelCircleIntegral a C.r

/-- Canonical-square deformation gives the general square-to-circle target
at the canonical square. -/
noncomputable def UnitKernelCanonicalSquareToCircleDeformation.toSquareToCircle
    {R : ZetaRectangle} {a : вДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.UnitKernelCanonicalSquareToCircleDeformation a C) :
    R.UnitKernelSquareToCircleDeformation a C.toSmallSquare C where
  square_eq_circle := H.square_eq_circle

/-! ### BK4: punctured CG from the canonical-square target -/

/-- Combine the unconditional rectangle-to-square deformation with the
canonical-square-to-circle deformation to obtain the punctured-rectangle
Cauchy-Goursat theorem. -/
noncomputable def PuncturedRectangleCauchyGoursat.of_canonicalSquareToCircle
    {R : ZetaRectangle} {a : вДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.UnitKernelCanonicalSquareToCircleDeformation a C) :
    R.PuncturedRectangleCauchyGoursat a C :=
  PuncturedRectangleCauchyGoursat.of_square_deformations
    (unitKernelRectangleToSquareDeformation C.toSmallSquare)
    H.toSquareToCircle

/-! ## BM: Centered-square reduction for the canonical-square obligation -/

/-! ### BM1: centered-square unit-kernel integral -/

/-- The unit-kernel integral around the axis-aligned square centered at the
origin with half-side `ѕБ`.  Translation-invariance reduces the canonical
square integral to this concrete `ѕБ`-parametrized one. -/
noncomputable def centeredSquareUnitKernelIntegral (ѕБ : вДЭ) : вДВ :=
  (вИЂ x in (-ѕБ)..ѕБ, (1 : вДВ) / ((x : вДВ) - (ѕБ : вДВ) * Complex.I))
    + (вИЂ y in (-ѕБ)..ѕБ, (1 : вДВ) / ((ѕБ : вДВ) + (y : вДВ) * Complex.I)) * Complex.I
    + (вИЂ x in ѕБ..(-ѕБ), (1 : вДВ) / ((x : вДВ) + (ѕБ : вДВ) * Complex.I))
    + (вИЂ y in ѕБ..(-ѕБ), (1 : вДВ) / (-(ѕБ : вДВ) + (y : вДВ) * Complex.I)) * Complex.I

/-! ### BM2: target вАФ canonical square equals centered square (translation invariance) -/

/-- Translation-invariance target: the unit-kernel integral around the
canonical square centered at `a` equals the same integral around the
centered square of equal half-side.  Pure affine change-of-variable. -/
structure CanonicalSquareEqualsCenteredSquare
    (R : ZetaRectangle) (a : вДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  canonical_eq_centered :
    R.smallSquareUnitKernelIntegral C.toSmallSquare =
      centeredSquareUnitKernelIntegral C.toSmallSquare.r

/-! ### BM3: target вАФ centered square integral equals `2ѕАi` -/

/-- Centered-square integral target: for any positive half-side, the
unit-kernel integral around the centered square equals `twoPiI`.  Provable
by four real arctan computations (one per edge, each evaluating to `iѕА/2`). -/
structure CenteredSquareEqualsTwoPiI : Prop where
  eq_twoPiI :
    вИА {ѕБ : вДЭ}, 0 < ѕБ вЖТ
      centeredSquareUnitKernelIntegral ѕБ = twoPiI

/-! ### BM4: combine BM2 + BM3 into the canonical squareвЖТcircle deformation -/

/-- Translation invariance + centered-square evaluation discharges the
canonical squareвЖТcircle target. -/
noncomputable def UnitKernelCanonicalSquareToCircleDeformation.of_centered_reduction
    (HCent : CenteredSquareEqualsTwoPiI)
    {R : ZetaRectangle} {a : вДВ}
    {C : R.SmallCircleInsideRectangle a}
    (HTrans : CanonicalSquareEqualsCenteredSquare R a C) :
    R.UnitKernelCanonicalSquareToCircleDeformation a C where
  square_eq_circle := by
    rw [HTrans.canonical_eq_centered]
    rw [HCent.eq_twoPiI C.toSmallSquare.r_pos]
    exact (unitKernelCircleIntegral_eq_twoPiI a C.r_pos).symm

/-! ## BN: Translation invariance вАФ `canonicalSquareEqualsCenteredSquare` -/

/-- Per-edge bottom integrand identity: shifting the integration coordinate
by `a.re` reduces the canonical bottom integrand to the centered-square form. -/
theorem canonicalSquare_bottom_eq_centered
    (a : вДВ) (ѕБ : вДЭ) :
    (вИЂ X in (a.re - ѕБ)..(a.re + ѕБ),
      unitPrincipalKernel a вЯ®X, a.im - ѕБвЯ©) =
      вИЂ x in (-ѕБ)..ѕБ, (1 : вДВ) / ((x : вДВ) - (ѕБ : вДВ) * Complex.I) := by
  rw [show (a.re - ѕБ : вДЭ) = a.re + (-ѕБ) from by ring,
      show (a.re + ѕБ : вДЭ) = a.re + ѕБ from rfl,
      вЖР intervalIntegral.integral_comp_add_left]
  apply intervalIntegral.integral_congr
  intro x _
  show unitPrincipalKernel a вЯ®a.re + x, a.im - ѕБвЯ© =
       (1 : вДВ) / ((x : вДВ) - (ѕБ : вДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (вЯ®a.re + x, a.im - ѕБвЯ© : вДВ) - a =
                 (x : вДВ) - (ѕБ : вДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_top_eq_centered
    (a : вДВ) (ѕБ : вДЭ) :
    (вИЂ X in (a.re + ѕБ)..(a.re - ѕБ),
      unitPrincipalKernel a вЯ®X, a.im + ѕБвЯ©) =
      вИЂ x in ѕБ..(-ѕБ), (1 : вДВ) / ((x : вДВ) + (ѕБ : вДВ) * Complex.I) := by
  rw [show (a.re - ѕБ : вДЭ) = a.re + (-ѕБ) from by ring,
      show (a.re + ѕБ : вДЭ) = a.re + ѕБ from rfl,
      вЖР intervalIntegral.integral_comp_add_left]
  apply intervalIntegral.integral_congr
  intro x _
  show unitPrincipalKernel a вЯ®a.re + x, a.im + ѕБвЯ© =
       (1 : вДВ) / ((x : вДВ) + (ѕБ : вДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (вЯ®a.re + x, a.im + ѕБвЯ© : вДВ) - a =
                 (x : вДВ) + (ѕБ : вДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_right_eq_centered
    (a : вДВ) (ѕБ : вДЭ) :
    (вИЂ Y in (a.im - ѕБ)..(a.im + ѕБ),
      unitPrincipalKernel a вЯ®a.re + ѕБ, YвЯ© * Complex.I) =
      (вИЂ y in (-ѕБ)..ѕБ, (1 : вДВ) / ((ѕБ : вДВ) + (y : вДВ) * Complex.I)) *
        Complex.I := by
  rw [show (a.im - ѕБ : вДЭ) = a.im + (-ѕБ) from by ring,
      show (a.im + ѕБ : вДЭ) = a.im + ѕБ from rfl,
      вЖР intervalIntegral.integral_comp_add_left]
  rw [intervalIntegral.integral_mul_const]
  apply congrArg (¬Ј * Complex.I)
  apply intervalIntegral.integral_congr
  intro y _
  show unitPrincipalKernel a вЯ®a.re + ѕБ, a.im + yвЯ© =
       (1 : вДВ) / ((ѕБ : вДВ) + (y : вДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (вЯ®a.re + ѕБ, a.im + yвЯ© : вДВ) - a =
                 (ѕБ : вДВ) + (y : вДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_left_eq_centered
    (a : вДВ) (ѕБ : вДЭ) :
    (вИЂ Y in (a.im + ѕБ)..(a.im - ѕБ),
      unitPrincipalKernel a вЯ®a.re - ѕБ, YвЯ© * Complex.I) =
      (вИЂ y in ѕБ..(-ѕБ), (1 : вДВ) / (-(ѕБ : вДВ) + (y : вДВ) * Complex.I)) *
        Complex.I := by
  rw [show (a.im - ѕБ : вДЭ) = a.im + (-ѕБ) from by ring,
      show (a.im + ѕБ : вДЭ) = a.im + ѕБ from rfl,
      вЖР intervalIntegral.integral_comp_add_left]
  rw [intervalIntegral.integral_mul_const]
  apply congrArg (¬Ј * Complex.I)
  apply intervalIntegral.integral_congr
  intro y _
  show unitPrincipalKernel a вЯ®a.re - ѕБ, a.im + yвЯ© =
       (1 : вДВ) / (-(ѕБ : вДВ) + (y : вДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (вЯ®a.re - ѕБ, a.im + yвЯ© : вДВ) - a =
                 -(ѕБ : вДВ) + (y : вДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

/-- Translation invariance: the unit-kernel integral around the canonical
square centered at `a` equals the centered-square integral of the same
half-side. -/
theorem canonicalSquareEqualsCenteredSquare
    {R : ZetaRectangle} {a : вДВ}
    (C : R.SmallCircleInsideRectangle a) :
    CanonicalSquareEqualsCenteredSquare R a C := by
  refine вЯ®?_вЯ©
  set ѕБ := C.toSmallSquare.r
  unfold smallSquareUnitKernelIntegral
  rw [вЖР rectangleIntegral_unitPrincipalKernel_eq]
  rw [rectangleIntegral_eq_coordinateBoundaryIntegral
        (rectangleEdgeIntegralCoordinateBridge _ _)]
  unfold coordinateBoundaryIntegral
  unfold bottomHorizontalIntegral rightVerticalIntegral
    topHorizontalIntegral leftVerticalIntegral
  unfold SmallSquareInsideRectangle.toRectangle
  unfold centeredSquareUnitKernelIntegral
  rw [canonicalSquare_bottom_eq_centered a ѕБ]
  rw [canonicalSquare_right_eq_centered a ѕБ]
  rw [canonicalSquare_top_eq_centered a ѕБ]
  rw [canonicalSquare_left_eq_centered a ѕБ]

/-! ## BO1: arctan FTC for the centered-square edge integrals -/

/-- `вИЂ x in -ѕБ..ѕБ, ѕБ/(x¬≤ + ѕБ¬≤) = ѕА/2`.  This is the core scalar
real integral underlying the centered-square edge evaluations.  The
primitive is `arctan(x/ѕБ)`; endpoints give `arctan(1) - arctan(-1) = ѕА/2`. -/
theorem integral_rho_div_sq_add_sq
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ x in (-ѕБ)..ѕБ, ѕБ / (x ^ 2 + ѕБ ^ 2)) = Real.pi / 2 := by
  have hѕБ_ne : ѕБ вЙ† 0 := ne_of_gt hѕБ
  -- Continuity / integrability.
  have h_cont : Continuous (fun x : вДЭ => ѕБ / (x ^ 2 + ѕБ ^ 2)) := by
    refine Continuous.div continuous_const ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x
      have h1 : (0 : вДЭ) вЙ§ x ^ 2 := sq_nonneg x
      have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
      linarith
  have h_int : IntervalIntegrable
      (fun x : вДЭ => ѕБ / (x ^ 2 + ѕБ ^ 2)) MeasureTheory.volume (-ѕБ) ѕБ :=
    h_cont.intervalIntegrable _ _
  -- Chain rule: deriv of `fun y => arctan (y/ѕБ)` is `ѕБ/(x¬≤+ѕБ¬≤)`.
  have h_deriv : вИА x вИИ Set.uIcc (-ѕБ) ѕБ,
      HasDerivAt (fun y : вДЭ => Real.arctan (y / ѕБ))
        (ѕБ / (x ^ 2 + ѕБ ^ 2)) x := by
    intro x _
    have h_arctan : HasDerivAt Real.arctan (1 / (1 + (x / ѕБ) ^ 2)) (x / ѕБ) :=
      Real.hasDerivAt_arctan _
    have h_div : HasDerivAt (fun y : вДЭ => y / ѕБ) (1 / ѕБ) x := by
      simpa using (hasDerivAt_id x).div_const ѕБ
    have h_comp := h_arctan.comp x h_div
    convert h_comp using 1
    field_simp
    ring
  -- FTC + endpoint arctan values.
  have hFTC := intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int
  rw [hFTC]
  have hѕБѕБ : ѕБ / ѕБ = 1 := div_self hѕБ_ne
  have hnѕБѕБ : (-ѕБ) / ѕБ = -1 := by rw [neg_div, hѕБѕБ]
  rw [hѕБѕБ, hnѕБѕБ, Real.arctan_one, Real.arctan_neg, Real.arctan_one]
  ring

/-! ## BO1.5: Odd integrand `x/(x¬≤+ѕБ¬≤)` vanishes on `[-ѕБ, ѕБ]` -/

/-- `вИЂ x in -ѕБ..ѕБ, x/(x¬≤ + ѕБ¬≤) = 0`.  The antiderivative `(1/2) log(x¬≤ + ѕБ¬≤)`
is even in `x`, so its values at `ѕБ` and `-ѕБ` agree. -/
theorem integral_x_div_sq_add_sq_symm
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ x in (-ѕБ)..ѕБ, x / (x ^ 2 + ѕБ ^ 2)) = 0 := by
  have h_pos : вИА x : вДЭ, (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := fun x => by
    have h1 : (0 : вДЭ) вЙ§ x ^ 2 := sq_nonneg x
    have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
    linarith
  have h_cont : Continuous (fun x : вДЭ => x / (x ^ 2 + ѕБ ^ 2)) := by
    refine Continuous.div continuous_id ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x; exact ne_of_gt (h_pos x)
  have h_int : IntervalIntegrable
      (fun x : вДЭ => x / (x ^ 2 + ѕБ ^ 2)) MeasureTheory.volume (-ѕБ) ѕБ :=
    h_cont.intervalIntegrable _ _
  have h_deriv : вИА x вИИ Set.uIcc (-ѕБ) ѕБ,
      HasDerivAt (fun y : вДЭ => (1/2 : вДЭ) * Real.log (y ^ 2 + ѕБ ^ 2))
        (x / (x ^ 2 + ѕБ ^ 2)) x := by
    intro x _
    have hpx : (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := h_pos x
    have h_ne : (x ^ 2 + ѕБ ^ 2) вЙ† 0 := ne_of_gt hpx
    have h_sq : HasDerivAt (fun y : вДЭ => y ^ 2 + ѕБ ^ 2) (2 * x) x := by
      simpa using (hasDerivAt_pow 2 x).add_const (ѕБ ^ 2)
    have h_log : HasDerivAt (fun y : вДЭ => Real.log (y ^ 2 + ѕБ ^ 2))
        ((2 * x) / (x ^ 2 + ѕБ ^ 2)) x := h_sq.log h_ne
    have h_half := h_log.const_mul (1/2 : вДЭ)
    convert h_half using 1
    field_simp
  have hFTC := intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int
  rw [hFTC]
  have h_eq : ((-ѕБ : вДЭ)) ^ 2 + ѕБ ^ 2 = ѕБ ^ 2 + ѕБ ^ 2 := by ring
  rw [h_eq]
  ring

/-! ## BO2: Centered-square edge integrals -/

/-- Bottom edge: `вИЂ x in -ѕБ..ѕБ, 1/(x - iѕБ) = (ѕА/2) * I`. -/
theorem centeredSquare_bottom_eq_pi_over_two_I
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ x in (-ѕБ)..ѕБ, (1 : вДВ) / ((x : вДВ) - (ѕБ : вДВ) * Complex.I))
      = (Real.pi / 2 : вДВ) * Complex.I := by
  have h_pos : вИА x : вДЭ, (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := fun x => by
    have h1 : (0 : вДЭ) вЙ§ x ^ 2 := sq_nonneg x
    have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
    linarith
  have h_ptwise : вИА x : вДЭ,
      (1 : вДВ) / ((x : вДВ) - (ѕБ : вДВ) * Complex.I) =
        ((x / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ)
          + ((ѕБ / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ) * Complex.I := by
    intro x
    have hpx_pos : (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := h_pos x
    have hpx_ne : (x ^ 2 + ѕБ ^ 2 : вДЭ) вЙ† 0 := ne_of_gt hpx_pos
    have h_denom : ((x : вДВ) - (ѕБ : вДВ) * Complex.I) вЙ† 0 := by
      intro h
      have h_im_z : ((x : вДВ) - (ѕБ : вДВ) * Complex.I).im = 0 := by rw [h]; rfl
      simp at h_im_z
      linarith
    have h_sum_C_ne : ((x : вДВ) ^ 2 + (ѕБ : вДВ) ^ 2) вЙ† 0 := by
      have h : ((x : вДВ) ^ 2 + (ѕБ : вДВ) ^ 2) = ((x ^ 2 + ѕБ ^ 2 : вДЭ) : вДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpx_ne
    have hI : (Complex.I : вДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((ѕБ : вДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun x _ => h_ptwise x)]
  have h_cont1 : Continuous (fun x : вДЭ => ((x / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x; exact ne_of_gt (h_pos x)
  have h_cont2 : Continuous
      (fun x : вДЭ => ((ѕБ / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x; exact ne_of_gt (h_pos x)
  have h_int1 := h_cont1.intervalIntegrable (ќЉ := MeasureTheory.volume) (-ѕБ) ѕБ
  have h_int2 := h_cont2.intervalIntegrable (ќЉ := MeasureTheory.volume) (-ѕБ) ѕБ
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  rw [integral_x_div_sq_add_sq_symm hѕБ, integral_rho_div_sq_add_sq hѕБ]
  push_cast
  ring

/-- Right edge: `(вИЂ y in -ѕБ..ѕБ, 1/(ѕБ + iy)) ¬Ј I = (ѕА/2) ¬Ј I`. -/
theorem centeredSquare_right_eq_pi_over_two_I
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ y in (-ѕБ)..ѕБ, (1 : вДВ) / ((ѕБ : вДВ) + (y : вДВ) * Complex.I)) * Complex.I
      = (Real.pi / 2 : вДВ) * Complex.I := by
  have h_pos : вИА y : вДЭ, (0 : вДЭ) < ѕБ ^ 2 + y ^ 2 := fun y => by
    have h1 : (0 : вДЭ) вЙ§ y ^ 2 := sq_nonneg y
    have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
    linarith
  have h_ptwise : вИА y : вДЭ,
      (1 : вДВ) / ((ѕБ : вДВ) + (y : вДВ) * Complex.I) =
        ((ѕБ / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ)
          + ((-y / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ) * Complex.I := by
    intro y
    have hpy_pos : (0 : вДЭ) < ѕБ ^ 2 + y ^ 2 := h_pos y
    have hpy_ne : (ѕБ ^ 2 + y ^ 2 : вДЭ) вЙ† 0 := ne_of_gt hpy_pos
    have h_denom : ((ѕБ : вДВ) + (y : вДВ) * Complex.I) вЙ† 0 := by
      intro h
      have h_re_z : ((ѕБ : вДВ) + (y : вДВ) * Complex.I).re = 0 := by rw [h]; rfl
      simp at h_re_z
      linarith
    have h_sum_C_ne : ((ѕБ : вДВ) ^ 2 + (y : вДВ) ^ 2) вЙ† 0 := by
      have h : ((ѕБ : вДВ) ^ 2 + (y : вДВ) ^ 2) = ((ѕБ ^ 2 + y ^ 2 : вДЭ) : вДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpy_ne
    have hI : (Complex.I : вДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((y : вДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun y _ => h_ptwise y)]
  have h_cont1 : Continuous (fun y : вДЭ => ((ѕБ / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ¬Ј exact continuous_const.add (continuous_pow 2)
    ¬Ј intro y; exact ne_of_gt (h_pos y)
  have h_cont2 : Continuous
      (fun y : вДЭ => ((-y / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id.neg ?_ ?_
    ¬Ј exact continuous_const.add (continuous_pow 2)
    ¬Ј intro y; exact ne_of_gt (h_pos y)
  have h_int1 := h_cont1.intervalIntegrable (ќЉ := MeasureTheory.volume) (-ѕБ) ѕБ
  have h_int2 := h_cont2.intervalIntegrable (ќЉ := MeasureTheory.volume) (-ѕБ) ѕБ
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (вИЂ y in (-ѕБ)..ѕБ, ѕБ / (ѕБ ^ 2 + y ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun y : вДЭ => ѕБ / (ѕБ ^ 2 + y ^ 2))
              = (fun y : вДЭ => ѕБ / (y ^ 2 + ѕБ ^ 2)) := by
      funext y; ring
    rw [h_eq]
    exact integral_rho_div_sq_add_sq hѕБ
  have h_im : (вИЂ y in (-ѕБ)..ѕБ, -y / (ѕБ ^ 2 + y ^ 2)) = 0 := by
    have h_eq : (fun y : вДЭ => -y / (ѕБ ^ 2 + y ^ 2))
              = (fun y : вДЭ => -(y / (y ^ 2 + ѕБ ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg]
    rw [integral_x_div_sq_add_sq_symm hѕБ]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-- Top edge: `вИЂ x in ѕБ..(-ѕБ), 1/(x + iѕБ) = (ѕА/2) ¬Ј I`. -/
theorem centeredSquare_top_eq_pi_over_two_I
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ x in ѕБ..(-ѕБ), (1 : вДВ) / ((x : вДВ) + (ѕБ : вДВ) * Complex.I))
      = (Real.pi / 2 : вДВ) * Complex.I := by
  have h_pos : вИА x : вДЭ, (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := fun x => by
    have h1 : (0 : вДЭ) вЙ§ x ^ 2 := sq_nonneg x
    have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
    linarith
  have h_ptwise : вИА x : вДЭ,
      (1 : вДВ) / ((x : вДВ) + (ѕБ : вДВ) * Complex.I) =
        ((x / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ)
          + ((-ѕБ / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ) * Complex.I := by
    intro x
    have hpx_pos : (0 : вДЭ) < x ^ 2 + ѕБ ^ 2 := h_pos x
    have hpx_ne : (x ^ 2 + ѕБ ^ 2 : вДЭ) вЙ† 0 := ne_of_gt hpx_pos
    have h_denom : ((x : вДВ) + (ѕБ : вДВ) * Complex.I) вЙ† 0 := by
      intro h
      have h_im_z : ((x : вДВ) + (ѕБ : вДВ) * Complex.I).im = 0 := by rw [h]; rfl
      simp at h_im_z
      linarith
    have h_sum_C_ne : ((x : вДВ) ^ 2 + (ѕБ : вДВ) ^ 2) вЙ† 0 := by
      have h : ((x : вДВ) ^ 2 + (ѕБ : вДВ) ^ 2) = ((x ^ 2 + ѕБ ^ 2 : вДЭ) : вДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpx_ne
    have hI : (Complex.I : вДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((ѕБ : вДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun x _ => h_ptwise x)]
  have h_cont1 : Continuous (fun x : вДЭ => ((x / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x; exact ne_of_gt (h_pos x)
  have h_cont2 : Continuous
      (fun x : вДЭ => ((-ѕБ / (x ^ 2 + ѕБ ^ 2) : вДЭ) : вДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ¬Ј exact (continuous_pow 2).add continuous_const
    ¬Ј intro x; exact ne_of_gt (h_pos x)
  have h_int1 := h_cont1.intervalIntegrable (ќЉ := MeasureTheory.volume) ѕБ (-ѕБ)
  have h_int2 := h_cont2.intervalIntegrable (ќЉ := MeasureTheory.volume) ѕБ (-ѕБ)
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (вИЂ x in ѕБ..(-ѕБ), x / (x ^ 2 + ѕБ ^ 2)) = 0 := by
    rw [intervalIntegral.integral_symm, integral_x_div_sq_add_sq_symm hѕБ]
    ring
  have h_im : (вИЂ x in ѕБ..(-ѕБ), -ѕБ / (x ^ 2 + ѕБ ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun x : вДЭ => -ѕБ / (x ^ 2 + ѕБ ^ 2))
              = (fun x : вДЭ => -(ѕБ / (x ^ 2 + ѕБ ^ 2))) := by
      funext x; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_rho_div_sq_add_sq hѕБ]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-- Left edge: `(вИЂ y in ѕБ..(-ѕБ), 1/(-ѕБ + iy)) ¬Ј I = (ѕА/2) ¬Ј I`. -/
theorem centeredSquare_left_eq_pi_over_two_I
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    (вИЂ y in ѕБ..(-ѕБ), (1 : вДВ) / (-(ѕБ : вДВ) + (y : вДВ) * Complex.I)) * Complex.I
      = (Real.pi / 2 : вДВ) * Complex.I := by
  have h_pos : вИА y : вДЭ, (0 : вДЭ) < ѕБ ^ 2 + y ^ 2 := fun y => by
    have h1 : (0 : вДЭ) вЙ§ y ^ 2 := sq_nonneg y
    have h2 : (0 : вДЭ) < ѕБ ^ 2 := by positivity
    linarith
  have h_ptwise : вИА y : вДЭ,
      (1 : вДВ) / (-(ѕБ : вДВ) + (y : вДВ) * Complex.I) =
        ((-ѕБ / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ)
          + ((-y / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ) * Complex.I := by
    intro y
    have hpy_pos : (0 : вДЭ) < ѕБ ^ 2 + y ^ 2 := h_pos y
    have hpy_ne : (ѕБ ^ 2 + y ^ 2 : вДЭ) вЙ† 0 := ne_of_gt hpy_pos
    have h_denom : (-(ѕБ : вДВ) + (y : вДВ) * Complex.I) вЙ† 0 := by
      intro h
      have h_re_z : (-(ѕБ : вДВ) + (y : вДВ) * Complex.I).re = 0 := by rw [h]; rfl
      simp at h_re_z
      linarith
    have h_sum_C_ne : ((ѕБ : вДВ) ^ 2 + (y : вДВ) ^ 2) вЙ† 0 := by
      have h : ((ѕБ : вДВ) ^ 2 + (y : вДВ) ^ 2) = ((ѕБ ^ 2 + y ^ 2 : вДЭ) : вДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpy_ne
    have hI : (Complex.I : вДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((y : вДВ) ^ 2 * ((ѕБ : вДВ) ^ 2 + (y : вДВ) ^ 2)) * hI
  rw [intervalIntegral.integral_congr (fun y _ => h_ptwise y)]
  have h_cont1 : Continuous (fun y : вДЭ => ((-ѕБ / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ¬Ј exact continuous_const.add (continuous_pow 2)
    ¬Ј intro y; exact ne_of_gt (h_pos y)
  have h_cont2 : Continuous
      (fun y : вДЭ => ((-y / (ѕБ ^ 2 + y ^ 2) : вДЭ) : вДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id.neg ?_ ?_
    ¬Ј exact continuous_const.add (continuous_pow 2)
    ¬Ј intro y; exact ne_of_gt (h_pos y)
  have h_int1 := h_cont1.intervalIntegrable (ќЉ := MeasureTheory.volume) ѕБ (-ѕБ)
  have h_int2 := h_cont2.intervalIntegrable (ќЉ := MeasureTheory.volume) ѕБ (-ѕБ)
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (вИЂ y in ѕБ..(-ѕБ), -ѕБ / (ѕБ ^ 2 + y ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun y : вДЭ => -ѕБ / (ѕБ ^ 2 + y ^ 2))
              = (fun y : вДЭ => -(ѕБ / (y ^ 2 + ѕБ ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_rho_div_sq_add_sq hѕБ]
    ring
  have h_im : (вИЂ y in ѕБ..(-ѕБ), -y / (ѕБ ^ 2 + y ^ 2)) = 0 := by
    have h_eq : (fun y : вДЭ => -y / (ѕБ ^ 2 + y ^ 2))
              = (fun y : вДЭ => -(y / (y ^ 2 + ѕБ ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_x_div_sq_add_sq_symm hѕБ]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-! ## BO4: Assemble the centered-square integral -/

/-- The unit-kernel integral around the centered square of half-side `ѕБ > 0`
equals `2ѕАi`.  Each of the four edge integrals contributes `(ѕА/2)¬ЈI`. -/
theorem centeredSquareUnitKernelIntegral_eq_twoPiI
    {ѕБ : вДЭ} (hѕБ : 0 < ѕБ) :
    centeredSquareUnitKernelIntegral ѕБ = twoPiI := by
  unfold centeredSquareUnitKernelIntegral twoPiI
  rw [centeredSquare_bottom_eq_pi_over_two_I hѕБ,
      centeredSquare_right_eq_pi_over_two_I hѕБ,
      centeredSquare_top_eq_pi_over_two_I hѕБ,
      centeredSquare_left_eq_pi_over_two_I hѕБ]
  ring

/-- **BO5 вАФ INHABITED:** the `CenteredSquareEqualsTwoPiI` Prop. -/
noncomputable def centeredSquareEqualsTwoPiI : CenteredSquareEqualsTwoPiI where
  eq_twoPiI := centeredSquareUnitKernelIntegral_eq_twoPiI

/-! ## AT: Residue-free argument-principle assembly -/

/-! ### AT1: unit-kernel theorem wrapper -/

/-- Convenience wrapper: punctured Cauchy-Goursat for a chosen small circle
gives the unit principal-kernel theorem. -/
noncomputable def unitPrincipalKernelIntegralTheorem_of_puncturedCG
    {R : ZetaRectangle} {a : вДВ}
    (C : R.SmallCircleInsideRectangle a)
    (HCG : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitPrincipalKernelIntegralTheorem a :=
  UnitPrincipalKernelIntegralTheorem.of_puncturedCauchyGoursat HCG

/-! ### AT2: general-coefficient kernel theorem via punctured CG -/

/-- Punctured Cauchy-Goursat for the unit kernel propagates through AQ4
linearity to give the normalized principal-kernel theorem at any integer
coefficient. -/
noncomputable def principalKernelIntegralTheorem_of_puncturedCG
    {R : ZetaRectangle} {a : вДВ} (k : вД§)
    (C : R.SmallCircleInsideRectangle a)
    (HCG : R.PuncturedRectangleCauchyGoursat a C) :
    R.PrincipalKernelIntegralTheorem k a :=
  (R.unitPrincipalKernelIntegralTheorem_of_puncturedCG C HCG).toNormalizedAtCoeff k

/-! ### AT3: per-singularity Cauchy-index data -/

/-- For each counted singularity of a rectangle principal-part package, a
small circle witness and a punctured Cauchy-Goursat theorem. -/
structure RectangleKernelIndexData
    (R : ZetaRectangle)
    (P : R.RectanglePrincipalPartData) where
  smallCircle :
    вИА s : вДВ, s вИИ P.singularities вЖТ R.SmallCircleInsideRectangle s
  puncturedCG :
    вИА s : вДВ, (hs : s вИИ P.singularities) вЖТ
      R.PuncturedRectangleCauchyGoursat s (smallCircle s hs)

/-! ### AT4: kernel contributions from Cauchy-index data -/

/-- Bundled per-singularity Cauchy-index data gives the normalized
principal-kernel contribution `= coefficient` for every singularity. -/
theorem RectangleKernelIndexData.kernelContribution
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (K : R.RectangleKernelIndexData P) :
    вИА s : вДВ, s вИИ P.singularities вЖТ
      R.normalizedPrincipalKernelRectangleIntegral
        (P.principalCoeff s) s =
      (P.principalCoeff s : вДВ) := fun s hs =>
  (R.principalKernelIntegralTheorem_of_puncturedCG
      (P.principalCoeff s) (K.smallCircle s hs) (K.puncturedCG s hs)
    ).normalized_integral_eq_coeff

/-! ### AT5: decomposition + kernel index вЗТ integral theorem -/

/-- A contour decomposition plus per-singularity Cauchy-index data assembles
into the residue-free rectangle argument-principle integral theorem. -/
noncomputable def RectanglePrincipalPartContourDecomposition.toIntegralTheorem_of_kernelData
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (D : R.RectanglePrincipalPartContourDecomposition P)
    (K : R.RectangleKernelIndexData P) :
    R.RectanglePrincipalPartIntegralTheorem :=
  D.toIntegralTheorem K.kernelContribution

/-! ### AT6: canonical residue-free argument-principle data -/

/-- Two-piece package for canonical zeta data: per-singularity Cauchy-index
data plus the contour decomposition.  These are the two remaining global
contour facts needed for the full residue-free argument principle. -/
structure CanonicalResidueFreeArgumentPrincipleData
    (R : ZetaRectangle)
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) where
  kernelIndex :
    R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z)
  decomposition :
    R.RectanglePrincipalPartContourDecomposition
      (R.countedPrincipalPartData hAdm Z)

/-! ### AT7: canonical data вЗТ canonical integral theorem -/

/-- Canonical residue-free argument-principle data inhabits the canonical
rectangle principal-part integral theorem. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toPrincipalPartIntegralTheorem
    {R : ZetaRectangle}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z) :
    R.RectanglePrincipalPartIntegralTheorem :=
  D.decomposition.toIntegralTheorem_of_kernelData D.kernelIndex

/-! ### BT4: canonical residue-free package from kernel index + remainder analyticity -/

/-- **BT4:** for canonical principal-part data, kernel index data plus
analytic-remainder data (BT2) inhabits the canonical residue-free
argument-principle package. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_remainderAnalytic
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta} {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (A : R.RectangleLogDerivRemainderAnalyticData
            (R.countedPrincipalPartData hAdm Z)) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z where
  kernelIndex := K
  decomposition := A.toPrincipalPartContourDecomposition

/-! ## BU: Analyticity of the log-derivative remainder -/

/-! ### BU1: expected-coefficient analytic principal-part wrapper -/

/-- At `s`, `ќґ'/ќґ` has the expected integer principal part with analytic
remainder (the analytic-strength counterpart of the continuous-remainder
field stored in `RectanglePrincipalPartData`). -/
def ZetaHasExpectedAnalyticPrincipalPart (s : вДВ) : Prop :=
  HasLogDerivIntegerPrincipalPart riemannZeta s (zetaLogDerivPrincipalCoeff s)

/-! ### BU4: analyticity of each piece away from counted singularities -/

/-- The principal kernel `k/(z вИТ s)` is analytic at every point `z вЙ† s`. -/
theorem analyticAt_principalKernel_of_ne
    {k : вД§} {s z : вДВ} (hz : z вЙ† s) :
    AnalyticAt вДВ (fun w : вДВ => principalKernel k s w) z := by
  unfold principalKernel
  refine analyticAt_const.div (analyticAt_id.sub analyticAt_const) ?_
  simpa [sub_eq_zero] using hz

/-- `ќґ'/ќґ` is analytic at every point off the pole `1` and off zeros. -/
theorem analyticAt_zetaLogDeriv_of_not_zero_not_one
    {z : вДВ} (hz1 : z вЙ† 1) (hz0 : riemannZeta z вЙ† 0) :
    AnalyticAt вДВ zetaLogDeriv z := by
  unfold zetaLogDeriv
  have hќґ : AnalyticAt вДВ riemannZeta z := riemannZeta_analyticAt_of_ne_one hz1
  exact hќґ.deriv.div hќґ hz0

/-- The principal-part sum is analytic at every point not in the
singularity set. -/
theorem analyticAt_principalPartSum_of_not_mem
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {z : вДВ}
    (hz : z вИЙ P.singularities) :
    AnalyticAt вДВ (R.principalPartSum P) z := by
  unfold principalPartSum
  refine Finset.analyticAt_fun_sum (c := z) P.singularities ?_
  intro s hs
  refine analyticAt_principalKernel_of_ne ?_
  intro hzs
  subst hzs
  exact hz hs

/-- The log-derivative remainder is analytic at every point that is not
a counted singularity, provided `ќґ вЙ† 0` and `z вЙ† 1` there. -/
theorem analyticAt_logDerivRemainder_of_not_singular
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {z : вДВ}
    (hz_not : z вИЙ P.singularities)
    (hz1 : z вЙ† 1) (hz0 : riemannZeta z вЙ† 0) :
    AnalyticAt вДВ (R.logDerivRemainder P) z := by
  unfold logDerivRemainder
  exact (analyticAt_zetaLogDeriv_of_not_zero_not_one hz1 hz0).sub
    (analyticAt_principalPartSum_of_not_mem hz_not)

/-! ### BU6: analytic-remainder input package + assembler

NOTE: Lean's `1/0 = 0` convention makes `R.logDerivRemainder P` not literally
analytic at a singularity `s` (because `zetaLogDeriv s вИТ principalKernel k s s`
equals `0 вИТ 0 = 0`, whereas the analytic extension's value `g s` is generally
nonzero).  We therefore take per-singularity analyticity as an input field,
along with the off-singularity ќґ-nonvanishing / non-pole conditions. -/

/-- Input data for analytic-remainder on the closed rectangle: ќґ does not
vanish and the pole is avoided at every non-counted closed-rectangle point,
and the remainder is analytic at every counted singularity. -/
structure RectangleLogDerivRemainderAnalyticInput
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  off_singularity_zeta_nonzero :
    вИА z, R.ContainsClosed z вЖТ z вИЙ P.singularities вЖТ riemannZeta z вЙ† 0
  off_singularity_not_pole :
    вИА z, R.ContainsClosed z вЖТ z вИЙ P.singularities вЖТ z вЙ† 1
  analytic_at_singularity :
    вИА s, s вИИ P.singularities вЖТ
      AnalyticAt вДВ (R.logDerivRemainder P) s

/-- **BU6 вАФ ASSEMBLER:** the analytic-input package discharges the BT2
analytic-remainder target by case-splitting at each closed-rectangle
point on whether it lies in the singularity set. -/
noncomputable def RectangleLogDerivRemainderAnalyticInput.toAnalyticData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderAnalyticInput P) :
    R.RectangleLogDerivRemainderAnalyticData P where
  analytic_remainder := by
    intro z hzClosed
    by_cases hzSing : z вИИ P.singularities
    ¬Ј exact I.analytic_at_singularity z hzSing
    ¬Ј exact analyticAt_logDerivRemainder_of_not_singular hzSing
        (I.off_singularity_not_pole z hzClosed hzSing)
        (I.off_singularity_zeta_nonzero z hzClosed hzSing)

/-! ## BV: Patched analytic-remainder extension (replacing raw remainder) -/

/-! ### BV1: extension data package -/

/-- Analytic extension data for the log-derivative remainder.

The raw expression `ќґ'/ќґ вИТ ќ£ principalKernel` has the right values away
from singularities, but at a singularity Lean's totalized division gives
`0` rather than the analytic-extension value.  This package supplies a
patched function `remainderExt` that agrees with the raw remainder off
singularities and is analytic on the closed rectangle. -/
structure RectangleLogDerivRemainderExtensionData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) where
  remainderExt : вДВ вЖТ вДВ
  agrees_off_singularities :
    вИА z : вДВ, z вИЙ P.singularities вЖТ
      remainderExt z = R.logDerivRemainder P z
  analytic_remainderExt :
    вИА z, R.ContainsClosed z вЖТ AnalyticAt вДВ remainderExt z

/-! ### BV2: extension and raw remainder have equal rectangle integrals -/

/-- Because the boundary avoids all counted singularities (strong
admissibility), the patched extension agrees with the raw remainder on
the boundary; hence their rectangle integrals are equal. -/
theorem rectangleIntegral_remainderExt_eq_raw
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.rectangleIntegral E.remainderExt =
      R.rectangleIntegral (R.logDerivRemainder P) := by
  unfold rectangleIntegral
  have h_eq_bottom :
      (вИЂ t in (0 : вДЭ)..1,
        E.remainderExt (R.bottomEdge t) * deriv R.bottomEdge t) =
      (вИЂ t in (0 : вДЭ)..1,
        R.logDerivRemainder P (R.bottomEdge t) * deriv R.bottomEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : вДЭ) вЙ§ 1)] at ht
    have hbd : R.ContainsBoundary (R.bottomEdge t) :=
      R.bottomEdge_mem_boundary ht.1 ht.2
    have hnot : R.bottomEdge t вИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.bottomEdge t) * deriv R.bottomEdge t =
      R.logDerivRemainder P (R.bottomEdge t) * deriv R.bottomEdge t
    rw [E.agrees_off_singularities (R.bottomEdge t) hnot]
  have h_eq_right :
      (вИЂ t in (0 : вДЭ)..1,
        E.remainderExt (R.rightEdge t) * deriv R.rightEdge t) =
      (вИЂ t in (0 : вДЭ)..1,
        R.logDerivRemainder P (R.rightEdge t) * deriv R.rightEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : вДЭ) вЙ§ 1)] at ht
    have hbd : R.ContainsBoundary (R.rightEdge t) :=
      R.rightEdge_mem_boundary ht.1 ht.2
    have hnot : R.rightEdge t вИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.rightEdge t) * deriv R.rightEdge t =
      R.logDerivRemainder P (R.rightEdge t) * deriv R.rightEdge t
    rw [E.agrees_off_singularities (R.rightEdge t) hnot]
  have h_eq_top :
      (вИЂ t in (0 : вДЭ)..1,
        E.remainderExt (R.topEdge t) * deriv R.topEdge t) =
      (вИЂ t in (0 : вДЭ)..1,
        R.logDerivRemainder P (R.topEdge t) * deriv R.topEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : вДЭ) вЙ§ 1)] at ht
    have hbd : R.ContainsBoundary (R.topEdge t) :=
      R.topEdge_mem_boundary ht.1 ht.2
    have hnot : R.topEdge t вИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.topEdge t) * deriv R.topEdge t =
      R.logDerivRemainder P (R.topEdge t) * deriv R.topEdge t
    rw [E.agrees_off_singularities (R.topEdge t) hnot]
  have h_eq_left :
      (вИЂ t in (0 : вДЭ)..1,
        E.remainderExt (R.leftEdge t) * deriv R.leftEdge t) =
      (вИЂ t in (0 : вДЭ)..1,
        R.logDerivRemainder P (R.leftEdge t) * deriv R.leftEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : вДЭ) вЙ§ 1)] at ht
    have hbd : R.ContainsBoundary (R.leftEdge t) :=
      R.leftEdge_mem_boundary ht.1 ht.2
    have hnot : R.leftEdge t вИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.leftEdge t) * deriv R.leftEdge t =
      R.logDerivRemainder P (R.leftEdge t) * deriv R.leftEdge t
    rw [E.agrees_off_singularities (R.leftEdge t) hnot]
  rw [h_eq_bottom, h_eq_right, h_eq_top, h_eq_left]

/-! ### BV3: extension data вЗТ raw remainder integral vanishes -/

/-- Cauchy-Goursat applied to the patched extension, transferred to the raw
remainder integral via boundary congruence (BV2). -/
noncomputable def RectangleLogDerivRemainderExtensionData.toVanishes
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.RectangleLogDerivRemainderIntegralVanishes P where
  integral_eq_zero := by
    have hExtZero : R.rectangleIntegral E.remainderExt = 0 :=
      globalRectangleCauchyGoursatBridge.cauchyGoursat R
        E.remainderExt E.analytic_remainderExt
    have hraw := rectangleIntegral_remainderExt_eq_raw E
    rw [вЖР hraw]
    exact hExtZero

/-! ### BV4: extension data closes the contour decomposition + canonical wrapper -/

/-- Linearity (BS6) + remainder extension data (BV1+BV3) вЗТ contour
decomposition.  This is the BV-analog of BT3, but using the patched
extension (which can actually be inhabited) in place of the raw
analytic-remainder target (which cannot, due to Lean's `1/0 = 0`). -/
noncomputable def RectangleLogDerivRemainderExtensionData.toPrincipalPartContourDecomposition
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.RectanglePrincipalPartContourDecomposition P :=
  RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    (rectangleLogDerivContourLinearDecomposition P) E.toVanishes

/-- **BV4 вАФ CANONICAL WRAPPER:** kernel-index data + remainder extension
data discharges the canonical residue-free argument-principle package. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_remainderExtension
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta} {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (E : R.RectangleLogDerivRemainderExtensionData
            (R.countedPrincipalPartData hAdm Z)) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z where
  kernelIndex := K
  decomposition := E.toPrincipalPartContourDecomposition

/-! ## BW: Patched analytic remainder from analytic local principal parts -/

/-! ### BW1: analytic local principal-part data -/

/-- Analytic local principal-part data: at every counted singularity, the
zeta log-derivative has the expected integer principal part with **analytic**
remainder (not just continuous).  This is the strengthening of
`P.localPrincipalPart` that the patched-extension construction requires. -/
structure RectangleAnalyticPrincipalPartData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  localAnalyticPrincipalPart :
    вИА s : вДВ, s вИИ P.singularities вЖТ
      HasLogDerivIntegerPrincipalPart riemannZeta s (P.principalCoeff s)

/-! ### BW2: `countedPrincipalPartData` admits analytic principal parts -/

/-- **BW2 вАФ PROVED:** the canonical counted principal-part data admits an
analytic principal-part package, via the BX3/BX5 analytic upgrades at each
nontrivial zero and at the pole. -/
theorem countedPrincipalPartData_analyticPrincipalPartData
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} :
    R.RectangleAnalyticPrincipalPartData
      (R.countedPrincipalPartData hAdm Z) where
  localAnalyticPrincipalPart := by
    intro s hs
    have hsCounted : R.IsCountedZetaSingularityInside s :=
      ((R.countedPrincipalPartData hAdm Z).singularities_complete s).mp hs
    rcases hsCounted with hsZero | hsPole
    ¬Ј have hsNT : IsNontrivialZetaZero s := hsZero.1
      show HasLogDerivIntegerPrincipalPart riemannZeta s
        (zetaLogDerivPrincipalCoeff s)
      rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
      exact zetaLogDeriv_principalPart_at_nontrivial_zero hsNT
    ¬Ј obtain вЯ®_, hs_eqвЯ© := hsPole
      subst hs_eq
      show HasLogDerivIntegerPrincipalPart riemannZeta (1 : вДВ)
        (zetaLogDerivPrincipalCoeff 1)
      rw [zetaLogDerivPrincipalCoeff_one]
      exact zetaLogDeriv_principalPart_at_one_unconditional

/-! ### BW3: extract the analytic remainder function and its properties -/

/-- The chosen local analytic remainder function at a singularity. -/
noncomputable def RectangleAnalyticPrincipalPartData.localAnalyticRemainder
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    (s : вДВ) (hs : s вИИ P.singularities) : вДВ вЖТ вДВ :=
  Classical.choose (A.localAnalyticPrincipalPart s hs)

theorem RectangleAnalyticPrincipalPartData.localAnalyticRemainder_analyticAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : вДВ} (hs : s вИИ P.singularities) :
    AnalyticAt вДВ (A.localAnalyticRemainder s hs) s :=
  (Classical.choose_spec (A.localAnalyticPrincipalPart s hs)).1

theorem RectangleAnalyticPrincipalPartData.localAnalyticRemainder_eventuallyEq
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : вДВ} (hs : s вИИ P.singularities) :
    logDeriv riemannZeta =бґ†[рЭУЭ[вЙ†] s]
      (fun z : вДВ =>
        (P.principalCoeff s : вДВ) / (z - s)
          + A.localAnalyticRemainder s hs z) :=
  (Classical.choose_spec (A.localAnalyticPrincipalPart s hs)).2

/-! ### BW4: piecewise-patched remainder -/

/-- The **full** local analytic remainder at a singularity `s`: the chosen
local analytic remainder for the `s`-pole minus all other principal kernels.
This is the value the patched remainder must take at `s` so that the patched
function equals the raw `R.logDerivRemainder P` on a punctured neighborhood
of `s`. -/
noncomputable def RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    (s : вДВ) (hs : s вИИ P.singularities) : вДВ вЖТ вДВ :=
  fun z =>
    A.localAnalyticRemainder s hs z
      - (P.singularities.erase s).sum
          (fun t => principalKernel (P.principalCoeff t) t z)

/-- The full local analytic remainder at `s` is analytic at `s`: the
chosen `g_s` is analytic there, and every kernel `k_t/(z-t)` with `t вЙ† s`
is analytic at `s`. -/
theorem RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt_analyticAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : вДВ} (hs : s вИИ P.singularities) :
    AnalyticAt вДВ (A.fullLocalAnalyticRemainderAt s hs) s := by
  unfold RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
  have hlocal : AnalyticAt вДВ (A.localAnalyticRemainder s hs) s :=
    A.localAnalyticRemainder_analyticAt hs
  have hsum :
      AnalyticAt вДВ
        (fun z : вДВ =>
          (P.singularities.erase s).sum
            (fun t => principalKernel (P.principalCoeff t) t z)) s := by
    refine Finset.analyticAt_fun_sum (c := s) (P.singularities.erase s) ?_
    intro t ht
    have hts : t вЙ† s := (Finset.mem_erase.mp ht).1
    exact analyticAt_principalKernel_of_ne (Ne.symm hts)
  exact hlocal.sub hsum

/-- The patched remainder: equal to the chosen **full** local analytic
remainder at each singularity (evaluated at that singularity), and equal
to the raw remainder elsewhere.  The `full` form ensures the patched
function equals an analytic function on a full neighborhood of each
singularity (not just a punctured one), making the BY4 eventual-equality
proof go through. -/
noncomputable def patchedLogDerivRemainder
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData)
    (A : R.RectangleAnalyticPrincipalPartData P) : вДВ вЖТ вДВ :=
  fun z =>
    if hz : z вИИ P.singularities then
      A.fullLocalAnalyticRemainderAt z hz z
    else
      R.logDerivRemainder P z

/-- Off the (finite) singularity set, the patched remainder agrees with
the raw remainder.  Immediate from the `if-then-else` definition. -/
theorem patchedLogDerivRemainder_agrees_off_singularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {z : вДВ} (hz : z вИЙ P.singularities) :
    patchedLogDerivRemainder P A z = R.logDerivRemainder P z := by
  unfold patchedLogDerivRemainder
  simp [hz]

/-! ### BW5: combined input + nonsingular-point analyticity -/

/-- Combined input data for inhabiting `RectangleLogDerivRemainderExtensionData`
from local analytic principal-part data plus the off-singularity ќґ-nonvanishing
and non-pole conditions on the closed rectangle. -/
structure RectangleLogDerivRemainderExtensionInput
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  analyticPP : R.RectangleAnalyticPrincipalPartData P
  off_singularity_not_pole :
    вИА z : вДВ, R.ContainsClosed z вЖТ z вИЙ P.singularities вЖТ z вЙ† (1 : вДВ)
  off_singularity_zeta_nonzero :
    вИА z : вДВ, R.ContainsClosed z вЖТ z вИЙ P.singularities вЖТ riemannZeta z вЙ† 0

/-- The patched remainder is analytic at every closed-rectangle point that is
not a counted singularity.  The patched and raw remainders agree on an open
neighborhood (complement of the finite singularity set), so analyticity of
the raw remainder there transfers. -/
theorem patchedLogDerivRemainder_analyticAt_of_not_singular
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderExtensionInput P)
    {z : вДВ} (hzClosed : R.ContainsClosed z) (hz : z вИЙ P.singularities) :
    AnalyticAt вДВ (patchedLogDerivRemainder P I.analyticPP) z := by
  have hraw : AnalyticAt вДВ (R.logDerivRemainder P) z :=
    analyticAt_logDerivRemainder_of_not_singular hz
      (I.off_singularity_not_pole z hzClosed hz)
      (I.off_singularity_zeta_nonzero z hzClosed hz)
  have hClosed : IsClosed ((P.singularities : Set вДВ)) :=
    P.singularities.finite_toSet.isClosed
  have hOpen : IsOpen ((P.singularities : Set вДВ)бґЬ) := hClosed.isOpen_compl
  have hAvoid : вИАбґ† w in рЭУЭ z, w вИЙ P.singularities := by
    have h_mem : z вИИ ((P.singularities : Set вДВ)бґЬ) := by simpa using hz
    exact hOpen.mem_nhds h_mem
  refine hraw.congr ?_
  filter_upwards [hAvoid] with w hw
  exact (patchedLogDerivRemainder_agrees_off_singularities I.analyticPP hw).symm

/-! ### BW6: isolated singular-point analyticity target + final assembler -/

/-- Target structure isolating the remaining analytic obligation: the
patched remainder is analytic at every counted singularity. -/
structure PatchedRemainderAnalyticAtSingularities
    (R : ZetaRectangle) {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P) : Prop where
  analyticAt :
    вИА s : вДВ, s вИИ P.singularities вЖТ
      AnalyticAt вДВ (patchedLogDerivRemainder P A) s

/-- **BW6 вАФ FINAL ASSEMBLER:** combined input data (BW5) plus the isolated
singular-point analyticity (BW6 target) discharges the extension data
needed by BV1, which in turn closes the principal-part contour
decomposition via BV3/BV4. -/
noncomputable def RectangleLogDerivRemainderExtensionInput.toExtensionData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderExtensionInput P)
    (S : R.PatchedRemainderAnalyticAtSingularities I.analyticPP) :
    R.RectangleLogDerivRemainderExtensionData P where
  remainderExt := patchedLogDerivRemainder P I.analyticPP
  agrees_off_singularities := fun z hz =>
    patchedLogDerivRemainder_agrees_off_singularities I.analyticPP hz
  analytic_remainderExt := by
    intro z hzClosed
    by_cases hzSing : z вИИ P.singularities
    ¬Ј exact S.analyticAt z hzSing
    ¬Ј exact patchedLogDerivRemainder_analyticAt_of_not_singular I hzClosed hzSing

/-! ## BY: Analyticity of the patched remainder at singularities -/

/-! ### BY1: finite isolation вАФ near `s`, only `s` itself can lie in `S` -/

/-- For a point `s` in a finite set `S`, near `s` the only element of `S`
encountered is `s` itself.  Uses that finite sets are closed. -/
theorem eventually_eq_or_not_mem_finset
    {S : Finset вДВ} {s : вДВ} :
    вИАбґ† z in рЭУЭ s, z = s вИ® z вИЙ S := by
  classical
  have hs_not : s вИЙ ((S.erase s : Set вДВ)) := by
    intro h
    exact (Finset.notMem_erase s S) (by exact_mod_cast h)
  have hclosed : IsClosed ((S.erase s : Set вДВ)) :=
    (S.erase s).finite_toSet.isClosed
  have hopen : IsOpen ((S.erase s : Set вДВ)бґЬ) := hclosed.isOpen_compl
  have hmem : ((S.erase s : Set вДВ)бґЬ) вИИ рЭУЭ s := hopen.mem_nhds hs_not
  filter_upwards [hmem] with z hz
  by_cases hzs : z = s
  ¬Ј exact Or.inl hzs
  ¬Ј refine Or.inr ?_
    intro hzS
    apply hz
    show z вИИ (S.erase s : Set вДВ)
    exact_mod_cast Finset.mem_erase.mpr вЯ®hzs, hzSвЯ©

/-! ### BY4: patched remainder equals full local analytic remainder on a `рЭУЭ s` -/

/-- The key local equality: on a neighborhood of any singularity `s`, the
patched remainder equals the full local analytic remainder.  At `z = s` the
two agree by definition (the `if`-branch); at `z вЙ† s` and `z вИЙ S` the raw
remainder equals the full local remainder via the punctured principal-part
equality + finite-sum split. -/
theorem patchedLogDerivRemainder_eventuallyEq_fullLocal
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : вДВ} (hs : s вИИ P.singularities) :
    patchedLogDerivRemainder P A =бґ†[рЭУЭ s] A.fullLocalAnalyticRemainderAt s hs := by
  classical
  have hIso : вИАбґ† z in рЭУЭ s, z = s вИ® z вИЙ P.singularities :=
    eventually_eq_or_not_mem_finset
  have hPP_nhds : вИАбґ† z in рЭУЭ s, z вИИ ({s}бґЬ : Set вДВ) вЖТ
      logDeriv riemannZeta z =
        (P.principalCoeff s : вДВ) / (z - s) + A.localAnalyticRemainder s hs z :=
    eventually_nhdsWithin_iff.mp (A.localAnalyticRemainder_eventuallyEq hs)
  filter_upwards [hIso, hPP_nhds] with z hzIso hzPPimp
  obtain hzs | hzNot := hzIso
  ¬Ј -- z = s: both sides reduce to `A.fullLocalAnalyticRemainderAt s hs s`
    rw [hzs]
    unfold patchedLogDerivRemainder
    simp [hs]
  ¬Ј -- z вИЙ P.singularities, hence z вЙ† s and the raw remainder applies
    have hz_ne : z вЙ† s := fun h => hzNot (h вЦЄ hs)
    have hz_compl : z вИИ ({s}бґЬ : Set вДВ) := hz_ne
    have hPP := hzPPimp hz_compl
    have h_patched_eq : patchedLogDerivRemainder P A z = R.logDerivRemainder P z :=
      patchedLogDerivRemainder_agrees_off_singularities A hzNot
    rw [h_patched_eq]
    -- Split the principalPartSum into s-term + erase-sum, and use hPP.
    unfold ZetaRectangle.logDerivRemainder ZetaRectangle.principalPartSum
      RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
    rw [вЖР Finset.add_sum_erase _ _ hs]
    have hzeta : zetaLogDeriv z = logDeriv riemannZeta z := rfl
    rw [hzeta, hPP]
    unfold principalKernel
    ring

/-! ### BY5: patched remainder analytic at each singularity -/

/-- The patched remainder is analytic at every counted singularity, via
`AnalyticAt.congr` on the BY4 eventual equality with the full local
analytic remainder. -/
theorem patchedLogDerivRemainder_analyticAt_singularity
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : вДВ} (hs : s вИИ P.singularities) :
    AnalyticAt вДВ (patchedLogDerivRemainder P A) s := by
  have h1 : AnalyticAt вДВ (A.fullLocalAnalyticRemainderAt s hs) s :=
    A.fullLocalAnalyticRemainderAt_analyticAt hs
  exact h1.congr (patchedLogDerivRemainder_eventuallyEq_fullLocal A hs).symm

/-! ### BY6: inhabit `PatchedRemainderAnalyticAtSingularities` unconditionally -/

/-- **BY6 вАФ UNCONDITIONAL INHABITATION:** the patched remainder is analytic
at every singularity, given only the analytic principal-part data.  This
closes the final analytic obligation in the rectangle decomposition. -/
theorem patchedLogDerivRemainder_analyticAtSingularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P) :
    R.PatchedRemainderAnalyticAtSingularities A where
  analyticAt := fun _ hs =>
    patchedLogDerivRemainder_analyticAt_singularity A hs

/-! ## BZ: Canonical-rectangle off-singularity wiring -/

/-! ### BZ0: closed = open вИ™ boundary -/

/-- Every point of the closed rectangle is either in the open rectangle or
on the boundary. -/
theorem containsOpen_or_boundary_of_containsClosed
    (R : ZetaRectangle) {z : вДВ}
    (hz : R.ContainsClosed z) :
    R.ContainsOpen z вИ® R.ContainsBoundary z := by
  by_cases hopen : R.ContainsOpen z
  ¬Ј exact Or.inl hopen
  ¬Ј exact Or.inr вЯ®hz, hopenвЯ©

/-- Closed-rectangle point that is not on the boundary is in the open
rectangle. -/
theorem containsOpen_of_containsClosed_not_boundary
    (R : ZetaRectangle) {z : вДВ}
    (hz : R.ContainsClosed z) (hnb : ¬ђ R.ContainsBoundary z) :
    R.ContainsOpen z := by
  rcases R.containsOpen_or_boundary_of_containsClosed hz with h | h
  ¬Ј exact h
  ¬Ј exact False.elim (hnb h)

/-! ### BZ2: not in counted singularities вЗТ not the pole -/

/-- For canonical counted principal-part data: if `z` is in the closed
rectangle and is not a counted singularity, then `z вЙ† 1`.  At `z = 1`, strong
admissibility's `poleNotOnBoundary` plus `ContainsClosed 1` forces
`PoleInside`, which makes `1` a counted singularity вАФ contradiction. -/
theorem not_pole_of_closed_not_mem_countedPrincipalPart_singularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} {z : вДВ}
    (hzClosed : R.ContainsClosed z)
    (hz : z вИЙ (R.countedPrincipalPartData hAdm Z).singularities) :
    z вЙ† (1 : вДВ) := by
  intro hz1
  subst hz1
  have hnb : ¬ђ R.ContainsBoundary (1 : вДВ) := hAdm.poleNotOnBoundary
  have hOpen : R.ContainsOpen (1 : вДВ) :=
    R.containsOpen_of_containsClosed_not_boundary hzClosed hnb
  have hPoleInside : R.PoleInside := hOpen
  have hcounted : R.IsCountedZetaSingularityInside (1 : вДВ) :=
    Or.inr вЯ®hPoleInside, rflвЯ©
  exact hz ((R.countedPrincipalPartData hAdm Z).singularities_complete 1 |>.mpr hcounted)

/-! ### BZ3: not in counted singularities вЗТ ќґ вЙ† 0 (given a zero-classification hypothesis) -/

/-- For canonical counted principal-part data: if `z` is not in the
singularity set and every zeta zero in the closed rectangle is a
counted nontrivial zero inside, then `ќґ z вЙ† 0`. -/
theorem zeta_nonzero_of_closed_not_mem_countedPrincipalPart_singularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} {z : вДВ}
    (_hzClosed : R.ContainsClosed z)
    (hz : z вИЙ (R.countedPrincipalPartData hAdm Z).singularities)
    (hZeroInside : riemannZeta z = 0 вЖТ R.IsNontrivialZeroInside z) :
    riemannZeta z вЙ† 0 := by
  intro hzeta
  have hInside : R.IsNontrivialZeroInside z := hZeroInside hzeta
  have hcounted : R.IsCountedZetaSingularityInside z := Or.inl hInside
  exact hz ((R.countedPrincipalPartData hAdm Z).singularities_complete z |>.mpr hcounted)

/-! ### BZ4: input package for canonical rectangles -/

/-- The clean geometric/zero-classification input for canonical residue-free
data: every zeta zero in the closed rectangle is a counted nontrivial zero
inside the rectangle.  For RvM rectangles this is concretely deducible from
positive bottom (excludes real trivial zeros) and the critical-strip bounds. -/
structure CanonicalRemainderNoUnremovedSingularities
    (R : ZetaRectangle) (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) : Prop where
  zero_inside_of_zeta_zero :
    вИА z : вДВ, R.ContainsClosed z вЖТ riemannZeta z = 0 вЖТ
      R.IsNontrivialZeroInside z

/-- Build the canonical extension input from the geometric/zero-classification
package and the unconditional BX6 analytic principal-part data. -/
noncomputable def RectangleLogDerivRemainderExtensionInput.of_canonical
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.RectangleLogDerivRemainderExtensionInput
      (R.countedPrincipalPartData hAdm Z) where
  analyticPP := countedPrincipalPartData_analyticPrincipalPartData
  off_singularity_not_pole := fun _ hzClosed hzNot =>
    not_pole_of_closed_not_mem_countedPrincipalPart_singularities
      hzClosed hzNot
  off_singularity_zeta_nonzero := fun z hzClosed hzNot =>
    zeta_nonzero_of_closed_not_mem_countedPrincipalPart_singularities
      hzClosed hzNot (N.zero_inside_of_zeta_zero z hzClosed)

/-! ### BZ5: final canonical residue-free data from the no-unremoved input -/

/-- **BZ5 вАФ UNCONDITIONAL FINAL ASSEMBLER:** kernel-index data plus the clean
no-unremoved-singularities geometric package inhabits the canonical
residue-free argument-principle data.  Every other rectangle-decomposition
obligation (analytic principal parts, patched-remainder analyticity, linearity
of contour integration, Cauchy-Goursat for the patched remainder) is now
discharged unconditionally. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_noUnremovedSingularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z :=
  let I : R.RectangleLogDerivRemainderExtensionInput
            (R.countedPrincipalPartData hAdm Z) :=
    RectangleLogDerivRemainderExtensionInput.of_canonical N
  let S : R.PatchedRemainderAnalyticAtSingularities I.analyticPP :=
    patchedLogDerivRemainder_analyticAtSingularities I.analyticPP
  CanonicalResidueFreeArgumentPrincipleData.of_remainderExtension K
    (I.toExtensionData S)

/-! ## CA: Canonical kernel-index data + final RvM-rectangle wiring -/

/-! ### CA1: canonical kernel-index data from the unit-kernel chain -/

/-- For every counted singularity, pick a canonical small circle inside the
rectangle and discharge the per-singularity punctured Cauchy-Goursat via
the unit-kernel chain (centered-square reduction + translation invariance
+ centered-square = 2ѕАi). -/
noncomputable def rectangleKernelIndexData_of_unitKernel
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} :
    R.RectangleKernelIndexData P := by
  classical
  let choose_circle :
      вИА s, s вИИ P.singularities вЖТ R.SmallCircleInsideRectangle s :=
    fun s hs =>
      Classical.choice (exists_smallCircleInsideRectangle (by
        have hsCounted : R.IsCountedZetaSingularityInside s :=
          (P.singularities_complete s).mp hs
        rcases hsCounted with hsZero | hsPole
        ¬Ј exact hsZero.2
        ¬Ј obtain вЯ®hPoleInside, hs_eqвЯ© := hsPole
          rw [hs_eq]; exact hPoleInside))
  exact {
    smallCircle := choose_circle
    puncturedCG := fun s hs =>
      PuncturedRectangleCauchyGoursat.of_canonicalSquareToCircle
        (UnitKernelCanonicalSquareToCircleDeformation.of_centered_reduction
          centeredSquareEqualsTwoPiI
          (canonicalSquareEqualsCenteredSquare (choose_circle s hs))) }

/-! ### CA2: canonical residue-free data from no-unremoved-singularities only -/

/-- Canonical residue-free argument-principle data built directly from the
no-unremoved-singularities geometric package вАФ the kernel-index data is
provided by CA1 (unit-kernel chain). -/
noncomputable def canonicalResidueFreeArgumentPrincipleData
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z :=
  CanonicalResidueFreeArgumentPrincipleData.of_noUnremovedSingularities
    (rectangleKernelIndexData_of_unitKernel
      (R := R) (P := R.countedPrincipalPartData hAdm Z))
    N

/-! ## AU: Finite-set algebra bridge to the residue-index formula -/

/-! ### AU5: principal-coefficient sum = weighted zero count вИТ pole count -/

/-- The sum of canonical principal coefficients over counted singularities
equals the weighted zero count minus the pole count.  This is the finite-set
algebra bridge between principal-part data and the older residue-index
formula. -/
theorem countedPrincipalCoeff_sum_eq_zeroCount_sub_poleCount
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) :
    (R.countedPrincipalPartData hAdm Z).singularities.sum
        (R.countedPrincipalPartData hAdm Z).principalCoeff =
      (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : вД§)
        - (R.poleCountInside : вД§) := by
  classical
  show (R.canonicalSingularities Z).sum zetaLogDerivPrincipalCoeff =
       (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : вД§)
         - (R.poleCountInside : вД§)
  have h_zero_sum :
      Z.zeros.sum zetaLogDerivPrincipalCoeff =
        (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : вД§) := by
    unfold weightedZeroCountInside
    push_cast
    refine Finset.sum_congr rfl (fun s hs => ?_)
    have hsNT : IsNontrivialZetaZero s := ((Z.complete s).mp hs).1
    exact zetaLogDerivPrincipalCoeff_of_zero hsNT
  have h1_not_mem : (1 : вДВ) вИЙ Z.zeros := by
    intro h1
    have hNT : IsNontrivialZetaZero (1 : вДВ) := ((Z.complete 1).mp h1).1
    have hlt : (1 : вДВ).re < 1 := hNT.2.2
    norm_num at hlt
  unfold canonicalSingularities
  by_cases hpole : R.PoleInside
  ¬Ј rw [if_pos hpole, Finset.sum_insert h1_not_mem,
        zetaLogDerivPrincipalCoeff_one, h_zero_sum]
    have h_pole_one : R.poleCountInside = 1 := by
      simp [poleCountInside, hpole]
    rw [h_pole_one]
    push_cast
    ring
  ¬Ј rw [if_neg hpole, h_zero_sum]
    have h_pole_zero : R.poleCountInside = 0 := by
      simp [poleCountInside, hpole]
    rw [h_pole_zero]
    push_cast
    ring

/-! ### AU4: canonical principal-part theorem вЖТ residue-index formula -/

/-- If a principal-part integral theorem's `ppData` matches the canonical
counted data, it yields the residue-index formula via AU5. -/
noncomputable def RectanglePrincipalPartIntegralTheorem.toResidueIndexFormula_of_canonical
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    (T : R.RectanglePrincipalPartIntegralTheorem)
    (hPP :
      T.ppData =
        R.countedPrincipalPartData hAdm
          (R.zeroSetInsideOfSlab hleft hright hgood
            (R.canonicalSlabZeroSet hbottom_nonneg))) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood where
  stronglyAdmissible := hAdm
  residueIndex := T.ppData.singularities.sum T.ppData.principalCoeff
  normalizedIntegral_eq_index := T.normalizedIntegral_eq_sum
  residueIndex_eq_count_sub_poles := by
    rw [hPP]
    exact countedPrincipalCoeff_sum_eq_zeroCount_sub_poleCount hAdm _

/-! ### AU6: canonical residue-free data вЖТ residue-index formula -/

/-- Canonical residue-free argument-principle data inhabits the rectangle
residue-index formula. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toResidueIndexFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (hZ :
      Z =
        R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood := by
  subst hZ
  exact D.toPrincipalPartIntegralTheorem.toResidueIndexFormula_of_canonical rfl

/-! ### AU7: canonical residue-free data вЖТ Turing interval certificate -/

/-- Canonical residue-free argument-principle data on the canonical slab
yields a Turing interval certificate, the final downstream consumer. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (hZ :
      Z =
        R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate :=
  (D.toResidueIndexFormula hZ).toTuringIntervalCertificate hbottom_pos

/-! ## AV: RvM rectangle family bridge -/

/-! ### AV1: RvM rectangle data structure -/

/-- A rectangle suitable for a good-height RiemannвАУvon Mangoldt count:
positive bottom (to keep the pole off the boundary), a good top,
straddles the critical strip, and is strongly admissible. -/
structure RvMRectangleData (T : вДЭ) where
  R : ZetaRectangle
  left_lt_zero : R.left < 0
  one_lt_right : 1 < R.right
  bottom_nonneg : 0 вЙ§ R.bottom
  bottom_pos : 0 < R.bottom
  top_eq : R.top = T
  goodTop : GoodHeight R.top
  stronglyAdmissible : R.StronglyAdmissibleForZeta

/-! ### AV2: canonical zero set inside the RvM rectangle -/

/-- The canonical rectangle-inside zero set for an RvM rectangle. -/
noncomputable def RvMRectangleData.zeroSetInside
    {T : вДЭ} (D : RvMRectangleData T) :
    D.R.ZeroSetInside :=
  D.R.zeroSetInsideOfSlab
    D.left_lt_zero
    D.one_lt_right
    D.goodTop
    (D.R.canonicalSlabZeroSet D.bottom_nonneg)

/-! ### AV3: residue-free data for an RvM rectangle -/

/-- Residue-free argument-principle data attached to an RvM rectangle.
This bundles the two global contour obligations
(`PuncturedRectangleCauchyGoursat` and `RectanglePrincipalPartContourDecomposition`)
for the canonical singularities of this rectangle. -/
structure RvMRectangleResidueFreeData
    {T : вДЭ} (D : RvMRectangleData T) where
  data :
    D.R.CanonicalResidueFreeArgumentPrincipleData
      D.stronglyAdmissible
      D.zeroSetInside

/-! ### AV4: RvM residue-free data вЖТ Turing certificate -/

/-- Residue-free data for an RvM rectangle yields a Turing interval
certificate for the rectangle's height slab. -/
noncomputable def RvMRectangleResidueFreeData.toTuringIntervalCertificate
    {T : вДЭ}
    {D : RvMRectangleData T}
    (A : RvMRectangleResidueFreeData D) :
    TuringIntervalCertificate :=
  A.data.toTuringIntervalCertificate rfl D.bottom_pos

/-! ### CA3: RvM-rectangle no-unremoved-singularities wrapper -/

/-- RvM-rectangle wrapper for the canonical no-unremoved-singularities
geometric package. -/
structure RvMRectangleNoUnremovedSingularities
    {T : вДЭ} (D : RvMRectangleData T) : Prop where
  noUnremoved :
    D.R.CanonicalRemainderNoUnremovedSingularities
      D.stronglyAdmissible D.zeroSetInside

/-- Build the RvM residue-free data from the no-unremoved-singularities
geometric package, via CA2's canonical-residue-free constructor. -/
noncomputable def RvMRectangleResidueFreeData.of_noUnremovedSingularities
    {T : вДЭ} {D : RvMRectangleData T}
    (N : RvMRectangleNoUnremovedSingularities D) :
    RvMRectangleResidueFreeData D where
  data := canonicalResidueFreeArgumentPrincipleData N.noUnremoved

/-! ### AV6: main-term evaluation at a single height -/

/-- Per-height main-term evaluation: the weighted slab count equals
`mainTerm T + Sarg T`.  Together with the rectangle certificate, this is the
analytic input needed to inhabit the good-height RvM formula. -/
structure RvMRectangleMainTermEvaluation
    {T : вДЭ} (D : RvMRectangleData T) where
  Sarg : вДЭ вЖТ вДЭ
  evaluation :
    (zetaWeightedZeroCountInHeightSlab
        D.R.bottom D.R.top D.bottom_nonneg D.R.hbottom_lt_top.le : вДЭ) =
      riemannVonMangoldtMainTerm T + Sarg T

/-! ### AV7: good-height RvM rectangle family -/

/-- A good-height family: a rectangle and residue-free data per good height,
together with the per-height RvM main-term evaluation evaluated against
a single global `Sarg`. -/
structure RvMGoodHeightRectangleFamily where
  Sarg : вДЭ вЖТ вДЭ
  rect :
    вИА T : вДЭ, RvMGoodHeight T вЖТ RvMRectangleData T
  residueFree :
    вИА T : вДЭ, (hT : RvMGoodHeight T) вЖТ RvMRectangleResidueFreeData (rect T hT)
  mainEval :
    вИА T : вДЭ, (hT : RvMGoodHeight T) вЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : вДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- A good-height rectangle family yields the good-height RvM formula
package. -/
noncomputable def RvMGoodHeightRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights where
  Sarg := F.Sarg
  formula := F.mainEval

/-! ### CA4: concrete good-height rectangle family (replacing `residueFree` with `noUnremoved`) -/

/-- Concrete good-height rectangle family: a rectangle, the
no-unremoved-singularities geometric package per good height, and the
per-height RvM main-term evaluation.  The residue-free data is built
automatically via CA3. -/
structure RvMGoodHeightConcreteRectangleFamily where
  Sarg : вДЭ вЖТ вДЭ
  rect : вИА T : вДЭ, RvMGoodHeight T вЖТ RvMRectangleData T
  noUnremoved :
    вИА T : вДЭ, (hT : RvMGoodHeight T) вЖТ
      RvMRectangleNoUnremovedSingularities (rect T hT)
  mainEval :
    вИА T : вДЭ, (hT : RvMGoodHeight T) вЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : вДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Convert a concrete good-height rectangle family into the existing
`RvMGoodHeightRectangleFamily` by building the residue-free data from
the no-unremoved-singularities package. -/
noncomputable def RvMGoodHeightConcreteRectangleFamily.toRectangleFamily
    (F : RvMGoodHeightConcreteRectangleFamily) :
    RvMGoodHeightRectangleFamily where
  Sarg := F.Sarg
  rect := F.rect
  residueFree := fun T hT =>
    RvMRectangleResidueFreeData.of_noUnremovedSingularities (F.noUnremoved T hT)
  mainEval := F.mainEval

/-! ### CA5: final good-height RvM theorem from the concrete family -/

/-- **CA5 вАФ FINAL:** the concrete good-height rectangle family directly
yields the proven good-height RiemannвАУvon Mangoldt formula package. -/
noncomputable def
    RvMGoodHeightConcreteRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightConcreteRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights :=
  F.toRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights

/-! ## CB: Standard safe-height rectangle constructor for RvM data -/

/-! ### CB1: geometric rectangle with bottom `B` and top `T` -/

/-- The standard horizontal-strip rectangle with `left = -1`, `right = 2`,
bottom `B`, and top `T`.  Encloses the critical strip `0 < re < 1`. -/
noncomputable def rectangleOfSafeHeights
    {B T : вДЭ} (_hBpos : 0 < B) (hBT : B < T) :
    ZetaRectangle where
  left := -1
  right := 2
  bottom := B
  top := T
  hleft_lt_right := by norm_num
  hbottom_lt_top := hBT

/-! ## CC: Strong admissibility from edge-by-edge boundary classification -/

/-! ### CC1: boundary zero-free package (named obligations) -/

/-- The remaining zeta-zero classification facts needed to prove strong
admissibility for `rectangleOfSafeHeights`.

* `left_edge`: no zeta zero anywhere on the vertical line `re = -1`
  (needs the functional equation to push back into the convergent region).
* `bottom_zeros_nontrivial`: every zeta zero with `im = B` is a nontrivial
  zero (rules out hypothetical "exotic" zeros; follows from the standard
  classification trivial zeros вИ™ nontrivial zeros).
* `top_zeros_nontrivial`: same for `im = T`. -/
structure SafeHeightRectangleBoundaryZeroFree (B T : вДЭ) : Prop where
  left_edge :
    вИА y : вДЭ, riemannZeta вЯ®-1, yвЯ© вЙ† 0
  bottom_zeros_nontrivial :
    вИА z : вДВ, z.im = B вЖТ riemannZeta z = 0 вЖТ IsNontrivialZetaZero z
  top_zeros_nontrivial :
    вИА z : вДВ, z.im = T вЖТ riemannZeta z = 0 вЖТ IsNontrivialZetaZero z

/-! ### CC2: easy edge / pole lemmas -/

/-- Right edge `re = 2` is zero-free for `ќґ` (Euler-product region). -/
theorem zeta_ne_zero_of_re_eq_two
    {z : вДВ} (hzre : z.re = (2 : вДЭ)) : riemannZeta z вЙ† 0 :=
  riemannZeta_ne_zero_of_one_lt_re (by simp [hzre])

/-- The pole `1 вИИ вДВ` does not lie on the boundary of a safe-height
rectangle: `Im 1 = 0 < B` puts it strictly below the rectangle's
horizontal slab. -/
theorem pole_not_on_boundary_safeRectangle
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T) :
    ¬ђ (rectangleOfSafeHeights hBpos hBT).ContainsBoundary (1 : вДВ) := by
  intro h
  have hc := h.1
  have h_im : B вЙ§ (1 : вДВ).im := hc.2.2.1
  simp at h_im
  linarith

/-- Boundary case-split for a safe-height rectangle: any boundary point
lies on exactly one of the four edges. -/
theorem boundary_cases_safeRectangle
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T) {z : вДВ}
    (hz : (rectangleOfSafeHeights hBpos hBT).ContainsBoundary z) :
    z.re = -1 вИ® z.re = 2 вИ® z.im = B вИ® z.im = T := by
  obtain вЯ®hC, hOвЯ© := hz
  have h1 : (-1 : вДЭ) вЙ§ z.re := hC.1
  have h2 : z.re вЙ§ (2 : вДЭ) := hC.2.1
  have h3 : B вЙ§ z.im := hC.2.2.1
  have h4 : z.im вЙ§ T := hC.2.2.2
  by_contra hcontra
  push_neg at hcontra
  obtain вЯ®hL, hR, hBe, hTeвЯ© := hcontra
  apply hO
  refine вЯ®?_, ?_, ?_, ?_вЯ©
  ¬Ј exact lt_of_le_of_ne h1 (Ne.symm hL)
  ¬Ј exact lt_of_le_of_ne h2 hR
  ¬Ј exact lt_of_le_of_ne h3 (Ne.symm hBe)
  ¬Ј exact lt_of_le_of_ne h4 hTe

/-! ### CC3: strong admissibility from `SafeHeightRectangleBoundaryZeroFree` -/

/-- Strong admissibility of the safe-height rectangle, derived from
`GoodHeight` on top/bottom plus the three remaining boundary
classification facts. -/
theorem stronglyAdmissible_rectangleOfSafeHeights
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleBoundaryZeroFree B T) :
    (rectangleOfSafeHeights hBpos hBT).StronglyAdmissibleForZeta where
  noZetaZerosOnBoundary := by
    intro s hsZero hsBoundary
    rcases boundary_cases_safeRectangle hBpos hBT hsBoundary with hL | hR | hB | hT'
    ¬Ј exact H.left_edge s.im (by
        have h_eq : (вЯ®-1, s.imвЯ© : вДВ) = s := by
          apply Complex.ext
          ¬Ј simp [hL]
          ¬Ј simp
        rw [h_eq]; exact hsZero)
    ¬Ј exact zeta_ne_zero_of_re_eq_two hR hsZero
    ¬Ј have hNT : IsNontrivialZetaZero s := H.bottom_zeros_nontrivial s hB hsZero
      exact hBgood s hNT hB
    ¬Ј have hNT : IsNontrivialZetaZero s := H.top_zeros_nontrivial s hT' hsZero
      exact hTgood s hNT hT'
  poleNotOnBoundary := pole_not_on_boundary_safeRectangle hBpos hBT

/-! ## CD: Interior zero-classification + canonical `noUnremoved` for safe rectangles -/

/-! ### CD2: zero-classification package (extends boundary package with interior) -/

/-- Full zeta-zero classification on a safe-height rectangle: combines the
boundary package (CC1) with an `interior_zeros_nontrivial` field stating
that every zeta zero in the open rectangle is a nontrivial zero. -/
structure SafeHeightRectangleZeroClassification
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T) : Prop
    extends SafeHeightRectangleBoundaryZeroFree B T where
  interior_zeros_nontrivial :
    вИА z : вДВ,
      (rectangleOfSafeHeights hBpos hBT).ContainsOpen z вЖТ
      riemannZeta z = 0 вЖТ
      IsNontrivialZetaZero z

/-! ### CD1: every closed-rectangle zeta zero is a nontrivial zero inside -/

/-- The classification package implies every zeta zero in the closed
safe-height rectangle is a nontrivial zero in the open rectangle. -/
theorem isNontrivialZeroInside_of_closed_safeRectangle_zero
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleZeroClassification hBpos hBT)
    {z : вДВ}
    (hzClosed : (rectangleOfSafeHeights hBpos hBT).ContainsClosed z)
    (hzeta : riemannZeta z = 0) :
    (rectangleOfSafeHeights hBpos hBT).IsNontrivialZeroInside z := by
  have hCases :
      (rectangleOfSafeHeights hBpos hBT).ContainsOpen z вИ®
        (rectangleOfSafeHeights hBpos hBT).ContainsBoundary z :=
    (rectangleOfSafeHeights hBpos hBT).containsOpen_or_boundary_of_containsClosed hzClosed
  rcases hCases with hOpen | hBoundary
  ¬Ј -- interior: classification field handles it
    exact вЯ®H.interior_zeros_nontrivial z hOpen hzeta, hOpenвЯ©
  ¬Ј -- boundary: derive contradiction from the boundary classification
    exfalso
    rcases boundary_cases_safeRectangle hBpos hBT hBoundary with hL | hR | hBdry | hTop
    ¬Ј apply H.left_edge z.im
      have h_eq : (вЯ®-1, z.imвЯ© : вДВ) = z := by
        apply Complex.ext
        ¬Ј simpa using hL.symm
        ¬Ј simp
      rw [h_eq]
      exact hzeta
    ¬Ј exact zeta_ne_zero_of_re_eq_two hR hzeta
    ¬Ј have hNT : IsNontrivialZetaZero z := H.bottom_zeros_nontrivial z hBdry hzeta
      exact hBgood z hNT hBdry
    ¬Ј have hNT : IsNontrivialZetaZero z := H.top_zeros_nontrivial z hTop hzeta
      exact hTgood z hNT hTop

/-! ### CB3 (updated): safe-height data via the zero-classification package -/

/-- Safe-height data for an RvM rectangle: positive bottom height `B`,
both heights `Good`, and the full safe-rectangle zeta-zero classification
package (CD2). -/
structure RvMSafeHeightData (T : вДЭ) where
  B : вДЭ
  B_pos : 0 < B
  B_lt_T : B < T
  goodBottom : GoodHeight B
  goodTop : GoodHeight T
  zeroClass : SafeHeightRectangleZeroClassification B_pos B_lt_T

/-! ### CB6 (updated): build `RvMRectangleData` from safe-height data -/

/-- Construct an `RvMRectangleData` for height `T` from safe-height data,
using CC3 to discharge strong admissibility via the boundary part of the
zero-classification package. -/
noncomputable def rvmRectangleDataOfSafeHeights
    {T : вДЭ} (H : RvMSafeHeightData T) :
    RvMRectangleData T where
  R := rectangleOfSafeHeights H.B_pos H.B_lt_T
  left_lt_zero := by show (-1 : вДЭ) < 0; norm_num
  one_lt_right := by show (1 : вДЭ) < 2; norm_num
  bottom_nonneg := le_of_lt H.B_pos
  bottom_pos := H.B_pos
  top_eq := rfl
  goodTop := H.goodTop
  stronglyAdmissible :=
    stronglyAdmissible_rectangleOfSafeHeights
      H.B_pos H.B_lt_T H.goodBottom H.goodTop
      H.zeroClass.toSafeHeightRectangleBoundaryZeroFree

/-! ### CD3: canonical no-unremoved-singularities for safe rectangles -/

/-- The zero-classification package implies the canonical
`CanonicalRemainderNoUnremovedSingularities` for any admissibility/zero-set
combination on the safe-height rectangle. -/
theorem noUnremovedSingularities_rectangleOfSafeHeights
    {B T : вДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleZeroClassification hBpos hBT)
    {hAdm : (rectangleOfSafeHeights hBpos hBT).StronglyAdmissibleForZeta}
    {Z : (rectangleOfSafeHeights hBpos hBT).ZeroSetInside} :
    (rectangleOfSafeHeights hBpos hBT).CanonicalRemainderNoUnremovedSingularities
      hAdm Z where
  zero_inside_of_zeta_zero := fun _ hzClosed hzeta =>
    isNontrivialZeroInside_of_closed_safeRectangle_zero
      hBpos hBT hBgood hTgood H hzClosed hzeta

/-! ### CD5: `RvMRectangleNoUnremovedSingularities` from safe-height data -/

/-- The RvM no-unremoved-singularities wrapper directly from safe-height
data вАФ every zero-in-closed-rectangle is nontrivial-inside by CD1, hence
the canonical no-unremoved property holds. -/
noncomputable def rvmRectangleNoUnremovedSingularitiesOfSafeHeights
    {T : вДЭ} (H : RvMSafeHeightData T) :
    RvMRectangleNoUnremovedSingularities (rvmRectangleDataOfSafeHeights H) where
  noUnremoved :=
    noUnremovedSingularities_rectangleOfSafeHeights
      H.B_pos H.B_lt_T H.goodBottom H.goodTop H.zeroClass

/-! ### CB7: existence of a good bottom height strictly inside `(0, T)` -/

/-- For any positive good height `T`, there exists a good bottom height
`B вИИ (0, T)`.  Pure use of `exists_goodHeight_between` on `(T/2, T)`. -/
theorem existsSafeBottomHeight
    {T : вДЭ} (hTpos : 0 < T) :
    вИГ B : вДЭ, 0 < B вИІ B < T вИІ GoodHeight B := by
  have hAlt : (T / 2 : вДЭ) < T := by linarith
  have hApos : (0 : вДЭ) < T / 2 := by linarith
  obtain вЯ®B, hAB, hBT, hgoodвЯ© := exists_goodHeight_between hApos hAlt
  exact вЯ®B, by linarith, hBT, hgoodвЯ©

/-! ### CD6: safe-rectangle good-height family + conversion to concrete family -/

/-- Safe-rectangle good-height family: a global `Sarg`, a safe-height
data per good height, and a per-height main-term evaluation.  Combined
with the canonical no-unremoved conversion (CD5), this directly yields
a `RvMGoodHeightConcreteRectangleFamily`. -/
structure RvMGoodHeightSafeRectangleFamily where
  Sarg : вДЭ вЖТ вДЭ
  safeData : вИА T : вДЭ, RvMGoodHeight T вЖТ RvMSafeHeightData T
  mainEval :
    вИА T : вДЭ, (hT : RvMGoodHeight T) вЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : вДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Convert a safe-rectangle family into the existing concrete family
by applying CB6 to obtain `rect` and CD5 to obtain `noUnremoved`. -/
noncomputable def RvMGoodHeightSafeRectangleFamily.toConcreteRectangleFamily
    (F : RvMGoodHeightSafeRectangleFamily) :
    RvMGoodHeightConcreteRectangleFamily where
  Sarg := F.Sarg
  rect := fun T hT => rvmRectangleDataOfSafeHeights (F.safeData T hT)
  noUnremoved := fun T hT =>
    rvmRectangleNoUnremovedSingularitiesOfSafeHeights (F.safeData T hT)
  mainEval := F.mainEval

/-- **CD6 вАФ FINAL:** the safe-rectangle family directly yields the proven
good-height RiemannвАУvon Mangoldt formula package. -/
noncomputable def
    RvMGoodHeightSafeRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightSafeRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights :=
  F.toConcreteRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights

end ZetaRectangle

/-! ## AW: Final Backlund/Turing input package -/

/-! ### AW1: master analytic-input package -/

/-- All remaining analytic inputs needed to derive the final
Backlund/Turing bound.  Everything past this structure is mechanical. -/
structure BacklundTuringAnalyticInputs where
