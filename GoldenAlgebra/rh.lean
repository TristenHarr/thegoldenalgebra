-- =====================================================================
-- §CCCXX. Hadamard product formula scaffold
-- =====================================================================
-- A more directly-Hadamard-shaped source: gives the Hadamard product
-- equality plus the product-side log-derivative. Provides exactly the
-- API the Hadamard agent needs to inhabit.

/-- 📦 **`CompletedXiHadamardProductFormula`** — Hadamard product
formula scaffold. Splits the Hadamard content into:
* `product_eq` — `completedXiFunction = productSide` (factorization);
* `product_differentiable_at` — productSide differentiability AFZ;
* `product_logDeriv_eq` — productSide log-derivative equals the
  abstract `xiZeroContribution`. -/
structure CompletedXiHadamardProductFormula : Type where
  xiZeroContribution : ℂ → ℂ
  productSide : ℂ → ℂ
  product_eq :
    ∀ s : ℂ, completedXiFunction s = productSide s
  product_differentiable_at :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ productSide s
  product_logDeriv_eq :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      logDerivativeResponse productSide s = xiZeroContribution s

/-- 🌟🌟🌟 **PROVED — `CompletedXiLogDerivativeSourceAFZ` from
Hadamard product formula.** Transfers differentiability and
log-derivative via `product_eq` (pointwise function equality). -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductFormula
    (H : CompletedXiHadamardProductFormula) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := H.xiZeroContribution
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  · intro s hs
    have hfun_eq : completedXiFunction = H.productSide := funext H.product_eq
    rw [hfun_eq]
    exact H.product_differentiable_at s hs
  · intro s hs
    have hfun_eq : completedXiFunction = H.productSide := funext H.product_eq
    have h := H.product_logDeriv_eq s hs
    unfold logDerivativeResponse at h ⊢
    rw [hfun_eq]
    exact h

-- =====================================================================
-- §CCCXXI. Finite canonical Hadamard product scaffolds
-- =====================================================================
-- Genus-1 Weierstrass factor `E₁(s/ρ) = (1 - s/ρ) · exp(s/ρ)` and
-- the finite Hadamard product. Uses Mathlib's `logDeriv_prod` for the
-- structural log-derivative-of-product identity. The per-factor
-- log-derivative computation `logDeriv (E₁(·/ρ)) s = 1/(s-ρ) + 1/ρ`
-- is deferred to a future stride.

/-- **Genus-1 Hadamard factor** `E₁(s/ρ) = (1 - s/ρ) · exp(s/ρ)`. -/
noncomputable def hadamardGenus1Factor (ρ s : ℂ) : ℂ :=
  (1 - s / ρ) * Complex.exp (s / ρ)

/-- ⭐ **PROVED — genus-1 factor non-vanishing when `s ≠ ρ` and `ρ ≠ 0`.** -/
lemma hadamardGenus1Factor_ne_zero {ρ s : ℂ} (hρ : ρ ≠ 0) (hsρ : s ≠ ρ) :
    hadamardGenus1Factor ρ s ≠ 0 := by
  unfold hadamardGenus1Factor
  apply mul_ne_zero
  · intro h
    have h1 : s / ρ = 1 := by linear_combination -h
    have h2 : s = ρ := by
      have := h1
      field_simp at this
      exact this
    exact hsρ h2
  · exact Complex.exp_ne_zero _

/-- ⭐ **PROVED — genus-1 factor is differentiable everywhere.** -/
lemma hadamardGenus1Factor_differentiableAt (ρ s : ℂ) :
    DifferentiableAt ℂ (hadamardGenus1Factor ρ) s := by
  unfold hadamardGenus1Factor
  have h_left : DifferentiableAt ℂ (fun y : ℂ => 1 - y / ρ) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner : DifferentiableAt ℂ (fun y : ℂ => y / ρ) s :=
    differentiableAt_id'.div_const _
  have h_right : DifferentiableAt ℂ (fun y : ℂ => Complex.exp (y / ρ)) s :=
    h_inner.cexp
  exact h_left.mul h_right

/-- **Finite Hadamard product** over a finite list of zero ordinates. -/
noncomputable def finiteHadamardProduct (zeros : Finset ℂ) (s : ℂ) : ℂ :=
  ∏ ρ ∈ zeros, hadamardGenus1Factor ρ s

/-- 🌟🌟 **PROVED — `logDeriv` of the finite Hadamard product = Σ of
per-factor `logDeriv`s.** Direct application of Mathlib's
`logDeriv_prod`. -/
theorem logDeriv_finiteHadamardProduct
    {zeros : Finset ℂ} {s : ℂ}
    (hρ_ne : ∀ ρ ∈ zeros, ρ ≠ 0)
    (hs_ne : ∀ ρ ∈ zeros, s ≠ ρ) :
    logDeriv (finiteHadamardProduct zeros) s
      = ∑ ρ ∈ zeros, logDeriv (hadamardGenus1Factor ρ) s := by
  unfold finiteHadamardProduct
  exact logDeriv_prod zeros (fun ρ => hadamardGenus1Factor ρ) s
    (fun ρ hρ => hadamardGenus1Factor_ne_zero (hρ_ne ρ hρ) (hs_ne ρ hρ))
    (fun ρ _ => hadamardGenus1Factor_differentiableAt ρ s)

/-- ⭐ **PROVED — bridge between `logDeriv` (Mathlib) and
`logDerivativeResponse` (this file).** Definitionally equal. -/
theorem logDerivativeResponse_eq_logDeriv (f : ℂ → ℂ) (z : ℂ) :
    logDerivativeResponse f z = logDeriv f z := rfl

/-- 🌟🌟 **PROVED — `logDerivativeResponse` of the finite Hadamard
product = Σ of per-factor responses.** Same as `logDeriv_finiteHadamardProduct`
under the definitional equality. -/
theorem logDerivativeResponse_finiteHadamardProduct
    {zeros : Finset ℂ} {s : ℂ}
    (hρ_ne : ∀ ρ ∈ zeros, ρ ≠ 0)
    (hs_ne : ∀ ρ ∈ zeros, s ≠ ρ) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = ∑ ρ ∈ zeros, logDerivativeResponse (hadamardGenus1Factor ρ) s := by
  simp only [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct hρ_ne hs_ne

-- =====================================================================
-- §CCCXXII. Per-factor log-derivative of the genus-1 Hadamard factor
-- =====================================================================
-- Closes the explicit value of `logDeriv (hadamardGenus1Factor ρ) s`
-- as the classical `1/(s-ρ) + 1/ρ`. Combined with §CCCXXI's finite
-- product log-derivative, this gives the regularized zero-sum form of
-- the finite Hadamard product log-derivative.

/-- 🌟🌟🌟 **PROVED — per-factor log-derivative of the genus-1
Hadamard factor.** `logDeriv ((1 - ·/ρ) · exp(·/ρ)) s = 1/(s-ρ) + 1/ρ`. -/
theorem logDeriv_hadamardGenus1Factor {ρ s : ℂ} (hρ : ρ ≠ 0) (hs : s ≠ ρ) :
    logDeriv (hadamardGenus1Factor ρ) s = 1 / (s - ρ) + 1 / ρ := by
  have h_left_diff : DifferentiableAt ℂ (fun y : ℂ => 1 - y/ρ) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner_diff : DifferentiableAt ℂ (fun y : ℂ => y/ρ) s :=
    differentiableAt_id'.div_const _
  have h_right_diff : DifferentiableAt ℂ (fun y : ℂ => Complex.exp (y/ρ)) s :=
    h_inner_diff.cexp
  have hsmρ : s - ρ ≠ 0 := sub_ne_zero.mpr hs
  have h_left_ne : (1 : ℂ) - s/ρ ≠ 0 := by
    intro h
    have h1 : s/ρ = 1 := by linear_combination -h
    apply hs
    field_simp at h1
    exact h1
  have h_exp_ne : Complex.exp (s/ρ) ≠ 0 := Complex.exp_ne_zero _
  have h_deriv_inner : deriv (fun y : ℂ => y/ρ) s = 1/ρ := by
    rw [deriv_div_const, deriv_id'']
  have h_deriv_left : deriv (fun y : ℂ => 1 - y/ρ) s = -(1/ρ) := by
    rw [deriv_sub (differentiableAt_const _) (differentiableAt_id'.div_const _),
        deriv_const, h_deriv_inner]
    ring
  have h_deriv_right : deriv (fun y : ℂ => Complex.exp (y/ρ)) s
      = Complex.exp (s/ρ) * (1/ρ) := by
    rw [deriv_cexp h_inner_diff, h_deriv_inner]
  have hρs : ρ - s ≠ 0 := sub_ne_zero.mpr (Ne.symm hs)
  rw [logDeriv_apply]
  unfold hadamardGenus1Factor
  rw [deriv_mul h_left_diff h_right_diff, h_deriv_left, h_deriv_right]
  -- Factor `Complex.exp (s/ρ)` out of numerator and cancel with denominator
  rw [show -(1 / ρ) * Complex.exp (s / ρ)
            + (1 - s / ρ) * (Complex.exp (s / ρ) * (1 / ρ))
          = Complex.exp (s / ρ) * (-(1 / ρ) + (1 - s / ρ) * (1 / ρ)) from by ring,
      show (1 - s / ρ) * Complex.exp (s / ρ)
          = Complex.exp (s / ρ) * (1 - s / ρ) from by ring,
      mul_div_mul_left _ _ h_exp_ne]
  -- Now: (-(1/ρ) + (1 - s/ρ) * (1/ρ)) / (1 - s/ρ) = 1/(s-ρ) + 1/ρ
  -- Simplify numerator to -s/ρ²
  rw [show -(1 / ρ) + (1 - s / ρ) * (1 / ρ) = -s / ρ ^ 2 from by
        field_simp; ring]
  -- Now: (-s/ρ²) / (1 - s/ρ) = 1/(s-ρ) + 1/ρ
  rw [show (1 : ℂ) - s / ρ = (ρ - s) / ρ from by field_simp]
  -- Now: (-s/ρ²) / ((ρ - s)/ρ) = 1/(s-ρ) + 1/ρ
  field_simp
  ring

/-- 🌟🌟🌟 **PROVED — per-factor `logDerivativeResponse` of the genus-1
Hadamard factor.** Same identity under the definitional bridge. -/
theorem logDerivativeResponse_hadamardGenus1Factor
    {ρ s : ℂ} (hρ : ρ ≠ 0) (hs : s ≠ ρ) :
    logDerivativeResponse (hadamardGenus1Factor ρ) s = 1 / (s - ρ) + 1 / ρ := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_hadamardGenus1Factor hρ hs

/-- 🌟🌟🌟 **PROVED — regularized form of the finite Hadamard product
log-derivative.** `logDeriv (finiteHadamardProduct zeros) s =
Σ_{ρ ∈ zeros} (1/(s-ρ) + 1/ρ)`. The classical paired/regularized zero
sum. -/
theorem logDeriv_finiteHadamardProduct_regularized
    {zeros : Finset ℂ} {s : ℂ}
    (hρ_ne : ∀ ρ ∈ zeros, ρ ≠ 0)
    (hs_ne : ∀ ρ ∈ zeros, s ≠ ρ) :
    logDeriv (finiteHadamardProduct zeros) s
      = ∑ ρ ∈ zeros, (1 / (s - ρ) + 1 / ρ) := by
  rw [logDeriv_finiteHadamardProduct hρ_ne hs_ne]
  apply Finset.sum_congr rfl
  intro ρ hρmem
  exact logDeriv_hadamardGenus1Factor (hρ_ne ρ hρmem) (hs_ne ρ hρmem)

/-- 🌟🌟🌟 **PROVED — regularized form of the finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_finiteHadamardProduct_regularized
    {zeros : Finset ℂ} {s : ℂ}
    (hρ_ne : ∀ ρ ∈ zeros, ρ ≠ 0)
    (hs_ne : ∀ ρ ∈ zeros, s ≠ ρ) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = ∑ ρ ∈ zeros, (1 / (s - ρ) + 1 / ρ) := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct_regularized hρ_ne hs_ne

-- =====================================================================
-- §CCCXXIII. Mathlib infinite-product / series API audit
-- =====================================================================
-- Located in `Mathlib/Topology/Algebra/InfiniteSum/Defs.lean`:
--   * `HasProd f a := Tendsto (∏ b ∈ s, f b) atTop (𝓝 a)` (Finset net).
--   * `Multipliable f := ∃ a, HasProd f a`.
--   * `tprod f`, notation `∏' i, f i` (irreducible_def, falls back to 1).
--   * Additive analogues via `@[to_additive]`: `HasSum`, `Summable`, `tsum`,
--     `∑' i, f i`.
--
-- For locally uniform convergence (needed for product = entire function):
--   `Mathlib/Topology/Algebra/InfiniteSum/UniformOn.lean`:
--     * `HasProdLocallyUniformlyOn`, `MultipliableLocallyUniformlyOn`.
--   `Mathlib/Analysis/NormedSpace/MultipliableUniformlyOn.lean`:
--     * normed-space adapted lemmas.
--
-- These are the right APIs for the infinite Hadamard product. Use
-- `HasProd` / `tprod` for the product value; `HasSum` / `tsum` for the
-- regularized log-derivative series.

-- =====================================================================
-- §CCCXXIV. Infinite Hadamard product + regularized log-deriv series
-- =====================================================================
-- Lifts the finite Hadamard products to the indexed/infinite setting.
-- Introduces the named target series so the analytic agent can prove
-- the convergence/equality statements directly.

/-- **Indexed infinite Hadamard product** over an arbitrary index set
of zero ordinates. Falls back to `1` when not multipliable (Mathlib's
`tprod` convention). -/
noncomputable def infiniteHadamardProduct
    {ι : Type*} (zeroLoc : ι → ℂ) (s : ℂ) : ℂ :=
  ∏' i : ι, hadamardGenus1Factor (zeroLoc i) s

/-- **Indexed regularized log-derivative series**: the term-wise sum
`Σ (1/(s-ρᵢ) + 1/ρᵢ)` that the infinite Hadamard log-derivative should
converge to. Falls back to `0` when not summable. -/
noncomputable def hadamardRegularizedLogDerivSeries
    {ι : Type*} (zeroLoc : ι → ℂ) (s : ℂ) : ℂ :=
  ∑' i : ι, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Finite regularized log-derivative sum** over a Finset. -/
noncomputable def finiteHadamardRegularizedSum
    {ι : Type*} (zeroLoc : ι → ℂ) (F : Finset ι) (s : ℂ) : ℂ :=
  ∑ i ∈ F, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Indexed finite Hadamard product**: the partial product over a
Finset, used for finite truncations of `infiniteHadamardProduct`. -/
noncomputable def indexedFiniteHadamardProduct
    {ι : Type*} (zeroLoc : ι → ℂ) (F : Finset ι) (s : ℂ) : ℂ :=
  ∏ i ∈ F, hadamardGenus1Factor (zeroLoc i) s

/-- 🌟🌟🌟 **PROVED — indexed finite Hadamard product log-derivative.**
The log-derivative of the indexed finite product equals the
indexed regularized sum. -/
theorem logDeriv_indexedFiniteHadamardProduct
    {ι : Type*} {zeroLoc : ι → ℂ} {F : Finset ι} {s : ℂ}
    (hρ : ∀ i ∈ F, zeroLoc i ≠ 0)
    (hs : ∀ i ∈ F, s ≠ zeroLoc i) :
    logDeriv (fun s' : ℂ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  unfold indexedFiniteHadamardProduct finiteHadamardRegularizedSum
  rw [logDeriv_prod F (fun i s' => hadamardGenus1Factor (zeroLoc i) s') s
        (fun i hi => hadamardGenus1Factor_ne_zero (hρ i hi) (hs i hi))
        (fun i _ => hadamardGenus1Factor_differentiableAt (zeroLoc i) s)]
  apply Finset.sum_congr rfl
  intro i hi
  exact logDeriv_hadamardGenus1Factor (hρ i hi) (hs i hi)

/-- 🌟🌟🌟 **PROVED — indexed finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct
    {ι : Type*} {zeroLoc : ι → ℂ} {F : Finset ι} {s : ℂ}
    (hρ : ∀ i ∈ F, zeroLoc i ≠ 0)
    (hs : ∀ i ∈ F, s ≠ zeroLoc i) :
    logDerivativeResponse
        (fun s' : ℂ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_indexedFiniteHadamardProduct hρ hs

-- =====================================================================
-- §CCCXXV. Locally-uniform Hadamard product analytic data
-- =====================================================================
-- The data structure that says: "this genus-1 infinite product is
-- analytically legitimate on the points where ξ is non-zero, and its
-- log-derivative equals the regularized zero-sum series."
--
-- The Mathlib `MultipliableLocallyUniformlyOn` Prop is the natural
-- analytic-agent target for inhabiting `product_differentiable_at_xi_nonzero`
-- and `logDeriv_eq_tsum_at_xi_nonzero`; we expose those AFZ-projected
-- consequences directly rather than threading the universe-quantified
-- LUC predicate through the bundle.

/-- 📦 **`HadamardLocallyUniformProductData`** — the analytic
legitimacy package for the infinite genus-1 Hadamard product. -/
structure HadamardLocallyUniformProductData
    {ι : Type*} (zeroLoc : ι → ℂ) : Type where
  product_multipliable :
    ∀ s : ℂ,
      Multipliable fun i : ι => hadamardGenus1Factor (zeroLoc i) s
  product_differentiable_at_xi_nonzero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at_xi_nonzero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      Summable fun i : ι => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at_xi_nonzero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- §CCCXXVI. Hadamard product with zeros + bridge to ξ-side AFZ source
-- =====================================================================

/-- 📦 **`CompletedXiHadamardProductWithZeros`** — the classical
Hadamard product representation of `completedXiFunction` with a
possible analytic prefactor. Parameterized by the zero index type `ι`. -/
structure CompletedXiHadamardProductWithZeros (ι : Type) : Type where
  zeroLoc : ι → ℂ
  prefactor : ℂ → ℂ
  prefactor_differentiable_at :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ prefactor s
  prefactor_ne_zero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      prefactor s ≠ 0
  xi_eq_product :
    ∀ s : ℂ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s
  product_data : HadamardLocallyUniformProductData zeroLoc

/-- **Zero contribution from a Hadamard-with-zeros bundle**:
`logDeriv prefactor + tsum regularized`. -/
noncomputable def xiZeroContributionFromHadamard
    {ι : Type} (H : CompletedXiHadamardProductWithZeros ι) : ℂ → ℂ :=
  fun s =>
    logDerivativeResponse H.prefactor s
      + hadamardRegularizedLogDerivSeries H.zeroLoc s

/-- 🌟🌟🌟 **PROVED — `CompletedXiLogDerivativeSourceAFZ` from
Hadamard-with-zeros bundle.** Uses `logDeriv_mul` (Mathlib) to split
the log-derivative of `prefactor · product`, then identifies the
product's log-derivative with the regularized series via
`product_data.logDeriv_eq_tsum_at_xi_nonzero`. -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    {ι : Type} (H : CompletedXiHadamardProductWithZeros ι) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := xiZeroContributionFromHadamard H
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  · intro s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    rw [hxi_eq_fun]
    exact (H.prefactor_differentiable_at s hs).mul
      (H.product_data.product_differentiable_at_xi_nonzero s hs)
  · intro s hs
    have h_pref_ne : H.prefactor s ≠ 0 := H.prefactor_ne_zero s hs
    have h_prod_ne : infiniteHadamardProduct H.zeroLoc s ≠ 0 := by
      intro h
      apply hs
      rw [H.xi_eq_product s, h, mul_zero]
    have h_pref_diff := H.prefactor_differentiable_at s hs
    have h_prod_diff := H.product_data.product_differentiable_at_xi_nonzero s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    calc logDerivativeResponse completedXiFunction s
        = logDeriv completedXiFunction s := rfl
      _ = logDeriv (H.prefactor * infiniteHadamardProduct H.zeroLoc) s := by
          rw [hxi_eq_fun]
      _ = logDeriv H.prefactor s
            + logDeriv (infiniteHadamardProduct H.zeroLoc) s :=
          logDeriv_mul s h_pref_ne h_prod_ne h_pref_diff h_prod_diff
      _ = logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroLoc s := by
          rw [← logDerivativeResponse_eq_logDeriv (f := H.prefactor),
              ← logDerivativeResponse_eq_logDeriv
                  (f := infiniteHadamardProduct H.zeroLoc),
              H.product_data.logDeriv_eq_tsum_at_xi_nonzero s hs]
      _ = xiZeroContributionFromHadamard H s := rfl

-- =====================================================================
-- §CCCXXVII. Log-derivative limit data (separate from convergence)
-- =====================================================================
-- The product-convergence content (`Multipliable`) is independent of
-- the log-derivative content (differentiability + summability + log-deriv
-- equal to tsum). Isolate the latter into its own data bundle, keyed by
-- an arbitrary `region : Set ℂ`. The bridge to
-- `HadamardLocallyUniformProductData` then takes a region-coverage
-- hypothesis (AFZ ⊆ region).

/-- 📦 **`HadamardLogDerivLimitData`** — the log-derivative-of-limit
content, packaged on an arbitrary `region : Set ℂ`. The genuine
analytic theorem (log-deriv interchanges with locally uniform
convergence) inhabits this bundle on the AFZ region of `ξ`. -/
structure HadamardLogDerivLimitData
    {ι : Type*} (zeroLoc : ι → ℂ) : Type where
  region : Set ℂ
  product_differentiable_at :
    ∀ s ∈ region,
      DifferentiableAt ℂ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at :
    ∀ s ∈ region,
      Summable fun i : ι => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at :
    ∀ s ∈ region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

/-- 🌟🌟🌟 **PROVED — `HadamardLocallyUniformProductData` from
log-derivative limit data + region coverage.** -/
noncomputable def HadamardLocallyUniformProductData.of_logDerivLimitData
    {ι : Type*} {zeroLoc : ι → ℂ}
    (Hprod :
      ∀ s : ℂ,
        Multipliable fun i : ι => hadamardGenus1Factor (zeroLoc i) s)
    (Hlim : HadamardLogDerivLimitData zeroLoc)
    (h_region :
      ∀ s : ℂ, completedXiFunction s ≠ 0 → s ∈ Hlim.region) :
    HadamardLocallyUniformProductData zeroLoc :=
  { product_multipliable := Hprod
    product_differentiable_at_xi_nonzero := fun s hs =>
      Hlim.product_differentiable_at s (h_region s hs)
    regularized_summable_at_xi_nonzero := fun s hs =>
      Hlim.regularized_summable_at s (h_region s hs)
    logDeriv_eq_tsum_at_xi_nonzero := fun s hs =>
      Hlim.logDeriv_eq_tsum_at s (h_region s hs) }

-- =====================================================================
-- §CCCXXVIII. Finite exhaustion interface
-- =====================================================================
-- The natural finite-to-infinite convergence interface: a sequence of
-- Finsets that exhausts the index type, with the partial products
-- converging to the infinite product and the partial regularized sums
-- converging to the regularized series.

/-- 📦 **`HadamardFiniteExhaustion`** — finite-truncation convergence
interface for the genus-1 Hadamard product. -/
structure HadamardFiniteExhaustion
    {ι : Type*} (zeroLoc : ι → ℂ) where
  exhaust : ℕ → Finset ι
  exhaust_mono :
    ∀ {n m : ℕ}, n ≤ m → exhaust n ⊆ exhaust m
  product_tendsto :
    ∀ s : ℂ,
      Tendsto
        (fun n => indexedFiniteHadamardProduct zeroLoc (exhaust n) s)
        Filter.atTop
        (𝓝 (infiniteHadamardProduct zeroLoc s))
  regularized_sum_tendsto :
    ∀ s : ℂ,
      Tendsto
        (fun n => finiteHadamardRegularizedSum zeroLoc (exhaust n) s)
        Filter.atTop
        (𝓝 (hadamardRegularizedLogDerivSeries zeroLoc s))

/-- ⭐ **PROVED — finite-truncation log-derivative identity at every
exhaustion stage.** Direct specialization of §CCCXXIV's
`logDerivativeResponse_indexedFiniteHadamardProduct`. -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct_at_exhaustion
    {ι : Type*} {zeroLoc : ι → ℂ}
    (Hex : HadamardFiniteExhaustion zeroLoc)
    {s : ℂ} {n : ℕ}
    (hρ : ∀ i ∈ Hex.exhaust n, zeroLoc i ≠ 0)
    (hs : ∀ i ∈ Hex.exhaust n, s ≠ zeroLoc i) :
    logDerivativeResponse
        (fun s' : ℂ => indexedFiniteHadamardProduct zeroLoc (Hex.exhaust n) s') s
      = finiteHadamardRegularizedSum zeroLoc (Hex.exhaust n) s :=
  logDerivativeResponse_indexedFiniteHadamardProduct hρ hs

-- =====================================================================
-- §CCCXXIX. Regularized Hadamard term — algebraic identity + norm
-- =====================================================================

/-- ⭐ **PROVED — paired/regularized identity.** The combined term
collapses to `s / ((s - ρ) · ρ)`. -/
lemma hadamard_regularized_term_eq {s ρ : ℂ} (hρ : ρ ≠ 0) (hsρ : s ≠ ρ) :
    1 / (s - ρ) + 1 / ρ = s / ((s - ρ) * ρ) := by
  have hsρ' : s - ρ ≠ 0 := sub_ne_zero.mpr hsρ
  field_simp

/-- ⭐ **PROVED — norm form of the regularized identity.** -/
lemma norm_hadamard_regularized_term_eq
    {s ρ : ℂ} (hρ : ρ ≠ 0) (hsρ : s ≠ ρ) :
    ‖1 / (s - ρ) + 1 / ρ‖ = ‖s‖ / (‖s - ρ‖ * ‖ρ‖) := by
  rw [hadamard_regularized_term_eq hρ hsρ, norm_div, norm_mul]

-- =====================================================================
-- §CCCXXX. Large-zero bound for the regularized term
-- =====================================================================

/-- ⭐ **PROVED — reverse-triangle large-zero bound.** When
`2 ‖s‖ ≤ ‖ρ‖`, we have `‖s − ρ‖ ≥ ‖ρ‖/2`. -/
lemma norm_sub_ge_half_of_two_norm_le {s ρ : ℂ}
    (hlarge : 2 * ‖s‖ ≤ ‖ρ‖) :
    ‖ρ‖ / 2 ≤ ‖s - ρ‖ := by
  have htriangle : ‖ρ‖ ≤ ‖s‖ + ‖s - ρ‖ := by
    have h_sub := norm_sub_le s (s - ρ)
    have h_eq : s - (s - ρ) = ρ := by ring
    rw [h_eq] at h_sub
    exact h_sub
  linarith

/-- 🌟🌟🌟 **PROVED — large-zero bound on the regularized Hadamard
term.** `‖1/(s−ρ) + 1/ρ‖ ≤ 2 ‖s‖ / ‖ρ‖²` for `‖ρ‖ ≥ 2 ‖s‖`. -/
lemma norm_hadamard_regularized_term_le_large {s ρ : ℂ}
    (hρ : ρ ≠ 0) (hsρ : s ≠ ρ) (hlarge : 2 * ‖s‖ ≤ ‖ρ‖) :
    ‖1 / (s - ρ) + 1 / ρ‖ ≤ 2 * ‖s‖ / ‖ρ‖ ^ 2 := by
  rw [norm_hadamard_regularized_term_eq hρ hsρ]
  have hρ_pos : 0 < ‖ρ‖ := norm_pos_iff.mpr hρ
  have h_sρ_pos : 0 < ‖s - ρ‖ := norm_pos_iff.mpr (sub_ne_zero.mpr hsρ)
  have h_denom_pos : 0 < ‖s - ρ‖ * ‖ρ‖ := mul_pos h_sρ_pos hρ_pos
  have h_ρ_sq_pos : 0 < ‖ρ‖ ^ 2 := by positivity
  have h_sρ_ge : ‖ρ‖ / 2 ≤ ‖s - ρ‖ := norm_sub_ge_half_of_two_norm_le hlarge
  have h_s_nn : 0 ≤ ‖s‖ := norm_nonneg _
  rw [div_le_div_iff₀ h_denom_pos h_ρ_sq_pos]
  have h_ρ_le : ‖ρ‖ ≤ 2 * ‖s - ρ‖ := by linarith
  have h_mul : ‖ρ‖ * ‖ρ‖ ≤ 2 * ‖s - ρ‖ * ‖ρ‖ :=
    mul_le_mul_of_nonneg_right h_ρ_le hρ_pos.le
  have h_ρ_sq : ‖ρ‖ ^ 2 = ‖ρ‖ * ‖ρ‖ := by ring
  nlinarith [h_mul, h_s_nn, h_ρ_sq]

-- =====================================================================
-- §CCCXXXI. Summability of regularized terms via inv-sq summability
-- =====================================================================

/-- 📦 **`HadamardZeroInvSqSummability`** — the classical analytic
hypothesis on a zero set: `Σ 1/‖ρ‖² < ∞` (genus ≤ 1) and for every
`s`, eventually `‖ρ‖ ≥ 2‖s‖`. -/
structure HadamardZeroInvSqSummability
    {ι : Type*} (zeroLoc : ι → ℂ) : Prop where
  zero_ne : ∀ i, zeroLoc i ≠ 0
  inv_sq_summable :
    Summable fun i : ι => (‖zeroLoc i‖ ^ 2)⁻¹
  eventually_large :
    ∀ s : ℂ, ∀ᶠ i in Filter.cofinite, 2 * ‖s‖ ≤ ‖zeroLoc i‖

/-- 🌟🌟🌟 **PROVED — regularized series is summable from inv-sq
summability + eventually-large.** -/
theorem summable_hadamard_regularized_terms_of_inv_sq
    {ι : Type*} {zeroLoc : ι → ℂ} {s : ℂ}
    (hzero_ne : ∀ i, zeroLoc i ≠ 0)
    (hs_ne : ∀ i, s ≠ zeroLoc i)
    (hinv_sq : Summable fun i : ι => (‖zeroLoc i‖ ^ 2)⁻¹)
    (heventual_large :
      ∀ᶠ i in Filter.cofinite, 2 * ‖s‖ ≤ ‖zeroLoc i‖) :
    Summable fun i : ι => 1 / (s - zeroLoc i) + 1 / zeroLoc i := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 2 * ‖s‖ * (‖zeroLoc i‖ ^ 2)⁻¹)
  · exact hinv_sq.mul_left (2 * ‖s‖)
  · filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_hadamard_regularized_term_le_large (hzero_ne i) (hs_ne i) hi
    have h_eq :
        (2 : ℝ) * ‖s‖ / ‖zeroLoc i‖ ^ 2
          = 2 * ‖s‖ * (‖zeroLoc i‖ ^ 2)⁻¹ := by
      rw [div_eq_mul_inv]
    linarith [h_eq ▸ h_bound]

/-- ⭐ **PROVED — regularized summability from the data bundle
`HadamardZeroInvSqSummability`.** -/
theorem HadamardZeroInvSqSummability.summable_regularized
    {ι : Type*} {zeroLoc : ι → ℂ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    {s : ℂ} (hs_ne : ∀ i, s ≠ zeroLoc i) :
    Summable fun i : ι => 1 / (s - zeroLoc i) + 1 / zeroLoc i :=
  summable_hadamard_regularized_terms_of_inv_sq
    H.zero_ne hs_ne H.inv_sq_summable (H.eventually_large s)

-- =====================================================================
-- §CCCXXXII. Genus-one Taylor bound (data + specialization)
-- =====================================================================

/-- 📦 **`GenusOneTaylorBoundData`** — quantitative form of
`1 - (1-w)·exp(w) = O(w²)`. Standard genus-one decay; `C = 4` is
unsharp but suffices for convergence. -/
structure GenusOneTaylorBoundData : Prop where
  bound :
    ∀ w : ℂ, ‖w‖ ≤ 1 →
      ‖1 - (1 - w) * Complex.exp w‖ ≤ 4 * ‖w‖ ^ 2

/-- 🌟🌟🌟 **PROVED — specialization to `hadamardGenus1Factor` with
`‖s‖ ≤ ‖ρ‖`.** -/
lemma norm_one_sub_hadamardGenus1Factor_le_large
    {ρ s : ℂ} (hρ : ρ ≠ 0) (hlarge : ‖s‖ ≤ ‖ρ‖)
    (Hbound : GenusOneTaylorBoundData) :
    ‖1 - hadamardGenus1Factor ρ s‖ ≤ 4 * (‖s‖ ^ 2 / ‖ρ‖ ^ 2) := by
  unfold hadamardGenus1Factor
  have hρ_pos : 0 < ‖ρ‖ := norm_pos_iff.mpr hρ
  have hw : ‖s / ρ‖ ≤ 1 := by
    rw [norm_div]
    exact div_le_one_of_le₀ hlarge (norm_nonneg _)
  have h := Hbound.bound (s / ρ) hw
  rw [norm_div, div_pow] at h
  exact h

-- =====================================================================
-- §CCCXXXIII. Product convergence from inverse-square zero summability
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — norm-summability of `1 - E₁(s/ρᵢ)`.** -/
theorem summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
    {ι : Type*} {zeroLoc : ι → ℂ} {s : ℂ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ∀ i, zeroLoc i ≠ 0)
    (hinv_sq : Summable fun i : ι => (‖zeroLoc i‖ ^ 2)⁻¹)
    (heventual_large :
      ∀ᶠ i in Filter.cofinite, ‖s‖ ≤ ‖zeroLoc i‖) :
    Summable fun i : ι => ‖1 - hadamardGenus1Factor (zeroLoc i) s‖ := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 4 * ‖s‖ ^ 2 * (‖zeroLoc i‖ ^ 2)⁻¹)
  · exact hinv_sq.mul_left (4 * ‖s‖ ^ 2)
  · filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_one_sub_hadamardGenus1Factor_le_large (hzero_ne i) hi Hbound
    have h_eq : (4 : ℝ) * ‖s‖ ^ 2 * (‖zeroLoc i‖ ^ 2)⁻¹
              = 4 * (‖s‖ ^ 2 / ‖zeroLoc i‖ ^ 2) := by
      rw [div_eq_mul_inv]; ring
    rw [Real.norm_of_nonneg (norm_nonneg _)]
    linarith [h_eq ▸ h_bound]

/-- 🌟🌟🌟 **PROVED — ℂ-valued `Summable (1 - E₁(s/ρᵢ))` from norm.** -/
theorem summable_one_sub_hadamardGenus1Factor_of_inv_sq
    {ι : Type*} {zeroLoc : ι → ℂ} {s : ℂ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ∀ i, zeroLoc i ≠ 0)
    (hinv_sq : Summable fun i : ι => (‖zeroLoc i‖ ^ 2)⁻¹)
    (heventual_large :
      ∀ᶠ i in Filter.cofinite, ‖s‖ ≤ ‖zeroLoc i‖) :
    Summable fun i : ι => 1 - hadamardGenus1Factor (zeroLoc i) s :=
  Summable.of_norm
    (summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large)

/-- 🌟🌟🌟 **PROVED — `Multipliable (hadamardGenus1Factor ∘ zeroLoc)`
from inverse-square zero summability + Taylor bound.** Uses Mathlib's
`Complex.multipliable_one_add_of_summable`. -/
theorem multipliable_hadamardGenus1Factor_of_inv_sq
    {ι : Type*} {zeroLoc : ι → ℂ} {s : ℂ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : ∀ i, zeroLoc i ≠ 0)
    (hinv_sq : Summable fun i : ι => (‖zeroLoc i‖ ^ 2)⁻¹)
    (heventual_large :
      ∀ᶠ i in Filter.cofinite, ‖s‖ ≤ ‖zeroLoc i‖) :
    Multipliable fun i : ι => hadamardGenus1Factor (zeroLoc i) s := by
  have h_sum :=
    summable_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large
  have h_sum_neg :
      Summable fun i : ι => hadamardGenus1Factor (zeroLoc i) s - 1 := by
    have := h_sum.neg
    simpa [neg_sub] using this
  have h_mul := Complex.multipliable_one_add_of_summable h_sum_neg
  simpa using h_mul

/-- ⭐ **PROVED — `Multipliable` from the `HadamardZeroInvSqSummability`
bundle + Taylor bound.** -/
theorem HadamardZeroInvSqSummability.multipliable_genus1
    {ι : Type*} {zeroLoc : ι → ℂ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    (Hbound : GenusOneTaylorBoundData) (s : ℂ) :
    Multipliable fun i : ι => hadamardGenus1Factor (zeroLoc i) s := by
  apply multipliable_hadamardGenus1Factor_of_inv_sq
    Hbound H.zero_ne H.inv_sq_summable
  filter_upwards [H.eventually_large s] with i hi
  have h_s_nn : 0 ≤ ‖s‖ := norm_nonneg s
  linarith

-- =====================================================================
-- §CCCXXXIV. Prove `GenusOneTaylorBoundData`
-- =====================================================================
-- Inhabits the genus-one Taylor bound via Mathlib's
-- `Complex.norm_exp_sub_one_le` and `Complex.norm_exp_sub_one_sub_id_le`.
-- Decomposition:
--   `1 - (1-w)·exp(w) = -(exp(w) - 1 - w) + w·(exp(w) - 1)`
-- Triangle inequality + the two Mathlib bounds give `‖·‖ ≤ 3·‖w‖²`,
-- which dominates `4·‖w‖²` for free.

/-- 🌟🌟🌟🌟 **PROVED — `GenusOneTaylorBoundData` inhabited.** -/
theorem genusOneTaylorBoundData : GenusOneTaylorBoundData := by
  refine ⟨?_⟩
  intro w hw
  have h_decomp :
      (1 : ℂ) - (1 - w) * Complex.exp w
        = -(Complex.exp w - 1 - w) + w * (Complex.exp w - 1) := by
    ring
  rw [h_decomp]
  have h_exp_sub_1_sub_id := Complex.norm_exp_sub_one_sub_id_le hw
  have h_exp_sub_1 := Complex.norm_exp_sub_one_le hw
  have h_w_nn : 0 ≤ ‖w‖ := norm_nonneg _
  calc ‖-(Complex.exp w - 1 - w) + w * (Complex.exp w - 1)‖
      ≤ ‖-(Complex.exp w - 1 - w)‖ + ‖w * (Complex.exp w - 1)‖ :=
        norm_add_le _ _
    _ = ‖Complex.exp w - 1 - w‖ + ‖w‖ * ‖Complex.exp w - 1‖ := by
        rw [norm_neg, norm_mul]
    _ ≤ ‖w‖ ^ 2 + ‖w‖ * (2 * ‖w‖) := by
        gcongr
    _ = 3 * ‖w‖ ^ 2 := by ring
    _ ≤ 4 * ‖w‖ ^ 2 := by nlinarith [sq_nonneg ‖w‖]

-- =====================================================================
-- §CCCXXXV. Hypothesis-free product-convergence convenience
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — `Multipliable (hadamardGenus1Factor ∘ zeroLoc)`
from `HadamardZeroInvSqSummability` alone** (no Taylor hypothesis). -/
theorem HadamardZeroInvSqSummability.product_multipliable
    {ι : Type*} {zeroLoc : ι → ℂ}
    (H : HadamardZeroInvSqSummability zeroLoc) :
    ∀ s : ℂ,
      Multipliable fun i : ι => hadamardGenus1Factor (zeroLoc i) s :=
  fun s => H.multipliable_genus1 genusOneTaylorBoundData s

-- =====================================================================
-- §CCCXXXVI. LUC log-derivative interchange scaffold
-- =====================================================================
-- The genuine analytic content of "log-derivative interchanges with
-- locally uniform convergence." Packaged as data on a region.

/-- 📦 **`HadamardProductLUCLogDerivData`** — the LUC + log-derivative
interchange data on `region : Set ℂ`. -/
structure HadamardProductLUCLogDerivData
    {ι : Type*} (zeroLoc : ι → ℂ) where
  region : Set ℂ
  locally_uniform_product :
    TendstoLocallyUniformlyOn
      (fun F : Finset ι => fun s : ℂ =>
        indexedFiniteHadamardProduct zeroLoc F s)
      (infiniteHadamardProduct zeroLoc)
      Filter.atTop
      region
  infinite_differentiable_at :
    ∀ s ∈ region,
      DifferentiableAt ℂ (infiniteHadamardProduct zeroLoc) s
  logDeriv_eq_tsum :
    ∀ s ∈ region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- §CCCXXXVII. Bridge LUC + invSq → HadamardLogDerivLimitData
-- =====================================================================

/-- 🌟🌟🌟 **PROVED — `HadamardLogDerivLimitData` from LUC + inv-sq +
no-collision in region.** -/
noncomputable def HadamardLogDerivLimitData.of_productLUC_and_invSq
    {ι : Type*} {zeroLoc : ι → ℂ}
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (HnonzeroRegion : ∀ s ∈ Hluc.region, ∀ i, s ≠ zeroLoc i) :
    HadamardLogDerivLimitData zeroLoc :=
  { region := Hluc.region
    product_differentiable_at := Hluc.infinite_differentiable_at
    regularized_summable_at := fun s hs =>
      Hinv.summable_regularized (HnonzeroRegion s hs)
    logDeriv_eq_tsum_at := Hluc.logDeriv_eq_tsum }

-- =====================================================================
-- §CCCXXXVIII. Final Hadamard assembly theorem
-- =====================================================================

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟
**PROVED — final Hadamard assembly.**

```
HadamardZeroInvSqSummability (Σ 1/‖ρ‖² + escape)
+ HadamardProductLUCLogDerivData (LUC log-deriv interchange)
+ ξ Hadamard factorization (prefactor · ∏ E₁)
+ prefactor AFZ (differentiable + non-vanishing)
⟹ CompletedXiHadamardProductWithZeros ι
``` -/
noncomputable def CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    {ι : Type} {zeroLoc : ι → ℂ}
    {prefactor : ℂ → ℂ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : ∀ s : ℂ, completedXiFunction s ≠ 0 → s ∈ Hluc.region)
    (HnonzeroRegion : ∀ s ∈ Hluc.region, ∀ i, s ≠ zeroLoc i)
    (Hfact :
      ∀ s : ℂ,
        completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s)
    (Hpref_diff :
      ∀ s : ℂ,
        completedXiFunction s ≠ 0 → DifferentiableAt ℂ prefactor s)
    (Hpref_ne :
      ∀ s : ℂ,
        completedXiFunction s ≠ 0 → prefactor s ≠ 0) :
    CompletedXiHadamardProductWithZeros ι := by
  refine
    { zeroLoc := zeroLoc
      prefactor := prefactor
      prefactor_differentiable_at := Hpref_diff
      prefactor_ne_zero := Hpref_ne
      xi_eq_product := Hfact
      product_data := ?_ }
  exact
    HadamardLocallyUniformProductData.of_logDerivLimitData
      Hinv.product_multipliable
      (HadamardLogDerivLimitData.of_productLUC_and_invSq
        Hluc Hinv HnonzeroRegion)
      Hregion

-- =====================================================================
-- §CCCXXXIX. ClassicalPathBAnalyticInputs bundle
-- =====================================================================
-- Bundles the five remaining classical analytic inputs for the
-- Hadamard side of Path B into a single Type. The Hadamard agent
-- supplies one inhabitant of this bundle; everything else is closed.

/-- 📦 **`ClassicalPathBAnalyticInputs`** — the Hadamard-side
classical-input bundle. The remaining xi-side analytic inputs for
Path B (aside from the Stieltjes equality) live in this single
object. -/
structure ClassicalPathBAnalyticInputs (ι : Type) where
  zeroLoc : ι → ℂ
  prefactor : ℂ → ℂ
  Hinv : HadamardZeroInvSqSummability zeroLoc
  Hluc : HadamardProductLUCLogDerivData zeroLoc
  Hregion :
    ∀ s : ℂ, completedXiFunction s ≠ 0 → s ∈ Hluc.region
  HnonzeroRegion :
    ∀ s ∈ Hluc.region, ∀ i, s ≠ zeroLoc i
  Hfact :
    ∀ s : ℂ,
      completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s
  Hpref_diff :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 → DifferentiableAt ℂ prefactor s
  Hpref_ne :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 → prefactor s ≠ 0

-- =====================================================================
-- §CCCXL. Bridge bundled inputs → Hadamard source AFZ
-- =====================================================================

/-- 🌟🌟 **PROVED — `CompletedXiHadamardProductWithZeros` from
the bundled classical inputs.** -/
noncomputable def ClassicalPathBAnalyticInputs.toHadamardProductWithZeros
    {ι : Type} (H : ClassicalPathBAnalyticInputs ι) :
    CompletedXiHadamardProductWithZeros ι :=
  CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    H.Hinv H.Hluc H.Hregion H.HnonzeroRegion
    H.Hfact H.Hpref_diff H.Hpref_ne

/-- 🌟🌟 **PROVED — `CompletedXiLogDerivativeSourceAFZ` from
the bundled classical inputs.** -/
noncomputable def ClassicalPathBAnalyticInputs.toCompletedXiSourceAFZ
    {ι : Type} (H : ClassicalPathBAnalyticInputs ι) :
    CompletedXiLogDerivativeSourceAFZ :=
  CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    H.toHadamardProductWithZeros

-- =====================================================================
-- §CCCXLI. Final classical-input front door
-- =====================================================================

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟
**PATH B FINAL FRONT DOOR (classical analytic inputs)**.

The cleanest possible statement of Path B. The work has been split
into two independent analytic packages — Hadamard and Stieltjes —
both bundled, both AFZ-correct.

```
hTuring + hHighLog                                           (parallel agent)
+ Hclassical : ClassicalPathBAnalyticInputs ι                 (Hadamard side)
+ Hstieltjes : XiZeroContributionStieltjesEqualitySourceAFZ
                  Dzero 10
                  (pullbackZeroContribution
                    Hclassical.toCompletedXiSourceAFZ)        (Stieltjes side)
+ h_Z_ge_15                                                   (trivial)
⟹ XiPullbackAntiHerglotzTarget
```

After this, the work splits cleanly:
* Hadamard side: inhabit `ClassicalPathBAnalyticInputs`.
* Stieltjes side: inhabit `XiZeroContributionStieltjesEqualitySourceAFZ`
  matched to `pullbackZeroContribution Hclassical.toCompletedXiSourceAFZ`. -/
theorem XiPullbackAntiHerglotzTarget_of_classicalPathBInputs
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {ι : Type}
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hclassical : ClassicalPathBAnalyticInputs ι)
    (Hstieltjes :
      XiZeroContributionStieltjesEqualitySourceAFZ
        Dzero 10
        (pullbackZeroContribution
          Hclassical.toCompletedXiSourceAFZ)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_completedXiHadamardAndStieltjesAFZ
    Dzero h_Z_ge_15 hTuring hHighLog
    Hclassical.toCompletedXiSourceAFZ
    Hstieltjes

-- =====================================================================
-- §CCCXLII. Canonical Hadamard zero index package
-- =====================================================================
-- Names the zero index type + zero-locating map + characterizing
-- properties. The analytic agent's first concrete choice (e.g.,
-- ι = ℕ with `zeroLoc n` = the n-th nontrivial zeta zero ordinate).

/-- 📦 **`CompletedXiZeroIndexPackage`** — characterization of the
zero set of `completedXiFunction` via an explicit index type. -/
structure CompletedXiZeroIndexPackage where
  ι : Type
  zeroLoc : ι → ℂ
  zeroLoc_ne_zero :
    ∀ i : ι, zeroLoc i ≠ 0
  zeroLoc_is_zero :
    ∀ i : ι, completedXiFunction (zeroLoc i) = 0
  all_completedXi_zeros :
    ∀ s : ℂ,
      completedXiFunction s = 0 →
      ∃ i : ι, zeroLoc i = s

-- =====================================================================
-- §CCCXLIII. Hadamard prefactor data package
-- =====================================================================

/-- 📦 **`CompletedXiHadamardPrefactorData`** — AFZ properties of the
Hadamard prefactor as a Prop. -/
structure CompletedXiHadamardPrefactorData (prefactor : ℂ → ℂ) : Prop where
  differentiable_at_nonzero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ prefactor s
  nonzero_at_nonzero :
    ∀ s : ℂ,
      completedXiFunction s ≠ 0 →
      prefactor s ≠ 0

-- =====================================================================
-- §CCCXLIV. Hadamard factorization data + assembly
-- =====================================================================

/-- 📦 **`CompletedXiHadamardFactorizationData`** — the classical
factorization identity `ξ = prefactor · ∏ E₁(·/ρᵢ)`. -/
structure CompletedXiHadamardFactorizationData
    {ι : Type*} (zeroLoc : ι → ℂ) (prefactor : ℂ → ℂ) : Prop where
  factorization :
    ∀ s : ℂ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s

/-- 🌟🌟🌟 **PROVED — `ClassicalPathBAnalyticInputs` from the
Hadamard packages.** Assembles the bundled inputs from the
separately-developed Hadamard components. -/
noncomputable def ClassicalPathBAnalyticInputs.of_hadamard_packages
    {ι : Type} {zeroLoc : ι → ℂ} {prefactor : ℂ → ℂ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : ∀ s : ℂ, completedXiFunction s ≠ 0 → s ∈ Hluc.region)
    (HnonzeroRegion : ∀ s ∈ Hluc.region, ∀ i, s ≠ zeroLoc i)
    (Hfact : CompletedXiHadamardFactorizationData zeroLoc prefactor)
    (Hpref : CompletedXiHadamardPrefactorData prefactor) :
    ClassicalPathBAnalyticInputs ι :=
  { zeroLoc := zeroLoc
    prefactor := prefactor
    Hinv := Hinv
    Hluc := Hluc
    Hregion := Hregion
    HnonzeroRegion := HnonzeroRegion
    Hfact := Hfact.factorization
    Hpref_diff := Hpref.differentiable_at_nonzero
    Hpref_ne := Hpref.nonzero_at_nonzero }

-- =====================================================================
-- §CCCXLV. Stieltjes mid/high/low equality split
-- =====================================================================
-- Splits `XiZeroContributionStieltjesEqualitySourceAFZ` into three
-- independent Props, each provable separately.

/-- 📦 **`StieltjesMidTailEqualityAFZ`** — AFZ Stieltjes equality
in the MID band (canonical adaptive T). -/
structure StieltjesMidTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  mid_eq :
    ∀ {z : ℂ} {L : ℂ},
      0 < z.im →
      XiPullback z ≠ 0 →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L →
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- 📦 **`StieltjesHighTailEqualityAFZ`** — AFZ Stieltjes equality
in the HIGH band (`T ≥ 140`). -/
structure StieltjesHighTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  high_eq :
    ∀ {z : ℂ} {T : ℝ} {L : ℂ},
      140 ≤ T →
      0 < z.im →
      XiPullback z ≠ 0 →
      2 * (1 + |z.re| + z.im) ≤ T →
      XiFluctuationTailValue Dzero T0 T z L →
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- 📦 **`StieltjesLowEqualityAFZ`** — AFZ Stieltjes equality in the
LOW band (bounded `[11, 14]`). Wraps
`LowFiniteStieltjesFormulaOnFirstZeroGapAFZ` for symmetry with
mid/high. -/
structure StieltjesLowEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (ZC : ℂ → ℂ) : Prop where
  low_eq : LowFiniteStieltjesFormulaOnFirstZeroGapAFZ Dzero T0 ZC

/-- 🌟🌟🌟 **PROVED — reassemble
`XiZeroContributionStieltjesEqualitySourceAFZ` from the three split
Props.** -/
theorem XiZeroContributionStieltjesEqualitySourceAFZ.of_mid_high_low
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : ℝ} {ZC : ℂ → ℂ}
    (Hmid : StieltjesMidTailEqualityAFZ Dzero T0 ZC)
    (Hhigh : StieltjesHighTailEqualityAFZ Dzero T0 ZC)
    (Hlow : StieltjesLowEqualityAFZ Dzero T0 ZC) :
    XiZeroContributionStieltjesEqualitySourceAFZ Dzero T0 ZC :=
  { midHigh_eq :=
      { mid_eq := Hmid.mid_eq
        high_eq := Hhigh.high_eq }
    low_eq := Hlow.low_eq }

