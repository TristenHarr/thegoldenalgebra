  have h_pow_lt : (2.71 : ℝ)^12 < (Real.exp 1)^12 :=
    pow_lt_pow_left₀ h_e_gt (by norm_num) (by norm_num)
  have h_10_pow : (10 : ℝ)^5 < (2.71 : ℝ)^12 := by norm_num
  have h_10_pow_lt_exp12 : (10 : ℝ)^5 < (Real.exp 1)^12 := by
    linarith
  have h_exp12_eq : Real.exp (12 : ℝ) = (Real.exp 1)^12 := by
    have h := Real.exp_one_pow 12
    have h_cast : ((12 : ℕ) : ℝ) = (12 : ℝ) := by norm_num
    rw [← h_cast]
    exact h.symm
  have h_exp_12_5_pow : (Real.exp (12 / 5 : ℝ))^5 = Real.exp 12 := by
