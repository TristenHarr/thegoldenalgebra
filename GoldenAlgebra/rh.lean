    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ÔäØ}
    {M : CloudDensityTailModelDecomposition}
    (H :
      ÔêÇ {z : Ôäé} {T : ÔäØ},
        140 Ôëñ T ÔåÆ
        0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        Ôêâ L : Ôäé,
          Tendsto
            (fun X : ÔäØ =>
              complexDensityTailPartial pairedCauchyComplexKernelTrue
                (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
                T X z)
            Filter.atTop
            (­ØôØ L) Ôêº
          logDerivativeResponse XiPullback z = M.model z + L) :
    XiHighResidualAsTailLimit Dzero T0 M := by
  refine Ôƒ¿?_Ôƒ®
  intro z T hT140 hy hregime
