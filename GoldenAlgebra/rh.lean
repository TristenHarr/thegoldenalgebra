    {C K ѕД : вДЭ}
    (hclosed_le : closedFormSErrorBoundCD (1/2 : вДЭ) (49/20 : вДЭ) y T вЙ§ y * C)
    (hcloud_const : K вЙ§ cloudK_T zeros100ceil T)
    (htail_const : ѕД вЙ§ tailK_80_140 T)
