/-! ### W1вАУW5: analytic readiness for `ќґ'/ќґ` on the contour -/

/-- **W1.** `zetaLogDeriv` is continuous at every point where ќґ is
analytic and nonzero.  Uses `AnalyticAt.deriv` (analyticity of `ќґ`
implies analyticity of `deriv ќґ`), `AnalyticAt.continuousAt`, and
`ContinuousAt.div`. -/
theorem continuousAt_zetaLogDeriv
    {z : вДВ}
    (hz_ne_one : z вЙ† 1)
    (hz_ne_zero : riemannZeta z вЙ† 0) :
    ContinuousAt zetaLogDeriv z := by
  unfold zetaLogDeriv
  have hAn : AnalyticAt вДВ riemannZeta z :=
    riemannZeta_analyticAt_of_ne_one hz_ne_one
  have hDerivCont : ContinuousAt (deriv riemannZeta) z :=
    hAn.deriv.continuousAt
  exact hDerivCont.div hAn.continuousAt hz_ne_zero

/-- **W2.** `t вЖ¶ zetaLogDeriv (ќ≥ t)` is continuous on `[0, 1]` given
edge-readiness. -/
theorem continuousOn_logDeriv_comp_edge
    {ќ≥ : вДЭ вЖТ вДВ}
    (hќ≥ : EdgeLogDerivReady ќ≥) :
    ContinuousOn (fun t : вДЭ => zetaLogDeriv (ќ≥ t)) (Set.Icc 0 1) := by
  intro t ht
  have ht0 : 0 вЙ§ t := ht.1
  have ht1 : t вЙ§ 1 := ht.2
  have hcont :=
    continuousAt_zetaLogDeriv
      (hќ≥.avoids_pole t ht0 ht1) (hќ≥.zeta_ne_zero t ht0 ht1)
  exact hcont.comp_continuousWithinAt
    hќ≥.continuous_edge.continuousAt.continuousWithinAt

/-- **W3.** The full log-derivative integrand is interval-integrable on
`[0, 1]` given edge-readiness plus continuity of the edge derivative. -/
theorem intervalIntegrable_logDerivIntegrand_of_edgeReady
    {ќ≥ : вДЭ вЖТ вДВ}
    (hќ≥ : EdgeLogDerivReady ќ≥)
    (hќ≥_deriv : ContinuousOn (fun t : вДЭ => deriv ќ≥ t) (Set.Icc 0 1)) :
    IntervalIntegrable
      (fun t : вДЭ => zetaLogDeriv (ќ≥ t) * deriv ќ≥ t)
      MeasureTheory.volume 0 1 := by
  have h1 := continuousOn_logDeriv_comp_edge hќ≥
  have hmul :
      ContinuousOn (fun t : вДЭ => zetaLogDeriv (ќ≥ t) * deriv ќ≥ t)
        (Set.Icc 0 1) := h1.mul hќ≥_deriv
  exact hmul.intervalIntegrable_of_Icc (by norm_num : (0 : вДЭ) вЙ§ 1)

/-- **W4.** Package for continuity of the four rectangle edge
derivatives on `[0, 1]`.  Affine edges have constant derivatives so
this is straightforward, but we package it separately to defer the
explicit `deriv` computation. -/
structure ZetaRectangleEdgeDerivContinuous (R : ZetaRectangle) : Prop where
  bottom : ContinuousOn (fun t : вДЭ => deriv R.bottomEdge t) (Set.Icc 0 1)
  right : ContinuousOn (fun t : вДЭ => deriv R.rightEdge t) (Set.Icc 0 1)
  top : ContinuousOn (fun t : вДЭ => deriv R.topEdge t) (Set.Icc 0 1)
  left : ContinuousOn (fun t : вДЭ => deriv R.leftEdge t) (Set.Icc 0 1)

/-- **W5.** Strong admissibility plus edge-derivative continuity yields
log-derivative integrability for the whole rectangle contour. -/
theorem ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    (hDeriv : R.ZetaRectangleEdgeDerivContinuous) :
    R.ZetaRectangleLogDerivIntegrable where
  bottom :=
    intervalIntegrable_logDerivIntegrand_of_edgeReady
      (bottomEdge_logDerivReady_of_stronglyAdmissible hAdm) hDeriv.bottom
  right :=
    intervalIntegrable_logDerivIntegrand_of_edgeReady
      (rightEdge_logDerivReady_of_stronglyAdmissible hAdm) hDeriv.right
  top :=
    intervalIntegrable_logDerivIntegrand_of_edgeReady
      (topEdge_logDerivReady_of_stronglyAdmissible hAdm) hDeriv.top
  left :=
    intervalIntegrable_logDerivIntegrand_of_edgeReady
      (leftEdge_logDerivReady_of_stronglyAdmissible hAdm) hDeriv.left

/-! ### X1вАУX5: derivative continuity for affine edges -/

/-- **X2 bottom.** `HasDerivAt R.bottomEdge ((R.right - R.left : вДВ)) t`. -/
theorem hasDerivAt_bottomEdge (R : ZetaRectangle) (t : вДЭ) :
    HasDerivAt R.bottomEdge (((R.right - R.left : вДЭ) : вДВ)) t := by
  have heq : R.bottomEdge = fun s : вДЭ =>
      ((R.left : вДВ) + (R.bottom : вДВ) * Complex.I)
        + (s : вДВ) * ((R.right - R.left : вДЭ) : вДВ) := by
    funext s
    apply Complex.ext <;> simp [bottomEdge]
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : вДЭ => (s : вДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const ((R.right - R.left : вДЭ) : вДВ)
  have h_add := h_mul.const_add ((R.left : вДВ) + (R.bottom : вДВ) * Complex.I)
  simpa using h_add

/-- **X2 right.** `HasDerivAt R.rightEdge` is `((R.top - R.bottom : вДВ) * I)`. -/
theorem hasDerivAt_rightEdge (R : ZetaRectangle) (t : вДЭ) :
    HasDerivAt R.rightEdge (((R.top - R.bottom : вДЭ) : вДВ) * Complex.I) t := by
  have heq : R.rightEdge = fun s : вДЭ =>
      ((R.right : вДВ) + (R.bottom : вДВ) * Complex.I)
        + (s : вДВ) * (((R.top - R.bottom : вДЭ) : вДВ) * Complex.I) := by
    funext s
    apply Complex.ext <;> simp [rightEdge]
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : вДЭ => (s : вДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (((R.top - R.bottom : вДЭ) : вДВ) * Complex.I)
  have h_add := h_mul.const_add ((R.right : вДВ) + (R.bottom : вДВ) * Complex.I)
  simpa using h_add

/-- **X2 top.** `HasDerivAt R.topEdge` is `-((R.right - R.left : вДВ))`. -/
theorem hasDerivAt_topEdge (R : ZetaRectangle) (t : вДЭ) :
    HasDerivAt R.topEdge (-((R.right - R.left : вДЭ) : вДВ)) t := by
  have heq : R.topEdge = fun s : вДЭ =>
      ((R.right : вДВ) + (R.top : вДВ) * Complex.I)
        + (s : вДВ) * (-((R.right - R.left : вДЭ) : вДВ)) := by
    funext s
    apply Complex.ext <;> simp [topEdge]
    ring
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : вДЭ => (s : вДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (-((R.right - R.left : вДЭ) : вДВ))
  have h_add := h_mul.const_add ((R.right : вДВ) + (R.top : вДВ) * Complex.I)
  simpa using h_add

/-- **X2 left.** `HasDerivAt R.leftEdge` is `-((R.top - R.bottom : вДВ) * I)`. -/
theorem hasDerivAt_leftEdge (R : ZetaRectangle) (t : вДЭ) :
    HasDerivAt R.leftEdge (-(((R.top - R.bottom : вДЭ) : вДВ) * Complex.I)) t := by
  have heq : R.leftEdge = fun s : вДЭ =>
      ((R.left : вДВ) + (R.top : вДВ) * Complex.I)
        + (s : вДВ) * (-(((R.top - R.bottom : вДЭ) : вДВ) * Complex.I)) := by
    funext s
    apply Complex.ext <;> simp [leftEdge]
    ring
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : вДЭ => (s : вДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (-(((R.top - R.bottom : вДЭ) : вДВ) * Complex.I))
  have h_add := h_mul.const_add ((R.left : вДВ) + (R.top : вДВ) * Complex.I)
  simpa using h_add

/-- Closed-form derivative of the bottom edge. -/
theorem deriv_bottomEdge (R : ZetaRectangle) (t : вДЭ) :
    deriv R.bottomEdge t = ((R.right - R.left : вДЭ) : вДВ) :=
  (R.hasDerivAt_bottomEdge t).deriv

/-- Closed-form derivative of the right edge. -/
theorem deriv_rightEdge (R : ZetaRectangle) (t : вДЭ) :
    deriv R.rightEdge t = ((R.top - R.bottom : вДЭ) : вДВ) * Complex.I :=
  (R.hasDerivAt_rightEdge t).deriv

/-- Closed-form derivative of the top edge. -/
theorem deriv_topEdge (R : ZetaRectangle) (t : вДЭ) :
    deriv R.topEdge t = -((R.right - R.left : вДЭ) : вДВ) :=
  (R.hasDerivAt_topEdge t).deriv

/-- Closed-form derivative of the left edge. -/
theorem deriv_leftEdge (R : ZetaRectangle) (t : вДЭ) :
    deriv R.leftEdge t = -(((R.top - R.bottom : вДЭ) : вДВ) * Complex.I) :=
  (R.hasDerivAt_leftEdge t).deriv

/-- **X3.** Derivative-continuity package for the four affine edges. -/
theorem ZetaRectangleEdgeDerivContinuous.of_affine_edges
    (R : ZetaRectangle) :
    R.ZetaRectangleEdgeDerivContinuous where
  bottom := by
    rw [show (fun t : вДЭ => deriv R.bottomEdge t)
          = fun _ : вДЭ => ((R.right - R.left : вДЭ) : вДВ) from
        funext fun t => R.deriv_bottomEdge t]
    exact continuousOn_const
  right := by
    rw [show (fun t : вДЭ => deriv R.rightEdge t)
          = fun _ : вДЭ => ((R.top - R.bottom : вДЭ) : вДВ) * Complex.I from
        funext fun t => R.deriv_rightEdge t]
    exact continuousOn_const
  top := by
    rw [show (fun t : вДЭ => deriv R.topEdge t)
          = fun _ : вДЭ => -((R.right - R.left : вДЭ) : вДВ) from
        funext fun t => R.deriv_topEdge t]
    exact continuousOn_const
  left := by
    rw [show (fun t : вДЭ => deriv R.leftEdge t)
          = fun _ : вДЭ => -(((R.top - R.bottom : вДЭ) : вДВ) * Complex.I) from
        funext fun t => R.deriv_leftEdge t]
    exact continuousOn_const

/-- **X4.** A strongly admissible zeta rectangle has interval-integrable
log-derivative integrands on all four edges. -/
theorem ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleLogDerivIntegrable :=
  ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible hAdm
    (ZetaRectangleEdgeDerivContinuous.of_affine_edges R)

/-- **X5.** A strongly admissible zeta rectangle is ready for the
logarithmic-derivative contour integral. -/
theorem ZetaRectangleContourIntegralReady.of_stronglyAdmissible
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleContourIntegralReady where
  stronglyAdmissible := hAdm
  integrable := ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine hAdm

/-! ### Y1вАУY5: argument-principle theorem target -/

/-- **Y1.** The exact analytic theorem needed from the argument
principle for `riemannZeta` on a strongly admissible rectangle.  Not
asserted to be inhabited; future Mathlib argument-principle work must
construct an inhabitant. -/
structure ZetaRectangleArgumentPrincipleTheorem
    (R : ZetaRectangle)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 вЙ§ R.bottom)
    (hgood : GoodHeight R.top) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  argumentIndex : вД§
  normalizedIntegral_eq_index :
    R.normalizedRectangleLogDerivIntegral = (argumentIndex : вДВ)
  formula :
    (R.weightedZeroCountInside
        (R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
        zetaGlobalZeroMultiplicity : вД§)
      -
    (R.poleCountInside : вД§)
      =
    argumentIndex

/-- **Y2.** The argument-principle theorem target produces actual
normalized argument-principle data. -/
noncomputable def ZetaRectangleArgumentPrincipleTheorem.toActualNormalizedData
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (A : R.ZetaRectangleArgumentPrincipleTheorem
      hleft hright hbottom_nonneg hgood) :
    R.ActualZetaRectangleNormalizedArgumentPrincipleData
      hleft hright hbottom_nonneg hgood where
  contour :=
    { ready :=
        ZetaRectangleContourIntegralReady.of_stronglyAdmissible
          A.stronglyAdmissible
      argumentIndex := A.argumentIndex
      normalizedIntegral_eq_index := A.normalizedIntegral_eq_index }
  admissible := A.stronglyAdmissible.toAdmissibleForZeta
  formula := A.formula

/-- **Y3.** Nonnegativity of the argument index in the
argument-principle theorem target. -/
structure ZetaRectangleArgumentPrincipleTheoremNat
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (A : R.ZetaRectangleArgumentPrincipleTheorem
      hleft hright hbottom_nonneg hgood) : Prop where
  argumentIndex_nonneg : 0 вЙ§ A.argumentIndex

/-- **Y4.** A proved argument-principle theorem target with nonnegative
index yields a Turing interval certificate. -/
noncomputable def ZetaRectangleArgumentPrincipleTheorem.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (A : R.ZetaRectangleArgumentPrincipleTheorem
      hleft hright hbottom_nonneg hgood)
    (AN : ZetaRectangleArgumentPrincipleTheoremNat A)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate :=
  A.toActualNormalizedData.toTuringIntervalCertificate
    AN.argumentIndex_nonneg
    hbottom_pos

/-- **Y5.** The Turing certificate obtained from an argument-principle
theorem target has certified count equal to the natural value of the
theorem's argument index. -/
theorem ZetaRectangleArgumentPrincipleTheorem.toTuringIntervalCertificate_certifiedCount
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (A : R.ZetaRectangleArgumentPrincipleTheorem
      hleft hright hbottom_nonneg hgood)
    (AN : ZetaRectangleArgumentPrincipleTheoremNat A)
    (hbottom_pos : 0 < R.bottom) :
    (A.toTuringIntervalCertificate AN hbottom_pos).certifiedCount =
      (A.toActualNormalizedData.toCanonicalData.toFormula).argumentIndexNat
        { argumentIndex_nonneg := AN.argumentIndex_nonneg } := rfl

/-! ### Z1вАУZ4: residue-theorem adapter for the zeta rectangle -/

/-- **Z1.** Residue-theorem output for `ќґ'/ќґ` on a rectangle: the
normalized rectangle integral equals an integer residue index, which in
turn equals zeros вИТ poles.  This is the Mathlib-facing shape: a future
residue-theorem proof should produce an inhabitant directly. -/
structure ZetaRectangleResidueIndexFormula
    (R : ZetaRectangle)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 вЙ§ R.bottom)
    (hgood : GoodHeight R.top) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  residueIndex : вД§
  normalizedIntegral_eq_index :
    R.normalizedRectangleLogDerivIntegral = (residueIndex : вДВ)
  residueIndex_eq_count_sub_poles :
    residueIndex =
      (R.weightedZeroCountInside
          (R.zeroSetInsideOfSlab hleft hright hgood
            (R.canonicalSlabZeroSet hbottom_nonneg))
          zetaGlobalZeroMultiplicity : вД§)
        -
      (R.poleCountInside : вД§)

/-- **Z2.** A residue-index formula yields the argument-principle
theorem target. -/
noncomputable def ZetaRectangleResidueIndexFormula.toArgumentPrincipleTheorem
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood) :
    R.ZetaRectangleArgumentPrincipleTheorem
      hleft hright hbottom_nonneg hgood where
  stronglyAdmissible := F.stronglyAdmissible
  argumentIndex := F.residueIndex
  normalizedIntegral_eq_index := F.normalizedIntegral_eq_index
  formula := F.residueIndex_eq_count_sub_poles.symm

/-- **Z3.** For a positive-bottom rectangle, the residue index is
nonnegative (pole count is `0`, so the index equals the weighted zero
count which is a natural number). -/
theorem ZetaRectangleResidueIndexFormula.residueIndex_nonneg_of_positive_bottom
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood)
    (hbottom_pos : 0 < R.bottom) :
    0 вЙ§ F.residueIndex := by
  have hpole : R.poleCountInside = 0 :=
    R.poleCountInside_eq_zero_of_positive_bottom hbottom_pos
  rw [F.residueIndex_eq_count_sub_poles, hpole]
  omega

/-- **Z4.** A residue-index formula for a positive-bottom rectangle
yields a Turing interval certificate. -/
noncomputable def ZetaRectangleResidueIndexFormula.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate :=
  F.toArgumentPrincipleTheorem.toTuringIntervalCertificate
    { argumentIndex_nonneg :=
        F.residueIndex_nonneg_of_positive_bottom hbottom_pos }
    hbottom_pos

end ZetaRectangle

/-! ### AB: local residue bookkeeping for `ќґ'/ќґ` -/

/-- **AB.** Local residue contribution of the logarithmic derivative
`ќґ'/ќґ`.  At a nontrivial zero of multiplicity `m`, the residue equals `m`;
at the pole `1`, the residue equals `-1`; elsewhere, `0`. -/
structure ZetaLogDerivLocalResidueData where
  residueAt : вДВ вЖТ вД§
  residue_zero :
    вИА s : вДВ, IsNontrivialZetaZero s вЖТ
      residueAt s = zetaGlobalZeroMultiplicity.mult s
  residue_pole_one : residueAt (1 : вДВ) = -1
  residue_elsewhere_zero :
    вИА s : вДВ, ¬ђ IsNontrivialZetaZero s вЖТ s вЙ† 1 вЖТ residueAt s = 0

namespace ZetaRectangle

/-! ### ACвАУAD: Mathlib-facing residue theorem output and conversion -/

/-- **AC.** Raw Mathlib residue-theorem output for `ќґ'/ќґ` on a
rectangle: the normalized rectangle integral equals the finite sum of
local residues over the singularities (zeros plus possibly the pole)
inside the rectangle. -/
structure ZetaRectangleResidueTheoremOutput (R : ZetaRectangle) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  singularities : Finset вДВ
  residueAt : вДВ вЖТ вД§
  normalizedIntegral_eq_sum :
    R.normalizedRectangleLogDerivIntegral =
      ((singularities.sum residueAt : вД§) : вДВ)
  singularities_complete :
    вИА s : вДВ,
      s вИИ singularities вЖФ
        (R.ContainsOpen s вИІ (riemannZeta s = 0 вИ® s = 1))

/-- **AD.** Convert a raw residue-theorem output into the rectangle
residue-index formula used by the Turing/Backlund pipeline.  The caller
must supply the algebraic identity matching the residue sum to
`zeros вИТ poles`. -/
noncomputable def ZetaRectangleResidueTheoremOutput.toResidueIndexFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (O : R.ZetaRectangleResidueTheoremOutput)
    (_Hloc : ZetaLogDerivLocalResidueData)
    (hSingularitiesMatch :
      O.singularities.sum O.residueAt =
        (R.weightedZeroCountInside
            (R.zeroSetInsideOfSlab hleft hright hgood
              (R.canonicalSlabZeroSet hbottom_nonneg))
            zetaGlobalZeroMultiplicity : вД§)
          -
        (R.poleCountInside : вД§)) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood where
  stronglyAdmissible := O.stronglyAdmissible
  residueIndex := O.singularities.sum O.residueAt
  normalizedIntegral_eq_index := O.normalizedIntegral_eq_sum
  residueIndex_eq_count_sub_poles := hSingularitiesMatch

/-! ### AE: canonical singularities + positive-bottom simplification -/

open Classical in
/-- The canonical singularity set inside a rectangle: zeros inside plus
the pole if it lies inside. -/
noncomputable def canonicalSingularities
    (R : ZetaRectangle) (Z : R.ZeroSetInside) : Finset вДВ :=
  if R.PoleInside then insert (1 : вДВ) Z.zeros else Z.zeros

/-- For a positive-bottom rectangle, the canonical singularities are
just the zeros inside (no pole). -/
theorem canonicalSingularities_eq_zeros_of_positive_bottom
    {R : ZetaRectangle}
    (Z : R.ZeroSetInside)
    (hbottom_pos : 0 < R.bottom) :
    R.canonicalSingularities Z = Z.zeros := by
  unfold canonicalSingularities
  simp [not_poleInside_of_positive_bottom hbottom_pos]

/-- If local residues at zeros agree with analytic multiplicity, the
residue sum over the zero support equals the weighted zero count. -/
theorem residue_sum_eq_weightedZeroCountInside
    {R : ZetaRectangle}
    (Z : R.ZeroSetInside)
    (residueAt : вДВ вЖТ вД§)
    (hres :
      вИА s : вДВ, s вИИ Z.zeros вЖТ
        residueAt s = (zetaGlobalZeroMultiplicity.mult s : вД§)) :
    Z.zeros.sum residueAt =
      (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : вД§) := by
  unfold weightedZeroCountInside
  push_cast
  exact Finset.sum_congr rfl hres

end ZetaRectangle

/-! ### AF1: local residue theorem target -/

/-- **AF1.** Local residue theorem for `ќґ'/ќґ`: at each nontrivial zero
the residue is the analytic multiplicity, at the pole `1` it is `-1`,
and elsewhere it is `0`. -/
structure ZetaLogDerivResidueTheorem where
  residueAt : вДВ вЖТ вД§
  residueAt_zero :
    вИА s : вДВ, IsNontrivialZetaZero s вЖТ
      residueAt s = (zetaGlobalZeroMultiplicity.mult s : вД§)
  residueAt_pole_one : residueAt (1 : вДВ) = -1
  residueAt_elsewhere :
    вИА s : вДВ,
      ¬ђ IsNontrivialZetaZero s вЖТ
      s вЙ† 1 вЖТ
      residueAt s = 0

/-- Convert a `ZetaLogDerivResidueTheorem` into the rectangle-facing
local residue data package. -/
noncomputable def ZetaLogDerivResidueTheorem.toLocalResidueData
    (L : ZetaLogDerivResidueTheorem) :
    ZetaLogDerivLocalResidueData where
  residueAt := L.residueAt
  residue_zero := L.residueAt_zero
  residue_pole_one := L.residueAt_pole_one
  residue_elsewhere_zero := L.residueAt_elsewhere

/-! ### AF2: candidate integer-valued residue function -/

open Classical in
/-- The expected integer-valued residue contribution of `ќґ'/ќґ`. -/
noncomputable def zetaLogDerivExpectedResidueIndex (s : вДВ) : вД§ :=
  if IsNontrivialZetaZero s then
    (zetaGlobalZeroMultiplicity.mult s : вД§)
  else if s = 1 then
    -1
  else
    0

theorem zetaLogDerivExpectedResidueIndex_of_zero
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    zetaLogDerivExpectedResidueIndex s =
      (zetaGlobalZeroMultiplicity.mult s : вД§) := by
  unfold zetaLogDerivExpectedResidueIndex
  simp [hs]

theorem zetaLogDerivExpectedResidueIndex_one :
    zetaLogDerivExpectedResidueIndex (1 : вДВ) = -1 := by
  unfold zetaLogDerivExpectedResidueIndex
  have hnot : ¬ђ IsNontrivialZetaZero (1 : вДВ) := by
    intro h
    have hlt : (1 : вДВ).re < 1 := h.2.2
    norm_num at hlt
  simp [hnot]

theorem zetaLogDerivExpectedResidueIndex_elsewhere
    {s : вДВ}
    (hs : ¬ђ IsNontrivialZetaZero s)
    (hs1 : s вЙ† 1) :
    zetaLogDerivExpectedResidueIndex s = 0 := by
  unfold zetaLogDerivExpectedResidueIndex
  simp [hs, hs1]

/-- The expected local residue-index data for `ќґ'/ќґ`.  The analytic
content (identifying this with Mathlib's complex residue of
`zetaLogDeriv`) remains as future work. -/
noncomputable def zetaLogDerivExpectedResidueTheorem :
    ZetaLogDerivResidueTheorem where
  residueAt := zetaLogDerivExpectedResidueIndex
  residueAt_zero := fun _s hs => zetaLogDerivExpectedResidueIndex_of_zero hs
  residueAt_pole_one := zetaLogDerivExpectedResidueIndex_one
  residueAt_elsewhere :=
    fun _s hs hs1 => zetaLogDerivExpectedResidueIndex_elsewhere hs hs1

/-! ### AG1вАУAG5: log-derivative local Laurent identities

Since Mathlib has no `Complex.residue` function, encode the local
residue indirectly as the `m/(z-s)` principal part of `logDeriv f`.
-/

/-- **AG2.** `HasLogDerivPrincipalPart f s m` means that near `s` but
away from `s`, the logarithmic derivative of `f` has principal part
`m/(z - s)` plus an analytic remainder. -/
def HasLogDerivPrincipalPart
    (f : вДВ вЖТ вДВ) (s : вДВ) (m : вДХ) : Prop :=
  вИГ g : вДВ вЖТ вДВ,
    AnalyticAt вДВ g s вИІ
      logDeriv f =бґ†[рЭУЭ[вЙ†] s]
        (fun z : вДВ => (m : вДВ) / (z - s) + g z)

/-- **AG3.** Local log-derivative principal part for `riemannZeta` at
a nontrivial zero: the residue equals the analytic multiplicity. -/
def ZetaHasLogDerivPrincipalPart (s : вДВ) : Prop :=
  HasLogDerivPrincipalPart riemannZeta s
    (zetaGlobalZeroMultiplicity.mult s)

/-- **AG5 (integer version).** Allows negative `k` to handle poles.  At
a simple pole of order `1`, the residue is `-1`. -/
def HasLogDerivIntegerPrincipalPart
    (f : вДВ вЖТ вДВ) (s : вДВ) (k : вД§) : Prop :=
  вИГ g : вДВ вЖТ вДВ,
    AnalyticAt вДВ g s вИІ
      logDeriv f =бґ†[рЭУЭ[вЙ†] s]
        (fun z : вДВ => (k : вДВ) / (z - s) + g z)

/-- A natural-coefficient principal part lifts to the integer version
via `Nat.cast`. -/
theorem HasLogDerivIntegerPrincipalPart.of_nat
    {f : вДВ вЖТ вДВ} {s : вДВ} {m : вДХ}
    (h : HasLogDerivPrincipalPart f s m) :
    HasLogDerivIntegerPrincipalPart f s (m : вД§) := by
  obtain вЯ®g, hg_an, hg_eqвЯ© := h
  refine вЯ®g, hg_an, ?_вЯ©
  filter_upwards [hg_eq] with z hz
  simpa using hz

