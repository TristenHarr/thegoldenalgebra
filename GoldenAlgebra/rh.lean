-- =====================================================================
-- ¬ІCCXLV. Canonical-T `herror` formulation
-- =====================================================================
-- Mathematical correction: the raw improper tail
-- `вИЂ_T^вИЮ kernel ¬Ј S` genuinely depends on `T`, so a `herror`
-- quantifying `(error z).im = (trueKernelAdaptiveTail T z).im`
-- for ALL adaptive `T` (with `error` independent of `T`) is too
-- strong вАФ it implicitly forces tail independence.
--
-- This section provides a corrected single-`T` formulation:
-- pick one canonical adaptive `T` per `z` (deterministic, via
-- `Classical.choose` inside a `dite`), and require `herror` only
-- at that canonical `T`. The original arbitrary-`T` formulation
-- is preserved (it can still be inhabited if tail independence
-- is actually proved later).
--
-- Adds:
--   canonicalAdaptiveT                                       вАФ deterministic zвЖ¶T
--   canonicalAdaptiveT_spec                                  вАФ spec lemma
--   XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail      вАФ canonical-T constructor
--   XiPullbackAntiHerglotzTarget_of_errorFormula_canonical   вАФ final front door

/-- **Canonical adaptive cutoff at `z`.** A deterministic choice of `T`
satisfying the adaptive band condition `10 вЙ§ T вЙ§ 140` and
`2(1 + |z.re| + z.im) вЙ§ T`, via `Classical.choose` inside a `dite`.
Outside the adaptive region (i.e. when no such `T` exists), returns
the sentinel `10`. -/
noncomputable def canonicalAdaptiveT (z : вДВ) : вДЭ :=
  letI : Decidable
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) :=
    Classical.propDecidable _
  if h : вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T then
    Classical.choose h
  else
    10

/-- в≠Р **PROVED вАФ canonical T is in the adaptive band when the band
exists for `z`.** -/
lemma canonicalAdaptiveT_spec
    {z : вДВ}
    (h : вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) :
    10 вЙ§ canonicalAdaptiveT z вИІ
    canonicalAdaptiveT z вЙ§ 140 вИІ
    2 * (1 + |z.re| + z.im) вЙ§ canonicalAdaptiveT z := by
  have h_choose := Classical.choose_spec h
  unfold canonicalAdaptiveT
  simp [h, h_choose]

/-- рЯМЯрЯМЯ **PROVED вАФ `XiLogDerivativeFormulaPieces` from canonical-T
herror.** Like `ofErrorAsFluctTail` but using the canonical adaptive
`T` per `z` plus an explicit Im-independence hypothesis. The
`fluctTail_im_eq_trueTail` field is recovered by `htail_indep`
bridging from the canonical `T` to any other adaptive `T`. -/
noncomputable def XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List вДЭ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (error : вДВ вЖТ вДВ)
    (hmodel : вИА z : вДВ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_canonical :
      вИА {z : вДВ},
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        0 < z.im вЖТ
        (error z).im =
          (trueKernelAdaptiveTail
            Dzero T0 hT0_pos hT0_le_10 hTuring
            (canonicalAdaptiveT z) z).im)
    (htail_indep :
      вИА {z : вДВ} {TвВБ TвВВ : вДЭ},
        10 вЙ§ TвВБ вЖТ TвВБ вЙ§ 140 вЖТ 2 * (1 + |z.re| + z.im) вЙ§ TвВБ вЖТ
        10 вЙ§ TвВВ вЖТ TвВВ вЙ§ 140 вЖТ 2 * (1 + |z.re| + z.im) вЙ§ TвВВ вЖТ
        0 < z.im вЖТ
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TвВБ z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z).im) :
    XiLogDerivativeFormulaPieces
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error :=
  XiLogDerivativeFormulaPieces.ofErrorAsFluctTail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M Tsmooth hTsmooth_ge error
    hmodel hxi
    (by
      intro z T h10 h140 hy hregime
      have hExists : вИГ T : вДЭ,
          10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T :=
        вЯ®T, h10, h140, hregimeвЯ©
      have hcanon := canonicalAdaptiveT_spec hExists
      have hcan_im : (error z).im =
          (trueKernelAdaptiveTail
            Dzero T0 hT0_pos hT0_le_10 hTuring
            (canonicalAdaptiveT z) z).im :=
        herror_canonical hExists hy
      rw [hcan_im]
      exact htail_indep hcanon.1 hcanon.2.1 hcanon.2.2 h10 h140 hregime hy)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **CLEAN FRONT DOOR (canonical-T herror).**
Final form with `herror` only required at the canonical adaptive `T`
per `z`, mathematically honest about the raw-tail T-dependence: the
extra `htail_indep` hypothesis carries the Im-independence claim
explicitly (rather than baking it into the structure of `herror`). -/
theorem XiPullbackAntiHerglotzTarget_of_errorFormula_canonical
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List вДЭ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (error : вДВ вЖТ вДВ)
    (hmodel : вИА z : вДВ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_canonical :
      вИА {z : вДВ},
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        0 < z.im вЖТ
        (error z).im =
          (trueKernelAdaptiveTail
            Dzero T0 hT0_pos hT0_le_10 hTuring
            (canonicalAdaptiveT z) z).im)
    (htail_indep :
      вИА {z : вДВ} {TвВБ TвВВ : вДЭ},
        10 вЙ§ TвВБ вЖТ TвВБ вЙ§ 140 вЖТ 2 * (1 + |z.re| + z.im) вЙ§ TвВБ вЖТ
        10 вЙ§ TвВВ вЖТ TвВВ вЙ§ 140 вЖТ 2 * (1 + |z.re| + z.im) вЙ§ TвВВ вЖТ
        0 < z.im вЖТ
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TвВБ z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z).im)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_formulaPieces
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error
    (XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error
      hmodel hxi herror_canonical htail_indep)
    B

-- =====================================================================
-- ¬ІCCXLVI. Tail additivity and cutoff-change formula
-- =====================================================================
-- The raw improper tail genuinely depends on `T`. Before assuming any
-- form of `htail_indep`, we expose the exact cutoff-change relation:
--
--   tail(TвВБ) = вИЂ_{TвВБ}^{TвВВ} kernel¬ЈS + tail(TвВВ)
--
-- On Im, this lands on the real `derivativeSidePartial` and hence on
-- the integral of `S ¬Ј pairedCauchyImKernelDeriv` вАФ the explicit
-- finite-correction term that determines when (and only when) tail Im
-- is invariant in `T`.
--
-- Adds:
--   complexDensityTailPartial_add_adjacent                    вАФ finite splitting
--   trueKernelAdaptiveTail_eq_finite_add_tail                 вАФ limit additivity
--   trueKernelAdaptiveTail_im_sub_eq_finite_real_integral     вАФ Im cutoff-change

/-- рЯМЯрЯМЯ **PROVED вАФ finite partial additivity.** Splits a finite
complex partial `[TвВБ, X]` across an intermediate cutoff `TвВВ`. Direct
application of `intervalIntegral.integral_add_adjacent_intervals`
after restricting the global integrability to each subinterval via
`IntervalIntegrable.mono_set`. -/
lemma complexDensityTailPartial_add_adjacent
    (kernel : вДЭ вЖТ вДВ вЖТ вДВ) (S : вДЭ вЖТ вДЭ)
    {TвВБ TвВВ X : вДЭ} (z : вДВ)
    (h12 : TвВБ вЙ§ TвВВ) (h2X : TвВВ вЙ§ X)
    (hInt :
      IntervalIntegrable
        (fun u => kernel u z * (S u : вДВ))
        MeasureTheory.volume TвВБ X) :
    complexDensityTailPartial kernel S TвВБ X z =
      complexDensityTailPartial kernel S TвВБ TвВВ z +
      complexDensityTailPartial kernel S TвВВ X z := by
  unfold complexDensityTailPartial
  have h1X : TвВБ вЙ§ X := le_trans h12 h2X
  have hInt_12 : IntervalIntegrable
      (fun u => kernel u z * (S u : вДВ))
      MeasureTheory.volume TвВБ TвВВ := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h12, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_right h2X
  have hInt_2X : IntervalIntegrable
      (fun u => kernel u z * (S u : вДВ))
      MeasureTheory.volume TвВВ X := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h2X, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_left h12
  exact (intervalIntegral.integral_add_adjacent_intervals hInt_12 hInt_2X).symm

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `trueKernelAdaptiveTail` additivity across
adaptive cutoffs.** For `TвВБ вЙ§ TвВВ` both in the adaptive band at `z`,

  `trueKernelAdaptiveTail TвВБ z
     = finite[TвВБ,TвВВ] partial + trueKernelAdaptiveTail TвВВ z`.

Proof: both tails are pointwise limits of complex partials; for
`X вЙ• TвВВ` the partial at `TвВБ` splits via ¬ІCCXLVI-1; the finite
`[TвВБ, TвВВ]` partial is constant in `X`; uniqueness of limits closes. -/
theorem trueKernelAdaptiveTail_eq_finite_add_tail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : вДВ} {TвВБ TвВВ : вДЭ}
    (h1 : 10 вЙ§ TвВБ) (h1' : TвВБ вЙ§ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) вЙ§ TвВБ)
    (h2 : 10 вЙ§ TвВВ) (h2' : TвВВ вЙ§ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) вЙ§ TвВВ)
    (h12 : TвВБ вЙ§ TвВВ) :
    trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВБ z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z
      + trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z := by
  -- Local helper: convergence directly to `trueKernelAdaptiveTail ... T z`
  have hconv_at : вИА {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      Tendsto (fun X : вДЭ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (рЭУЭ (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z)) := by
    intro T hT10 hT140 hTreg
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring hT10 hT140 hy hTreg
    have hregion :
        10 вЙ§ T вИІ T вЙ§ 140 вИІ 0 < z.im вИІ 2 * (1 + |z.re| + z.im) вЙ§ T :=
      вЯ®hT10, hT140, hy, hTregвЯ©
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists
  have hT1_conv := hconv_at h1 h1' hr1
  have hT2_conv := hconv_at h2 h2' hr2
  have hsplit_ev : вИАбґ† X : вДЭ in Filter.atTop,
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ X z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z +
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВВ X z := by
    filter_upwards [Filter.eventually_ge_atTop TвВВ] with X hT2X
    have h1X : TвВБ вЙ§ X := le_trans h12 hT2X
    have hInt :=
      true_int_of_finiteFluctuation
        Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h1X
    exact complexDensityTailPartial_add_adjacent
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z h12 hT2X hInt
  have h_const_finite :
      Tendsto (fun _ : вДЭ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TвВБ TвВВ z) Filter.atTop
      (рЭУЭ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z)) := tendsto_const_nhds
  have h_sum_tendsto :
      Tendsto (fun X : вДЭ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TвВБ TвВВ z +
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TвВВ X z) Filter.atTop
      (рЭУЭ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z)) :=
    h_const_finite.add hT2_conv
  have hT1_to_sum :
      Tendsto (fun X : вДЭ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          TвВБ X z) Filter.atTop
      (рЭУЭ (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z)) :=
    h_sum_tendsto.congr' (hsplit_ev.mono (fun X hX => hX.symm))
  exact tendsto_nhds_unique hT1_conv hT1_to_sum

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ cutoff-change formula on Im (the real
finite correction term).** Subtracting `Im` across the additivity
theorem lands on the explicit real integral

  `(tail TвВБ).im вИТ (tail TвВВ).im
     = вИЂ_{TвВБ}^{TвВВ} S(u) ¬Ј pairedCauchyImKernelDeriv z.re z.im u du`,

where `S = Phase1IBP.finiteFluctuationPrimitive Dzero T0`. This is the
honest cutoff-dependence вАФ `htail_indep` holds (in Im) iff the RHS
vanishes; in general it does not, and any formula combining `model`
with `error` must absorb this finite correction. -/
theorem trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : вДВ} {TвВБ TвВВ : вДЭ}
    (h1 : 10 вЙ§ TвВБ) (h1' : TвВБ вЙ§ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) вЙ§ TвВБ)
    (h2 : 10 вЙ§ TвВВ) (h2' : TвВВ вЙ§ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) вЙ§ TвВВ)
    (h12 : TвВБ вЙ§ TвВВ) :
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВБ z).im -
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z).im
      = вИЂ u in TвВБ..TвВВ,
          Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
            pairedCauchyImKernelDeriv z.re z.im u := by
  have hadd := trueKernelAdaptiveTail_eq_finite_add_tail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    h1 h1' hy hr1 h2 h2' hr2 h12
  have him_sum := congrArg Complex.im hadd
  simp only [Complex.add_im] at him_sum
  have him_diff :
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВБ z).im -
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring TвВВ z).im =
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        TвВБ TвВВ z).im := by
    linarith
  rw [him_diff]
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hInt_true := true_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_wrap := wrap_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_true_uhp : IntervalIntegrable
      (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im) *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : вДЭ) : вДВ))
      MeasureTheory.volume TвВБ TвВВ := by
    rw [hzUHP]; exact hInt_true
  have hInt_wrap_uhp : IntervalIntegrable
      (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im) *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : вДЭ) : вДВ))
      MeasureTheory.volume TвВБ TвВВ := by
    rw [hzUHP]; exact hInt_wrap
  have h_im_swap_uhp :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im TвВБ TвВВ hInt_true_uhp hInt_wrap_uhp
  rw [hzUHP] at h_im_swap_uhp
  rw [h_im_swap_uhp]
  have h_deriv_uhp :=
    complexDensityTailPartial_im_eq_derivativeSidePartial
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im TвВБ TвВВ
  rw [hzUHP] at h_deriv_uhp
  rw [h_deriv_uhp]
  unfold Phase1IBP.derivativeSidePartial
  rfl

-- =====================================================================
-- ¬ІCCXLVII. Corrected cutoff-dependent error interface
-- =====================================================================
-- ¬ІCCXLVI proved that the raw improper tail is genuinely cutoff-
-- dependent: `(tail TвВБ).im - (tail TвВВ).im` equals an explicit finite
-- real integral. The ¬ІCCXLV `htail_indep` assumption is therefore
-- mathematically over-strong (it only holds when the finite correction
-- vanishes for every adaptive pair, which is not generally true).
--
-- This section provides the mathematically honest interface:
-- `herror` is specified at the canonical adaptive `T` plus an explicit
-- finite correction term that transports the canonical-tail Im to any
-- other adaptive `T` via ¬ІCCXLVI's cutoff-change law. No false
-- independence assumption.
--
-- Adds:
--   trueKernelTailCorrection                                       вАФ finite real correction
--   HErrorCanonicalCorrected                                       вАФ corrected Im claim
--   fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected           вАФ bridge lemma
--   XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected   вАФ corrected constructor
--   XiPullbackAntiHerglotzTarget_of_errorFormula_canonicalCorrected вАФ corrected front door

/-- в≠Р **PROVED вАФ generic explicit-integrand `intervalIntegral.integral_symm`.**
Wraps `intervalIntegral.integral_symm` with `f` as an explicit
parameter, supplied via named-argument `(f := f)`. Use this everywhere
instead of the underlying lemma: the underlying lemma leaves `f`
implicit, so calling it forces the unifier to infer `f` from the goal,
which can unfold heavy named definitions (`trueKernelTailCorrection`,
`finiteFluctuationPrimitive`, вА¶) and trigger `whnf` timeouts.

Mathlib signature: `integral_symm (a b) : вИЂ x in b..a, f x вИВќЉ = -вИЂ x in a..b, f x вИВќЉ`.
We swap endpoints so the LHS reads `вИЂ x in a..b`. -/
lemma intervalIntegral_symm_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace вДЭ E]
    (f : вДЭ вЖТ E) (a b : вДЭ) :
    (вИЂ x in a..b, f x) = - вИЂ x in b..a, f x :=
  intervalIntegral.integral_symm (f := f) b a

/-- **Named integrand for `trueKernelTailCorrection`.** Top-level
`fun u => вА¶` so the symmetry lemma below can pass it as an explicit
argument to `intervalIntegral_symm_apply` without making Lean unfold
the heavy correction definition. -/
noncomputable def trueKernelTailCorrectionIntegrand
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ) (z : вДВ) :
    вДЭ вЖТ вДЭ :=
  fun u =>
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
      pairedCauchyImKernelDeriv z.re z.im u

/-- **Finite real cutoff-correction.** The explicit `[Tc, T]`
real integral whose value differs between any two adaptive-cutoff
`trueKernelAdaptiveTail` Im values at `z`. From ¬ІCCXLVI:

  `(trueKernelAdaptiveTail Tc z).im вИТ (trueKernelAdaptiveTail T z).im
      = trueKernelTailCorrection Tc T z`     when `Tc вЙ§ T`.

For `T вЙ§ Tc`, `trueKernelTailCorrection_symm` flips the sign so the
identity recovers in the other orientation. The integrand is supplied
via the named top-level `trueKernelTailCorrectionIntegrand` so the
symmetry lemma can avoid a `whnf` explosion on Mathlib's
`intervalIntegral.integral_symm`. -/
noncomputable def trueKernelTailCorrection
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (Tc T : вДЭ) (z : вДВ) : вДЭ :=
  вИЂ u in Tc..T, trueKernelTailCorrectionIntegrand Dzero T0 z u

/-- в≠Р **PROVED вАФ symmetry of the cutoff correction.** Cheap proof:
the integrand is now a named top-level term, so
`intervalIntegral_symm_apply` receives `f` explicitly and Lean never
needs to unfold heavy definitions during unification. -/
theorem trueKernelTailCorrection_symm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 a b : вДЭ) (z : вДВ) :
    trueKernelTailCorrection Dzero T0 a b z =
      - trueKernelTailCorrection Dzero T0 b a z := by
  unfold trueKernelTailCorrection
  exact intervalIntegral_symm_apply
    (trueKernelTailCorrectionIntegrand Dzero T0 z) a b

/-- **Corrected canonical-T herror claim.** Compared to ¬ІCCXLV's
`herror_canonical`, this version explicitly carries the finite
cutoff-correction term that absorbs the difference between the raw
tail at the canonical adaptive `T` and the raw tail at the
package-supplied `T`. No tail Im-independence is asserted. -/
def HErrorCanonicalCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : вДВ вЖТ вДВ) : Prop :=
  вИА {z : вДВ} {T : вДЭ},
    10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
    2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
    (error z).im =
      (trueKernelAdaptiveTail
        Dzero T0 hT0_pos hT0_le_10 hTuring
        (canonicalAdaptiveT z) z).im
      -
      trueKernelTailCorrection
        Dzero T0 (canonicalAdaptiveT z) T z

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ bridge from `HErrorCanonicalCorrected` to
arbitrary-T Im match.** Routes through ¬ІCCXLVI's
`trueKernelAdaptiveTail_im_sub_eq_finite_real_integral` with case
analysis on whether `canonicalAdaptiveT z вЙ§ T` or `T вЙ§ canonicalAdaptiveT z`.
In the second case `intervalIntegral.integral_symm` flips the sign so
the same final formula recovers. -/
theorem fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : вДВ вЖТ вДВ)
    (herror_corr : HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error) :
    вИА {z : вДВ} {T : вДЭ},
      10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      (error z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring T z).im := by
  intro z T h10 h140 hy hregime
  have hExists : вИГ T : вДЭ,
      10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T :=
    вЯ®T, h10, h140, hregimeвЯ©
  have hc := canonicalAdaptiveT_spec hExists
  have hcorr := herror_corr h10 h140 hy hregime
  rw [hcorr]
  by_cases hle : canonicalAdaptiveT z вЙ§ T
  ¬Ј -- canonical вЙ§ T case: direct application of ¬ІCCXLVI
    have hadd_im :=
      trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
        Dzero T0 hT0_pos hT0_le_10 hTuring
        hc.1 hc.2.1 hy hc.2.2 h10 h140 hregime hle
    simp only [trueKernelTailCorrection, trueKernelTailCorrectionIntegrand]
    rw [вЖР hadd_im]
    ring
  ¬Ј -- T < canonical case: use ¬ІCCXLVI with swapped endpoints + the
    -- named `trueKernelTailCorrection_symm` (avoids rewriting raw
    -- `intervalIntegral.integral_symm` inside the full goal вАФ that
    -- forces the unifier to unfold tail/kernel definitions and times out).
    push_neg at hle
    have hle' : T вЙ§ canonicalAdaptiveT z := le_of_lt hle
    have hadd_im :=
      trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
        Dzero T0 hT0_pos hT0_le_10 hTuring
        h10 h140 hy hregime hc.1 hc.2.1 hc.2.2 hle'
    rw [trueKernelTailCorrection_symm Dzero T0 (canonicalAdaptiveT z) T z]
    simp only [trueKernelTailCorrection, trueKernelTailCorrectionIntegrand]
    rw [вЖР hadd_im]
    ring

/-- рЯМЯрЯМЯ **PROVED вАФ `XiLogDerivativeFormulaPieces` from corrected
canonical-T herror.** Like `ofErrorAsCanonicalTail`, but uses
`HErrorCanonicalCorrected` (carrying the explicit finite correction
from ¬ІCCXLVI) instead of the over-strong `htail_indep`. The
`fluctTail_im_eq_trueTail` field is recovered through the bridge
theorem above. -/
noncomputable def XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List вДЭ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (error : вДВ вЖТ вДВ)
    (hmodel : вИА z : вДВ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_corr : HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error) :
    XiLogDerivativeFormulaPieces
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error :=
  XiLogDerivativeFormulaPieces.ofErrorAsFluctTail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M Tsmooth hTsmooth_ge error
    hmodel hxi
    (by
      intro z T h10 h140 hy hregime
      exact fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected
        Dzero T0 hT0_pos hT0_le_10 hTuring error herror_corr
        h10 h140 hy hregime)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **CLEANEST FRONT DOOR (mathematically
honest cutoff handling).** Replaces
`XiPullbackAntiHerglotzTarget_of_errorFormula_canonical` with the
corrected cutoff-dependence interface. No `htail_indep` hypothesis вАФ
