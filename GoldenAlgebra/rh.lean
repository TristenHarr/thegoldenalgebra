  ring

/-! ## BO1.5: Odd integrand `x/(x┬▓+¤ü┬▓)` vanishes on `[-¤ü, ¤ü]` -/

/-- `Ôê½ x in -¤ü..¤ü, x/(x┬▓ + ¤ü┬▓) = 0`.  The antiderivative `(1/2) log(x┬▓ + ¤ü┬▓)`
is even in `x`, so its values at `¤ü` and `-¤ü` agree. -/
theorem integral_x_div_sq_add_sq_symm
    {¤ü : ÔäØ} (h¤ü : 0 < ¤ü) :
    (Ôê½ x in (-¤ü)..¤ü, x / (x ^ 2 + ¤ü ^ 2)) = 0 := by
  have h_pos : ÔêÇ x : ÔäØ, (0 : ÔäØ) < x ^ 2 + ¤ü ^ 2 := fun x => by
    have h1 : (0 : ÔäØ) Ôëñ x ^ 2 := sq_nonneg x
    have h2 : (0 : ÔäØ) < ¤ü ^ 2 := by positivity
    linarith
  have h_cont : Continuous (fun x : ÔäØ => x / (x ^ 2 + ¤ü ^ 2)) := by
    refine Continuous.div continuous_id ?_ ?_
    ┬À exact (continuous_pow 2).add continuous_const
    ┬À intro x; exact ne_of_gt (h_pos x)
  have h_int : IntervalIntegrable
      (fun x : ÔäØ => x / (x ^ 2 + ¤ü ^ 2)) MeasureTheory.volume (-¤ü) ¤ü :=
    h_cont.intervalIntegrable _ _
  have h_deriv : ÔêÇ x Ôêê Set.uIcc (-¤ü) ¤ü,
      HasDerivAt (fun y : ÔäØ => (1/2 : ÔäØ) * Real.log (y ^ 2 + ¤ü ^ 2))
        (x / (x ^ 2 + ¤ü ^ 2)) x := by
    intro x _
    have hpx : (0 : ÔäØ) < x ^ 2 + ¤ü ^ 2 := h_pos x
    have h_ne : (x ^ 2 + ¤ü ^ 2) Ôëá 0 := ne_of_gt hpx
    have h_sq : HasDerivAt (fun y : ÔäØ => y ^ 2 + ¤ü ^ 2) (2 * x) x := by
      simpa using (hasDerivAt_pow 2 x).add_const (¤ü ^ 2)
    have h_log : HasDerivAt (fun y : ÔäØ => Real.log (y ^ 2 + ¤ü ^ 2))
        ((2 * x) / (x ^ 2 + ¤ü ^ 2)) x := h_sq.log h_ne
    have h_half := h_log.const_mul (1/2 : ÔäØ)
    convert h_half using 1
    field_simp
  have hFTC := intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int
  rw [hFTC]
  have h_eq : ((-¤ü : ÔäØ)) ^ 2 + ¤ü ^ 2 = ¤ü ^ 2 + ¤ü ^ 2 := by ring
  rw [h_eq]
  ring

/-! ## BO2: Centered-square edge integrals -/

/-- Bottom edge: `Ôê½ x in -¤ü..¤ü, 1/(x - i¤ü) = (¤Ç/2) * I`. -/
theorem centeredSquare_bottom_eq_pi_over_two_I
    {¤ü : ÔäØ} (h¤ü : 0 < ¤ü) :
    (Ôê½ x in (-¤ü)..¤ü, (1 : Ôäé) / ((x : Ôäé) - (¤ü : Ôäé) * Complex.I))
      = (Real.pi / 2 : Ôäé) * Complex.I := by
  have h_pos : ÔêÇ x : ÔäØ, (0 : ÔäØ) < x ^ 2 + ¤ü ^ 2 := fun x => by
    have h1 : (0 : ÔäØ) Ôëñ x ^ 2 := sq_nonneg x
    have h2 : (0 : ÔäØ) < ¤ü ^ 2 := by positivity
    linarith
  have h_ptwise : ÔêÇ x : ÔäØ,
      (1 : Ôäé) / ((x : Ôäé) - (¤ü : Ôäé) * Complex.I) =
        ((x / (x ^ 2 + ¤ü ^ 2) : ÔäØ) : Ôäé)
          + ((¤ü / (x ^ 2 + ¤ü ^ 2) : ÔäØ) : Ôäé) * Complex.I := by
    intro x
    have hpx_pos : (0 : ÔäØ) < x ^ 2 + ¤ü ^ 2 := h_pos x
    have hpx_ne : (x ^ 2 + ¤ü ^ 2 : ÔäØ) Ôëá 0 := ne_of_gt hpx_pos
    have h_denom : ((x : Ôäé) - (¤ü : Ôäé) * Complex.I) Ôëá 0 := by
      intro h
      have h_im_z : ((x : Ôäé) - (¤ü : Ôäé) * Complex.I).im = 0 := by rw [h]; rfl
      simp at h_im_z
      linarith
    have h_sum_C_ne : ((x : Ôäé) ^ 2 + (¤ü : Ôäé) ^ 2) Ôëá 0 := by
      have h : ((x : Ôäé) ^ 2 + (¤ü : Ôäé) ^ 2) = ((x ^ 2 + ¤ü ^ 2 : ÔäØ) : Ôäé) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpx_ne
    have hI : (Complex.I : Ôäé) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((¤ü : Ôäé) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun x _ => h_ptwise x)]
  have h_cont1 : Continuous (fun x : ÔäØ => ((x / (x ^ 2 + ¤ü ^ 2) : ÔäØ) : Ôäé)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id ?_ ?_
    ┬À exact (continuous_pow 2).add continuous_const
    ┬À intro x; exact ne_of_gt (h_pos x)
  have h_cont2 : Continuous
      (fun x : ÔäØ => ((¤ü / (x ^ 2 + ¤ü ^ 2) : ÔäØ) : Ôäé) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ┬À exact (continuous_pow 2).add continuous_const
    ┬À intro x; exact ne_of_gt (h_pos x)
  have h_int1 := h_cont1.intervalIntegrable (╬╝ := MeasureTheory.volume) (-¤ü) ¤ü
  have h_int2 := h_cont2.intervalIntegrable (╬╝ := MeasureTheory.volume) (-¤ü) ¤ü
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  rw [integral_x_div_sq_add_sq_symm h¤ü, integral_rho_div_sq_add_sq h¤ü]
  push_cast
  ring

/-- Right edge: `(Ôê½ y in -¤ü..¤ü, 1/(¤ü + iy)) ┬À I = (¤Ç/2) ┬À I`. -/
theorem centeredSquare_right_eq_pi_over_two_I
    {¤ü : ÔäØ} (h¤ü : 0 < ¤ü) :
