structure LowCloudTailSplitAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (ZC : Ôäé ÔåÆ Ôäé)
    (finiteCloudContribution : Ôäé ÔåÆ Ôäé)
    (tailContribution : Ôäé ÔåÆ Ôäé) : Prop where
  cloud_exact :
    ÔêÇ z : Ôäé, lowCompactRegion z ÔåÆ
