/-! ### Analytic zero multiplicity interface

Bridge from Mathlib's `analyticOrderAt` (valued in `вДХвИЮ`) to the
`GlobalZeroMultiplicity` interface (valued in `вДХ`).  This layer is
fully no-axiom/no-sorry: it does not assert that nontrivial zeta zeros
have finite positive analytic order вАФ instead it parameterizes the
construction by a witness of that fact, which becomes the real analytic
proof obligation. -/

/-- Alias for `analyticOrderAt`, the order of vanishing of an analytic
function at a point. -/
noncomputable def analyticZeroOrder (f : вДВ вЖТ вДВ) (s : вДВ) : вДХвИЮ :=
  analyticOrderAt f s

/-- A point has finite positive analytic zero order for `f`. -/
def HasFinitePositiveAnalyticZeroOrder (f : вДВ вЖТ вДВ) (s : вДВ) : Prop :=
  вИГ n : вДХ, 0 < n вИІ analyticOrderAt f s = (n : вДХвИЮ)

/-- A point has finite positive analytic zeta-zero multiplicity. -/
def HasFinitePositiveZetaMultiplicity (s : вДВ) : Prop :=
  HasFinitePositiveAnalyticZeroOrder riemannZeta s

/-- A proof that every nontrivial zeta zero has finite positive analytic
order.  This structure asserts nothing unless inhabited; constructing an
inhabitant is the first real analytic theorem obligation. -/
structure ZetaAnalyticMultiplicityWitness where
  finite_positive :
    вИА {s : вДВ}, IsNontrivialZetaZero s вЖТ
      HasFinitePositiveZetaMultiplicity s

open Classical in
/-- The natural-number multiplicity extracted from a
`ZetaAnalyticMultiplicityWitness`. -/
noncomputable def zetaMultiplicityOfWitness
    (W : ZetaAnalyticMultiplicityWitness) (s : вДВ) : вДХ :=
  if hs : IsNontrivialZetaZero s then
    Classical.choose (W.finite_positive hs)
  else
    0

/-- The extracted multiplicity is positive on nontrivial zeta zeros. -/
theorem zetaMultiplicityOfWitness_pos
    (W : ZetaAnalyticMultiplicityWitness)
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    0 < zetaMultiplicityOfWitness W s := by
  unfold zetaMultiplicityOfWitness
  rw [dif_pos hs]
  exact (Classical.choose_spec (W.finite_positive hs)).1

/-- The extracted multiplicity matches the analytic order of vanishing of
`riemannZeta` at every nontrivial zero. -/
theorem zetaMultiplicityOfWitness_order_eq
    (W : ZetaAnalyticMultiplicityWitness)
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    analyticOrderAt riemannZeta s =
      (zetaMultiplicityOfWitness W s : вДХвИЮ) := by
  unfold zetaMultiplicityOfWitness
  rw [dif_pos hs]
  exact (Classical.choose_spec (W.finite_positive hs)).2

/-- The `GlobalZeroMultiplicity` instance derived from a
`ZetaAnalyticMultiplicityWitness`. -/
noncomputable def zetaGlobalZeroMultiplicityOfWitness
    (W : ZetaAnalyticMultiplicityWitness) :
    GlobalZeroMultiplicity where
  mult := zetaMultiplicityOfWitness W
  positive_of_isNontrivialZetaZero := by
    intro s hs
    exact zetaMultiplicityOfWitness_pos W hs

/-! ### First analytic facts about nontrivial zeta zeros

Decomposition of the eventual `zetaAnalyticMultiplicityWitness` proof:

  1. Nontrivial zeros are not the pole `1`               (this section).
  2. `riemannZeta` is analytic at every `s вЙ† 1`.
  3. `riemannZeta` is not locally identically zero
     at any nontrivial zero.
  4. `analyticOrderAt riemannZeta s` is finite (вЙ† вК§) at a nontrivial zero.
  5. `analyticOrderAt riemannZeta s вЙ† 0` since `ќґ(s) = 0`.
  6. Combine into `ZetaAnalyticMultiplicityWitness`.

Only step (1) is added here.  Steps (2)вАУ(5) need probing of Mathlib's
`riemannZeta` analyticity and `analyticOrderAt` API in a live session. -/

/-- A nontrivial zeta zero is not the pole `1`. -/
theorem isNontrivialZetaZero_ne_one
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    s вЙ† 1 := by
  intro h
  have hre : s.re = 1 := by
    rw [h]; norm_num
  linarith [hs.2.2]

/-! ### Structural helpers around the analytic multiplicity witness -/

/-- A nontrivial zeta zero gives a positive finite analytic zeta
multiplicity once its analytic order is known to be a finite positive
natural value. -/
theorem hasFinitePositiveZetaMultiplicity_of_order_eq
    {s : вДВ} {n : вДХ}
    (hn : 0 < n)
    (horder : analyticOrderAt riemannZeta s = (n : вДХвИЮ)) :
    HasFinitePositiveZetaMultiplicity s :=
  вЯ®n, hn, horderвЯ©

/-- If the zeta analytic multiplicity witness is available, then every
nontrivial zero has positive multiplicity in the induced global model. -/
theorem zetaGlobalZeroMultiplicityOfWitness_pos
    (W : ZetaAnalyticMultiplicityWitness)
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    0 < (zetaGlobalZeroMultiplicityOfWitness W).mult s :=
  zetaMultiplicityOfWitness_pos W hs

/-- If the zeta analytic multiplicity witness is available, then the
induced multiplicity agrees with Mathlib's analytic order at every
nontrivial zero. -/
theorem zetaGlobalZeroMultiplicityOfWitness_order_eq
    (W : ZetaAnalyticMultiplicityWitness)
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    analyticOrderAt riemannZeta s =
      ((zetaGlobalZeroMultiplicityOfWitness W).mult s : вДХвИЮ) :=
  zetaMultiplicityOfWitness_order_eq W hs

/-- `riemannZeta` is analytic at every point off its pole at `1`. -/
theorem riemannZeta_analyticAt_of_ne_one
    {p : вДВ} (hp : p вЙ† 1) :
    AnalyticAt вДВ riemannZeta p := by
  have hOpen : IsOpen ({1}бґЬ : Set вДВ) := isClosed_singleton.isOpen_compl
  have hDiff : DifferentiableOn вДВ riemannZeta ({1}бґЬ : Set вДВ) :=
    fun z hz => (differentiableAt_riemannZeta hz).differentiableWithinAt
  exact hDiff.analyticAt (hOpen.mem_nhds (hp : p вИИ ({1}бґЬ : Set вДВ)))

/-- The Riemann zeta function is analytic at every nontrivial zero
(corollary of `riemannZeta_analyticAt_of_ne_one`). -/
theorem riemannZeta_analyticAt_of_isNontrivialZetaZero
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    AnalyticAt вДВ riemannZeta s :=
  riemannZeta_analyticAt_of_ne_one (isNontrivialZetaZero_ne_one hs)

/-- **Step 2 (generalized).** The Riemann zeta function is not locally
identically zero at any point off its pole.  Proof: if it were
eventually zero near `p`, then by the analytic identity theorem on the
preconnected open set `вДВ \ {1}` (ќґ is analytic there, вДВ \ {pt} has
real-rank > 1 hence preconnected), ќґ would vanish on all of `вДВ \ {1}` вАФ
contradicting `riemannZeta 2 вЙ† 0`. -/
theorem riemannZeta_not_eventuallyEq_zero_of_ne_one
    {p : вДВ} (hp : p вЙ† 1) :
    ¬ђ riemannZeta =бґ†[рЭУЭ p] 0 := by
  intro hlocal
  have hp_mem : p вИИ ({1}бґЬ : Set вДВ) := hp
  have hOpen : IsOpen ({1}бґЬ : Set вДВ) := isClosed_singleton.isOpen_compl
  have hPre : IsPreconnected ({(1 : вДВ)}бґЬ : Set вДВ) :=
    (isConnected_compl_singleton_of_one_lt_rank (by simp) (1 : вДВ)).isPreconnected
  have hAnalytic : AnalyticOnNhd вДВ riemannZeta ({1}бґЬ : Set вДВ) := by
    intro z hz
    have hDiff : DifferentiableOn вДВ riemannZeta ({1}бґЬ : Set вДВ) :=
      fun w hw => (differentiableAt_riemannZeta hw).differentiableWithinAt
    exact hDiff.analyticAt (hOpen.mem_nhds hz)
  have hZero_on : Set.EqOn riemannZeta 0 ({1}бґЬ : Set вДВ) :=
    hAnalytic.eqOn_zero_of_preconnected_of_eventuallyEq_zero hPre hp_mem hlocal
  have htwo_ne_one : (2 : вДВ) вЙ† 1 := by
    intro h
    have hre : (2 : вДВ).re = (1 : вДВ).re := congrArg Complex.re h
    simp at hre
  have htwo_mem : (2 : вДВ) вИИ ({1}бґЬ : Set вДВ) := htwo_ne_one
  have hZeta_two_zero : riemannZeta (2 : вДВ) = 0 := by
    have h := hZero_on htwo_mem
    simp at h
    exact h
  have hZeta_two_ne : riemannZeta (2 : вДВ) вЙ† 0 := by
    apply riemannZeta_ne_zero_of_one_lt_re
    show (1 : вДЭ) < (2 : вДВ).re
    norm_num
  exact hZeta_two_ne hZeta_two_zero

/-- **Step 2 (corollary).** Specialization to nontrivial zeta zeros via
`isNontrivialZetaZero_ne_one`. -/
theorem riemannZeta_not_eventuallyEq_zero_at_nontrivial_zero
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    ¬ђ riemannZeta =бґ†[рЭУЭ s] 0 :=
  riemannZeta_not_eventuallyEq_zero_of_ne_one
    (isNontrivialZetaZero_ne_one hs)

/-! ### Finite positive analytic order of nontrivial zeta zeros -/

/-- **Steps 3-4.** At a nontrivial zeta zero, the analytic order of
`riemannZeta` is finite (not `вК§`) and positive (not `0`).  Combined
with `Nat.cast_analyticOrderNatAt`, this gives the natural-number
witness needed for `HasFinitePositiveZetaMultiplicity`. -/
theorem hasFinitePositiveZetaMultiplicity_of_isNontrivialZetaZero
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    HasFinitePositiveZetaMultiplicity s := by
  have hAn : AnalyticAt вДВ riemannZeta s :=
    riemannZeta_analyticAt_of_isNontrivialZetaZero hs
  have hNotLocal : ¬ђ riemannZeta =бґ†[рЭУЭ s] 0 :=
    riemannZeta_not_eventuallyEq_zero_at_nontrivial_zero hs
  have hzero : riemannZeta s = 0 := hs.1
  have hnot_top : analyticOrderAt riemannZeta s вЙ† вК§ := fun htop =>
    hNotLocal (analyticOrderAt_eq_top.mp htop)
  have hnot_zero : analyticOrderAt riemannZeta s вЙ† 0 := fun hzero_order =>
    (hAn.analyticOrderAt_eq_zero.mp hzero_order) hzero
  refine вЯ®analyticOrderNatAt riemannZeta s, ?_,
    (Nat.cast_analyticOrderNatAt hnot_top).symmвЯ©
  by_contra hn_not_pos
  push_neg at hn_not_pos
  have hn_zero : analyticOrderNatAt riemannZeta s = 0 := by omega
  apply hnot_zero
  rw [вЖР Nat.cast_analyticOrderNatAt hnot_top, hn_zero]
  simp

/-! ### Step 5: the zeta analytic multiplicity witness -/

/-- **Step 5.** Every nontrivial zeta zero has finite positive analytic
multiplicity.  This is the bridge from abstract multiplicities to
actual analytic zeta-zero multiplicities. -/
theorem zetaAnalyticMultiplicityWitness :
    ZetaAnalyticMultiplicityWitness where
  finite_positive := by
    intro s hs
    exact hasFinitePositiveZetaMultiplicity_of_isNontrivialZetaZero hs

/-! ### Step 6: the actual zeta global zero-multiplicity model -/

/-- **Step 6.** The actual global multiplicity model for nontrivial zeta
zeros, obtained from Mathlib's analytic order of vanishing. -/
noncomputable def zetaGlobalZeroMultiplicity : GlobalZeroMultiplicity :=
  zetaGlobalZeroMultiplicityOfWitness zetaAnalyticMultiplicityWitness

/-- Actual zeta multiplicity is positive at every nontrivial zeta
zero. -/
theorem zetaGlobalZeroMultiplicity_pos
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    0 < zetaGlobalZeroMultiplicity.mult s :=
  zetaGlobalZeroMultiplicityOfWitness_pos
    zetaAnalyticMultiplicityWitness hs

/-- Actual zeta multiplicity agrees with analytic order at every
nontrivial zeta zero. -/
theorem zetaGlobalZeroMultiplicity_order_eq
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    analyticOrderAt riemannZeta s =
      (zetaGlobalZeroMultiplicity.mult s : вДХвИЮ) :=
  zetaGlobalZeroMultiplicityOfWitness_order_eq
    zetaAnalyticMultiplicityWitness hs

/-! ### Finite zero-set target: bounding rectangle

First brick toward `zeroSetUpToHeight_exists`: the closed rectangle
`{ s : вДВ | 0 вЙ§ s.re вЙ§ 1 вИІ 0 вЙ§ s.im вЙ§ T }` contains the zero-counting
set `IsZetaZeroUpToHeight T`.  Compactness of this rectangle plus
analytic isolated-zero theory will later give finiteness. -/

/-- Closed rectangle containing the nontrivial zeta zeros counted up to
height `T`. -/
def closedCriticalRectangle (T : вДЭ) : Set вДВ :=
  {s : вДВ | 0 вЙ§ s.re вИІ s.re вЙ§ 1 вИІ 0 вЙ§ s.im вИІ s.im вЙ§ T}

/-- The set of nontrivial zeta zeros counted up to height `T`. -/
def zetaZerosUpToHeightSet (T : вДЭ) : Set вДВ :=
  {s : вДВ | IsZetaZeroUpToHeight T s}

/-- A nontrivial zeta zero counted up to height `T` lies in the closed
critical rectangle. -/
theorem isZetaZeroUpToHeight_mem_closedCriticalRectangle
    {T : вДЭ} {s : вДВ}
    (hs : IsZetaZeroUpToHeight T s) :
    s вИИ closedCriticalRectangle T := by
  rcases hs with вЯ®hzero, him_pos, him_leвЯ©
  rcases hzero with вЯ®_, hre_pos, hre_ltвЯ©
  exact вЯ®le_of_lt hre_pos, le_of_lt hre_lt, le_of_lt him_pos, him_leвЯ©

/-- The zero-counting set is contained in the closed critical
rectangle. -/
theorem zetaZerosUpToHeightSet_subset_rectangle
    (T : вДЭ) :
    zetaZerosUpToHeightSet T вКЖ closedCriticalRectangle T := by
  intro s hs
  exact isZetaZeroUpToHeight_mem_closedCriticalRectangle hs

/-- The closed critical rectangle is closed in вДВ.  Intersection of four
closed half-planes via `isClosed_le` and continuity of `Complex.re` /
`Complex.im`. -/
theorem isClosed_closedCriticalRectangle (T : вДЭ) :
    IsClosed (closedCriticalRectangle T) := by
  have h_eq : closedCriticalRectangle T =
      {s : вДВ | 0 вЙ§ s.re} вИ© {s | s.re вЙ§ 1} вИ©
        {s | 0 вЙ§ s.im} вИ© {s | s.im вЙ§ T} := by
    ext s
    simp [closedCriticalRectangle, and_assoc]
  rw [h_eq]
  exact (((isClosed_le continuous_const Complex.continuous_re).inter
    (isClosed_le Complex.continuous_re continuous_const)).inter
    (isClosed_le continuous_const Complex.continuous_im)).inter
    (isClosed_le Complex.continuous_im continuous_const)

/-- The closed critical rectangle is bounded: contained in the closed
ball of radius `1 + max 0 T` around the origin via
`Complex.norm_le_abs_re_add_abs_im`. -/
theorem isBounded_closedCriticalRectangle (T : вДЭ) :
    Bornology.IsBounded (closedCriticalRectangle T) := by
  apply (Metric.isBounded_closedBall (x := (0 : вДВ)) (r := 1 + max 0 T)).subset
  intro s hs
  rcases hs with вЯ®h1, _h2, h3, h4вЯ©
  rw [Metric.mem_closedBall, dist_zero_right]
  have hTle : s.im вЙ§ max 0 T := le_max_of_le_right h4
  calc вАЦsвАЦ
      вЙ§ |s.re| + |s.im| := Complex.norm_le_abs_re_add_abs_im s
    _ = s.re + s.im := by rw [abs_of_nonneg h1, abs_of_nonneg h3]
    _ вЙ§ 1 + max 0 T := by linarith

/-- **Step B.** The closed critical rectangle is compact (HeineвАУBorel:
closed and bounded in the proper space вДВ). -/
theorem isCompact_closedCriticalRectangle (T : вДЭ) :
    IsCompact (closedCriticalRectangle T) :=
  Metric.isCompact_iff_isClosed_bounded.mpr
    вЯ®isClosed_closedCriticalRectangle T, isBounded_closedCriticalRectangle TвЯ©

/-! ### Local finiteness of counted zeta zeros -/

/-- **Step C1.** If `riemannZeta` is analytic at `p` and nonzero at `p`,
then near `p` there are no counted zeta zeros: continuity propagates the
nonzero value locally. -/
theorem zetaZerosUpToHeightSet_eventually_empty_of_analytic_ne_zero
    {T : вДЭ} {p : вДВ}
    (hAn : AnalyticAt вДВ riemannZeta p)
    (hp : riemannZeta p вЙ† 0) :
    вИГ U вИИ рЭУЭ p, вИА z вИИ U, z вИЙ zetaZerosUpToHeightSet T := by
  have hcont : ContinuousAt riemannZeta p := hAn.continuousAt
  have hEventually_ne : вИАбґ† z in рЭУЭ p, riemannZeta z вЙ† 0 := hcont.eventually_ne hp
  refine вЯ®{z : вДВ | riemannZeta z вЙ† 0}, hEventually_ne, ?_вЯ©
  intro z hz hzset
  exact hz hzset.1.1

/-- **Step C2.** A zero-free neighborhood gives a finite (empty) local
intersection with the counted zero set. -/
theorem zetaZerosUpToHeightSet_finite_inter_of_eventually_empty
    {T : вДЭ}
    {U : Set вДВ}
    (hU : вИА z вИИ U, z вИЙ zetaZerosUpToHeightSet T) :
    Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  have hempty : U вИ© zetaZerosUpToHeightSet T = вИЕ := by
    ext z
    refine вЯ®?_, ?_вЯ©
    ¬Ј rintro вЯ®hzU, hzsetвЯ©
      exact (hU z hzU) hzset
    ¬Ј intro hz
      exact absurd hz (Set.notMem_empty z)
  rw [hempty]
  exact Set.finite_empty

/-- If `riemannZeta` is analytic and nonzero at `p`, then the counted
zero set is locally finite near `p`. -/
theorem zetaZerosUpToHeightSet_locallyFinite_of_analytic_ne_zero
    {T : вДЭ} {p : вДВ}
    (hAn : AnalyticAt вДВ riemannZeta p)
    (hp : riemannZeta p вЙ† 0) :
    вИГ U вИИ рЭУЭ p, Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  obtain вЯ®U, hU_nhds, hU_emptyвЯ© :=
    zetaZerosUpToHeightSet_eventually_empty_of_analytic_ne_zero (T := T) hAn hp
  exact вЯ®U, hU_nhds,
    zetaZerosUpToHeightSet_finite_inter_of_eventually_empty hU_emptyвЯ©

/-- **Step C3.** If `riemannZeta` is analytic at `p`, vanishes at `p`,
and is not locally identically zero there, then the counted zero set
is locally finite near `p`.  Uses the *principle of isolated zeros*
(`AnalyticAt.eventually_eq_zero_or_eventually_ne_zero`): the only
counted zero in a small enough neighborhood of `p` can be `p` itself. -/
theorem zetaZerosUpToHeightSet_locallyFinite_of_analytic_zero_not_local
    {T : вДЭ} {p : вДВ}
    (hAn : AnalyticAt вДВ riemannZeta p)
    (_hpzero : riemannZeta p = 0)
    (hNotLocal : ¬ђ riemannZeta =бґ†[рЭУЭ p] 0) :
    вИГ U вИИ рЭУЭ p, Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  rcases hAn.eventually_eq_zero_or_eventually_ne_zero with hlocal | hpunct
  ¬Ј exact absurd hlocal hNotLocal
  -- `hpunct : вИАбґ† z in рЭУЭ[вЙ†] p, riemannZeta z вЙ† 0`.  Lift to ordinary nhd.
  rw [eventually_nhdsWithin_iff] at hpunct
  refine вЯ®{z : вДВ | z вИИ ({p}бґЬ : Set вДВ) вЖТ riemannZeta z вЙ† 0}, hpunct, ?_вЯ©
  apply Set.Finite.subset (Set.finite_singleton p)
  rintro z вЯ®hzU, hzsetвЯ©
  by_cases hzp : z = p
  ¬Ј simp [hzp]
  ¬Ј have hzmem : z вИИ ({p}бґЬ : Set вДВ) := hzp
    exact absurd hzset.1.1 (hzU hzmem)

/-- C3 specialized to counted zeros: every counted zero has a
neighborhood with only finitely many counted zeros. -/
theorem zetaZerosUpToHeightSet_locallyFinite_of_counted_zero
    {T : вДЭ} {p : вДВ}
    (hp : IsZetaZeroUpToHeight T p) :
    вИГ U вИИ рЭУЭ p, Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  have hpNT : IsNontrivialZetaZero p := hp.1
  exact
    zetaZerosUpToHeightSet_locallyFinite_of_analytic_zero_not_local
      (T := T)
      (riemannZeta_analyticAt_of_isNontrivialZetaZero hpNT)
      hpNT.1
      (riemannZeta_not_eventuallyEq_zero_at_nontrivial_zero hpNT)

/-! ### Step C4: local finiteness at the pole `1` -/

/-- **Step C4.1.** Near the pole `s = 1`, in any punctured neighborhood,
`riemannZeta` is nonzero.  Uses `riemannZeta_residue_one`:
`(s - 1) * ќґ(s) вЖТ 1` in `рЭУЭ[вЙ†] 1`.  Since `1 вЙ† 0`, eventually the
product is nonzero, hence so is `ќґ(s)`. -/
theorem riemannZeta_eventually_ne_zero_nhdsWithin_ne_one :
    вИАбґ† z in рЭУЭ[вЙ†] (1 : вДВ), riemannZeta z вЙ† 0 := by
  have hprod_ne : вИАбґ† z in рЭУЭ[вЙ†] (1 : вДВ), (z - 1) * riemannZeta z вЙ† 0 :=
    riemannZeta_residue_one.eventually_ne (by norm_num : (1 : вДВ) вЙ† 0)
  filter_upwards [hprod_ne] with z hzprod hzeta_zero
  rw [hzeta_zero, mul_zero] at hzprod
  exact hzprod rfl

/-- **Step C4.2.** The counted zeta zero set is locally finite near the
pole `1`. -/
theorem zetaZerosUpToHeightSet_locallyFinite_at_one
    {T : вДЭ} :
    вИГ U вИИ рЭУЭ (1 : вДВ), Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  have hpunct := riemannZeta_eventually_ne_zero_nhdsWithin_ne_one
  rw [eventually_nhdsWithin_iff] at hpunct
  refine вЯ®{z : вДВ | z вИИ ({1}бґЬ : Set вДВ) вЖТ riemannZeta z вЙ† 0}, hpunct, ?_вЯ©
  apply Set.Finite.subset (Set.finite_singleton (1 : вДВ))
  rintro z вЯ®hzU, hzsetвЯ©
  by_cases hz_eq_one : z = 1
  ¬Ј simp [hz_eq_one]
  ¬Ј have hzmem : z вИИ ({1}бґЬ : Set вДВ) := hz_eq_one
    exact absurd hzset.1.1 (hzU hzmem)

/-! ### Step C5: local finiteness everywhere on the rectangle -/

/-- **Step C5.** The counted zeta zeros are locally finite at every point
of the closed critical rectangle: split on whether the point is the pole
`1` or, off the pole, whether `riemannZeta` vanishes there. -/
theorem zetaZerosUpToHeightSet_locallyFinite_on_rectangle
    (T : вДЭ) :
    вИА p вИИ closedCriticalRectangle T,
      вИГ U вИИ рЭУЭ p, Set.Finite (U вИ© zetaZerosUpToHeightSet T) := by
  intro p _hpRect
  by_cases hp_one : p = 1
  ¬Ј subst hp_one
    exact zetaZerosUpToHeightSet_locallyFinite_at_one
  ¬Ј have hAn : AnalyticAt вДВ riemannZeta p := riemannZeta_analyticAt_of_ne_one hp_one
    by_cases hpzero : riemannZeta p = 0
    ¬Ј exact
        zetaZerosUpToHeightSet_locallyFinite_of_analytic_zero_not_local
          (T := T) hAn hpzero
          (riemannZeta_not_eventuallyEq_zero_of_ne_one hp_one)
    ¬Ј exact
        zetaZerosUpToHeightSet_locallyFinite_of_analytic_ne_zero
          (T := T) hAn hpzero

/-! ### Compactness + local finiteness вЗТ global finiteness -/

/-- **Step D1.** If a set `Z` is contained in a compact set `K` and around
every point of `K` there is a neighborhood whose intersection with `Z`
is finite, then `Z` is finite.  General topology lemma: finite subcover
of `K` provides a finite cover of `Z`, and a finite union of finite
intersections is finite. -/
theorem Set.Finite.of_subset_isCompact_of_locallyFinite_nhds
    {ќ± : Type*} [TopologicalSpace ќ±]
    {Z K : Set ќ±}
    (hK : IsCompact K)
    (hZK : Z вКЖ K)
    (hlocal : вИА p вИИ K, вИГ U вИИ рЭУЭ p, Set.Finite (U вИ© Z)) :
    Set.Finite Z := by
  classical
  choose! V hV_nhds hV_finite using hlocal
  obtain вЯ®t, ht_sub, ht_coverвЯ© := hK.elim_nhds_subcover V hV_nhds
  have hZsubset : Z вКЖ вЛГ p вИИ t, V p вИ© Z := by
    intro z hz
    have hzK : z вИИ K := hZK hz
    obtain вЯ®p, hpt, hzVpвЯ© := Set.mem_iUnionвВВ.mp (ht_cover hzK)
    exact Set.mem_iUnionвВВ.mpr вЯ®p, hpt, hzVp, hzвЯ©
  refine Set.Finite.subset ?_ hZsubset
  refine Set.Finite.biUnion t.finite_toSet ?_
  intro p hp
  exact hV_finite p (ht_sub p hp)

/-- **Step D2.** The set of counted nontrivial zeta zeros up to height
`T` is finite.  Combines compactness of the closed critical rectangle,
the subset inclusion, and the on-rectangle local finiteness. -/
theorem zetaZerosUpToHeightSet_finite
    (T : вДЭ) (_hT : 0 вЙ§ T) :
    Set.Finite (zetaZerosUpToHeightSet T) :=
  Set.Finite.of_subset_isCompact_of_locallyFinite_nhds
    (K := closedCriticalRectangle T)
    (isCompact_closedCriticalRectangle T)
    (zetaZerosUpToHeightSet_subset_rectangle T)
    (zetaZerosUpToHeightSet_locallyFinite_on_rectangle T)

/-- **Step D3.** A canonical finite zero-set certificate up to height
`T`, obtained from finiteness of the counted zeta zero set. -/
noncomputable def zeroSetUpToHeightOfFinite
    (T : вДЭ) (hT : 0 вЙ§ T) :
    ZeroSetUpToHeight T where
  zeros := (zetaZerosUpToHeightSet_finite T hT).toFinset
  complete := by
    intro s
    rw [Set.Finite.mem_toFinset]
    rfl

/-- **Step D4.** A completed finite zero-set certificate exists at every
nonnegative height. -/
theorem zeroSetUpToHeight_exists
    (T : вДЭ) (hT : 0 вЙ§ T) :
    Nonempty (ZeroSetUpToHeight T) :=
  вЯ®zeroSetUpToHeightOfFinite T hTвЯ©

/-! ### Actual zeta zero count and fluctuation `S(T)` -/

/-- **E1.** Canonical completed finite zero-set certificate for height
`T вЙ• 0`. -/
noncomputable def zetaZeroSetUpToHeight
    (T : вДЭ) (hT : 0 вЙ§ T) :
    ZeroSetUpToHeight T :=
  zeroSetUpToHeightOfFinite T hT

/-- **E2.** Actual multiplicity-weighted count of nontrivial zeta zeros
with `0 < Im(s) вЙ§ T`, using the analytic-order multiplicity model
`zetaGlobalZeroMultiplicity`. -/
noncomputable def zetaWeightedZeroCountUpToHeight
    (T : вДЭ) (hT : 0 вЙ§ T) : вДХ :=
  weightedZeroCountFromCertificate
    (weightedZeroSetOfGlobalMultiplicity
      zetaGlobalZeroMultiplicity
      (zetaZeroSetUpToHeight T hT))

/-- The actual weighted zero count agrees with the count computed from
any completed zero-set certificate at the same height. -/
theorem zetaWeightedZeroCountUpToHeight_eq_of_certificate
    {T : вДЭ} (hT : 0 вЙ§ T)
    (Z : ZeroSetUpToHeight T) :
    zetaWeightedZeroCountUpToHeight T hT =
      weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity
          zetaGlobalZeroMultiplicity Z) := by
  unfold zetaWeightedZeroCountUpToHeight
  apply weightedZeroCountFromCertificate_eq_of_mult_eq
  intro s _hs
  rfl

/-- **E3.** Actual zero-counting fluctuation

  `S(T) = N(T) вИТ NвВА(T)`,

where `N(T)` is the analytic-multiplicity-weighted nontrivial zeta-zero
count and `NвВА(T)` is the smooth RiemannвАУvon Mangoldt main term.  For
`T < 0`, the count is taken to be `0`. -/
noncomputable def concreteS (T : вДЭ) : вДЭ :=
  if hT : 0 вЙ§ T then
    (zetaWeightedZeroCountUpToHeight T hT : вДЭ) - smoothMainTerm T
  else
    - smoothMainTerm T

/-- **E4.** On nonnegative heights, `concreteS T` is the weighted zero
count minus the smooth main term. -/
theorem concreteS_eq_weighted_count_sub_smoothMainTerm
    {T : вДЭ} (hT : 0 вЙ§ T) :
    concreteS T =
      (zetaWeightedZeroCountUpToHeight T hT : вДЭ) - smoothMainTerm T := by
  unfold concreteS
  simp [hT]

/-- **E5.** For any completed zero-set certificate at a nonnegative
height, `concreteS` equals the corresponding analytic-weighted count
minus the smooth main term. -/
theorem concreteS_eq_certificate_weighted_count_sub_smoothMainTerm
    {T : вДЭ} (hT : 0 вЙ§ T)
    (Z : ZeroSetUpToHeight T) :
    concreteS T =
      (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity
          zetaGlobalZeroMultiplicity Z) : вДЭ)
        - smoothMainTerm T := by
  rw [concreteS_eq_weighted_count_sub_smoothMainTerm hT,
      zetaWeightedZeroCountUpToHeight_eq_of_certificate hT Z]

/-- **E6.** The actual weighted zero count is monotone in the height
parameter. -/
theorem zetaWeightedZeroCountUpToHeight_mono
    {TвВБ TвВВ : вДЭ}
    (hTвВБ : 0 вЙ§ TвВБ) (hTвВВ : 0 вЙ§ TвВВ)
    (h12 : TвВБ вЙ§ TвВВ) :
    zetaWeightedZeroCountUpToHeight TвВБ hTвВБ вЙ§
      zetaWeightedZeroCountUpToHeight TвВВ hTвВВ := by
  unfold zetaWeightedZeroCountUpToHeight
  exact
    weightedZeroCountOfGlobalMultiplicity_le_of_le
      zetaGlobalZeroMultiplicity h12
      (zetaZeroSetUpToHeight TвВБ hTвВБ)
      (zetaZeroSetUpToHeight TвВВ hTвВВ)

/-- If the cumulative weighted zero count has the same value at the two
endpoints of an interval, monotonicity forces it to have that value
throughout the interval. -/
theorem zetaWeightedZeroCountUpToHeight_eq_of_endpoint_eq
    {A B T : вДЭ} {count : вДХ}
    (hA0 : 0 вЙ§ A) (hT0 : 0 вЙ§ T) (hB0 : 0 вЙ§ B)
    (hAT : A вЙ§ T) (hTB : T вЙ§ B)
    (hAcount : zetaWeightedZeroCountUpToHeight A hA0 = count)
    (hBcount : zetaWeightedZeroCountUpToHeight B hB0 = count) :
    zetaWeightedZeroCountUpToHeight T hT0 = count := by
  have hA_le_T :
      zetaWeightedZeroCountUpToHeight A hA0 вЙ§
        zetaWeightedZeroCountUpToHeight T hT0 :=
    zetaWeightedZeroCountUpToHeight_mono hA0 hT0 hAT
  have hT_le_B :
      zetaWeightedZeroCountUpToHeight T hT0 вЙ§
        zetaWeightedZeroCountUpToHeight B hB0 :=
    zetaWeightedZeroCountUpToHeight_mono hT0 hB0 hTB
  omega

/-- **E7.** Actual multiplicity-weighted zero count in the height slab
`(A, B]`. -/
noncomputable def zetaWeightedZeroCountInHeightSlab
    (A B : вДЭ) (hA : 0 вЙ§ A) (hAB : A вЙ§ B) : вДХ :=
  weightedZeroCountInHeightSlabFromCertificate
    (weightedZeroSetInHeightSlabOfDifference
      zetaGlobalZeroMultiplicity
      hA hAB
      (zetaZeroSetUpToHeight A hA)
      (zetaZeroSetUpToHeight B (le_trans hA hAB)))

/-- The actual weighted zero count in `(A, B]` is the cumulative
difference `N(B) вИТ N(A)`. -/
theorem zetaWeightedZeroCountInHeightSlab_eq_sub
    {A B : вДЭ} (hA : 0 вЙ§ A) (hAB : A вЙ§ B) :
    zetaWeightedZeroCountInHeightSlab A B hA hAB =
      zetaWeightedZeroCountUpToHeight B (le_trans hA hAB)
        - zetaWeightedZeroCountUpToHeight A hA := by
  unfold zetaWeightedZeroCountInHeightSlab zetaWeightedZeroCountUpToHeight
  exact
    weightedZeroCountInHeightSlabOfDifference_eq_sub
      zetaGlobalZeroMultiplicity hA hAB
      (zetaZeroSetUpToHeight A hA)
      (zetaZeroSetUpToHeight B (le_trans hA hAB))

/-- If a slab `(A, B]` has certified weighted count `slabCount`, then a
known cumulative count at `A` propagates to the cumulative count at `B`.
This is the arithmetic bridge from Turing interval counts to endpoint
counts. -/
theorem zetaWeightedZeroCountUpToHeight_right_eq_of_left_eq_slab_count
    {A B : вДЭ} {leftCount slabCount : вДХ}
    (hA : 0 вЙ§ A) (hAB : A вЙ§ B)
    (hleft :
      zetaWeightedZeroCountUpToHeight A hA = leftCount)
    (hslab :
      zetaWeightedZeroCountInHeightSlab A B hA hAB = slabCount) :
    zetaWeightedZeroCountUpToHeight B (le_trans hA hAB)
      = leftCount + slabCount := by
  have hsub :
      zetaWeightedZeroCountUpToHeight B (le_trans hA hAB)
        - zetaWeightedZeroCountUpToHeight A hA = slabCount := by
    rw [вЖР zetaWeightedZeroCountInHeightSlab_eq_sub hA hAB]
    exact hslab
  have hmono :
      zetaWeightedZeroCountUpToHeight A hA вЙ§
        zetaWeightedZeroCountUpToHeight B (le_trans hA hAB) :=
    zetaWeightedZeroCountUpToHeight_mono hA (le_trans hA hAB) hAB
  omega

/-! ### RiemannвАУvon Mangoldt decomposition interface -/

/-- **F1.** The smooth RiemannвАУvon Mangoldt main term used in the
zero-counting formula (alias of `smoothMainTerm`). -/
noncomputable def riemannVonMangoldtMainTerm (T : вДЭ) : вДЭ :=
  smoothMainTerm T

/-- The concrete fluctuation is `N(T) вИТ NвВА(T)` at nonnegative heights. -/
theorem concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm
    {T : вДЭ} (hT : 0 вЙ§ T) :
    concreteS T =
      (zetaWeightedZeroCountUpToHeight T hT : вДЭ)
        - riemannVonMangoldtMainTerm T := by
  simpa [riemannVonMangoldtMainTerm]
    using concreteS_eq_weighted_count_sub_smoothMainTerm hT

/-- **F2.** A RiemannвАУvon Mangoldt argument term: a real-valued function
that agrees with `concreteS` on nonnegative heights.  Constructing an
inhabitant is what an actual argument-principle / contour computation
must provide. -/
structure RiemannVonMangoldtArgumentTerm where
  Sarg : вДЭ вЖТ вДЭ
  agrees_with_concreteS :
    вИА T : вДЭ, 0 вЙ§ T вЖТ Sarg T = concreteS T

/-- **F3.** A proved RiemannвАУvon Mangoldt formula package: the actual
zeta zero count `N(T)` decomposes as `NвВА(T) + Sarg T` for some explicit
argument-term function. -/
structure ProvenRiemannVonMangoldtFormula where
  Sarg : вДЭ вЖТ вДЭ
  formula :
    вИА (T : вДЭ) (hT : 0 вЙ§ T),
      (zetaWeightedZeroCountUpToHeight T hT : вДЭ)
        =
      riemannVonMangoldtMainTerm T + Sarg T

namespace ProvenRiemannVonMangoldtFormula

/-- **F4.** In a proved RiemannвАУvon Mangoldt formula the argument term
agrees with `concreteS` on nonnegative heights. -/
theorem Sarg_eq_concreteS
    (F : ProvenRiemannVonMangoldtFormula)
    {T : вДЭ} (hT : 0 вЙ§ T) :
    F.Sarg T = concreteS T := by
  have hN :
      (zetaWeightedZeroCountUpToHeight T hT : вДЭ)
        =
      riemannVonMangoldtMainTerm T + F.Sarg T :=
    F.formula T hT
  have hS :
      concreteS T =
        (zetaWeightedZeroCountUpToHeight T hT : вДЭ)
          - riemannVonMangoldtMainTerm T :=
    concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm hT
  linarith

/-- Convert a proved RiemannвАУvon Mangoldt formula into the simpler
agreement package. -/
noncomputable def toArgumentTerm
    (F : ProvenRiemannVonMangoldtFormula) :
    RiemannVonMangoldtArgumentTerm where
  Sarg := F.Sarg
  agrees_with_concreteS := by
    intro T hT
    exact F.Sarg_eq_concreteS hT

end ProvenRiemannVonMangoldtFormula

/-- **F5.** A Backlund-style bound on an argument term.  Carries the
lower-threshold constraint `2ѕА вЙ§ lower` and the half-log-plus-half
inequality. -/
structure BacklundArgumentBound (Sarg : вДЭ вЖТ вДЭ) where
  lower : вДЭ
  lower_ge_two_pi : 2 * Real.pi вЙ§ lower
  bound :
    вИА T : вДЭ, lower вЙ§ T вЖТ
      |Sarg T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2

/-- **F6.** A proved RiemannвАУvon Mangoldt formula together with a
Backlund bound on its argument term gives the final concrete
Backlund/Turing bound package for `concreteS`. -/
noncomputable def ProvenRiemannVonMangoldtFormula.toProvenBacklundTuringBound
    (F : ProvenRiemannVonMangoldtFormula)
    (B : BacklundArgumentBound F.Sarg) :
    ProvenBacklundTuringBound where
  S := concreteS
  lower := B.lower
  lower_ge_two_pi := B.lower_ge_two_pi
  halfLogPlusHalf := by
    intro T hT
    have htwo_pi_nonneg : (0 : вДЭ) вЙ§ 2 * Real.pi := by positivity
    have hT_nonneg : 0 вЙ§ T :=
      le_trans (le_trans htwo_pi_nonneg B.lower_ge_two_pi) hT
    have hSarg : F.Sarg T = concreteS T := F.Sarg_eq_concreteS hT_nonneg
    rw [вЖР hSarg]
    exact B.bound T hT

/-! ### RiemannвАУvon Mangoldt argument term: contour interface

Good-height variants of the RvM formula and the Backlund bound, plus
explicit extensions to all (sufficiently large) heights.  The contour /
argument-principle proof naturally applies first to good heights (no
zero on the horizontal boundary); the final Backlund/Turing bound must
hold for all large heights.  Keeping these as separate packages prevents
accidentally conflating the two. -/

/-- **G1.** A height suitable for applying the zero-counting contour
formula: nonnegative and "good" (no nontrivial zeta zero lies on the
horizontal line `Im s = T`). -/
structure RvMGoodHeight (T : вДЭ) : Prop where
  pos : 0 < T
  good : GoodHeight T

/-- A good RvM height is nonnegative (derived from positivity). -/
theorem RvMGoodHeight.nonneg {T : вДЭ} (hT : RvMGoodHeight T) : 0 вЙ§ T :=
  le_of_lt hT.pos

/-- **G2.** Abstract argument-variation data for the RiemannвАУvon
Mangoldt contour at a good height `T`.  Eventually instantiated by the
change of argument of the completed zeta function along the standard
rectangle. -/
structure RvMContourArgumentData (T : вДЭ) where
  hT : RvMGoodHeight T
  argumentTerm : вДЭ

/-- **G3.** A proved RiemannвАУvon Mangoldt formula on good heights:
`N(T) = NвВА(T) + Sarg T` whenever the height is good. -/
structure ProvenRiemannVonMangoldtFormulaOnGoodHeights where
  Sarg : вДЭ вЖТ вДЭ
  formula :
    вИА (T : вДЭ) (hT : RvMGoodHeight T),
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : вДЭ)
        =
      riemannVonMangoldtMainTerm T + Sarg T

/-- **G4.** Data extending a good-height RiemannвАУvon Mangoldt formula
to all nonnegative heights. -/
structure RvMGoodHeightExtension
    (Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights) where
  formula_all :
    вИА (T : вДЭ) (hT : 0 вЙ§ T),
      (zetaWeightedZeroCountUpToHeight T hT : вДЭ)
        =
      riemannVonMangoldtMainTerm T + Fgood.Sarg T

/-- Convert a good-height RvM formula plus an all-height extension into
a full `ProvenRiemannVonMangoldtFormula`. -/
noncomputable def RvMGoodHeightExtension.toProvenRiemannVonMangoldtFormula
    {Fgood : ProvenRiemannVonMangoldtFormulaOnGoodHeights}
    (E : RvMGoodHeightExtension Fgood) :
    ProvenRiemannVonMangoldtFormula where
  Sarg := Fgood.Sarg
  formula := E.formula_all

/-- **G5.** Backlund-style bound on an argument term, first proved only
at good heights. -/
structure BacklundArgumentBoundOnGoodHeights (Sarg : вДЭ вЖТ вДЭ) where
  lower : вДЭ
  lower_ge_two_pi : 2 * Real.pi вЙ§ lower
  bound :
    вИА T : вДЭ, lower вЙ§ T вЖТ GoodHeight T вЖТ
      |Sarg T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2

/-- Data extending a good-height Backlund bound to all heights at or
above the lower threshold. -/
structure BacklundGoodHeightBoundExtension
    {Sarg : вДЭ вЖТ вДЭ}
    (Bgood : BacklundArgumentBoundOnGoodHeights Sarg) where
  bound_all :
    вИА T : вДЭ, Bgood.lower вЙ§ T вЖТ
      |Sarg T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2

/-- Convert a good-height Backlund bound plus an all-height extension
into a full `BacklundArgumentBound`. -/
noncomputable def BacklundGoodHeightBoundExtension.toBacklundArgumentBound
    {Sarg : вДЭ вЖТ вДЭ}
    {Bgood : BacklundArgumentBoundOnGoodHeights Sarg}
    (E : BacklundGoodHeightBoundExtension Bgood) :
    BacklundArgumentBound Sarg where
  lower := Bgood.lower
  lower_ge_two_pi := Bgood.lower_ge_two_pi
  bound := E.bound_all

/-! ### Good-height extension infrastructure -/

/-- **H1.** A real height `T` is a zeta-zero height if some nontrivial
zeta zero lies on the horizontal line `Im(s) = T`. -/
def IsZetaZeroHeight (T : вДЭ) : Prop :=
  вИГ s : вДВ, IsNontrivialZetaZero s вИІ s.im = T

/-- `GoodHeight T` is equivalent to saying `T` is not a zeta-zero
height. -/
theorem goodHeight_iff_not_isZetaZeroHeight (T : вДЭ) :
    GoodHeight T вЖФ ¬ђ IsZetaZeroHeight T := by
  constructor
  ¬Ј intro hgood hzeroHeight
    rcases hzeroHeight with вЯ®s, hs, hsTвЯ©
    exact hgood s hs hsT
  ¬Ј intro hnot s hs hsT
    exact hnot вЯ®s, hs, hsTвЯ©

/-- **H2.** The set of positive zero heights in `(0, T]` is finite,
since each comes from one of the finitely many counted zeta zeros up
to height `T`. -/
theorem positiveZetaZeroHeights_finite_upto
    (T : вДЭ) (hT : 0 вЙ§ T) :
    Set.Finite {t : вДЭ | 0 < t вИІ t вЙ§ T вИІ IsZetaZeroHeight t} := by
  classical
  let Z : ZeroSetUpToHeight T := zetaZeroSetUpToHeight T hT
  let H : Finset вДЭ := Z.zeros.image (fun s : вДВ => s.im)
  have hsubset :
      {t : вДЭ | 0 < t вИІ t вЙ§ T вИІ IsZetaZeroHeight t} вКЖ (H : Set вДЭ) := by
    intro t ht
    rcases ht with вЯ®ht_pos, ht_le, hheightвЯ©
    rcases hheight with вЯ®s, hsNT, hs_imвЯ©
    have hsCount : IsZetaZeroUpToHeight T s := by
      refine вЯ®hsNT, ?_, ?_вЯ©
      ¬Ј simpa [hs_im] using ht_pos
      ¬Ј simpa [hs_im] using ht_le
    have hs_mem : s вИИ Z.zeros := (Z.complete s).mpr hsCount
    exact Finset.mem_image.mpr вЯ®s, hs_mem, hs_imвЯ©
  exact H.finite_toSet.subset hsubset

/-- A nonempty open real interval contains a point outside any given
finite set. -/
theorem exists_mem_Ioo_not_mem_finite
    {A B : вДЭ} (hAB : A < B) {F : Set вДЭ} (hF : F.Finite) :
    вИГ t : вДЭ, A < t вИІ t < B вИІ t вИЙ F := by
  have hinf : (Set.Ioo A B \ F).Infinite :=
    (Set.Ioo_infinite hAB).diff hF
  obtain вЯ®t, вЯ®вЯ®hAt, htBвЯ©, htFвЯ©вЯ© := hinf.nonempty
  exact вЯ®t, hAt, htB, htFвЯ©

/-- **H3.** Every positive open interval `(A, B)` contains a good
height (one with no nontrivial zeta zero on its horizontal line). -/
theorem exists_goodHeight_between
    {A B : вДЭ} (hA : 0 < A) (hAB : A < B) :
    вИГ T : вДЭ, A < T вИІ T < B вИІ GoodHeight T := by
  have hF : Set.Finite {t : вДЭ | 0 < t вИІ t вЙ§ B вИІ IsZetaZeroHeight t} :=
    positiveZetaZeroHeights_finite_upto B (le_trans hA.le hAB.le)
  obtain вЯ®T, hAT, hTB, hTnotвЯ© := exists_mem_Ioo_not_mem_finite hAB hF
  refine вЯ®T, hAT, hTB, ?_вЯ©
  rw [goodHeight_iff_not_isZetaZeroHeight]
  intro hZeroHeight
  exact hTnot вЯ®lt_trans hA hAT, hTB.le, hZeroHeightвЯ©

/-! **H4 (target).**
Next extension target: if `Sarg` has suitable one-sided continuity or
right-continuity, and the RvM formula/Backlund bound holds on
arbitrarily close good heights, then it extends to all heights.

The extension theorem should use `exists_goodHeight_between` plus
monotonicity / right-continuity properties of the zero-counting
function.  Not declared yet (no axiom, no `sorry`). -/

/-! ### Good-height approximation lemmas -/

/-- **I1.** For every positive height `T` and every positive `ќµ`, there
is a good height strictly between `T` and `T + ќµ`. -/
theorem exists_goodHeight_between_self_add
    {T ќµ : вДЭ} (hT : 0 < T) (hќµ : 0 < ќµ) :
    вИГ U : вДЭ, T < U вИІ U < T + ќµ вИІ GoodHeight U :=
  exists_goodHeight_between hT (by linarith)

/-- **I2.** For every positive height `T` and every `ќµ` with `0 < ќµ < T`,
there is a good height strictly between `T - ќµ` and `T`. -/
theorem exists_goodHeight_between_sub_self
    {T ќµ : вДЭ} (hќµ : 0 < ќµ) (hќµT : ќµ < T) :
    вИГ U : вДЭ, T - ќµ < U вИІ U < T вИІ GoodHeight U := by
  have hleft_pos : 0 < T - ќµ := by linarith
  have hleft_lt : T - ќµ < T := by linarith
  exact exists_goodHeight_between hleft_pos hleft_lt

/-- **I4.** Inside any positive open interval, there is a good height
avoiding an additional finite set of forbidden heights. -/
theorem exists_goodHeight_between_not_mem_finite
    {A B : вДЭ} (hA : 0 < A) (hAB : A < B)
    {F : Set вДЭ} (hF : F.Finite) :
    вИГ T : вДЭ, A < T вИІ T < B вИІ GoodHeight T вИІ T вИЙ F := by
  have hZH : Set.Finite {t : вДЭ | 0 < t вИІ t вЙ§ B вИІ IsZetaZeroHeight t} :=
    positiveZetaZeroHeights_finite_upto B (le_trans hA.le hAB.le)
  have hUnion :
      ({t : вДЭ | 0 < t вИІ t вЙ§ B вИІ IsZetaZeroHeight t} вИ™ F).Finite :=
    hZH.union hF
  obtain вЯ®T, hAT, hTB, hTnotвЯ© :=
    exists_mem_Ioo_not_mem_finite hAB hUnion
  have hTnotZH : T вИЙ {t : вДЭ | 0 < t вИІ t вЙ§ B вИІ IsZetaZeroHeight t} :=
    fun h => hTnot (Or.inl h)
  have hTnotF : T вИЙ F :=
    fun h => hTnot (Or.inr h)
  have hgood : GoodHeight T := by
    rw [goodHeight_iff_not_isZetaZeroHeight]
    intro hheight
    exact hTnotZH вЯ®lt_trans hA hAT, hTB.le, hheightвЯ©
  exact вЯ®T, hAT, hTB, hgood, hTnotFвЯ©

/-! ### Safe contour heights -/

/-- **I5.** A safe contour height in `(A, B)` is a good height in that
open interval вАФ usable as a horizontal contour level that avoids any
nontrivial zeta zero. -/
structure SafeContourHeight (A B : вДЭ) where
  T : вДЭ
  hA_lt : A < T
  hT_lt_B : T < B
  good : GoodHeight T

/-- Existence of a safe contour height in any positive open interval. -/
theorem exists_safeContourHeight
    {A B : вДЭ} (hA : 0 < A) (hAB : A < B) :
    Nonempty (SafeContourHeight A B) := by
  obtain вЯ®T, hAT, hTB, hgoodвЯ© := exists_goodHeight_between hA hAB
  exact вЯ®вЯ®T, hAT, hTB, hgoodвЯ©вЯ©

/-- Existence of a safe contour height avoiding any additional finite
set of forbidden heights. -/
theorem exists_safeContourHeight_avoiding_finite
    {A B : вДЭ} (hA : 0 < A) (hAB : A < B)
    {F : Set вДЭ} (hF : F.Finite) :
    вИГ H : SafeContourHeight A B, H.T вИЙ F := by
  obtain вЯ®T, hAT, hTB, hgood, hnotFвЯ© :=
    exists_goodHeight_between_not_mem_finite hA hAB hF
  exact вЯ®вЯ®T, hAT, hTB, hgoodвЯ©, hnotFвЯ©

/-! ### Zeta rectangle contour geometry -/

/-- **J1.** A rectangular contour parameter package for zero-counting.
The rectangle is bounded by real parts `left` and `right`, and imaginary
parts `bottom` and `top`. -/
structure ZetaRectangle where
  left : вДЭ
  right : вДЭ
  bottom : вДЭ
  top : вДЭ
  hleft_lt_right : left < right
  hbottom_lt_top : bottom < top

namespace ZetaRectangle

/-- A point lies in the closed rectangle. -/
def ContainsClosed (R : ZetaRectangle) (s : вДВ) : Prop :=
  R.left вЙ§ s.re вИІ s.re вЙ§ R.right вИІ
  R.bottom вЙ§ s.im вИІ s.im вЙ§ R.top

/-- A point lies in the open rectangle. -/
def ContainsOpen (R : ZetaRectangle) (s : вДВ) : Prop :=
  R.left < s.re вИІ s.re < R.right вИІ
  R.bottom < s.im вИІ s.im < R.top

/-- A point lies on the boundary of the rectangle. -/
def ContainsBoundary (R : ZetaRectangle) (s : вДВ) : Prop :=
  R.ContainsClosed s вИІ ¬ђ R.ContainsOpen s

/-- The standard zero-counting rectangle enclosing the critical strip
up to height `T`, with horizontal bottom `0`. -/
def criticalStripRectangle
    (left right T : вДЭ)
    (hleft_lt_zero : left < 0)
    (hone_lt_right : 1 < right)
    (hT_pos : 0 < T) :
    ZetaRectangle where
  left := left
  right := right
  bottom := 0
  top := T
  hleft_lt_right := by linarith
  hbottom_lt_top := hT_pos

/-- A positive-bottom critical-strip rectangle, used when the contour
must avoid the pole at `1` on the real axis. -/
def criticalStripRectanglePositiveBottom
    (left right bottom top : вДЭ)
    (hleft_lt_zero : left < 0)
    (hone_lt_right : 1 < right)
    (_hbottom_pos : 0 < bottom)
    (hbottom_lt_top : bottom < top) :
    ZetaRectangle where
  left := left
  right := right
  bottom := bottom
  top := top
  hleft_lt_right := by linarith
  hbottom_lt_top := hbottom_lt_top

/-! ### Boundary avoidance -/

/-- **J2.** No nontrivial zeta zero lies on the rectangle boundary. -/
def NoZerosOnBoundary (R : ZetaRectangle) : Prop :=
  вИА s : вДВ, IsNontrivialZetaZero s вЖТ R.ContainsBoundary s вЖТ False

/-- The zeta pole `1` does not lie on the rectangle boundary. -/
def PoleNotOnBoundary (R : ZetaRectangle) : Prop :=
  ¬ђ R.ContainsBoundary (1 : вДВ)

/-- The rectangle is admissible for a zeta argument-principle count:
no counted zeros and no pole lie on the boundary. -/
structure AdmissibleForZeta (R : ZetaRectangle) : Prop where
  noZerosOnBoundary : R.NoZerosOnBoundary
  poleNotOnBoundary : R.PoleNotOnBoundary

/-! ### Boundary lemmas -/

/-- **J3.** If the top height is good, then no nontrivial zero lies on
the top edge. -/
theorem no_zero_on_top_edge_of_goodHeight
    {R : ZetaRectangle}
    (hgood : GoodHeight R.top)
    {s : вДВ}
    (hs : IsNontrivialZetaZero s)
    (_hsClosed : R.ContainsClosed s)
    (hsTop : s.im = R.top) :
    False :=
  hgood s hs hsTop

/-- **J4.** No counted zero (height-bounded by `T`) can lie on the
bottom edge `im = 0`, because counted zeros have strictly positive
imaginary part. -/
theorem no_counted_zero_on_bottom_edge
    {T : вДЭ} {s : вДВ}
    (hs : IsZetaZeroUpToHeight T s)
    (hsBottom : s.im = 0) :
    False := by
  have hpos : 0 < s.im := hs.2.1
  linarith

/-- **J5.** A rectangle with strictly positive bottom edge places the
zeta pole `1` (which lies on `im = 0`) strictly below the rectangle, so
`1` is not on its boundary. -/
theorem poleNotOnBoundary_of_positive_bottom
    {R : ZetaRectangle}
    (hbottom_pos : 0 < R.bottom) :
    R.PoleNotOnBoundary := by
  intro h
  rcases h with вЯ®hclosed, _hopen_notвЯ©
  have him_le : R.bottom вЙ§ (1 : вДВ).im := hclosed.2.2.1
  rw [Complex.one_im] at him_le
  linarith

/-! ### Rectangle zero-count formula interface -/

/-- **K1.** A nontrivial zeta zero lies strictly inside a rectangle. -/
def IsNontrivialZeroInside (R : ZetaRectangle) (s : вДВ) : Prop :=
  IsNontrivialZetaZero s вИІ R.ContainsOpen s

/-- A finite certificate for the set of nontrivial zeta zeros inside a
rectangle. -/
structure ZeroSetInside (R : ZetaRectangle) where
  zeros : Finset вДВ
  complete :
    вИА s : вДВ, s вИИ zeros вЖФ R.IsNontrivialZeroInside s

/-- The multiplicity-weighted zero count inside a rectangle. -/
def weightedZeroCountInside
    (R : ZetaRectangle)
    (Z : R.ZeroSetInside)
    (M : GlobalZeroMultiplicity) : вДХ :=
  Z.zeros.sum M.mult

/-- Membership in a rectangle zero-set certificate is exactly the
inside-zero predicate. -/
theorem mem_zeroSetInside_iff
    {R : ZetaRectangle} (Z : R.ZeroSetInside) (s : вДВ) :
    s вИИ Z.zeros вЖФ R.IsNontrivialZeroInside s :=
  Z.complete s

/-- Any two rectangle zero-set certificates for the same rectangle have
the same finite support. -/
theorem zeroSetInside_zeros_unique
    {R : ZetaRectangle} (ZвВБ ZвВВ : R.ZeroSetInside) :
    ZвВБ.zeros = ZвВВ.zeros := by
  ext s
  rw [ZвВБ.complete s, ZвВВ.complete s]

/-! ### Pole-inside predicate -/

/-- **K2.** The zeta pole `1` lies strictly inside the rectangle. -/
def PoleInside (R : ZetaRectangle) : Prop :=
  R.ContainsOpen (1 : вДВ)

open Classical in
/-- The zeta pole count inside a rectangle: `1` if the pole is inside,
`0` otherwise.  For positive-bottom rectangles this is always `0`. -/
noncomputable def poleCountInside (R : ZetaRectangle) : вДХ :=
  if R.PoleInside then 1 else 0

/-- A positive-bottom rectangle has no pole inside (the pole `1` has
`im = 0 < bottom`). -/
theorem not_poleInside_of_positive_bottom
    {R : ZetaRectangle}
    (hbottom_pos : 0 < R.bottom) :
    ¬ђ R.PoleInside := by
  intro h
  have him_gt : R.bottom < (1 : вДВ).im := h.2.2.1
  rw [Complex.one_im] at him_gt
  linarith

/-- A positive-bottom rectangle has pole count zero. -/
theorem poleCountInside_eq_zero_of_positive_bottom
    {R : ZetaRectangle}
    (hbottom_pos : 0 < R.bottom) :
    R.poleCountInside = 0 := by
  unfold poleCountInside
  simp [not_poleInside_of_positive_bottom hbottom_pos]

/-! ### Rectangle argument-principle formula -/

/-- **K3.** A rectangle-level zeta argument-principle formula:

  `(weighted zero count inside) вИТ (pole count inside) = argumentIndex`,

where `argumentIndex` is the integer-valued contour index, eventually
realized as the change of argument / logarithmic-derivative integral. -/
structure ZetaArgumentPrincipleFormula (R : ZetaRectangle) where
  admissible : R.AdmissibleForZeta
  zeroSet : R.ZeroSetInside
  M : GlobalZeroMultiplicity
  argumentIndex : вД§
  formula :
    (R.weightedZeroCountInside zeroSet M : вД§)
      - (R.poleCountInside : вД§)
      =
    argumentIndex

/-- **K4.** For a positive-bottom rectangle, the pole term vanishes and
the argument index equals the inside weighted zero count. -/
theorem ZetaArgumentPrincipleFormula.argumentIndex_eq_zeroCount_of_positive_bottom
    {R : ZetaRectangle}
    (F : R.ZetaArgumentPrincipleFormula)
    (hbottom_pos : 0 < R.bottom) :
    F.argumentIndex = (R.weightedZeroCountInside F.zeroSet F.M : вД§) := by
  have hpole : R.poleCountInside = 0 :=
    R.poleCountInside_eq_zero_of_positive_bottom hbottom_pos
  have h := F.formula
  rw [hpole] at h
  omega

/-! ### Bridge from rectangle interior to height slabs -/

/-- **K5.** A nontrivial zeta zero with `R.bottom < Im(s) < R.top` lies
strictly inside a critical-strip rectangle (`left < 0`, `right > 1`). -/
theorem isNontrivialZeroInside_of_slab_lt_top
    {R : ZetaRectangle} {s : вДВ}
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hs : IsNontrivialZetaZero s)
    (hbottom : R.bottom < s.im)
    (htop : s.im < R.top) :
    R.IsNontrivialZeroInside s := by
  rcases hs with вЯ®hzeta, hre_pos, hre_ltвЯ©
  exact
    вЯ®вЯ®hzeta, hre_pos, hre_ltвЯ©,
      lt_trans hleft hre_pos,
      lt_trans hre_lt hright,
      hbottom,
      htopвЯ©

/-! ### Good-top conversion from slabs to rectangle interiors -/

/-- **L1.** For a nontrivial zeta zero, if the top height is good and
`s.im вЙ§ R.top`, then in fact `s.im < R.top` (else `s` would be a zero
on the horizontal top edge, contradicting `GoodHeight R.top`). -/
theorem im_lt_top_of_le_top_of_goodHeight
    {R : ZetaRectangle} {s : вДВ}
    (hgood : GoodHeight R.top)
    (hs : IsNontrivialZetaZero s)
    (hle : s.im вЙ§ R.top) :
    s.im < R.top := by
  rcases lt_or_eq_of_le hle with hlt | heq
  ¬Ј exact hlt
  ¬Ј exact False.elim (hgood s hs heq)

/-- **L2.** A zero in the half-open height slab `(R.bottom, R.top]`
lies in the open rectangle if the top height is good and the rectangle
contains the full critical strip horizontally. -/
theorem isNontrivialZeroInside_of_slab_of_goodTop
    {R : ZetaRectangle} {s : вДВ}
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hgood : GoodHeight R.top)
    (hs : IsZetaZeroInHeightSlab R.bottom R.top s) :
    R.IsNontrivialZeroInside s := by
  rcases hs with вЯ®hsNT, hbottom, hleTopвЯ©
  exact
    isNontrivialZeroInside_of_slab_lt_top
      hleft hright hsNT hbottom
      (im_lt_top_of_le_top_of_goodHeight hgood hsNT hleTop)

/-- **L3.** A nontrivial zeta zero inside a rectangle lies in the
height slab `(R.bottom, R.top]`. -/
theorem isZetaZeroInHeightSlab_of_isNontrivialZeroInside
    {R : ZetaRectangle} {s : вДВ}
    (hs : R.IsNontrivialZeroInside s) :
    IsZetaZeroInHeightSlab R.bottom R.top s := by
  rcases hs with вЯ®hsNT, hrectвЯ©
  exact вЯ®hsNT, hrect.2.2.1, le_of_lt hrect.2.2.2вЯ©

/-- **L4.** For a critical-strip rectangle with good top, the
nontrivial zeros inside the rectangle are exactly the nontrivial zeros
in the height slab `(R.bottom, R.top]`. -/
theorem isNontrivialZeroInside_iff_slab_of_goodTop
    {R : ZetaRectangle} {s : вДВ}
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hgood : GoodHeight R.top) :
    R.IsNontrivialZeroInside s вЖФ
      IsZetaZeroInHeightSlab R.bottom R.top s := by
  constructor
  ¬Ј intro hs
    exact isZetaZeroInHeightSlab_of_isNontrivialZeroInside hs
  ¬Ј intro hs
    exact isNontrivialZeroInside_of_slab_of_goodTop
      hleft hright hgood hs

/-- **L5.** Convert a height-slab zero-set certificate into a
rectangle-inside zero-set certificate, for a good-top rectangle
containing the critical strip horizontally. -/
noncomputable def zeroSetInsideOfSlab
    {R : ZetaRectangle}
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hgood : GoodHeight R.top)
    (Z : ZeroSetInHeightSlab R.bottom R.top) :
    R.ZeroSetInside where
  zeros := Z.zeros
  complete := by
    intro s
    rw [Z.complete s]
    exact (isNontrivialZeroInside_iff_slab_of_goodTop hleft hright hgood).symm

end ZetaRectangle

/-! ### Weighted slab certificates from global multiplicity -/

open Classical in
/-- **M1.** The height-slab multiplicity induced by a global multiplicity
model: equal to the global multiplicity on zeros in the slab, `0`
outside. -/
noncomputable def truncatedSlabMultiplicity
    (M : GlobalZeroMultiplicity) (A B : вДЭ) (s : вДВ) : вДХ :=
  if IsZetaZeroInHeightSlab A B s then M.mult s else 0

/-- On a zero in the slab, the truncated slab multiplicity equals the
global multiplicity. -/
theorem truncatedSlabMultiplicity_eq_global
    (M : GlobalZeroMultiplicity) {A B : вДЭ} {s : вДВ}
    (hs : IsZetaZeroInHeightSlab A B s) :
    truncatedSlabMultiplicity M A B s = M.mult s := by
  unfold truncatedSlabMultiplicity
  exact if_pos hs

/-- Away from the slab, the truncated slab multiplicity is zero. -/
theorem truncatedSlabMultiplicity_eq_zero
    (M : GlobalZeroMultiplicity) {A B : вДЭ} {s : вДВ}
    (hs : ¬ђ IsZetaZeroInHeightSlab A B s) :
    truncatedSlabMultiplicity M A B s = 0 := by
  unfold truncatedSlabMultiplicity
  exact if_neg hs

/-- A simple slab certificate plus a global multiplicity model gives a
weighted slab certificate, using the truncated slab multiplicity. -/
noncomputable def weightedZeroSetInHeightSlabOfGlobalMultiplicity
    (M : GlobalZeroMultiplicity)
    {A B : вДЭ}
    (Z : ZeroSetInHeightSlab A B) :
    WeightedZeroSetInHeightSlab A B where
  zeros := Z.zeros
  mult := truncatedSlabMultiplicity M A B
  complete := Z.complete
  positive_on_zeros := by
    intro s hs
    have hsSlab : IsZetaZeroInHeightSlab A B s := (Z.complete s).mp hs
    rw [truncatedSlabMultiplicity_eq_global M hsSlab]
    exact M.positive_of_isNontrivialZetaZero hsSlab.1
  zero_off_zeros := by
    intro s hsNotMem
    apply truncatedSlabMultiplicity_eq_zero
    intro hsSlab
    exact hsNotMem ((Z.complete s).mpr hsSlab)

namespace ZetaRectangle

/-- **M2.** The weighted rectangle-inside count equals the weighted slab
count after converting a slab certificate to a rectangle-inside
certificate.  Both sides reduce to `Z.zeros.sum (M.mult)` on the
support of `Z`. -/
theorem weightedZeroCountInside_zeroSetInsideOfSlab_eq
    {R : ZetaRectangle}
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hgood : GoodHeight R.top)
    (Z : ZeroSetInHeightSlab R.bottom R.top)
    (M : GlobalZeroMultiplicity) :
    R.weightedZeroCountInside
        (zeroSetInsideOfSlab hleft hright hgood Z) M
      =
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfGlobalMultiplicity M Z) := by
  unfold weightedZeroCountInside
  unfold weightedZeroCountInHeightSlabFromCertificate
  apply Finset.sum_congr rfl
  intro s hs
  have hsSlab : IsZetaZeroInHeightSlab R.bottom R.top s :=
    (Z.complete s).mp hs
  exact (truncatedSlabMultiplicity_eq_global M hsSlab).symm

/-- **M3.** Canonical simple slab certificate for a rectangle's height
interval, using the actual cumulative zeta zero-set certificates at the
endpoints. -/
noncomputable def canonicalSlabZeroSet
    (R : ZetaRectangle)
    (hbottom_nonneg : 0 вЙ§ R.bottom) :
    ZeroSetInHeightSlab R.bottom R.top :=
  zeroSetInHeightSlabOfDifference
    hbottom_nonneg
    R.hbottom_lt_top.le
    (zetaZeroSetUpToHeight R.bottom hbottom_nonneg)
    (zetaZeroSetUpToHeight R.top
      (le_trans hbottom_nonneg R.hbottom_lt_top.le))

/-- The weighted count of the canonical rectangle slab equals the
actual zeta weighted zero count in the corresponding height slab. -/
theorem weighted_count_canonicalSlab_eq_zetaWeightedZeroCountInHeightSlab
    (R : ZetaRectangle)
    (hbottom_nonneg : 0 вЙ§ R.bottom) :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfGlobalMultiplicity
          zetaGlobalZeroMultiplicity
          (R.canonicalSlabZeroSet hbottom_nonneg))
      =
    zetaWeightedZeroCountInHeightSlab
      R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le := rfl

/-- **M4.** For a positive-bottom, good-top, horizontally wide rectangle,
a rectangle argument-principle formula whose `zeroSet` is the canonical
slab certificate and whose `M` is the actual `zetaGlobalZeroMultiplicity`
computes the actual weighted zero count in the corresponding height
slab. -/
theorem ZetaArgumentPrincipleFormula.argumentIndex_eq_actual_slab_count
    {R : ZetaRectangle}
    (F : R.ZetaArgumentPrincipleFormula)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 вЙ§ R.bottom)
    (hbottom_pos : 0 < R.bottom)
    (hgood : GoodHeight R.top)
    (hZeroSet :
      F.zeroSet =
        R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
    (hM : F.M = zetaGlobalZeroMultiplicity) :
    F.argumentIndex =
      (zetaWeightedZeroCountInHeightSlab
        R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le : вД§) := by
  have harg :
      F.argumentIndex = (R.weightedZeroCountInside F.zeroSet F.M : вД§) :=
    F.argumentIndex_eq_zeroCount_of_positive_bottom hbottom_pos
  rw [harg, hZeroSet, hM]
  have hcount := R.weightedZeroCountInside_zeroSetInsideOfSlab_eq
    hleft hright hgood (R.canonicalSlabZeroSet hbottom_nonneg)
    zetaGlobalZeroMultiplicity
  rw [hcount]
  rw [R.weighted_count_canonicalSlab_eq_zetaWeightedZeroCountInHeightSlab
    hbottom_nonneg]

/-! ### Canonical zeta rectangle argument-principle package -/

/-- **N1.** Canonical argument-principle data for a zeta rectangle
whose interior zeros are identified with the actual zeta zeros in the
corresponding height slab, and whose multiplicity model is the actual
`zetaGlobalZeroMultiplicity`. -/
structure CanonicalZetaArgumentPrincipleFormula
    (R : ZetaRectangle)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 вЙ§ R.bottom)
    (hgood : GoodHeight R.top) where
  admissible : R.AdmissibleForZeta
  argumentIndex : вД§
  formula :
    (R.weightedZeroCountInside
        (R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
        zetaGlobalZeroMultiplicity : вД§)
      -
    (R.poleCountInside : вД§)
      =
    argumentIndex

/-- **N2.** Forget the canonical choices and view canonical zeta
rectangle data as a generic rectangle argument-principle formula. -/
noncomputable def CanonicalZetaArgumentPrincipleFormula.toGeneric
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood) :
    R.ZetaArgumentPrincipleFormula where
  admissible := F.admissible
  zeroSet :=
    R.zeroSetInsideOfSlab hleft hright hgood
      (R.canonicalSlabZeroSet hbottom_nonneg)
  M := zetaGlobalZeroMultiplicity
  argumentIndex := F.argumentIndex
  formula := F.formula

/-- **N3.** For a positive-bottom canonical zeta rectangle, the
argument index is exactly the actual weighted zeta zero count in the
corresponding height slab. -/
theorem CanonicalZetaArgumentPrincipleFormula.argumentIndex_eq_actual_slab_count
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (hbottom_pos : 0 < R.bottom) :
    F.argumentIndex =
      (zetaWeightedZeroCountInHeightSlab
        R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le : вД§) :=
  F.toGeneric.argumentIndex_eq_actual_slab_count
    hleft hright hbottom_nonneg hbottom_pos hgood rfl rfl

/-- **N4.** A canonical positive-bottom rectangle argument-principle
formula yields a Turing interval certificate for the slab
`(R.bottom, R.top]`. -/
noncomputable def CanonicalZetaArgumentPrincipleFormula.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (_F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (_hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate where
  A := R.bottom
  B := R.top
  hA_nonneg := hbottom_nonneg
  hAB := R.hbottom_lt_top.le
  ZA := zetaZeroSetUpToHeight R.bottom hbottom_nonneg
  ZB := zetaZeroSetUpToHeight R.top
    (le_trans hbottom_nonneg R.hbottom_lt_top.le)
  M := zetaGlobalZeroMultiplicity
  certifiedCount :=
    zetaWeightedZeroCountInHeightSlab
      R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le
  count_eq := rfl

/-- The Turing interval certificate associated to a canonical
positive-bottom rectangle has certified count equal to the argument
index after casting to `вД§`. -/
theorem CanonicalZetaArgumentPrincipleFormula.toTuringIntervalCertificate_count_eq_argumentIndex
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (hbottom_pos : 0 < R.bottom) :
    ((F.toTuringIntervalCertificate hbottom_pos).certifiedCount : вД§)
      =
    F.argumentIndex := by
  unfold CanonicalZetaArgumentPrincipleFormula.toTuringIntervalCertificate
  exact (F.argumentIndex_eq_actual_slab_count hbottom_pos).symm

/-! ### Argument-index certificates -/

/-- **O1.** A canonical zeta rectangle argument-principle formula whose
argument index is known to be nonnegative.  Needed to turn an integer
argument-principle index into a natural-number Turing interval count. -/
structure CanonicalZetaArgumentPrincipleNatFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood) : Prop where
  argumentIndex_nonneg : 0 вЙ§ F.argumentIndex

/-- **O2.** The natural count associated to a nonnegative argument
index. -/
noncomputable def CanonicalZetaArgumentPrincipleFormula.argumentIndexNat
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (_HN : CanonicalZetaArgumentPrincipleNatFormula F) : вДХ :=
  Int.toNat F.argumentIndex

/-- Casting the natural index back to `вД§` recovers the argument
index. -/
theorem CanonicalZetaArgumentPrincipleFormula.argumentIndexNat_cast
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (HN : CanonicalZetaArgumentPrincipleNatFormula F) :
    ((F.argumentIndexNat HN : вДХ) : вД§) = F.argumentIndex := by
  unfold CanonicalZetaArgumentPrincipleFormula.argumentIndexNat
  exact Int.toNat_of_nonneg HN.argumentIndex_nonneg

/-- **O3.** For a positive-bottom canonical rectangle, the natural
argument index equals the actual weighted zeta zero count in the
corresponding height slab. -/
theorem CanonicalZetaArgumentPrincipleFormula.argumentIndexNat_eq_actual_slab_count
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (HN : CanonicalZetaArgumentPrincipleNatFormula F)
    (hbottom_pos : 0 < R.bottom) :
    F.argumentIndexNat HN =
      zetaWeightedZeroCountInHeightSlab
        R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le := by
  have h1 := F.argumentIndexNat_cast HN
  have h2 := F.argumentIndex_eq_actual_slab_count hbottom_pos
  have h3 :
      ((F.argumentIndexNat HN : вДХ) : вД§)
        =
      ((zetaWeightedZeroCountInHeightSlab
          R.bottom R.top hbottom_nonneg R.hbottom_lt_top.le : вДХ) : вД§) :=
    h1.trans h2
  exact_mod_cast h3

/-- **O4.** A canonical positive-bottom rectangle argument-principle
formula with nonnegative index yields a Turing interval certificate
whose certified count is the natural argument index. -/
noncomputable def CanonicalZetaArgumentPrincipleFormula.toTuringIntervalCertificateFromIndex
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (HN : CanonicalZetaArgumentPrincipleNatFormula F)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate where
  A := R.bottom
  B := R.top
  hA_nonneg := hbottom_nonneg
  hAB := R.hbottom_lt_top.le
  ZA := zetaZeroSetUpToHeight R.bottom hbottom_nonneg
  ZB := zetaZeroSetUpToHeight R.top
    (le_trans hbottom_nonneg R.hbottom_lt_top.le)
  M := zetaGlobalZeroMultiplicity
  certifiedCount := F.argumentIndexNat HN
  count_eq := (F.argumentIndexNat_eq_actual_slab_count HN hbottom_pos).symm

/-- **O5.** The index-based Turing certificate has certified count equal
to the natural argument index. -/
theorem CanonicalZetaArgumentPrincipleFormula.toTuringIntervalCertificateFromIndex_certifiedCount
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (HN : CanonicalZetaArgumentPrincipleNatFormula F)
    (hbottom_pos : 0 < R.bottom) :
    (F.toTuringIntervalCertificateFromIndex HN hbottom_pos).certifiedCount =
      F.argumentIndexNat HN := rfl

/-! ### Rectangle contour integral data -/

/-- **P1.** Raw contour-integral data for a zeta rectangle.  Eventually
`logDerivIntegral` is the normalized contour integral of `ќґ'(s)/ќґ(s)`
around the rectangle. -/
structure ZetaRectangleContourIntegralData (R : ZetaRectangle) where
  logDerivIntegral : вДВ
  argumentIndex : вД§

/-- **P2.** A proof package saying the normalized logarithmic-derivative
contour integral equals the integer argument index. -/
structure ZetaRectangleContourIndexData (R : ZetaRectangle) extends
    R.ZetaRectangleContourIntegralData where
  normalizedIntegral_eq_index :
    logDerivIntegral = (argumentIndex : вДВ)

/-- **P3.** Canonical argument-principle data for a zeta rectangle: the
contour/index data together with the formula relating the rectangle's
inside weighted zero count and pole count to the integer index. -/
structure CanonicalZetaArgumentPrincipleData
    (R : ZetaRectangle)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 вЙ§ R.bottom)
    (hgood : GoodHeight R.top) where
  admissible : R.AdmissibleForZeta
  contour : R.ZetaRectangleContourIndexData
  formula :
    (R.weightedZeroCountInside
        (R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
        zetaGlobalZeroMultiplicity : вД§)
      -
    (R.poleCountInside : вД§)
      =
    contour.argumentIndex

/-- **P4.** Contour/index argument-principle data produces the canonical
zeta rectangle argument-principle formula. -/
noncomputable def CanonicalZetaArgumentPrincipleData.toFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (D : R.CanonicalZetaArgumentPrincipleData
      hleft hright hbottom_nonneg hgood) :
    R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood where
  admissible := D.admissible
  argumentIndex := D.contour.argumentIndex
  formula := D.formula

/-- **P5.** Argument-principle data with nonnegative index вАФ exactly the
form needed to produce a natural-number Turing interval certificate. -/
structure CanonicalZetaArgumentPrincipleDataNat
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (D : R.CanonicalZetaArgumentPrincipleData
      hleft hright hbottom_nonneg hgood) : Prop where
  argumentIndex_nonneg : 0 вЙ§ D.contour.argumentIndex

/-- **P6.** Canonical contour/index data with nonnegative index gives a
Turing interval certificate. -/
noncomputable def CanonicalZetaArgumentPrincipleData.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (D : R.CanonicalZetaArgumentPrincipleData
      hleft hright hbottom_nonneg hgood)
    (DN : CanonicalZetaArgumentPrincipleDataNat D)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate :=
  (D.toFormula).toTuringIntervalCertificateFromIndex
    { argumentIndex_nonneg := DN.argumentIndex_nonneg }
    hbottom_pos

/-- **P7.** The Turing certificate obtained from contour/index data has
certified count equal to the natural value of the contour argument
index. -/
theorem CanonicalZetaArgumentPrincipleData.toTuringIntervalCertificate_certifiedCount
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (D : R.CanonicalZetaArgumentPrincipleData
      hleft hright hbottom_nonneg hgood)
    (DN : CanonicalZetaArgumentPrincipleDataNat D)
    (hbottom_pos : 0 < R.bottom) :
    (D.toTuringIntervalCertificate DN hbottom_pos).certifiedCount =
      (D.toFormula).argumentIndexNat
        { argumentIndex_nonneg := DN.argumentIndex_nonneg } := rfl

/-! ### Zeta logarithmic derivative -/

/-- **Q1.** The logarithmic derivative of the Riemann zeta function,
the integrand in the argument-principle contour integral. -/
noncomputable def zetaLogDeriv (z : вДВ) : вДВ :=
  deriv riemannZeta z / riemannZeta z

/-- The logarithmic derivative spelled as the standard quotient. -/
theorem zetaLogDeriv_eq
    {z : вДВ} (_hz : riemannZeta z вЙ† 0) :
    zetaLogDeriv z = deriv riemannZeta z / riemannZeta z := rfl

/-! ### Rectangle contour paths -/

/-- **Q2 bottom.** Bottom edge: `left + i¬Јbottom` to `right + i¬Јbottom`. -/
noncomputable def bottomEdge (R : ZetaRectangle) (t : вДЭ) : вДВ :=
  вЯ®R.left + t * (R.right - R.left), R.bottomвЯ©

/-- **Q2 right.** Right edge: `right + i¬Јbottom` to `right + i¬Јtop`. -/
noncomputable def rightEdge (R : ZetaRectangle) (t : вДЭ) : вДВ :=
  вЯ®R.right, R.bottom + t * (R.top - R.bottom)вЯ©

/-- **Q2 top.** Top edge: `right + i¬Јtop` to `left + i¬Јtop`. -/
noncomputable def topEdge (R : ZetaRectangle) (t : вДЭ) : вДВ :=
  вЯ®R.right - t * (R.right - R.left), R.topвЯ©

/-- **Q2 left.** Left edge: `left + i¬Јtop` to `left + i¬Јbottom`. -/
noncomputable def leftEdge (R : ZetaRectangle) (t : вДЭ) : вДВ :=
  вЯ®R.left, R.top - t * (R.top - R.bottom)вЯ©

/-! ### Edge endpoints -/

@[simp] theorem bottomEdge_zero (R : ZetaRectangle) :
    R.bottomEdge 0 = вЯ®R.left, R.bottomвЯ© := by
  simp [bottomEdge]

@[simp] theorem bottomEdge_one (R : ZetaRectangle) :
    R.bottomEdge 1 = вЯ®R.right, R.bottomвЯ© := by
  apply Complex.ext <;> simp [bottomEdge]

@[simp] theorem rightEdge_zero (R : ZetaRectangle) :
    R.rightEdge 0 = вЯ®R.right, R.bottomвЯ© := by
  simp [rightEdge]

@[simp] theorem rightEdge_one (R : ZetaRectangle) :
    R.rightEdge 1 = вЯ®R.right, R.topвЯ© := by
  apply Complex.ext <;> simp [rightEdge]

@[simp] theorem topEdge_zero (R : ZetaRectangle) :
    R.topEdge 0 = вЯ®R.right, R.topвЯ© := by
  simp [topEdge]

@[simp] theorem topEdge_one (R : ZetaRectangle) :
    R.topEdge 1 = вЯ®R.left, R.topвЯ© := by
  apply Complex.ext <;> simp [topEdge]

@[simp] theorem leftEdge_zero (R : ZetaRectangle) :
    R.leftEdge 0 = вЯ®R.left, R.topвЯ© := by
  simp [leftEdge]

@[simp] theorem leftEdge_one (R : ZetaRectangle) :
    R.leftEdge 1 = вЯ®R.left, R.bottomвЯ© := by
  apply Complex.ext <;> simp [leftEdge]

/-! ### Rectangle contour package -/

/-- **Q5.** The four directed edges of the positively oriented rectangle
contour. -/
structure RectangleContour (R : ZetaRectangle) where
  bottom : вДЭ вЖТ вДВ
  right : вДЭ вЖТ вДВ
  top : вДЭ вЖТ вДВ
  left : вДЭ вЖТ вДВ

/-- The canonical positively oriented rectangle contour. -/
noncomputable def contour (R : ZetaRectangle) : RectangleContour R where
  bottom := R.bottomEdge
  right := R.rightEdge
  top := R.topEdge
  left := R.leftEdge

/-! ### Rectangle log-derivative integrals -/

/-- **Q6 bottom.** Integral of `ќґ'/ќґ` along the bottom edge. -/
noncomputable def bottomLogDerivIntegral (R : ZetaRectangle) : вДВ :=
  вИЂ t in (0 : вДЭ)..1, zetaLogDeriv (R.bottomEdge t) * deriv R.bottomEdge t

/-- **Q6 right.** Integral of `ќґ'/ќґ` along the right edge. -/
noncomputable def rightLogDerivIntegral (R : ZetaRectangle) : вДВ :=
  вИЂ t in (0 : вДЭ)..1, zetaLogDeriv (R.rightEdge t) * deriv R.rightEdge t

/-- **Q6 top.** Integral of `ќґ'/ќґ` along the top edge. -/
noncomputable def topLogDerivIntegral (R : ZetaRectangle) : вДВ :=
  вИЂ t in (0 : вДЭ)..1, zetaLogDeriv (R.topEdge t) * deriv R.topEdge t

/-- **Q6 left.** Integral of `ќґ'/ќґ` along the left edge. -/
noncomputable def leftLogDerivIntegral (R : ZetaRectangle) : вДВ :=
  вИЂ t in (0 : вДЭ)..1, zetaLogDeriv (R.leftEdge t) * deriv R.leftEdge t

/-- The full logarithmic derivative integral around the rectangle. -/
noncomputable def rectangleLogDerivIntegral (R : ZetaRectangle) : вДВ :=
  R.bottomLogDerivIntegral + R.rightLogDerivIntegral
    + R.topLogDerivIntegral + R.leftLogDerivIntegral

/-! ### Rectangle edge containment -/

/-- **Q4 bottom.** The bottom edge stays in the closed rectangle for
`0 вЙ§ t вЙ§ 1`. -/
theorem bottomEdge_mem_closed
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsClosed (R.bottomEdge t) := by
  refine вЯ®?_, ?_, ?_, ?_вЯ©
  ¬Ј show R.left вЙ§ R.left + t * (R.right - R.left)
    nlinarith [R.hleft_lt_right]
  ¬Ј show R.left + t * (R.right - R.left) вЙ§ R.right
    nlinarith [R.hleft_lt_right]
  ¬Ј show R.bottom вЙ§ R.bottom
    rfl
  ¬Ј show R.bottom вЙ§ R.top
    exact le_of_lt R.hbottom_lt_top

/-- **Q4 right.** The right edge stays in the closed rectangle for
`0 вЙ§ t вЙ§ 1`. -/
theorem rightEdge_mem_closed
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsClosed (R.rightEdge t) := by
  refine вЯ®?_, ?_, ?_, ?_вЯ©
  ¬Ј show R.left вЙ§ R.right
    exact le_of_lt R.hleft_lt_right
  ¬Ј show R.right вЙ§ R.right
    rfl
  ¬Ј show R.bottom вЙ§ R.bottom + t * (R.top - R.bottom)
    nlinarith [R.hbottom_lt_top]
  ¬Ј show R.bottom + t * (R.top - R.bottom) вЙ§ R.top
    nlinarith [R.hbottom_lt_top]

/-- **Q4 top.** The top edge stays in the closed rectangle for
`0 вЙ§ t вЙ§ 1`. -/
theorem topEdge_mem_closed
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsClosed (R.topEdge t) := by
  refine вЯ®?_, ?_, ?_, ?_вЯ©
  ¬Ј show R.left вЙ§ R.right - t * (R.right - R.left)
    nlinarith [R.hleft_lt_right]
  ¬Ј show R.right - t * (R.right - R.left) вЙ§ R.right
    nlinarith [R.hleft_lt_right]
  ¬Ј show R.bottom вЙ§ R.top
    exact le_of_lt R.hbottom_lt_top
  ¬Ј show R.top вЙ§ R.top
    rfl

/-- **Q4 left.** The left edge stays in the closed rectangle for
`0 вЙ§ t вЙ§ 1`. -/
theorem leftEdge_mem_closed
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsClosed (R.leftEdge t) := by
  refine вЯ®?_, ?_, ?_, ?_вЯ©
  ¬Ј show R.left вЙ§ R.left
    rfl
  ¬Ј show R.left вЙ§ R.right
    exact le_of_lt R.hleft_lt_right
  ¬Ј show R.bottom вЙ§ R.top - t * (R.top - R.bottom)
    nlinarith [R.hbottom_lt_top]
  ¬Ј show R.top - t * (R.top - R.bottom) вЙ§ R.top
    nlinarith [R.hbottom_lt_top]

/-! ### Rectangle edge boundary membership -/

/-- **R1 bottom.** The bottom edge lies on the rectangle boundary. -/
theorem bottomEdge_mem_boundary
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsBoundary (R.bottomEdge t) := by
  refine вЯ®R.bottomEdge_mem_closed ht0 ht1, ?_вЯ©
  intro hopen
  have hbottom_lt : R.bottom < (R.bottomEdge t).im := hopen.2.2.1
  simp [bottomEdge] at hbottom_lt

/-- **R1 right.** The right edge lies on the rectangle boundary. -/
theorem rightEdge_mem_boundary
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsBoundary (R.rightEdge t) := by
  refine вЯ®R.rightEdge_mem_closed ht0 ht1, ?_вЯ©
  intro hopen
  have hright_lt : (R.rightEdge t).re < R.right := hopen.2.1
  simp [rightEdge] at hright_lt

/-- **R1 top.** The top edge lies on the rectangle boundary. -/
theorem topEdge_mem_boundary
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsBoundary (R.topEdge t) := by
  refine вЯ®R.topEdge_mem_closed ht0 ht1, ?_вЯ©
  intro hopen
  have htop_lt : (R.topEdge t).im < R.top := hopen.2.2.2
  simp [topEdge] at htop_lt

/-- **R1 left.** The left edge lies on the rectangle boundary. -/
theorem leftEdge_mem_boundary
    (R : ZetaRectangle) {t : вДЭ}
    (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    R.ContainsBoundary (R.leftEdge t) := by
  refine вЯ®R.leftEdge_mem_closed ht0 ht1, ?_вЯ©
  intro hopen
  have hleft_lt : R.left < (R.leftEdge t).re := hopen.1
  simp [leftEdge] at hleft_lt

/-! ### Admissibility on edges -/

/-- **R2 generic.** An admissible rectangle has no nontrivial zeta zero
on any boundary point. -/
theorem not_isNontrivialZetaZero_of_admissible_boundary
    {R : ZetaRectangle}
    (hAdm : R.AdmissibleForZeta)
    {s : вДВ}
    (hsBoundary : R.ContainsBoundary s) :
    ¬ђ IsNontrivialZetaZero s :=
  fun hs => hAdm.noZerosOnBoundary s hs hsBoundary

/-- **R2 bottom.** No nontrivial zeta zero on the bottom edge of an
admissible rectangle. -/
theorem not_isNontrivialZetaZero_bottomEdge
    {R : ZetaRectangle}
    (hAdm : R.AdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    ¬ђ IsNontrivialZetaZero (R.bottomEdge t) :=
  not_isNontrivialZetaZero_of_admissible_boundary hAdm
    (R.bottomEdge_mem_boundary ht0 ht1)

/-- **R2 right.** No nontrivial zeta zero on the right edge. -/
theorem not_isNontrivialZetaZero_rightEdge
    {R : ZetaRectangle}
    (hAdm : R.AdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    ¬ђ IsNontrivialZetaZero (R.rightEdge t) :=
  not_isNontrivialZetaZero_of_admissible_boundary hAdm
    (R.rightEdge_mem_boundary ht0 ht1)

/-- **R2 top.** No nontrivial zeta zero on the top edge. -/
theorem not_isNontrivialZetaZero_topEdge
    {R : ZetaRectangle}
    (hAdm : R.AdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    ¬ђ IsNontrivialZetaZero (R.topEdge t) :=
  not_isNontrivialZetaZero_of_admissible_boundary hAdm
    (R.topEdge_mem_boundary ht0 ht1)

/-- **R2 left.** No nontrivial zeta zero on the left edge. -/
theorem not_isNontrivialZetaZero_leftEdge
    {R : ZetaRectangle}
    (hAdm : R.AdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    ¬ђ IsNontrivialZetaZero (R.leftEdge t) :=
  not_isNontrivialZetaZero_of_admissible_boundary hAdm
    (R.leftEdge_mem_boundary ht0 ht1)

/-! ### Strong admissibility (no zeta zero whatsoever on boundary) -/

/-- **R3.** No zeta zero (trivial or nontrivial) lies on the rectangle
boundary.  This is the boundary condition needed for the logarithmic
derivative `ќґ'/ќґ`. -/
def NoZetaZerosOnBoundary (R : ZetaRectangle) : Prop :=
  вИА s : вДВ, riemannZeta s = 0 вЖТ R.ContainsBoundary s вЖТ False

/-- Strong admissibility: no zeta zeros and no pole on the boundary. -/
structure StronglyAdmissibleForZeta (R : ZetaRectangle) : Prop where
  noZetaZerosOnBoundary : R.NoZetaZerosOnBoundary
  poleNotOnBoundary : R.PoleNotOnBoundary

/-- Strong admissibility implies ordinary admissibility, since every
nontrivial zero is a zeta zero. -/
theorem StronglyAdmissibleForZeta.toAdmissibleForZeta
    {R : ZetaRectangle}
    (h : R.StronglyAdmissibleForZeta) :
    R.AdmissibleForZeta where
  noZerosOnBoundary := by
    intro s hsNT hsBoundary
    exact h.noZetaZerosOnBoundary s hsNT.1 hsBoundary
  poleNotOnBoundary := h.poleNotOnBoundary

/-! ### Strong nonvanishing on edges -/

/-- **R4 generic.** Strong admissibility implies `ќґ вЙ† 0` on every
boundary point. -/
theorem zeta_ne_zero_of_stronglyAdmissible_boundary
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    {s : вДВ}
    (hsBoundary : R.ContainsBoundary s) :
    riemannZeta s вЙ† 0 :=
  fun hz => hAdm.noZetaZerosOnBoundary s hz hsBoundary

/-- **R4 bottom.** `ќґ вЙ† 0` on the bottom edge under strong
admissibility. -/
theorem zeta_ne_zero_bottomEdge
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    riemannZeta (R.bottomEdge t) вЙ† 0 :=
  zeta_ne_zero_of_stronglyAdmissible_boundary hAdm
    (R.bottomEdge_mem_boundary ht0 ht1)

/-- **R4 right.** `ќґ вЙ† 0` on the right edge. -/
theorem zeta_ne_zero_rightEdge
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    riemannZeta (R.rightEdge t) вЙ† 0 :=
  zeta_ne_zero_of_stronglyAdmissible_boundary hAdm
    (R.rightEdge_mem_boundary ht0 ht1)

/-- **R4 top.** `ќґ вЙ† 0` on the top edge. -/
theorem zeta_ne_zero_topEdge
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    riemannZeta (R.topEdge t) вЙ† 0 :=
  zeta_ne_zero_of_stronglyAdmissible_boundary hAdm
    (R.topEdge_mem_boundary ht0 ht1)

/-- **R4 left.** `ќґ вЙ† 0` on the left edge. -/
theorem zeta_ne_zero_leftEdge
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    {t : вДЭ} (ht0 : 0 вЙ§ t) (ht1 : t вЙ§ 1) :
    riemannZeta (R.leftEdge t) вЙ† 0 :=
  zeta_ne_zero_of_stronglyAdmissible_boundary hAdm
    (R.leftEdge_mem_boundary ht0 ht1)

/-! ### Edge continuity -/

/-- **S1 bottom.** The bottom edge parametrization is continuous. -/
theorem continuous_bottomEdge (R : ZetaRectangle) :
    Continuous R.bottomEdge := by
  have heq : R.bottomEdge =
      fun t : вДЭ =>
        ((R.left + t * (R.right - R.left) : вДЭ) : вДВ)
          + (R.bottom : вДВ) * Complex.I := by
    funext t
    apply Complex.ext <;> simp [bottomEdge]
  rw [heq]
  continuity

/-- **S1 right.** The right edge parametrization is continuous. -/
theorem continuous_rightEdge (R : ZetaRectangle) :
    Continuous R.rightEdge := by
  have heq : R.rightEdge =
      fun t : вДЭ =>
        ((R.right : вДЭ) : вДВ)
          + ((R.bottom + t * (R.top - R.bottom) : вДЭ) : вДВ) * Complex.I := by
    funext t
    apply Complex.ext <;> simp [rightEdge]
  rw [heq]
  continuity

/-- **S1 top.** The top edge parametrization is continuous. -/
theorem continuous_topEdge (R : ZetaRectangle) :
    Continuous R.topEdge := by
  have heq : R.topEdge =
      fun t : вДЭ =>
        ((R.right - t * (R.right - R.left) : вДЭ) : вДВ)
          + (R.top : вДВ) * Complex.I := by
    funext t
    apply Complex.ext <;> simp [topEdge]
  rw [heq]
  continuity

/-- **S1 left.** The left edge parametrization is continuous. -/
theorem continuous_leftEdge (R : ZetaRectangle) :
    Continuous R.leftEdge := by
  have heq : R.leftEdge =
      fun t : вДЭ =>
        ((R.left : вДЭ) : вДВ)
          + ((R.top - t * (R.top - R.bottom) : вДЭ) : вДВ) * Complex.I := by
    funext t
    apply Complex.ext <;> simp [leftEdge]
  rw [heq]
  continuity

/-! ### Log-derivative integrability package -/

/-- **S3b.** Integrability hypotheses for the zeta logarithmic derivative
along the four edges of a rectangle.  Future analytic work must inhabit
this package; it does not assert integrability. -/
structure ZetaRectangleLogDerivIntegrable (R : ZetaRectangle) : Prop where
  bottom :
