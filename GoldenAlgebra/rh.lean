/-- **Helper 8b def**: a safe rational lower bound for `tailK_12_13`. -/
noncomputable def tailK12_const : вДЭ := 7 / 1000

/-- в≠Р **PROVED вАФ Helper 8b: `tailK_12_13 T вЙ• 7/1000` on `[12, 13]`.**
Chain: `tailK = (22/15)¬Ј((affine LB)/(2ѕА))/T`. With affine LB вЙ• 2/5,
`1/(2ѕА) вЙ• 3/19`, and `1/T вЙ• 1/13`:
  tailK вЙ• (22/15)¬Ј(2/5)¬Ј(3/19)¬Ј(1/13) = 132/18525 > 7/1000. -/
lemma tailK_12_13_ge_const
    {T : вДЭ} (hT12 : 12 вЙ§ T) (hT13 : T вЙ§ 13) :
    tailK12_const вЙ§ tailK_12_13 T := by
  unfold tailK12_const tailK_12_13
  have hT_pos : 0 < T := by linarith
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_aff_ge : (2 / 5 : вДЭ) вЙ§ (2 / 5 : вДЭ) + (T - 12) / 10 := by linarith
  have h_aff_nn : (0 : вДЭ) вЙ§ (2 / 5 : вДЭ) + (T - 12) / 10 := by linarith
  have h_2pi_inv : (3 / 19 : вДЭ) вЙ§ 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_three_nineteenths
  have h_T_le_13 : T вЙ§ 13 := hT13
  have h_inv_T : (1 / 13 : вДЭ) вЙ§ 1 / T := one_div_le_one_div_of_le hT_pos h_T_le_13
  -- chain:  (22/15) ¬Ј ((2/5)¬Ј(3/19))/13 вЙ§ (22/15)¬Ј(affine LB)¬Ј(1/(2ѕА))/T  вЙ§  tailK_12_13 T
  -- = 132/(18525). Want вЙ• 7/1000.
  have h_2pi_inv_nn : (0 : вДЭ) вЙ§ 1 / (2 * Real.pi) := by positivity
  have h_T_inv_nn : (0 : вДЭ) вЙ§ 1 / T := by positivity
  -- Show: (22/15) ¬Ј (affine LB / (2ѕА)) / T = (22/15) ¬Ј (affine LB) ¬Ј (1/(2ѕА)) ¬Ј (1/T)
  have h_form_eq : (22 / 15 : вДЭ) *
      (((2 / 5 : вДЭ) + (T - 12) / 10) / (2 * Real.pi)) / T
      = (22 / 15) * ((2/5 : вДЭ) + (T - 12)/10) * (1 / (2 * Real.pi)) * (1/T) := by
    ring
  rw [h_form_eq]
  -- Bound by the four nonneg multiplicands
  have h_22_15_nn : (0:вДЭ) вЙ§ 22 / 15 := by norm_num
  have h_aff_part_nn : (0:вДЭ) вЙ§ (22 / 15) * ((2/5 : вДЭ) + (T - 12)/10) := by
    apply mul_nonneg h_22_15_nn h_aff_nn
  have h1 : (22 / 15 : вДЭ) * (2/5) вЙ§ (22 / 15) * ((2/5 : вДЭ) + (T - 12)/10) := by
    apply mul_le_mul_of_nonneg_left h_aff_ge h_22_15_nn
  have h2 : (22 / 15 : вДЭ) * ((2/5 : вДЭ) + (T - 12)/10) * (3/19)
          вЙ§ (22 / 15) * ((2/5 : вДЭ) + (T - 12)/10) * (1/(2*Real.pi)) := by
    apply mul_le_mul_of_nonneg_left h_2pi_inv h_aff_part_nn
  -- Combine into nlinarith-style
  nlinarith [h1, h2, h_inv_T, h_2pi_inv, h_22_15_nn, h_aff_ge, h_aff_nn,
             mul_pos hT_pos hT_pos]

