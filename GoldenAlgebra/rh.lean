/-- тнР **PROVED тАФ Helper 7: smooth-tail LB on `[12, 13]`** via affine ╧Б
plus CLV's `_ge_22_15` bound. -/
lemma smoothTail_ge_affine_12_13
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hT12 : 12 тЙд T) (hT13 : T тЙд 13)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T) :
    y * tailK_12_13 T тЙд smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_12_13
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hT_2pi : 2 * Real.pi тЙд T := by linarith
  have hreg' : 2 * (1 + |x| + y) тЙд T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : ((2/5 : тДЭ) + (T - 12) / 10) / (2 * Real.pi) тЙд zeroDensityRho T :=
    zeroDensityRho_ge_affine_12_13 hT12 hT13
