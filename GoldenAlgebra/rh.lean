/-- Ô¡É **PROVED ÔÇö adaptive `8y/T┬▓` kernel bound** at the boundary.
On the adaptive regime `2(1 + |x| + y) Ôëñ T`,
`|pairedCauchyImKernel x y T| Ôëñ 8 ┬À y / T┬▓`. -/
lemma abs_pairedCauchyImKernel_adaptive_8
    {x y T : ÔäØ} (hy : 0 Ôëñ y) (h_reg : 2 * (1 + |x| + y) Ôëñ T) :
    |pairedCauchyImKernel x y T| Ôëñ 8 * y / T ^ 2 := by
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_x_lt_T : |x| < T := by linarith
  have h_kbnd : |pairedCauchyImKernel x y T| Ôëñ 2 * y / (T - |x|) ^ 2 :=
    Phase1IBP.abs_pairedCauchyImKernel_le_quadratic_tail x y T hy h_x_lt_T
  have h_T_minus_x_ge : T / 2 Ôëñ T - |x| := by linarith
  have h_T_minus_x_nn : (0 : ÔäØ) Ôëñ T / 2 := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_sq_ge : (T / 2) ^ 2 Ôëñ (T - |x|) ^ 2 :=
    pow_le_pow_leftÔéÇ h_T_minus_x_nn h_T_minus_x_ge 2
  have h_half_sq_eq : (T / 2) ^ 2 = T ^ 2 / 4 := by ring
  rw [h_half_sq_eq] at h_sq_ge
  have h_sq_pos : 0 < (T - |x|) ^ 2 := pow_pos h_T_minus_x_pos 2
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_target : 2 * y / (T - |x|) ^ 2 Ôëñ 8 * y / T ^ 2 := by
    rw [div_le_div_iffÔéÇ h_sq_pos h_T_sq_pos]
    nlinarith [h_sq_ge, hy]
  linarith

