theorem closedFormSErrorBoundCD_expand
    (C D y T : тДЭ) (hT : T тЙа 0) :
    closedFormSErrorBoundCD C D y T
      = (y / T^2) * (17 * C * Real.log T + 17 * D + 9 * C / 2) := by
