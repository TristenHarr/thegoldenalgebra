/-! ## CR: Functional-equation left-edge zero transfer (proof attempt) -/

/-- `cos(ѕА * вЯ®2, -yвЯ© / 2) = -cosh(ѕАy/2)`.  Decomposes the argument as
`ѕА + (-ѕАy/2)¬ЈI` and uses the angle-addition formula + `cos(x¬ЈI) = cosh x`. -/
theorem cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh (y : вДЭ) :
    Complex.cos ((Real.pi : вДВ) * (вЯ®2, -yвЯ© : вДВ) / 2) =
      -((Real.cosh (Real.pi * y / 2) : вДЭ) : вДВ) := by
  have h_decomp :
      ((Real.pi : вДВ) * (вЯ®2, -yвЯ© : вДВ) / 2) =
        (Real.pi : вДВ) + (-((Real.pi * y / 2 : вДЭ) : вДВ)) * Complex.I := by
    apply Complex.ext
    ¬Ј simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_re,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
    ¬Ј simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_im,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
      ring
  rw [h_decomp, Complex.cos_add]
  have h_cos_pi : Complex.cos (Real.pi : вДВ) = -1 := by
    rw [вЖР Complex.ofReal_cos, Real.cos_pi]; push_cast; rfl
  have h_sin_pi : Complex.sin (Real.pi : вДВ) = 0 := by
    rw [вЖР Complex.ofReal_sin, Real.sin_pi]; push_cast; rfl
  rw [h_cos_pi, h_sin_pi]
  rw [Complex.cos_mul_I]
  rw [show -((Real.pi * y / 2 : вДЭ) : вДВ) = -(((Real.pi * y / 2 : вДЭ) : вДВ)) from rfl,
      Complex.cosh_neg]
  rw [Complex.ofReal_cosh]
  ring

/-- Nonvanishing of the cosine factor in the FE at `s = вЯ®2, -yвЯ©`. -/
theorem cos_pi_mul_twoMinusYI_div_two_ne_zero (y : вДЭ) :
    Complex.cos ((Real.pi : вДВ) * (вЯ®2, -yвЯ© : вДВ) / 2) вЙ† 0 := by
  rw [cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh]
  rw [neg_ne_zero, Complex.ofReal_ne_zero]
  exact (Real.cosh_pos _).ne'

/-- **CR вАФ PROVED:** the functional-equation left-edge nonzero transfer.
At `s = вЯ®2, -yвЯ©` we apply `riemannZeta_one_sub` and show every factor on
the right is nonzero. -/
theorem zetaFunctionalEquationLeftEdgeTransfer :
    ZetaFunctionalEquationLeftEdgeTransfer := by
  intro y _hright
  set s : вДВ := вЯ®2, -yвЯ© with hs_def
  have h_s_re : s.re = 2 := by simp [hs_def]
  have h_one_sub_s : (1 : вДВ) - s = вЯ®(-1 : вДЭ), yвЯ© := by
    apply Complex.ext
    ¬Ј show (1 - s).re = -1
      simp [hs_def, Complex.sub_re, Complex.one_re]
      norm_num
    ¬Ј show (1 - s).im = y
      simp [hs_def, Complex.sub_im, Complex.one_im]
  have h_s_ne_neg_n : вИА n : вДХ, s вЙ† -вЖСn := by
    intro n h
    have h_re : s.re = (-(n : вДВ)).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (ќ± := вДЭ) n]
  have h_s_ne_one : s вЙ† 1 := by
    intro h
    have h_re : s.re = (1 : вДВ).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
  rw [вЖР h_one_sub_s, riemannZeta_one_sub h_s_ne_neg_n h_s_ne_one]
  have h_2pi_ne_C : ((2 : вДВ) * (Real.pi : вДВ)) вЙ† 0 := by
    have hѕА : (Real.pi : вДВ) вЙ† 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) hѕА
  have h_2pi_pow : ((2 * (Real.pi : вДВ)) ^ (-s)) вЙ† 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s вЙ† 0 := by
    apply Complex.Gamma_ne_zero_of_re_pos
    rw [h_s_re]; norm_num
  have h_zeta_ne : riemannZeta s вЙ† 0 := by
    apply riemannZeta_ne_zero_of_one_lt_re
    rw [h_s_re]; norm_num
  have h_cos_ne : Complex.cos ((Real.pi : вДВ) * s / 2) вЙ† 0 := by
    rw [hs_def]
    exact cos_pi_mul_twoMinusYI_div_two_ne_zero y
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  ¬Ј norm_num
  ¬Ј exact h_2pi_pow
  ¬Ј exact h_gamma_ne
  ¬Ј exact h_cos_ne
  ¬Ј exact h_zeta_ne

/-! ## CS: No zeros of `ќґ` in the left half-plane upper half -/

/-- `Complex.cos w вЙ† 0` whenever `w.im вЙ† 0`.  Zeros of `cos` are real
half-odd-integer multiples of `ѕА`, so any complex `w` with nonzero
imaginary part avoids them. -/
theorem Complex.cos_ne_zero_of_im_ne_zero
    {w : вДВ} (hw : w.im вЙ† 0) :
    Complex.cos w вЙ† 0 := by
  rw [Complex.cos_ne_zero_iff]
  intro k heq
  have h_im_eq :
      w.im = ((2 * (k : вДВ) + 1) * (Real.pi : вДВ) / 2).im :=
    congrArg Complex.im heq
  have h_rhs_im : ((2 * (k : вДВ) + 1) * (Real.pi : вДВ) / 2).im = 0 := by
    simp [Complex.div_im, Complex.mul_im, Complex.add_im, Complex.intCast_im,
          Complex.ofReal_re, Complex.ofReal_im, Complex.one_im,
          Complex.normSq_apply]
  rw [h_rhs_im] at h_im_eq
  exact hw h_im_eq

/-- **CS вАФ PROVED:** `ќґ` has no zeros at points with `Re вЙ§ 0` and `Im > 0`.
Functional equation: ќґ(1-s) = factors ¬Ј ќґ(s), at `s = 1 - z` (so `Re s вЙ• 1`,
`Im s = -Im z < 0`).  RHS factors are all nonzero (`ќУ(s) вЙ† 0` since
`Re s > 0`; `ќґ(s) вЙ† 0` since `Re s вЙ• 1`; `cos(ѕАs/2) вЙ† 0` since `Im s вЙ† 0`;
`(2ѕА)^(-s) вЙ† 0`; `2 вЙ† 0`).  Contradicts `ќґ z = ќґ(1-s) = 0`. -/
theorem zetaNoZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper := by
  intro z hzRe hzIm hzeta
  set s : вДВ := 1 - z with hs_def
  have hs_re : s.re = 1 - z.re := by simp [hs_def]
  have hs_im : s.im = -z.im := by simp [hs_def]
  have hs_re_ge_one : 1 вЙ§ s.re := by rw [hs_re]; linarith
  have hs_re_pos : 0 < s.re := by linarith
  have hs_im_neg : s.im < 0 := by rw [hs_im]; linarith
  have hs_im_ne : s.im вЙ† 0 := ne_of_lt hs_im_neg
  have h_zeta_s_ne : riemannZeta s вЙ† 0 :=
    riemannZeta_ne_zero_of_one_le_re hs_re_ge_one
  have hs_ne_neg_n : вИА n : вДХ, s вЙ† -вЖСn := by
    intro n h
    have h_re : s.re = (-(n : вДВ)).re := congrArg Complex.re h
    rw [hs_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (ќ± := вДЭ) n]
  have hs_ne_one : s вЙ† 1 := by
    intro h
    have h_im : s.im = (1 : вДВ).im := congrArg Complex.im h
    simp at h_im
    linarith
  have h_1s_z : (1 : вДВ) - s = z := by simp [hs_def]
  have hFE := riemannZeta_one_sub hs_ne_neg_n hs_ne_one
  rw [h_1s_z, hzeta] at hFE
  apply absurd hFE.symm
  have h_2pi_ne_C : ((2 : вДВ) * (Real.pi : вДВ)) вЙ† 0 := by
    have hѕА : (Real.pi : вДВ) вЙ† 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) hѕА
  have h_2pi_pow : ((2 * (Real.pi : вДВ)) ^ (-s)) вЙ† 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s вЙ† 0 :=
    Complex.Gamma_ne_zero_of_re_pos hs_re_pos
  have h_cos_ne : Complex.cos ((Real.pi : вДВ) * s / 2) вЙ† 0 := by
    apply Complex.cos_ne_zero_of_im_ne_zero
    have h_arg_im : ((Real.pi : вДВ) * s / 2).im = Real.pi * s.im / 2 := by
      simp [Complex.div_im, Complex.mul_im, Complex.ofReal_re,
            Complex.ofReal_im, Complex.normSq_apply]
    rw [h_arg_im]
    have hpi_pos : 0 < Real.pi := Real.pi_pos
    intro h
    have : Real.pi * s.im = 0 := by linarith
    rcases mul_eq_zero.mp this with h1 | h2
    ¬Ј exact absurd h1 hpi_pos.ne'
    ¬Ј exact hs_im_ne h2
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  ¬Ј norm_num
  ¬Ј exact h_2pi_pow
  ¬Ј exact h_gamma_ne
  ¬Ј exact h_cos_ne
  ¬Ј exact h_zeta_s_ne

