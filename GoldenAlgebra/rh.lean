    rw [Complex.star_def,
        show ((1 / 2 : вДВ)) = (((1 / 2 : вДЭ)) : вДВ) from by norm_num,
        Complex.conj_ofReal]
  rw [show star ((1 / 2 : вДВ) * s * (s - 1) * completedRiemannZetaвВА s + (1 / 2 : вДВ))
        = (1 / 2 : вДВ) * star s * (star s - 1) * star (completedRiemannZetaвВА s) + (1 / 2 : вДВ)
      from by
    rw [star_add, star_mul', star_mul', star_mul', star_sub, star_one, h_half]]

/-- в≠Р **PROVED вАФ strengthened RH-facing capstone with Schwarz reduced
to the FE-pair real-lifting target.** -/
