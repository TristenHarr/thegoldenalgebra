  have hnonneg :
      0 тЙд (extra.map (fun ╬│ => 2 * y / (x^2 + ╬│^2 + y^2))).sum := by
    apply List.sum_nonneg
    intro a ha
    simp only [List.mem_map] at ha
    rcases ha with тЯи╬│, _, rflтЯй
    have hnum : (0 : тДЭ) тЙд 2 * y := by linarith
    have hdenpos : 0 < x^2 + ╬│^2 + y^2 := by positivity
    exact div_nonneg hnum (le_of_lt hdenpos)
  linarith

/-- тнР **PROVED тАФ Helper: `cloudK_T` monotone under list append.** -/
