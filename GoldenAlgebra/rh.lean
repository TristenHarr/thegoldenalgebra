fields discharged by CR2 and CS. -/
noncomputable def zetaFunctionalEquationStandardZeroFactsViaTransfer :
    ZetaFunctionalEquationStandardZeroFactsViaTransfer where
  noZerosLeftHalfPlaneUpper := zetaNoZerosLeftHalfPlaneUpper
  leftEdgeTransfer := zetaFunctionalEquationLeftEdgeTransfer

/-- The fully-proven zero-classification input. -/
noncomputable def zetaZeroClassificationInput : ZetaZeroClassificationInput :=
