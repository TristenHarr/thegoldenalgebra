        tailContribution z = lowTailZeroContribution Dzero T0 z
  split :
    тИА z : тДВ, lowCompactRegion z тЖТ XiPullback z тЙа 0 тЖТ
      LowFirstZeroGapNoAtoms Dzero тЖТ
        ZC z = finiteCloudContribution z + tailContribution z

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `LowZeroContributionSplitAFZ` from the atomic
cloud/tail split.** Reduces the ┬зCCCLX target to three independent
identities. -/
theorem LowZeroContributionSplitAFZ.of_cloudTailSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {ZC : тДВ тЖТ тДВ} {finiteCloudContribution tailContribution : тДВ тЖТ тДВ}
    (H : LowCloudTailSplitAFZ Dzero T0 ZC
            finiteCloudContribution tailContribution) :
    LowZeroContributionSplitAFZ Dzero T0 ZC := by
  refine тЯи?_тЯй
  intro z hz hne Hno
  rw [H.split z hz hne Hno, H.cloud_exact z hz,
      H.tail_exact z hz hne Hno]

