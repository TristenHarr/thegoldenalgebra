noncomputable def perWindowGlobalErrorControl_of_low_mid_high
    {error : Ôäé ÔåÆ Ôäé}
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi)
    (hF_B : F.B = 10)
    (hF_model : F.model = xiCloudDensityModel_zeros100ceil.model)
    (hlow : lowTErrorControlled error F.errorBound)
    (hmid : closedFormErrorControlledOnFiniteBand error)
    (hhigh : highTErrorControlled error) :
    PerWindowGlobalErrorControl xiCloudDensityModel_zeros100ceil error where
  low := by
    intro z T hT2pi hT10 hy hreg
