    (Tsmooth : вДЭ) (hTsmooth_ge : 2 * Real.pi вЙ§ Tsmooth)
    (error : вДВ вЖТ вДВ) where
  fluctTailPart : вДВ вЖТ вДВ
  model_eq :
    вИА z : вДВ,
