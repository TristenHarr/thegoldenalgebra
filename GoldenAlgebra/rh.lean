noncomputable def globalRectangleCauchyGoursatBridge : RectangleCauchyGoursatBridge :=
  RectangleCauchyGoursatBridge.of_mathlibHook mathlibCauchyGoursatHook

/-! ## BT: Cauchy-Goursat closure of the principal-part contour decomposition -/

/-! ### BT1: vanishing of the remainder integral from analyticity -/

/-- If the log-derivative remainder is analytic at every point of the closed
rectangle, then its rectangle boundary integral vanishes (Mathlib
Cauchy-Goursat via the unconditional global bridge). -/
noncomputable def rectangleLogDerivRemainderIntegralVanishes_of_analyticOn
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (hAn : ÔêÇ z Ôêê {z : Ôäé | R.ContainsClosed z},
      AnalyticAt Ôäé (R.logDerivRemainder P) z) :
    R.RectangleLogDerivRemainderIntegralVanishes P where
  integral_eq_zero :=
    globalRectangleCauchyGoursatBridge.cauchyGoursat R
      (R.logDerivRemainder P) hAn

/-! ### BT2: analytic-remainder data package -/

/-- The analytic content needed for the remainder: after subtracting all
local principal parts, `╬Â'/╬Â` is analytic at every closed-rectangle point. -/
