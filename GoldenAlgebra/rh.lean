-- §CCLXXVII. Low residual explicit-formula interface
-- =====================================================================
-- `Hlow` cannot be reduced to rational/log bounds alone:
-- `xiResidualError honestZeroDensityModelTwoPi` contains `Λ[Ξ]` with
-- no concrete computation in the repo. The correct move is the
-- low-band analogue of `Hcanon_tailLimit` / `Hhigh_tailLimit`: a named
-- explicit-formula residual bound at the canonical first-zero
-- parameters `(γ₁, D) := (14, 1/2)`.
--
-- Adds:
--   lowResidualExplicitBound                            — explicit closed form
--   XiLowResidualExplicitData                           — residual ≤ explicit bound
--   LowMarginDominatesExplicitBound                     — explicit bound ≤ model margin
--   XiLowResidualMargin_of_explicit_and_margin          — bridge
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit
--                                                       — final front door

/-- **Low residual explicit bound** — `closedFormFirstZeroErrorBound`
at the canonical first-zero parameters `(γ₁, D) := (14, 1/2)` and
inner cutoff `T := 2π`. Numerically `≈ 0.19 · z.im` for
`0 < z.im ≤ 4`. -/
noncomputable def lowResidualExplicitBound (z : ℂ) : ℝ :=
  closedFormFirstZeroErrorBound z.im (2 * Real.pi) 14 (1 / 2)

/-- 📦 **`XiLowResidualExplicitData`** — the low-band xi-specific
analytic target: on the compact low region, the canonical residual's
Im is bounded by `lowResidualExplicitBound z`. -/
structure XiLowResidualExplicitData
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_bound :
    ∀ z : ℂ,
      lowCompactRegion z →
      |(xiResidualError M z).im| ≤ lowResidualExplicitBound z

/-- 📦 **`LowMarginDominatesExplicitBound`** — model-margin side of
the split: the explicit residual bound is dominated by the actual
model margin on the compact low region. Tractable via `simpleCloudSum`
+ `HonestSmoothTailRationalLB_twoPi`. -/
def LowMarginDominatesExplicitBound
    (M : CloudDensityTailModelDecomposition) : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowResidualExplicitBound z ≤ -(M.model z).im

/-- 🌟🌟 **PROVED — `XiLowResidualMargin` from the two-piece split.**
Composes the explicit residual bound (xi-specific) with the model
margin dominance (model-side analytic). -/
theorem XiLowResidualMargin_of_explicit_and_margin
    (Hexplicit : XiLowResidualExplicitData honestZeroDensityModelTwoPi)
    (Hmargin : LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi) :
    XiLowResidualMargin honestZeroDensityModelTwoPi := by
  intro z hz
  exact le_trans (Hexplicit.residual_bound z hz) (Hmargin z hz)

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **FINAL
FRONT DOOR (twoPi + tail limits + low explicit split).**

The low-band obligation is now split into two genuine analytic pieces:

```
hTuring + hHighLog              (parallel agent)
+ Hcanon_tailLimit              (mid residual Tendsto)
+ Hhigh_tailLimit               (high residual Tendsto)
+ Hlow_explicit                 (xi: residual ≤ closed-form first-zero bound)
+ Hlow_margin                   (model: closed-form bound ≤ -Im(model))
⟹ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hcanon_tailLimit :
      XiCanonicalResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hhigh_tailLimit :
      XiHighResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hlow_explicit :
      XiLowResidualExplicitData honestZeroDensityModelTwoPi)
    (Hlow_margin :
      LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_tailLimits
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
    Hcanon_tailLimit Hhigh_tailLimit
    (XiLowResidualMargin_of_explicit_and_margin
      Hlow_explicit Hlow_margin)

-- =====================================================================
-- §CCLXXVIII. Structural reduction of `LowMarginDominatesExplicitBound`
--             to a single model-side rational/log arithmetic inequality
-- =====================================================================
-- `LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi` is the
-- model-side half of the §CCLXXVII split. It is purely model-side —
-- no `Λ[Ξ]` content — so it should reduce to rational/log arithmetic
-- on the compact low region. This section discharges the structural
-- pieces (cloud anti-Herglotz `-Im` identity, smooth-tail CLV bound
-- via `HonestSmoothTailRationalLB_twoPi` at `T = 10`, and additive
-- `Im` decomposition of the honest model) and exposes the remaining
-- analytic obligation as a single named arithmetic Prop.
--
-- After this section, the entire low-band model obligation is
-- `lowResidualExplicitBound z ≤ simpleCloudSum + smoothTailRationalLowerBoundAbs(...,10)`
-- on `lowCompactRegion z` — a pure inequality in `z.re`, `z.im`, and the
-- 100-element list `zeros100ceil`, with no complex analysis remaining.
--
-- Adds:
--   honestZeroDensityModelTwoPi_model_eq          — definitional decomp
--   honestZeroDensityModelTwoPi_neg_im_eq          — `-Im(model)` splits
--   lowModelMarginEnvelope_eq_cloud_plus_smooth   — envelope form
--   honestZeroDensityModelTwoPi_cloud_simpleLB    — cloud LB via simpleCloudSum
--   honestZeroDensityModelTwoPi_smooth_LB_at_10   — smooth LB at T=10 via CLV
--   LowExplicitArithmeticBound                     — named arithmetic Prop
--   LowMarginDominatesExplicitBound_twoPi_of_arith — `_of_arith` reduction
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit_arith
--                                                  — front door consuming arith

/-- ⭐ **PROVED — model decomposition at `Tsmooth := 2π`.** The honest
model is definitionally the sum of the paired finite cloud on
`zeros100ceil` and the `zeroDensitySmoothTailModel` at `2π`. -/
lemma honestZeroDensityModelTwoPi_model_eq (z : ℂ) :
    honestZeroDensityModelTwoPi.model z
      = cloudModel zeros100ceil z
        + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z := rfl

/-- ⭐ **PROVED — `-Im` of the honest model splits additively.** -/
lemma honestZeroDensityModelTwoPi_neg_im_eq (z : ℂ) :
    -(honestZeroDensityModelTwoPi.model z).im
      = -(cloudModel zeros100ceil z).im
        + -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  rw [honestZeroDensityModelTwoPi_model_eq, Complex.add_im]
  ring

/-- ⭐ **PROVED — envelope form of the additive `-Im` split.** -/
lemma lowModelMarginEnvelope_eq_cloud_plus_smooth (z : ℂ) :
    lowModelMarginEnvelope z
      = -(cloudModel zeros100ceil z).im
        + -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  unfold lowModelMarginEnvelope
  exact honestZeroDensityModelTwoPi_neg_im_eq z

/-- ⭐ **PROVED — cloud part of the model margin is bounded below by
`simpleCloudSum`.** Composes `cloudImNegSum_ge_simpleCloudSum` with the
identity `-Im(cloudModel) = cloudImNegSum`. -/
lemma honestZeroDensityModelTwoPi_cloud_simpleLB
    {z : ℂ} (hy : 0 < z.im) :
    simpleCloudSum zeros100ceil z.re z.im
      ≤ -(cloudModel zeros100ceil z).im := by
  rw [cloudModel_neg_im_at]
  exact cloudImNegSum_ge_simpleCloudSum zeros100ceil z.re z.im hy

/-- ⭐ **PROVED — smooth part of the model margin at `T = 10`** via
`HonestSmoothTailRationalLB_twoPi`. The choice `T := 10` is forced by
the low compact regime `2(1 + |z.re| + z.im) ≤ 10`. -/
lemma honestZeroDensityModelTwoPi_smooth_LB_at_10
    {z : ℂ} (hz : lowCompactRegion z) :
    smoothTailRationalLowerBoundAbs z.re z.im 10
      ≤ -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  have h2pi_le_10 : 2 * Real.pi ≤ 10 := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  exact HonestSmoothTailRationalLB_twoPi z 10 h2pi_le_10 hz.1 hz.2

/-- 📦 **`LowExplicitArithmeticBound`** — the named pure-arithmetic
obligation isolated by the §CCLXXVIII reduction. After all structural
content is discharged, `LowMarginDominatesExplicitBound` reduces to
this single rational/log inequality on the compact low region:
```
lowResidualExplicitBound z
  ≤ simpleCloudSum zeros100ceil z.re z.im
      + smoothTailRationalLowerBoundAbs z.re z.im 10
```
No complex analysis remaining — only the explicit closed-form
expressions in `z.re`, `z.im`, and the 100-element list. -/
def LowExplicitArithmeticBound : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowResidualExplicitBound z
      ≤ simpleCloudSum zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbs z.re z.im 10

/-- 🌟🌟🌟🌟 **PROVED — `LowMarginDominatesExplicitBound` from the
arithmetic Prop.** The structural decomposition (cloud `-Im` identity,
smooth-tail CLV LB at `T=10`, additive `Im` split) discharges all
complex-analytic content; the remaining obligation is the named
`LowExplicitArithmeticBound`. -/
theorem LowMarginDominatesExplicitBound_twoPi_of_arith
    (harith : LowExplicitArithmeticBound) :
    LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi := by
  intro z hz
  have hcloud := honestZeroDensityModelTwoPi_cloud_simpleLB hz.1
  have hsmooth := honestZeroDensityModelTwoPi_smooth_LB_at_10 hz
  have harith_z := harith z hz
  rw [honestZeroDensityModelTwoPi_neg_im_eq]
  linarith

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **FINAL
FRONT DOOR (twoPi + tail limits + low explicit split with arithmetic).**

The low-band model obligation is now reduced to a single pure
