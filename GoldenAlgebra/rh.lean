/-- Requires `1 вЙ§ A` so we get `1 вЙ§ T` and thus `Real.log T вЙ• 0`. -/
lemma closedFormSErrorBoundCD_36_48_subband_le_const
    {A L y T : вДЭ}
    (hy : 0 вЙ§ y)
    (hA_ge_one : 1 вЙ§ A)
    (hTA : A вЙ§ T)
    (hlog : Real.log T вЙ§ L) :
    closedFormSErrorBoundCD (1 / 2 : вДЭ) 1 y T
      вЙ§ y * (((17 / 2 : вДЭ) * L + 77 / 4) / A^2) := by
  have hApos : 0 < A := by linarith
  have hTpos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hTpos
  have hT2pos : 0 < T^2 := by positivity
  have hA2pos : 0 < A^2 := by positivity
  have hA2_le_T2 : A^2 вЙ§ T^2 := by nlinarith
  have hT_ge_one : (1 : вДЭ) вЙ§ T := by linarith
  have hlog_nn : 0 вЙ§ Real.log T := Real.log_nonneg hT_ge_one
  have hL_nn : 0 вЙ§ L := le_trans hlog_nn hlog
  rw [closedFormSErrorBoundCD_half_one_eq hT_ne]
  unfold closedFormSErrorBoundHalfOne
  have hcoeff_le :
      (17 / 2 : вДЭ) * Real.log T + 77 / 4 вЙ§ (17 / 2 : вДЭ) * L + 77 / 4 := by
    nlinarith
  have hnum_nn : 0 вЙ§ (17 / 2 : вДЭ) * L + 77 / 4 := by nlinarith
  have hz_nn : 0 вЙ§ y / T^2 := div_nonneg hy (le_of_lt hT2pos)
  calc
    (y / T^2) * ((17 / 2 : вДЭ) * Real.log T + 77 / 4)
        вЙ§ (y / T^2) * ((17 / 2 : вДЭ) * L + 77 / 4) :=
          mul_le_mul_of_nonneg_left hcoeff_le hz_nn
    _ = y * (((17 / 2 : вДЭ) * L + 77 / 4) / T^2) := by ring
    _ вЙ§ y * (((17 / 2 : вДЭ) * L + 77 / 4) / A^2) := by
      apply mul_le_mul_of_nonneg_left _ hy
      exact div_le_div_of_nonneg_left hnum_nn hA2pos hA2_le_T2

