/-- Closed rectangle containing the nontrivial zeta zeros counted up to
height `T`. -/
def closedCriticalRectangle (T : ÔäØ) : Set Ôäé :=
  {s : Ôäé | 0 Ôëñ s.re Ôêº s.re Ôëñ 1 Ôêº 0 Ôëñ s.im Ôêº s.im Ôëñ T}

/-- The set of nontrivial zeta zeros counted up to height `T`. -/
def zetaZerosUpToHeightSet (T : ÔäØ) : Set Ôäé :=
  {s : Ôäé | IsZetaZeroUpToHeight T s}

