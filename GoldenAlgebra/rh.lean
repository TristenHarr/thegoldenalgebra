/-- ⭐ **PROVED — Helper 7: smooth-tail LB on `[12, 13]`** via affine ρ
plus CLV's `_ge_22_15` bound. -/
lemma smoothTail_ge_affine_12_13
    {x y T : ℝ}
    (hx : 0 ≤ x) (hT12 : 12 ≤ T) (hT13 : T ≤ 13)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) ≤ T) :
