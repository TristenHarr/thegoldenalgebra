    I.toSeparatedV2.toSeparatedInputs LC hT

/-! ### CW15: discharge `rightLogDerivPlain` via compactness + analyticity -/

/-- Compactness wrapper: if `y Ôåª ÔÇû(deriv ╬Â / ╬Â)(2 + iy)ÔÇû` is continuous
on `[T, T + 1]`, then it is bounded there. -/
theorem exists_bound_zeta_logDeriv_rightSide_of_continuousOn
    (T : ÔäØ)
    (hcont :
      ContinuousOn
        (fun y : ÔäØ =>
          ÔÇûderiv riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) /
              riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I)ÔÇû)
        (Set.Icc T (T + 1))) :
    Ôêâ C : ÔäØ, 0 Ôëñ C Ôêº
      ÔêÇ y : ÔäØ, T Ôëñ y ÔåÆ y Ôëñ T + 1 ÔåÆ
        ÔÇûderiv riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) /
            riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I)ÔÇû Ôëñ C := by
  have hcomp : IsCompact (Set.Icc T (T + 1)) := isCompact_Icc
  have hne : (Set.Icc T (T + 1)).Nonempty :=
    Set.nonempty_Icc.mpr (by linarith)
  obtain Ôƒ¿yÔéÇ, _hyÔéÇmem, hyÔéÇmaxÔƒ® :=
    hcomp.exists_isMaxOn hne hcont
  set M : ÔäØ :=
    ÔÇûderiv riemannZeta ((2 : Ôäé) + (yÔéÇ : Ôäé) * Complex.I) /
        riemannZeta ((2 : Ôäé) + (yÔéÇ : Ôäé) * Complex.I)ÔÇû with hM_def
  refine Ôƒ¿max M 0, le_max_right _ _, ?_Ôƒ®
  intro y hyT hyT1
  have hmem : y Ôêê Set.Icc T (T + 1) := Ôƒ¿hyT, hyT1Ôƒ®
  have hle :
      ÔÇûderiv riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) /
          riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I)ÔÇû Ôëñ M :=
    hyÔéÇmax hmem
  exact le_trans hle (le_max_left _ _)

/-- For every `T ÔëÑ 140`, the function `y Ôåª ÔÇû(deriv ╬Â / ╬Â)(2 + iy)ÔÇû` is
continuous on `[T, T + 1]`.  Uses analyticity of `╬Â` away from `1`
(`riemannZeta_analyticAt_of_ne_one`), the derived continuity of
`deriv ╬Â`, and the nonvanishing of `╬Â` on `Re s = 2`. -/
theorem continuousOn_zeta_logDeriv_rightSide
    (T : ÔäØ) (_hT : (140 : ÔäØ) Ôëñ T) :
    ContinuousOn
      (fun y : ÔäØ =>
        ÔÇûderiv riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) /
            riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I)ÔÇû)
      (Set.Icc T (T + 1)) := by
  intro y _hy
  refine ContinuousAt.continuousWithinAt ?_
  -- Re(2 + iy) = 2.
  have hre :
      ((2 : Ôäé) + (y : Ôäé) * Complex.I).re = 2 := by
    simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
          Complex.ofReal_re, Complex.ofReal_im]
  have hne : ((2 : Ôäé) + (y : Ôäé) * Complex.I) Ôëá 1 := by
    intro heq
    have h1re : ((1 : Ôäé).re) = 2 := by rw [ÔåÉ hre, heq]
    norm_num at h1re
  have hzeta_ne :
      riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) Ôëá 0 :=
    riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)
  have hAn :
      AnalyticAt Ôäé riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) :=
    riemannZeta_analyticAt_of_ne_one hne
  -- Continuity of `z Ôåª (deriv ╬Â / ╬Â) z` at 2 + iy.
  have hquot_at :
      ContinuousAt
        (fun z : Ôäé => deriv riemannZeta z / riemannZeta z)
        ((2 : Ôäé) + (y : Ôäé) * Complex.I) :=
    (hAn.deriv.continuousAt).div hAn.continuousAt hzeta_ne
  -- Line y Ôåª 2 + iy is continuous.
  have hline_cont :
      Continuous (fun y : ÔäØ => (2 : Ôäé) + (y : Ôäé) * Complex.I) :=
    continuous_const.add
      (Complex.continuous_ofReal.mul continuous_const)
  -- Compose into a real ÔåÆ Ôäé function and take norm.
  have hcompose_at :
      ContinuousAt
        (fun y : ÔäØ =>
          deriv riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I) /
            riemannZeta ((2 : Ôäé) + (y : Ôäé) * Complex.I)) y := by
    change ContinuousAt
      ((fun z : Ôäé => deriv riemannZeta z / riemannZeta z) Ôêÿ
        (fun y : ÔäØ => (2 : Ôäé) + (y : Ôäé) * Complex.I)) y
    refine ContinuousAt.comp ?_ hline_cont.continuousAt
    exact hquot_at
  exact hcompose_at.norm

/-- **CW15 ÔÇö `ZetaLogDerivPlainBoundOnBacklundRightSideInput` DISCHARGED.**
Compactness of `[T, T + 1]` + continuity of `y Ôåª ÔÇû(deriv ╬Â / ╬Â)(2 + iy)ÔÇû`. -/
theorem zetaLogDerivPlainBoundOnBacklundRightSideInput :
    ZetaLogDerivPlainBoundOnBacklundRightSideInput where
  bound := by
    intro T hT
    exact exists_bound_zeta_logDeriv_rightSide_of_continuousOn T
      (continuousOn_zeta_logDeriv_rightSide T hT)

/-! ### CW15: final aggregator ÔÇö only `combination` and `LC` remain -/

/-- Final-stage analytic inputs.  After CW15, the only honest remaining
obligations are the classical Backlund combination lemma and the
zero-count right local constancy. -/
