-- ┬зCCLXXXVIII. Zero-branch regression + taint convention
-- =====================================================================

/-- ЁЯМЯ **PROVED тАФ regression: the zero-branch margin guard.** Names the
exact algebra step every guarded local-package constructor relies on in
its `XiPullback z = 0` branch. -/
theorem lowResidualMargin_zero_branch_guard_test
    {M : CloudDensityTailModelDecomposition}
    {z : тДВ}
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hdecomp :
      тИА z : тДВ,
        logDerivativeResponse XiPullback z =
          M.model z + xiResidualError M z)
    (hz : 0 < z.im)
    (hzero : XiPullback z = 0) :
    |(xiResidualError M z).im| тЙд -(M.model z).im :=
  errorMargin_at_XiPullback_zero_of_decomp
    hmodelAnti hdecomp hz hzero

/-! ### Taint convention

`logDerivativeResponse XiPullback z` is the `a / 0 = 0` totalization of
`deriv (XiPullback) z / XiPullback z`. At any `z` with
`XiPullback z = 0`, the value collapses to `0` тАФ *not* the analytic
limit. `xiResidualError M z := logDerivativeResponse XiPullback z тИТ
M.model z` inherits this taint: at a zero, the residual is
*definitionally* `тИТM.model z`, regardless of any analytic interpretation.

Rule of thumb. Any public analytic input that mentions either
`logDerivativeResponse XiPullback z` or `xiResidualError M z` for `z`
ranging over a region of UHP must carry an explicit
`XiPullback z тЙа 0 тЖТ` guard. The only places allowed to drop the guard
are trusted wrapper constructors that internally do
```
by_cases hzero : XiPullback z = 0
┬╖ exact errorMargin_at_XiPullback_zero_of_decomp ...
┬╖ exact analytic_input ... hzero
```
The ┬зCCL-bis / ┬зCCLXXXII / ┬зCCLXXXVII chain implements this convention.
Discharge of an unguarded analytic input cannot proceed at a zero
without circularity. -/

-- =====================================================================
-- ┬зCCLXXXVII. Discharge `Hgap` via structural `DzeroStartsAfter` + NтВА-root
-- =====================================================================
-- The ┬зCCLXXXV `FirstZeroGapForDzero` Prop says
-- `finiteFluctuationPrimitive Dzero T0 u = -smoothZeroCountingN0 u`
-- on `[2╧А, ╬│]`. Under `DzeroStartsAfter ╬│` (no fluctuation atoms in
-- `[T0, ╬│]`) the discrete part vanishes and the structural identity
-- reduces to
--   `finiteFluctuationPrimitive Dzero T0 u
--      = smoothZeroCountingN0 T0 тИТ smoothZeroCountingN0 u`.
-- So the ┬зCCLXXXV shape `= -NтВА(u)` holds **iff** `smoothZeroCountingN0 T0 = 0`,
-- i.e., iff `T0` is the unique root `uтВА тЙИ 9.74` of `NтВА` in `(2╧А, тИЮ)`.
-- This section honestly carries that constraint as the `hN0_T0`
-- hypothesis. A future refactor could replace `FirstZeroGapForDzero`
-- with a basepoint-adjusted shape `S(T0, u) = NтВА(T0) тИТ NтВА(u)` that
-- accepts arbitrary `T0 тЙд 2╧А`.
--
-- Adds:
--   DzeroStartsAfter                                      тАФ no atoms below ╬│
--   discreteCountingPrimitive_eq_zero_of_startsAfter      тАФ discrete vanishes
--   smoothCountingPrimitive_eq_N0_diff                    тАФ FTC bridge
--   finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter  тАФ structural identity
--   FirstZeroGapForDzero_of_startsAfter_at_root           тАФ inhabit Hgap
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowFiniteIBP_11_14_half_startsAfter
--                                                          тАФ Hgap-free front door

/-- ЁЯУж **`DzeroStartsAfter Dzero ╬│`** тАФ strict structural condition:
every zero ordinate in `Dzero.Z` is strictly greater than `╬│`. For
`zeros100ceil` with first entry `15`, `DzeroStartsAfter Dzero 14`
holds (`14 < 15`). The strict inequality avoids edge cases at `u = ╬│`. -/
structure DzeroStartsAfter
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (╬│ : тДЭ) : Prop where
  z_gt_gamma : тИА i : тДХ, ╬│ < Dzero.toFluctuationMeasureData.Z i

/-- тнР **PROVED тАФ discrete counting primitive vanishes on `[T0, u]`** when
all atoms lie strictly above `╬│ тЙе u`. Each `if T0 тЙд Z_j тИз Z_j тЙд u`
term is false because `u < Z_j`. -/
lemma discreteCountingPrimitive_eq_zero_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ u : тДЭ}
    (H : DzeroStartsAfter Dzero ╬│) (hu : u тЙд ╬│) :
    Phase1IBP.discreteCountingPrimitive
        Dzero.toFluctuationMeasureData T0 u = 0 := by
  classical
  unfold Phase1IBP.discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j _
  have hZj : ╬│ < Dzero.toFluctuationMeasureData.Z j := H.z_gt_gamma j
  have hu_Zj : u < Dzero.toFluctuationMeasureData.Z j :=
    lt_of_le_of_lt hu hZj
  have hnot :
      ┬м (T0 тЙд Dzero.toFluctuationMeasureData.Z j тИз
         Dzero.toFluctuationMeasureData.Z j тЙд u) := by
    intro тЯи_, hтЯй
    exact (not_lt.mpr h) hu_Zj
  simp [hnot]

/-- тнР **PROVED тАФ `smoothCountingPrimitive T0 u = NтВА(u) тИТ NтВА(T0)`** for
positive `T0 тЙд u`, via FTC and `hasDerivAt_smoothZeroCountingN0`. -/
lemma smoothCountingPrimitive_eq_N0_diff
    {T0 u : тДЭ} (hT0 : 0 < T0) (hT0u : T0 тЙд u) :
    Phase1IBP.smoothCountingPrimitive T0 u
      = smoothZeroCountingN0 u - smoothZeroCountingN0 T0 := by
  unfold Phase1IBP.smoothCountingPrimitive
  have h_deriv : тИА v тИИ Set.uIcc T0 u,
      HasDerivAt smoothZeroCountingN0 (zeroDensityRho v) v := by
    intro v hv
    rw [Set.uIcc_of_le hT0u] at hv
    exact hasDerivAt_smoothZeroCountingN0
      (lt_of_lt_of_le hT0 hv.1)
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T0 u :=
    Phase1IBP.zeroDensityRho_intervalIntegrable hT0 hT0u
  exact intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int

/-- тнР **PROVED тАФ structural identity for `finiteFluctuationPrimitive`**
on the first-zero gap under `DzeroStartsAfter`:
`S(T0, u) = NтВА(T0) тИТ NтВА(u)`. -/
theorem finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ u : тДЭ}
    (H : DzeroStartsAfter Dzero ╬│)
    (hT0_pos : 0 < T0) (hT0u : T0 тЙд u) (hu : u тЙд ╬│) :
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
      = smoothZeroCountingN0 T0 - smoothZeroCountingN0 u := by
  unfold Phase1IBP.finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_eq_zero_of_startsAfter H hu,
      smoothCountingPrimitive_eq_N0_diff hT0_pos hT0u]
  ring

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `FirstZeroGapForDzero Dzero T0 14` inhabitant** from
the structural pieces. Requires:
* `H : DzeroStartsAfter Dzero 14` тАФ no atoms below 14;
* `hT0_pos : 0 < T0`;
* `hT0_le_2pi : T0 тЙд 2╧А` тАФ so the smooth-bridge integration on
  `[T0, u]` extends over the full gap `[2╧А, 14]`;
* `hN0_T0 : smoothZeroCountingN0 T0 = 0` тАФ the basepoint-root condition
  needed to specialize the structural identity to the ┬зCCLXXXV shape.

The `hN0_T0` hypothesis pins `T0` to the unique root `uтВА тЙИ 9.74` of
`NтВА` in `(2╧А, тИЮ)`. A future refactor of ┬зCCLXXXV's Hgap shape to
`S(T0, u) = NтВА(T0) тИТ NтВА(u)` would eliminate this constraint. -/
theorem FirstZeroGapForDzero_of_startsAfter_at_root
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    (H : DzeroStartsAfter Dzero 14)
    (hT0_pos : 0 < T0)
    (hT0_le_2pi : T0 тЙд 2 * Real.pi)
    (hN0_T0 : smoothZeroCountingN0 T0 = 0) :
    FirstZeroGapForDzero Dzero T0 14 := by
  refine тЯи?_тЯй
  intro u hu_2pi hu14
  have hT0u : T0 тЙд u := le_trans hT0_le_2pi hu_2pi
  have h := finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter
              H hT0_pos hT0u hu14
  rw [h, hN0_T0]
  ring

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PATH B
FRONT DOOR (`Hgap` discharged via `DzeroStartsAfter` + `NтВА(T0) = 0`)**.

Replaces the ┬зCCLXXXVI `Hgap` input with the structural pair
