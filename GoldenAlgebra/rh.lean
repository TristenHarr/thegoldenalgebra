theorem FirstZeroAdjustedSBound_of_AdjustedGap_and_diffBound
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 γ D : ℝ}
    (Hgap : FirstZeroGapForDzeroAdjusted Dzero T0 γ)
    (hdiff :
      ∀ u : ℝ, 11 ≤ u → u ≤ γ →
        |smoothZeroCountingN0 T0 - smoothZeroCountingN0 u| ≤ D) :
    FirstZeroAdjustedSBound Dzero T0 γ D := by
  refine ⟨?_⟩
  intro u hu11 huγ
  have h_2pi_lt_11 : 2 * Real.pi ≤ 11 := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hu_2pi : 2 * Real.pi ≤ u := le_trans h_2pi_lt_11 hu11
  rw [Hgap.fluct_eq_N0_diff u hu_2pi huγ]
  exact hdiff u hu11 huγ

/-- 🌟🌟🌟 **PROVED — refactored AwayFromZeros IBP closure using
