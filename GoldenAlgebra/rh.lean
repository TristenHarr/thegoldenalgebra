-- `(1/2)¬Јs¬Ј(s-1)` polynomial prefactor in the definition. So the
-- subtype excluding 0 cannot satisfy the strong `all_completedXi_zeros`
-- field of `ConcreteCompletedXiZeroSystem` вАФ the zero at the origin
-- is missed.
--
-- The fix (¬ІCCCLXXXI) is `ConcreteCompletedXiNonzeroZeroSystem` whose
-- surjectivity is restricted to **nonzero** zeros, with a bridge to
-- the strong version (¬ІCCCLXXXII) under `completedXiFunction 0 вЙ† 0`.

/-- **Subtype of nonzero zeros of `completedXiFunction`.** Natural
candidate for `ќє`. -/
def CompletedXiNonzeroZeroIndex : Type :=
  { s : вДВ // completedXiFunction s = 0 вИІ s вЙ† 0 }

/-- The subtype's zero-location map. -/
def completedXiNonzeroZeroLoc (i : CompletedXiNonzeroZeroIndex) : вДВ := i.1

-- =====================================================================
-- ¬ІCCCLXXXI. Nonzero zero-system (sharper)
-- =====================================================================

/-- рЯУ¶ **`ConcreteCompletedXiNonzeroZeroSystem`** вАФ like
`ConcreteCompletedXiZeroSystem` but the surjectivity field only
covers **nonzero** zeros. Avoids the zero-at-origin hazard. -/
structure ConcreteCompletedXiNonzeroZeroSystem (ќє : Type) : Type where
  zeroLoc : ќє вЖТ вДВ
  zeroLoc_ne_zero : вИА i : ќє, zeroLoc i вЙ† 0
  zeroLoc_is_zero : вИА i : ќє, completedXiFunction (zeroLoc i) = 0
  all_nonzero_completedXi_zeros :
    вИА s : вДВ,
      completedXiFunction s = 0 вЖТ s вЙ† 0 вЖТ
      вИГ i : ќє, zeroLoc i = s

-- =====================================================================
-- ¬ІCCCLXXXII. Bridge: nonzero-zero system вЖТ zero system under
--             `completedXiFunction 0 вЙ† 0`
-- =====================================================================

/-- в≠Р **PROVED вАФ `ConcreteCompletedXiZeroSystem` from the nonzero
variant under `completedXiFunction 0 вЙ† 0`.** This hypothesis is
strong; for the ќУ-based `completedXiFunction` it is generally false.
A future refactor should use Mathlib's `entireRiemannXi` where the
zero at the origin is absorbed into the prefactor and this
hypothesis becomes provable. -/
def ConcreteCompletedXiNonzeroZeroSystem.toZeroSystem
    {ќє : Type}
    (H : ConcreteCompletedXiNonzeroZeroSystem ќє)
    (h0 : completedXiFunction 0 вЙ† 0) :
    ConcreteCompletedXiZeroSystem ќє :=
  { zeroLoc := H.zeroLoc
    zeroLoc_ne_zero := H.zeroLoc_ne_zero
    zeroLoc_is_zero := H.zeroLoc_is_zero
    all_completedXi_zeros := by
      intro s hs
      have hs0 : s вЙ† 0 := by
        intro h
        apply h0
        rw [h] at hs
        exact hs
      exact H.all_nonzero_completedXi_zeros s hs hs0 }

