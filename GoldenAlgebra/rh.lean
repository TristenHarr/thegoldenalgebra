/-- **Scalar large-`T` margin condition at constant `c = 22/15`.**
The sharper sufficient condition: `((22/15)┬╖T/(2╧А))┬╖log(T/(2╧А)) тЙе
(17/2)┬╖log T + 439/10`, equivalently `(11T/(15╧А))┬╖log(T/(2╧А)) тЙе тАж`.

Python: this scalar crosses zero at `T тЙИ 135`; `T0 = 140` is the clean
safe threshold. -/
noncomputable def largeTScalarMarginConditionTwentyTwoFifteenths (T : тДЭ) : Prop :=
  (17 / 2) * Real.log T + 439 / 10
    тЙд ((22 / 15) * T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))

/-- тнР **PROVED тАФ `c = 22/15` scalar condition тЯ╣ closed-form domination
at `(C, D) = (1/2, 49/20)`** for `T тЙе 140`. -/
theorem largeTScalarConditionTwentyTwoFifteenths_implies_domination
    {x y T : тДЭ}
    (hT140 : 140 тЙд T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) тЙд T)
    (hscalar : largeTScalarMarginConditionTwentyTwoFifteenths T) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) (49 / 20 : тДЭ) y T
      тЙд smoothTailRationalLowerBoundAbs x y T := by
  have h_2pi_lt_140 : 2 * Real.pi < 140 := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hT2pi : 2 * Real.pi тЙд T := le_trans (le_of_lt h_2pi_lt_140) hT140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T тЙа 0 := ne_of_gt hT_pos
  have hT2_pos : 0 < T^2 := by positivity
  have hy_nn : 0 тЙд y := le_of_lt hy
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  have h_yT2_nn : 0 тЙд y / T^2 := div_nonneg hy_nn (le_of_lt hT2_pos)
  have h_step2 :
      (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)
        тЙд (y / T^2) *
            (((22 / 15) * T / (2 * Real.pi)) *
              Real.log (T / (2 * Real.pi))) :=
    mul_le_mul_of_nonneg_left hscalar h_yT2_nn
  have h_step3 :
      (y / T^2) *
          (((22 / 15) * T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi)))
        = (22 / 15) * zeroDensityRho T * y / T := by
    unfold zeroDensityRho
    have hpi_ne : (Real.pi : тДЭ) тЙа 0 := ne_of_gt h_pi_pos
    field_simp; ring
  rw [h_step3] at h_step2
  have h_geom :
      (22 / 15) * zeroDensityRho T * y / T
        тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT2pi hy hadapt
  linarith

