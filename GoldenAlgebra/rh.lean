/-! ## CP: Right-sided closure for the `concreteS` bound -/

/-! ### CP1: right-sided closure principle -/

/-- Right-sided closure: if every threshold-respecting `T` admits good-
height witnesses on the right (`T тЙд U < T + ╬╡`) where the bound holds,
then the bound holds at `T`.  Strictly stronger usage than the symmetric
`ConcreteSBoundGoodHeightClosure` because the witness lies on the right
of `T`. -/
structure ConcreteSRightClosure (lower : тДЭ) : Prop where
  closure :
    тИА T : тДЭ, lower тЙд T тЖТ
      (тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ
        тИГ U : тДЭ, RvMGoodHeight U тИз lower тЙд U тИз T тЙд U тИз U < T + ╬╡ тИз
          |concreteS U| тЙд (1 / 2 : тДЭ) * Real.log U + 1 / 2) тЖТ
      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2

/-! ### CP2: right-sided good-height density above a positive threshold -/

/-- Right-sided refinement of `exists_goodHeight_near_right_ge_lower`:
extracts `T тЙд U < T + ╬╡` directly. -/
theorem exists_goodHeight_right_near
    {lower T ╬╡ : тДЭ}
    (hLower_pos : 0 < lower) (hLT : lower тЙд T) (h╬╡ : 0 < ╬╡) :
    тИГ U : тДЭ, RvMGoodHeight U тИз lower тЙд U тИз T тЙд U тИз U < T + ╬╡ := by
  have hTpos : 0 < T := lt_of_lt_of_le hLower_pos hLT
  obtain тЯиU, hTU, hUeps, hUgoodтЯй :=
    exists_goodHeight_between_self_add hTpos h╬╡
  have hUpos : 0 < U := lt_trans hTpos hTU
  exact тЯиU, тЯиhUpos, hUgoodтЯй, by linarith, le_of_lt hTU, hUepsтЯй

/-! ### CP3: `BacklundGoodHeightBoundExtension` from right closure + H140 -/

/-- The right closure principle plus the good-height Backlund estimate
yields `BacklundGoodHeightBoundExtension`.  Compared with CN3 the
witness now lies on the right of `T`, matching the right-continuity
structure of the analytic limit. -/
noncomputable def BacklundGoodHeightBoundExtension.of_rightClosure
    (H140 : ConcreteSBacklundEstimateFrom140OnGoodHeights)
    (C : ConcreteSRightClosure 140) :
    BacklundGoodHeightBoundExtension
      H140.toEstimate.toBacklundArgumentBoundOnGoodHeights where
  bound_all := by
    intro T hT
    refine C.closure T hT ?_
    intro ╬╡ h╬╡
    have h140_pos : (0 : тДЭ) < 140 := by norm_num
    obtain тЯиU, hUgood, hUlower, hTU, hUepsтЯй :=
      exists_goodHeight_right_near h140_pos hT h╬╡
    exact тЯиU, hUgood, hUlower, hTU, hUeps, H140 U hUgood hUlowerтЯй

