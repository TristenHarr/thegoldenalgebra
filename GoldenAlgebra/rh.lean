      Ôëñ |s.re| + |s.im| := Complex.norm_le_abs_re_add_abs_im s
    _ = s.re + s.im := by rw [abs_of_nonneg h1, abs_of_nonneg h3]
    _ Ôëñ 1 + max 0 T := by linarith

