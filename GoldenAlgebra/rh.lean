-- ┬з16.4-A. Mathlib discharge of the analytic factorization promise
-- ---------------------------------------------------------------------
-- The Prop `AnalyticZeroAdmitsFactorization F ╧Б` from ┬з16.4 is the
-- isolated-zero content of complex analysis: every analytic
-- non-degenerate zero admits the local factorization
-- `F z = (z тИТ ╧Б)^m ┬╖ g z` with `g ╧Б тЙа 0`. Mathlib's
-- `AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff`
-- (`Mathlib.Analysis.Analytic.IsolatedZeros`) supplies this directly;
-- this subsection wires it in and reduces `AnalyticZeroAdmitsFactorization`
-- to a *theorem*, not a hypothesis. The downstream effect: the
-- `h_admits` field of `entire_function_roots_real_of_analytic_inputs`
-- is now automatic тАФ see
-- `entire_function_roots_real_of_analytic_nondeg` below.

/-- тнР **PROVED тАФ Mathlib discharge of `AnalyticZeroAdmitsFactorization`.**
Given any function `F : тДВ тЖТ тДВ` analytic and non-degenerate at `╧Б`
with `F ╧Б = 0`, Mathlib's isolated-zeros machinery extracts a
positive multiplicity `m` and an analytic non-vanishing remainder
`g`. The proof:

* `AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff` gives
  `(n, g, hg_an, hg_ne, hg_eq)` with `F z = (z тИТ ╧Б)^n тАв g z` near `╧Б`;
* `n > 0` follows: if `n = 0` then `F ╧Б = g ╧Б`, contradicting
  `F ╧Б = 0` and `g ╧Б тЙа 0`;
* `тАв` becomes `*` via `smul_eq_mul` on `тДВ`;
* `g` is differentiable in a neighborhood of `╧Б` via
  `AnalyticAt.eventually_analyticAt` + `AnalyticAt.differentiableAt`;
* `deriv g / g` is continuous at `╧Б` via `AnalyticAt.deriv` +
  `AnalyticAt.continuousAt` + `ContinuousAt.div`. -/
theorem analytic_zero_admits_factorization
    (F : тДВ тЖТ тДВ) (╧Б : тДВ) :
    AnalyticZeroAdmitsFactorization F ╧Б := by
  intro hND hzero
  obtain тЯиn, g, hg_an, hg_ne, hg_eqтЯй :=
    (AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff hND.isAnalytic).mpr
      hND.not_eventually_zero
  -- Show `n > 0` from `F ╧Б = 0` and `g ╧Б тЙа 0`.
  have hm_pos : 0 < n := by
    by_contra hcon
    push_neg at hcon
    have hn0 : n = 0 := Nat.le_zero.mp hcon
    subst hn0
    have heq : F ╧Б = (╧Б - ╧Б) ^ 0 тАв g ╧Б := hg_eq.self_of_nhds
    simp at heq
    rw [hzero] at heq
    exact hg_ne heq.symm
  -- Convert `тАв` to `*` (canonical тДВ-action).
  have hfactor : тИАс╢а z in ЁЭУЭ ╧Б, F z = (z - ╧Б) ^ n * g z := by
    filter_upwards [hg_eq] with z hz
    rw [hz, smul_eq_mul]
  -- `g` is differentiable in a neighborhood of `╧Б`.
  have hg_diff_nhds : тИАс╢а z in ЁЭУЭ ╧Б, DifferentiableAt тДВ g z := by
    filter_upwards [hg_an.eventually_analyticAt] with z hz
    exact hz.differentiableAt
  -- `deriv g / g` is continuous at `╧Б`.
  have hcont_background : ContinuousAt (fun z => deriv g z / g z) ╧Б :=
    hg_an.deriv.continuousAt.div hg_an.continuousAt hg_ne
  exact тЯи{ m := n
           hm_pos := hm_pos
           g := g
           hg╧Б := hg_ne
           hg_diff_nhds := hg_diff_nhds
           hcont_background := hcont_background
           hfactor := hfactor }тЯй

/-- тнР **PROVED тАФ entire-function Mathlib discharge.** The global form:
every `F : тДВ тЖТ тДВ` automatically inhabits
`EntireAnalyticZerosAdmitFactorization`. -/
