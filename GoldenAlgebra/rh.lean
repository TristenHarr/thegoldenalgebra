    (hlowMargin :
      ÔêÇ {z : Ôäé} {T : ÔäØ},
        2 * Real.pi Ôëñ T ÔåÆ T Ôëñ 10 ÔåÆ
        0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        |(xiResidualError HModel.M z).im| Ôëñ -(HModel.M.model z).im) :
