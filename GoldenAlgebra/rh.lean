/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ
**PROVED тАФ final Hadamard assembly.**

```
HadamardZeroInvSqSummability (╬г 1/тАЦ╧БтАЦ┬▓ + escape)
+ HadamardProductLUCLogDerivData (LUC log-deriv interchange)
+ ╬╛ Hadamard factorization (prefactor ┬╖ тИП EтВБ)
+ prefactor AFZ (differentiable + non-vanishing)
тЯ╣ CompletedXiHadamardProductWithZeros ╬╣
``` -/
noncomputable def CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    {╬╣ : Type} {zeroLoc : ╬╣ тЖТ тДВ}
    {prefactor : тДВ тЖТ тДВ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : тИА s : тДВ, completedXiFunction s тЙа 0 тЖТ s тИИ Hluc.region)
    (HnonzeroRegion : тИА s тИИ Hluc.region, тИА i, s тЙа zeroLoc i)
    (Hfact :
      тИА s : тДВ,
        completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s)
    (Hpref_diff :
      тИА s : тДВ,
        completedXiFunction s тЙа 0 тЖТ DifferentiableAt тДВ prefactor s)
    (Hpref_ne :
      тИА s : тДВ,
        completedXiFunction s тЙа 0 тЖТ prefactor s тЙа 0) :
    CompletedXiHadamardProductWithZeros ╬╣ := by
  refine
    { zeroLoc := zeroLoc
      prefactor := prefactor
      prefactor_differentiable_at := Hpref_diff
      prefactor_ne_zero := Hpref_ne
      xi_eq_product := Hfact
      product_data := ?_ }
  exact
    HadamardLocallyUniformProductData.of_logDerivLimitData
      Hinv.product_multipliable
      (HadamardLogDerivLimitData.of_productLUC_and_invSq
        Hluc Hinv HnonzeroRegion)
      Hregion

-- =====================================================================
-- ┬зCCCXXXIX. ClassicalPathBAnalyticInputs bundle
-- =====================================================================
-- Bundles the five remaining classical analytic inputs for the
-- Hadamard side of Path B into a single Type. The Hadamard agent
-- supplies one inhabitant of this bundle; everything else is closed.

/-- ЁЯУж **`ClassicalPathBAnalyticInputs`** тАФ the Hadamard-side
classical-input bundle. The remaining xi-side analytic inputs for
Path B (aside from the Stieltjes equality) live in this single
object. -/
structure ClassicalPathBAnalyticInputs (╬╣ : Type) where
  zeroLoc : ╬╣ тЖТ тДВ
  prefactor : тДВ тЖТ тДВ
  Hinv : HadamardZeroInvSqSummability zeroLoc
  Hluc : HadamardProductLUCLogDerivData zeroLoc
  Hregion :
    тИА s : тДВ, completedXiFunction s тЙа 0 тЖТ s тИИ Hluc.region
  HnonzeroRegion :
    тИА s тИИ Hluc.region, тИА i, s тЙа zeroLoc i
  Hfact :
    тИА s : тДВ,
      completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s
  Hpref_diff :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ DifferentiableAt тДВ prefactor s
  Hpref_ne :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ prefactor s тЙа 0

-- =====================================================================
-- ┬зCCCXL. Bridge bundled inputs тЖТ Hadamard source AFZ
-- =====================================================================

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `CompletedXiHadamardProductWithZeros` from
the bundled classical inputs.** -/
noncomputable def ClassicalPathBAnalyticInputs.toHadamardProductWithZeros
    {╬╣ : Type} (H : ClassicalPathBAnalyticInputs ╬╣) :
    CompletedXiHadamardProductWithZeros ╬╣ :=
  CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    H.Hinv H.Hluc H.Hregion H.HnonzeroRegion
    H.Hfact H.Hpref_diff H.Hpref_ne

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `CompletedXiLogDerivativeSourceAFZ` from
the bundled classical inputs.** -/
noncomputable def ClassicalPathBAnalyticInputs.toCompletedXiSourceAFZ
    {╬╣ : Type} (H : ClassicalPathBAnalyticInputs ╬╣) :
    CompletedXiLogDerivativeSourceAFZ :=
  CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    H.toHadamardProductWithZeros

-- =====================================================================
-- ┬зCCCXLI. Final classical-input front door
-- =====================================================================

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ
**PATH B FINAL FRONT DOOR (classical analytic inputs)**.

The cleanest possible statement of Path B. The work has been split
into two independent analytic packages тАФ Hadamard and Stieltjes тАФ
both bundled, both AFZ-correct.

```
hTuring + hHighLog                                           (parallel agent)
+ Hclassical : ClassicalPathBAnalyticInputs ╬╣                 (Hadamard side)
+ Hstieltjes : XiZeroContributionStieltjesEqualitySourceAFZ
                  Dzero 10
                  (pullbackZeroContribution
                    Hclassical.toCompletedXiSourceAFZ)        (Stieltjes side)
+ h_Z_ge_15                                                   (trivial)
тЯ╣ XiPullbackAntiHerglotzTarget
```

After this, the work splits cleanly:
* Hadamard side: inhabit `ClassicalPathBAnalyticInputs`.
* Stieltjes side: inhabit `XiZeroContributionStieltjesEqualitySourceAFZ`
  matched to `pullbackZeroContribution Hclassical.toCompletedXiSourceAFZ`. -/
theorem XiPullbackAntiHerglotzTarget_of_classicalPathBInputs
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {╬╣ : Type}
    (h_Z_ge_15 : тИА i : тДХ, (15 : тДЭ) тЙд Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hclassical : ClassicalPathBAnalyticInputs ╬╣)
    (Hstieltjes :
      XiZeroContributionStieltjesEqualitySourceAFZ
        Dzero 10
        (pullbackZeroContribution
          Hclassical.toCompletedXiSourceAFZ)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_completedXiHadamardAndStieltjesAFZ
    Dzero h_Z_ge_15 hTuring hHighLog
    Hclassical.toCompletedXiSourceAFZ
    Hstieltjes

-- =====================================================================
-- ┬зCCCXLII. Canonical Hadamard zero index package
-- =====================================================================
-- Names the zero index type + zero-locating map + characterizing
-- properties. The analytic agent's first concrete choice (e.g.,
-- ╬╣ = тДХ with `zeroLoc n` = the n-th nontrivial zeta zero ordinate).

/-- ЁЯУж **`CompletedXiZeroIndexPackage`** тАФ characterization of the
zero set of `completedXiFunction` via an explicit index type. -/
structure CompletedXiZeroIndexPackage where
  ╬╣ : Type
  zeroLoc : ╬╣ тЖТ тДВ
  zeroLoc_ne_zero :
    тИА i : ╬╣, zeroLoc i тЙа 0
  zeroLoc_is_zero :
    тИА i : ╬╣, completedXiFunction (zeroLoc i) = 0
  all_completedXi_zeros :
    тИА s : тДВ,
      completedXiFunction s = 0 тЖТ
      тИГ i : ╬╣, zeroLoc i = s

-- =====================================================================
-- ┬зCCCXLIII. Hadamard prefactor data package
-- =====================================================================

/-- ЁЯУж **`CompletedXiHadamardPrefactorData`** тАФ AFZ properties of the
Hadamard prefactor as a Prop. -/
structure CompletedXiHadamardPrefactorData (prefactor : тДВ тЖТ тДВ) : Prop where
  differentiable_at_nonzero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      DifferentiableAt тДВ prefactor s
  nonzero_at_nonzero :
    тИА s : тДВ,
      completedXiFunction s тЙа 0 тЖТ
      prefactor s тЙа 0

-- =====================================================================
-- ┬зCCCXLIV. Hadamard factorization data + assembly
-- =====================================================================

/-- ЁЯУж **`CompletedXiHadamardFactorizationData`** тАФ the classical
factorization identity `╬╛ = prefactor ┬╖ тИП EтВБ(┬╖/╧Бс╡в)`. -/
structure CompletedXiHadamardFactorizationData
    {╬╣ : Type*} (zeroLoc : ╬╣ тЖТ тДВ) (prefactor : тДВ тЖТ тДВ) : Prop where
  factorization :
    тИА s : тДВ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `ClassicalPathBAnalyticInputs` from the
Hadamard packages.** Assembles the bundled inputs from the
separately-developed Hadamard components. -/
noncomputable def ClassicalPathBAnalyticInputs.of_hadamard_packages
    {╬╣ : Type} {zeroLoc : ╬╣ тЖТ тДВ} {prefactor : тДВ тЖТ тДВ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : тИА s : тДВ, completedXiFunction s тЙа 0 тЖТ s тИИ Hluc.region)
    (HnonzeroRegion : тИА s тИИ Hluc.region, тИА i, s тЙа zeroLoc i)
    (Hfact : CompletedXiHadamardFactorizationData zeroLoc prefactor)
    (Hpref : CompletedXiHadamardPrefactorData prefactor) :
    ClassicalPathBAnalyticInputs ╬╣ :=
  { zeroLoc := zeroLoc
    prefactor := prefactor
    Hinv := Hinv
    Hluc := Hluc
    Hregion := Hregion
    HnonzeroRegion := HnonzeroRegion
    Hfact := Hfact.factorization
    Hpref_diff := Hpref.differentiable_at_nonzero
    Hpref_ne := Hpref.nonzero_at_nonzero }

-- =====================================================================
-- ┬зCCCXLV. Stieltjes mid/high/low equality split
-- =====================================================================
-- Splits `XiZeroContributionStieltjesEqualitySourceAFZ` into three
-- independent Props, each provable separately.

/-- ЁЯУж **`StieltjesMidTailEqualityAFZ`** тАФ AFZ Stieltjes equality
in the MID band (canonical adaptive T). -/
structure StieltjesMidTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  mid_eq :
    тИА {z : тДВ} {L : тДВ},
      0 < z.im тЖТ
      XiPullback z тЙа 0 тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- ЁЯУж **`StieltjesHighTailEqualityAFZ`** тАФ AFZ Stieltjes equality
in the HIGH band (`T тЙе 140`). -/
structure StieltjesHighTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  high_eq :
    тИА {z : тДВ} {T : тДЭ} {L : тДВ},
      140 тЙд T тЖТ
      0 < z.im тЖТ
      XiPullback z тЙа 0 тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      XiFluctuationTailValue Dzero T0 T z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- ЁЯУж **`StieltjesLowEqualityAFZ`** тАФ AFZ Stieltjes equality in the
LOW band (bounded `[11, 14]`). Wraps
`LowFiniteStieltjesFormulaOnFirstZeroGapAFZ` for symmetry with
mid/high. -/
structure StieltjesLowEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  low_eq : LowFiniteStieltjesFormulaOnFirstZeroGapAFZ Dzero T0 ZC

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ reassemble
`XiZeroContributionStieltjesEqualitySourceAFZ` from the three split
Props.** -/
theorem XiZeroContributionStieltjesEqualitySourceAFZ.of_mid_high_low
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (Hmid : StieltjesMidTailEqualityAFZ Dzero T0 ZC)
    (Hhigh : StieltjesHighTailEqualityAFZ Dzero T0 ZC)
    (Hlow : StieltjesLowEqualityAFZ Dzero T0 ZC) :
    XiZeroContributionStieltjesEqualitySourceAFZ Dzero T0 ZC :=
  { midHigh_eq :=
      { mid_eq := Hmid.mid_eq
        high_eq := Hhigh.high_eq }
    low_eq := Hlow.low_eq }

-- =====================================================================
-- ┬зCCCXLVI. Stieltjes classical-input bundle
-- =====================================================================

/-- ЁЯУж **`ClassicalPathBStieltjesInputsAFZ`** тАФ Stieltjes-side
classical-input bundle. Three independently-provable AFZ Stieltjes
equalities. -/
structure ClassicalPathBStieltjesInputsAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  mid : StieltjesMidTailEqualityAFZ Dzero T0 ZC
  high : StieltjesHighTailEqualityAFZ Dzero T0 ZC
  low : StieltjesLowEqualityAFZ Dzero T0 ZC

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `XiZeroContributionStieltjesEqualitySourceAFZ`
from the Stieltjes input bundle.** -/
theorem ClassicalPathBStieltjesInputsAFZ.toEqualitySource
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (H : ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC) :
    XiZeroContributionStieltjesEqualitySourceAFZ Dzero T0 ZC :=
  XiZeroContributionStieltjesEqualitySourceAFZ.of_mid_high_low
    H.mid H.high H.low

-- =====================================================================
-- ┬зCCCXLVII. Final two-bundle Path B front door
-- =====================================================================

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ
**PATH B FINAL FRONT DOOR (TWO CLASSICAL BUNDLES)**.

The most readable form of the final theorem. The xi-side analytic
content has been split into two independent classical bundles.

```
hTuring + hHighLog                                              (parallel agent)
+ Hhadamard  : ClassicalPathBAnalyticInputs ╬╣                    (Hadamard side)
+ Hstieltjes : ClassicalPathBStieltjesInputsAFZ
                  Dzero 10
                  (pullbackZeroContribution
                    Hhadamard.toCompletedXiSourceAFZ)             (Stieltjes side)
+ h_Z_ge_15                                                       (trivial)
тЯ╣ XiPullbackAntiHerglotzTarget
``` -/
theorem XiPullbackAntiHerglotzTarget_of_classicalPathBHadamardAndStieltjesInputs
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {╬╣ : Type}
    (h_Z_ge_15 : тИА i : тДХ, (15 : тДЭ) тЙд Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hhadamard : ClassicalPathBAnalyticInputs ╬╣)
    (Hstieltjes :
      ClassicalPathBStieltjesInputsAFZ
        Dzero 10
        (pullbackZeroContribution
          Hhadamard.toCompletedXiSourceAFZ)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_classicalPathBInputs
    Dzero h_Z_ge_15 hTuring hHighLog
    Hhadamard
    Hstieltjes.toEqualitySource

-- =====================================================================
-- ┬зCCCXLVIII. Low Stieltjes target тАФ unwrap to bare formula
-- =====================================================================

/-- тнР **PROVED тАФ `StieltjesLowEqualityAFZ` from
`LowFiniteStieltjesFormulaOnFirstZeroGapAFZ`.** -/
theorem StieltjesLowEqualityAFZ.of_lowFiniteFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (H : LowFiniteStieltjesFormulaOnFirstZeroGapAFZ Dzero T0 ZC) :
    StieltjesLowEqualityAFZ Dzero T0 ZC :=
  тЯиHтЯй

-- =====================================================================
-- ┬зCCCXLIX. Low formula split into "contribution identity"
-- =====================================================================

/-- ЁЯУж **`LowFiniteStieltjesContributionIdentityAFZ`** тАФ the bare
low Stieltjes contribution identity under AFZ + first-zero-gap. -/
structure LowFiniteStieltjesContributionIdentityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  identity :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      XiPullback z тЙа 0 тЖТ
      FirstZeroGapIdentityOn Dzero T0 11 14 тЖТ
      (ZC z
          - (cloudModel zeros100ceil z
              + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = lowFiniteFluctuationContribution Dzero T0 z

/-- тнР **PROVED тАФ bridge from contribution identity to low formula.** -/
theorem LowFiniteStieltjesFormulaOnFirstZeroGapAFZ.of_contributionIdentity
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (H : LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC) :
    LowFiniteStieltjesFormulaOnFirstZeroGapAFZ Dzero T0 ZC := by
  refine тЯи?_тЯй
  intro z hz hne Hgap
  exact H.identity z hz hne Hgap

-- =====================================================================
-- ┬зCCCL. Stieltjes bundle assembly from low contribution identity
-- =====================================================================

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `ClassicalPathBStieltjesInputsAFZ` from
mid + high + low-contribution-identity.** -/
theorem ClassicalPathBStieltjesInputsAFZ.of_mid_high_lowContribution
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (Hmid : StieltjesMidTailEqualityAFZ Dzero T0 ZC)
    (Hhigh : StieltjesHighTailEqualityAFZ Dzero T0 ZC)
    (Hlow : LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC) :
    ClassicalPathBStieltjesInputsAFZ Dzero T0 ZC :=
  { mid := Hmid
    high := Hhigh
    low :=
      StieltjesLowEqualityAFZ.of_lowFiniteFormula
        (LowFiniteStieltjesFormulaOnFirstZeroGapAFZ.of_contributionIdentity
          Hlow) }

-- =====================================================================
-- ┬зCCCLI. Complex IBP helpers + IBP identity Prop
-- =====================================================================
-- Lifts the real boundary term and complex integral into named
-- complex-valued helpers whose `.im` recovers `lowFiniteFluctuationContribution`.

/-- **Low finite boundary term (complex)**: real boundary value lifted
to `тДВ` via multiplication by `I`. Its `.im` equals the real boundary. -/
noncomputable def lowFiniteBoundaryTerm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (z : тДВ) : тДВ :=
  ((lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11 : тДЭ) : тДВ) * Complex.I

/-- **Low finite kernel integral (complex)**: the true-kernel complex
density tail partial on `[11, 14]`. -/
noncomputable def lowFiniteKernelIntegral
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (z : тДВ) : тДВ :=
  complexDensityTailPartial pairedCauchyComplexKernelTrue
    (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14 z

/-- тнР **PROVED тАФ `lowFiniteBoundaryTerm.im` = real boundary value.** -/
lemma lowFiniteBoundaryTerm_im
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ) (z : тДВ) :
    (lowFiniteBoundaryTerm Dzero T0 z).im
      = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11 := by
  unfold lowFiniteBoundaryTerm
  simp [Complex.mul_I_im]

/-- тнР **PROVED тАФ sum's `.im` matches `lowFiniteFluctuationContribution`.** -/
lemma lowFiniteBoundary_add_kernelIntegral_im
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ) (z : тДВ) :
    (lowFiniteBoundaryTerm Dzero T0 z
        + lowFiniteKernelIntegral Dzero T0 z).im
      = lowFiniteFluctuationContribution Dzero T0 z := by
  unfold lowFiniteFluctuationContribution lowFiniteKernelIntegral
  rw [Complex.add_im, lowFiniteBoundaryTerm_im]

/-- ЁЯУж **`LowFiniteStieltjesIBPIdentityAFZ`** тАФ bare IBP form of the
low Stieltjes contribution identity, using the complex boundary +
kernel integral helpers. -/
structure LowFiniteStieltjesIBPIdentityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  ibp_identity :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      XiPullback z тЙа 0 тЖТ
      FirstZeroGapIdentityOn Dzero T0 11 14 тЖТ
      (ZC z
          - (cloudModel zeros100ceil z
              + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = (lowFiniteBoundaryTerm Dzero T0 z
            + lowFiniteKernelIntegral Dzero T0 z).im

/-- тнР **PROVED тАФ bridge: IBP identity тЖТ contribution identity.** -/
theorem LowFiniteStieltjesContributionIdentityAFZ.of_ibp
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (H : LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC) :
    LowFiniteStieltjesContributionIdentityAFZ Dzero T0 ZC := by
  refine тЯи?_тЯй
  intro z hz hne Hgap
  rw [H.ibp_identity z hz hne Hgap]
  exact lowFiniteBoundary_add_kernelIntegral_im Dzero T0 z

-- =====================================================================
-- ┬зCCCLII. Finite zero-sum Stieltjes formula (complex equality)
-- =====================================================================

/-- ЁЯУж **`LowFiniteZeroSumStieltjesFormulaAFZ`** тАФ complex-equality
form of the low Stieltjes contribution. -/
structure LowFiniteZeroSumStieltjesFormulaAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  zero_sum_formula :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      XiPullback z тЙа 0 тЖТ
      FirstZeroGapIdentityOn Dzero T0 11 14 тЖТ
      ZC z
        = cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + lowFiniteBoundaryTerm Dzero T0 z
          + lowFiniteKernelIntegral Dzero T0 z

/-- тнР **PROVED тАФ bridge: zero-sum complex formula тЖТ IBP identity.** -/
theorem LowFiniteStieltjesIBPIdentityAFZ.of_zero_sum_formula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData}
    {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (H : LowFiniteZeroSumStieltjesFormulaAFZ Dzero T0 ZC) :
    LowFiniteStieltjesIBPIdentityAFZ Dzero T0 ZC := by
  refine тЯи?_тЯй
  intro z hz hne Hgap
  have h := H.zero_sum_formula z hz hne Hgap
  rw [h]
  congr 1
  ring

