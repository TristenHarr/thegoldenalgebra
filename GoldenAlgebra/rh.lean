/-- в≠Р **PROVED вАФ Helper 1: box bound from adaptive region.**
On the adaptive region, `x¬≤ + y¬≤ вЙ§ (T/2 - 1)¬≤`. Removes repeated
geometry from every cert. -/
lemma x2_add_y2_le_T_half_sub_one_sq
    {x y T : вДЭ}
    (hx : 0 вЙ§ x) (hy : 0 вЙ§ y)
    (hreg : 2 * (1 + x + y) вЙ§ T) :
    x^2 + y^2 вЙ§ (T / 2 - 1)^2 := by
  have hxy : x + y вЙ§ T / 2 - 1 := by linarith
  have hsum_nn : 0 вЙ§ x + y := by linarith
  have h_T_half_nn : 0 вЙ§ T / 2 - 1 := by linarith
  have hxyle : x^2 + y^2 вЙ§ (x + y)^2 := by
    nlinarith [mul_nonneg hx hy]
  have hsq_le : (x + y)^2 вЙ§ (T / 2 - 1)^2 := by
    have h1 : -(T/2 - 1) вЙ§ x + y := by linarith
    exact sq_le_sq' h1 hxy
  linarith

/-- **Helper 2 def**: `cloudK_T zeros T = ќ£ 1/((T/2-1)¬≤ + ќ≥¬≤)`. -/
noncomputable def cloudK_T (zeros : List вДЭ) (T : вДЭ) : вДЭ :=
  (zeros.map fun g => 1 / ((T / 2 - 1)^2 + g^2)).sum

/-- в≠Р **PROVED вАФ Helper 2: simpleCloudSum lower bound via adaptive box.**
Wraps `simpleCloudSum_ge_T_box_bound` with `M = T/2 - 1` extracted from
the adaptive region. The slab cert never needs to manually prove the
`x¬≤ + y¬≤` box bound. -/
lemma simpleCloudSum_ge_admissible_T_bound
    (zeros : List вДЭ) {x y T : вДЭ}
    (hx : 0 вЙ§ x) (hy : 0 < y)
    (hreg : 2 * (1 + x + y) вЙ§ T) :
    2 * y * cloudK_T zeros T вЙ§ simpleCloudSum zeros x y := by
  have hy0 : 0 вЙ§ y := le_of_lt hy
  have hbox : x^2 + y^2 вЙ§ (T / 2 - 1)^2 :=
    x2_add_y2_le_T_half_sub_one_sq hx hy0 hreg
  exact simpleCloudSum_ge_T_box_bound zeros x y (T / 2 - 1) hbox hy

/-- в≠Р **PROVED вАФ Helper 3a: `log(12/(2ѕА)) вЙ• 2/5`.**
Via `Real.add_one_le_exp(-2/5)` вЯє `exp(2/5) вЙ§ 5/3 вЙ§ 12/(2ѕА)`. -/
lemma log_12_div_2pi_ge_2_5 :
    (2 / 5 : вДЭ) вЙ§ Real.log (12 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_pos : 0 < Real.exp (2/5) := Real.exp_pos _
  have h_one_sub : (-(2/5 : вДЭ)) + 1 вЙ§ Real.exp (-(2/5)) := Real.add_one_le_exp _
  have h_35 : (3/5 : вДЭ) вЙ§ Real.exp (-(2/5)) := by linarith
  rw [Real.exp_neg] at h_35
  have h_exp_le : Real.exp (2/5) вЙ§ 5/3 := by
    have := mul_le_mul_of_nonneg_right h_35 (le_of_lt h_exp_pos)
    rw [inv_mul_cancelвВА (ne_of_gt h_exp_pos)] at this
    linarith
  have h_12_2pi_ge : (5/3 : вДЭ) вЙ§ 12 / (2 * Real.pi) := by
    rw [le_div_iffвВА h_2pi_pos]; nlinarith
  have h_T_ge_exp : Real.exp (2/5) вЙ§ 12 / (2 * Real.pi) :=
    le_trans h_exp_le h_12_2pi_ge
  have h := Real.log_le_log h_exp_pos h_T_ge_exp
  rwa [Real.log_exp] at h

/-- в≠Р **PROVED вАФ Helper 3b: `log(13/(2ѕА)) вЙ• 1/2`.**
Via `Real.add_one_le_exp(-1/2)` вЯє `exp(1/2) вЙ§ 2 вЙ§ 13/(2ѕА)`. -/
lemma log_13_div_2pi_ge_1_2 :
    (1 / 2 : вДЭ) вЙ§ Real.log (13 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_pos : 0 < Real.exp (1/2) := Real.exp_pos _
  have h_one_sub : (-(1/2 : вДЭ)) + 1 вЙ§ Real.exp (-(1/2)) := Real.add_one_le_exp _
  have h_half : (1/2 : вДЭ) вЙ§ Real.exp (-(1/2)) := by linarith
  rw [Real.exp_neg] at h_half
  have h_exp_le : Real.exp (1/2) вЙ§ 2 := by
    have := mul_le_mul_of_nonneg_right h_half (le_of_lt h_exp_pos)
    rw [inv_mul_cancelвВА (ne_of_gt h_exp_pos)] at this
    linarith
  have h_13_2pi_ge : (2 : вДЭ) вЙ§ 13 / (2 * Real.pi) := by
    rw [le_div_iffвВА h_2pi_pos]; nlinarith
  have h_T_ge_exp : Real.exp (1/2) вЙ§ 13 / (2 * Real.pi) :=
    le_trans h_exp_le h_13_2pi_ge
  have h := Real.log_le_log h_exp_pos h_T_ge_exp
  rwa [Real.log_exp] at h

/-- в≠Р **PROVED вАФ Helper 4: affine LB for `log(T/(2ѕА))` on `[12, 13]`.**
Combines endpoint bounds with `Real.secant_le_log` applied to `log`.
The expression `(2/5) + (T-12)/10` equals `(T-8)/10` algebraically and
is exactly the secant connecting the endpoint LB values. -/
lemma log_T_over_2pi_ge_affine_12_13
    {T : вДЭ} (hT12 : 12 вЙ§ T) (hT13 : T вЙ§ 13) :
    (2 / 5 : вДЭ) + (T - 12) / 10
      вЙ§ Real.log (T / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_2pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  -- secant_le_log on [12, 13] applied to log T
  have h12pos : (0 : вДЭ) < 12 := by norm_num
  have h_12_lt_13 : (12 : вДЭ) < 13 := by norm_num
  have h_secant := Real.secant_le_log h12pos h_12_lt_13 hT12 hT13
  -- Simplify coefficients: 13 - 12 = 1
  have h_secant' :
      (13 - T) * Real.log 12 + (T - 12) * Real.log 13 вЙ§ Real.log T := by
    have h_div_1a : (13 - T) / (13 - 12) = 13 - T := by norm_num
    have h_div_1b : (T - 12) / (13 - 12) = T - 12 := by norm_num
    rw [h_div_1a, h_div_1b] at h_secant
    exact h_secant
  -- log(12/(2ѕА)) = log 12 - log(2ѕА), log(13/(2ѕА)) = log 13 - log(2ѕА)
  have h_log_T_div : Real.log (T / (2 * Real.pi)) = Real.log T - Real.log (2 * Real.pi) :=
    Real.log_div hT_ne h_2pi_ne
  have h_log_12_div : Real.log (12 / (2 * Real.pi)) = Real.log 12 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (12 : вДЭ) вЙ† 0) h_2pi_ne
  have h_log_13_div : Real.log (13 / (2 * Real.pi)) = Real.log 13 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (13 : вДЭ) вЙ† 0) h_2pi_ne
  -- Use endpoint LBs
  have h12 := log_12_div_2pi_ge_2_5
  have h13 := log_13_div_2pi_ge_1_2
  rw [h_log_12_div] at h12
  rw [h_log_13_div] at h13
  have h13mT_nn : 0 вЙ§ 13 - T := by linarith
  have hTm12_nn : 0 вЙ§ T - 12 := by linarith
  rw [h_log_T_div]
  -- (13-T)¬Ј(log 12 - log(2ѕА)) + (T-12)¬Ј(log 13 - log(2ѕА))
  -- = (13-T)¬Јlog 12 + (T-12)¬Јlog 13 - log(2ѕА)¬Ј(13-T + T-12)
  -- = (13-T)¬Јlog 12 + (T-12)¬Јlog 13 - log(2ѕА) вЙ§ log T - log(2ѕА)
  -- And LHS вЙ• (13-T)¬Ј(2/5) + (T-12)¬Ј(1/2) (using endpoint bounds applied via h12, h13)
  -- (13-T)¬Ј(2/5) + (T-12)¬Ј(1/2) = 2(13-T)/5 + (T-12)/2 = (T - 8)/10 (algebra)
  -- which equals (2/5) + (T-12)/10.
  nlinarith [h_secant', h12, h13, h13mT_nn, hTm12_nn]

/-- в≠Р **PROVED вАФ Helper 5: affine LB for `zeroDensityRho` on `[12, 13]`.**
Direct division of the log bound by `2ѕА`. -/
lemma zeroDensityRho_ge_affine_12_13
    {T : вДЭ} (hT12 : 12 вЙ§ T) (hT13 : T вЙ§ 13) :
