    (ZC : вДВ вЖТ вДВ) : Prop where
  low_eq : LowFiniteStieltjesFormulaOnFirstZeroGapAFZ Dzero T0 ZC

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ reassemble
`XiZeroContributionStieltjesEqualitySourceAFZ` from the three split
