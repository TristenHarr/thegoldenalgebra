  intro hG
  rcases Complex.GammaÔäØ_eq_zero_iff.mp hG with Ôƒ¿n, hnÔƒ®
  apply hsPole
  exact Ôƒ¿n, by rw [hn]; ringÔƒ®

/-- Ô¡É **PROVED ÔÇö `GammaÔäØ` as the explicit exponential ╬ô-factor.** -/
theorem GammaReal_eq_exp_gamma (s : Ôäé) :
    GammaÔäØ s =
      Complex.exp (-(s / 2) * (Real.log Real.pi : Ôäé))
        * Complex.Gamma (s / 2) := by
  rw [GammaÔäØ_def]
  congr 1
  rw [Complex.cpow_def_of_ne_zero]
  ┬À congr 1
    rw [Complex.ofReal_log Real.pi_pos.le]
    ring
  ┬À exact Complex.ofReal_ne_zero.mpr Real.pi_ne_zero

/-- ­ƒîƒ­ƒîƒ **PROVED unconditionally** ÔÇö Mathlib's completed zeta is the
raw ╬ô┬À╬Â expression off ╬ô-poles. -/
