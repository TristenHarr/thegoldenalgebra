namespace OverflowResidueRH

open Complex Filter Topology

-- =====================================================================
-- ┬º1. Sign laws
-- =====================================================================

/-- **Anti-Herglotz upper-half-plane sign law.** `R : Ôäé ÔåÆ Ôäé` is
anti-Herglotz iff `Im R z Ôëñ 0` for every `z` with `Im z > 0`. The sign law
of any real-rooted residue cloud `╬ú m_j / (z ÔêÆ r_j)` with real `r_j` and
positive `m_j`. -/
def AntiHerglotzUHP (R : Ôäé ÔåÆ Ôäé) : Prop :=
  ÔêÇ z : Ôäé, 0 < z.im ÔåÆ (R z).im Ôëñ 0

/-- **Positive upper imaginary escape.** Some upper-half-plane point has
strictly positive imaginary response ÔÇö the witness produced by a nonreal
upper-half-plane pole of the function whose log-derivative is `R`. -/
def PositiveUpperImaginaryEscape (R : Ôäé ÔåÆ Ôäé) : Prop :=
  Ôêâ z : Ôäé, 0 < z.im Ôêº 0 < (R z).im

/-- **The clean iff.** Anti-Herglotz on the upper half-plane is precisely
the absence of positive upper-imaginary escape. -/
theorem antiHerglotz_iff_no_positiveUpperEscape (R : Ôäé ÔåÆ Ôäé) :
    AntiHerglotzUHP R Ôåö ┬¼ PositiveUpperImaginaryEscape R := by
  unfold AntiHerglotzUHP PositiveUpperImaginaryEscape
  constructor
  ┬À intro hanti Ôƒ¿z, hzim, hRimÔƒ®
    exact absurd (hanti z hzim) (not_le.mpr hRim)
  ┬À intro hno z hzim
    by_contra hpos
    push_neg at hpos
    exact hno Ôƒ¿z, hzim, hposÔƒ®

/-- The logical gate ÔÇö restating the iff as the contradiction direction. -/
theorem positive_escape_kills_antiHerglotz
    {R : Ôäé ÔåÆ Ôäé} (h : PositiveUpperImaginaryEscape R) :
    ┬¼ AntiHerglotzUHP R :=
  fun hanti => (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti h

-- =====================================================================
-- ┬º2. Real residue clouds
-- =====================================================================

/-- **Atom.** For a real root `r` and any upper-half-plane `z`,
  Im(1 / (z ÔêÆ r)) = ÔêÆ(Im z) / |z ÔêÆ r|┬▓ Ôëñ 0.
The single nonpositivity fact from which the anti-Herglotz cloud law
follows by summation. -/
theorem complex_real_root_residue_imag_nonpos
    (z : Ôäé) (r : ÔäØ) (hz : 0 < z.im) :
    ((1 : Ôäé) / (z - (r : Ôäé))).im Ôëñ 0 := by
  -- z Ôëá r since z has positive imaginary part and r is real.
  have hne : z - (r : Ôäé) Ôëá 0 := by
    intro h
    rw [sub_eq_zero] at h
    have him : z.im = ((r : Ôäé)).im := congr_arg Complex.im h
    rw [Complex.ofReal_im] at him
    linarith
  rw [one_div, Complex.inv_im, Complex.sub_im, Complex.ofReal_im, sub_zero]
  have hns : 0 < Complex.normSq (z - (r : Ôäé)) := Complex.normSq_pos.mpr hne
  exact le_of_lt (div_neg_of_neg_of_pos (by linarith) hns)

/-- **Real residue cloud is anti-Herglotz.** For any finite list of real
roots, the cloud `z Ôåª ╬ú_r 1 / (z ÔêÆ r)` satisfies the anti-Herglotz
upper-half-plane sign law.

This single list theorem subsumes the GA `polynomial_one/two/three_real_roots_logDeriv_antiHerglotz`
toy cases (GA 31563ÔÇô31589). -/
theorem real_residue_cloud_antiHerglotz_list (rs : List ÔäØ) :
    AntiHerglotzUHP
      (fun z : Ôäé => (rs.map (fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé)))).sum) := by
  intro z hz
  show ((rs.map (fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé)))).sum).im Ôëñ 0
  induction rs with
  | nil => simp
  | cons r rs ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have h1 : ((1 : Ôäé) / (z - (r : Ôäé))).im Ôëñ 0 :=
      complex_real_root_residue_imag_nonpos z r hz
    linarith

/-- Ô¡É **PROVED ÔÇö weighted real residue cloud is anti-Herglotz.**
Generalizes `real_residue_cloud_antiHerglotz_list` to `(root, weight)`
pairs with non-negative real weights. Useful for multiplicities (just
repeat the same root) and for finite zero clouds with arbitrary positive
masses.

Mechanism: for real `w ÔëÑ 0` and real root `r`,
  `Im((w : Ôäé) ┬À (1 / (z ÔêÆ r)))  =  w ┬À Im(1 / (z ÔêÆ r))  Ôëñ  0`
since `w ÔëÑ 0` and `Im(1/(z ÔêÆ r)) Ôëñ 0` (the `complex_real_root_residue_imag_nonpos`
atom). Sum nonpositive contributions by induction. -/
theorem real_weighted_residue_cloud_antiHerglotz_list
    (atoms : List (ÔäØ ├ù ÔäØ))
    (hweights : ÔêÇ a Ôêê atoms, 0 Ôëñ a.2) :
    AntiHerglotzUHP
      (fun z : Ôäé =>
        (atoms.map fun a : ÔäØ ├ù ÔäØ =>
          (a.2 : Ôäé) * ((1 : Ôäé) / (z - (a.1 : Ôäé)))).sum) := by
  intro z hz
  show ((atoms.map fun a : ÔäØ ├ù ÔäØ =>
          (a.2 : Ôäé) * ((1 : Ôäé) / (z - (a.1 : Ôäé)))).sum).im Ôëñ 0
  induction atoms with
  | nil => simp
  | cons a atoms ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have ha_weight : 0 Ôëñ a.2 := hweights a (List.mem_cons_self ..)
    have hrest : ÔêÇ b Ôêê atoms, 0 Ôëñ b.2 :=
      fun b hb => hweights b (List.mem_cons_of_mem _ hb)
    have h_residue : ((1 : Ôäé) / (z - (a.1 : Ôäé))).im Ôëñ 0 :=
      complex_real_root_residue_imag_nonpos z a.1 hz
    have h_atom :
        ((a.2 : Ôäé) * ((1 : Ôäé) / (z - (a.1 : Ôäé)))).im Ôëñ 0 := by
      -- Im((w : Ôäé) ┬À c) = w ┬À c.im (since (w : Ôäé).im = 0).
      rw [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im,
          zero_mul, add_zero]
      exact mul_nonpos_of_nonneg_of_nonpos ha_weight h_residue
    have h_tail := ih hrest
    linarith

-- =====================================================================
-- ┬º3. Pole-witness abstraction
-- =====================================================================

/-- The **overflow field** / logarithmic derivative
  ╬ø[f](z) := f'(z) / f(z).
A signed residue cloud for any factored object. -/
noncomputable def logDerivativeResponse (f : Ôäé ÔåÆ Ôäé) : Ôäé ÔåÆ Ôäé :=
  fun z => deriv f z / f z

/-- **Log-derivative pole-witness law.** Every upper-half-plane zero of
`f` produces positive upper-imaginary escape for the response `R`. In
applications `R = logDerivativeResponse f`; the parameterization keeps
the abstraction sharp.

Discharged in concrete cases by local factorization `f(z) = (z ÔêÆ ¤ü)^m ┬À g(z)`
with `g(¤ü) Ôëá 0`, applied to `╬ø[f](z) = m / (z ÔêÆ ¤ü) + g'(z)/g(z)`. The
constructive discharge for any such decomposition is
`localLogDerivPoleDecomposition_forces_escape` in ┬º5. -/
structure LogDerivPoleWitnessLaw (f R : Ôäé ÔåÆ Ôäé) : Prop where
  upper_zero_forces_escape :
    ÔêÇ ¤ü : Ôäé, f ¤ü = 0 ÔåÆ 0 < ¤ü.im ÔåÆ PositiveUpperImaginaryEscape R

-- =====================================================================
-- ┬º4. Probe arithmetic at an upper pole  (CXXIX)
-- =====================================================================
-- The `m / (ÔêÆ╬Á┬ÀI)` blow-up family. A real residue `m` divided by `ÔêÆ╬Á┬ÀI`
-- rotates onto the positive imaginary axis with magnitude `m/╬Á`, which
-- diverges as `╬Á Ôåô 0` and defeats any bounded background.

/-- **PROVED ÔÇö escape value `m/╬Á` exceeds any bounded `K` once `╬Á < m/K`.**
This is the analytic clincher: a bounded background cannot kill the
`m/╬Á` divergence near an upper pole. -/
theorem escape_exceeds_bounded_background
    (m K eps : ÔäØ) (_hm : m > 0) (hK : K > 0) (h╬Á : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps > K := by
  rw [gt_iff_lt, lt_div_iffÔéÇ h╬Á]
  have hKne : K Ôëá 0 := ne_of_gt hK
  have : K * eps < K * (m / K) := by
    apply mul_lt_mul_of_pos_left hsmall hK
  have hKK : K * (m / K) = m := by
    field_simp
  rw [hKK] at this
  linarith

/-- **PROVED ÔÇö escape strictly positive: `m/╬Á ÔêÆ K > 0` once `╬Á < m/K`.** -/
theorem residual_escape_positive
    (m K eps : ÔäØ) (hm : m > 0) (hK : K > 0) (h╬Á : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps - K > 0 := by
  have h := escape_exceeds_bounded_background m K eps hm hK h╬Á hsmall
  linarith

/-- **PROVED ÔÇö probe subtraction: `(a + (bÔêÆ╬Á)┬ÀI) ÔêÆ (a + b┬ÀI) = ÔêÆ╬Á┬ÀI`.** -/
theorem complex_probe_subtraction (a b eps : ÔäØ) :
    ((a : Ôäé) + (b - eps) * Complex.I) - ((a : Ôäé) + b * Complex.I)
      = -eps * Complex.I := by
  ring

/-- **PROVED ÔÇö `Im(m / (ÔêÆ╬Á┬ÀI)) = m / ╬Á`** for `╬Á Ôëá 0`.
The central probe identity: at the probe just below an upper pole, the
residue contribution `m / (z_╬Á ÔêÆ ¤ü)` has imaginary part `m/╬Á`. -/
theorem upper_pole_probe_imag (m eps : ÔäØ) (h╬Á : eps Ôëá 0) :
    ((m : Ôäé) / ((-eps : Ôäé) * Complex.I)).im = m / eps := by
  have h╬Á2 : eps^2 Ôëá 0 := pow_ne_zero 2 h╬Á
  rw [Complex.div_im]
  rw [Complex.normSq_mul, Complex.normSq_I, mul_one]
  simp only [Complex.mul_re, Complex.mul_im, Complex.I_re, Complex.I_im,
    Complex.ofReal_re, Complex.ofReal_im, Complex.neg_re, Complex.neg_im,
    Complex.normSq_neg, Complex.normSq_ofReal,
    mul_zero, mul_one, zero_mul, sub_zero, add_zero, neg_zero, zero_sub,
    neg_neg]
  field_simp
  ring

/-- **PROVED ÔÇö `Im(m / (ÔêÆ╬Á┬ÀI)) > 0` when `m, ╬Á > 0`.** -/
theorem upper_pole_probe_imag_positive
    (m eps : ÔäØ) (hm : 0 < m) (h╬Á : 0 < eps) :
    0 < ((m : Ôäé) / ((-eps : Ôäé) * Complex.I)).im := by
  rw [upper_pole_probe_imag m eps (ne_of_gt h╬Á)]
  exact div_pos hm h╬Á

/-- **PROVED ÔÇö escape exceeds bounded background (complex form):**
if `m, ╬Á > 0` and `╬Á < m/K` and `|Im B| Ôëñ K` then
`Im(m / (ÔêÆ╬Á┬ÀI) + B) > 0`. -/
theorem upper_pole_escape_with_background_complex
    (m eps K : ÔäØ) (B : Ôäé)
    (hm : 0 < m) (hK : 0 < K) (h╬Á : 0 < eps)
    (hsmall : eps < m / K)
    (hB : |B.im| Ôëñ K) :
    0 < (((m : Ôäé) / ((-eps : Ôäé) * Complex.I)) + B).im := by
  rw [Complex.add_im, upper_pole_probe_imag m eps (ne_of_gt h╬Á)]
  have hescape : m / eps > K :=
    escape_exceeds_bounded_background m K eps hm hK h╬Á hsmall
  have hB_lb : -K Ôëñ B.im := neg_le_of_abs_le hB
  linarith

/-- **PROVED ÔÇö escape via probe formula combined: at `z_╬Á` for upper pole
`¤ü`, the residue + background imaginary part is positive.** -/
theorem polynomial_upper_root_forces_escape_complex
    (a b eps m K : ÔäØ) (B : Ôäé)
    (_hb : 0 < b) (hm : 0 < m) (hK : 0 < K)
    (h╬Á : 0 < eps) (_h╬Á_lt_b : eps < b)
    (hsmall : eps < m / K)
    (hB : |B.im| Ôëñ K) :
    0 < (((m : Ôäé) /
      (((a : Ôäé) + (b - eps) * Complex.I) - ((a : Ôäé) + b * Complex.I))) + B).im := by
  rw [complex_probe_subtraction]
  exact upper_pole_escape_with_background_complex m eps K B hm hK h╬Á hsmall hB

-- =====================================================================
-- ┬º5. Local pole decomposition engine  (CXXXI Layers 1ÔÇô2)
-- =====================================================================

/-- **Local-decomposition data for a log-derivative response at an upper
pole.** The pole is at `¤ü` with multiplicity `m`. The response equals
`m/(z ÔêÆ ¤ü) + background z` on the probe segment `¤ü ÔêÆ ╬Á┬ÀI` for
`0 < ╬Á < ╬Á0`. The background's imaginary part is uniformly bounded by `K`
on that segment. -/
structure LocalLogDerivPoleDecomposition (R : Ôäé ÔåÆ Ôäé) (¤ü : Ôäé) where
  m : Ôäò
  hm_pos : 0 < m
  background : Ôäé ÔåÆ Ôäé
  ╬Á0 : ÔäØ
  h╬Á0 : 0 < ╬Á0
  h╬Á0_lt : ╬Á0 < ¤ü.im
  K : ÔäØ
  hK_pos : 0 < K
  decomp_at_probe :
    ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
      R (¤ü - (╬Á : Ôäé) * Complex.I) =
        ((m : ÔäØ) : Ôäé) / ((¤ü - (╬Á : Ôäé) * Complex.I) - ¤ü) +
        background (¤ü - (╬Á : Ôäé) * Complex.I)
  background_bounded :
    ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
      |(background (¤ü - (╬Á : Ôäé) * Complex.I)).im| Ôëñ K

/-- **PROVED ÔÇö THE TRUE ANALYTIC ENGINE.** A local pole decomposition at
an upper pole forces a positive upper-imaginary escape. Pick
`╬Á := min(╬ÁÔéÇ/2, m/(2K))`, apply `upper_pole_escape_with_background_complex`. -/
theorem localLogDerivPoleDecomposition_forces_escape
    {R : Ôäé ÔåÆ Ôäé} {¤ü : Ôäé}
    (D : LocalLogDerivPoleDecomposition R ¤ü) :
    PositiveUpperImaginaryEscape R := by
  have hm_real_pos : (0 : ÔäØ) < (D.m : ÔäØ) := by exact_mod_cast D.hm_pos
  have hmK_pos : 0 < (D.m : ÔäØ) / D.K := div_pos hm_real_pos D.hK_pos
  let ╬Á : ÔäØ := min (D.╬Á0 / 2) ((D.m : ÔäØ) / D.K / 2)
  have h╬Á_pos : 0 < ╬Á := by
    refine lt_min ?_ ?_
    ┬À linarith [D.h╬Á0]
    ┬À linarith
  have h╬Á_lt_╬Á0 : ╬Á < D.╬Á0 := by
    refine lt_of_le_of_lt (min_le_left _ _) ?_
    linarith [D.h╬Á0]
  have h╬Á_lt_mK : ╬Á < (D.m : ÔäØ) / D.K := by
    refine lt_of_le_of_lt (min_le_right _ _) ?_
    linarith
  refine Ôƒ¿¤ü - (╬Á : Ôäé) * Complex.I, ?_, ?_Ôƒ®
  ┬À -- 0 < (¤ü ÔêÆ ╬Á┬ÀI).im = ¤ü.im ÔêÆ ╬Á
    have h_im : (¤ü - (╬Á : Ôäé) * Complex.I).im = ¤ü.im - ╬Á := by
      simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
            Complex.ofReal_re, Complex.ofReal_im]
    rw [h_im]
    linarith [D.h╬Á0_lt]
  ┬À -- 0 < Im(R(¤ü ÔêÆ ╬Á┬ÀI))
    rw [D.decomp_at_probe ╬Á h╬Á_pos h╬Á_lt_╬Á0]
    have hsub : (¤ü - (╬Á : Ôäé) * Complex.I) - ¤ü = -(╬Á : Ôäé) * Complex.I := by
      ring
    rw [hsub]
    have hB := D.background_bounded ╬Á h╬Á_pos h╬Á_lt_╬Á0
    exact upper_pole_escape_with_background_complex
      (D.m : ÔäØ) ╬Á D.K (D.background (¤ü - (╬Á : Ôäé) * Complex.I))
      hm_real_pos D.hK_pos h╬Á_pos h╬Á_lt_mK hB

/-- **PROVED ÔÇö complex local-pole decomposition for a simple root.**
If `p` factors locally as `p = (X ÔêÆ ¤ü) ┬À q` at `z` with `q(z) Ôëá 0`
and `z Ôëá ¤ü`, then `(p value)' / (p value) = 1/(zÔêÆ¤ü) + q'/q`.
Stated as an algebraic identity on values. -/
theorem complex_local_pole_decomposition_simple_root
    (z ¤ü q dq : Ôäé) (h¤ü : z Ôëá ¤ü) (hq : q Ôëá 0) :
    (q + (z - ¤ü) * dq) / ((z - ¤ü) * q)
      = 1 / (z - ¤ü) + dq / q := by
  have h¤ü' : z - ¤ü Ôëá 0 := sub_ne_zero.mpr h¤ü
  field_simp
  ring

/-- **PROVED ÔÇö complex local-pole decomposition for multiplicity 2.**
If `p = (X ÔêÆ ¤ü)┬▓ ┬À q`, then at `z Ôëá ¤ü`, `q(z) Ôëá 0`:
`p'(z)/p(z) = 2/(zÔêÆ¤ü) + q'(z)/q(z)`. -/
theorem complex_local_pole_decomposition_double_root
    (z ¤ü q dq : Ôäé) (h¤ü : z Ôëá ¤ü) (hq : q Ôëá 0) :
    (2 * (z - ¤ü) * q + (z - ¤ü)^2 * dq) / ((z - ¤ü)^2 * q)
      = 2 / (z - ¤ü) + dq / q := by
  have h¤ü' : z - ¤ü Ôëá 0 := sub_ne_zero.mpr h¤ü
  have h¤ü'2 : (z - ¤ü)^2 Ôëá 0 := pow_ne_zero 2 h¤ü'
  field_simp
  ring

/-- **PROVED ÔÇö complex local-pole decomposition for multiplicity 3.** -/
theorem complex_local_pole_decomposition_triple_root
    (z ¤ü q dq : Ôäé) (h¤ü : z Ôëá ¤ü) (hq : q Ôëá 0) :
    (3 * (z - ¤ü)^2 * q + (z - ¤ü)^3 * dq) / ((z - ¤ü)^3 * q)
      = 3 / (z - ¤ü) + dq / q := by
  have h¤ü' : z - ¤ü Ôëá 0 := sub_ne_zero.mpr h¤ü
  have h¤ü'3 : (z - ¤ü)^3 Ôëá 0 := pow_ne_zero 3 h¤ü'
  field_simp
  ring

/-- **PROVED ÔÇö local-pole decomposition for general multiplicity `m = k+1`
in the form `(p value)' / (p value) = m/(zÔêÆ¤ü) + q'/q`** when supplied
with the standard derivative expansion `m┬À(zÔêÆ¤ü)^(mÔêÆ1)┬Àq + (zÔêÆ¤ü)^m┬Àq'`. -/
theorem complex_local_pole_decomposition_general
    (z ¤ü q dq : Ôäé) (k : Ôäò) (h¤ü : z Ôëá ¤ü) (hq : q Ôëá 0) :
    (((k + 1 : Ôäò) : Ôäé) * (z - ¤ü)^k * q + (z - ¤ü)^(k + 1) * dq)
      / ((z - ¤ü)^(k + 1) * q)
      = ((k + 1 : Ôäò) : Ôäé) / (z - ¤ü) + dq / q := by
  have h¤ü' : z - ¤ü Ôëá 0 := sub_ne_zero.mpr h¤ü
  have h¤ü'k : (z - ¤ü)^k Ôëá 0 := pow_ne_zero k h¤ü'
  have h¤ü'sk : (z - ¤ü)^(k + 1) Ôëá 0 := pow_ne_zero (k + 1) h¤ü'
  rw [pow_succ]
  field_simp
  ring

-- =====================================================================
-- ┬º6. Engine theorems
-- =====================================================================

/-- **Anti-Herglotz forbids upper zeros.** Pole witness + anti-Herglotz
response ÔçÆ `f` has no upper-half-plane zeros. One line via the iff. -/
theorem antiHerglotz_forbids_upper_zeros
    {f R : Ôäé ÔåÆ Ôäé}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R) :
    ÔêÇ ¤ü : Ôäé, 0 < ¤ü.im ÔåÆ f ¤ü Ôëá 0 := by
  intro ¤ü hupper hzero
  have hesc := hpole.upper_zero_forces_escape ¤ü hzero hupper
  exact (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti hesc

/-- `(star z).im = -z.im` ÔÇö the `Star`-side restatement of `Complex.conj_im`. -/
theorem complex_star_im (¤ü : Ôäé) : (star ¤ü).im = -¤ü.im := by
  show (starRingEnd Ôäé ¤ü).im = -¤ü.im
  exact Complex.conj_im ¤ü

/-- **Anti-Herglotz + Schwarz symmetry forces real zeros.** Trichotomy on
`¤ü.im`:

* Upper zero: killed directly by `antiHerglotz_forbids_upper_zeros`.
* Lower zero: killed via conjugate reflection ÔÇö `f (star ¤ü) = star (f ¤ü) = 0`
  with `(star ¤ü).im = ÔêÆ¤ü.im > 0`, again contradicting
  `antiHerglotz_forbids_upper_zeros`. -/
theorem antiHerglotz_plus_symmetry_forces_real_zeros_complex
    {f R : Ôäé ÔåÆ Ôäé}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R)
    (hsym : ÔêÇ z : Ôäé, f (star z) = star (f z)) :
    ÔêÇ ¤ü : Ôäé, f ¤ü = 0 ÔåÆ ¤ü.im = 0 := by
  intro ¤ü h¤üzero
  rcases lt_trichotomy ¤ü.im 0 with hneg | hzero | hpos
  ┬À -- lower zero ÔçÆ conjugate is upper zero ÔçÆ contradiction
    have hconj_zero : f (star ¤ü) = 0 := by
      rw [hsym ¤ü, h¤üzero]
      simp
    have hupper_conj : 0 < (star ¤ü).im := by
      rw [complex_star_im]
      linarith
    exact absurd hconj_zero
      (antiHerglotz_forbids_upper_zeros hpole hanti (star ¤ü) hupper_conj)
  ┬À exact hzero
  ┬À -- upper zero directly contradicts the engine
    exact absurd h¤üzero
      (antiHerglotz_forbids_upper_zeros hpole hanti ¤ü hpos)

-- =====================================================================
-- ┬º6-bis. Totalization-at-zeros analysis (engine soundness)
-- =====================================================================
-- A reviewer-flagged concern: `logDerivativeResponse f z = f'(z) / f(z)`
-- evaluates to `0` at any zero of `f` because Lean uses the totalized
-- division convention `a / 0 = 0`. So the anti-Herglotz inequality
-- `Im (R z) Ôëñ 0` reads as `0 Ôëñ 0` at every zero, trivially true.
--
-- The lemmas below make precise *why this is harmless*: the
-- pole-witness engine never queries `R` at a zero ÔÇö it queries `R` at a
-- probe `¤ü ÔêÆ ╬Á┬ÀI` with `╬Á > 0`, which is provably distinct from `¤ü`
-- (`probe_ne_pole`). At the probe, `f` is genuinely nonzero (by
-- analytic continuity on a small enough neighbourhood; this is what
-- `continuousAt_implies_probe_nonzero` packages), and the value
-- `m / (z ÔêÆ ¤ü) + bounded` is the honest analytic content the engine
-- contradicts.
--
-- So `AntiHerglotzUHP R` is consumed by the engine *at probe points,
-- never at zeros*. The totalization is bookkeeping, not load-bearing.

/-- **PROVED ÔÇö totalized log-derivative is `0` at any zero.**
Pure consequence of Lean's `a / 0 = 0` convention; recorded as a named
lemma so the totalization behaviour is explicit. -/
theorem logDerivativeResponse_eq_zero_at_zero
    {f : Ôäé ÔåÆ Ôäé} {¤ü : Ôäé} (hzero : f ¤ü = 0) :
    logDerivativeResponse f ¤ü = 0 := by
  unfold logDerivativeResponse
  rw [hzero, div_zero]

/-- **PROVED ÔÇö anti-Herglotz inequality is vacuous at any zero.**
At a zero, both sides of `(R z).im Ôëñ 0` are `0`. The substantive
content of `AntiHerglotzUHP R` therefore lies entirely on the
zero-free set. -/
theorem antiHerglotz_at_zero_is_vacuous
    {f : Ôäé ÔåÆ Ôäé} {¤ü : Ôäé} (hzero : f ¤ü = 0) :
    (logDerivativeResponse f ¤ü).im = 0 := by
  rw [logDerivativeResponse_eq_zero_at_zero hzero]
  exact Complex.zero_im

/-- **PROVED ÔÇö engine probe is never a zero.** The escape constructed by
`localLogDerivPoleDecomposition_forces_escape` lives at probe
`¤ü ÔêÆ ╬Á┬ÀI` with `╬Á > 0`, and the imaginary parts differ by exactly `╬Á`.
`f` is separately ensured nonzero at the probe by
`continuousAt_implies_probe_nonzero` (defined in ┬º9), so the totalization
at `¤ü` itself never enters the engine's contradiction. (The ┬º9 lemma
`probe_ne_pole` proves the same fact in the same form; this copy lives
here so that ┬º6-bis is self-contained and can be quoted before ┬º9.) -/
theorem engine_probe_is_not_the_zero
    (¤ü : Ôäé) (╬Á : ÔäØ) (h╬Á : 0 < ╬Á) :
    ¤ü - (╬Á : Ôäé) * Complex.I Ôëá ¤ü := by
  intro h
  have him_diff : (¤ü - (╬Á : Ôäé) * Complex.I).im = ¤ü.im := by rw [h]
  have him_calc : (¤ü - (╬Á : Ôäé) * Complex.I).im = ¤ü.im - ╬Á := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- Ô¡É **PROVED ÔÇö sharper anti-Herglotz form, restricted to nonzero
points.** `AntiHerglotzUHP R` with totalized `R = ╬ø[f]` is *equivalent*
on its substantive content to the same inequality demanded only at points
where `f Ôëá 0`. The forward direction is trivial; the backward direction
patches in the vacuous `0 Ôëñ 0` at zeros. This formalises the claim that
the totalization adds no proof obligations. -/
theorem antiHerglotz_iff_antiHerglotz_away_from_zeros
    (f : Ôäé ÔåÆ Ôäé) :
    AntiHerglotzUHP (logDerivativeResponse f)
      Ôåö ÔêÇ z : Ôäé, 0 < z.im ÔåÆ f z Ôëá 0 ÔåÆ
          (logDerivativeResponse f z).im Ôëñ 0 := by
  constructor
  ┬À intro h z hz _; exact h z hz
  ┬À intro h z hz
    by_cases hfz : f z = 0
    ┬À rw [antiHerglotz_at_zero_is_vacuous hfz]
    ┬À exact h z hz hfz

-- =====================================================================
-- ┬º7. Polynomial instantiation  (CXXXI Layers 3ÔÇô4)
-- =====================================================================

/-- **Polynomial logDeriv response (value form):** `╬ø[p](z) = p'(z) / p(z)`. -/
noncomputable def polynomialLogDerivResponse (p : Polynomial Ôäé) : Ôäé ÔåÆ Ôäé :=
  fun z => p.derivative.eval z / p.eval z

/-- **PROVED ÔÇö applied to the abstract engine: any polynomial supplying
a `LocalLogDerivPoleDecomposition` at an upper root has a positive
escape.** -/
theorem polynomial_local_pole_forces_escape
    (p : Polynomial Ôäé) (¤ü : Ôäé)
    (D : LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ¤ü) :
    PositiveUpperImaginaryEscape (polynomialLogDerivResponse p) :=
  localLogDerivPoleDecomposition_forces_escape D

/-- **Polynomial pole-witness hypothesis (deferred Mathlib instantiation).**
For every upper-half-plane root `¤ü` of `p` we have a
`LocalLogDerivPoleDecomposition` at `¤ü`. The general construction of such
a decomposition from `p Ôëá 0` and `p.eval ¤ü = 0` requires Mathlib's
polynomial root-multiplicity + bounded-continuity machinery and lives in
CXXXII / Mathlib-side work. -/
structure PolynomialPoleWitnessHypothesis (p : Polynomial Ôäé) : Prop where
  decomp_at_each_upper_root :
    ÔêÇ ¤ü : Ôäé, p.eval ¤ü = 0 ÔåÆ 0 < ¤ü.im ÔåÆ
      Nonempty (LocalLogDerivPoleDecomposition
        (polynomialLogDerivResponse p) ¤ü)

/-- **PROVED ÔÇö polynomial log-derivative pole-witness law:** the
hypothesis package implies the abstract `LogDerivPoleWitnessLaw`. -/
