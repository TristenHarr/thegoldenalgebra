                          (Or.inr (List.mem_cons_self ..))))))))))))))
      push_neg at h8
      refine тЯиs9, ?_, le_of_lt h8, hT140тЯй
      exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
              (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
