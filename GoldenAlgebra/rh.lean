    (StripGapToLC.bridge F.toRightGapInStrip) hT

/-! ### CW18: discharge local finiteness from `ZetaZeroPosImagPosRe` -/

/-- **CW18 вАФ local finiteness in the strip window from
`ZetaZeroPosImagPosRe`.**  Given the functional-equation content that
every ќґ-zero with positive imaginary part has positive real part, the
strip window is contained in `zetaZerosUpToHeightSet (T + 1)`, which is
already proven finite (`zetaZerosUpToHeightSet_finite`). -/
theorem ZetaZerosLocallyFiniteInBacklundStripInput.of_posRe
    (H : ZetaZeroPosImagPosRe) :
    ZetaZerosLocallyFiniteInBacklundStripInput where
  finite_window := by
    intro T hT
    have hT1_nonneg : (0 : вДЭ) вЙ§ T + 1 := by linarith
    have hfin : Set.Finite (zetaZerosUpToHeightSet (T + 1)) :=
      zetaZerosUpToHeightSet_finite (T + 1) hT1_nonneg
    refine hfin.subset ?_
    intro ѕБ hѕБ
    obtain вЯ®hzero, _hre1, _hre2, him_lt, him_leвЯ© := hѕБ
    have him_pos : (0 : вДЭ) < ѕБ.im := by linarith
    have hposre : 0 < ѕБ.re := H ѕБ him_pos hzero
    have hreone : ѕБ.re < 1 := zetaZero_re_lt_one hzero
    exact вЯ®вЯ®hzero, hposre, hreoneвЯ©, him_pos, him_leвЯ©

/-- **CW18 вАФ sharper final theorem.**  Replaces the local-finite-zeros
input with the smaller, more focused functional-equation classification
fact `ZetaZeroPosImagPosRe`. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction_and_posRe
    (E : BacklundNumericalExtractionInput)
    (H : ZetaZeroPosImagPosRe)
    (StripGapToLC : ZetaStripGapToLocalConstancyInput)
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction_and_localFiniteZeros
    E (ZetaZerosLocallyFiniteInBacklundStripInput.of_posRe H)
    StripGapToLC hT

/-! ### CW19: discharge `ZetaZeroPosImagPosRe` -/

/-- **CW19 вАФ `ZetaZeroPosImagPosRe` DISCHARGED.**  Combines the already-
proved functional-equation fact `zetaNoZerosLeftHalfPlaneUpper` with the
existing wrapper `ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper`. -/
theorem zetaZeroPosImagPosRe : ZetaZeroPosImagPosRe :=
  ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper
    zetaNoZerosLeftHalfPlaneUpper

/-- **CW19 вАФ final theorem from numerical extraction + strip-gap вЖТ LC
bridge.**  The functional-equation classification is now supplied
unconditionally inside this theorem, leaving only the two genuinely
hardest obligations as free parameters. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction_and_stripGapBridge
    (E : BacklundNumericalExtractionInput)
    (StripGapToLC : ZetaStripGapToLocalConstancyInput)
