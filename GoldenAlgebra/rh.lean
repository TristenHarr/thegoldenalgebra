lemma slabSimple_36_48_subband_assembly
    {A B L K ╧Д x y T : тДЭ}
    (hx : 0 тЙд x)
    (hTA : A тЙд T) (_hTB : T тЙд B)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T)
    (hA_ge_36 : 36 тЙд A)
    (hlog : Real.log T тЙд L)
    (hcloud_const : K тЙд cloudK_T zeros100ceil T)
    (htail_const : ╧Д тЙд tailK_36_48 T)
    (hscalar :
      (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) тЙд 2 * K + ╧Д) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) 1 y T
      тЙд simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hA_ge_one : (1 : тДЭ) тЙд A := by linarith
  have hT36 : 36 тЙд T := le_trans hA_ge_36 hTA
  have hclosed :
      closedFormSErrorBoundCD (1 / 2 : тДЭ) 1 y T
        тЙд y * (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) :=
    closedFormSErrorBoundCD_36_48_subband_le_const hy_nn hA_ge_one hTA hlog
  have hscaled :
      y * (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) тЙд y * (2 * K + ╧Д) :=
    mul_le_mul_of_nonneg_left hscalar hy_nn
  have hcloud :
      2 * y * cloudK_T zeros100ceil T
        тЙд simpleCloudSum zeros100ceil x y :=
    simpleCloudSum_ge_admissible_T_bound zeros100ceil hx hy hreg
  have htail :
      y * tailK_36_48 T тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_const_36_48 hx hT36 hy hreg
  have h_y_const_le_dyn :
      y * (2 * K + ╧Д)
        тЙд 2 * y * cloudK_T zeros100ceil T + y * tailK_36_48 T := by
    nlinarith [hy_nn, hcloud_const, htail_const]
  calc
    closedFormSErrorBoundCD (1 / 2 : тДЭ) 1 y T
        тЙд y * (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) := hclosed
    _ тЙд y * (2 * K + ╧Д) := hscaled
    _ тЙд 2 * y * cloudK_T zeros100ceil T + y * tailK_36_48 T :=
        h_y_const_le_dyn
    _ тЙд simpleCloudSum zeros100ceil x y
          + smoothTailRationalLowerBoundAbs x y T :=
        add_le_add hcloud htail

