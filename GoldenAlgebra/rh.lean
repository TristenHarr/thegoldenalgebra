  have htail :
      y * tailK_12_13 T
        Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_affine_12_13 hx hT12 hT13 hy hreg
  rw [hclosed]
  calc
    y * ((527 / 100 : ÔäØ) / T^2)
        Ôëñ y * (2 * cloudK_T zeros25ceil T + tailK_12_13 T) := hscaled
    _ = 2 * y * cloudK_T zeros25ceil T + y * tailK_12_13 T := hsplit
    _ Ôëñ simpleCloudSum zeros25ceil x y
