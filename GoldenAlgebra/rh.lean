/-- Numerical form of Backlund's good-height estimate: the explicit
inequality that the three analytic estimates combine into. -/
def BacklundNumericalCombinationEstimate (T : вДЭ) : Prop :=
  |concreteS T| вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2

/-- The classical Backlund combination input: the lemma that contracts
the three named estimates into `BacklundNumericalCombinationEstimate T`.
Isolates the "assemble-the-pieces" step from the analytic inputs that
feed it. -/
structure BacklundClassicalCombinationInput : Prop where
  combine :
    вИА T : вДЭ, RvMGoodHeight T вЖТ (140 : вДЭ) вЙ§ T вЖТ
      BacklundJensenRectangleEstimate T вЖТ
      BacklundRightSideArgumentVariationEstimate T вЖТ
      BacklundHorizontalBoundaryEstimate T вЖТ
