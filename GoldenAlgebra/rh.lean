/-! ### Analytic zero multiplicity interface

Bridge from Mathlib's `analyticOrderAt` (valued in `ÔäòÔê×`) to the
`GlobalZeroMultiplicity` interface (valued in `Ôäò`).  This layer is
fully no-axiom/no-sorry: it does not assert that nontrivial zeta zeros
have finite positive analytic order ÔÇö instead it parameterizes the
construction by a witness of that fact, which becomes the real analytic
proof obligation. -/

/-- Alias for `analyticOrderAt`, the order of vanishing of an analytic
function at a point. -/
noncomputable def analyticZeroOrder (f : Ôäé ÔåÆ Ôäé) (s : Ôäé) : ÔäòÔê× :=
  analyticOrderAt f s

/-- A point has finite positive analytic zero order for `f`. -/
def HasFinitePositiveAnalyticZeroOrder (f : Ôäé ÔåÆ Ôäé) (s : Ôäé) : Prop :=
  Ôêâ n : Ôäò, 0 < n Ôêº analyticOrderAt f s = (n : ÔäòÔê×)

/-- A point has finite positive analytic zeta-zero multiplicity. -/
def HasFinitePositiveZetaMultiplicity (s : Ôäé) : Prop :=
  HasFinitePositiveAnalyticZeroOrder riemannZeta s

/-- A proof that every nontrivial zeta zero has finite positive analytic
order.  This structure asserts nothing unless inhabited; constructing an
inhabitant is the first real analytic theorem obligation. -/
structure ZetaAnalyticMultiplicityWitness where
  finite_positive :
    ÔêÇ {s : Ôäé}, IsNontrivialZetaZero s ÔåÆ
      HasFinitePositiveZetaMultiplicity s

open Classical in
/-- The natural-number multiplicity extracted from a
`ZetaAnalyticMultiplicityWitness`. -/
noncomputable def zetaMultiplicityOfWitness
    (W : ZetaAnalyticMultiplicityWitness) (s : Ôäé) : Ôäò :=
  if hs : IsNontrivialZetaZero s then
    Classical.choose (W.finite_positive hs)
  else
    0

/-- The extracted multiplicity is positive on nontrivial zeta zeros. -/
theorem zetaMultiplicityOfWitness_pos
    (W : ZetaAnalyticMultiplicityWitness)
    {s : Ôäé} (hs : IsNontrivialZetaZero s) :
    0 < zetaMultiplicityOfWitness W s := by
  unfold zetaMultiplicityOfWitness
  rw [dif_pos hs]
  exact (Classical.choose_spec (W.finite_positive hs)).1

/-- The extracted multiplicity matches the analytic order of vanishing of
`riemannZeta` at every nontrivial zero. -/
theorem zetaMultiplicityOfWitness_order_eq
    (W : ZetaAnalyticMultiplicityWitness)
    {s : Ôäé} (hs : IsNontrivialZetaZero s) :
    analyticOrderAt riemannZeta s =
      (zetaMultiplicityOfWitness W s : ÔäòÔê×) := by
  unfold zetaMultiplicityOfWitness
  rw [dif_pos hs]
  exact (Classical.choose_spec (W.finite_positive hs)).2

/-- The `GlobalZeroMultiplicity` instance derived from a
`ZetaAnalyticMultiplicityWitness`. -/
noncomputable def zetaGlobalZeroMultiplicityOfWitness
    (W : ZetaAnalyticMultiplicityWitness) :
    GlobalZeroMultiplicity where
  mult := zetaMultiplicityOfWitness W
  positive_of_isNontrivialZetaZero := by
    intro s hs
    exact zetaMultiplicityOfWitness_pos W hs

/-! ### First analytic facts about nontrivial zeta zeros

Decomposition of the eventual `zetaAnalyticMultiplicityWitness` proof:

  1. Nontrivial zeros are not the pole `1`               (this section).
  2. `riemannZeta` is analytic at every `s Ôëá 1`.
  3. `riemannZeta` is not locally identically zero
     at any nontrivial zero.
  4. `analyticOrderAt riemannZeta s` is finite (Ôëá Ôèñ) at a nontrivial zero.
  5. `analyticOrderAt riemannZeta s Ôëá 0` since `╬Â(s) = 0`.
  6. Combine into `ZetaAnalyticMultiplicityWitness`.

Only step (1) is added here.  Steps (2)ÔÇô(5) need probing of Mathlib's
`riemannZeta` analyticity and `analyticOrderAt` API in a live session. -/

/-- A nontrivial zeta zero is not the pole `1`. -/
theorem isNontrivialZetaZero_ne_one
    {s : Ôäé} (hs : IsNontrivialZetaZero s) :
    s Ôëá 1 := by
  intro h
  have hre : s.re = 1 := by
    rw [h]; norm_num
  linarith [hs.2.2]

/-! ### Structural helpers around the analytic multiplicity witness -/

/-- A nontrivial zeta zero gives a positive finite analytic zeta
multiplicity once its analytic order is known to be a finite positive
