/-- `7/(18┬╖B) тЙд tailK_36_48 T` for `T тЙд B`. Chain: `(22/15)┬╖(5/3)┬╖(7/44) = 7/18`. -/
lemma tailK_36_48_ge_const
    {T B : тДЭ} (hTpos : 0 < T) (hTB : T тЙд B) :
    (7 / (18 * B) : тДЭ) тЙд tailK_36_48 T := by
  unfold tailK_36_48
  have hBpos : 0 < B := by linarith
  have hBne : B тЙа 0 := ne_of_gt hBpos
  have h_2pi_inv : (7 / 44 : тДЭ) тЙд 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_inv_T : (1 / B : тДЭ) тЙд 1 / T :=
    one_div_le_one_div_of_le hTpos hTB
  have h_form :
      (22 / 15 : тДЭ) * ((5 / 3 : тДЭ) / (2 * Real.pi)) / T
        = (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) * (1 / T) := by ring
  rw [h_form]
  have hA_nn : (0 : тДЭ) тЙд (22 / 15) * (5 / 3) := by positivity
  have hA_2pi_nn :
      (0 : тДЭ) тЙд (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) := by positivity
  have h_inv_B_nn : (0 : тДЭ) тЙд 1 / B := by positivity
  have h2 :
      (22 / 15 : тДЭ) * (5 / 3) * (7 / 44)
        тЙд (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_2pi_inv hA_nn
  have h3 :
      (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) * (1 / B)
        тЙд (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) * (1 / T) :=
    mul_le_mul_of_nonneg_left h_inv_T hA_2pi_nn
  have h4 :
      (22 / 15 : тДЭ) * (5 / 3) * (7 / 44) * (1 / B)
        тЙд (22 / 15 : тДЭ) * (5 / 3) * (1 / (2 * Real.pi)) * (1 / B) :=
    mul_le_mul_of_nonneg_right h2 h_inv_B_nn
  have h_const :
      (22 / 15 : тДЭ) * (5 / 3) * (7 / 44) * (1 / B) = 7 / (18 * B) := by
    field_simp
    ring
  linarith

/-- Requires `1 тЙд A` so we get `1 тЙд T` and thus `Real.log T тЙе 0`. -/
lemma closedFormSErrorBoundCD_36_48_subband_le_const
    {A L y T : тДЭ}
    (hy : 0 тЙд y)
    (hA_ge_one : 1 тЙд A)
    (hTA : A тЙд T)
    (hlog : Real.log T тЙд L) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) 1 y T
      тЙд y * (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) := by
  have hApos : 0 < A := by linarith
  have hTpos : 0 < T := by linarith
  have hT_ne : T тЙа 0 := ne_of_gt hTpos
  have hT2pos : 0 < T^2 := by positivity
  have hA2pos : 0 < A^2 := by positivity
  have hA2_le_T2 : A^2 тЙд T^2 := by nlinarith
  have hT_ge_one : (1 : тДЭ) тЙд T := by linarith
  have hlog_nn : 0 тЙд Real.log T := Real.log_nonneg hT_ge_one
  have hL_nn : 0 тЙд L := le_trans hlog_nn hlog
  rw [closedFormSErrorBoundCD_half_one_eq hT_ne]
  unfold closedFormSErrorBoundHalfOne
  have hcoeff_le :
      (17 / 2 : тДЭ) * Real.log T + 77 / 4 тЙд (17 / 2 : тДЭ) * L + 77 / 4 := by
    nlinarith
  have hnum_nn : 0 тЙд (17 / 2 : тДЭ) * L + 77 / 4 := by nlinarith
  have hz_nn : 0 тЙд y / T^2 := div_nonneg hy (le_of_lt hT2pos)
  calc
    (y / T^2) * ((17 / 2 : тДЭ) * Real.log T + 77 / 4)
        тЙд (y / T^2) * ((17 / 2 : тДЭ) * L + 77 / 4) :=
          mul_le_mul_of_nonneg_left hcoeff_le hz_nn
    _ = y * (((17 / 2 : тДЭ) * L + 77 / 4) / T^2) := by ring
    _ тЙд y * (((17 / 2 : тДЭ) * L + 77 / 4) / A^2) := by
      apply mul_le_mul_of_nonneg_left _ hy
      exact div_le_div_of_nonneg_left hnum_nn hA2pos hA2_le_T2

lemma cloudK_T_zeros100ceil_ge_const_of_box
    {K B T : тДЭ}
    (h_static :
      K тЙд (zeros100ceil.map
        (fun ╬│ : тДЭ => 1 / (B^2 + ╬│^2))).sum)
    (hlo : 0 тЙд T / 2 - 1)
    (hhi : T / 2 - 1 тЙд B)
    (hpos : 0 < T / 2 - 1) :
