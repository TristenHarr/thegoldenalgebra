-- =====================================================================
-- ┬зCCXLV. Canonical-T `herror` formulation
-- =====================================================================
-- Mathematical correction: the raw improper tail
-- `тИл_T^тИЮ kernel ┬╖ S` genuinely depends on `T`, so a `herror`
-- quantifying `(error z).im = (trueKernelAdaptiveTail T z).im`
-- for ALL adaptive `T` (with `error` independent of `T`) is too
-- strong тАФ it implicitly forces tail independence.
--
-- This section provides a corrected single-`T` formulation:
-- pick one canonical adaptive `T` per `z` (deterministic, via
-- `Classical.choose` inside a `dite`), and require `herror` only
-- at that canonical `T`. The original arbitrary-`T` formulation
-- is preserved (it can still be inhabited if tail independence
-- is actually proved later).
--
-- Adds:
--   canonicalAdaptiveT                                       тАФ deterministic zтЖжT
--   canonicalAdaptiveT_spec                                  тАФ spec lemma
--   XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail      тАФ canonical-T constructor
--   XiPullbackAntiHerglotzTarget_of_errorFormula_canonical   тАФ final front door

/-- **Canonical adaptive cutoff at `z`.** A deterministic choice of `T`
satisfying the adaptive band condition `10 тЙд T тЙд 140` and
`2(1 + |z.re| + z.im) тЙд T`, via `Classical.choose` inside a `dite`.
Outside the adaptive region (i.e. when no such `T` exists), returns
the sentinel `10`. -/
noncomputable def canonicalAdaptiveT (z : тДВ) : тДЭ :=
  letI : Decidable
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) :=
    Classical.propDecidable _
  if h : тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T then
    Classical.choose h
  else
    10

/-- тнР **PROVED тАФ canonical T is in the adaptive band when the band
exists for `z`.** -/
lemma canonicalAdaptiveT_spec
    {z : тДВ}
    (h : тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) :
    10 тЙд canonicalAdaptiveT z тИз
    canonicalAdaptiveT z тЙд 140 тИз
    2 * (1 + |z.re| + z.im) тЙд canonicalAdaptiveT z := by
  have h_choose := Classical.choose_spec h
  unfold canonicalAdaptiveT
  simp [h, h_choose]

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `XiLogDerivativeFormulaPieces` from canonical-T
herror.** Like `ofErrorAsFluctTail` but using the canonical adaptive
`T` per `z` plus an explicit Im-independence hypothesis. The
`fluctTail_im_eq_trueTail` field is recovered by `htail_indep`
bridging from the canonical `T` to any other adaptive `T`. -/
noncomputable def XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List тДЭ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : тДЭ) (hTsmooth_ge : 2 * Real.pi тЙд Tsmooth)
    (error : тДВ тЖТ тДВ)
    (hmodel : тИА z : тДВ,
        M.model z =
