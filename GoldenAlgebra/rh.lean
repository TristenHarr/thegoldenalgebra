      countLower
  right_count_eq :
    zetaWeightedZeroCountUpToHeight B
      (le_trans
        (le_trans (by positivity : (0 : ÔäØ) Ôëñ 2 * Real.pi) hA_two_pi)
        hAB) =
      countUpper
  mainLower_le_left :
    mainLower Ôëñ smoothMainTerm A
  right_le_mainUpper :
    smoothMainTerm B Ôëñ mainUpper
  upperCount_minus_lowerMain_le :
    (countUpper : ÔäØ) - mainLower Ôëñ (25167 / 10000 : ÔäØ)
