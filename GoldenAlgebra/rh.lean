  topRatioUpper : вДЭ
  bottomLogLower : вДЭ
  topLogUpper : вДЭ
  left_count_eq :
    zetaWeightedZeroCountUpToHeight bottom
      (le_trans (by positivity : (0 : вДЭ) вЙ§ 2 * Real.pi)
        (backlund_two_pi_le_of_ge_140 hbottom_ge_140)) =
      leftCount
  right_count_eq :
    zetaWeightedZeroCountUpToHeight top
      (le_trans
        (le_trans (by positivity : (0 : вДЭ) вЙ§ 2 * Real.pi)
          (backlund_two_pi_le_of_ge_140 hbottom_ge_140))
        hbottom_lt_top.le) =
      rightCount
  bottom_ratio_mul_arith :
    2 * (3141593 / 1000000 : вДЭ) * bottomRatioLower вЙ§ bottom
  top_ratio_mul_arith :
    top вЙ§ 2 * (3141592 / 1000000 : вДЭ) * topRatioUpper
