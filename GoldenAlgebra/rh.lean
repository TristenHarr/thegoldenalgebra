theorem XiResidualLowIBPRepresentationAtAwayFromZeros_11_14_half_of_finiteIBP_SBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (Hdom : XiLowResidualFiniteIBPDominationAwayFromZeros
              Dzero T0 honestZeroDensityModelTwoPi)
    (HSbound : FirstZeroAdjustedSBound Dzero T0 14 (1 / 2))
    (Hint : тИА z : тДВ, lowCompactRegion z тЖТ
      IntervalIntegrable
        (fun u => |lowFirstZeroIBPIntegrand Dzero T0 z.re z.im u|)
        MeasureTheory.volume 11 14) :
    XiResidualLowIBPRepresentationAtAwayFromZeros 11 14 (1 / 2)
      honestZeroDensityModelTwoPi := by
  refine тЯи?_тЯй
  intro z hz hne
  have hy : 0 < z.im := hz.1
  have hregime10 : 2 * (1 + |z.re| + z.im) тЙд 10 := hz.2
  have hregime11 : 2 * (1 + |z.re| + z.im) тЙд 11 := by linarith
  have hS : тИА u : тДЭ, 11 тЙд u тЖТ u тЙд 14 тЖТ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| тЙд (1 / 2 : тДЭ) :=
    fun u hu11 hu14 => HSbound.fluct_abs_le u hu11 hu14
  have hS11 : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 11| тЙд (1 / 2 : тДЭ) :=
    hS 11 le_rfl (by norm_num)
  have hbdy : |lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11|
              тЙд 8 * z.im * (1 / 2 : тДЭ) / (11 : тДЭ) ^ 2 :=
    lowFirstZeroBoundaryTerm_abs_le hy.le hregime11 hS11
  have hderiv : |lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14|
              тЙд 9 * z.im * (1 / 2 : тДЭ) / (11 : тДЭ) ^ 2
                - 9 * z.im * (1 / 2 : тДЭ) / (14 : тДЭ) ^ 2 :=
    lowFirstZeroDerivativeSide_abs_le_majorant
      Dzero T0 hy hregime11 (by norm_num : (11 : тДЭ) тЙд 14)
      (by norm_num : (0 : тДЭ) тЙд 1 / 2) hS (Hint z hz)
  have hsum :
      |lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11|
        + |lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14|
          тЙд closedFormFirstZeroErrorBound z.im 11 14 (1 / 2) :=
    lowFirstZeroIBP_sum_le_closedForm hbdy hderiv
