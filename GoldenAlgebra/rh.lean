-- ¬ІCCCXXI. Finite canonical Hadamard product scaffolds
-- =====================================================================
-- Genus-1 Weierstrass factor `EвВБ(s/ѕБ) = (1 - s/ѕБ) ¬Ј exp(s/ѕБ)` and
-- the finite Hadamard product. Uses Mathlib's `logDeriv_prod` for the
-- structural log-derivative-of-product identity. The per-factor
-- log-derivative computation `logDeriv (EвВБ(¬Ј/ѕБ)) s = 1/(s-ѕБ) + 1/ѕБ`
-- is deferred to a future stride.

/-- **Genus-1 Hadamard factor** `EвВБ(s/ѕБ) = (1 - s/ѕБ) ¬Ј exp(s/ѕБ)`. -/
noncomputable def hadamardGenus1Factor (ѕБ s : вДВ) : вДВ :=
  (1 - s / ѕБ) * Complex.exp (s / ѕБ)

/-- в≠Р **PROVED вАФ genus-1 factor non-vanishing when `s вЙ† ѕБ` and `ѕБ вЙ† 0`.** -/
lemma hadamardGenus1Factor_ne_zero {ѕБ s : вДВ} (hѕБ : ѕБ вЙ† 0) (hsѕБ : s вЙ† ѕБ) :
    hadamardGenus1Factor ѕБ s вЙ† 0 := by
  unfold hadamardGenus1Factor
  apply mul_ne_zero
  ¬Ј intro h
    have h1 : s / ѕБ = 1 := by linear_combination -h
    have h2 : s = ѕБ := by
      have := h1
      field_simp at this
      exact this
    exact hsѕБ h2
  ¬Ј exact Complex.exp_ne_zero _

/-- в≠Р **PROVED вАФ genus-1 factor is differentiable everywhere.** -/
lemma hadamardGenus1Factor_differentiableAt (ѕБ s : вДВ) :
    DifferentiableAt вДВ (hadamardGenus1Factor ѕБ) s := by
  unfold hadamardGenus1Factor
  have h_left : DifferentiableAt вДВ (fun y : вДВ => 1 - y / ѕБ) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner : DifferentiableAt вДВ (fun y : вДВ => y / ѕБ) s :=
    differentiableAt_id'.div_const _
  have h_right : DifferentiableAt вДВ (fun y : вДВ => Complex.exp (y / ѕБ)) s :=
    h_inner.cexp
  exact h_left.mul h_right

/-- **Finite Hadamard product** over a finite list of zero ordinates. -/
noncomputable def finiteHadamardProduct (zeros : Finset вДВ) (s : вДВ) : вДВ :=
  вИП ѕБ вИИ zeros, hadamardGenus1Factor ѕБ s

/-- рЯМЯрЯМЯ **PROVED вАФ `logDeriv` of the finite Hadamard product = ќ£ of
per-factor `logDeriv`s.** Direct application of Mathlib's
`logDeriv_prod`. -/
theorem logDeriv_finiteHadamardProduct
    {zeros : Finset вДВ} {s : вДВ}
    (hѕБ_ne : вИА ѕБ вИИ zeros, ѕБ вЙ† 0)
    (hs_ne : вИА ѕБ вИИ zeros, s вЙ† ѕБ) :
    logDeriv (finiteHadamardProduct zeros) s
      = вИС ѕБ вИИ zeros, logDeriv (hadamardGenus1Factor ѕБ) s := by
  unfold finiteHadamardProduct
  exact logDeriv_prod zeros (fun ѕБ => hadamardGenus1Factor ѕБ) s
    (fun ѕБ hѕБ => hadamardGenus1Factor_ne_zero (hѕБ_ne ѕБ hѕБ) (hs_ne ѕБ hѕБ))
    (fun ѕБ _ => hadamardGenus1Factor_differentiableAt ѕБ s)

/-- в≠Р **PROVED вАФ bridge between `logDeriv` (Mathlib) and
`logDerivativeResponse` (this file).** Definitionally equal. -/
theorem logDerivativeResponse_eq_logDeriv (f : вДВ вЖТ вДВ) (z : вДВ) :
    logDerivativeResponse f z = logDeriv f z := rfl

/-- рЯМЯрЯМЯ **PROVED вАФ `logDerivativeResponse` of the finite Hadamard
product = ќ£ of per-factor responses.** Same as `logDeriv_finiteHadamardProduct`
under the definitional equality. -/
theorem logDerivativeResponse_finiteHadamardProduct
    {zeros : Finset вДВ} {s : вДВ}
    (hѕБ_ne : вИА ѕБ вИИ zeros, ѕБ вЙ† 0)
    (hs_ne : вИА ѕБ вИИ zeros, s вЙ† ѕБ) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = вИС ѕБ вИИ zeros, logDerivativeResponse (hadamardGenus1Factor ѕБ) s := by
  simp only [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct hѕБ_ne hs_ne

-- =====================================================================
-- ¬ІCCCXXII. Per-factor log-derivative of the genus-1 Hadamard factor
-- =====================================================================
-- Closes the explicit value of `logDeriv (hadamardGenus1Factor ѕБ) s`
-- as the classical `1/(s-ѕБ) + 1/ѕБ`. Combined with ¬ІCCCXXI's finite
-- product log-derivative, this gives the regularized zero-sum form of
-- the finite Hadamard product log-derivative.

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ per-factor log-derivative of the genus-1
Hadamard factor.** `logDeriv ((1 - ¬Ј/ѕБ) ¬Ј exp(¬Ј/ѕБ)) s = 1/(s-ѕБ) + 1/ѕБ`. -/
theorem logDeriv_hadamardGenus1Factor {ѕБ s : вДВ} (hѕБ : ѕБ вЙ† 0) (hs : s вЙ† ѕБ) :
    logDeriv (hadamardGenus1Factor ѕБ) s = 1 / (s - ѕБ) + 1 / ѕБ := by
  have h_left_diff : DifferentiableAt вДВ (fun y : вДВ => 1 - y/ѕБ) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner_diff : DifferentiableAt вДВ (fun y : вДВ => y/ѕБ) s :=
    differentiableAt_id'.div_const _
  have h_right_diff : DifferentiableAt вДВ (fun y : вДВ => Complex.exp (y/ѕБ)) s :=
    h_inner_diff.cexp
  have hsmѕБ : s - ѕБ вЙ† 0 := sub_ne_zero.mpr hs
  have h_left_ne : (1 : вДВ) - s/ѕБ вЙ† 0 := by
    intro h
    have h1 : s/ѕБ = 1 := by linear_combination -h
    apply hs
    field_simp at h1
    exact h1
  have h_exp_ne : Complex.exp (s/ѕБ) вЙ† 0 := Complex.exp_ne_zero _
  have h_deriv_inner : deriv (fun y : вДВ => y/ѕБ) s = 1/ѕБ := by
    rw [deriv_div_const, deriv_id'']
  have h_deriv_left : deriv (fun y : вДВ => 1 - y/ѕБ) s = -(1/ѕБ) := by
    rw [deriv_sub (differentiableAt_const _) (differentiableAt_id'.div_const _),
        deriv_const, h_deriv_inner]
    ring
  have h_deriv_right : deriv (fun y : вДВ => Complex.exp (y/ѕБ)) s
      = Complex.exp (s/ѕБ) * (1/ѕБ) := by
    rw [deriv_cexp h_inner_diff, h_deriv_inner]
  have hѕБs : ѕБ - s вЙ† 0 := sub_ne_zero.mpr (Ne.symm hs)
  rw [logDeriv_apply]
  unfold hadamardGenus1Factor
  rw [deriv_mul h_left_diff h_right_diff, h_deriv_left, h_deriv_right]
  -- Factor `Complex.exp (s/ѕБ)` out of numerator and cancel with denominator
  rw [show -(1 / ѕБ) * Complex.exp (s / ѕБ)
            + (1 - s / ѕБ) * (Complex.exp (s / ѕБ) * (1 / ѕБ))
          = Complex.exp (s / ѕБ) * (-(1 / ѕБ) + (1 - s / ѕБ) * (1 / ѕБ)) from by ring,
      show (1 - s / ѕБ) * Complex.exp (s / ѕБ)
          = Complex.exp (s / ѕБ) * (1 - s / ѕБ) from by ring,
      mul_div_mul_left _ _ h_exp_ne]
  -- Now: (-(1/ѕБ) + (1 - s/ѕБ) * (1/ѕБ)) / (1 - s/ѕБ) = 1/(s-ѕБ) + 1/ѕБ
  -- Simplify numerator to -s/ѕБ¬≤
  rw [show -(1 / ѕБ) + (1 - s / ѕБ) * (1 / ѕБ) = -s / ѕБ ^ 2 from by
        field_simp; ring]
  -- Now: (-s/ѕБ¬≤) / (1 - s/ѕБ) = 1/(s-ѕБ) + 1/ѕБ
  rw [show (1 : вДВ) - s / ѕБ = (ѕБ - s) / ѕБ from by field_simp]
  -- Now: (-s/ѕБ¬≤) / ((ѕБ - s)/ѕБ) = 1/(s-ѕБ) + 1/ѕБ
  field_simp
  ring

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ per-factor `logDerivativeResponse` of the genus-1
Hadamard factor.** Same identity under the definitional bridge. -/
theorem logDerivativeResponse_hadamardGenus1Factor
    {ѕБ s : вДВ} (hѕБ : ѕБ вЙ† 0) (hs : s вЙ† ѕБ) :
    logDerivativeResponse (hadamardGenus1Factor ѕБ) s = 1 / (s - ѕБ) + 1 / ѕБ := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_hadamardGenus1Factor hѕБ hs

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ regularized form of the finite Hadamard product
log-derivative.** `logDeriv (finiteHadamardProduct zeros) s =
ќ£_{ѕБ вИИ zeros} (1/(s-ѕБ) + 1/ѕБ)`. The classical paired/regularized zero
sum. -/
theorem logDeriv_finiteHadamardProduct_regularized
    {zeros : Finset вДВ} {s : вДВ}
    (hѕБ_ne : вИА ѕБ вИИ zeros, ѕБ вЙ† 0)
    (hs_ne : вИА ѕБ вИИ zeros, s вЙ† ѕБ) :
    logDeriv (finiteHadamardProduct zeros) s
      = вИС ѕБ вИИ zeros, (1 / (s - ѕБ) + 1 / ѕБ) := by
  rw [logDeriv_finiteHadamardProduct hѕБ_ne hs_ne]
  apply Finset.sum_congr rfl
  intro ѕБ hѕБmem
  exact logDeriv_hadamardGenus1Factor (hѕБ_ne ѕБ hѕБmem) (hs_ne ѕБ hѕБmem)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ regularized form of the finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_finiteHadamardProduct_regularized
    {zeros : Finset вДВ} {s : вДВ}
    (hѕБ_ne : вИА ѕБ вИИ zeros, ѕБ вЙ† 0)
    (hs_ne : вИА ѕБ вИИ zeros, s вЙ† ѕБ) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = вИС ѕБ вИИ zeros, (1 / (s - ѕБ) + 1 / ѕБ) := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct_regularized hѕБ_ne hs_ne

-- =====================================================================
-- ¬ІCCCXXIII. Mathlib infinite-product / series API audit
-- =====================================================================
-- Located in `Mathlib/Topology/Algebra/InfiniteSum/Defs.lean`:
--   * `HasProd f a := Tendsto (вИП b вИИ s, f b) atTop (рЭУЭ a)` (Finset net).
--   * `Multipliable f := вИГ a, HasProd f a`.
--   * `tprod f`, notation `вИП' i, f i` (irreducible_def, falls back to 1).
--   * Additive analogues via `@[to_additive]`: `HasSum`, `Summable`, `tsum`,
--     `вИС' i, f i`.
--
-- For locally uniform convergence (needed for product = entire function):
--   `Mathlib/Topology/Algebra/InfiniteSum/UniformOn.lean`:
--     * `HasProdLocallyUniformlyOn`, `MultipliableLocallyUniformlyOn`.
--   `Mathlib/Analysis/NormedSpace/MultipliableUniformlyOn.lean`:
--     * normed-space adapted lemmas.
--
-- These are the right APIs for the infinite Hadamard product. Use
-- `HasProd` / `tprod` for the product value; `HasSum` / `tsum` for the
-- regularized log-derivative series.

-- =====================================================================
-- ¬ІCCCXXIV. Infinite Hadamard product + regularized log-deriv series
-- =====================================================================
-- Lifts the finite Hadamard products to the indexed/infinite setting.
-- Introduces the named target series so the analytic agent can prove
-- the convergence/equality statements directly.

/-- **Indexed infinite Hadamard product** over an arbitrary index set
of zero ordinates. Falls back to `1` when not multipliable (Mathlib's
`tprod` convention). -/
noncomputable def infiniteHadamardProduct
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) (s : вДВ) : вДВ :=
  вИП' i : ќє, hadamardGenus1Factor (zeroLoc i) s

/-- **Indexed regularized log-derivative series**: the term-wise sum
`ќ£ (1/(s-ѕБбµҐ) + 1/ѕБбµҐ)` that the infinite Hadamard log-derivative should
converge to. Falls back to `0` when not summable. -/
noncomputable def hadamardRegularizedLogDerivSeries
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) (s : вДВ) : вДВ :=
  вИС' i : ќє, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Finite regularized log-derivative sum** over a Finset. -/
noncomputable def finiteHadamardRegularizedSum
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) (F : Finset ќє) (s : вДВ) : вДВ :=
  вИС i вИИ F, (1 / (s - zeroLoc i) + 1 / zeroLoc i)

/-- **Indexed finite Hadamard product**: the partial product over a
Finset, used for finite truncations of `infiniteHadamardProduct`. -/
noncomputable def indexedFiniteHadamardProduct
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) (F : Finset ќє) (s : вДВ) : вДВ :=
  вИП i вИИ F, hadamardGenus1Factor (zeroLoc i) s

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ indexed finite Hadamard product log-derivative.**
The log-derivative of the indexed finite product equals the
indexed regularized sum. -/
theorem logDeriv_indexedFiniteHadamardProduct
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {F : Finset ќє} {s : вДВ}
    (hѕБ : вИА i вИИ F, zeroLoc i вЙ† 0)
    (hs : вИА i вИИ F, s вЙ† zeroLoc i) :
    logDeriv (fun s' : вДВ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  unfold indexedFiniteHadamardProduct finiteHadamardRegularizedSum
  rw [logDeriv_prod F (fun i s' => hadamardGenus1Factor (zeroLoc i) s') s
        (fun i hi => hadamardGenus1Factor_ne_zero (hѕБ i hi) (hs i hi))
        (fun i _ => hadamardGenus1Factor_differentiableAt (zeroLoc i) s)]
  apply Finset.sum_congr rfl
  intro i hi
  exact logDeriv_hadamardGenus1Factor (hѕБ i hi) (hs i hi)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ indexed finite Hadamard product
`logDerivativeResponse`.** -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {F : Finset ќє} {s : вДВ}
    (hѕБ : вИА i вИИ F, zeroLoc i вЙ† 0)
    (hs : вИА i вИИ F, s вЙ† zeroLoc i) :
    logDerivativeResponse
        (fun s' : вДВ => indexedFiniteHadamardProduct zeroLoc F s') s
      = finiteHadamardRegularizedSum zeroLoc F s := by
  rw [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_indexedFiniteHadamardProduct hѕБ hs

-- =====================================================================
-- ¬ІCCCXXV. Locally-uniform Hadamard product analytic data
-- =====================================================================
-- The data structure that says: "this genus-1 infinite product is
-- analytically legitimate on the points where ќЊ is non-zero, and its
-- log-derivative equals the regularized zero-sum series."
--
-- The Mathlib `MultipliableLocallyUniformlyOn` Prop is the natural
-- analytic-agent target for inhabiting `product_differentiable_at_xi_nonzero`
-- and `logDeriv_eq_tsum_at_xi_nonzero`; we expose those AFZ-projected
-- consequences directly rather than threading the universe-quantified
-- LUC predicate through the bundle.

/-- рЯУ¶ **`HadamardLocallyUniformProductData`** вАФ the analytic
legitimacy package for the infinite genus-1 Hadamard product. -/
structure HadamardLocallyUniformProductData
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) : Type where
  product_multipliable :
    вИА s : вДВ,
      Multipliable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s
  product_differentiable_at_xi_nonzero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      DifferentiableAt вДВ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at_xi_nonzero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      Summable fun i : ќє => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at_xi_nonzero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

-- =====================================================================
-- ¬ІCCCXXVI. Hadamard product with zeros + bridge to ќЊ-side AFZ source
-- =====================================================================

/-- рЯУ¶ **`CompletedXiHadamardProductWithZeros`** вАФ the classical
Hadamard product representation of `completedXiFunction` with a
possible analytic prefactor. Parameterized by the zero index type `ќє`. -/
structure CompletedXiHadamardProductWithZeros (ќє : Type) : Type where
  zeroLoc : ќє вЖТ вДВ
  prefactor : вДВ вЖТ вДВ
  prefactor_differentiable_at :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      DifferentiableAt вДВ prefactor s
  prefactor_ne_zero :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      prefactor s вЙ† 0
  xi_eq_product :
    вИА s : вДВ,
      completedXiFunction s
        = prefactor s * infiniteHadamardProduct zeroLoc s
  product_data : HadamardLocallyUniformProductData zeroLoc

/-- **Zero contribution from a Hadamard-with-zeros bundle**:
`logDeriv prefactor + tsum regularized`. -/
noncomputable def xiZeroContributionFromHadamard
    {ќє : Type} (H : CompletedXiHadamardProductWithZeros ќє) : вДВ вЖТ вДВ :=
  fun s =>
    logDerivativeResponse H.prefactor s
      + hadamardRegularizedLogDerivSeries H.zeroLoc s

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `CompletedXiLogDerivativeSourceAFZ` from
Hadamard-with-zeros bundle.** Uses `logDeriv_mul` (Mathlib) to split
the log-derivative of `prefactor ¬Ј product`, then identifies the
product's log-derivative with the regularized series via
`product_data.logDeriv_eq_tsum_at_xi_nonzero`. -/
noncomputable def CompletedXiLogDerivativeSourceAFZ_of_hadamardProductWithZeros
    {ќє : Type} (H : CompletedXiHadamardProductWithZeros ќє) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := xiZeroContributionFromHadamard H
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  ¬Ј intro s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    rw [hxi_eq_fun]
    exact (H.prefactor_differentiable_at s hs).mul
      (H.product_data.product_differentiable_at_xi_nonzero s hs)
  ¬Ј intro s hs
    have h_pref_ne : H.prefactor s вЙ† 0 := H.prefactor_ne_zero s hs
    have h_prod_ne : infiniteHadamardProduct H.zeroLoc s вЙ† 0 := by
      intro h
      apply hs
      rw [H.xi_eq_product s, h, mul_zero]
    have h_pref_diff := H.prefactor_differentiable_at s hs
    have h_prod_diff := H.product_data.product_differentiable_at_xi_nonzero s hs
    have hxi_eq_fun :
        completedXiFunction
          = H.prefactor * (infiniteHadamardProduct H.zeroLoc) := by
      funext s'
      simpa [Pi.mul_apply] using H.xi_eq_product s'
    calc logDerivativeResponse completedXiFunction s
        = logDeriv completedXiFunction s := rfl
      _ = logDeriv (H.prefactor * infiniteHadamardProduct H.zeroLoc) s := by
          rw [hxi_eq_fun]
      _ = logDeriv H.prefactor s
            + logDeriv (infiniteHadamardProduct H.zeroLoc) s :=
          logDeriv_mul s h_pref_ne h_prod_ne h_pref_diff h_prod_diff
      _ = logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroLoc s := by
          rw [вЖР logDerivativeResponse_eq_logDeriv (f := H.prefactor),
              вЖР logDerivativeResponse_eq_logDeriv
                  (f := infiniteHadamardProduct H.zeroLoc),
              H.product_data.logDeriv_eq_tsum_at_xi_nonzero s hs]
      _ = xiZeroContributionFromHadamard H s := rfl

-- =====================================================================
-- ¬ІCCCXXVII. Log-derivative limit data (separate from convergence)
-- =====================================================================
-- The product-convergence content (`Multipliable`) is independent of
-- the log-derivative content (differentiability + summability + log-deriv
-- equal to tsum). Isolate the latter into its own data bundle, keyed by
-- an arbitrary `region : Set вДВ`. The bridge to
-- `HadamardLocallyUniformProductData` then takes a region-coverage
-- hypothesis (AFZ вКЖ region).

/-- рЯУ¶ **`HadamardLogDerivLimitData`** вАФ the log-derivative-of-limit
content, packaged on an arbitrary `region : Set вДВ`. The genuine
analytic theorem (log-deriv interchanges with locally uniform
convergence) inhabits this bundle on the AFZ region of `ќЊ`. -/
structure HadamardLogDerivLimitData
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) : Type where
  region : Set вДВ
  product_differentiable_at :
    вИА s вИИ region,
      DifferentiableAt вДВ (infiniteHadamardProduct zeroLoc) s
  regularized_summable_at :
    вИА s вИИ region,
      Summable fun i : ќє => 1 / (s - zeroLoc i) + 1 / zeroLoc i
  logDeriv_eq_tsum_at :
    вИА s вИИ region,
      logDerivativeResponse (infiniteHadamardProduct zeroLoc) s
        = hadamardRegularizedLogDerivSeries zeroLoc s

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `HadamardLocallyUniformProductData` from
log-derivative limit data + region coverage.** -/
noncomputable def HadamardLocallyUniformProductData.of_logDerivLimitData
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ}
    (Hprod :
      вИА s : вДВ,
        Multipliable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s)
    (Hlim : HadamardLogDerivLimitData zeroLoc)
    (h_region :
      вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ s вИИ Hlim.region) :
    HadamardLocallyUniformProductData zeroLoc :=
  { product_multipliable := Hprod
    product_differentiable_at_xi_nonzero := fun s hs =>
      Hlim.product_differentiable_at s (h_region s hs)
    regularized_summable_at_xi_nonzero := fun s hs =>
      Hlim.regularized_summable_at s (h_region s hs)
    logDeriv_eq_tsum_at_xi_nonzero := fun s hs =>
      Hlim.logDeriv_eq_tsum_at s (h_region s hs) }

-- =====================================================================
-- ¬ІCCCXXVIII. Finite exhaustion interface
-- =====================================================================
-- The natural finite-to-infinite convergence interface: a sequence of
-- Finsets that exhausts the index type, with the partial products
-- converging to the infinite product and the partial regularized sums
-- converging to the regularized series.

/-- рЯУ¶ **`HadamardFiniteExhaustion`** вАФ finite-truncation convergence
interface for the genus-1 Hadamard product. -/
structure HadamardFiniteExhaustion
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) where
  exhaust : вДХ вЖТ Finset ќє
  exhaust_mono :
    вИА {n m : вДХ}, n вЙ§ m вЖТ exhaust n вКЖ exhaust m
  product_tendsto :
    вИА s : вДВ,
      Tendsto
        (fun n => indexedFiniteHadamardProduct zeroLoc (exhaust n) s)
        Filter.atTop
        (рЭУЭ (infiniteHadamardProduct zeroLoc s))
  regularized_sum_tendsto :
    вИА s : вДВ,
      Tendsto
        (fun n => finiteHadamardRegularizedSum zeroLoc (exhaust n) s)
        Filter.atTop
        (рЭУЭ (hadamardRegularizedLogDerivSeries zeroLoc s))

/-- в≠Р **PROVED вАФ finite-truncation log-derivative identity at every
exhaustion stage.** Direct specialization of ¬ІCCCXXIV's
`logDerivativeResponse_indexedFiniteHadamardProduct`. -/
theorem logDerivativeResponse_indexedFiniteHadamardProduct_at_exhaustion
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ}
    (Hex : HadamardFiniteExhaustion zeroLoc)
    {s : вДВ} {n : вДХ}
    (hѕБ : вИА i вИИ Hex.exhaust n, zeroLoc i вЙ† 0)
    (hs : вИА i вИИ Hex.exhaust n, s вЙ† zeroLoc i) :
    logDerivativeResponse
        (fun s' : вДВ => indexedFiniteHadamardProduct zeroLoc (Hex.exhaust n) s') s
      = finiteHadamardRegularizedSum zeroLoc (Hex.exhaust n) s :=
  logDerivativeResponse_indexedFiniteHadamardProduct hѕБ hs

-- =====================================================================
-- ¬ІCCCXXIX. Regularized Hadamard term вАФ algebraic identity + norm
-- =====================================================================

/-- в≠Р **PROVED вАФ paired/regularized identity.** The combined term
collapses to `s / ((s - ѕБ) ¬Ј ѕБ)`. -/
lemma hadamard_regularized_term_eq {s ѕБ : вДВ} (hѕБ : ѕБ вЙ† 0) (hsѕБ : s вЙ† ѕБ) :
    1 / (s - ѕБ) + 1 / ѕБ = s / ((s - ѕБ) * ѕБ) := by
  have hsѕБ' : s - ѕБ вЙ† 0 := sub_ne_zero.mpr hsѕБ
  field_simp

/-- в≠Р **PROVED вАФ norm form of the regularized identity.** -/
lemma norm_hadamard_regularized_term_eq
    {s ѕБ : вДВ} (hѕБ : ѕБ вЙ† 0) (hsѕБ : s вЙ† ѕБ) :
    вАЦ1 / (s - ѕБ) + 1 / ѕБвАЦ = вАЦsвАЦ / (вАЦs - ѕБвАЦ * вАЦѕБвАЦ) := by
  rw [hadamard_regularized_term_eq hѕБ hsѕБ, norm_div, norm_mul]

-- =====================================================================
-- ¬ІCCCXXX. Large-zero bound for the regularized term
-- =====================================================================

/-- в≠Р **PROVED вАФ reverse-triangle large-zero bound.** When
`2 вАЦsвАЦ вЙ§ вАЦѕБвАЦ`, we have `вАЦs вИТ ѕБвАЦ вЙ• вАЦѕБвАЦ/2`. -/
lemma norm_sub_ge_half_of_two_norm_le {s ѕБ : вДВ}
    (hlarge : 2 * вАЦsвАЦ вЙ§ вАЦѕБвАЦ) :
    вАЦѕБвАЦ / 2 вЙ§ вАЦs - ѕБвАЦ := by
  have htriangle : вАЦѕБвАЦ вЙ§ вАЦsвАЦ + вАЦs - ѕБвАЦ := by
    have h_sub := norm_sub_le s (s - ѕБ)
    have h_eq : s - (s - ѕБ) = ѕБ := by ring
    rw [h_eq] at h_sub
    exact h_sub
  linarith

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ large-zero bound on the regularized Hadamard
term.** `вАЦ1/(sвИТѕБ) + 1/ѕБвАЦ вЙ§ 2 вАЦsвАЦ / вАЦѕБвАЦ¬≤` for `вАЦѕБвАЦ вЙ• 2 вАЦsвАЦ`. -/
lemma norm_hadamard_regularized_term_le_large {s ѕБ : вДВ}
    (hѕБ : ѕБ вЙ† 0) (hsѕБ : s вЙ† ѕБ) (hlarge : 2 * вАЦsвАЦ вЙ§ вАЦѕБвАЦ) :
    вАЦ1 / (s - ѕБ) + 1 / ѕБвАЦ вЙ§ 2 * вАЦsвАЦ / вАЦѕБвАЦ ^ 2 := by
  rw [norm_hadamard_regularized_term_eq hѕБ hsѕБ]
  have hѕБ_pos : 0 < вАЦѕБвАЦ := norm_pos_iff.mpr hѕБ
  have h_sѕБ_pos : 0 < вАЦs - ѕБвАЦ := norm_pos_iff.mpr (sub_ne_zero.mpr hsѕБ)
  have h_denom_pos : 0 < вАЦs - ѕБвАЦ * вАЦѕБвАЦ := mul_pos h_sѕБ_pos hѕБ_pos
  have h_ѕБ_sq_pos : 0 < вАЦѕБвАЦ ^ 2 := by positivity
  have h_sѕБ_ge : вАЦѕБвАЦ / 2 вЙ§ вАЦs - ѕБвАЦ := norm_sub_ge_half_of_two_norm_le hlarge
  have h_s_nn : 0 вЙ§ вАЦsвАЦ := norm_nonneg _
  rw [div_le_div_iffвВА h_denom_pos h_ѕБ_sq_pos]
  have h_ѕБ_le : вАЦѕБвАЦ вЙ§ 2 * вАЦs - ѕБвАЦ := by linarith
  have h_mul : вАЦѕБвАЦ * вАЦѕБвАЦ вЙ§ 2 * вАЦs - ѕБвАЦ * вАЦѕБвАЦ :=
    mul_le_mul_of_nonneg_right h_ѕБ_le hѕБ_pos.le
  have h_ѕБ_sq : вАЦѕБвАЦ ^ 2 = вАЦѕБвАЦ * вАЦѕБвАЦ := by ring
  nlinarith [h_mul, h_s_nn, h_ѕБ_sq]

-- =====================================================================
-- ¬ІCCCXXXI. Summability of regularized terms via inv-sq summability
-- =====================================================================

/-- рЯУ¶ **`HadamardZeroInvSqSummability`** вАФ the classical analytic
hypothesis on a zero set: `ќ£ 1/вАЦѕБвАЦ¬≤ < вИЮ` (genus вЙ§ 1) and for every
`s`, eventually `вАЦѕБвАЦ вЙ• 2вАЦsвАЦ`. -/
structure HadamardZeroInvSqSummability
    {ќє : Type*} (zeroLoc : ќє вЖТ вДВ) : Prop where
  zero_ne : вИА i, zeroLoc i вЙ† 0
  inv_sq_summable :
    Summable fun i : ќє => (вАЦzeroLoc iвАЦ ^ 2)вБї¬є
  eventually_large :
    вИА s : вДВ, вИАбґ† i in Filter.cofinite, 2 * вАЦsвАЦ вЙ§ вАЦzeroLoc iвАЦ

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ regularized series is summable from inv-sq
summability + eventually-large.** -/
theorem summable_hadamard_regularized_terms_of_inv_sq
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {s : вДВ}
    (hzero_ne : вИА i, zeroLoc i вЙ† 0)
    (hs_ne : вИА i, s вЙ† zeroLoc i)
    (hinv_sq : Summable fun i : ќє => (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
    (heventual_large :
      вИАбґ† i in Filter.cofinite, 2 * вАЦsвАЦ вЙ§ вАЦzeroLoc iвАЦ) :
    Summable fun i : ќє => 1 / (s - zeroLoc i) + 1 / zeroLoc i := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 2 * вАЦsвАЦ * (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
  ¬Ј exact hinv_sq.mul_left (2 * вАЦsвАЦ)
  ¬Ј filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_hadamard_regularized_term_le_large (hzero_ne i) (hs_ne i) hi
    have h_eq :
        (2 : вДЭ) * вАЦsвАЦ / вАЦzeroLoc iвАЦ ^ 2
          = 2 * вАЦsвАЦ * (вАЦzeroLoc iвАЦ ^ 2)вБї¬є := by
      rw [div_eq_mul_inv]
    linarith [h_eq вЦЄ h_bound]

/-- в≠Р **PROVED вАФ regularized summability from the data bundle
`HadamardZeroInvSqSummability`.** -/
theorem HadamardZeroInvSqSummability.summable_regularized
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    {s : вДВ} (hs_ne : вИА i, s вЙ† zeroLoc i) :
    Summable fun i : ќє => 1 / (s - zeroLoc i) + 1 / zeroLoc i :=
  summable_hadamard_regularized_terms_of_inv_sq
    H.zero_ne hs_ne H.inv_sq_summable (H.eventually_large s)

-- =====================================================================
-- ¬ІCCCXXXII. Genus-one Taylor bound (data + specialization)
-- =====================================================================

/-- рЯУ¶ **`GenusOneTaylorBoundData`** вАФ quantitative form of
`1 - (1-w)¬Јexp(w) = O(w¬≤)`. Standard genus-one decay; `C = 4` is
unsharp but suffices for convergence. -/
structure GenusOneTaylorBoundData : Prop where
  bound :
    вИА w : вДВ, вАЦwвАЦ вЙ§ 1 вЖТ
      вАЦ1 - (1 - w) * Complex.exp wвАЦ вЙ§ 4 * вАЦwвАЦ ^ 2

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ specialization to `hadamardGenus1Factor` with
`вАЦsвАЦ вЙ§ вАЦѕБвАЦ`.** -/
lemma norm_one_sub_hadamardGenus1Factor_le_large
    {ѕБ s : вДВ} (hѕБ : ѕБ вЙ† 0) (hlarge : вАЦsвАЦ вЙ§ вАЦѕБвАЦ)
    (Hbound : GenusOneTaylorBoundData) :
    вАЦ1 - hadamardGenus1Factor ѕБ sвАЦ вЙ§ 4 * (вАЦsвАЦ ^ 2 / вАЦѕБвАЦ ^ 2) := by
  unfold hadamardGenus1Factor
  have hѕБ_pos : 0 < вАЦѕБвАЦ := norm_pos_iff.mpr hѕБ
  have hw : вАЦs / ѕБвАЦ вЙ§ 1 := by
    rw [norm_div]
    exact div_le_one_of_leвВА hlarge (norm_nonneg _)
  have h := Hbound.bound (s / ѕБ) hw
  rw [norm_div, div_pow] at h
  exact h

-- =====================================================================
-- ¬ІCCCXXXIII. Product convergence from inverse-square zero summability
-- =====================================================================

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ norm-summability of `1 - EвВБ(s/ѕБбµҐ)`.** -/
theorem summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {s : вДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : вИА i, zeroLoc i вЙ† 0)
    (hinv_sq : Summable fun i : ќє => (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
    (heventual_large :
      вИАбґ† i in Filter.cofinite, вАЦsвАЦ вЙ§ вАЦzeroLoc iвАЦ) :
    Summable fun i : ќє => вАЦ1 - hadamardGenus1Factor (zeroLoc i) sвАЦ := by
  apply Summable.of_norm_bounded_eventually
    (g := fun i => 4 * вАЦsвАЦ ^ 2 * (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
  ¬Ј exact hinv_sq.mul_left (4 * вАЦsвАЦ ^ 2)
  ¬Ј filter_upwards [heventual_large] with i hi
    have h_bound :=
      norm_one_sub_hadamardGenus1Factor_le_large (hzero_ne i) hi Hbound
    have h_eq : (4 : вДЭ) * вАЦsвАЦ ^ 2 * (вАЦzeroLoc iвАЦ ^ 2)вБї¬є
              = 4 * (вАЦsвАЦ ^ 2 / вАЦzeroLoc iвАЦ ^ 2) := by
      rw [div_eq_mul_inv]; ring
    rw [Real.norm_of_nonneg (norm_nonneg _)]
    linarith [h_eq вЦЄ h_bound]

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ вДВ-valued `Summable (1 - EвВБ(s/ѕБбµҐ))` from norm.** -/
theorem summable_one_sub_hadamardGenus1Factor_of_inv_sq
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {s : вДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : вИА i, zeroLoc i вЙ† 0)
    (hinv_sq : Summable fun i : ќє => (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
    (heventual_large :
      вИАбґ† i in Filter.cofinite, вАЦsвАЦ вЙ§ вАЦzeroLoc iвАЦ) :
    Summable fun i : ќє => 1 - hadamardGenus1Factor (zeroLoc i) s :=
  Summable.of_norm
    (summable_norm_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `Multipliable (hadamardGenus1Factor вИШ zeroLoc)`
from inverse-square zero summability + Taylor bound.** Uses Mathlib's
`Complex.multipliable_one_add_of_summable`. -/
theorem multipliable_hadamardGenus1Factor_of_inv_sq
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ} {s : вДВ}
    (Hbound : GenusOneTaylorBoundData)
    (hzero_ne : вИА i, zeroLoc i вЙ† 0)
    (hinv_sq : Summable fun i : ќє => (вАЦzeroLoc iвАЦ ^ 2)вБї¬є)
    (heventual_large :
      вИАбґ† i in Filter.cofinite, вАЦsвАЦ вЙ§ вАЦzeroLoc iвАЦ) :
    Multipliable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s := by
  have h_sum :=
    summable_one_sub_hadamardGenus1Factor_of_inv_sq
      Hbound hzero_ne hinv_sq heventual_large
  have h_sum_neg :
      Summable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s - 1 := by
    have := h_sum.neg
    simpa [neg_sub] using this
  have h_mul := Complex.multipliable_one_add_of_summable h_sum_neg
  simpa using h_mul

/-- в≠Р **PROVED вАФ `Multipliable` from the `HadamardZeroInvSqSummability`
bundle + Taylor bound.** -/
theorem HadamardZeroInvSqSummability.multipliable_genus1
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ}
    (H : HadamardZeroInvSqSummability zeroLoc)
    (Hbound : GenusOneTaylorBoundData) (s : вДВ) :
    Multipliable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s := by
  apply multipliable_hadamardGenus1Factor_of_inv_sq
    Hbound H.zero_ne H.inv_sq_summable
  filter_upwards [H.eventually_large s] with i hi
  have h_s_nn : 0 вЙ§ вАЦsвАЦ := norm_nonneg s
  linarith

-- =====================================================================
-- ¬ІCCCXXXIV. Prove `GenusOneTaylorBoundData`
-- =====================================================================
-- Inhabits the genus-one Taylor bound via Mathlib's
-- `Complex.norm_exp_sub_one_le` and `Complex.norm_exp_sub_one_sub_id_le`.
-- Decomposition:
--   `1 - (1-w)¬Јexp(w) = -(exp(w) - 1 - w) + w¬Ј(exp(w) - 1)`
-- Triangle inequality + the two Mathlib bounds give `вАЦ¬ЈвАЦ вЙ§ 3¬ЈвАЦwвАЦ¬≤`,
-- which dominates `4¬ЈвАЦwвАЦ¬≤` for free.

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `GenusOneTaylorBoundData` inhabited.** -/
theorem genusOneTaylorBoundData : GenusOneTaylorBoundData := by
  refine вЯ®?_вЯ©
  intro w hw
  have h_decomp :
      (1 : вДВ) - (1 - w) * Complex.exp w
        = -(Complex.exp w - 1 - w) + w * (Complex.exp w - 1) := by
    ring
  rw [h_decomp]
  have h_exp_sub_1_sub_id := Complex.norm_exp_sub_one_sub_id_le hw
  have h_exp_sub_1 := Complex.norm_exp_sub_one_le hw
  have h_w_nn : 0 вЙ§ вАЦwвАЦ := norm_nonneg _
  calc вАЦ-(Complex.exp w - 1 - w) + w * (Complex.exp w - 1)вАЦ
      вЙ§ вАЦ-(Complex.exp w - 1 - w)вАЦ + вАЦw * (Complex.exp w - 1)вАЦ :=
        norm_add_le _ _
    _ = вАЦComplex.exp w - 1 - wвАЦ + вАЦwвАЦ * вАЦComplex.exp w - 1вАЦ := by
        rw [norm_neg, norm_mul]
    _ вЙ§ вАЦwвАЦ ^ 2 + вАЦwвАЦ * (2 * вАЦwвАЦ) := by
        gcongr
    _ = 3 * вАЦwвАЦ ^ 2 := by ring
    _ вЙ§ 4 * вАЦwвАЦ ^ 2 := by nlinarith [sq_nonneg вАЦwвАЦ]

-- =====================================================================
-- ¬ІCCCXXXV. Hypothesis-free product-convergence convenience
-- =====================================================================

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `Multipliable (hadamardGenus1Factor вИШ zeroLoc)`
from `HadamardZeroInvSqSummability` alone** (no Taylor hypothesis). -/
theorem HadamardZeroInvSqSummability.product_multipliable
    {ќє : Type*} {zeroLoc : ќє вЖТ вДВ}
    (H : HadamardZeroInvSqSummability zeroLoc) :
    вИА s : вДВ,
      Multipliable fun i : ќє => hadamardGenus1Factor (zeroLoc i) s :=
  fun s => H.multipliable_genus1 genusOneTaylorBoundData s

