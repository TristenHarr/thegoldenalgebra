  intro s hs
  rcases hs with Ôƒ¿h1, _h2, h3, h4Ôƒ®
  rw [Metric.mem_closedBall, dist_zero_right]
  have hTle : s.im Ôëñ max 0 T := le_max_of_le_right h4
