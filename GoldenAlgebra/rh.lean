+ Hlow  : XiLowResidualFiniteIBPDomination       (finite low IBP)
+ h_Z_ge_15
⟹ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Htail :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi)
    (Hlow :
      XiLowResidualFiniteIBPDomination
        Dzero 10 honestZeroDensityModelTwoPi) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_xiStieltjesFormula
    Dzero h_Z_ge_15 hTuring hHighLog
    (XiResidualStieltjesFormulaData_of_logDerivativeModelTailDecomposition
      Htail Hlow)

-- =====================================================================
-- §CCXCVIII. Low finite IBP — equality vs domination + A/B split
-- =====================================================================
-- `Hlow : XiLowResidualFiniteIBPDomination` says `|Im(residual)| ≤
-- |boundary| + |deriv side|`. The cleaner analytic target is the
-- equality `Im(residual) = boundary + deriv side`, from which the
-- domination follows by `abs_add`. The equality further splits into:
--   A. residual `Im` equals true-kernel finite integral `Im` on `[11, 14]`
--   B. the true-kernel finite integral `Im` equals boundary + deriv side
-- Piece A is the xi explicit-formula content for the bounded interval.
-- Piece B is finite IBP — uses existing `finiteFluctuationKernelPartial_true_ibp`.
--
-- This section names both A and B, the equality → domination bridge,
-- and the final front door consuming the equality form.

/-- 📦 **`XiLowResidualFiniteIBPEquality`** — equality form of the low
finite IBP target. Says `Im(residual) = boundary + deriv side` on
`lowCompactRegion`. Strictly stronger than `XiLowResidualFiniteIBPDomination`
(which gives only the absolute-value inequality). -/
structure XiLowResidualFiniteIBPEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_boundary_add_deriv :
    ∀ z : ℂ,
      lowCompactRegion z →
      (xiResidualError M z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14

/-- ⭐ **PROVED — equality ⟹ domination.** Direct via `abs_add`. -/
theorem XiLowResidualFiniteIBPDomination_of_equality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiLowResidualFiniteIBPEquality Dzero T0 M) :
    XiLowResidualFiniteIBPDomination Dzero T0 M := by
  refine ⟨?_⟩
  intro z hz
  rw [H.residual_im_eq_boundary_add_deriv z hz]
  exact abs_add _ _

/-- 📦 **`XiLowResidualFiniteIntegralEquality`** — piece A of the
equality split. Says `Im(residual) = Im(finite true-kernel integral
on [11, 14])`. This is the xi explicit-formula content; piece B
converts the integral into boundary + derivative side via IBP. -/
structure XiLowResidualFiniteIntegralEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_integral :
    ∀ z : ℂ,
      lowCompactRegion z →
      (xiResidualError M z).im
        = (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            11 14 z).im

/-- 📦 **`LowFiniteIntegralIBPEquality`** — piece B of the split.
Pure IBP identity: the finite true-kernel integral `Im` over `[11, 14]`
equals `boundary + deriv side`. Independent of `M` (the residual);
purely a Stieltjes-IBP identity for the kernel against the
fluctuation primitive. -/
structure LowFiniteIntegralIBPEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) : Prop where
  integral_im_eq_boundary_add_deriv :
    ∀ z : ℂ,
      lowCompactRegion z →
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          11 14 z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14

/-- ⭐ **PROVED — equality from A + B.** Composes the xi-side integral
identification (A) with the IBP integral-to-boundary identity (B). -/
theorem XiLowResidualFiniteIBPEquality_of_integralEquality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (HA : XiLowResidualFiniteIntegralEquality Dzero T0 M)
    (HB : LowFiniteIntegralIBPEquality Dzero T0) :
    XiLowResidualFiniteIBPEquality Dzero T0 M := by
  refine ⟨?_⟩
  intro z hz
  rw [HA.residual_im_eq_integral z hz, HB.integral_im_eq_boundary_add_deriv z hz]

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
FINAL FRONT DOOR (low equality form)**. Replaces the low domination
input with the cleaner equality form.

```
hTuring + hHighLog
+ Htail  : XiLogDerivativeModelTailDecomposition
+ HlowEq : XiLowResidualFiniteIBPEquality
+ h_Z_ge_15
⟹ XiPullbackAntiHerglotzTarget
```

Or further refined into A + B:
```
+ HlowA  : XiLowResidualFiniteIntegralEquality   (xi explicit formula on [11, 14])
+ HlowB  : LowFiniteIntegralIBPEquality           (pure IBP identity)
``` -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Htail :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi)
    (HlowEq :
      XiLowResidualFiniteIBPEquality
        Dzero 10 honestZeroDensityModelTwoPi) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition
    Dzero h_Z_ge_15 hTuring hHighLog Htail
    (XiLowResidualFiniteIBPDomination_of_equality HlowEq)

-- =====================================================================
-- §CCXCIX. Corrected low split + HlowB proof
-- =====================================================================
-- §CCXCVIII split `XiLowResidualFiniteIBPEquality` into:
--   A : residual.im = integral.im                   (xi-side)
--   B : integral.im = boundary + deriv side         (proposed pure-IBP)
--
-- **Critical audit finding (this section).** Piece B as stated is
-- provably FALSE in general. Kernel Im compatibility says
--   `Im (pairedCauchyComplexKernelTrue u (UHP x y)) = pairedCauchyImKernelDeriv x y u`
-- (pointwise, from `pairedCauchyComplexKernelTrue_imCompatible`), so
-- `(complexDensityTailPartial true-kernel S 11 14 z).im` is the
-- derivative-side integral on `[11, 14]` — there is no boundary term
-- from the IBP step alone. The boundary term must live on the
-- xi-side.
--
-- This section keeps §CCXCVIII's structures (they remain logically
-- well-formed, just under-inhabited) and adds the CORRECTED split:
--
--   B' : integral.im = derivative side              -- PROVED here
--   A' : residual.im = boundary + integral.im       -- xi-side w/ boundary
--   composition: A' + B' → XiLowResidualFiniteIBPEquality
--
-- Adds:
--   lowFiniteIntegralIm_eq_derivativeSide                       — PROVED (B')
--   XiLowResidualImEqBoundaryAddIntegralIm                      — corrected A'
--   XiLowResidualFiniteIBPEquality_of_correctedSplit            — composition
--   XiPullbackAntiHerglotzTarget_..._lowCorrectedSplit          — final front door

/-- 🌟🌟🌟 **PROVED — HlowB (corrected).** On the low compact region,
the Im of the true-kernel partial of the finite fluctuation primitive
over `[11, 14]` equals the derivative-side integral
`lowFirstZeroDerivativeSide`. No boundary term.

Chain:
1. integrability of true-kernel integrand on `[11, 14]` (via
   `finiteFluctuationPrimitive_trueKernel_intervalIntegrable`);
2. integrability of wrap-kernel integrand on `[11, 14]` (via
   `wrapKernel_intervalIntegrable_of_real_derivative_integrable`
   applied to the real integrand from
   `finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic`);
3. kernel Im compat transfers Im of true partial to Im of wrap
   partial (`complexDensityTailPartial_im_eq_of_kernelImCompatible`
   with `pairedCauchyComplexKernelTrue_imCompatible`);
4. wrap partial Im = real derivative-side partial
   (`complexDensityTailPartial_im_eq_derivativeSidePartial`);
5. `lowFirstZeroDerivativeSide_eq_partial` is `rfl`. -/
theorem lowFiniteIntegralIm_eq_derivativeSide
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    {z : ℂ} (hy : 0 < z.im) :
    (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        11 14 z).im
      = lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14 := by
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hT0_le_11 : T0 ≤ (11 : ℝ) := by linarith
  have h11_le_14 : (11 : ℝ) ≤ 14 := by norm_num
  have h_true_int :
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                    * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
        MeasureTheory.volume 11 14 := by
    rw [hzUHP]
    exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
      Dzero T0 11 14 z hT0_pos hT0_le_11 h11_le_14 (ne_of_gt hy)
  have hreal :
      IntervalIntegrable
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
                    * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume 11 14 :=
    finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic
      Dzero T0 11 14 z.re z.im hT0_pos hT0_le_11 h11_le_14 hy
  have h_deriv_int :
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                    * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
        MeasureTheory.volume 11 14 :=
    wrapKernel_intervalIntegrable_of_real_derivative_integrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14 hreal
  have h_im_eq :
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im
        =
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14 h_true_int h_deriv_int
  have h_deriv_eq :
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im
        =
      Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        z.re z.im 11 14 :=
    complexDensityTailPartial_im_eq_derivativeSidePartial
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14
  calc (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14 z).im
      = (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im := by rw [hzUHP]
    _ = (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im := h_im_eq
    _ = Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        z.re z.im 11 14 := h_deriv_eq
    _ = lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14 :=
        (lowFirstZeroDerivativeSide_eq_partial Dzero T0 z.re z.im 11 14).symm

/-- 📦 **`XiLowResidualImEqBoundaryAddIntegralIm` (corrected A').** The
xi-side residual decomposition that DOES include the boundary term:
`Im(residual) = boundary + Im(true-kernel partial on [11, 14])` on the
low compact region. This is the actual content of the xi explicit
formula on the bounded interval — the boundary `k(11)·S(T0, 11)` comes
from the residual decomposition itself, not from any IBP rearrangement
of the integral. -/
structure XiLowResidualImEqBoundaryAddIntegralIm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_boundary_add_integral :
    ∀ z : ℂ,
      lowCompactRegion z →
      (xiResidualError M z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- 🌟🌟🌟 **PROVED — bridge from corrected split to master
equality.** Combines A' (xi-side residual = boundary + integral) with
B' (the proved integral = derivative-side identity) to produce
`XiLowResidualFiniteIBPEquality`. -/
theorem XiLowResidualFiniteIBPEquality_of_correctedSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    {M : CloudDensityTailModelDecomposition}
    (HA : XiLowResidualImEqBoundaryAddIntegralIm Dzero T0 M) :
    XiLowResidualFiniteIBPEquality Dzero T0 M := by
  refine ⟨?_⟩
  intro z hz
  rw [HA.residual_im_eq_boundary_add_integral z hz,
      lowFiniteIntegralIm_eq_derivativeSide Dzero T0 hT0_pos hT0_le_10 hz.1]

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **PATH B
FINAL FRONT DOOR (corrected low split — A' only)**.

The low obligation is now reduced to the single xi-side input
`XiLowResidualImEqBoundaryAddIntegralIm` (the boundary-inclusive
residual decomposition on the bounded interval `[11, 14]`). B' is
absorbed into the proof.

```
hTuring + hHighLog
+ Htail : XiLogDerivativeModelTailDecomposition
+ HlowA : XiLowResidualImEqBoundaryAddIntegralIm     -- xi explicit formula on [11, 14]
+ h_Z_ge_15
⟹ XiPullbackAntiHerglotzTarget
```

This is the cleanest form of Path B: three explicit-formula identifications
(`decomp_high`, `decomp_mid`, `residual_im_eq_boundary_add_integral`),
each of the canonical shape, plus the trivial data-side gap. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowCorrectedSplit
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : ∀ i : ℕ, (15 : ℝ) ≤ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Htail :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi)
    (HlowA :
      XiLowResidualImEqBoundaryAddIntegralIm
        Dzero 10 honestZeroDensityModelTwoPi) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowEquality
    Dzero h_Z_ge_15 hTuring hHighLog Htail
    (XiLowResidualFiniteIBPEquality_of_correctedSplit
      (by norm_num : (0 : ℝ) < 10) (by norm_num : (10 : ℝ) ≤ 10) HlowA)

-- =====================================================================
-- §CCC. Master xi explicit-formula source — tail (high + mid)
-- =====================================================================
-- All remaining xi-side targets share one conceptual source:
--   Λ[Ξ](z) = honest model(z) + fluctuation contribution
-- where the fluctuation contribution is a tail Stieltjes integral
-- (mid/high) or a bounded boundary-plus-finite integral (low).
--
-- This section defines `XiModelTailExplicitFormula` — the master source
-- for high + mid — and exhibits the bridges to `decomp_high` and
-- `decomp_mid` of §CCXCVII's `XiLogDerivativeModelTailDecomposition`.

/-- 📦 **`XiFluctuationTailValue`** — names the tail-limit value `L` of
the true-kernel partials against the fluctuation primitive starting at
cutoff `T`. Used to avoid premature `Classical.choose` while still
referring to a specific limit. -/
structure XiFluctuationTailValue
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 T : ℝ)
    (z L : ℂ) : Prop where
  tendsto_tail :
    Tendsto
      (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (𝓝 L)

/-- 📦 **`XiModelTailExplicitFormula`** — master source for both `decomp_high`
and `decomp_mid`. Says for every `(z, T)` in the adaptive regime,
there is a tail-limit value `L` with `Λ[Ξ](z) = M.model z + L`. -/
structure XiModelTailExplicitFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  explicit_formula :
    ∀ {z : ℂ} {T : ℝ},
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        XiFluctuationTailValue Dzero T0 T z L ∧
        logDerivativeResponse XiPullback z = M.model z + L

/-- 🌟🌟 **PROVED — `decomp_high` bridge from `XiModelTailExplicitFormula`.**
Specializes the master formula to `T ≥ 140`. -/
theorem decomp_high_of_modelTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiModelTailExplicitFormula Dzero T0 M) :
    ∀ {z : ℂ} {T : ℝ},
      140 ≤ T →
      0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      ∃ L : ℂ,
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              T X z)
          Filter.atTop
          (𝓝 L) ∧
        logDerivativeResponse XiPullback z = M.model z + L := by
  intro z T _hT hy hregime
  obtain ⟨L, hL, hdecomp⟩ := H.explicit_formula hy hregime
  exact ⟨L, hL.tendsto_tail, hdecomp⟩

/-- 🌟🌟 **PROVED — `decomp_mid` bridge from `XiModelTailExplicitFormula`.**
Specializes the master formula to the canonical adaptive cutoff. -/
theorem decomp_mid_of_modelTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiModelTailExplicitFormula Dzero T0 M) :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
      ∃ L : ℂ,
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop
          (𝓝 L) ∧
        logDerivativeResponse XiPullback z = M.model z + L := by
  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  obtain ⟨L, hL, hdecomp⟩ := H.explicit_formula hy hc.2.2
  exact ⟨L, hL.tendsto_tail, hdecomp⟩

/-- 🌟🌟🌟 **PROVED — `XiLogDerivativeModelTailDecomposition` from
`XiModelTailExplicitFormula`.** Bundles high + mid into the §CCXCVII
master Prop. -/
theorem XiLogDerivativeModelTailDecomposition_of_modelTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiModelTailExplicitFormula Dzero T0 M) :
    XiLogDerivativeModelTailDecomposition Dzero T0 M :=
  { decomp_high := decomp_high_of_modelTailFormula H
    decomp_mid := decomp_mid_of_modelTailFormula H }

-- =====================================================================
-- §CCCI. Master xi explicit-formula source — low (bounded interval)
-- =====================================================================
-- The low-band analogue of `XiModelTailExplicitFormula`. The boundary
-- term is part of the source formula — this is the corrected A' shape
-- from §CCXCIX, given a clean source-theorem name.

/-- 📦 **`XiLowModelFiniteExplicitFormula`** — low-band master source.
Says on `lowCompactRegion z`:
  `Im(residual) = boundary_at_11 + Im(finite true-kernel integral on [11, 14])`
where `residual := Λ[Ξ] - M.model`. The boundary comes from the
xi-side residual decomposition itself; the integral is the
true-kernel finite Stieltjes integral on `[11, 14]`. -/
structure XiLowModelFiniteExplicitFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  low_formula :
    ∀ z : ℂ,
      lowCompactRegion z →
      (xiResidualError M z).im
