noncomputable def lowResidualEnvelope (z : ℂ) : ℝ :=
  |(xiResidualError honestZeroDensityModelTwoPi z).im|

/-- **Low model margin envelope** for the canonical model. -/
noncomputable def lowModelMarginEnvelope (z : ℂ) : ℝ :=
  -(honestZeroDensityModelTwoPi.model z).im

/-- **`LowCompactEnvelopeDominates`** — model-margin envelope
dominates residual envelope on the compact low region. -/
def LowCompactEnvelopeDominates : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowResidualEnvelope z ≤ lowModelMarginEnvelope z

/-- ⭐ **PROVED — `XiLowResidualMargin` from the envelope dominance Prop.**
The two envelopes unfold to the canonical residual / model margin
sides of `XiLowResidualMargin`. -/
theorem XiLowResidualMargin_of_envelopeDominates
    (H : LowCompactEnvelopeDominates) :
    XiLowResidualMargin honestZeroDensityModelTwoPi := by
  intro z hz
  exact H z hz

/-- ⭐ **PROVED — `|z.re| ≤ 4` on the low compact region.** -/
lemma lowCompactRegion_abs_re_le_four
    {z : ℂ} (hz : lowCompactRegion z) :
    |z.re| ≤ 4 := by
  rcases hz with ⟨hy, hbound⟩
  nlinarith [abs_nonneg z.re]

/-- ⭐ **PROVED — `z.im ≤ 4` on the low compact region.** -/
lemma lowCompactRegion_im_le_four
    {z : ℂ} (hz : lowCompactRegion z) :
    z.im ≤ 4 := by
  rcases hz with ⟨hy, hbound⟩
  nlinarith [abs_nonneg z.re]

/-- **Rectangular compact box** `|x| ≤ 4 ∧ 0 < y ∧ y ≤ 4`. -/
def lowCompactBox (x y : ℝ) : Prop :=
  |x| ≤ 4 ∧ 0 < y ∧ y ≤ 4

/-- ⭐ **PROVED — `lowCompactRegion z` projects to a compact box.** -/
lemma lowCompactBox_of_lowCompactRegion
    {z : ℂ} (hz : lowCompactRegion z) :
    lowCompactBox z.re z.im :=
  ⟨lowCompactRegion_abs_re_le_four hz, hz.1,
   lowCompactRegion_im_le_four hz⟩

/-- 📦 **`LowCompactNumericalCertificate`** — the final compact-box
numerical certificate for the low band. Says: for every `(x, y)` in
the rectangular box `|x| ≤ 4, 0 < y ≤ 4`, the residual envelope at
`upperHalfPoint x y` is dominated by the model-margin envelope. This
is the shape an interval-arithmetic / first-zero numerical proof
should produce. -/
def LowCompactNumericalCertificate : Prop :=
  ∀ x y : ℝ,
    lowCompactBox x y →
    lowResidualEnvelope (upperHalfPoint x y)
      ≤ lowModelMarginEnvelope (upperHalfPoint x y)

/-- 🌟 **PROVED — envelope dominance from the numerical certificate.**
Routes through `lowCompactBox_of_lowCompactRegion` and
`upperHalfPoint_re_im` to apply the certificate at each `z`. -/
theorem LowCompactEnvelopeDominates_of_numericalCertificate
    (H : LowCompactNumericalCertificate) :
    LowCompactEnvelopeDominates := by
  intro z hz
  have hbox := lowCompactBox_of_lowCompactRegion hz
  have huhp : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have h := H z.re z.im hbox
  rw [huhp] at h
  exact h

/-- 🌟🌟🌟🌟 **PROVED — `XiLowResidualMargin` from the compact
numerical certificate.** Composition of the two bridges. -/
theorem XiLowResidualMargin_of_numericalCertificate
    (H : LowCompactNumericalCertificate) :
    XiLowResidualMargin honestZeroDensityModelTwoPi :=
  XiLowResidualMargin_of_envelopeDominates
    (LowCompactEnvelopeDominates_of_numericalCertificate H)

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **FINAL
FRONT DOOR (twoPi + tail limits + compact numerical low).**

The five-input Route B capstone with `Hlow` replaced by the bounded
compact-box numerical certificate:

```
hTuring + hHighLog              (parallel agent)
+ Hcanon_tailLimit              (mid residual Tendsto)
+ Hhigh_tailLimit               (high residual Tendsto)
+ Hcompact                      (numerical bound on |x| ≤ 4, 0 < y ≤ 4)
⟹ XiPullbackAntiHerglotzTarget
```
-/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_compactLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (Hcanon_tailLimit :
      XiCanonicalResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hhigh_tailLimit :
      XiHighResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hcompact : LowCompactNumericalCertificate) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_tailLimits
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
    Hcanon_tailLimit Hhigh_tailLimit
    (XiLowResidualMargin_of_numericalCertificate Hcompact)

