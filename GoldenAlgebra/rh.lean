/-- в≠Р **PROVED вАФ `simpleCloudSum` is even in `x`.**
Per-term: `2y/((-x)¬≤ + ќ≥¬≤ + y¬≤) = 2y/(x¬≤ + ќ≥¬≤ + y¬≤)`. -/
theorem simpleCloudSum_neg_x (zeros : List вДЭ) (x y : вДЭ) :
    simpleCloudSum zeros (-x) y = simpleCloudSum zeros x y := by
  unfold simpleCloudSum
  congr 1
  apply List.map_congr_left
  intro g _
  have : (-x)^2 = x^2 := by ring
  rw [this]

/-- в≠Р **PROVED вАФ `SlabSimplePolyIneq` reduces to its `x вЙ• 0` form.**
Mirror of `slabPolyIneq_of_nonneg_x` for the `simpleCloudSum` variant.
Halves SDP certificate complexity: the external solver only needs to
discharge the inequality on the `x вЙ• 0` branch. -/
theorem slabSimplePolyIneq_of_nonneg_x
    {zeros : List вДЭ} {Tmin Tmax C D : вДЭ}
    (H : вИА x y T : вДЭ,
        0 вЙ§ x вЖТ
        Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ 0 < y вЖТ
        2 * (1 + x + y) вЙ§ T вЖТ
          closedFormSErrorBoundCD C D y T
            вЙ§ simpleCloudSum zeros x y
              + smoothTailRationalLowerBoundAbs x y T) :
    SlabSimplePolyIneq zeros Tmin Tmax C D := by
  intro x y T hTmin hTmax hy hreg
  by_cases hx : 0 вЙ§ x
  ¬Ј have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at hreg
    exact H x y T hx hTmin hTmax hy hreg
  ¬Ј push_neg at hx
    have hxneg : 0 вЙ§ -x := by linarith
    have habs : |x| = -x := abs_of_neg hx
    rw [habs] at hreg
    have Hneg := H (-x) y T hxneg hTmin hTmax hy hreg
    rw [вЖР simpleCloudSum_neg_x zeros x y,
        вЖР smoothTailRationalLowerBoundAbs_neg_x x y T]
    exact Hneg

