  have h_eq : Function.update f 1 (limUnder (­ØôØ[Ôëá] (1 : Ôäé)) f) = riemannZetaPoleUnit := by
    rw [h_lim_one]
    funext z
    by_cases hz : z = 1
    ┬À subst hz; simp [riemannZetaPoleUnit]
    ┬À rw [riemannZetaPoleUnit_eq_of_ne_one hz, Function.update_of_ne hz]
  rw [ÔåÉ h_eq]
