/-- тнР **PROVED тАФ Helper: `simpleCloudSum` monotone under list append.** -/
lemma simpleCloudSum_append_ge_left
    (zs extra : List тДЭ) {x y : тДЭ} (hy : 0 < y) :
    simpleCloudSum zs x y тЙд simpleCloudSum (zs ++ extra) x y := by
  unfold simpleCloudSum
