/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0(14) Ôëñ 9/20`** (tightening of
┬ºCCLXXXI's `_le_half` bound). Same proof technique: tangent at
`q = 2` via `Real.log_le_sub_one_of_pos` on `q/2`. The ┬ºCCLXXXI proof
actually shows `NÔéÇ(14) Ôëñ ÔêÆ0.1918┬À(7/¤Ç) + 7/8 < 0.4487`, which is
`< 9/20 = 0.45` (margin Ôëê 0.0013). -/
theorem smoothZeroCountingN0_at_14_le_nine_twentieth :
    smoothZeroCountingN0 14 Ôëñ (9 / 20 : ÔäØ) := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  have h_eq : (14 : ÔäØ) / (2 * Real.pi) = 7 / Real.pi := by ring
  rw [h_eq]
  have h_7pi_pos : 0 < 7 / Real.pi := by positivity
  have h_7pi_nn : 0 Ôëñ 7 / Real.pi := le_of_lt h_7pi_pos
  have h_7pi_lt : 7 / Real.pi < 2.23 := by
    rw [div_lt_iffÔéÇ h_pi_pos]; linarith
  have h_7pi_gt : (2.222 : ÔäØ) < 7 / Real.pi := by
    rw [lt_div_iffÔéÇ h_pi_pos]; linarith
  have h_7pi_half_pos : 0 < 7 / Real.pi / 2 := by linarith
  have h_log_qhalf_le : Real.log (7 / Real.pi / 2) Ôëñ 7 / Real.pi / 2 - 1 :=
    Real.log_le_sub_one_of_pos h_7pi_half_pos
  have h_log_div : Real.log (7 / Real.pi / 2)
                = Real.log (7 / Real.pi) - Real.log 2 :=
    Real.log_div (ne_of_gt h_7pi_pos) (by norm_num : (2 : ÔäØ) Ôëá 0)
  have h_log_q_bound :
      Real.log (7 / Real.pi) Ôëñ Real.log 2 + 7 / Real.pi / 2 - 1 := by
    linarith
  have h_log2_lt : Real.log 2 Ôëñ 0.6932 := by
    have := Real.log_two_lt_d9
    linarith
  have h_mul1 : (7 / Real.pi) * Real.log (7 / Real.pi)
              Ôëñ (7 / Real.pi) * (Real.log 2 + 7 / Real.pi / 2 - 1) :=
    mul_le_mul_of_nonneg_left h_log_q_bound h_7pi_nn
  have h_mul2 : (7 / Real.pi) * Real.log 2 Ôëñ (7 / Real.pi) * 0.6932 :=
    mul_le_mul_of_nonneg_left h_log2_lt h_7pi_nn
  have h_qsq : (7 / Real.pi) * (7 / Real.pi) Ôëñ (7 / Real.pi) * 2.23 :=
    mul_le_mul_of_nonneg_left h_7pi_lt.le h_7pi_nn
  nlinarith [h_mul1, h_mul2, h_qsq, h_7pi_lt, h_7pi_gt, h_7pi_pos]

/-- Ô¡É **PROVED ÔÇö `smoothZeroCountingN0(10) ÔëÑ -1/20`** via the Pad├®
lower bound `Real.le_log_one_add_of_nonneg`:
`2x/(x+2) Ôëñ log(1+x)` with `x := (5-¤Ç)/¤Ç ÔëÑ 0` gives
`log(5/¤Ç) ÔëÑ 2(5-¤Ç)/(5+¤Ç)`, hence
`(5/¤Ç)┬Àlog(5/¤Ç) ÔëÑ 10(5-¤Ç)/(¤Ç(5+¤Ç))`. Clearing denominators reduces
to `37¤Ç┬▓ ÔêÆ 415¤Ç + 1000 ÔëÑ 0` on `¤Ç Ôêê (3.14, 3.15)`, which holds with
margin Ôëê 60. Numerically `NÔéÇ(10) Ôëê 0.023 ÔëÑ -0.05`. -/
theorem smoothZeroCountingN0_at_10_ge_neg_one_twentieth :
    -(1 / 20 : ÔäØ) Ôëñ smoothZeroCountingN0 10 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  have h_eq : (10 : ÔäØ) / (2 * Real.pi) = 5 / Real.pi := by ring
  rw [h_eq]
  have h_5_lt_pi : Real.pi < 5 := by linarith
  have h_5pi_pos : 0 < 5 / Real.pi := by positivity
  -- x := (5 - ¤Ç) / ¤Ç ÔëÑ 0
  have h_x_nn : (0 : ÔäØ) Ôëñ (5 - Real.pi) / Real.pi := by
    apply div_nonneg
    ┬À linarith
    ┬À exact le_of_lt h_pi_pos
  -- 1 + x = 5/¤Ç
  have h_one_add : 1 + (5 - Real.pi) / Real.pi = 5 / Real.pi := by
    field_simp
  -- Pad├®: log(5/¤Ç) ÔëÑ 2x/(x+2) = 2(5-¤Ç)/(5+¤Ç)
  have h_pade_raw :
      2 * ((5 - Real.pi) / Real.pi) / ((5 - Real.pi) / Real.pi + 2)
        Ôëñ Real.log (1 + (5 - Real.pi) / Real.pi) :=
    Real.le_log_one_add_of_nonneg h_x_nn
  rw [h_one_add] at h_pade_raw
  -- Setup nonzero hypotheses and the polynomial-form Pad├® bound
  have h_5_plus_pi_pos : (0 : ÔäØ) < 5 + Real.pi := by linarith
  have h¤Ç_ne : Real.pi Ôëá 0 := ne_of_gt h_pi_pos
  have h5p¤Ç_ne : (5 + Real.pi : ÔäØ) Ôëá 0 := ne_of_gt h_5_plus_pi_pos
  have h_inner_pos : (0 : ÔäØ) < (5 - Real.pi) / Real.pi + 2 := by positivity
  have h_inner_ne : ((5 - Real.pi) / Real.pi + 2) Ôëá 0 := ne_of_gt h_inner_pos
  -- Step 1: clear outer division by multiplying by ((5-¤Ç)/¤Ç + 2)
  have h_pade_step1 :
      2 * ((5 - Real.pi) / Real.pi)
        Ôëñ ((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_right h_pade_raw (le_of_lt h_inner_pos)
    rw [div_mul_cancelÔéÇ _ h_inner_ne] at h
    linarith
  -- Step 2: multiply by ¤Ç to clear inner /¤Ç
  -- ¤Ç ┬À 2((5-¤Ç)/¤Ç) = 2(5-¤Ç); ¤Ç ┬À ((5-¤Ç)/¤Ç + 2) = (5-¤Ç) + 2¤Ç = 5+¤Ç
  have h_pade_poly :
      2 * (5 - Real.pi) Ôëñ (5 + Real.pi) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_left h_pade_step1 (le_of_lt h_pi_pos)
    have hl : Real.pi * (2 * ((5 - Real.pi) / Real.pi)) = 2 * (5 - Real.pi) := by
      field_simp
    have h_factor :
        Real.pi * ((5 - Real.pi) / Real.pi + 2) = 5 + Real.pi := by
      field_simp; ring
    have hr :
        Real.pi * (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
          = (5 + Real.pi) * Real.log (5 / Real.pi) := by
      rw [show Real.pi *
            (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
            = (Real.pi * ((5 - Real.pi) / Real.pi + 2))
                * Real.log (5 / Real.pi) from by ring,
          h_factor]
    linarith [h, hl.symm.le, hl.le, hr.le, hr.symm.le]
  -- Step 3: polynomial inequality from ¤Ç bounds ÔÇö `(200-37¤Ç)(5+¤Ç) Ôëñ 400(5-¤Ç)`
  -- equivalently `37¤Ç┬▓ - 415¤Ç + 1000 ÔëÑ 0` (margin Ôëê 60 on (3.14, 3.15))
  have h_polyq :
      (200 - 37 * Real.pi) * (5 + Real.pi) Ôëñ 400 * (5 - Real.pi) := by
    nlinarith [h_pi_lt, h_pi_gt, sq_nonneg (Real.pi - 3.14),
               sq_nonneg (3.15 - Real.pi)]
  -- Step 4: chain via h_pade_poly ┬À 200: 200┬À(5+¤Ç)┬Àlog(5/¤Ç) ÔëÑ 400(5-¤Ç) ÔëÑ (200-37¤Ç)(5+¤Ç)
  have h_chain :
      (200 - 37 * Real.pi) * (5 + Real.pi)
        Ôëñ 200 * ((5 + Real.pi) * Real.log (5 / Real.pi)) := by
    have := mul_le_mul_of_nonneg_left h_pade_poly (by norm_num : (0 : ÔäØ) Ôëñ 200)
    linarith
  -- Step 5: divide by (5+¤Ç) > 0: 200 - 37¤Ç Ôëñ 200┬Àlog(5/¤Ç)
  have h_200_log :
      200 - 37 * Real.pi Ôëñ 200 * Real.log (5 / Real.pi) := by
    by_contra hneg
    push_neg at hneg
    have h_mul := mul_lt_mul_of_pos_right hneg h_5_plus_pi_pos
    have h_assoc :
        200 * Real.log (5 / Real.pi) * (5 + Real.pi)
          = 200 * ((5 + Real.pi) * Real.log (5 / Real.pi)) := by ring
    rw [h_assoc] at h_mul
    linarith
  -- Step 6: derive goal by multiplying 1/(40¤Ç) to scale to (5/¤Ç)┬Àlog(5/¤Ç)
  -- Equivalently: 0 Ôëñ 200┬Àlog(5/¤Ç) - 200 + 37¤Ç (from h_200_log + linarith)
  have h_target_poly :
      (0 : ÔäØ) Ôëñ 200 * Real.log (5 / Real.pi) - 200 + 37 * Real.pi := by
    linarith
  -- Scale by 1/(40¤Ç) > 0 to convert to goal form
  have h_inv_pos : (0 : ÔäØ) < 1 / (40 * Real.pi) := by positivity
  have h_scaled := mul_le_mul_of_nonneg_left h_target_poly (le_of_lt h_inv_pos)
  rw [mul_zero] at h_scaled
  -- Simplify 1/(40¤Ç) ┬À (200┬Àlog(5/¤Ç) - 200 + 37¤Ç) = (5/¤Ç)┬Àlog(5/¤Ç) - 5/¤Ç + 37/40
  have h_lhs_eq :
