    have hden_nn : 0 Ôëñ (T / 2 - 1)^2 + ╬│^2 := by positivity
    exact one_div_nonneg.mpr hden_nn
  linarith

/-- Ô¡É **PROVED ÔÇö termwise comparison TÔåÆ11/2 for the cloud denominator.**
For `12 Ôëñ T Ôëñ 13` and any `╬│`,
  `1/((11/2)┬▓ + ╬│┬▓) Ôëñ 1/((T/2 - 1)┬▓ + ╬│┬▓)`.
(The denominator on the right is positive since `T/2 - 1 ÔëÑ 5 > 0`.) -/
lemma one_div_Tbox_le_one_div_12_13
    {T ╬│ : ÔäØ}
    (hT12 : 12 Ôëñ T) (hT13 : T Ôëñ 13) :
    1 / (((11 / 2 : ÔäØ)^2) + ╬│^2)
      Ôëñ 1 / (((T / 2 - 1)^2) + ╬│^2) := by
  have hlow : 0 Ôëñ T / 2 - 1 := by linarith
  have hhi : T / 2 - 1 Ôëñ (11 / 2 : ÔäØ) := by linarith
  have hsq : (T / 2 - 1)^2 Ôëñ ((11 / 2 : ÔäØ)^2) := sq_le_sq' (by linarith) hhi
  have hden : (T / 2 - 1)^2 + ╬│^2 Ôëñ ((11 / 2 : ÔäØ)^2) + ╬│^2 := by linarith
  have hT_half_pos : 0 < T / 2 - 1 := by linarith
  have hTsq_pos : 0 < (T / 2 - 1)^2 := pow_pos hT_half_pos 2
  have hdenpos : 0 < (T / 2 - 1)^2 + ╬│^2 := by
    have h╬│2 : 0 Ôëñ ╬│^2 := sq_nonneg _
    linarith
  exact one_div_le_one_div_of_le hdenpos hden

