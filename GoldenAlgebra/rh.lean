/-! ### Smooth main-term aliases

We alias the already-proved global definitions `smoothZeroCountingN0` and
`zeroDensityRho` so this layer does not fork the meaning of the smooth
zero-counting function. -/

/-- The smooth RiemannвАУvon Mangoldt main term used by the Backlund/Turing
layer.  Alias of `smoothZeroCountingN0`. -/
noncomputable def smoothMainTerm (u : вДЭ) : вДЭ :=
  smoothZeroCountingN0 u

/-- The smooth zero-density used by the Backlund/Turing layer.  Alias of
`zeroDensityRho`. -/
noncomputable def smoothDensity (u : вДЭ) : вДЭ :=
  zeroDensityRho u

theorem smoothDensity_nonneg_of_ge_two_pi
    {u : вДЭ} (hu : 2 * Real.pi вЙ§ u) :
    0 вЙ§ smoothDensity u := by
  simpa [smoothDensity] using zeroDensityRho_nonneg_of_ge_two_pi hu

theorem deriv_smoothMainTerm
    {u : вДЭ} (hu : 0 < u) :
    deriv smoothMainTerm u = smoothDensity u := by
  simpa [smoothMainTerm, smoothDensity] using deriv_smoothZeroCountingN0 hu

/-- Derivative form for the Backlund smooth main term. -/
theorem hasDerivAt_smoothMainTerm
    {u : вДЭ} (hu : 0 < u) :
    HasDerivAt smoothMainTerm (smoothDensity u) u := by
  have h2pi_pos : (0 : вДЭ) < 2 * Real.pi := by positivity
  have hq_pos : (0 : вДЭ) < u / (2 * Real.pi) := div_pos hu h2pi_pos
  have hq_ne : u / (2 * Real.pi) вЙ† 0 := ne_of_gt hq_pos
  have hlin :
      HasDerivAt (fun v : вДЭ => v / (2 * Real.pi))
        (1 / (2 * Real.pi)) u := by
    simpa using (hasDerivAt_id u).div_const (2 * Real.pi)
  have hlog :
      HasDerivAt (fun v : вДЭ => Real.log (v / (2 * Real.pi)))
        (1 / u) u := by
    have h := (Real.hasDerivAt_log hq_ne).comp u hlin
    have hsimp :
        (u / (2 * Real.pi))вБї¬є * (1 / (2 * Real.pi)) = 1 / u := by
      field_simp
      ring
    rw [hsimp] at h
    simpa [Function.comp_def] using h
  have hprod := hlin.mul hlog
  have hsub := hprod.sub hlin
  have hfinal := hsub.add_const (7 / 8)
  have hderiv :
      (1 / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
        + (u / (2 * Real.pi)) * (1 / u) - 1 / (2 * Real.pi)
      = smoothDensity u := by
    unfold smoothDensity zeroDensityRho
    field_simp
    ring
  have hfunc :
      (fun v : вДЭ => (v / (2 * Real.pi)) * Real.log (v / (2 * Real.pi))
                    - v / (2 * Real.pi) + 7 / 8)
        = smoothMainTerm := by
    funext v
    rfl
  rw [вЖР hfunc, вЖР hderiv]
  exact hfinal

/-- The Backlund smooth main term is monotone on `[2ѕА, вИЮ)`. -/
theorem smoothMainTerm_monotoneOn_Ici_two_pi :
    MonotoneOn smoothMainTerm (Set.Ici (2 * Real.pi)) := by
  apply monotoneOn_of_deriv_nonneg (convex_Ici _)
  ¬Ј intro x hx
    have hx_ge : 2 * Real.pi вЙ§ x := hx
    have hx_pos : 0 < x := lt_of_lt_of_le (by positivity) hx_ge
    exact (hasDerivAt_smoothMainTerm hx_pos).continuousAt.continuousWithinAt
  ¬Ј intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    exact (hasDerivAt_smoothMainTerm hx_pos).differentiableAt.differentiableWithinAt
  ¬Ј intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    rw [(hasDerivAt_smoothMainTerm (lt_trans (by positivity) hx_2pi)).deriv]
    exact smoothDensity_nonneg_of_ge_two_pi (le_of_lt hx_2pi)

/-- Endpoint bounds for the monotone smooth main term bound the whole
interval. -/
theorem smoothMainTerm_bounds_of_endpoint_bounds
    {A B T mainLower mainUpper : вДЭ}
    (hA2pi : 2 * Real.pi вЙ§ A)
    (hAT : A вЙ§ T) (hTB : T вЙ§ B)
    (hlow : mainLower вЙ§ smoothMainTerm A)
    (hhigh : smoothMainTerm B вЙ§ mainUpper) :
    mainLower вЙ§ smoothMainTerm T вИІ smoothMainTerm T вЙ§ mainUpper := by
  have hmono := smoothMainTerm_monotoneOn_Ici_two_pi
  have hT2pi : 2 * Real.pi вЙ§ T := le_trans hA2pi hAT
  have hB2pi : 2 * Real.pi вЙ§ B := le_trans hT2pi hTB
  have hleft : smoothMainTerm A вЙ§ smoothMainTerm T :=
    hmono hA2pi hT2pi hAT
  have hright : smoothMainTerm T вЙ§ smoothMainTerm B :=
    hmono hT2pi hB2pi hTB
  constructor
  ¬Ј exact le_trans hlow hleft
  ¬Ј exact le_trans hright hhigh

/-- A lower log-ratio bound gives a lower bound for the Backlund smooth
main term.  This is the reusable endpoint arithmetic step needed by the
finite `[140, 374]` slab table. -/
theorem smoothMainTerm_lower_bound_of_log_ratio_lower
    {T logLower mainLower : вДЭ}
    (hT0 : 0 вЙ§ T)
    (hlog : logLower вЙ§ Real.log (T / (2 * Real.pi)))
    (harith :
      mainLower
        вЙ§ (T / (2 * Real.pi)) * logLower
          - T / (2 * Real.pi) + 7 / 8) :
    mainLower вЙ§ smoothMainTerm T := by
  have hratio_nonneg : 0 вЙ§ T / (2 * Real.pi) := by positivity
  have hmul :
      (T / (2 * Real.pi)) * logLower
        вЙ§ (T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left hlog hratio_nonneg
  unfold smoothMainTerm smoothZeroCountingN0
  linarith

/-- An upper log-ratio bound gives an upper bound for the Backlund smooth
main term. -/
theorem smoothMainTerm_upper_bound_of_log_ratio_upper
    {T logUpper mainUpper : вДЭ}
    (hT0 : 0 вЙ§ T)
    (hlog : Real.log (T / (2 * Real.pi)) вЙ§ logUpper)
    (harith :
      (T / (2 * Real.pi)) * logUpper
        - T / (2 * Real.pi) + 7 / 8
          вЙ§ mainUpper) :
    smoothMainTerm T вЙ§ mainUpper := by
  have hratio_nonneg : 0 вЙ§ T / (2 * Real.pi) := by positivity
  have hmul :
      (T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        вЙ§ (T / (2 * Real.pi)) * logUpper :=
    mul_le_mul_of_nonneg_left hlog hratio_nonneg
  unfold smoothMainTerm smoothZeroCountingN0
  linarith

/-- A certified lower bound for the positive ratio `T / (2ѕА)` gives the
corresponding lower logarithm bound. -/
theorem log_ratio_lower_of_ratio_lower
    {T ratioLower logLower : вДЭ}
    (hratio_pos : 0 < ratioLower)
    (hratio : ratioLower вЙ§ T / (2 * Real.pi))
    (hlog : logLower вЙ§ Real.log ratioLower) :
    logLower вЙ§ Real.log (T / (2 * Real.pi)) := by
  exact le_trans hlog (Real.log_le_log hratio_pos hratio)

/-- A certified upper bound for the positive ratio `T / (2ѕА)` gives the
corresponding upper logarithm bound. -/
theorem log_ratio_upper_of_ratio_upper
    {T ratioUpper logUpper : вДЭ}
    (hT_ratio_pos : 0 < T / (2 * Real.pi))
    (hratio : T / (2 * Real.pi) вЙ§ ratioUpper)
    (hlog : Real.log ratioUpper вЙ§ logUpper) :
    Real.log (T / (2 * Real.pi)) вЙ§ logUpper := by
  exact le_trans (Real.log_le_log hT_ratio_pos hratio) hlog

/-- Exponential form of a lower logarithm certificate. -/
theorem log_lower_of_exp_le
    {x logLower : вДЭ}
    (h : Real.exp logLower вЙ§ x) :
    logLower вЙ§ Real.log x := by
  have hpos : 0 < Real.exp logLower := Real.exp_pos _
  have hlog := Real.log_le_log hpos h
  simpa [Real.log_exp] using hlog

/-- Exponential form of an upper logarithm certificate. -/
theorem log_upper_of_le_exp
    {x logUpper : вДЭ}
    (hx : 0 < x)
    (h : x вЙ§ Real.exp logUpper) :
    Real.log x вЙ§ logUpper := by
  have hlog := Real.log_le_log hx h
  simpa [Real.log_exp] using hlog

/-- Multiplicative form of a lower ratio certificate.  Finite-table
rows often prove `2ѕА * r вЙ§ T` by rational interval arithmetic; this
turns it into `r вЙ§ T / (2ѕА)`. -/
theorem ratio_lower_of_two_pi_mul_le
    {T ratioLower : вДЭ}
    (h : 2 * Real.pi * ratioLower вЙ§ T) :
    ratioLower вЙ§ T / (2 * Real.pi) := by
  have hden : 0 < 2 * Real.pi := by positivity
  rw [le_div_iffвВА hden]
  simpa [mul_comm, mul_left_comm, mul_assoc] using h

/-- Multiplicative form of an upper ratio certificate. -/
theorem ratio_upper_of_le_two_pi_mul
    {T ratioUpper : вДЭ}
    (h : T вЙ§ 2 * Real.pi * ratioUpper) :
    T / (2 * Real.pi) вЙ§ ratioUpper := by
  have hden : 0 < 2 * Real.pi := by positivity
  rw [div_le_iffвВА hden]
  simpa [mul_comm, mul_left_comm, mul_assoc] using h

/-- A rational upper bound for `ѕА` lets a finite table prove lower ratio
certificates without mentioning division by `2ѕА`. -/
theorem ratio_lower_of_pi_upper_bound
    {T ratioLower piUpper : вДЭ}
    (hratio_nonneg : 0 вЙ§ ratioLower)
    (hpi : Real.pi вЙ§ piUpper)
    (h : 2 * piUpper * ratioLower вЙ§ T) :
    ratioLower вЙ§ T / (2 * Real.pi) := by
  apply ratio_lower_of_two_pi_mul_le
  have hscale : 2 * Real.pi * ratioLower вЙ§ 2 * piUpper * ratioLower := by
    nlinarith
  exact le_trans hscale h

/-- A rational lower bound for `ѕА` lets a finite table prove upper ratio
certificates without mentioning division by `2ѕА`. -/
theorem ratio_upper_of_pi_lower_bound
    {T ratioUpper piLower : вДЭ}
    (hratio_nonneg : 0 вЙ§ ratioUpper)
    (hpi : piLower вЙ§ Real.pi)
    (h : T вЙ§ 2 * piLower * ratioUpper) :
    T / (2 * Real.pi) вЙ§ ratioUpper := by
  apply ratio_upper_of_le_two_pi_mul
  have hscale : 2 * piLower * ratioUpper вЙ§ 2 * Real.pi * ratioUpper := by
    nlinarith
