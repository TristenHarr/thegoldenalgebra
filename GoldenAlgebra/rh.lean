error bound are caller-supplied; the four `cert_*` fields are the
sub-band-specific polynomial inequalities. -/
structure FirstZeroBandCertInputs (model : тДВ тЖТ тДВ) (errorBound : тДЭ тЖТ тДЭ тЖТ тДЭ) where
  cert_2pi_7 : тИА z : тДВ, тИА T : тДЭ,
      2 * Real.pi тЙд T тЖТ T тЙд 7 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z.im T тЙд -(model z).im
  cert_7_8 : тИА z : тДВ, тИА T : тДЭ,
      7 тЙд T тЖТ T тЙд 8 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z.im T тЙд -(model z).im
  cert_8_9 : тИА z : тДВ, тИА T : тДЭ,
      8 тЙд T тЖТ T тЙд 9 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z.im T тЙд -(model z).im
  cert_9_10 : тИА z : тДВ, тИА T : тДЭ,
      9 тЙд T тЖТ T тЙд 10 тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z.im T тЙд -(model z).im

/-- тнР **PROVED тАФ bundle тЯ╣ `FirstZeroBandCertificate`** at `gamma1`
(any `╬│тВБ тЙе 10`). Dispatches by 4-way case analysis on `T`. -/
noncomputable def firstZeroBandCert_from_inputs
    (model : тДВ тЖТ тДВ) (errorBound : тДЭ тЖТ тДЭ тЖТ тДЭ)
    (gamma1 : тДЭ) (h_10_le_gamma1 : 10 тЙд gamma1)
    (I : FirstZeroBandCertInputs model errorBound) :
    FirstZeroBandCertificate where
  Tmin := 2 * Real.pi
  Tmax := 10
  gamma1 := gamma1
  Tmin_ge_two_pi := le_refl _
  Tmin_le_Tmax := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  Tmax_le_gamma1 := h_10_le_gamma1
  model := model
  errorBound := errorBound
  cert := by
    intro z T hTmin hTmax hy hreg
    by_cases h1 : T тЙд 7
    ┬╖ exact I.cert_2pi_7 z T hTmin h1 hy hreg
    push_neg at h1
    by_cases h2 : T тЙд 8
    ┬╖ exact I.cert_7_8 z T (le_of_lt h1) h2 hy hreg
    push_neg at h2
    by_cases h3 : T тЙд 9
    ┬╖ exact I.cert_8_9 z T (le_of_lt h2) h3 hy hreg
    push_neg at h3
    exact I.cert_9_10 z T (le_of_lt h3) hTmax hy hreg

/-- тнР **PROVED тАФ top-level: `FirstZeroBandCertInputs` тЯ╣ per-probe
`ModelMarginLowerBound`** in the first-zero band. -/
theorem firstZeroBand_modelMargin_of_inputs
    (model : тДВ тЖТ тДВ) (errorBound : тДЭ тЖТ тДЭ тЖТ тДЭ)
    (gamma1 : тДЭ) (h_10_le_gamma1 : 10 тЙд gamma1)
    (I : FirstZeroBandCertInputs model errorBound)
    {z : тДВ} {T : тДЭ}
    (hTmin : 2 * Real.pi тЙд T) (hTmax : T тЙд 10)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    errorBound z.im T тЙд -(model z).im :=
  (firstZeroBandCert_from_inputs model errorBound gamma1 h_10_le_gamma1 I).cert
    z T hTmin hTmax hy hreg

