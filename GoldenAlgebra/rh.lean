-- ¬ІCCCXVI. ќЊ-side Hadamard source + bridge through chain rule
-- =====================================================================
-- The Hadamard product theorem is naturally stated for the completed
-- ќЊ on the s-plane. The chain rule `XiPullback_logDeriv_chain_rule`
-- converts to the z-plane pullback. This section adds the ќЊ-side
-- source Prop and bridges it to `XiHadamardLogDerivativeSourceAFZ`.
--
-- Note on differentiability: `completedXiFunction` (ќУ-based) is NOT
-- automatically differentiable at every `1/2 + I¬Јz` with `0 < z.im`
-- вАФ ќУ has poles at non-positive integers and the trivial-zero
-- cancellation isn't built into the definition. The ќЊ-side source
-- carries differentiability AFZ as a field; concrete inhabitants
-- discharge it via the Hadamard product factorization or by
-- bridging to Mathlib's `entireRiemannXi`.

/-- рЯУ¶ **`CompletedXiLogDerivativeSourceAFZ`** вАФ ќЊ-side Hadamard source
on the s-plane. -/
structure CompletedXiLogDerivativeSourceAFZ : Type where
  xiZeroContribution : вДВ вЖТ вДВ
  xi_diff_at :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      DifferentiableAt вДВ completedXiFunction s
  xi_logDeriv_eq :
    вИА s : вДВ,
      completedXiFunction s вЙ† 0 вЖТ
      logDerivativeResponse completedXiFunction s = xiZeroContribution s

/-- **Pullback of the ќЊ-side zero contribution to the z-plane.**
`ќЫ[ќЮ] = I ¬Ј ќЫ[ќЊ](¬љ + I¬Јz)` from the chain rule. -/
noncomputable def pullbackZeroContribution
    (H : CompletedXiLogDerivativeSourceAFZ) : вДВ вЖТ вДВ :=
  fun z => Complex.I * H.xiZeroContribution ((1 / 2 : вДВ) + Complex.I * z)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ z-plane AFZ Hadamard source from ќЊ-side AFZ
source via chain rule.** -/
noncomputable def XiHadamardLogDerivativeSourceAFZ_of_completedXi
    (H : CompletedXiLogDerivativeSourceAFZ) :
    XiHadamardLogDerivativeSourceAFZ :=
  { zeroContribution := pullbackZeroContribution H
    logDeriv_eq_zeroContribution := by
      intro z _hy hne
      have hs_ne :
          completedXiFunction ((1 / 2 : вДВ) + Complex.I * z) вЙ† 0 := by
        unfold XiPullback at hne
        exact hne
      have hxi_diff := H.xi_diff_at _ hs_ne
      have hchain := XiPullback_logDeriv_chain_rule hxi_diff
      have h_logderiv := H.xi_logDeriv_eq _ hs_ne
      unfold logDerivativeResponse at h_logderiv
      rw [hchain]
      unfold pullbackZeroContribution
      rw [h_logderiv] }

