-- ┬зCCXCIII-B. Smooth uniform lower bound on `lowCompactRegion`
-- =====================================================================
-- Proves `smoothLBConst тЙд smoothTailRationalLowerBoundAbsNorm z.re z.im 10`
-- where `smoothLBConst := (259/3586)┬╖(5/29) тЙИ 0.01246`. The factor
-- `5/29` is the uniform LB for the kernel factor (equality at `(0, 4)`);
-- `259/3586` is the rational LB for `╧Б(10)` via Pad├й `log(5/╧А) тЙе 74/163`
-- and `1/(2╧А) тЙе 7/44`.

/-- тнР **PROVED тАФ Pad├й bound** `2(5тИТ╧А)/(5+╧А) тЙд log(5/╧А)`. -/
lemma pade_log_5_div_pi :
    2 * (5 - Real.pi) / (5 + Real.pi) тЙд Real.log (5 / Real.pi) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_5_lt_pi : Real.pi < 5 := by linarith
  have h╧А_ne : Real.pi тЙа 0 := ne_of_gt h_pi_pos
  have h_5_plus_pi_pos : (0 : тДЭ) < 5 + Real.pi := by linarith
  have h_x_nn : (0 : тДЭ) тЙд (5 - Real.pi) / Real.pi := by
    apply div_nonneg
    ┬╖ linarith
    ┬╖ exact le_of_lt h_pi_pos
  have h_one_add : 1 + (5 - Real.pi) / Real.pi = 5 / Real.pi := by
    field_simp
  have h_pade := Real.le_log_one_add_of_nonneg h_x_nn
  rw [h_one_add] at h_pade
  -- Multiply h_pade by ((5-╧А)/╧А + 2) > 0
  have h_inner_pos : (0 : тДЭ) < (5 - Real.pi) / Real.pi + 2 := by positivity
  have h_inner_ne : ((5 - Real.pi) / Real.pi + 2) тЙа 0 := ne_of_gt h_inner_pos
  have h_step1 :
      2 * ((5 - Real.pi) / Real.pi)
        тЙд ((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_right h_pade (le_of_lt h_inner_pos)
    rw [div_mul_cancelтВА _ h_inner_ne] at h
    linarith
  -- Multiply by ╧А > 0
  have h_step2 :
      2 * (5 - Real.pi) тЙд (5 + Real.pi) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_left h_step1 (le_of_lt h_pi_pos)
    have hl : Real.pi * (2 * ((5 - Real.pi) / Real.pi)) = 2 * (5 - Real.pi) := by
      field_simp
    have h_factor :
        Real.pi * ((5 - Real.pi) / Real.pi + 2) = 5 + Real.pi := by
      field_simp; ring
    have hr :
        Real.pi * (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
          = (5 + Real.pi) * Real.log (5 / Real.pi) := by
      rw [show Real.pi *
            (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
            = (Real.pi * ((5 - Real.pi) / Real.pi + 2))
                * Real.log (5 / Real.pi) from by ring,
          h_factor]
    linarith [h, hl.le, hl.symm.le, hr.le, hr.symm.le]
  -- Divide by (5+╧А) > 0 to recover 2(5-╧А)/(5+╧А) тЙд log(5/╧А)
  have h5p╧А_ne : (5 + Real.pi : тДЭ) тЙа 0 := ne_of_gt h_5_plus_pi_pos
  rw [div_le_iffтВА h_5_plus_pi_pos]
  linarith [h_step2]

/-- тнР **PROVED тАФ rational `74/163 тЙд 2(5тИТ╧А)/(5+╧А)`** from `╧А тЙд 3.15`. -/
lemma pade_rational_lb_at_5_div_pi :
    (74 / 163 : тДЭ) тЙд 2 * (5 - Real.pi) / (5 + Real.pi) := by
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_5_plus_pi_pos : (0 : тДЭ) < 5 + Real.pi := by linarith
  rw [le_div_iffтВА h_5_plus_pi_pos]
  linarith

/-- тнР **PROVED тАФ `log(5/╧А) тЙе 74/163`.** -/
lemma log_5_div_pi_ge_74_div_163 :
    (74 / 163 : тДЭ) тЙд Real.log (5 / Real.pi) :=
  le_trans pade_rational_lb_at_5_div_pi pade_log_5_div_pi

/-- ЁЯМЯ **PROVED тАФ `╧Б(10) тЙе 259/3586`.** -/
theorem zeroDensityRho_10_ge_259_div_3586 :
    (259 / 3586 : тДЭ) тЙд zeroDensityRho 10 := by
  have h_eq : (10 : тДЭ) / (2 * Real.pi) = 5 / Real.pi := by ring
  have h_inv : (7 / 44 : тДЭ) тЙд 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_log : (74 / 163 : тДЭ) тЙд Real.log (5 / Real.pi) :=
