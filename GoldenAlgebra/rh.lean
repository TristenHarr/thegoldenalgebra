-- ¬ІCCXCIII-A. `HlowArith_norm` cloud lower bound
-- =====================================================================
-- On `lowCompactRegion`, `x¬≤ + y¬≤ вЙ§ 16` (from `|x| + y вЙ§ 4`), so each
-- normalized cloud term `2/(x¬≤+ќ≥¬≤+y¬≤) вЙ• 2/(ќ≥¬≤+16)`. Summing over
-- `zeros100ceil` gives the uniform lower bound
--   `cloudLBConst := ќ£_{ќ≥ вИИ zeros100ceil} 2/(ќ≥¬≤+16) вЙИ 0.0370`.
-- Cloud alone is insufficient (`C вЙИ 0.0473`, gap вЙИ -0.0103). The
-- smooth lower bound (¬ІCCXCIII-B, separate section) supplies the
-- additional вЙИ 0.0125 to close with margin вЙИ 0.0024.

/-- в≠Р **PROVED вАФ `x¬≤ + y¬≤ вЙ§ 16` on the low compact region.** Follows
from `(|x| + y)¬≤ вЙ§ 16` and dropping the non-negative cross term `2|x|y`. -/
lemma lowCompactRegion_sq_re_add_sq_im_le_16
    {z : вДВ} (hz : lowCompactRegion z) :
    z.re ^ 2 + z.im ^ 2 вЙ§ 16 := by
  have hy : 0 < z.im := hz.1
  have h_sum : 2 * (1 + |z.re| + z.im) вЙ§ 10 := hz.2
  have h_xy : |z.re| + z.im вЙ§ 4 := by linarith
  have h_abs_nn : (0 : вДЭ) вЙ§ |z.re| := abs_nonneg _
  have h_y_nn : (0 : вДЭ) вЙ§ z.im := le_of_lt hy
  have h_sq_re : z.re ^ 2 = |z.re| ^ 2 := (sq_abs z.re).symm
  rw [h_sq_re]
  nlinarith [sq_nonneg (|z.re| + z.im), h_abs_nn, h_y_nn, h_xy,
             mul_nonneg h_abs_nn h_y_nn]

/-- в≠Р **PROVED вАФ generic pointwise list sum bound.** -/
lemma list_sum_le_sum_of_pointwise
    {ќ± : Type*} {L : List ќ±} {f g : ќ± вЖТ вДЭ}
    (h : вИА a вИИ L, f a вЙ§ g a) :
    (L.map f).sum вЙ§ (L.map g).sum := by
  induction L with
  | nil => simp
  | cons a rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_a : f a вЙ§ g a := h a (by simp)
    have h_rest : вИА b вИИ rest, f b вЙ§ g b :=
      fun b hb => h b (List.mem_cons_of_mem a hb)
    have h_rest_le := ih h_rest
    linarith

/-- в≠Р **PROVED вАФ per-zero cloud lower bound.** -/
lemma simpleCloudSumNorm_term_lower
    {x y ќ≥ : вДЭ} (hxy : x ^ 2 + y ^ 2 вЙ§ 16) (hy : 0 < y) :
    (2 : вДЭ) / (ќ≥ ^ 2 + 16) вЙ§ 2 / (x ^ 2 + ќ≥ ^ 2 + y ^ 2) := by
  have h_xsq_nn : (0 : вДЭ) вЙ§ x ^ 2 := sq_nonneg x
  have h_ysq_pos : (0 : вДЭ) < y ^ 2 := by positivity
  have h_gamma_sq_nn : (0 : вДЭ) вЙ§ ќ≥ ^ 2 := sq_nonneg ќ≥
  have h_denom_pos : (0 : вДЭ) < x ^ 2 + ќ≥ ^ 2 + y ^ 2 := by linarith
  have h_denom_target_pos : (0 : вДЭ) < ќ≥ ^ 2 + 16 := by positivity
  have h_denom_le : x ^ 2 + ќ≥ ^ 2 + y ^ 2 вЙ§ ќ≥ ^ 2 + 16 := by linarith
  rw [div_le_div_iffвВА h_denom_target_pos h_denom_pos]
  nlinarith [h_denom_le, h_denom_pos, h_denom_target_pos]

/-- **Cloud lower-bound constant**: `ќ£_{ќ≥ вИИ zeros100ceil} 2/(ќ≥¬≤ + 16) вЙИ 0.0370`. -/
noncomputable def cloudLBConst : вДЭ :=
  (zeros100ceil.map (fun ќ≥ : вДЭ => 2 / (ќ≥ ^ 2 + 16))).sum

/-- рЯМЯ **PROVED вАФ uniform cloud lower bound** on the low compact region:
`cloudLBConst вЙ§ simpleCloudSumNorm zeros100ceil z.re z.im`. -/
theorem simpleCloudSumNorm_zeros100ceil_lower_bound
    {z : вДВ} (hz : lowCompactRegion z) :
    cloudLBConst вЙ§ simpleCloudSumNorm zeros100ceil z.re z.im := by
  unfold cloudLBConst simpleCloudSumNorm
  have hy : 0 < z.im := hz.1
  have hxy : z.re ^ 2 + z.im ^ 2 вЙ§ 16 :=
    lowCompactRegion_sq_re_add_sq_im_le_16 hz
  exact list_sum_le_sum_of_pointwise
    (fun ќ≥ _ => simpleCloudSumNorm_term_lower hxy hy)

