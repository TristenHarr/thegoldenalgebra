  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  have h10 : 10 Ôëñ canonicalAdaptiveT z := hc.1
  have h140 : canonicalAdaptiveT z Ôëñ 140 := hc.2.1
  have hregime : 2 * (1 + |z.re| + z.im) Ôëñ canonicalAdaptiveT z := hc.2.2
  have hT0leT : T0 Ôëñ canonicalAdaptiveT z := by linarith
  have hTpos : 0 < canonicalAdaptiveT z := by linarith
  have hEnv :
      ÔêÇßÂá u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
