-- ---------------------------------------------------------------------
-- Two Mathlib-backed numerical bounds suffice:
--   * `Real.exp_one_lt_d9 : exp 1 < 2.7182818286` вЗТ exp 1 вЙ§ 2.72
--   * `Real.exp_one_gt_d9 : 2.7182818283 < exp 1` вЗТ 2.71 вЙ§ exp 1
--   * `Real.pi_lt_d2     : ѕА < 3.15`              вЗТ 2ѕА < 6.3
--   * `Real.pi_lt_four   : ѕА < 4`                 вЗТ 22¬Јa > 255ѕА for a вЙ• 140

/-- в≠Р **PROVED вАФ `scalarGap22_15 140 > 0`.**

Chain:
  `log(140/(2ѕА)) > 3` (since `140 > 2ѕА¬Јe¬≥ вЙ§ 6.3¬Ј2.72¬≥ вЙ§ 126.78`),
  `log 140 < 5`        (since `140 вЙ§ 2.71вБµ вЙ§ exp 1 ^ 5 = eвБµ`),
  вЗТ LHS `вЙ• (308/(3ѕА))¬Ј3 = 308/ѕА вЙ• 308/3.15 вЙИ 97.78`,
  вЗТ RHS `вЙ§ (17/2)¬Ј5 + 43.9 = 86.4`,
  вЗТ gap `вЙ• 11.38 > 0`. Python: actual gap вЙИ 15.53. -/
theorem scalarGap22_15_at_140_nonneg :
    (0 : вДЭ) вЙ§ scalarGap22_15 140 := by
  unfold scalarGap22_15
  -- ѕА bounds
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_d2 : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi) вЙ† 0 := ne_of_gt h_2pi_pos
  have h_pi_ne : (Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_pi_pos
  -- exp 1 bounds
  have h_e_lt : Real.exp 1 < 2.72 := lt_trans Real.exp_one_lt_d9 (by norm_num)
