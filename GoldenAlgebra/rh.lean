/-- в≠Р **PROVED вАФ `slabSimple_19_32_core`.** -/
lemma slabSimple_19_32_core
    {x y T : вДЭ}
    (hx : 0 вЙ§ x) (hT19 : 19 вЙ§ T) (hT32 : T вЙ§ 32)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) вЙ§ T) :
    closedFormSErrorBoundCD 0 (1 : вДЭ) y T
      вЙ§ simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hTpos : (0 : вДЭ) < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hTpos
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hclosed :
      closedFormSErrorBoundCD 0 (1 : вДЭ) y T = y * (17 / T^2) :=
    closedFormSErrorBoundCD_19_32 hT_ne
  have hscalar :
      (17 : вДЭ) / T^2 вЙ§ 2 * cloudK_T zeros100ceil T + tailK_19_32 T :=
    scalar_19_32_cert hT19 hT32
  have hscaled :
      y * ((17 : вДЭ) / T^2) вЙ§ y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T) :=
    mul_le_mul_of_nonneg_left hscalar hy_nn
  have hsplit :
      y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T)
        = 2 * y * cloudK_T zeros100ceil T + y * tailK_19_32 T := by ring
  have hcloud :
      2 * y * cloudK_T zeros100ceil T
        вЙ§ simpleCloudSum zeros100ceil x y :=
    simpleCloudSum_ge_admissible_T_bound zeros100ceil hx hy hreg
  have htail :
      y * tailK_19_32 T
        вЙ§ smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_affine_19_32 hx hT19 hT32 hy hreg
  rw [hclosed]
  calc
    y * ((17 : вДЭ) / T^2)
        вЙ§ y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T) := hscaled
    _ = 2 * y * cloudK_T zeros100ceil T + y * tailK_19_32 T := hsplit
    _ вЙ§ simpleCloudSum zeros100ceil x y
          + smoothTailRationalLowerBoundAbs x y T :=
        add_le_add hcloud htail

