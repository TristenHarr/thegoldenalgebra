      F hF_A hF_B hF_model hlow hT2pi hT10 hy hreg
  mid := hmid
  high := by
    intro z T hT140 hy hreg
    exact highT_errorMargin_of_highTErrorControlled
      (M := xiCloudDensityModel_zeros100ceil) (error := error)
      xiCloudDensityModel_zeros100ceil_zeros hhigh hT140 hy hreg

-- =====================================================================
-- CLXXXVe: Decomposition scaffolding вАФ concrete `xiModelError` + global target
-- =====================================================================
-- Makes the log-derivative decomposition trivial-by-definition: define
-- `xiModelError z := ќЫ[XiPullback] z - M.model z`. Then the entire analytic
-- mountain reduces to three error-bound theorems (low/mid/high) on this
-- concrete residual. Phase1IBP / first-zero / large-T can each target
-- exactly one of those three predicates.

/-- **Canonical error function.** Defined by residual subtraction:
`xiModelError z := logDerivativeResponse XiPullback z - xiCloudDensityModel_zeros100ceil.model z`.

The decomposition `logDeriv = model + error` then holds by definition. -/
noncomputable def xiModelError_zeros100ceil (z : вДВ) : вДВ :=
  logDerivativeResponse XiPullback z
    - xiCloudDensityModel_zeros100ceil.model z

/-- в≠Р **PROVED вАФ Trivial-by-definition decomposition.** -/
theorem xiModelError_zeros100ceil_decomp (z : вДВ) :
    logDerivativeResponse XiPullback z =
      xiCloudDensityModel_zeros100ceil.model z
        + xiModelError_zeros100ceil z := by
  unfold xiModelError_zeros100ceil
  ring

/-- **Global control target for the canonical residual.**
Bundles the three remaining analytic mountains as a single propositional
target: a first-zero certificate matching the low band, plus the three
error-bound predicates instantiated at `xiModelError_zeros100ceil`. -/
structure XiModelErrorGlobalControlTarget where
  F : FirstZeroDirectBandCertificate
  hFA : F.A = 2 * Real.pi
  hFB : F.B = 10
  hFmodel : F.model = xiCloudDensityModel_zeros100ceil.model
  hlow : lowTErrorControlled xiModelError_zeros100ceil F.errorBound
  hmid : closedFormErrorControlledOnFiniteBand xiModelError_zeros100ceil
  hhigh : highTErrorControlled xiModelError_zeros100ceil

/-- в≠Р **PROVED вАФ Existence of admissible `T` for any `z : вДВ`.**
For any complex `z`, picking `T = max(2ѕА, 2¬Ј(1+|z.re|+z.im))` gives
`2ѕА вЙ§ T` and the adaptive-region constraint. -/
lemma exists_admissible_T (z : вДВ) :
    вИГ T : вДЭ, 2 * Real.pi вЙ§ T вИІ 2 * (1 + |z.re| + z.im) вЙ§ T := by
  refine вЯ®max (2 * Real.pi) (2 * (1 + |z.re| + z.im)), ?_, ?_вЯ©
  ¬Ј exact le_max_left _ _
  ¬Ј exact le_max_right _ _

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ Global `LocalXiCloudDensityErrorPackage`** from the
canonical-error global control target.

This is the **final analytic landing pad**: once the three error-bound
hypotheses (lowT/closedForm/highT) are supplied for the canonical
`xiModelError_zeros100ceil` residual, the entire local package falls out,
covering all of `вДВ` (region = `True`). -/
noncomputable def localPackage_global_of_xiModelErrorGlobalControl
    (H : XiModelErrorGlobalControlTarget) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_of_globalErrorControl
    xiCloudDensityModel_zeros100ceil
    xiCloudDensityModel_zeros100ceil_zeros
    xiCloudDensityModel_zeros100ceil_modelAnti
    xiModelError_zeros100ceil
    (fun _ => True)
    (fun z _ => exists_admissible_T z)
    (fun z _ => xiModelError_zeros100ceil_decomp z)
    (perWindowGlobalErrorControl_of_low_mid_high
      H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ Global `XiPullbackAntiHerglotzTarget`** from the
canonical-error global control target.

Since the local package covers all of `вДВ` (region = `True`), its
`implies_regionAntiHerglotz` gives `(ќЫ[XiPullback] z).im вЙ§ 0` for all
`z` with `0 < z.im` вАФ exactly `XiPullbackAntiHerglotzTarget`. -/
theorem xiPullbackAntiHerglotzTarget_of_xiModelErrorGlobalControl
    (H : XiModelErrorGlobalControlTarget) :
    XiPullbackAntiHerglotzTarget := by
  intro z hz
  -- Inline the local package's anti-Herglotz on z directly via the
  -- model-Anti + finite-band error margin chain (sidesteps the
  -- `P.region z = (fun _ => True) z` definitional-reduction issue).
  rw [xiModelError_zeros100ceil_decomp z, Complex.add_im]
  have h_model_im :
      (xiCloudDensityModel_zeros100ceil.model z).im вЙ§ 0 :=
    xiCloudDensityModel_zeros100ceil_modelAnti z hz
  obtain вЯ®T, hT2pi, hregTвЯ© := exists_admissible_T z
  have h_err_margin :
      |(xiModelError_zeros100ceil z).im|
        вЙ§ -(xiCloudDensityModel_zeros100ceil.model z).im :=
    errorMargin_of_globalErrorControl
      (M := xiCloudDensityModel_zeros100ceil)
      (error := xiModelError_zeros100ceil)
      xiCloudDensityModel_zeros100ceil_zeros
      (perWindowGlobalErrorControl_of_low_mid_high
        H.F H.hFA H.hFB H.hFmodel H.hlow H.hmid H.hhigh)
      hT2pi hz hregT
  have h_err_le :
      (xiModelError_zeros100ceil z).im
        вЙ§ |(xiModelError_zeros100ceil z).im| :=
    le_abs_self _
  linarith

-- =====================================================================
-- CLXXXVI: Phase 1.1 вАФ localized fluctuation measures (Mathlib measure objects)
-- =====================================================================
-- The ¬І16.1 `FluctuationMeasureData` records `S = N вИТ NвВА` at the
-- function level. This section lifts the same data to actual Mathlib
-- `Measure вДЭ` objects:
--   `dN = ќ£_{j<n} (mult j) вАҐ dirac (Z j)`     (Phase 1.1 discrete part)
--   `dNвВА = volume.withDensity ѕБ`              (Phase 1.1 smooth part)
-- and their localized restrictions to a window `[T, X]`. We do NOT yet
-- subtract them as a `SignedMeasure вДЭ` on the whole real line вАФ
-- `dNвВА` is infinite globally, so that is the trap. Localized first,
-- whole-line later via `X вЖТ вИЮ`.

namespace Phase1Measure

open MeasureTheory
open scoped ENNReal

/-- **Discrete zero-counting measure:**
  `dN = ќ£_{j<n} (mult j) вАҐ dirac (Z j)`.
The atomic measure supported on the zero ordinates `{Z 0, вА¶, Z (n-1)}`
with weight `mult j` at each. -/
noncomputable def discreteZeroMeasure
    (D : FluctuationMeasureData) : Measure вДЭ :=
  (Finset.range D.n).sum fun j =>
    ((D.mult j : вДЭвЙ•0вИЮ)) вАҐ Measure.dirac (D.Z j)

/-- **Smooth zero-counting measure:**
  `dNвВА = volume.withDensity (ENNReal.ofReal вИШ ѕБ)`,
where `ѕБ = zeroDensityRho = (1/(2ѕА))¬Јlog(u/(2ѕА))`. Infinite on `вДЭ`
globally; finite when restricted to a bounded window. -/
noncomputable def smoothZeroCountingMeasure : Measure вДЭ :=
  (MeasureTheory.volume : Measure вДЭ).withDensity
    (fun u : вДЭ => ENNReal.ofReal (zeroDensityRho u))

/-- **Localized discrete measure** on `[T, X]`. -/
noncomputable def discreteZeroMeasureOn
    (D : FluctuationMeasureData) (T X : вДЭ) : Measure вДЭ :=
  (discreteZeroMeasure D).restrict (Set.Icc T X)

/-- **Localized smooth measure** on `[T, X]`. Finite on any bounded
interval because `ѕБ` is bounded there. -/
noncomputable def smoothZeroCountingMeasureOn
    (T X : вДЭ) : Measure вДЭ :=
  smoothZeroCountingMeasure.restrict (Set.Icc T X)

end Phase1Measure

-- =====================================================================
-- CLXXXVII: Bridge вАФ concrete smooth Stieltjes partial via intervalIntegral
-- =====================================================================
-- The ¬І16.2-A `StieltjesPartialSplit` keeps `smoothPart : вДЭ вЖТ вДЭ` abstract.
-- This section pins it down to the explicit interval integral
--   `smoothStieltjesPartial f T X := вИЂ u in T..X, f u ¬Ј ѕБ(u) du`
-- and constructs `FluctuationMeasureData.toStieltjesPartialSplit` from
-- any `FluctuationMeasureData D` and integrand `f`, with the discrete
-- ќ£-of-Diracs side defaulting to `discreteStieltjesPartial D.Z D.mult D.n`.

namespace Phase1Measure

open MeasureTheory
open intervalIntegral

/-- **Smooth Stieltjes partial integral** for a real integrand `f`:
  `вИЂ_T^X f(u) ¬Ј ѕБ(u) du`. -/
noncomputable def smoothStieltjesPartial
    (f : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДЭ :=
  вИЂ u in T..X, f u * zeroDensityRho u

/-- **Concrete total finite Stieltjes partial** for `f`:
  `ќ£_{T вЙ§ Z j вЙ§ X} mult j ¬Ј f(Z j) вИТ вИЂ_T^X f(u)¬ЈѕБ(u) du`.
The function-level realization of `вИЂ_T^X f dS = вИЂ_T^X f d(N вИТ NвВА)`. -/
noncomputable def concreteStieltjesPartial
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДЭ :=
  discreteStieltjesPartial D.Z D.mult D.n f T X
    - smoothStieltjesPartial f T X

/-- в≠Р **PROVED вАФ `FluctuationMeasureData` projects to `StieltjesPartialSplit`.**
The discrete side is the canonical `discreteStieltjesPartial`; the smooth
side is the concrete `smoothStieltjesPartial`; the `total` field is the
difference and `total_eq` is `rfl`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toStieltjesPartialSplit
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T : вДЭ) :
    StieltjesPartialSplit where
  Z          := D.Z
  mult       := D.mult
  n          := D.n
  f          := f
  T          := T
  smoothPart := fun X => smoothStieltjesPartial f T X
  total      := fun X => concreteStieltjesPartial D f T X
  total_eq   := fun _ => rfl

/-- в≠Р **PROVED вАФ specialization to the imaginary paired-Cauchy kernel.**
Plugs `f := pairedCauchyImKernel x y` into the generic
`toStieltjesPartialSplit`. This is the integrand that appears on the
imaginary side of `вИЂ K_u(z) dS(u)`. -/
noncomputable def _root_.OverflowResidueRH.FluctuationMeasureData.toKernelStieltjesPartialSplit
    (D : FluctuationMeasureData) (x y T : вДЭ) :
    StieltjesPartialSplit :=
  D.toStieltjesPartialSplit
    (fun u : вДЭ => pairedCauchyImKernel x y u) T

end Phase1Measure

-- =====================================================================
-- CLXXXVIII: Phase 1.3 вАФ finite + improper kernel IBP scaffolds
-- =====================================================================
-- The integration-by-parts identity
--   `вИЂ_T^X k_z(u) dS(u)
--      = k_z(X)¬ЈS(X) вИТ k_z(T)¬ЈS(T) вИТ вИЂ_T^X S(u)¬Јk_z'(u) du`
-- packaged as named data. `FiniteKernelStieltjesIBP` carries the finite
-- identity per `X`; `ImproperKernelStieltjesIBP` adds the three limits
-- needed to pass `X вЖТ вИЮ`:
--   (i)  partial X вЖТ L
--   (ii) k_z(X)¬ЈS(X) вЖТ 0  (boundary at вИЮ)
--   (iii) вИЂ_T^X S k' вЖТ J
-- From these, the improper IBP identity reads `L = вИТk_z(T)¬ЈS(T) вИТ J`
-- and the bound `|L| вЙ§ |k_z(T)|¬ЈB(T) + вИЂ_T^вИЮ B(u)¬Ј|k_z'(u)| du` follows
-- from `|S u| вЙ§ B u` and the kernel decay envelopes
-- (`abs_pairedCauchyImKernelDeriv_le_adaptive_18`).

namespace Phase1IBP

open Filter Topology
open intervalIntegral

/-- **IBP boundary term** for the imaginary paired-Cauchy kernel:
  `k_z(X)¬ЈS(X) вИТ k_z(T)¬ЈS(T)`. -/
noncomputable def kernelBoundaryTerm
    (S : вДЭ вЖТ вДЭ) (x y T X : вДЭ) : вДЭ :=
  pairedCauchyImKernel x y X * S X
    - pairedCauchyImKernel x y T * S T

/-- **IBP derivative-side integral**:
  `вИЂ_T^X S(u) ¬Ј k_z'(u) du`. -/
noncomputable def kernelIBPDerivativeIntegral
    (S : вДЭ вЖТ вДЭ) (x y T X : вДЭ) : вДЭ :=
  вИЂ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Finite Stieltjes IBP identity for the imaginary kernel.**
Packages the per-`X` identity
  `partial X = k_z(X)¬ЈS(X) вИТ k_z(T)¬ЈS(T) вИТ вИЂ_T^X S k'`.
The `partial` field is the running finite Stieltjes integral
  `вИЂ_T^X k_z(u) dS(u)`
(realized in practice via `concreteStieltjesPartial`). -/
structure FiniteKernelStieltjesIBP where
  S          : вДЭ вЖТ вДЭ
  partialF   : вДЭ вЖТ вДЭ
  x          : вДЭ
  y          : вДЭ
  T          : вДЭ
  finite_ibp :
    вИА X : вДЭ,
      partialF X =
        kernelBoundaryTerm S x y T X
          - kernelIBPDerivativeIntegral S x y T X

/-- **Improper Stieltjes IBP for the imaginary kernel.** Extends the
finite identity with three limits that let us pass `X вЖТ вИЮ`:

* `partial_tendsto`            вАФ `partial X вЖТ L`
* `boundary_atTop`             вАФ `k_z(X)¬ЈS(X) вЖТ 0`
* `derivative_integral_tendsto` вАФ `вИЂ_T^X S k' вЖТ J`

The improper IBP identity that follows: `L = вИТk_z(T)¬ЈS(T) вИТ J`. -/
structure ImproperKernelStieltjesIBP where
  S          : вДЭ вЖТ вДЭ
  partialF   : вДЭ вЖТ вДЭ
  x          : вДЭ
  y          : вДЭ
  T          : вДЭ
  L          : вДЭ
  finiteIBP  : FiniteKernelStieltjesIBP
  finiteIBP_S_eq        : finiteIBP.S = S
  finiteIBP_partial_eq  : finiteIBP.partialF = partialF
  finiteIBP_x_eq        : finiteIBP.x = x
  finiteIBP_y_eq        : finiteIBP.y = y
  finiteIBP_T_eq        : finiteIBP.T = T
  partialF_tendsto :
    Tendsto partialF atTop (рЭУЭ L)
  boundary_atTop :
    Tendsto
      (fun X : вДЭ => pairedCauchyImKernel x y X * S X)
      atTop
      (рЭУЭ 0)
  derivative_integral_tendsto :
    вИГ J : вДЭ,
      Tendsto
        (fun X : вДЭ => kernelIBPDerivativeIntegral S x y T X)
        atTop
        (рЭУЭ J)

/-- в≠Р **PROVED вАФ improper IBP identity: `L = вИТk_z(T)¬ЈS(T) вИТ J`.**
The three limits combined with the per-`X` finite identity force the
limiting value of the partial integral to be the boundary term at `T`
plus the (negated) derivative-side integral at infinity. -/
theorem ImproperKernelStieltjesIBP.improper_identity
    (I : ImproperKernelStieltjesIBP) :
    вИГ J : вДЭ,
      Tendsto
        (fun X : вДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (рЭУЭ J) вИІ
      I.L = - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J := by
  obtain вЯ®J, hJвЯ© := I.derivative_integral_tendsto
  refine вЯ®J, hJ, ?_вЯ©
  -- partial X = k(X)¬ЈS(X) вИТ k(T)¬ЈS(T) вИТ вИЂ_T^X S k'
  have h_finite_X :
      вИА X : вДЭ,
        I.partialF X =
          pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X := by
    intro X
    have h := I.finiteIBP.finite_ibp X
    -- rewrite finiteIBP fields вЖТ I fields via the *_eq hypotheses
    rw [I.finiteIBP_partial_eq] at h
    unfold kernelBoundaryTerm at h
    rw [I.finiteIBP_S_eq, I.finiteIBP_x_eq, I.finiteIBP_y_eq, I.finiteIBP_T_eq] at h
    exact h
  -- Pass to the limit `X вЖТ вИЮ`.
  have h_const :
      Tendsto
        (fun _ : вДЭ => pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (рЭУЭ (pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    tendsto_const_nhds
  have h_diff :
      Tendsto
        (fun X : вДЭ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T)
        atTop
        (рЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T)) :=
    I.boundary_atTop.sub h_const
  have h_rhs :
      Tendsto
        (fun X : вДЭ =>
          pairedCauchyImKernel I.x I.y X * I.S X
            - pairedCauchyImKernel I.x I.y I.T * I.S I.T
            - kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (рЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) :=
    h_diff.sub hJ
  -- partial = RHS as functions, so the limit of partial is the same.
  have h_partial_rhs :
      (fun X : вДЭ => I.partialF X) =
      (fun X : вДЭ =>
        pairedCauchyImKernel I.x I.y X * I.S X
          - pairedCauchyImKernel I.x I.y I.T * I.S I.T
          - kernelIBPDerivativeIntegral I.S I.x I.y I.T X) :=
    funext h_finite_X
  have h_partial_lim :
      Tendsto (fun X : вДЭ => I.partialF X) atTop
        (рЭУЭ (0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J)) := by
    rw [h_partial_rhs]; exact h_rhs
  -- Unique limit of `partial` вЯє `L = 0 вИТ k(T)¬ЈS(T) вИТ J`.
  have h_unique :
      I.L = 0 - pairedCauchyImKernel I.x I.y I.T * I.S I.T - J :=
    tendsto_nhds_unique I.partialF_tendsto h_partial_lim
  linarith

/-- в≠Р **PROVED вАФ improper IBP wrapper.** Extract the `ImproperStieltjesIntegralData`
of ¬І16.2 from an `ImproperKernelStieltjesIBP`. -/
noncomputable def ImproperKernelStieltjesIBP.toImproperData
    (I : ImproperKernelStieltjesIBP) :
    ImproperStieltjesIntegralData where
  F        := I.partialF
  T        := I.T
  L        := I.L
  converges := I.partialF_tendsto

-- ---------------------------------------------------------------------
-- CLXXXIX: IBP-side bound on |L|
-- ---------------------------------------------------------------------
-- With `|S(u)| вЙ§ B(u)` on `[T, вИЮ)` and the derivative-side integral
-- bounded in absolute value by вИЂ_T^вИЮ B(u)¬Ј|k_z'(u)| du, the improper
-- identity `L = вИТk_z(T)¬ЈS(T) вИТ J` gives
--   |L|  вЙ§  |k_z(T)|¬ЈB(T) + |J|
--         вЙ§  |k_z(T)|¬ЈB(T) + вИЂ_T^вИЮ B(u)¬Ј|k_z'(u)| du.
-- The first inequality is triangle; the second is the hypothesis on
-- the derivative-side integral.

/-- в≠Р **PROVED вАФ triangle bound on the improper IBP value.**
`|L| вЙ§ |k_z(T)¬ЈS(T)| + |J|`. Pure arithmetic from the improper IBP
identity. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_triangle
    (I : ImproperKernelStieltjesIBP) :
    вИГ J : вДЭ,
      Tendsto
        (fun X : вДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
        atTop
        (рЭУЭ J) вИІ
      |I.L| вЙ§ |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
  obtain вЯ®J, hJ, hLвЯ© := I.improper_identity
  refine вЯ®J, hJ, ?_вЯ©
  -- L = -k(T)¬ЈS(T) - J, so |L| = |-k¬ЈS - J| вЙ§ |k¬ЈS| + |J|.
  rw [hL]
  calc |(- pairedCauchyImKernel I.x I.y I.T * I.S I.T) - J|
      вЙ§ |- pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := abs_sub _ _
    _ = |pairedCauchyImKernel I.x I.y I.T * I.S I.T| + |J| := by
        rw [neg_mul, abs_neg]

/-- в≠Р **PROVED вАФ `|L|` bound via `|S(T)| вЙ§ B(T)` and a derivative-integral
envelope.** Given:
- `|S(u)| вЙ§ B(u)` on `[T, вИЮ)`;
- the derivative-side integral has limit `J` with `|J| вЙ§ Jbound`;
the improper IBP value satisfies
  `|L|  вЙ§  |k_z(T)|¬ЈB(T)  +  Jbound`.

The shape matches the `ibpMargin` field of `ImaginaryStieltjesTailIBPBound`
(¬І13, CXLIV): `|k_z(T)|¬ЈB(T) + integralBound вЙ§ modelMargin`. -/
theorem ImproperKernelStieltjesIBP.abs_L_le_of_S_and_J_bound
    (I : ImproperKernelStieltjesIBP)
    (B : вДЭ вЖТ вДЭ)
    (hS_bound : вИА u : вДЭ, I.T вЙ§ u вЖТ |I.S u| вЙ§ B u)
    (Jbound : вДЭ)
    (hJ_bound :
      вИА J : вДЭ,
        Tendsto
          (fun X : вДЭ => kernelIBPDerivativeIntegral I.S I.x I.y I.T X)
          atTop
          (рЭУЭ J) вЖТ |J| вЙ§ Jbound) :
    |I.L| вЙ§ |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound := by
  obtain вЯ®J, hJ, hLtriвЯ© := I.abs_L_le_triangle
  have hJ_le : |J| вЙ§ Jbound := hJ_bound J hJ
  have hS_T : |I.S I.T| вЙ§ B I.T := hS_bound I.T le_rfl
  have h_kS : |pairedCauchyImKernel I.x I.y I.T * I.S I.T|
              вЙ§ |pairedCauchyImKernel I.x I.y I.T| * B I.T := by
    rw [abs_mul]
    exact mul_le_mul_of_nonneg_left hS_T (abs_nonneg _)
  linarith [hLtri, hJ_le, h_kS]

end Phase1IBP

-- =====================================================================
-- CXC: Closed-form discharge of `ImaginaryStieltjesTailIBPBound`
-- =====================================================================
-- Threads `Phase1IBP.ImproperKernelStieltjesIBP` into the existing
-- ¬І13 `ImaginaryStieltjesTailIBPBound`. The discharge requires:
--   вАҐ the improper IBP package (which we just defined);
--   вАҐ a bound function `B : вДЭ вЖТ вДЭ` for the fluctuation;
--   вАҐ a closed-form bound `Jbound` for the derivative-side improper
--     integral (the analytic content that produces the `18y/u¬≥` decay
--     envelope, currently a hypothesis until the next-pass IBP grind
--     produces it from `abs_pairedCauchyImKernelDeriv_le_adaptive_18`).
-- The output is an `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
-- is exactly the IBP-side bound the ¬І13 chain consumes.

namespace Phase1IBP

open Filter Topology

/-- в≠Р **PROVED вАФ `ImproperKernelStieltjesIBP` discharges
`ImaginaryStieltjesTailIBPBound`.** Given:

* the improper IBP package `I`;
* the bound function `B` for `|S|` on `[T, вИЮ)`;
* a closed-form envelope `Jbound` for the derivative-side integral;
* and the margin hypothesis `|k_z(T)|¬ЈB(T) + Jbound вЙ§ modelMargin`
  (already certified by the ¬І13/¬ІCLXXXIII slab bundle in the form
  `closedFormSErrorBoundCD C D y T вЙ§ -(model z).im`),

construct the ¬І13 `ImaginaryStieltjesTailIBPBound` whose `ibpMargin`
field is the headline inequality. -/
noncomputable def ImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : ImproperKernelStieltjesIBP)
    (B : вДЭ вЖТ вДЭ)
    (hS_bound : вИА u : вДЭ, I.T вЙ§ u вЖТ |I.S u| вЙ§ B u)
    (Jbound : вДЭ)
    (modelMargin : вДЭ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound вЙ§ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

end Phase1IBP

-- =====================================================================
-- ¬ІCXCI. Smooth finite-window kernel IBP (Phase 1.3 grind, smooth side)
-- =====================================================================
-- The first concrete piece of the IBP chain. For a closed window
-- `[T, X]` with `0 < T вЙ§ X`, the integration-by-parts identity
--   `вИЂ_T^X k_z(u)¬ЈѕБ(u) du
--      = k_z(X)¬ЈS(X) вИТ k_z(T)¬ЈS(T) вИТ вИЂ_T^X S(u)¬Јk_z'(u) du`
-- where `S(u) := вИЂ_T^u ѕБ(v) dv = smoothCountingPrimitive T u`.
-- This is the *smooth* half of `FiniteKernelStieltjesIBP`; the discrete
-- Abel summation against the zero Diracs is ¬ІCXCII (next).
-- Built on Mathlib's:
--   вАҐ `intervalIntegral.integral_hasDerivAt_right` (FTC, upper endpoint)
--   вАҐ `intervalIntegral.integral_mul_deriv_eq_deriv_mul` (IBP)
--   вАҐ `Real.continuousAt_log` (continuity of `log` away from 0).

namespace Phase1IBP

open MeasureTheory Filter Topology

/-- **Smooth counting primitive** for the zero-counting density:
  `S(X) = вИЂ_T^X ѕБ(u) du`. -/
noncomputable def smoothCountingPrimitive (T X : вДЭ) : вДЭ :=
  вИЂ u in T..X, zeroDensityRho u

/-- в≠Р **PROVED вАФ `S(T) = 0`**. Trivial via `integral_same`. -/
lemma smoothCountingPrimitive_self (T : вДЭ) :
    smoothCountingPrimitive T T = 0 := by
  unfold smoothCountingPrimitive
  exact intervalIntegral.integral_same

/-- в≠Р **PROVED вАФ `zeroDensityRho` is continuous at any `X > 0`.**
`ѕБ(u) = (1/(2ѕА))¬Јlog(u/(2ѕА))`; `log` is continuous away from `0`. -/
lemma zeroDensityRho_continuousAt {X : вДЭ} (hX : 0 < X) :
    ContinuousAt zeroDensityRho X := by
  unfold zeroDensityRho
  have h2pi_pos : (0 : вДЭ) < 2 * Real.pi := by positivity
  have h_div_pos : 0 < X / (2 * Real.pi) := div_pos hX h2pi_pos
  have h_div_ne : X / (2 * Real.pi) вЙ† 0 := ne_of_gt h_div_pos
  have h_inner : ContinuousAt (fun u : вДЭ => u / (2 * Real.pi)) X :=
    (continuous_id.div_const _).continuousAt
  -- Use `ContinuousAt.log` which composes cleanly (avoids the
  -- `HDiv.hDiv` unification trap that bites `Real.continuousAt_log.comp`).
  have h_log : ContinuousAt (fun u : вДЭ => Real.log (u / (2 * Real.pi))) X :=
    h_inner.log h_div_ne
  exact continuousAt_const.mul h_log

/-- в≠Р **PROVED вАФ `zeroDensityRho` is continuous on `Set.Ioi 0`.** -/
lemma zeroDensityRho_continuousOn_Ioi :
    ContinuousOn zeroDensityRho (Set.Ioi 0) :=
  fun _ hu => (zeroDensityRho_continuousAt hu).continuousWithinAt

/-- в≠Р **PROVED вАФ `zeroDensityRho` is `IntervalIntegrable` on `[T, X]`
when `0 < T вЙ§ X`.** Continuity on the compact `[T, X] вКВ (0, вИЮ)` gives
integrability. -/
lemma zeroDensityRho_intervalIntegrable
    {T X : вДЭ} (hT : 0 < T) (hTX : T вЙ§ X) :
    IntervalIntegrable zeroDensityRho MeasureTheory.volume T X := by
  refine ContinuousOn.intervalIntegrable_of_Icc hTX ?_
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  exact (zeroDensityRho_continuousAt hu_pos).continuousWithinAt

/-- в≠Р **PROVED вАФ FTC: `smoothCountingPrimitive T` is differentiable on
`(0, вИЮ)` and its derivative is `zeroDensityRho`.** -/
lemma smoothCountingPrimitive_hasDerivAt
    {T X : вДЭ} (hT : 0 < T) (hTX : T вЙ§ X) :
    HasDerivAt (fun u : вДЭ => smoothCountingPrimitive T u)
      (zeroDensityRho X) X := by
  have hX : 0 < X := lt_of_lt_of_le hT hTX
  have hX_cont : ContinuousAt zeroDensityRho X := zeroDensityRho_continuousAt hX
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  -- StronglyMeasurableAtFilter via a continuity neighborhood: on `Ioi 0`,
  -- `ѕБ` is continuous, hence AE-strongly-measurable.
  have h_Ioi_mem : Set.Ioi (0 : вДЭ) вИИ рЭУЭ X := Ioi_mem_nhds hX
  have h_smaf : StronglyMeasurableAtFilter zeroDensityRho (рЭУЭ X) MeasureTheory.volume :=
    вЯ®Set.Ioi 0, h_Ioi_mem,
     zeroDensityRho_continuousOn_Ioi.aestronglyMeasurable measurableSet_IoiвЯ©
  exact intervalIntegral.integral_hasDerivAt_right h_int h_smaf hX_cont

/-- в≠Р **PROVED вАФ `pairedCauchyImKernel x y` is differentiable at every `u`
for `y > 0`, with `HasDerivAt`-form derivative `pairedCauchyImKernelDeriv`.**
Lifts the `deriv` form (CXLV `deriv_pairedCauchyImKernel`) to the
`HasDerivAt` form by composing `DifferentiableAt` combinators and
substituting the proven derivative value. -/
lemma pairedCauchyImKernel_hasDerivAt
    {y : вДЭ} (hy : 0 < y) (x u : вДЭ) :
    HasDerivAt (fun v : вДЭ => pairedCauchyImKernel x y v)
      (pairedCauchyImKernelDeriv x y u) u := by
  have hd1_pos : (0 : вДЭ) < (x - u)^2 + y^2 := by positivity
  have hd2_pos : (0 : вДЭ) < (x + u)^2 + y^2 := by positivity
  have h_diff : DifferentiableAt вДЭ (fun v : вДЭ => pairedCauchyImKernel x y v) u := by
    unfold pairedCauchyImKernel
    have h1 : DifferentiableAt вДЭ (fun v : вДЭ => (x - v)^2 + y^2) u :=
      (((differentiableAt_const x).sub differentiableAt_id).pow 2).add_const _
    have h2 : DifferentiableAt вДЭ (fun v : вДЭ => (x + v)^2 + y^2) u :=
      (((differentiableAt_const x).add differentiableAt_id).pow 2).add_const _
    have hi1 : DifferentiableAt вДЭ (fun v : вДЭ => 1 / ((x - v)^2 + y^2)) u :=
      (differentiableAt_const _).div h1 (ne_of_gt hd1_pos)
    have hi2 : DifferentiableAt вДЭ (fun v : вДЭ => 1 / ((x + v)^2 + y^2)) u :=
      (differentiableAt_const _).div h2 (ne_of_gt hd2_pos)
    exact (differentiableAt_const (-y)).mul (hi1.add hi2)
  have h_value : deriv (fun v : вДЭ => pairedCauchyImKernel x y v) u
                  = pairedCauchyImKernelDeriv x y u :=
    deriv_pairedCauchyImKernel x y u hy
  rw [вЖР h_value]
  exact h_diff.hasDerivAt

/-- в≠Р **PROVED вАФ `pairedCauchyImKernelDeriv x y` is continuous on `вДЭ`
for `y > 0`.** Used to discharge the integrability hypothesis of IBP. -/
lemma pairedCauchyImKernelDeriv_continuous
    {y : вДЭ} (hy : 0 < y) (x : вДЭ) :
    Continuous (fun u : вДЭ => pairedCauchyImKernelDeriv x y u) := by
  unfold pairedCauchyImKernelDeriv
  have h_plus_sq : Continuous (fun u : вДЭ => ((x + u)^2 + y^2)^2) := by
    have h : Continuous (fun u : вДЭ => (x + u)^2 + y^2) :=
      ((continuous_const.add continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have h_minus_sq : Continuous (fun u : вДЭ => ((x - u)^2 + y^2)^2) := by
    have h : Continuous (fun u : вДЭ => (x - u)^2 + y^2) :=
      ((continuous_const.sub continuous_id).pow 2).add continuous_const
    exact h.pow 2
  have hne_plus : вИА u : вДЭ, ((x + u)^2 + y^2)^2 вЙ† 0 := fun u => by
    have : 0 < ((x + u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have hne_minus : вИА u : вДЭ, ((x - u)^2 + y^2)^2 вЙ† 0 := fun u => by
    have : 0 < ((x - u)^2 + y^2)^2 := by positivity
    exact ne_of_gt this
  have h_div_plus : Continuous (fun u : вДЭ => (x + u) / ((x + u)^2 + y^2)^2) :=
    (continuous_const.add continuous_id).div h_plus_sq hne_plus
  have h_div_minus : Continuous (fun u : вДЭ => (x - u) / ((x - u)^2 + y^2)^2) :=
    (continuous_const.sub continuous_id).div h_minus_sq hne_minus
  exact continuous_const.mul (h_div_plus.sub h_div_minus)

/-- в≠Р **PROVED вАФ `pairedCauchyImKernelDeriv` is `IntervalIntegrable`** on
any window. Direct from continuity. -/
lemma pairedCauchyImKernelDeriv_intervalIntegrable
    {y : вДЭ} (hy : 0 < y) (x T X : вДЭ) :
    IntervalIntegrable (fun u : вДЭ => pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
  (pairedCauchyImKernelDeriv_continuous hy x).intervalIntegrable T X

/-- рЯМЯ **PROVED вАФ SMOOTH FINITE-WINDOW IBP IDENTITY** for the imaginary
paired-Cauchy kernel against the zero-counting density:

  `вИЂ_T^X k_z(u)¬ЈѕБ(u) du
     = k_z(X)¬ЈS(X) вИТ k_z(T)¬ЈS(T) вИТ вИЂ_T^X S(u)¬Јk_z'(u) du`

where `S(u) := smoothCountingPrimitive T u`. The smooth half of the
finite Stieltjes IBP вАФ combined with the discrete Abel summation
(next), this yields the first concrete inhabitant of
`FiniteKernelStieltjesIBP`. -/
theorem smooth_zeroDensity_kernel_ibp
    {y : вДЭ} (hy : 0 < y) (x T X : вДЭ)
    (hT : 0 < T) (hTX : T вЙ§ X) :
    (вИЂ u in T..X, pairedCauchyImKernel x y u * zeroDensityRho u) =
      pairedCauchyImKernel x y X * smoothCountingPrimitive T X
        - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
        - вИЂ u in T..X,
            smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
  have hu_deriv :
      вИА u вИИ Set.uIcc T X,
        HasDerivAt (fun v : вДЭ => pairedCauchyImKernel x y v)
          (pairedCauchyImKernelDeriv x y u) u :=
    fun u _ => pairedCauchyImKernel_hasDerivAt hy x u
  have hv_deriv :
      вИА u вИИ Set.uIcc T X,
        HasDerivAt (fun v : вДЭ => smoothCountingPrimitive T v)
          (zeroDensityRho u) u := by
    intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    exact smoothCountingPrimitive_hasDerivAt hT hu.1
  have hu'_int :
      IntervalIntegrable (fun u : вДЭ => pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    pairedCauchyImKernelDeriv_intervalIntegrable hy x T X
  have hv'_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T X :=
    zeroDensityRho_intervalIntegrable hT hTX
  have h_ibp :=
    intervalIntegral.integral_mul_deriv_eq_deriv_mul
      hu_deriv hv_deriv hu'_int hv'_int
  -- h_ibp :  вИЂ k * ѕБ = k(X)¬ЈS(X) вИТ k(T)¬ЈS(T) вИТ вИЂ k' * S
  -- target:  вИЂ k * ѕБ = k(X)¬ЈS(X) вИТ k(T)¬ЈS(T) вИТ вИЂ S * k'
  have h_swap :
      (вИЂ u in T..X,
         pairedCauchyImKernelDeriv x y u * smoothCountingPrimitive T u) =
      (вИЂ u in T..X,
         smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u) := by
    refine intervalIntegral.integral_congr ?_
    intro u _; exact mul_comm _ _
  linarith [h_ibp, h_swap]

end Phase1IBP

-- =====================================================================
-- ¬ІCXCII-A. Ordered discrete Abel summation (Phase 1.3 grind, discrete side)
-- =====================================================================
-- The discrete half of `FiniteKernelStieltjesIBP`. The safe path:
-- prove the pure algebraic summation-by-parts identity over
-- `Finset.range (n + 1)` first, then instantiate with clipped zero
-- weights against the imaginary kernel.
--
-- Pure algebra:
--   `вИС_{j вЙ§ n} a_j ¬Ј b_j
--      = (вИС_{j вЙ§ n} a_j) ¬Ј b_n
--        вИТ вИС_{j < n} (вИС_{i вЙ§ j} a_i) ¬Ј (b_{j+1} вИТ b_j)`
--
-- Clipped instantiation:
--   `a_j := if T вЙ§ Z_j вЙ§ X then mult_j else 0`
--   `b_j := f (Z_j)`.

namespace Phase1IBP

open BigOperators

/-- в≠Р **PROVED вАФ pure algebraic Abel/summation-by-parts identity over
`Finset.range (n + 1)`.** -/
lemma fin_sum_mul_eq_boundary_sub_sum_succ
    (n : вДХ) (a b : вДХ вЖТ вДЭ) :
    (вИС j вИИ Finset.range (n + 1), a j * b j)
      =
    (вИС j вИИ Finset.range (n + 1), a j) * b n
      -
    вИС j вИИ Finset.range n,
      (вИС i вИИ Finset.range (j + 1), a i) * (b (j + 1) - b j) := by
  induction n with
  | zero => simp
  | succ n ih =>
    rw [Finset.sum_range_succ (fun j => a j * b j) (n + 1), ih,
        Finset.sum_range_succ (fun j => a j) (n + 1),
        Finset.sum_range_succ
          (fun j => (вИС i вИИ Finset.range (j + 1), a i) * (b (j + 1) - b j)) n]
    ring

/-- **Discrete counting primitive** for the zero list, clipped to `[T, X]`:
  `N_{T,X}(D) = ќ£_{j < n : T вЙ§ Z_j вЙ§ X} mult_j`. -/
noncomputable def discreteCountingPrimitive
    (D : FluctuationMeasureData) (T X : вДЭ) : вДЭ :=
  вИС j вИИ Finset.range D.n,
    if T вЙ§ D.Z j вИІ D.Z j вЙ§ X then (D.mult j : вДЭ) else 0

/-- **Discrete kernel partial** for an arbitrary integrand `f`:
  `ќ£_{j < n : T вЙ§ Z_j вЙ§ X} mult_j ¬Ј f(Z_j)`. -/
noncomputable def discreteKernelPartial
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДЭ :=
  вИС j вИИ Finset.range D.n,
    if T вЙ§ D.Z j вИІ D.Z j вЙ§ X then (D.mult j : вДЭ) * f (D.Z j) else 0

/-- в≠Р **PROVED вАФ counting primitive at `X = T`.** Only ordinates
exactly at `T` contribute. -/
lemma discreteCountingPrimitive_left
    (D : FluctuationMeasureData) (T : вДЭ) :
    discreteCountingPrimitive D T T
      =
    вИС j вИИ Finset.range D.n,
      if D.Z j = T then (D.mult j : вДЭ) else 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : D.Z j = T
  ¬Ј have hpair : T вЙ§ D.Z j вИІ D.Z j вЙ§ T := вЯ®h.ge, h.leвЯ©
    simp [h, hpair]
  ¬Ј have hnot : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ T) := by
      intro hpair
      exact h (le_antisymm hpair.2 hpair.1)
    simp [h, hnot]

/-- в≠Р **PROVED вАФ counting primitive is monotone in the upper cutoff.** -/
lemma discreteCountingPrimitive_mono
    (D : FluctuationMeasureData) (T : вДЭ) :
    Monotone (fun X => discreteCountingPrimitive D T X) := by
  classical
  intro X Y hXY
  unfold discreteCountingPrimitive
  apply Finset.sum_le_sum
  intro j _
  have hmult_nn : (0 : вДЭ) вЙ§ (D.mult j : вДЭ) := Nat.cast_nonneg _
  by_cases hTX : T вЙ§ D.Z j
  ¬Ј by_cases hZX : D.Z j вЙ§ X
    ¬Ј have hZY : D.Z j вЙ§ Y := le_trans hZX hXY
      have hX_pair : T вЙ§ D.Z j вИІ D.Z j вЙ§ X := вЯ®hTX, hZXвЯ©
      have hY_pair : T вЙ§ D.Z j вИІ D.Z j вЙ§ Y := вЯ®hTX, hZYвЯ©
      rw [if_pos hX_pair, if_pos hY_pair]
    ¬Ј by_cases hZY : D.Z j вЙ§ Y
      ¬Ј have hY_pair : T вЙ§ D.Z j вИІ D.Z j вЙ§ Y := вЯ®hTX, hZYвЯ©
        have hX_nopair : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ X) := fun вЯ®_, hвЯ© => hZX h
        rw [if_neg hX_nopair, if_pos hY_pair]
        exact hmult_nn
      ¬Ј have hX_nopair : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ X) := fun вЯ®_, hвЯ© => hZX h
        have hY_nopair : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ Y) := fun вЯ®_, hвЯ© => hZY h
        rw [if_neg hX_nopair, if_neg hY_nopair]
  ¬Ј have hX_nopair : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ X) := fun вЯ®h, _вЯ© => hTX h
    have hY_nopair : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ Y) := fun вЯ®h, _вЯ© => hTX h
    rw [if_neg hX_nopair, if_neg hY_nopair]

/-- **Ordered-zero-list fluctuation data.** Extends `FluctuationMeasureData`
with monotonicity of the ordinate sequence вАФ the discrete Abel summation
needs the ordinates in order. -/
structure OrderedFluctuationMeasureData extends FluctuationMeasureData where
  mono_Z : Monotone Z

/-- **Clipped weight**: `a_j = mult_j` if `T вЙ§ Z_j вЙ§ X`, else `0`. -/
noncomputable def clippedWeight
    (D : FluctuationMeasureData) (T X : вДЭ) : вДХ вЖТ вДЭ :=
  fun j => if T вЙ§ D.Z j вИІ D.Z j вЙ§ X then (D.mult j : вДЭ) else 0

/-- в≠Р **PROVED вАФ `discreteKernelPartial` rewritten as a clipped pure sum.**
The clipped weight absorbs the indicator so the partial collapses to
`вИС a_j ¬Ј b_j` for `a_j = clippedWeight`, `b_j = f (Z_j)`. -/
lemma discreteKernelPartial_eq_clippedSum
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) :
    discreteKernelPartial D f T X
      =
    вИС j вИИ Finset.range D.n,
      clippedWeight D T X j * f (D.Z j) := by
  unfold discreteKernelPartial clippedWeight
  apply Finset.sum_congr rfl
  intro j _
  by_cases h : T вЙ§ D.Z j вИІ D.Z j вЙ§ X
  ¬Ј rw [if_pos h, if_pos h]
  ¬Ј rw [if_neg h, if_neg h, zero_mul]

/-- в≠Р **PROVED вАФ `discreteCountingPrimitive` is the sum of `clippedWeight`.** -/
lemma discreteCountingPrimitive_eq_clippedSum
    (D : FluctuationMeasureData) (T X : вДЭ) :
    discreteCountingPrimitive D T X
      = вИС j вИИ Finset.range D.n, clippedWeight D T X j := rfl

/-- рЯМЯ **PROVED вАФ RAW ABEL IDENTITY** for the ordered discrete kernel
partial over `Finset.range (m + 1)`, with `D.n = m + 1`.

  `discreteKernelPartial D f T X
     = (вИС clippedWeight) ¬Ј f (Z m)
       вИТ вИС_{j < m} (cumulative clippedWeight up to j) ¬Ј (f (Z_{j+1}) вИТ f (Z_j))`

The discrete-side analogue of `smooth_zeroDensity_kernel_ibp` (¬ІCXCI),
generic in the integrand. -/
theorem ordered_discrete_kernel_abel_clipped
    (D : OrderedFluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) {m : вДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (вИС j вИИ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) * f (D.Z m)
      -
    вИС j вИИ Finset.range m,
      (вИС i вИИ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (f (D.Z (j + 1)) - f (D.Z j)) := by
  rw [discreteKernelPartial_eq_clippedSum, hn]
  exact fin_sum_mul_eq_boundary_sub_sum_succ m
    (fun j => clippedWeight D.toFluctuationMeasureData T X j)
    (fun j => f (D.Z j))

/-- рЯМЯ **PROVED вАФ paired-Cauchy-imaginary kernel Abel identity.**
Specializes `ordered_discrete_kernel_abel_clipped` to
`f := pairedCauchyImKernel x y`. This is the discrete-side companion
to `smooth_zeroDensity_kernel_ibp` (¬ІCXCI). -/
theorem ordered_discrete_pairedCauchyIm_abel_clipped
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    (вИС j вИИ Finset.range D.n,
        clippedWeight D.toFluctuationMeasureData T X j) *
          pairedCauchyImKernel x y (D.Z m)
      -
    вИС j вИИ Finset.range m,
      (вИС i вИИ Finset.range (j + 1),
          clippedWeight D.toFluctuationMeasureData T X i) *
        (pairedCauchyImKernel x y (D.Z (j + 1))
          - pairedCauchyImKernel x y (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- ¬ІCXCII-B. Named primitives, Abel remainder, finite fluctuation
-- =====================================================================
-- Wraps the Abel identity in readable named forms:
--   вАҐ `clippedCumulativeWeight`: the prefix-sum primitive appearing on
--     the Abel RHS (this is `discreteCountingPrimitive` restricted to
--     `Finset.range (j + 1)`);
--   вАҐ `discreteAbelRemainder f`: the sum of cumulative √Ч kernel-difference
--     terms (the discrete analogue of `вИЂ S¬Јk'`);
--   вАҐ `discreteKernelAbelRemainder`: paired-Cauchy specialization;
--   вАҐ `ordered_discrete_kernel_ibp_raw`: the compact discrete IBP.

/-- **Cumulative clipped weight** through index `j`:
  `ќ£_{i вЙ§ j} clippedWeight i = ќ£_{i вЙ§ j, T вЙ§ Z i вЙ§ X} mult i`. -/
noncomputable def clippedCumulativeWeight
    (D : OrderedFluctuationMeasureData) (T X : вДЭ) (j : вДХ) : вДЭ :=
  вИС i вИИ Finset.range (j + 1), clippedWeight D.toFluctuationMeasureData T X i

/-- в≠Р **PROVED вАФ `clippedCumulativeWeight` unfolds to the discrete
counting prefix sum (rfl).** -/
lemma clippedCumulativeWeight_eq_discreteCountingPrefix
    (D : OrderedFluctuationMeasureData) (T X : вДЭ) (j : вДХ) :
    clippedCumulativeWeight D T X j
      =
    вИС i вИИ Finset.range (j + 1),
      if T вЙ§ D.Z i вИІ D.Z i вЙ§ X then (D.mult i : вДЭ) else 0 := rfl

/-- в≠Р **PROVED вАФ Abel identity with the named primitives.** Rewrites
`ordered_discrete_kernel_abel_clipped` using `discreteCountingPrimitive`
and `clippedCumulativeWeight`. Pure renaming; defeq through both. -/
theorem ordered_discrete_kernel_abel_clipped_named
    (D : OrderedFluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) {m : вДХ}
    (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData f T X
      =
    (discreteCountingPrimitive D.toFluctuationMeasureData T X) * f (D.Z m)
      -
    вИС j вИИ Finset.range m,
      clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j)) :=
  ordered_discrete_kernel_abel_clipped D f T X hn

/-- **Discrete Abel remainder** for an arbitrary integrand `f`:
the sum of cumulative weights √Ч kernel differences. Discrete analogue
of `вИЂ_T^X S(u)¬Јf'(u) du`. -/
noncomputable def discreteAbelRemainder
    (D : OrderedFluctuationMeasureData) (f : вДЭ вЖТ вДЭ)
    (T X : вДЭ) (m : вДХ) : вДЭ :=
  вИС j вИИ Finset.range m,
    clippedCumulativeWeight D T X j * (f (D.Z (j + 1)) - f (D.Z j))

/-- **Discrete Abel remainder** specialized to the imaginary
paired-Cauchy kernel. -/
noncomputable def discreteKernelAbelRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) (m : вДХ) : вДЭ :=
  discreteAbelRemainder D (fun u => pairedCauchyImKernel x y u) T X m

/-- рЯМЯ **PROVED вАФ RAW DISCRETE IBP** for the imaginary paired-Cauchy
kernel against the clipped zero counts, in named-primitive form:

  `discreteKernelPartial D k T X
     = discreteCountingPrimitive D T X ¬Ј k(Z_m)
       вИТ discreteKernelAbelRemainder D x y T X m`.

The compact discrete-side companion to `smooth_zeroDensity_kernel_ibp`. -/
theorem ordered_discrete_kernel_ibp_raw
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m := by
  unfold discreteKernelAbelRemainder discreteAbelRemainder
  exact ordered_discrete_kernel_abel_clipped_named D
    (fun u => pairedCauchyImKernel x y u) T X hn

-- =====================================================================
-- ¬ІCXCIII. Finite fluctuation primitive + raw combined IBP
-- =====================================================================
-- Now combine the smooth (¬ІCXCI) and discrete (¬ІCXCII) halves into the
-- finite-window fluctuation IBP identity.
--
--   `S_total(u) := S_discrete(u) вИТ S_smooth(u)`
--   `F(T, X)   := вИЂ_T^X k dS_total = discreteKernelPartial вИТ вИЂ k¬ЈѕБ`
--
-- The raw identity reads
--
--   `F(T, X) = N(X)¬Јk(Z_m) вИТ R_discrete
--             вИТ (k(X)¬ЈS_smooth(X) вИТ k(T)¬ЈS_smooth(T) вИТ вИЂ S_smooth ¬Ј k')`
--
-- Note: the boundary on the discrete side is at `k(Z_m)`, not yet at
-- `k(X)`. The endpoint correction is ¬ІCXCIV (next patch).

/-- **Finite fluctuation primitive**:
  `S(T, X) := N(X) вИТ S_smooth(X)` (discrete count minus smooth integral). -/
noncomputable def finiteFluctuationPrimitive
    (D : OrderedFluctuationMeasureData) (T X : вДЭ) : вДЭ :=
  discreteCountingPrimitive D.toFluctuationMeasureData T X
    - smoothCountingPrimitive T X

/-- в≠Р **PROVED вАФ finite fluctuation primitive at the left endpoint.**
`S_smooth(T) = 0`, so `S(T, T) = N(T, T)`. -/
lemma finiteFluctuationPrimitive_left
    (D : OrderedFluctuationMeasureData) (T : вДЭ) :
    finiteFluctuationPrimitive D T T
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T T := by
  simp [finiteFluctuationPrimitive, smoothCountingPrimitive_self]

/-- в≠Р **PROVED вАФ when there is no zero atom at `T`, the discrete count
at `X = T` vanishes.** Optional convention; keeps boundary atoms
visible by being separately stated rather than baked into the
primitive. -/
lemma discreteCountingPrimitive_left_zero_of_no_atom
    (D : FluctuationMeasureData) (T : вДЭ)
    (hno : вИА j вИИ Finset.range D.n, D.Z j вЙ† T) :
    discreteCountingPrimitive D T T = 0 := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j hj
  have hnot : ¬ђ (T вЙ§ D.Z j вИІ D.Z j вЙ§ T) := by
    intro h
    exact hno j hj (le_antisymm h.2 h.1)
  simp [hnot]

/-- **Finite fluctuation kernel partial** for the imaginary paired-Cauchy
kernel:
  `F(T, X) := ќ£_clipped mult¬Јk(Z) вИТ вИЂ_T^X k¬ЈѕБ`. -/
noncomputable def finiteFluctuationKernelPartial
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) : вДЭ :=
  discreteKernelPartial D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X
    -
  вИЂ u in T..X,
      pairedCauchyImKernel x y u * zeroDensityRho u

/-- **Raw mixed remainder** combining the discrete Abel remainder and
the smooth integral `вИЂ S_smooth ¬Ј k'`. The first ingredient of the
finite fluctuation IBP body. -/
noncomputable def finiteFluctuationRawRemainder
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) (m : вДХ) : вДЭ :=
  discreteKernelAbelRemainder D x y T X m
    -
  вИЂ u in T..X,
      smoothCountingPrimitive T u *
        pairedCauchyImKernelDeriv x y u

/-- рЯМЯрЯМЯ **PROVED вАФ RAW FINITE FLUCTUATION IBP IDENTITY.**

Combines `ordered_discrete_kernel_ibp_raw` (¬ІCXCII) and
`smooth_zeroDensity_kernel_ibp` (¬ІCXCI) into

  `finiteFluctuationKernelPartial D x y T X
     = N(X)¬Јk(Z_m) вИТ R_discrete
       вИТ (k(X)¬ЈS_smooth(X) вИТ k(T)¬ЈS_smooth(T) вИТ вИЂ S_smooth¬Јk')`.

The boundary on the discrete side is at `k(Z_m)` (the last ordinate of
the indexed finite list), NOT yet at `k(X)`. Bringing the boundary to
`k(X)` requires the endpoint correction `k(X) вИТ k(Z_m)`, which is
¬ІCXCIV. This raw form is the honest output of summation-by-parts plus
FTC IBP. -/
theorem finiteFluctuationKernelPartial_raw_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T вЙ§ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y (D.Z m)
      -
    discreteKernelAbelRemainder D x y T X m
      -
    (pairedCauchyImKernel x y X * smoothCountingPrimitive T X
      - pairedCauchyImKernel x y T * smoothCountingPrimitive T T
      - вИЂ u in T..X,
          smoothCountingPrimitive T u *
            pairedCauchyImKernelDeriv x y u) := by
  unfold finiteFluctuationKernelPartial
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn,
      smooth_zeroDensity_kernel_ibp hy x T X hT hTX]

-- =====================================================================
-- ¬ІCXCIV. Endpoint correction вАФ shift boundary from k(Z_m) to k(X)
-- =====================================================================
-- The raw discrete IBP boundary is `N ¬Ј k(Z_m)`. Analytic estimates want
-- the boundary at the cutoff `k(X)`. The difference is the endpoint
-- correction `N ¬Ј (k(X) - k(Z_m))`. Subtracting it gives the
-- analytically clean IBP identity.

/-- **Generic discrete Abel endpoint correction**: the boundary delta
between `f(X)` and `f(D.Z m)` scaled by the discrete count primitive. -/
noncomputable def discreteAbelEndpointCorrection
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) (m : вДХ) : вДЭ :=
  discreteCountingPrimitive D T X * (f X - f (D.Z m))

/-- в≠Р **PROVED вАФ Endpoint-corrected discrete IBP (paired Cauchy
kernel).** Rearranges `ordered_discrete_kernel_ibp_raw` so the boundary
uses `pairedCauchyImKernel x y X` instead of `pairedCauchyImKernel x y (D.Z m)`,
introducing the endpoint correction term explicitly. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteAbelEndpointCorrection D.toFluctuationMeasureData
      (fun u => pairedCauchyImKernel x y u) T X m := by
  rw [ordered_discrete_kernel_ibp_raw D x y T X hn]
  unfold discreteAbelEndpointCorrection
  ring

/-- **Paired-Cauchy specialization** of the discrete Abel endpoint
correction. -/
noncomputable def discreteKernelEndpointCorrection
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ) : вДЭ :=
  discreteAbelEndpointCorrection D.toFluctuationMeasureData
    (fun u => pairedCauchyImKernel x y u) T X m

/-- в≠Р **PROVED вАФ Endpoint-corrected discrete IBP**, paired-kernel form
using the specialized `discreteKernelEndpointCorrection`. -/
theorem ordered_discrete_kernel_ibp_endpoint_corrected_paired
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ} (hn : D.n = m + 1) :
    discreteKernelPartial D.toFluctuationMeasureData
        (fun u => pairedCauchyImKernel x y u) T X
      =
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      * pairedCauchyImKernel x y X
      -
    discreteKernelAbelRemainder D x y T X m
      -
    discreteKernelEndpointCorrection D x y T X m := by
  unfold discreteKernelEndpointCorrection
  exact ordered_discrete_kernel_ibp_endpoint_corrected D x y T X hn

/-- **Combined endpoint correction** for the finite fluctuation IBP.
Same data as the discrete endpoint correction (the smooth side has its
boundary at `k(X) ¬Ј S_smooth(X)` already, so no smooth correction). -/
noncomputable def finiteFluctuationEndpointCorrection
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) (m : вДХ) : вДЭ :=
  discreteKernelEndpointCorrection D x y T X m

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ Endpoint-corrected finite fluctuation IBP.**
The analytically clean shape:

  `finiteFluctuationKernelPartial D x y T X
     = finiteFluctuationPrimitive D T X ¬Ј k(X)
       вИТ finiteFluctuationRawRemainder D x y T X m
       вИТ finiteFluctuationEndpointCorrection D x y T X m`.

Both boundaries now align at `k(X)`. Uses `smoothCountingPrimitive_self`
to discharge `S_smooth(T) = 0` (so the `k(T) ¬Ј S_smooth(T)` term in the
raw IBP vanishes). -/
theorem finiteFluctuationKernelPartial_endpoint_corrected_ibp
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ} (hn : D.n = m + 1)
    (hT : 0 < T) (hTX : T вЙ§ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    finiteFluctuationPrimitive D T X
      * pairedCauchyImKernel x y X
      -
    finiteFluctuationRawRemainder D x y T X m
      -
    finiteFluctuationEndpointCorrection D x y T X m := by
  rw [finiteFluctuationKernelPartial_raw_ibp D x y T X hn hT hTX hy]
  unfold finiteFluctuationPrimitive finiteFluctuationRawRemainder
        finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection
        discreteAbelEndpointCorrection
  rw [smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- ¬ІCXCIV-bounds: Endpoint correction zero case + absolute bounds
-- =====================================================================
-- Makes the endpoint correction harmless: it vanishes when X is chosen
-- AT an atom (X = D.Z m), and is bounded by `count ¬Ј |k(X)-k(D.Z m)|`
-- otherwise. Then a Lipschitz-style wrapper lets future kernel-derivative
-- bounds slot in. Finally `..._abs_le_of_parts` combines raw remainder +
-- endpoint correction bounds via the triangle inequality.

/-- в≠Р **PROVED вАФ Generic endpoint correction vanishes** when `X = D.Z m`. -/
theorem discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) (m : вДХ)
    (hX : X = D.Z m) :
    discreteAbelEndpointCorrection D f T X m = 0 := by
  unfold discreteAbelEndpointCorrection
  rw [hX]
  ring

/-- в≠Р **PROVED вАФ Paired-Cauchy endpoint correction vanishes** at `X = D.Z m`. -/
theorem discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ)
    (hX : X = D.Z m) :
    discreteKernelEndpointCorrection D x y T X m = 0 := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_eq_zero_of_X_eq_Z
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m hX

/-- в≠Р **PROVED вАФ Combined endpoint correction vanishes** at `X = D.Z m`. -/
theorem finiteFluctuationEndpointCorrection_eq_zero_of_X_eq_Z
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ)
    (hX : X = D.Z m) :
    finiteFluctuationEndpointCorrection D x y T X m = 0 := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_eq_zero_of_X_eq_Z D x y T X m hX

/-- в≠Р **PROVED вАФ Generic endpoint correction absolute bound.** -/
theorem discreteAbelEndpointCorrection_abs_le
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) (m : вДХ) :
    |discreteAbelEndpointCorrection D f T X m|
      вЙ§ |discreteCountingPrimitive D T X|
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul]

/-- в≠Р **PROVED вАФ Cleaner bound** when the count primitive is nonneg. -/
theorem discreteAbelEndpointCorrection_abs_le_count
    (D : FluctuationMeasureData) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) (m : вДХ)
    (hN : 0 вЙ§ discreteCountingPrimitive D T X) :
    |discreteAbelEndpointCorrection D f T X m|
      вЙ§ discreteCountingPrimitive D T X
          * |f X - f (D.Z m)| := by
  unfold discreteAbelEndpointCorrection
  rw [abs_mul, abs_of_nonneg hN]

/-- в≠Р **PROVED вАФ Paired-Cauchy endpoint absolute bound.** -/
theorem discreteKernelEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ) :
    |discreteKernelEndpointCorrection D x y T X m|
      вЙ§ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold discreteKernelEndpointCorrection
  exact discreteAbelEndpointCorrection_abs_le
    D.toFluctuationMeasureData (fun u => pairedCauchyImKernel x y u) T X m

/-- в≠Р **PROVED вАФ Combined finite-fluctuation endpoint absolute bound.** -/
theorem finiteFluctuationEndpointCorrection_abs_le
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ) :
    |finiteFluctuationEndpointCorrection D x y T X m|
      вЙ§ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := by
  unfold finiteFluctuationEndpointCorrection
  exact discreteKernelEndpointCorrection_abs_le D x y T X m

/-- в≠Р **PROVED вАФ Lipschitz-hypothesis wrapper.**
Given an externally-supplied kernel-difference bound `K ¬Ј |X вИТ D.Z m|`,
yields `count ¬Ј K ¬Ј |X вИТ D.Z m|`. Future kernel-derivative work can plug
the Lipschitz `K` here without re-proving the structural bound. -/
theorem discreteKernelEndpointCorrection_abs_le_deriv_bound
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ) (K : вДЭ)
    (hN : 0 вЙ§ discreteCountingPrimitive D.toFluctuationMeasureData T X)
    (hLip :
      |pairedCauchyImKernel x y X
        - pairedCauchyImKernel x y (D.Z m)|
        вЙ§ K * |X - D.Z m|) :
    |discreteKernelEndpointCorrection D x y T X m|
      вЙ§ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by
  have h0 :
      |discreteKernelEndpointCorrection D x y T X m|
        вЙ§ |discreteCountingPrimitive D.toFluctuationMeasureData T X|
            * |pairedCauchyImKernel x y X
                - pairedCauchyImKernel x y (D.Z m)| :=
    discreteKernelEndpointCorrection_abs_le D x y T X m
  rw [abs_of_nonneg hN] at h0
  have h_step :
      discreteCountingPrimitive D.toFluctuationMeasureData T X
        * |pairedCauchyImKernel x y X
            - pairedCauchyImKernel x y (D.Z m)|
        вЙ§ discreteCountingPrimitive D.toFluctuationMeasureData T X
            * (K * |X - D.Z m|) :=
    mul_le_mul_of_nonneg_left hLip hN
  calc |discreteKernelEndpointCorrection D x y T X m|
      вЙ§ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * |pairedCauchyImKernel x y X
              - pairedCauchyImKernel x y (D.Z m)| := h0
    _ вЙ§ discreteCountingPrimitive D.toFluctuationMeasureData T X
          * (K * |X - D.Z m|) := h_step
    _ = discreteCountingPrimitive D.toFluctuationMeasureData T X
          * K * |X - D.Z m| := by ring

/-- **Per-piece IBP-correction bound predicate.**
The IBP body has two analytic terms to bound: the raw remainder and the
endpoint correction. This predicate names both budgets simultaneously. -/
def finiteFluctuationRemainderControlled
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ)
    (Braw Bend : вДЭ) : Prop :=
  |finiteFluctuationRawRemainder D x y T X m| вЙ§ Braw вИІ
  |finiteFluctuationEndpointCorrection D x y T X m| вЙ§ Bend

/-- в≠Р **PROVED вАФ Triangle inequality combines raw + endpoint bounds.**
The full IBP correction (raw remainder + endpoint correction) is bounded
by the sum of the individual bounds. The abstract building block that
turns piece-wise IBP estimates into a single error budget. -/
theorem finiteFluctuationCorrection_abs_le_of_parts
    {D : OrderedFluctuationMeasureData} {x y T X : вДЭ} {m : вДХ}
    {Braw Bend : вДЭ}
    (hraw : |finiteFluctuationRawRemainder D x y T X m| вЙ§ Braw)
    (hend : |finiteFluctuationEndpointCorrection D x y T X m| вЙ§ Bend) :
    |finiteFluctuationRawRemainder D x y T X m
      + finiteFluctuationEndpointCorrection D x y T X m|
      вЙ§ Braw + Bend := by
  calc |finiteFluctuationRawRemainder D x y T X m
        + finiteFluctuationEndpointCorrection D x y T X m|
      вЙ§ |finiteFluctuationRawRemainder D x y T X m|
        + |finiteFluctuationEndpointCorrection D x y T X m| := abs_add _ _
    _ вЙ§ Braw + Bend := add_le_add hraw hend

-- =====================================================================
-- ¬ІCXCV. FTC bridge вАФ Abel sums вЖТ interval integrals of N ¬Ј k'
-- =====================================================================
-- Goal:
--   `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
--      = вИЂ_T^X N(u) ¬Ј k'(u) du`
-- under clean window assumptions (`OrderedWindow`): all indexed
-- ordinates lie in `[T, X]` and are strictly increasing.
--
-- Strategy (Option A вАФ Window):
--   1. Express the clipped weights as raw `mult` (clipping is trivial
--      since every `Z_j вИИ [T, X]`).
--   2. Rewrite the cumulative weights as the unclipped partial sums.
--   3. Decompose `N(u)` as `вИС_i mult_i ¬Ј [Z_i вЙ§ u]` on `[T, X]`.
--   4. By linearity + a per-`i` FTC identity
--        `вИЂ_T^X [Z_i вЙ§ u] ¬Ј k'(u) du = k(X) вИТ k(Z_i)`
--      the integral equals `вИС_i mult_i ¬Ј (k(X) вИТ k(Z_i))`.
--   5. This matches `R + EC` via the endpoint-corrected discrete IBP.
--
-- Steps 1вАУ3 and 5 are pure algebra and land here. Step 4 вАФ the
-- indicator-against-`k'` FTC integral вАФ is the genuine analytic
-- content; it lives as a Prop hypothesis on the headline theorem,
-- matching the file's "capstone consumes Prop hypotheses" pattern.

/-- **Ordered-window data**: every indexed ordinate lies inside
`[T, X]` and the ordinates are strictly increasing. The clean
hypothesis package that lets the Abel/FTC bridge land without
juggling boundary atoms or duplicate ordinates. -/
structure OrderedWindow
    (D : OrderedFluctuationMeasureData) (T X : вДЭ) (m : вДХ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T вЙ§ D.Z 0
  hlast_le_X  : D.Z m вЙ§ X
  hstrict     : вИА j, j < m вЖТ D.Z j < D.Z (j + 1)

/-- в≠Р **PROVED вАФ under `OrderedWindow`, every indexed ordinate
`Z_j` lies in `[T, X]`.** Monotonicity from `D.mono_Z` together with
`T вЙ§ Z_0` and `Z_m вЙ§ X` does the job. -/
lemma OrderedWindow.Z_mem_window
    {D : OrderedFluctuationMeasureData} {T X : вДЭ} {m j : вДХ}
    (W : OrderedWindow D T X m) (hj : j вЙ§ m) :
    T вЙ§ D.Z j вИІ D.Z j вЙ§ X := by
  refine вЯ®?_, ?_вЯ©
  ¬Ј exact le_trans W.hT_le_first (D.mono_Z (Nat.zero_le j))
  ¬Ј exact le_trans (D.mono_Z hj) W.hlast_le_X

/-- в≠Р **PROVED вАФ under `OrderedWindow`, the clipped weight equals the
raw multiplicity for every `j вЙ§ m`.** -/
lemma clippedWeight_eq_mult_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : вДЭ} {m j : вДХ}
    (W : OrderedWindow D T X m) (hj : j вЙ§ m) :
    clippedWeight D.toFluctuationMeasureData T X j = (D.mult j : вДЭ) := by
  unfold clippedWeight
  rw [if_pos (W.Z_mem_window hj)]

/-- в≠Р **PROVED вАФ under `OrderedWindow`, the clipped cumulative weight
through index `j вЙ§ m` equals the unclipped partial sum
`вИС_{i вЙ§ j} mult_i`.** -/
lemma clippedCumulativeWeight_eq_partialSum_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : вДЭ} {m j : вДХ}
    (W : OrderedWindow D T X m) (hj : j вЙ§ m) :
    clippedCumulativeWeight D T X j
      = вИС i вИИ Finset.range (j + 1), (D.mult i : вДЭ) := by
  unfold clippedCumulativeWeight
  apply Finset.sum_congr rfl
  intro i hi
  have hi_le_m : i вЙ§ m := by
    have hi_lt : i < j + 1 := Finset.mem_range.mp hi
    omega
  exact clippedWeight_eq_mult_of_orderedWindow W hi_le_m

/-- в≠Р **PROVED вАФ under `OrderedWindow`, the full clipped sum
(= `discreteCountingPrimitive D T X` = `N(X)`) equals the total
multiplicity.** -/
lemma discreteCountingPrimitive_full_of_orderedWindow
    {D : OrderedFluctuationMeasureData} {T X : вДЭ} {m : вДХ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T X
      = вИС i вИИ Finset.range D.n, (D.mult i : вДЭ) := by
  rw [discreteCountingPrimitive_eq_clippedSum, W.hn]
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < m + 1 := Finset.mem_range.mp hi
  exact clippedWeight_eq_mult_of_orderedWindow W (by omega)

/-- **Per-`i` FTC integrand identity (analytic hypothesis).** For each
ordinate `Z_i` in the window, the indicator-against-kernel-derivative
integral equals the kernel boundary difference:

  `вИЂ_T^X [Z_i вЙ§ u] ¬Ј k'(u) du = k(X) вИТ k(Z_i)`.

This is the genuine analytic content of the ¬ІCXCV bridge вАФ it
encapsulates an interval split at `Z_i` plus FTC on `[Z_i, X]` for
`pairedCauchyImKernel` (the indicator vanishes on `[T, Z_i)`).
Packaged as a Prop so the bridge theorem itself stays algebraic. -/
def IndicatorKernelFTCHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (m : вДХ) : Prop :=
  вИА i вИИ Finset.range D.n, i вЙ§ m вЖТ
    (вИЂ u in T..X,
        (if D.Z i вЙ§ u then (1 : вДЭ) else 0) * pairedCauchyImKernelDeriv x y u)
      = pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)

/-- **Linearity hypothesis**: pulling the finite sum over `i вИИ range n`
out of the kernel-derivative integral. Mathlib's
`intervalIntegral.integral_finset_sum` discharges this given pointwise
integrability of each summand; packaged as a Prop to keep the algebraic
core focused. -/
def IntegralSumLinearityHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) : Prop :=
  (вИЂ u in T..X,
      (вИС i вИИ Finset.range D.n,
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0))
        * pairedCauchyImKernelDeriv x y u)
    =
  вИС i вИИ Finset.range D.n,
    (D.mult i : вДЭ) *
      вИЂ u in T..X,
        (if D.Z i вЙ§ u then (1 : вДЭ) else 0) * pairedCauchyImKernelDeriv x y u

/-- **N(u) decomposition hypothesis**: under `OrderedWindow`, the
clipped counting primitive at any inner `u вИИ [T, X]` agrees with the
unclipped indicator sum `вИС_i mult_i ¬Ј [Z_i вЙ§ u]`. Packaged as an
integrand-level equality so the integral can be congruenced. -/
def NDecompositionIntegrandHypothesis
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) : Prop :=
  (вИЂ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
    =
  вИЂ u in T..X,
    (вИС i вИИ Finset.range D.n,
      (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0))
      * pairedCauchyImKernelDeriv x y u

/-- в≠Р **PROVED вАФ algebraic Abel-sum closed form** for `R + EC` under
`OrderedWindow`:

  `discreteKernelAbelRemainder + discreteAbelEndpointCorrection
     = вИС_{i вЙ§ m} mult_i ¬Ј (k(X) вИТ k(Z_i))`.

Derivation: invoke the endpoint-corrected discrete IBP to convert the
LHS to `N(X) ¬Ј k(X) вИТ discreteKernelPartial`; expand both via
`OrderedWindow` and rearrange. -/
theorem discrete_remainder_plus_correction_eq_explicit_sum
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    вИС i вИИ Finset.range D.n,
      (D.mult i : вДЭ) *
        (pairedCauchyImKernel x y X - pairedCauchyImKernel x y (D.Z i)) := by
  -- Endpoint-corrected discrete IBP: partial = N¬Јk(X) вИТ R вИТ EC.
  have h_ibp :=
    ordered_discrete_kernel_ibp_endpoint_corrected D x y T X W.hn
  -- Solve for R + EC: R + EC = N¬Јk(X) вИТ partial.
  have h_RE :
      discreteKernelAbelRemainder D x y T X m
        + discreteAbelEndpointCorrection D.toFluctuationMeasureData
            (fun u => pairedCauchyImKernel x y u) T X m
        = discreteCountingPrimitive D.toFluctuationMeasureData T X
            * pairedCauchyImKernel x y X
          - discreteKernelPartial D.toFluctuationMeasureData
              (fun u => pairedCauchyImKernel x y u) T X := by
    linarith [h_ibp]
  rw [h_RE]
  -- Now expand `partial` under OrderedWindow: clipping vanishes.
  have h_partial :
      discreteKernelPartial D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X
        = вИС i вИИ Finset.range D.n,
            (D.mult i : вДЭ) * pairedCauchyImKernel x y (D.Z i) := by
    unfold discreteKernelPartial
    rw [W.hn]
    apply Finset.sum_congr rfl
    intro i hi
    have hi_lt : i < m + 1 := Finset.mem_range.mp hi
    have hi_le_m : i вЙ§ m := by omega
    rw [if_pos (W.Z_mem_window hi_le_m)]
  rw [h_partial, discreteCountingPrimitive_full_of_orderedWindow W]
  -- N(X) ¬Ј k(X) вИТ вИС mult_i ¬Ј k(Z_i) = вИС mult_i ¬Ј (k(X) вИТ k(Z_i))
  rw [Finset.sum_mul, вЖР Finset.sum_sub_distrib]
  apply Finset.sum_congr rfl
  intro i _
  ring

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ FTC BRIDGE: discrete Abel + endpoint correction
= integral of `N ¬Ј k'`** (under OrderedWindow + analytic hypotheses).

Identifies the discrete Abel remainder plus the endpoint correction
with the interval integral

  `вИЂ_T^X N(u) ¬Ј k'(u) du`,

routing the genuine analytic content through three Prop hypotheses:
the N-decomposition integrand rewrite, the integral-linearity swap,
and the per-`i` indicator-FTC identity. With all three discharged
(future work via Mathlib's `intervalIntegral.integral_finset_sum`,
`integral_congr`, and `integral_eq_sub_of_hasDerivAt`), this is the
first finite-window FTC bridge from Abel sums to step-function
integrals. -/
theorem discrete_corrected_remainder_eq_intervalIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m)
    (h_decomp : NDecompositionIntegrandHypothesis D x y T X)
    (h_linear : IntegralSumLinearityHypothesis D x y T X)
    (h_ftc : IndicatorKernelFTCHypothesis D x y T X m) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    вИЂ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
  -- Algebraic side: R + EC = вИС mult_i ¬Ј (k(X) вИТ k(Z_i)).
  rw [discrete_remainder_plus_correction_eq_explicit_sum D x y T X W]
  -- Analytic side: rewrite the integral through the three hypotheses.
  rw [h_decomp, h_linear]
  -- Now the integral side is вИС mult_i ¬Ј (вИЂ indicator ¬Ј k').
  -- Discharge each per-`i` via the FTC hypothesis.
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i вЙ§ m := by rw [W.hn] at hi_lt; omega
  rw [h_ftc i hi hi_le_m]

-- =====================================================================
-- ¬ІCXCVI-A. Discharge `NDecompositionIntegrandHypothesis`
-- =====================================================================
-- Under `OrderedWindow`, the clipping condition `T вЙ§ Z_i вИІ Z_i вЙ§ u`
-- collapses to `Z_i вЙ§ u` (the `T вЙ§ Z_i` part is automatic). The
-- counting primitive then equals `вИС_i mult_i ¬Ј [Z_i вЙ§ u]` pointwise
-- (for every `u`, not just `u вИИ [T, X]`), so the integrand rewrite
-- discharges via `intervalIntegral.integral_congr`.

/-- в≠Р **PROVED вАФ pointwise decomposition of `N(u)`** under `OrderedWindow`:
  `discreteCountingPrimitive D T u
     = вИС_i mult_i ¬Ј [Z_i вЙ§ u]`.
Holds for every `u : вДЭ` because the `T вЙ§ Z_i` half of the clipping
condition is automatic from `OrderedWindow`. -/
lemma discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (T X u : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) :
    discreteCountingPrimitive D.toFluctuationMeasureData T u
      =
    вИС i вИИ Finset.range D.n,
      (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0) := by
  classical
  unfold discreteCountingPrimitive
  apply Finset.sum_congr rfl
  intro i hi
  have hi_lt : i < D.n := Finset.mem_range.mp hi
  have hi_le_m : i вЙ§ m := by rw [W.hn] at hi_lt; omega
  have hT_Zi : T вЙ§ D.Z i := (W.Z_mem_window hi_le_m).1
  by_cases hZi_u : D.Z i вЙ§ u
  ¬Ј have hclip : T вЙ§ D.Z i вИІ D.Z i вЙ§ u := вЯ®hT_Zi, hZi_uвЯ©
    rw [if_pos hclip, if_pos hZi_u, mul_one]
  ¬Ј have hclip : ¬ђ (T вЙ§ D.Z i вИІ D.Z i вЙ§ u) := fun h => hZi_u h.2
    rw [if_neg hclip, if_neg hZi_u, mul_zero]

/-- рЯМЯ **PROVED вАФ `NDecompositionIntegrandHypothesis` discharged**
under `OrderedWindow`. The pointwise lemma plus
`intervalIntegral.integral_congr` does the work. -/
theorem nDecompositionIntegrand_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) :
    NDecompositionIntegrandHypothesis D x y T X := by
  unfold NDecompositionIntegrandHypothesis
  refine intervalIntegral.integral_congr ?_
  intro u _
  show discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      = (вИС i вИИ Finset.range D.n, (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0))
          * pairedCauchyImKernelDeriv x y u
  rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W]

-- =====================================================================
-- ¬ІCXCVI-B-prep. FTC for the paired-Cauchy imaginary kernel derivative
-- =====================================================================
-- Pure FTC: `вИЂ_a^b k'(u) du = k(b) вИТ k(a)`. Independent of indicators.
-- Becomes the engine for `IndicatorKernelFTCHypothesis` once the
-- indicator split lemma lands (next patch).

/-- рЯМЯ **PROVED вАФ FTC for `pairedCauchyImKernel`**:
  `вИЂ_a^b k'(u) du = k(b) вИТ k(a)`.
Direct application of `intervalIntegral.integral_eq_sub_of_hasDerivAt`
with the per-point derivative `pairedCauchyImKernel_hasDerivAt` and
the continuity-based integrability `pairedCauchyImKernelDeriv_intervalIntegrable`. -/
theorem pairedCauchyImKernelDeriv_integral_eq_sub
    {y : вДЭ} (hy : 0 < y) (x a b : вДЭ) :
    (вИЂ u in a..b, pairedCauchyImKernelDeriv x y u)
      =
    pairedCauchyImKernel x y b - pairedCauchyImKernel x y a := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ¬Ј intro u _
    exact pairedCauchyImKernel_hasDerivAt hy x u
  ¬Ј exact pairedCauchyImKernelDeriv_intervalIntegrable hy x a b

-- =====================================================================
-- ¬ІCXCVI-B. Indicator splitting + `IndicatorKernelFTCHypothesis`
-- =====================================================================
-- Key analytic step: for `T вЙ§ a вЙ§ X`,
--   `вИЂ_T^X [a вЙ§ u] ¬Ј k'(u) du = вИЂ_a^X k'(u) du`.
-- Mathlib has `intervalIntegral.integral_indicator` for `Set.Ioi`; we
-- recast `[a вЙ§ u]` (i.e. `Set.Ici a`) to `Set.Ioi a` via an a.e.
-- equality (they differ only at the single point `{a}`, measure 0)
-- and then invoke Mathlib's lemma directly.

-- Strategy that AVOIDS `intervalIntegral.integral_indicator` entirely.
-- That theorem's general type drives the `whnf` budget to zero on the
-- explicit `pairedCauchyImKernelDeriv` rational body. The route below
-- closes the cutoff identity via:
--   1. closed cutoff `[a вЙ§ u]` = strict cutoff `[a < u]` (one AE step)
--   2. split `вИЂ_T^X = вИЂ_T^a + вИЂ_a^X` (adjacent intervals)
--   3. left piece: pointwise zero  (no AE needed under strict cutoff)
--   4. right piece: AE-equal to `g`
--   5. assemble via calc.

/-- в≠Р **PROVED вАФ a.e. on `volume`, every point differs from a fixed `a`.**
Volume-singleton triviality, packaged for use with `filter_upwards`. -/
lemma ae_ne_real (a : вДЭ) :
    вИАбµР u : вДЭ вИВMeasureTheory.volume, u вЙ† a := by
  refine MeasureTheory.ae_iff.mpr ?_
  have h_eq : {u : вДЭ | ¬ђ u вЙ† a} = {a} := by
    ext u
    simp [Set.mem_setOf_eq, Set.mem_singleton_iff, not_not]
  rw [h_eq]
  exact Real.volume_singleton

/-- в≠Р **PROVED вАФ closed cutoff equals strict cutoff in the
interval integral.** Single AE step using `ae_ne_real`. -/
lemma integral_if_le_eq_integral_if_lt
    (g : вДЭ вЖТ вДЭ) (a T X : вДЭ) :
    (вИЂ u in T..X, (if a вЙ§ u then (1 : вДЭ) else 0) * g u)
      =
    вИЂ u in T..X, (if a < u then (1 : вДЭ) else 0) * g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne _
  by_cases hle : a вЙ§ u
  ¬Ј have hlt : a < u := lt_of_le_of_ne hle (Ne.symm hu_ne)
    rw [if_pos hle, if_pos hlt]
  ¬Ј have hnlt : ¬ђ a < u := fun h => hle (le_of_lt h)
    rw [if_neg hle, if_neg hnlt]

/-- в≠Р **PROVED вАФ strict cutoff left piece is zero** on `[T, a]`.
Pointwise: every `u вИИ [T, a]` has `a < u` false (since `u вЙ§ a`). -/
lemma integral_if_lt_left_zero
    (g : вДЭ вЖТ вДЭ) (T a : вДЭ) (hTa : T вЙ§ a) :
    (вИЂ u in T..a, (if a < u then (1 : вДЭ) else 0) * g u) = 0 := by
  have h_eq : вИА u вИИ Set.uIcc T a,
      (if a < u then (1 : вДЭ) else 0) * g u = 0 := by
    intro u hu
    rw [Set.uIcc_of_le hTa] at hu
    have hua : u вЙ§ a := hu.2
    have hnlt : ¬ђ a < u := not_lt.mpr hua
    rw [if_neg hnlt, zero_mul]
  calc (вИЂ u in T..a, (if a < u then (1 : вДЭ) else 0) * g u)
      = вИЂ _ in T..a, (0 : вДЭ) := intervalIntegral.integral_congr h_eq
    _ = 0 := intervalIntegral.integral_zero

/-- в≠Р **PROVED вАФ strict cutoff right piece equals `g`** on `[a, X]`.
Single AE step (since `a < u` fails only at `u = a`). -/
lemma integral_if_lt_right_eq
    (g : вДЭ вЖТ вДЭ) (a X : вДЭ) (haX : a вЙ§ X) :
    (вИЂ u in a..X, (if a < u then (1 : вДЭ) else 0) * g u)
      =
    вИЂ u in a..X, g u := by
  apply intervalIntegral.integral_congr_ae
  filter_upwards [ae_ne_real a] with u hu_ne hu_mem
  rw [Set.uIoc_of_le haX] at hu_mem
  have hau_lt : a < u := hu_mem.1
  rw [if_pos hau_lt, one_mul]

/-- в≠Р **PROVED вАФ strict cutoff √Ч `g`** is interval-integrable on the
left sub-interval `[T, a]`. Integrand is pointwise zero on `(T, a]`
(since `u вЙ§ a вЖТ ¬ђ(a < u)`); congruence with the constant-zero
integrable function discharges. -/
lemma intervalIntegrable_if_lt_mul_left
    (g : вДЭ вЖТ вДЭ) (a T : вДЭ) (hTa : T вЙ§ a) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : вДЭ) else 0) * g u)
      MeasureTheory.volume T a := by
  refine (intervalIntegrable_const (c := (0 : вДЭ))).congr ?_
  rw [Set.uIoc_of_le hTa]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hua : u вЙ§ a := hu.2
  have hnlt : ¬ђ a < u := not_lt.mpr hua
  show (0 : вДЭ) = (if a < u then (1 : вДЭ) else 0) * g u
  rw [if_neg hnlt, zero_mul]

/-- в≠Р **PROVED вАФ strict cutoff √Ч `g`** is interval-integrable on the
right sub-interval `[a, X]` when `g` is. Integrand equals `g` for
`a < u`; congruence with `g` discharges. -/
lemma intervalIntegrable_if_lt_mul_right
    (g : вДЭ вЖТ вДЭ) (a X : вДЭ) (haX : a вЙ§ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume a X) :
    IntervalIntegrable
      (fun u => (if a < u then (1 : вДЭ) else 0) * g u)
      MeasureTheory.volume a X := by
  refine hg_int.congr ?_
  rw [Set.uIoc_of_le haX]
  refine (MeasureTheory.ae_restrict_iff' measurableSet_Ioc).mpr ?_
  refine MeasureTheory.ae_of_all _ ?_
  intro u hu
  have hau : a < u := hu.1
  show g u = (if a < u then (1 : вДЭ) else 0) * g u
  rw [if_pos hau, one_mul]

/-- в≠Р **PROVED вАФ strict cutoff splits cleanly at `a`**:
  `вИЂ_T^X [a < u] ¬Ј g(u) du = вИЂ_a^X g(u) du`.
Uses adjacent-interval splitting, left zero, right `g`. No
`integral_indicator` invocation. -/
lemma integral_if_lt_eq_integral_from_cut
    (g : вДЭ вЖТ вДЭ) (T a X : вДЭ)
    (hTa : T вЙ§ a) (haX : a вЙ§ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (вИЂ u in T..X, (if a < u then (1 : вДЭ) else 0) * g u)
      =
    вИЂ u in a..X, g u := by
  -- split `g`'s integrability to the right sub-interval
  have hTX : T вЙ§ X := le_trans hTa haX
  have h_sub_right : Set.uIcc a X вКЖ Set.uIcc T X := by
    rw [Set.uIcc_of_le haX, Set.uIcc_of_le hTX]
    exact Set.Icc_subset_Icc_left hTa
  have hg_right : IntervalIntegrable g MeasureTheory.volume a X :=
    hg_int.mono_set h_sub_right
  -- indicator-product integrability on each sub-interval
  have h_int_left := intervalIntegrable_if_lt_mul_left g a T hTa
  have h_int_right := intervalIntegrable_if_lt_mul_right g a X haX hg_right
  calc
    (вИЂ u in T..X, (if a < u then (1 : вДЭ) else 0) * g u)
        =
      (вИЂ u in T..a, (if a < u then (1 : вДЭ) else 0) * g u)
        + вИЂ u in a..X, (if a < u then (1 : вДЭ) else 0) * g u :=
        (intervalIntegral.integral_add_adjacent_intervals
          h_int_left h_int_right).symm
    _ = 0 + вИЂ u in a..X, g u := by
          rw [integral_if_lt_left_zero g T a hTa,
              integral_if_lt_right_eq g a X haX]
    _ = вИЂ u in a..X, g u := zero_add _

/-- рЯМЯ **PROVED вАФ generic indicator cutoff identity**:
  `вИЂ_T^X [a вЙ§ u] ¬Ј g(u) du = вИЂ_a^X g(u) du`   for `T вЙ§ a вЙ§ X`.

Routes through strict cutoff to bypass `intervalIntegral.integral_indicator`. -/
theorem indicator_Ici_integral_eq_integral_from_cut
    (g : вДЭ вЖТ вДЭ) (T a X : вДЭ)
    (hTa : T вЙ§ a) (haX : a вЙ§ X)
    (hg_int : IntervalIntegrable g MeasureTheory.volume T X) :
    (вИЂ u in T..X, (if a вЙ§ u then (1 : вДЭ) else 0) * g u)
      =
    вИЂ u in a..X, g u := by
  rw [integral_if_le_eq_integral_if_lt g a T X,
      integral_if_lt_eq_integral_from_cut g T a X hTa haX hg_int]

/-- в≠Р **PROVED вАФ kernel-specific indicator cutoff identity**, by
direct specialization of `indicator_Ici_integral_eq_integral_from_cut`.
The kernel-derivative is interval-integrable from continuity for any
`y > 0` (via `pairedCauchyImKernelDeriv_intervalIntegrable`). -/
theorem pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
    (x y T a X : вДЭ) (hTa : T вЙ§ a) (haX : a вЙ§ X) (hy : 0 < y) :
    (вИЂ u in T..X,
        (if a вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      =
    вИЂ u in a..X, pairedCauchyImKernelDeriv x y u :=
  indicator_Ici_integral_eq_integral_from_cut
    (pairedCauchyImKernelDeriv x y) T a X hTa haX
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X)

/-- рЯМЯрЯМЯ **PROVED вАФ `IndicatorKernelFTCHypothesis` discharged**
under `OrderedWindow`. Combines the indicator cutoff lemma with the
pure FTC for the kernel derivative. -/
theorem indicatorKernelFTC_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IndicatorKernelFTCHypothesis D x y T X m := by
  intro i hi hi_le_m
  have hZi := W.Z_mem_window hi_le_m
  rw [pairedCauchy_indicator_Ici_integral_eq_integral_from_cut
        x y T (D.Z i) X hZi.1 hZi.2 hy]
  exact pairedCauchyImKernelDeriv_integral_eq_sub hy x (D.Z i) X

-- =====================================================================
-- ¬ІCXCVI-C. Discharge `IntegralSumLinearityHypothesis`
-- =====================================================================
-- The indicator √Ч kernel-derivative term is interval-integrable
-- (it equals `Set.indicator (Set.Ici Z_i) (mult_i ¬Ј k')`, where the
-- argument is continuous, hence integrable). Then
-- `intervalIntegral.integral_finset_sum` discharges the sum-linearity.

/-- в≠Р **PROVED вАФ interval integrability of each indicator √Ч kernel
derivative term.** -/
lemma indicator_kernel_deriv_term_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) (i : вДХ)
    (hy : 0 < y) :
    IntervalIntegrable
      (fun u : вДЭ =>
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- The term equals `Set.indicator (Set.Ici (D.Z i)) (mult_i ¬Ј k')`.
  have h_eq :
      (fun u : вДЭ =>
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = Set.indicator (Set.Ici (D.Z i))
          (fun u : вДЭ => (D.mult i : вДЭ) * pairedCauchyImKernelDeriv x y u) := by
    funext u
    by_cases h : D.Z i вЙ§ u
    ¬Ј have hmem : u вИИ Set.Ici (D.Z i) := h
      rw [if_pos h, mul_one, Set.indicator_of_mem hmem]
    ¬Ј have hnmem : u вИЙ Set.Ici (D.Z i) := h
      rw [if_neg h, mul_zero, zero_mul, Set.indicator_of_notMem hnmem]
  rw [h_eq]
  -- `IntervalIntegrable.indicator` isn't in Mathlib; build manually
  -- from the two `IntegrableOn` components.
  have h_const_mul : IntervalIntegrable
      (fun u : вДЭ => (D.mult i : вДЭ) * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
    (pairedCauchyImKernelDeriv_intervalIntegrable hy x T X).const_mul (D.mult i : вДЭ)
  exact вЯ®h_const_mul.1.indicator measurableSet_Ici,
         h_const_mul.2.indicator measurableSet_IciвЯ©

/-- рЯМЯ **PROVED вАФ `IntegralSumLinearityHypothesis` discharged** under
`OrderedWindow` (well, just needs `hy : 0 < y` for the term
integrability). Three-step proof: pointwise distribute `(вИС) ¬Ј k'` to
`вИС ((¬Ј) ¬Ј k')`; apply `intervalIntegral.integral_finset_sum`; pull
each `mult_i` constant out of the per-`i` integral. -/
theorem integralSumLinearity_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ)
    (hy : 0 < y) :
    IntegralSumLinearityHypothesis D x y T X := by
  unfold IntegralSumLinearityHypothesis
  -- Step 1: pointwise distribute the sum over k'(u).
  have h_distrib : вИА u : вДЭ,
      (вИС i вИИ Finset.range D.n,
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0))
        * pairedCauchyImKernelDeriv x y u
      =
      вИС i вИИ Finset.range D.n,
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
    intro u
    rw [Finset.sum_mul]
  -- Step 2: rewrite the LHS integral using the pointwise distribution.
  have h_rewrite :
      (вИЂ u in T..X,
        (вИС i вИИ Finset.range D.n,
          (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0))
          * pairedCauchyImKernelDeriv x y u)
      =
      вИЂ u in T..X,
        вИС i вИИ Finset.range D.n,
          (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u := by
    refine intervalIntegral.integral_congr ?_
    intro u _
    exact h_distrib u
  rw [h_rewrite]
  -- Step 3: pull the finite sum out of the integral.
  have h_int : вИА i вИИ Finset.range D.n,
      IntervalIntegrable
        (fun u : вДЭ =>
          (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X :=
    fun i _ => indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  rw [intervalIntegral.integral_finset_sum h_int]
  -- Step 4: per-i, pull constant `mult_i` out of `вИЂ`.
  apply Finset.sum_congr rfl
  intro i _
  have h_term :
      (fun u : вДЭ =>
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u)
      = (fun u : вДЭ =>
          (D.mult i : вДЭ) *
            ((if D.Z i вЙ§ u then (1 : вДЭ) else 0) * pairedCauchyImKernelDeriv x y u)) := by
    funext u; ring
  rw [h_term, intervalIntegral.integral_const_mul]

-- =====================================================================
-- ¬ІCXCVII. Unconditional FTC bridge + finite-window true IBP
-- =====================================================================
-- All three Prop hypotheses are now discharged. The FTC bridge and the
-- full finite-window IBP normal form become unconditional theorems.

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ UNCONDITIONAL FTC BRIDGE** under `OrderedWindow`.
Combines the three discharged hypotheses with the algebraic bridge
`discrete_corrected_remainder_eq_intervalIntegral`. -/
theorem discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    discreteKernelAbelRemainder D x y T X m
      + discreteAbelEndpointCorrection D.toFluctuationMeasureData
          (fun u => pairedCauchyImKernel x y u) T X m
      =
    вИЂ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u :=
  discrete_corrected_remainder_eq_intervalIntegral D x y T X W
    (nDecompositionIntegrand_of_orderedWindow D x y T X W)
    (integralSumLinearity_of_orderedWindow D x y T X hy)
    (indicatorKernelFTC_of_orderedWindow D x y T X W hy)

-- =====================================================================
-- ¬ІCXCVIII. True finite-window fluctuation IBP (no analytic hypotheses)
-- =====================================================================
-- Combines the unconditional FTC bridge `discrete_corrected_remainder_eq_
-- intervalIntegral_of_orderedWindow` with the endpoint-corrected
-- finite-fluctuation IBP into the clean finite-window Stieltjes IBP:
--
--   `finiteFluctuationKernelPartial = k(X) ¬Ј S(T,X) вИТ вИЂ_T^X S(T,u) ¬Ј k'(u) du`
--
-- where `S(T, ¬Ј) = finiteFluctuationPrimitive D T`. No Prop hypotheses.

/-- **Per-`i` indicator-kernel-derivative term**, top-level definition
to keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteKernelDerivIndicatorTerm
    (D : OrderedFluctuationMeasureData) (x y : вДЭ) (i : вДХ) : вДЭ вЖТ вДЭ :=
  fun u =>
    (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- в≠Р **PROVED вАФ `N(u) ¬Ј k'(u)` is interval-integrable** on `[T, X]`
under `OrderedWindow`. Uses the indicator decomposition: `N` equals
`вИС_i mult_i ¬Ј [Z_i вЙ§ u]` (pointwise everywhere), and each term in the
sum is interval-integrable. The integrability of the sum is stated
as a **sum of functions**, not a `fun u => вИС ... u`, to avoid the
function-vs-sum unification timeout. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) (hy : 0 < y) :
    IntervalIntegrable
      (fun u => discreteCountingPrimitive D.toFluctuationMeasureData T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun_int :
      IntervalIntegrable
        (вИС i вИИ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (by
      intro i _
      unfold discreteKernelDerivIndicatorTerm
      exact indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy)
  refine h_sum_fun_int.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (вИС i, term i) u = вИС i, term i u  (Finset.sum_apply)
  -- = (вИС i, mult_i * indicator_i) * k'(u)  (Finset.sum_mul reverse)
  -- = N(u) * k'(u)  (decomposition lemma)
  calc
    (вИС i вИИ Finset.range D.n, discreteKernelDerivIndicatorTerm D x y i) u
        =
      вИС i вИИ Finset.range D.n,
        (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
          * pairedCauchyImKernelDeriv x y u := by
          simp only [Finset.sum_apply, discreteKernelDerivIndicatorTerm]
    _ =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u := by
          symm
          rw [discreteCountingPrimitive_eq_indicator_sum_of_orderedWindow D T X u W,
              Finset.sum_mul]

/-- в≠Р **PROVED вАФ `S_smooth(u) ¬Ј k'(u)` is interval-integrable** on
`[T, X]` for `0 < T вЙ§ X` and `0 < y`. Both factors are continuous on
`[T, X]`: `S_smooth` via the existing `HasDerivAt` (differentiable вЗТ
continuous), and `k'` via `pairedCauchyImKernelDeriv_continuous`. -/
lemma smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
    {T X : вДЭ} (hT : 0 < T) (hTX : T вЙ§ X) (x : вДЭ) {y : вДЭ} (hy : 0 < y) :
    IntervalIntegrable
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  -- S_smooth is continuous on [T, X] via HasDerivAt вЖТ differentiableAt вЖТ continuousAt
  have h_S_cont : ContinuousOn (fun u => smoothCountingPrimitive T u)
      (Set.Icc T X) := by
    intro u hu
    have h_diff : DifferentiableAt вДЭ (fun v => smoothCountingPrimitive T v) u :=
      (smoothCountingPrimitive_hasDerivAt hT hu.1).differentiableAt
    exact h_diff.continuousAt.continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    (pairedCauchyImKernelDeriv_continuous hy x).continuousOn
  have h_prod_cont : ContinuousOn
      (fun u => smoothCountingPrimitive T u
                  * pairedCauchyImKernelDeriv x y u)
      (Set.Icc T X) :=
    h_S_cont.mul h_k_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- **True derivative-side integral** for the finite fluctuation IBP:
  `вИЂ_T^X S(T,u) ¬Ј k'(u) du`  where `S(T, ¬Ј) = finiteFluctuationPrimitive D T`. -/
noncomputable def finiteFluctuationDerivativeIntegral
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) : вДЭ :=
  вИЂ u in T..X,
    finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u

/-- в≠Р **PROVED вАФ derivative-side integral splits as difference of two
integrals**:
  `finiteFluctuationDerivativeIntegral = (вИЂ N¬Јk') вИТ (вИЂ S_smooth¬Јk')`.
Uses `intervalIntegral.integral_sub` with the two integrability
helpers above. -/
lemma finiteFluctuationDerivativeIntegral_expand
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m) (hT : 0 < T) (hTX : T вЙ§ X) (hy : 0 < y) :
    finiteFluctuationDerivativeIntegral D x y T X
      =
    (вИЂ u in T..X,
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u)
      -
    вИЂ u in T..X,
      smoothCountingPrimitive T u
        * pairedCauchyImKernelDeriv x y u := by
  unfold finiteFluctuationDerivativeIntegral finiteFluctuationPrimitive
  have h_pointwise : вИА u : вДЭ,
      (discreteCountingPrimitive D.toFluctuationMeasureData T u
        - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u
      =
      discreteCountingPrimitive D.toFluctuationMeasureData T u
        * pairedCauchyImKernelDeriv x y u
      - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u := by
    intro u; ring
  rw [show (fun u : вДЭ =>
        (discreteCountingPrimitive D.toFluctuationMeasureData T u
          - smoothCountingPrimitive T u) * pairedCauchyImKernelDeriv x y u)
      = (fun u : вДЭ =>
        discreteCountingPrimitive D.toFluctuationMeasureData T u
          * pairedCauchyImKernelDeriv x y u
        - smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u)
      from funext h_pointwise]
  exact intervalIntegral.integral_sub
    (discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable D x y T X W hy)
    (smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable hT hTX x hy)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ TRUE FINITE-WINDOW FLUCTUATION IBP**
(no analytic Prop hypotheses):

  `finiteFluctuationKernelPartial D x y T X
     = k(X) ¬Ј S(T,X) вИТ вИЂ_T^X S(T,u) ¬Ј k'(u) du`

where `S(T, ¬Ј) = finiteFluctuationPrimitive D T`.

This is the first unconditional finite-window Stieltjes IBP for the
xi fluctuation against the imaginary paired-Cauchy kernel. Combines:
* the endpoint-corrected fluctuation IBP (¬ІCXCIV);
* the unconditional FTC bridge (¬ІCXCVII);
* the derivative-integral expansion (above).

All three were unconditional, so this is too. -/
theorem finiteFluctuationKernelPartial_true_ibp
    (D : OrderedFluctuationMeasureData) (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T вЙ§ X) (hy : 0 < y) :
    finiteFluctuationKernelPartial D x y T X
      =
    pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
      -
    finiteFluctuationDerivativeIntegral D x y T X := by
  -- Step 1: invoke the endpoint-corrected IBP
  rw [finiteFluctuationKernelPartial_endpoint_corrected_ibp
        D x y T X W.hn hT hTX hy]
  -- Step 2: unfold rawRemainder + endpointCorrection
  unfold finiteFluctuationRawRemainder finiteFluctuationEndpointCorrection
        discreteKernelEndpointCorrection discreteAbelEndpointCorrection
  -- Step 3: bridge `R + EC = вИЂN¬Јk'`
  have h_bridge :=
    discrete_corrected_remainder_eq_intervalIntegral_of_orderedWindow D x y T X W hy
  -- Step 4: derivative-side expansion
  have h_expand :=
    finiteFluctuationDerivativeIntegral_expand D x y T X W hT hTX hy
  -- Step 5: name abbreviations to dodge integral atoms inside `ring`.
  set N := discreteCountingPrimitive D.toFluctuationMeasureData T X with hN
  set ffP := finiteFluctuationPrimitive D T X with hffP
  set kX := pairedCauchyImKernel x y X with hkX
  set ffDI := finiteFluctuationDerivativeIntegral D x y T X with hffDI
  set R := discreteKernelAbelRemainder D x y T X m with hR
  set SI := вИЂ u in T..X,
              smoothCountingPrimitive T u * pairedCauchyImKernelDeriv x y u
    with hSI
  set NI := вИЂ u in T..X,
              discreteCountingPrimitive D.toFluctuationMeasureData T u
                * pairedCauchyImKernelDeriv x y u
    with hNI
  -- `set ... with ...` already replaced occurrences in `h_bridge` and
  -- `h_expand`. We still need to unfold `discreteAbelEndpointCorrection`
  -- in `h_bridge` so it exposes `N * (kX - k(D.Z m))`.
  unfold discreteAbelEndpointCorrection at h_bridge
  show ffP * kX - (R - SI) - N * (kX - pairedCauchyImKernel x y (D.Z m))
       = kX * ffP - ffDI
  linarith

/-- в≠Р **PROVED вАФ `finiteFluctuationPrimitive D T T = 0` when no zero
ordinate sits exactly at `T`.** Combines
`discreteCountingPrimitive_left_zero_of_no_atom` with
`smoothCountingPrimitive_self`. -/
lemma finiteFluctuationPrimitive_left_zero_of_no_atom
    (D : OrderedFluctuationMeasureData) (T : вДЭ)
    (hnoT : вИА j вИИ Finset.range D.n, D.Z j вЙ† T) :
    finiteFluctuationPrimitive D T T = 0 := by
  unfold finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_left_zero_of_no_atom D.toFluctuationMeasureData T hnoT,
      smoothCountingPrimitive_self]
  ring

-- =====================================================================
-- ¬ІCXCIX. Finite-window IBP packaging + tail-window eventual data
-- =====================================================================
-- (A) `FiniteWindowKernelStieltjesIBP`: a one-endpoint package recording
-- the finite-window Stieltjes IBP identity at a specific `X`. Makes
-- `finiteFluctuationKernelPartial_true_ibp` reusable by downstream
-- improper-limit records without reopening the Abel machinery.
-- (B) `OrderedTailWindowData` + `orderedWindow_eventually_atTop`: data
-- that's stable as `X вЖТ вИЮ`, with the eventual-window lemma that says
-- `OrderedWindow D T X m` holds for all sufficiently large `X`. This is
-- the bridge for building improper IBP packages from finite-window ones.

/-- **One-endpoint finite-window Stieltjes IBP record.** Records the
finite IBP identity at a specific cutoff `X`:

  `partialAtX = k(X)¬ЈS(X) вИТ k(T)¬ЈS(T) вИТ вИЂ_T^X S(u)¬Јk'(u) du`.

Different from the global `FiniteKernelStieltjesIBP` (¬ІCLXXXVIII), which
quantifies the identity over **all** `X`. This record is the natural
finite-window output of `finiteFluctuationKernelPartial_true_ibp`. -/
structure FiniteWindowKernelStieltjesIBP where
  S : вДЭ вЖТ вДЭ
  partialAtX : вДЭ
  x : вДЭ
  y : вДЭ
  T : вДЭ
  X : вДЭ
  finite_ibp_at_X :
    partialAtX =
      pairedCauchyImKernel x y X * S X
        - pairedCauchyImKernel x y T * S T
        - вИЂ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- рЯМЯ **PROVED вАФ package `finiteFluctuationKernelPartial_true_ibp` as
a `FiniteWindowKernelStieltjesIBP`.** Requires `OrderedWindow` and the
no-atom-at-`T` convention (so the `k(T)¬ЈS(T)` term is correctly zero).
The output is the canonical finite-window IBP record. -/
noncomputable def orderedWindowFiniteWindowKernelStieltjesIBP
    (D : OrderedFluctuationMeasureData)
    (x y T X : вДЭ) {m : вДХ}
    (W : OrderedWindow D T X m)
    (hT : 0 < T) (hTX : T вЙ§ X) (hy : 0 < y)
    (hnoT : вИА j вИИ Finset.range D.n, D.Z j вЙ† T) :
    FiniteWindowKernelStieltjesIBP where
  S := fun U => finiteFluctuationPrimitive D T U
  partialAtX := finiteFluctuationKernelPartial D x y T X
  x := x
  y := y
  T := T
  X := X
  finite_ibp_at_X := by
    have hmain :=
      finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
    have hleft :
        finiteFluctuationPrimitive D T T = 0 :=
      finiteFluctuationPrimitive_left_zero_of_no_atom D T hnoT
    rw [hmain, hleft]
    unfold finiteFluctuationDerivativeIntegral
    ring

/-- **Tail-window data** for the eventual-`X` form. Holds the
window-invariant pieces (`D.n = m + 1`, `T вЙ§ Z_0`, strict ordinates)
without committing to a specific upper cutoff `X`. Once `X` is large
enough вАФ specifically, `X вЙ• Z_m` вАФ this lifts to a full
`OrderedWindow D T X m`. -/
structure OrderedTailWindowData
    (D : OrderedFluctuationMeasureData) (T : вДЭ) (m : вДХ) : Prop where
  hn          : D.n = m + 1
  hT_le_first : T вЙ§ D.Z 0
  hstrict     : вИА j, j < m вЖТ D.Z j < D.Z (j + 1)

/-- рЯМЯ **PROVED вАФ `OrderedWindow D T X m` holds eventually as `X вЖТ вИЮ`.**
The discrete zero list `{Z_0, вА¶, Z_m}` is fixed; once `X вЙ• Z_m`, the
window inclusion `Z_m вЙ§ X` holds. Combined with the
window-invariant data in `OrderedTailWindowData`, this gives the
full `OrderedWindow` predicate for all sufficiently large `X`.

This is the key "finite windows become valid eventually" lemma,
enabling improper-limit packages to consume the finite IBP theorem. -/
lemma orderedWindow_eventually_atTop
    (D : OrderedFluctuationMeasureData) (T : вДЭ) {m : вДХ}
    (Wtail : OrderedTailWindowData D T m) :
    вИАбґ† X in Filter.atTop, OrderedWindow D T X m := by
  filter_upwards [Filter.eventually_ge_atTop (D.Z m)] with X hXm
  exact
    { hn := Wtail.hn
      hT_le_first := Wtail.hT_le_first
      hlast_le_X := hXm
      hstrict := Wtail.hstrict }

-- =====================================================================
-- ¬ІCC. Base paired-Cauchy kernel decay
-- =====================================================================
-- Pure algebraic decay bound for the boundary term `pairedCauchyImKernel x y X`
-- in the regime `|x| < X`:
--
--   `|k(X)| вЙ§ 2y / (X вИТ |x|)¬≤`.
--
-- Built in tiny algebraic pieces (positivity, denominator comparisons,
-- per-term Cauchy bounds) so each step has a small local goal. No
-- filter, no kernel-body unfolding in a single step.

/-- в≠Р **PROVED вАФ positive tail gap** `X вИТ |x| > 0` when `|x| < X`. -/
lemma tailGap_pos_of_abs_lt (x X : вДЭ) (hX : |x| < X) :
    0 < X - |x| := by linarith

/-- в≠Р **PROVED вАФ positive tail-gap square**. -/
lemma tailGap_sq_pos_of_abs_lt (x X : вДЭ) (hX : |x| < X) :
    0 < (X - |x|)^2 := by
  have h : 0 < X - |x| := tailGap_pos_of_abs_lt x X hX
  positivity

/-- в≠Р **PROVED вАФ `(X вИТ |x|)¬≤ вЙ§ (X вИТ x)¬≤`.** Case split on sign of `x`. -/
lemma tailGap_sq_le_sub_sq (x X : вДЭ) (hX : |x| < X) :
    (X - |x|)^2 вЙ§ (X - x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 вЙ§ x
  ¬Ј rw [abs_of_nonneg hx]
  ¬Ј have hxle : x вЙ§ 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle]
    -- goal: (X - -x)^2 вЙ§ (X - x)^2, i.e., (X + x)^2 вЙ§ (X - x)^2 when x вЙ§ 0
    have hXx_nonpos : X * x вЙ§ 0 :=
      mul_nonpos_of_nonneg_of_nonpos hX_pos.le hxle
    nlinarith [hXx_nonpos]

/-- в≠Р **PROVED вАФ `(X вИТ |x|)¬≤ вЙ§ (X + x)¬≤`.** Same by_cases pattern. -/
lemma tailGap_sq_le_add_sq (x X : вДЭ) (hX : |x| < X) :
    (X - |x|)^2 вЙ§ (X + x)^2 := by
  have hX_pos : 0 < X := lt_of_le_of_lt (abs_nonneg x) hX
  by_cases hx : 0 вЙ§ x
  ¬Ј rw [abs_of_nonneg hx]
    -- goal: (X - x)^2 вЙ§ (X + x)^2 when x вЙ• 0
    have hXx_nonneg : 0 вЙ§ X * x := mul_nonneg hX_pos.le hx
    nlinarith [hXx_nonneg]
  ¬Ј have hxle : x вЙ§ 0 := le_of_not_ge hx
    rw [abs_of_nonpos hxle, sub_neg_eq_add]

/-- в≠Р **PROVED вАФ denominator lower bound** with the `+ y¬≤` term:
  `(X вИТ |x|)¬≤ вЙ§ (X вИТ x)¬≤ + y¬≤`. -/
lemma tailGap_sq_le_sub_den (x y X : вДЭ) (hX : |x| < X) :
    (X - |x|)^2 вЙ§ (X - x)^2 + y^2 := by
  have h1 := tailGap_sq_le_sub_sq x X hX
  have h2 : 0 вЙ§ y^2 := sq_nonneg y
  linarith

/-- в≠Р **PROVED вАФ denominator lower bound** with the `+ y¬≤` term, plus form. -/
lemma tailGap_sq_le_add_den (x y X : вДЭ) (hX : |x| < X) :
    (X - |x|)^2 вЙ§ (X + x)^2 + y^2 := by
  have h1 := tailGap_sq_le_add_sq x X hX
  have h2 : 0 вЙ§ y^2 := sq_nonneg y
  linarith

/-- в≠Р **PROVED вАФ bound on the `-` Cauchy term** (kernel uses `(x-X)`,
which squares to `(X-x)`, hence equivalent). -/
lemma cauchy_sub_term_le_tail
    (x y X : вДЭ) (hy : 0 вЙ§ y) (hX : |x| < X) :
    y / ((x - X)^2 + y^2) вЙ§ y / (X - |x|)^2 := by
  have hsq_eq : (x - X)^2 = (X - x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_sub_den x y X hX)

/-- в≠Р **PROVED вАФ bound on the `+` Cauchy term**. -/
lemma cauchy_add_term_le_tail
    (x y X : вДЭ) (hy : 0 вЙ§ y) (hX : |x| < X) :
    y / ((x + X)^2 + y^2) вЙ§ y / (X - |x|)^2 := by
  have hsq_eq : (x + X)^2 = (X + x)^2 := by ring
  rw [hsq_eq]
  exact div_le_div_of_nonneg_left hy
    (tailGap_sq_pos_of_abs_lt x X hX) (tailGap_sq_le_add_den x y X hX)

/-- в≠Р **PROVED вАФ pointwise reciprocal Cauchy term is non-negative.** -/
lemma reciprocal_quadratic_nonneg (x X y : вДЭ) :
    0 вЙ§ 1 / ((x - X)^2 + y^2) := by positivity

/-- в≠Р **PROVED вАФ sum of reciprocal Cauchy terms is non-negative.** -/
lemma reciprocal_quadratic_sum_nonneg (x X y : вДЭ) :
    0 вЙ§ 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) := by positivity

/-- рЯМЯ **PROVED вАФ BASE KERNEL DECAY**:
  `|pairedCauchyImKernel x y X| вЙ§ 2y / (X вИТ |x|)¬≤`   when `0 вЙ§ y, |x| < X`.

The boundary-term inequality needed for the improper IBP limit. Pure
algebra: distribute `-y`, take abs, bound each Cauchy term by
`y/(XвИТ|x|)¬≤`, sum, factor `2`. -/
theorem abs_pairedCauchyImKernel_le_quadratic_tail
    (x y X : вДЭ) (hy : 0 вЙ§ y) (hX : |x| < X) :
    |pairedCauchyImKernel x y X|
      вЙ§ 2 * y / (X - |x|)^2 := by
  unfold pairedCauchyImKernel
  -- Rewrite `-y * sum` as `-(y ¬Ј sum)`, then `|вИТ¬Ј| = |¬Ј|`.
  have h_neg_form :
      -y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = -(y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))) := by ring
  rw [h_neg_form, abs_neg]
  -- The non-negated product is non-negative.
  have h_sum_nn : 0 вЙ§ 1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2) :=
    reciprocal_quadratic_sum_nonneg x X y
  have h_prod_nn : 0 вЙ§ y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2)) :=
    mul_nonneg hy h_sum_nn
  rw [abs_of_nonneg h_prod_nn]
  -- Distribute `y ¬Ј sum = y/A + y/B`.
  have h_distrib :
      y * (1 / ((x - X)^2 + y^2) + 1 / ((x + X)^2 + y^2))
      = y / ((x - X)^2 + y^2) + y / ((x + X)^2 + y^2) := by
    rw [mul_add, mul_one_div, mul_one_div]
  rw [h_distrib]
  have h_sub := cauchy_sub_term_le_tail x y X hy hX
  have h_add := cauchy_add_term_le_tail x y X hy hX
  have h_double : y / (X - |x|)^2 + y / (X - |x|)^2
                = 2 * y / (X - |x|)^2 := by ring
  linarith

-- =====================================================================
-- ¬ІCCI. Boundary term decay вЖТ 0 (crude asymptotics + squeeze)
-- =====================================================================
-- Goal:
--   `Tendsto (fun X => k(X) ¬Ј S(X)) atTop (рЭУЭ 0)`
-- under the log-envelope hypothesis `|S X| вЙ§ C¬Јlog X + D` eventually.
--
-- Strategy (intentionally crude, to dodge the sharp asymptotic):
--   1. `(X вИТ |x|)¬≤ вЙ• X¬≤/4` eventually (when `2|x| вЙ§ X`).
--   2. `log X вЙ§ X` eventually.
--   3. `C¬Јlog X + D вЙ§ (C + |D| + 1)¬ЈX` eventually.
--   4. `|k(X) ¬Ј S X| вЙ§ (8y(C+|D|+1))/X` eventually.
--   5. Squeeze with `const/X вЖТ 0`.

/-- в≠Р **PROVED вАФ `|x| < X` eventually.** -/
lemma eventually_abs_lt_atTop (x : вДЭ) :
    вИАбґ† X : вДЭ in Filter.atTop, |x| < X :=
  Filter.eventually_gt_atTop |x|

/-- в≠Р **PROVED вАФ `2 ¬Ј |x| вЙ§ X` eventually.** -/
lemma eventually_two_abs_le_atTop (x : вДЭ) :
    вИАбґ† X : вДЭ in Filter.atTop, 2 * |x| вЙ§ X :=
  Filter.eventually_ge_atTop (2 * |x|)

/-- в≠Р **PROVED вАФ shifted square lower bound:**
  `X¬≤/4 вЙ§ (X вИТ |x|)¬≤`   when `0 вЙ§ X` and `2|x| вЙ§ X`. -/
lemma shifted_sq_ge_quarter_sq
    (x X : вДЭ) (hX : 0 вЙ§ X) (hx : 2 * |x| вЙ§ X) :
    X^2 / 4 вЙ§ (X - |x|)^2 := by
  have hhalf : X / 2 вЙ§ X - |x| := by linarith
  have hhalf_nonneg : 0 вЙ§ X / 2 := by linarith
  nlinarith [hhalf, hhalf_nonneg, abs_nonneg x]

/-- в≠Р **PROVED вАФ `log X вЙ§ X`** eventually as `X вЖТ вИЮ`. -/
lemma eventually_log_le_self :
    вИАбґ† X : вДЭ in Filter.atTop, Real.log X вЙ§ X := by
  filter_upwards [Filter.eventually_gt_atTop (0 : вДЭ)] with X hX
  have h := Real.log_le_sub_one_of_pos hX
  linarith

/-- в≠Р **PROVED вАФ log envelope dominated by linear envelope** eventually:
  `C¬Јlog X + D вЙ§ (C + |D| + 1) ¬Ј X`. -/
lemma log_envelope_le_linear_eventually
    (C D : вДЭ) (hC : 0 вЙ§ C) :
    вИАбґ† X : вДЭ in Filter.atTop,
      C * Real.log X + D вЙ§ (C + |D| + 1) * X := by
  filter_upwards
    [eventually_log_le_self,
     Filter.eventually_ge_atTop (1 : вДЭ)] with X hlog hXge1
  have hXnonneg : 0 вЙ§ X := by linarith
  have hClog_le : C * Real.log X вЙ§ C * X :=
    mul_le_mul_of_nonneg_left hlog hC
  have hD_le_abs : D вЙ§ |D| := le_abs_self D
  have habs_le_absX : |D| вЙ§ |D| * X := by
    have habs_nn : 0 вЙ§ |D| := abs_nonneg D
    nlinarith [habs_nn, hXge1]
  have h_one_X_nn : 0 вЙ§ 1 * X := by linarith
  nlinarith [hClog_le, hD_le_abs, habs_le_absX, hXnonneg]

/-- в≠Р **PROVED вАФ `A / X вЖТ 0` as `X вЖТ вИЮ`** for any constant `A`. -/
lemma const_div_tendsto_zero_atTop (A : вДЭ) :
    Tendsto (fun X : вДЭ => A / X) Filter.atTop (рЭУЭ 0) := by
  simpa [div_eq_mul_inv] using
    (tendsto_const_nhds (x := A)).mul tendsto_inv_atTop_zero

/-- в≠Р **PROVED вАФ boundary term dominated by `const/X` eventually.**
Combines the kernel decay bound, the shifted-square lower bound, and
the log-envelope linear domination. -/
lemma boundary_abs_le_const_over_X_eventually
    {S : вДЭ вЖТ вДЭ} {C D : вДЭ} (x y : вДЭ)
    (hy : 0 вЙ§ y) (hC : 0 вЙ§ C) (_hD : 0 вЙ§ D)
    (hS : вИАбґ† X in Filter.atTop, |S X| вЙ§ C * Real.log X + D) :
    вИАбґ† X in Filter.atTop,
      |pairedCauchyImKernel x y X * S X|
        вЙ§ (8 * y * (C + |D| + 1)) / X := by
  filter_upwards
    [hS,
     eventually_abs_lt_atTop x,
     Filter.eventually_gt_atTop (0 : вДЭ),
     eventually_two_abs_le_atTop x,
     log_envelope_le_linear_eventually C D hC]
    with X hSX hAbs hXpos h2abs hloglin
  have hk : |pairedCauchyImKernel x y X| вЙ§ 2 * y / (X - |x|)^2 :=
    abs_pairedCauchyImKernel_le_quadratic_tail x y X hy hAbs
  have hshift : X^2 / 4 вЙ§ (X - |x|)^2 :=
    shifted_sq_ge_quarter_sq x X hXpos.le h2abs
  have henv_nonneg : 0 вЙ§ C * Real.log X + D :=
    le_trans (abs_nonneg _) hSX
  have h_denom_pos : 0 < (X - |x|)^2 :=
    tailGap_sq_pos_of_abs_lt x X hAbs
  have h_quarter_pos : 0 < X^2 / 4 := by positivity
  have h_kbnd_nn : 0 вЙ§ 2 * y / (X - |x|)^2 :=
    div_nonneg (by linarith) h_denom_pos.le
  have h_quarter_inv_nn : 0 вЙ§ 2 * y / (X^2 / 4) :=
    div_nonneg (by linarith) h_quarter_pos.le
  -- Step 1: |k ¬Ј S| = |k| ¬Ј |S| вЙ§ (2y/(X-|x|)¬≤) ¬Ј env
  have h_step1 : |pairedCauchyImKernel x y X * S X|
              вЙ§ (2 * y / (X - |x|)^2) * (C * Real.log X + D) := by
    rw [abs_mul]
    exact mul_le_mul hk hSX (abs_nonneg _) h_kbnd_nn
  -- Step 2: (2y/(X-|x|)¬≤) ¬Ј env вЙ§ (2y/(X¬≤/4)) ¬Ј env
  have h_step2 : (2 * y / (X - |x|)^2) * (C * Real.log X + D)
              вЙ§ (2 * y / (X^2 / 4)) * (C * Real.log X + D) := by
    apply mul_le_mul_of_nonneg_right _ henv_nonneg
    exact div_le_div_of_nonneg_left (by linarith) h_quarter_pos hshift
  -- Step 3: (2y/(X¬≤/4)) ¬Ј env вЙ§ (2y/(X¬≤/4)) ¬Ј ((C+|D|+1)¬ЈX)
  have h_step3 : (2 * y / (X^2 / 4)) * (C * Real.log X + D)
              вЙ§ (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X) :=
    mul_le_mul_of_nonneg_left hloglin h_quarter_inv_nn
  -- Step 4: algebra вАФ (2y/(X¬≤/4)) ¬Ј ((C+|D|+1)¬ЈX) = 8y(C+|D|+1)/X
  have h_step4 : (2 * y / (X^2 / 4)) * ((C + |D| + 1) * X)
              = 8 * y * (C + |D| + 1) / X := by
    have hXne : X вЙ† 0 := ne_of_gt hXpos
    field_simp
    ring
  linarith

/-- рЯМЯрЯМЯ **PROVED вАФ BOUNDARY TERM TENDS TO ZERO** under a log
envelope `|S X| вЙ§ C ¬Ј log X + D`:

  `Tendsto (fun X => k(X) ¬Ј S(X)) atTop (рЭУЭ 0)`.

Squeeze on the absolute value via the
`boundary_abs_le_const_over_X_eventually` upper bound + `const/X вЖТ 0`. -/
theorem boundary_atTop_of_log_envelope
    {S : вДЭ вЖТ вДЭ} {C D : вДЭ} (x y : вДЭ)
    (hy : 0 вЙ§ y) (hC : 0 вЙ§ C) (hD : 0 вЙ§ D)
    (hS : вИАбґ† X in Filter.atTop, |S X| вЙ§ C * Real.log X + D) :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (рЭУЭ 0) := by
  -- Step 1: prove |¬Ј| вЖТ 0 via squeeze
  have h_abs_tendsto : Tendsto
      (fun X => |pairedCauchyImKernel x y X * S X|) Filter.atTop (рЭУЭ 0) := by
    apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
      tendsto_const_nhds
      (const_div_tendsto_zero_atTop (8 * y * (C + |D| + 1)))
    ¬Ј exact Filter.Eventually.of_forall (fun X => abs_nonneg _)
    ¬Ј exact boundary_abs_le_const_over_X_eventually x y hy hC hD hS
  -- Step 2: |¬Ј| вЖТ 0 вЯє ¬Ј вЖТ 0
  rw [tendsto_zero_iff_abs_tendsto_zero]
  exact h_abs_tendsto

-- =====================================================================
-- ¬ІCCII. Derivative-side improper convergence: architecture + eventual bound
-- =====================================================================
-- Sets up the derivative-side improper limit lane:
--   вАҐ `derivativeSidePartial` вАФ the partial integral as a function of `X`
--   вАҐ `ImproperIntervalIntegralConverges` вАФ Prop wrapper around `Tendsto`
--   вАҐ `derivative_integral_tendsto_of_improperConverges` вАФ bridge
--   вАҐ `derivative_integrand_abs_le_log_kernel_eventually` вАФ combines log
--     envelope on `S` with the existing kernel decay
--     `abs_pairedCauchyImKernelDeriv_le_adaptive_18` to bound the
--     integrand by `(C¬Јlog u + D) ¬Ј 18y/u¬≥` eventually.
--
-- The actual convergence of the majorant integral (and hence the
-- derivative-side partial) is the analytic content; it's isolated here
-- as a Prop and inhabited in a follow-up patch (uses Mathlib's
-- absolute-convergence/DCT-for-improper-integrals machinery + the
-- explicit primitive of `log u / u¬≥`).

/-- **Derivative-side partial integral**:
  `вИЂ_T^X S(u) ¬Ј k'(u) du`   where `k' = pairedCauchyImKernelDeriv x y`.
The variable side of the IBP whose limit as `X вЖТ вИЮ` is the open
analytic content of the improper IBP. -/
noncomputable def derivativeSidePartial
    (S : вДЭ вЖТ вДЭ) (x y T X : вДЭ) : вДЭ :=
  вИЂ u in T..X, S u * pairedCauchyImKernelDeriv x y u

/-- **Improper interval-integral convergence** for `f` at basepoint `T`:
there exists `L` such that `вИЂ_T^X f(u) du вЖТ L` as `X вЖТ вИЮ`. Prop
wrapper around `Tendsto`. -/
def ImproperIntervalIntegralConverges (f : вДЭ вЖТ вДЭ) (T : вДЭ) : Prop :=
  вИГ L : вДЭ, Tendsto (fun X : вДЭ => вИЂ u in T..X, f u) Filter.atTop (рЭУЭ L)

/-- в≠Р **PROVED вАФ derivative-side convergence bridge.** If the improper
integral of `S(u) ¬Ј k'(u)` converges (as a Prop), then the
`derivativeSidePartial` tends to that limit. Direct unpacking. -/
lemma derivative_integral_tendsto_of_improperConverges
    {S : вДЭ вЖТ вДЭ} {x y T : вДЭ}
    (h : ImproperIntervalIntegralConverges
          (fun u => S u * pairedCauchyImKernelDeriv x y u) T) :
    вИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (рЭУЭ J) := by
  obtain вЯ®L, hLвЯ© := h
  exact вЯ®L, hLвЯ©

/-- рЯМЯ **PROVED вАФ eventual bound on the derivative-side integrand.**
For `0 < y`, log envelope `|S u| вЙ§ C log u + D` eventually, and `u`
in the adaptive kernel regime `2(1 + |x| + y) вЙ§ u`:

  `|S(u) ¬Ј k'(u)| вЙ§ (C¬Јlog u + D) ¬Ј 18y/u¬≥`   eventually.

Combines the existing kernel decay
`abs_pairedCauchyImKernelDeriv_le_adaptive_18` (giving the `18y/u¬≥`
envelope) with the log envelope on `S`. -/
lemma derivative_integrand_abs_le_log_kernel_eventually
    {S : вДЭ вЖТ вДЭ} {C D : вДЭ} (x y : вДЭ)
    (hy : 0 < y) (_hC : 0 вЙ§ C) (_hD : 0 вЙ§ D)
    (hS : вИАбґ† u in Filter.atTop, |S u| вЙ§ C * Real.log u + D) :
    вИАбґ† u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        вЙ§ (C * Real.log u + D) * (18 * y / u^3) := by
  filter_upwards
    [hS,
     Filter.eventually_ge_atTop (2 * (1 + |x| + y))] with u hSu h_reg
  rw [abs_mul]
  -- Adaptive bound: T = u (the threshold itself), so hT = h_reg and hu = le_refl u.
  have hkernel : |pairedCauchyImKernelDeriv x y u| вЙ§ 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 (le_of_lt hy) h_reg (le_refl u)
  have henv_nn : 0 вЙ§ C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hkernel (abs_nonneg _) henv_nn

/-- **Headline target (Prop-staged): under log envelope + majorant
convergence, the derivative-side partial integral converges.**

Stated with the majorant `(C¬Јlog u + D) ¬Ј 18y/u¬≥` whose explicit
primitive shows finite convergence (`вИЂ log u / u¬≥` and `вИЂ 1/u¬≥` both
integrate to terms vanishing at `вИЮ`). The Mathlib absolute-convergence
chase to actually inhabit the conclusion is the next analytic patch. -/
def DerivativeSideMajorantConverges
    (_x y T : вДЭ) (C D : вДЭ) : Prop :=
  ImproperIntervalIntegralConverges
    (fun u => (C * Real.log u + D) * (18 * y / u^3)) T

/-- рЯМЯрЯМЯ **PROVED вАФ `derivative_integral_tendsto_of_log_envelope` modulo
majorant convergence.** Given:

* `0 < y`, `0 вЙ§ C, 0 вЙ§ D`;
* log envelope `|S u| вЙ§ C¬Јlog u + D` eventually;
* the majorant integral `вИЂ (C¬Јlog u + D)¬Ј18y/u¬≥ du` converges as
  `X вЖТ вИЮ` (Prop `DerivativeSideMajorantConverges`);

the bridge to convergence of `derivativeSidePartial S x y T` would
follow by the absolute-convergence comparison theorem (next patch).

The current statement isolates exactly what's left: an absolute
domination lemma + Mathlib's "absolutely-convergent improper integral
converges" theorem. -/
def DerivativeSideConvergesUnderLogEnvelope
    (S : вДЭ вЖТ вДЭ) (x y T C D : вДЭ) : Prop :=
  (вИАбґ† u in Filter.atTop, |S u| вЙ§ C * Real.log u + D) вЖТ
  DerivativeSideMajorantConverges x y T C D вЖТ
  вИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
    Filter.atTop (рЭУЭ J)

-- =====================================================================
-- ¬ІCCIII. Majorant primitive + DerivativeSideMajorantConverges discharge
-- =====================================================================
-- Discharges `DerivativeSideMajorantConverges` via explicit primitive:
--   `M(u)  := (C ¬Ј log u + D) ¬Ј 18y/u¬≥`     (the majorant)
--   `P(u)  := вИТ9y ¬Ј (C ¬Ј log u + D + C/2) / u¬≤`   (a primitive)
-- with `P'(u) = M(u)` for `u > 0`, and `P(X) вЖТ 0` as `X вЖТ вИЮ`.

/-- **Named majorant** for the derivative-side integrand. -/
noncomputable def derivativeSideMajorant
    (y C D : вДЭ) (u : вДЭ) : вДЭ :=
  (C * Real.log u + D) * (18 * y / u^3)

/-- **Explicit primitive** of the majorant on `u > 0`:
  `P(u) = вИТ9y ¬Ј (C ¬Ј log u + D + C/2) / u¬≤`. -/
noncomputable def derivativeSideMajorantPrimitive
    (y C D : вДЭ) (u : вДЭ) : вДЭ :=
  -9 * y * (C * Real.log u + D + C / 2) / u^2

/-- рЯМЯ **PROVED вАФ `P'(u) = M(u)`** on `u > 0`. Calculus on
  `log`, `t^2`, and `HasDerivAt.div`, then `field_simp + ring` to
  reconcile the derivative shape. -/
lemma hasDerivAt_derivativeSideMajorantPrimitive
    (y C D u : вДЭ) (hu : 0 < u) :
    HasDerivAt
      (fun t => derivativeSideMajorantPrimitive y C D t)
      (derivativeSideMajorant y C D u)
      u := by
  unfold derivativeSideMajorantPrimitive derivativeSideMajorant
  have hu_ne : u вЙ† 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have hu_sq_ne : u^2 вЙ† 0 := ne_of_gt hu_sq_pos
  have h_log : HasDerivAt Real.log uвБї¬є u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * Real.log t + D + C / 2) (C * uвБї¬є) u := by
    have h1 := h_log.const_mul C
    have h2 := h1.add_const D
    exact h2.add_const (C / 2)
  have h_sq : HasDerivAt (fun t : вДЭ => t^2) (2 * u) u := by
    have := (hasDerivAt_id u).pow 2
    simpa [pow_one] using this
  have h_div : HasDerivAt
      (fun t : вДЭ => (C * Real.log t + D + C / 2) / t^2)
      ((C * uвБї¬є * u^2 - (C * Real.log u + D + C / 2) * (2 * u)) / (u^2)^2) u :=
    h_g.div h_sq hu_sq_ne
  have h_neg9y : HasDerivAt
      (fun t : вДЭ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
      (-9 * y * ((C * uвБї¬є * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)) u :=
    h_div.const_mul (-9 * y)
  have h_fun_eq : (fun t : вДЭ => -9 * y * ((C * Real.log t + D + C / 2) / t^2))
                = (fun t : вДЭ => -9 * y * (C * Real.log t + D + C / 2) / t^2) := by
    funext t; ring
  rw [h_fun_eq] at h_neg9y
  have h_val :
      -9 * y * ((C * uвБї¬є * u^2 - (C * Real.log u + D + C / 2) * (2 * u))
                  / (u^2)^2)
        = (C * Real.log u + D) * (18 * y / u^3) := by
    field_simp
    ring
  rw [h_val] at h_neg9y
  exact h_neg9y

/-- в≠Р **PROVED вАФ majorant is continuous on `[T, X]`** for `0 < T вЙ§ X`. -/
lemma derivativeSideMajorant_continuousOn_Icc
    (y C D T X : вДЭ) (hT : 0 < T) (_hTX : T вЙ§ X) :
    ContinuousOn (fun u => derivativeSideMajorant y C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold derivativeSideMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.mul ?_ ?_
  ¬Ј refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  ¬Ј refine continuousAt_const.div ?_ ?_
    ¬Ј exact continuousAt_id.pow 3
    ¬Ј exact pow_ne_zero 3 (ne_of_gt hu_pos)

/-- в≠Р **PROVED вАФ majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma derivativeSideMajorant_intervalIntegrable
    (y C D T X : вДЭ) (hT : 0 < T) (hTX : T вЙ§ X) :
    IntervalIntegrable (fun u => derivativeSideMajorant y C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (derivativeSideMajorant_continuousOn_Icc y C D T X hT hTX)

/-- рЯМЯ **PROVED вАФ FTC for the majorant**:
  `вИЂ_T^X M(u) du = P(X) вИТ P(T)`. -/
lemma derivativeSideMajorant_integral_eq_sub
    (y C D T X : вДЭ) (hT : 0 < T) (hTX : T вЙ§ X) :
    (вИЂ u in T..X, derivativeSideMajorant y C D u)
      = derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ¬Ј intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_derivativeSideMajorantPrimitive y C D u hu_pos
  ¬Ј exact derivativeSideMajorant_intervalIntegrable y C D T X hT hTX

/-- в≠Р **PROVED вАФ `1/X¬≤ вЖТ 0`** as `X вЖТ вИЮ`. Via `Tendsto.mul` on `1/X ¬Ј 1/X`. -/
lemma one_div_sq_tendsto_zero :
    Tendsto (fun X : вДЭ => 1 / X^2) Filter.atTop (рЭУЭ 0) := by
  have h_inv := const_div_tendsto_zero_atTop (1 : вДЭ)
  have h_prod : Tendsto (fun X : вДЭ => 1 / X * (1 / X)) Filter.atTop (рЭУЭ (0 * 0)) :=
    h_inv.mul h_inv
  rw [show (0 * 0 : вДЭ) = 0 from by ring] at h_prod
  have h_eq : (fun X : вДЭ => 1 / X * (1 / X)) = (fun X : вДЭ => 1 / X^2) := by
    funext X; rw [pow_two]; ring
  rw [h_eq] at h_prod
  exact h_prod

/-- в≠Р **PROVED вАФ `log X / X¬≤ вЖТ 0`** as `X вЖТ вИЮ`. Squeeze between `0`
(eventually, for `X вЙ• 1`) and `1/X`. -/
lemma log_div_sq_tendsto_zero :
    Tendsto (fun X : вДЭ => Real.log X / X^2) Filter.atTop (рЭУЭ 0) := by
  apply tendsto_of_tendsto_of_tendsto_of_le_of_le'
    (tendsto_const_nhds (x := (0 : вДЭ)))
    (const_div_tendsto_zero_atTop (1 : вДЭ))
  ¬Ј -- 0 вЙ§ log X / X¬≤ eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : вДЭ)] with X hX
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:вДЭ) < 1) hX
    have hlog_nn : 0 вЙ§ Real.log X := Real.log_nonneg hX
    positivity
  ¬Ј -- log X / X¬≤ вЙ§ 1/X eventually
    filter_upwards [Filter.eventually_ge_atTop (1 : вДЭ),
                    eventually_log_le_self] with X hX hlog
    have hX_pos : 0 < X := lt_of_lt_of_le (by norm_num : (0:вДЭ) < 1) hX
    have hX_sq_pos : 0 < X^2 := by positivity
    rw [div_le_div_iffвВА hX_sq_pos hX_pos]
    -- log X * X вЙ§ X^2 * 1, i.e., X ¬Ј log X вЙ§ X¬≤
    have h_mul : X * Real.log X вЙ§ X * X :=
      mul_le_mul_of_nonneg_left hlog hX_pos.le
    nlinarith [h_mul]

/-- рЯМЯ **PROVED вАФ `P(X) вЖТ 0`** as `X вЖТ вИЮ`. The primitive splits as
two terms, each a constant times a vanishing piece (`log X / X¬≤` and
`1/X¬≤`). -/
lemma derivativeSideMajorantPrimitive_tendsto_zero
    (y C D : вДЭ) :
    Tendsto (fun X : вДЭ => derivativeSideMajorantPrimitive y C D X)
      Filter.atTop (рЭУЭ 0) := by
  unfold derivativeSideMajorantPrimitive
  -- -9y ¬Ј (C log X + D + C/2) / X¬≤ = (-9yC) ¬Ј log X/X¬≤ + (-9y(D+C/2)) ¬Ј 1/X¬≤
  have h_logterm : Tendsto (fun X : вДЭ => (-9 * y * C) * (Real.log X / X^2))
      Filter.atTop (рЭУЭ ((-9 * y * C) * 0)) :=
    log_div_sq_tendsto_zero.const_mul (-9 * y * C)
  have h_constterm : Tendsto (fun X : вДЭ => (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (рЭУЭ ((-9 * y * (D + C/2)) * 0)) :=
    one_div_sq_tendsto_zero.const_mul (-9 * y * (D + C/2))
  have h_sum : Tendsto (fun X : вДЭ =>
      (-9 * y * C) * (Real.log X / X^2) + (-9 * y * (D + C/2)) * (1 / X^2))
      Filter.atTop (рЭУЭ ((-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-9 * y * C) * 0 + (-9 * y * (D + C/2)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  -- Rewrite our primitive to match the sum's form
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : вДЭ)] with X hX
  have hX_sq_ne : X^2 вЙ† 0 := pow_ne_zero 2 (ne_of_gt hX)
  field_simp
  ring

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `DerivativeSideMajorantConverges`** for any `x`,
  `y`, `T > 0`, `C, D`. The limit is `вИТP(T)`. Combines FTC + primitive
  tending to 0. -/
theorem derivativeSideMajorantConverges
    (x y T C D : вДЭ) (hT : 0 < T) :
    DerivativeSideMajorantConverges x y T C D := by
  refine вЯ®-derivativeSideMajorantPrimitive y C D T, ?_вЯ©
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : вДЭ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (рЭУЭ (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : вДЭ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (рЭУЭ (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  -- Bridge to the integral form via FTC for X вЙ• T
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

-- =====================================================================
-- ¬ІCCIV. Absolute-convergence comparison scaffolding
-- =====================================================================
-- The missing analytic ingredient for `derivative_integral_tendsto`:
--   `|f| вЙ§ M eventually + вИЂ_T^X M вЖТ LM  вЯє  вИГ J, вИЂ_T^X f вЖТ J`.
-- Built in stages:
--   A. named partial/tail integrals (keeps the elaborator cheap);
--   B. tail identity `вИЂ_T^B вИТ вИЂ_T^A = вИЂ_A^B`;
--   C. tail smallness: `Tendsto M_partial atTop (рЭУЭ LM) вЗТ tails eventually small`;
--   D. finite comparison: `|вИЂ f| вЙ§ вИЂ M` (per-interval, given a pointwise bound).
-- The full comparison theorem (Cauchy criterion + completeness) is the
-- next analytic patch.

/-- **Named partial integral** at upper cutoff `X`. -/
noncomputable def intervalPartialIntegral
    (f : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДЭ :=
  вИЂ u in T..X, f u

/-- **Named tail integral** between `A` and `B`. -/
noncomputable def intervalTailIntegral
    (f : вДЭ вЖТ вДЭ) (A B : вДЭ) : вДЭ :=
  вИЂ u in A..B, f u

/-- в≠Р **PROVED вАФ tail identity for partial integrals.**
  `вИЂ_T^B f вИТ вИЂ_T^A f = вИЂ_A^B f`  for `T вЙ§ A вЙ§ B` with `f` integrable on `[T, B]`. -/
lemma intervalPartialIntegral_sub_eq_tail
    (f : вДЭ вЖТ вДЭ) (T A B : вДЭ)
    (hTA : T вЙ§ A) (hAB : A вЙ§ B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume T B) :
    intervalPartialIntegral f T B - intervalPartialIntegral f T A
      = intervalTailIntegral f A B := by
  unfold intervalPartialIntegral intervalTailIntegral
  have hTB : T вЙ§ B := le_trans hTA hAB
  have h_T_A : IntervalIntegrable f MeasureTheory.volume T A :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hTA, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_right hAB)
  have h_A_B : IntervalIntegrable f MeasureTheory.volume A B :=
    hf_int.mono_set (by
      rw [Set.uIcc_of_le hAB, Set.uIcc_of_le hTB]
      exact Set.Icc_subset_Icc_left hTA)
  have h_split : (вИЂ u in T..B, f u) = (вИЂ u in T..A, f u) + вИЂ u in A..B, f u :=
    (intervalIntegral.integral_add_adjacent_intervals h_T_A h_A_B).symm
  linarith

/-- рЯМЯ **PROVED вАФ tail smallness from partial-integral convergence.**
If `вИЂ_T^X M вЖТ LM` as `X вЖТ вИЮ`, then for any `ќµ > 0` the tail integral
`вИЂ_A^B M` is `< ќµ` for all sufficiently large `A вЙ§ B`. Pure
filter-algebra epsilon argument: pick `ќµ/2` neighborhoods of `LM`, use
the triangle inequality on the tail identity. -/
lemma tail_integral_small_of_partial_tendsto
    {M : вДЭ вЖТ вДЭ} {T LM : вДЭ}
    (hM_int_all : вИА X, IntervalIntegrable M MeasureTheory.volume T X)
    (hM : Tendsto (fun X => intervalPartialIntegral M T X)
            Filter.atTop (рЭУЭ LM)) :
    вИА ќµ > 0, вИАбґ† A in Filter.atTop, вИАбґ† B in Filter.atTop,
      A вЙ§ B вЖТ |intervalTailIntegral M A B| < ќµ := by
  intro ќµ hќµ
  have hќµ2 : 0 < ќµ / 2 := by linarith
  -- Tendsto in metric form: dist (partial X) LM < ќµ/2 eventually
  have hA_close : вИАбґ† A in Filter.atTop,
      |intervalPartialIntegral M T A - LM| < ќµ/2 := by
    have h := (Metric.tendsto_nhds.mp hM) (ќµ/2) hќµ2
    filter_upwards [h] with A hdist
    rwa [Real.dist_eq] at hdist
  filter_upwards [hA_close, Filter.eventually_ge_atTop T] with A hAclose hTA
  filter_upwards [hA_close, Filter.eventually_ge_atTop A] with B hBclose hAB hABle
  -- Tail identity: вИЂ_A^B M = partial M T B вИТ partial M T A
  have h_tail_eq : intervalTailIntegral M A B
                 = intervalPartialIntegral M T B
                   - intervalPartialIntegral M T A := by
    have := intervalPartialIntegral_sub_eq_tail M T A B hTA hABle (hM_int_all B)
    linarith
  rw [h_tail_eq]
  -- Triangle inequality: |pB вИТ pA| вЙ§ |pB вИТ LM| + |pA вИТ LM| < ќµ
  have h_tri : |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
            вЙ§ |intervalPartialIntegral M T B - LM|
              + |intervalPartialIntegral M T A - LM| := by
    calc |intervalPartialIntegral M T B - intervalPartialIntegral M T A|
        = |(intervalPartialIntegral M T B - LM)
            + -(intervalPartialIntegral M T A - LM)| := by ring_nf
      _ вЙ§ |intervalPartialIntegral M T B - LM|
          + |-(intervalPartialIntegral M T A - LM)| := abs_add _ _
      _ = |intervalPartialIntegral M T B - LM|
          + |intervalPartialIntegral M T A - LM| := by rw [abs_neg]
  linarith

/-- рЯМЯ **PROVED вАФ finite-window absolute comparison**:
  `|вИЂ_A^B f| вЙ§ вИЂ_A^B M`  when `|f u| вЙ§ M u` on `[A, B]`, both integrable. -/
lemma intervalIntegral_abs_le_intervalIntegral_majorant
    {f M : вДЭ вЖТ вДЭ} {A B : вДЭ}
    (hAB : A вЙ§ B)
    (hf_int : IntervalIntegrable f MeasureTheory.volume A B)
    (hM_int : IntervalIntegrable M MeasureTheory.volume A B)
    (hbound : вИА u вИИ Set.Icc A B, |f u| вЙ§ M u) :
    |вИЂ u in A..B, f u| вЙ§ вИЂ u in A..B, M u := by
  -- Step 1: |вИЂ f| вЙ§ вИЂ |f|
  have h_abs_int : IntervalIntegrable (fun u => |f u|) MeasureTheory.volume A B :=
    hf_int.abs
  have h1 : |вИЂ u in A..B, f u| вЙ§ вИЂ u in A..B, |f u| :=
    intervalIntegral.abs_integral_le_integral_abs hAB
  -- Step 2: вИЂ |f| вЙ§ вИЂ M via monotone
  have h2 : вИЂ u in A..B, |f u| вЙ§ вИЂ u in A..B, M u := by
    apply intervalIntegral.integral_mono_on hAB h_abs_int hM_int
    intro u hu
    exact hbound u hu
  linarith

-- =====================================================================
-- ¬ІCCV. Comparison theorem: Cauchy + complete-space convergence
-- =====================================================================
-- The headline analytic theorem for derivative-side improper convergence:
--
--   `|f u| вЙ§ M u eventually  +  вИЂ_T^X M вЖТ LM
--      вЯє  вИГ J, вИЂ_T^X f вЖТ J`.
--
-- Strategy:
--   1. Show `(fun X => вИЂ_T^X f)` is Cauchy at `atTop` via the finite
--      comparison applied to tails (using the M partial integrals'
--      ќµ/2 closeness to `LM`).
--   2. Conclude convergence via `CompleteSpace.complete` for `вДЭ`.

/-- рЯМЯрЯМЯ **PROVED вАФ ABSOLUTE-CONVERGENCE COMPARISON THEOREM.**
For real-valued `f, M` with `f, M` interval-integrable on each `[T, X]`
for `X вЙ• T`, `|f u| вЙ§ M u` eventually, and the M-partial integrals
converging:

  the f-partial integrals also converge.

The integrability hypothesis is restricted to `X вЙ• T` because for many
natural majorants (e.g. `(C¬Јlog u + D)¬Ј18y/u¬≥`) the integrand fails to
be integrable on `(0, T]` if `T < 0` etc. -/
theorem improperIntegralConverges_of_absMajorant
    {f M : вДЭ вЖТ вДЭ} {T LM : вДЭ}
    (hf_int : вИА X, T вЙ§ X вЖТ IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : вИА X, T вЙ§ X вЖТ IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => intervalPartialIntegral M T X)
                    Filter.atTop (рЭУЭ LM))
    (hbound : вИАбґ† u in Filter.atTop, |f u| вЙ§ M u) :
    ImproperIntervalIntegralConverges f T := by
  -- Step 1: show Cauchy of the f-partial integrals at `atTop`
  have h_cauchy : Cauchy
      (Filter.map (fun X => intervalPartialIntegral f T X) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine вЯ®Filter.map_neBot, ?_вЯ©
    intro ќµ hќµ
    have hќµ2 : 0 < ќµ / 2 := by linarith
    -- M partial close to LM eventually
    have h_M_close : вИАбґ† A in Filter.atTop,
        |intervalPartialIntegral M T A - LM| < ќµ / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (ќµ / 2) hќµ2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain вЯ®N_M, hN_MвЯ© := Filter.eventually_atTop.mp h_M_close
    obtain вЯ®N0, hN0вЯ© := Filter.eventually_atTop.mp hbound
    let N : вДЭ := max T (max N0 N_M)
    refine вЯ®(fun X => intervalPartialIntegral f T X) '' {X | N вЙ§ X}, ?_, ?_вЯ©
    ¬Ј exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    -- Orientation-safe distance argument via key lemma
    suffices key :
        вИА Y1 Y2 : вДЭ, N вЙ§ Y1 вЖТ N вЙ§ Y2 вЖТ Y1 вЙ§ Y2 вЖТ
          |intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1| < ќµ by
      rintro _ вЯ®X1, hX1, rflвЯ© _ вЯ®X2, hX2, rflвЯ©
      rw [Real.dist_eq]
      rcases le_total X1 X2 with hX12 | hX21
      ¬Ј rw [abs_sub_comm]; exact key X1 X2 hX1 hX2 hX12
      ¬Ј exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    -- Extract individual bounds from `N := max T (max N0 N_M)`
    have hT_Y1 : T вЙ§ Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T вЙ§ Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 вЙ§ Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M вЙ§ Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M вЙ§ Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    -- Tail identities for f and M
    have h_tail_f :
        intervalPartialIntegral f T Y2 - intervalPartialIntegral f T Y1
          = intervalTailIntegral f Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail f T Y1 Y2 hT_Y1 hY12 (hf_int Y2 hT_Y2)
    have h_tail_M :
        intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1
          = intervalTailIntegral M Y1 Y2 :=
      intervalPartialIntegral_sub_eq_tail M T Y1 Y2 hT_Y1 hY12 (hM_int Y2 hT_Y2)
    rw [h_tail_f]
    -- Sub-interval integrability for the finite comparison
    have hsub_uIcc : Set.uIcc Y1 Y2 вКЖ Set.uIcc T Y2 := by
      rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
      exact Set.Icc_subset_Icc_left hT_Y1
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      (hf_int Y2 hT_Y2).mono_set hsub_uIcc
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      (hM_int Y2 hT_Y2).mono_set hsub_uIcc
    have hbound_Y1Y2 : вИА u вИИ Set.Icc Y1 Y2, |f u| вЙ§ M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    -- Finite comparison: |tail f| вЙ§ tail M
    have h_comp : |intervalTailIntegral f Y1 Y2| вЙ§ intervalTailIntegral M Y1 Y2 := by
      unfold intervalTailIntegral
      exact intervalIntegral_abs_le_intervalIntegral_majorant
        hY12 hf_int_Y1Y2 hM_int_Y1Y2 hbound_Y1Y2
    -- M partial-difference triangle: |partial M Y2 - partial M Y1| < ќµ
    have h_M_partial_close : |intervalTailIntegral M Y1 Y2| < ќµ := by
      rw [вЖР h_tail_M]
      have h1 := hN_M Y1 hN_M_Y1
      have h2 := hN_M Y2 hN_M_Y2
      calc |intervalPartialIntegral M T Y2 - intervalPartialIntegral M T Y1|
          вЙ§ |intervalPartialIntegral M T Y2 - LM|
            + |LM - intervalPartialIntegral M T Y1| := abs_sub_le _ _ _
        _ = |intervalPartialIntegral M T Y2 - LM|
            + |intervalPartialIntegral M T Y1 - LM| := by
              rw [abs_sub_comm LM]
        _ < ќµ / 2 + ќµ / 2 := add_lt_add h2 h1
        _ = ќµ := by ring
    -- tail M вЙ• 0 (from |tail f| вЙ§ tail M and abs вЙ• 0)
    have h_tail_M_nn : 0 вЙ§ intervalTailIntegral M Y1 Y2 :=
      le_trans (abs_nonneg _) h_comp
    have h_abs_tail_M : |intervalTailIntegral M Y1 Y2|
                      = intervalTailIntegral M Y1 Y2 :=
      abs_of_nonneg h_tail_M_nn
    rw [h_abs_tail_M] at h_M_partial_close
    exact lt_of_le_of_lt h_comp h_M_partial_close
  -- Step 2: Cauchy + complete-space вЯє convergence
  obtain вЯ®L, hLвЯ© := CompleteSpace.complete h_cauchy
  exact вЯ®L, hLвЯ©

-- =====================================================================
-- ¬ІCCVI. Derivative-side improper integral converges (wiring)
-- =====================================================================
-- Wires the generic comparison theorem `improperIntegralConverges_of_absMajorant`
-- to the derivative-side integrand `S(u) ¬Ј k'(u)`. The inputs are:
--   вАҐ `derivativeSideMajorantConverges`         (¬ІCCIII)
--   вАҐ `derivativeSideMajorant_intervalIntegrable` (¬ІCCIII)
--   вАҐ `derivative_integrand_abs_le_log_kernel_eventually` (¬ІCCII)
-- The remaining open input is just integrability of `S ¬Ј k'` on each
-- finite window `[T, X]` (`X вЙ• T`), which is a local regularity
-- condition on `S` вАФ for arbitrary `S` it must be supplied; for the
-- finite-fluctuation primitive it falls out of ¬ІCXCVIII's machinery.

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ DERIVATIVE-SIDE IMPROPER CONVERGENCE under a log
envelope.** Given `0 < y`, `0 < T`, `0 вЙ§ C`, `0 вЙ§ D`, a log envelope
`|S u| вЙ§ C¬Јlog u + D` eventually, and finite-window integrability of
`S ¬Ј k'` on each `[T, X]` (`T вЙ§ X`):

  `вИГ J, Tendsto (fun X => вИЂ_T^X S(u)¬Јk'(u) du) atTop (рЭУЭ J)`. -/
theorem derivative_integral_tendsto_of_log_envelope
    {S : вДЭ вЖТ вДЭ} {C D x y T : вДЭ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 вЙ§ C) (hD : 0 вЙ§ D)
    (hS : вИАбґ† u in Filter.atTop, |S u| вЙ§ C * Real.log u + D)
    (hf_int : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    вИГ J, Tendsto (fun X : вДЭ => derivativeSidePartial S x y T X)
      Filter.atTop (рЭУЭ J) := by
  -- Set up the majorant
  obtain вЯ®LM, hLMвЯ© := derivativeSideMajorantConverges x y T C D hT
  -- Integrability of the majorant on each `[T, X]` (`T вЙ§ X`)
  have hMint : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable (derivativeSideMajorant y C D)
        MeasureTheory.volume T X :=
    fun X hTX => derivativeSideMajorant_intervalIntegrable y C D T X hT hTX
  -- Eventual pointwise bound
  have hbound : вИАбґ† u in Filter.atTop,
      |S u * pairedCauchyImKernelDeriv x y u|
        вЙ§ derivativeSideMajorant y C D u :=
    derivative_integrand_abs_le_log_kernel_eventually x y hy hC hD hS
  -- Apply the comparison theorem
  have hconv : ImproperIntervalIntegralConverges
      (fun u => S u * pairedCauchyImKernelDeriv x y u) T :=
    improperIntegralConverges_of_absMajorant
      (f := fun u => S u * pairedCauchyImKernelDeriv x y u)
      (M := derivativeSideMajorant y C D)
      (T := T) (LM := LM)
      hf_int hMint hLM hbound
  -- Bridge to derivativeSidePartial
  exact derivative_integral_tendsto_of_improperConverges
    (S := S) (x := x) (y := y) (T := T) hconv

-- =====================================================================
-- ¬ІCCVII. partialF_tendsto + concrete partial convergence
-- =====================================================================
-- The third improper-limit obligation: `partialF X вЖТ L` as `X вЖТ вИЮ`.
-- Falls out of the finite IBP identity once the boundary term and
-- derivative-side partial integral both converge.

/-- рЯМЯ **PROVED вАФ generic partial-integral limit lemma** under the
**clean** finite IBP form (no `-k(T)¬ЈS(T)` term, e.g. when `S(T) = 0`):

  `partialF X = k(X)¬ЈS X вИТ derivativeSidePartial S x y T X` eventually,
  `k(X)¬ЈS X вЖТ 0`,
  `derivativeSidePartial вЖТ J`
   вЯє `partialF вЖТ вИТJ`. -/
lemma partialF_tendsto_of_clean_finiteIBP_and_limits
    {S partialF : вДЭ вЖТ вДЭ} {x y T J : вДЭ}
    (hfinite_eventually :
      вИАбґ† X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (рЭУЭ 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (рЭУЭ J)) :
    Tendsto partialF Filter.atTop (рЭУЭ (-J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - derivativeSidePartial S x y T X)
        Filter.atTop (рЭУЭ (0 - J)) := hboundary.sub hderiv
  have hzero : (0 - J : вДЭ) = -J := by ring
  rw [вЖР hzero]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - derivativeSidePartial S x y T X)
              =бґ†[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- рЯМЯ **PROVED вАФ generic partial-integral limit lemma** under the
**standard** finite IBP form (includes the `-k(T)¬ЈS(T)` term):

  `partialF X = k(X)¬ЈS X вИТ k(T)¬ЈS T вИТ derivativeSidePartial X` eventually,
   вЯє `partialF вЖТ вИТk(T)¬ЈS T вИТ J`. -/
lemma partialF_tendsto_of_standard_finiteIBP_and_limits
    {S partialF : вДЭ вЖТ вДЭ} {x y T J : вДЭ}
    (hfinite_eventually :
      вИАбґ† X in Filter.atTop,
        partialF X =
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
    (hboundary :
      Tendsto (fun X => pairedCauchyImKernel x y X * S X)
        Filter.atTop (рЭУЭ 0))
    (hderiv :
      Tendsto (fun X => derivativeSidePartial S x y T X)
        Filter.atTop (рЭУЭ J)) :
    Tendsto partialF Filter.atTop
      (рЭУЭ (-(pairedCauchyImKernel x y T * S T) - J)) := by
  have htarget :
      Tendsto (fun X =>
          pairedCauchyImKernel x y X * S X
            - pairedCauchyImKernel x y T * S T
            - derivativeSidePartial S x y T X)
        Filter.atTop
        (рЭУЭ (0 - pairedCauchyImKernel x y T * S T - J)) :=
    (hboundary.sub tendsto_const_nhds).sub hderiv
  have hconst :
      0 - pairedCauchyImKernel x y T * S T - J
        = -(pairedCauchyImKernel x y T * S T) - J := by ring
  rw [вЖР hconst]
  have hsymm : (fun X => pairedCauchyImKernel x y X * S X
                          - pairedCauchyImKernel x y T * S T
                          - derivativeSidePartial S x y T X)
              =бґ†[Filter.atTop] partialF := by
    filter_upwards [hfinite_eventually] with X heq
    exact heq.symm
  exact Filter.Tendsto.congr' hsymm htarget

/-- рЯМЯ **PROVED вАФ finite IBP identity holds eventually under
`OrderedTailWindowData`.** Combines `orderedWindow_eventually_atTop`
with `finiteFluctuationKernelPartial_true_ibp` and converts
`finiteFluctuationDerivativeIntegral` to `derivativeSidePartial`. -/
lemma finiteFluctuationKernelPartial_true_ibp_eventually
    (D : OrderedFluctuationMeasureData) (x y T : вДЭ) {m : вДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) :
    вИАбґ† X in Filter.atTop,
      finiteFluctuationKernelPartial D x y T X =
        pairedCauchyImKernel x y X
          * finiteFluctuationPrimitive D T X
          - derivativeSidePartial
              (fun U => finiteFluctuationPrimitive D T U) x y T X := by
  filter_upwards [orderedWindow_eventually_atTop D T Wtail,
                  Filter.eventually_ge_atTop T] with X W hTX
  have h := finiteFluctuationKernelPartial_true_ibp D x y T X W hT hTX hy
  -- `finiteFluctuationDerivativeIntegral = derivativeSidePartial` for `S = ffP D T`.
  show finiteFluctuationKernelPartial D x y T X
        = pairedCauchyImKernel x y X * finiteFluctuationPrimitive D T X
          - вИЂ u in T..X,
              finiteFluctuationPrimitive D T u * pairedCauchyImKernelDeriv x y u
  rw [h]
  rfl

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `finiteFluctuationKernelPartial` converges**
under a log envelope on `finiteFluctuationPrimitive D T` plus
finite-window integrability of `ffP ¬Ј k'`. The limit is `вИТJ` where
`J` is the limit of the derivative-side partial integral. -/
theorem finiteFluctuationKernelPartial_tendsto_of_logEnvelope
    (D : OrderedFluctuationMeasureData) (x y T C Dconst : вДЭ) {m : вДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 вЙ§ C) (hD : 0 вЙ§ Dconst)
    (hS : вИАбґ† X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| вЙ§ C * Real.log X + Dconst)
    (hInt : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    вИГ L, Tendsto (fun X => finiteFluctuationKernelPartial D x y T X)
      Filter.atTop (рЭУЭ L) := by
  obtain вЯ®J, hJвЯ© :=
    derivative_integral_tendsto_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y) (T := T)
      hy hT hC hD hS hInt
  have hb :
      Tendsto (fun X => pairedCauchyImKernel x y X
                          * finiteFluctuationPrimitive D T X)
        Filter.atTop (рЭУЭ 0) :=
    boundary_atTop_of_log_envelope
      (S := fun U => finiteFluctuationPrimitive D T U)
      (C := C) (D := Dconst) (x := x) (y := y)
      (le_of_lt hy) hC hD hS
  have hfinite :=
    finiteFluctuationKernelPartial_true_ibp_eventually D x y T Wtail hT hy
  exact вЯ®-J, partialF_tendsto_of_clean_finiteIBP_and_limits
              hfinite hb hJвЯ©

-- =====================================================================
-- ¬ІCCVIII. EventualImproperKernelStieltjesIBP
-- =====================================================================
-- Eventual finite IBP variant of the ¬ІCLXXXVIII improper record.
-- The existing `ImproperKernelStieltjesIBP` requires `FiniteKernelStieltjesIBP`
-- with the per-`X` IBP identity holding for ALL `X`. Our finite IBP only
-- holds for `X` large enough (eventually under `OrderedWindow`). This
-- eventual-form record is mathematically sufficient for the improper
-- limit, since `partial_tendsto` only uses the eventual identity.

/-- **Eventual improper kernel Stieltjes IBP package.** Same as
`ImproperKernelStieltjesIBP` (¬ІCLXXXVIII) but accepts the finite IBP
identity as an `atTop`-eventual equality rather than `вИА X`. -/
structure EventualImproperKernelStieltjesIBP where
  S          : вДЭ вЖТ вДЭ
  partialF   : вДЭ вЖТ вДЭ
  x          : вДЭ
  y          : вДЭ
  T          : вДЭ
  L          : вДЭ
  finiteIBP_eventually :
    вИАбґ† X in Filter.atTop,
      partialF X =
        pairedCauchyImKernel x y X * S X
          - derivativeSidePartial S x y T X
  partial_tendsto :
    Tendsto partialF Filter.atTop (рЭУЭ L)
  boundary_atTop :
    Tendsto (fun X => pairedCauchyImKernel x y X * S X)
      Filter.atTop (рЭУЭ 0)
  derivative_integral_tendsto :
    вИГ J, Tendsto (fun X => derivativeSidePartial S x y T X)
      Filter.atTop (рЭУЭ J)

/-- в≠Р **PROVED вАФ improper identity for the eventual record.**
The limit `L` equals `-J` where `J` is the limit of the derivative-side
partial integral. Uses `partialF_tendsto_of_clean_finiteIBP_and_limits`
to derive `Tendsto partialF (рЭУЭ (-J))`, then uniqueness pins `L = -J`. -/
theorem EventualImproperKernelStieltjesIBP.improper_identity
    (I : EventualImproperKernelStieltjesIBP) :
    вИГ J,
      Tendsto (fun X => derivativeSidePartial I.S I.x I.y I.T X)
        Filter.atTop (рЭУЭ J)
      вИІ I.L = -J := by
  rcases I.derivative_integral_tendsto with вЯ®J, hJвЯ©
  have hL' : Tendsto I.partialF Filter.atTop (рЭУЭ (-J)) :=
    partialF_tendsto_of_clean_finiteIBP_and_limits
      I.finiteIBP_eventually I.boundary_atTop hJ
  have huniq : I.L = -J := tendsto_nhds_unique I.partial_tendsto hL'
  exact вЯ®J, hJ, huniqвЯ©

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ Eventual improper IBP from ordered-tail data
+ log envelope.** End-to-end constructor: given the window-invariant
zero-list data, `T > 0`, `y > 0`, a log envelope on the finite
fluctuation primitive, and finite-window integrability of `ffP ¬Ј k'`,
produces the eventual improper IBP record. -/
noncomputable def eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : вДЭ) {m : вДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 вЙ§ C) (hD : 0 вЙ§ Dconst)
    (hS : вИАбґ† X in Filter.atTop,
            |finiteFluctuationPrimitive D T X| вЙ§ C * Real.log X + Dconst)
    (hInt : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X) :
    EventualImproperKernelStieltjesIBP :=
  -- We pre-extract the `L` witness via `Classical.choose`. `obtain` is
  -- unavailable in a structure-building term because `Exists.casesOn` is
  -- restricted to elimination into `Prop`.
  let hL_exists :=
    finiteFluctuationKernelPartial_tendsto_of_logEnvelope
      D x y T C Dconst Wtail hT hy hC hD hS hInt
  { S := fun U => finiteFluctuationPrimitive D T U
    partialF := fun X => finiteFluctuationKernelPartial D x y T X
    x := x
    y := y
    T := T
    L := hL_exists.choose
    finiteIBP_eventually :=
      finiteFluctuationKernelPartial_true_ibp_eventually
        D x y T Wtail hT hy
    partial_tendsto := hL_exists.choose_spec
    boundary_atTop :=
      boundary_atTop_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y)
        (le_of_lt hy) hC hD hS
    derivative_integral_tendsto :=
      derivative_integral_tendsto_of_log_envelope
        (S := fun U => finiteFluctuationPrimitive D T U)
        (C := C) (D := Dconst) (x := x) (y := y) (T := T)
        hy hT hC hD hS hInt }

-- =====================================================================
-- ¬ІCCIX. Bridge: EventualImproperKernelStieltjesIBP вЖТ ImaginaryStieltjesTailIBPBound
-- =====================================================================
-- Direct mirror of ¬ІCXC `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`,
-- consuming the eventual improper IBP record. Mathematically identical
-- вАФ both versions only repack the data fields `S`, `T`, `x`, `y` plus
-- the user-supplied `B`, `integralBound`, `modelMargin`, `ibpMargin`.

/-- рЯМЯ **PROVED вАФ bridge from `EventualImproperKernelStieltjesIBP` to
`ImaginaryStieltjesTailIBPBound`** (¬І13 / ¬ІCXC chain). Mirror of the
old `ImproperKernelStieltjesIBP.toImaginaryTailIBPBound`. -/
noncomputable def EventualImproperKernelStieltjesIBP.toImaginaryTailIBPBound
    (I : EventualImproperKernelStieltjesIBP)
    (B : вДЭ вЖТ вДЭ)
    (hS_bound : вИА u : вДЭ, I.T вЙ§ u вЖТ |I.S u| вЙ§ B u)
    (Jbound : вДЭ)
    (modelMargin : вДЭ)
    (hmargin :
      |pairedCauchyImKernel I.x I.y I.T| * B I.T + Jbound вЙ§ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S            := I.S
  B            := B
  T            := I.T
  x            := I.x
  y            := I.y
  hS_bound     := hS_bound
  integralBound := Jbound
  modelMargin  := modelMargin
  ibpMargin    := hmargin

-- =====================================================================
-- ¬ІCCX. Explicit `|J|` bound from the derivative-side majorant
-- =====================================================================
-- Pass the finite-window absolute comparison
--   `|вИЂ_T^X S¬Јk'| вЙ§ вИЂ_T^X M`
-- to the `X вЖТ вИЮ` limit using:
--   вАҐ `derivativeSidePartial вЖТ J`
--   вАҐ `вИЂ_T^X M вЖТ вИТP(T)`  (explicit Tendsto via the majorant primitive)
-- Combined via `le_of_tendsto_of_tendsto'`.

/-- рЯМЯ **PROVED вАФ explicit Tendsto for the majorant integral.**
The integral `вИЂ_T^X M(u) du` tends to `вИТP(T)` as `X вЖТ вИЮ`. Explicit
form (the existence-only `derivativeSideMajorantConverges` is the
вИГ-wrapped version of this). -/
theorem derivativeSideMajorant_integral_tendsto_atTop
    (_x y T C D : вДЭ) (hT : 0 < T) :
    Tendsto (fun X => вИЂ u in T..X, derivativeSideMajorant y C D u)
      Filter.atTop (рЭУЭ (-derivativeSideMajorantPrimitive y C D T)) := by
  have hprim0 := derivativeSideMajorantPrimitive_tendsto_zero y C D
  have hconst : Tendsto (fun _ : вДЭ => derivativeSideMajorantPrimitive y C D T)
      Filter.atTop (рЭУЭ (derivativeSideMajorantPrimitive y C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : вДЭ =>
      derivativeSideMajorantPrimitive y C D X
        - derivativeSideMajorantPrimitive y C D T) Filter.atTop
      (рЭУЭ (0 - derivativeSideMajorantPrimitive y C D T)) :=
    hprim0.sub hconst
  rw [show (0 - derivativeSideMajorantPrimitive y C D T
            = -derivativeSideMajorantPrimitive y C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  symm
  exact derivativeSideMajorant_integral_eq_sub y C D T X hT hTX

/-- рЯМЯ **PROVED вАФ finite-window absolute bound** for the derivative-side
partial integral. Requires:
* `T` already inside the adaptive regime (`2(1+|x|+y) вЙ§ T`);
* log envelope on `S` on `[T, вИЮ)`. -/
lemma derivativeSidePartial_abs_le_majorant_partial
    {S : вДЭ вЖТ вДЭ} (C D x y T X : вДЭ)
    (hy : 0 < y) (hT : 0 < T) (_hC : 0 вЙ§ C) (_hD : 0 вЙ§ D)
    (hreg : 2 * (1 + |x| + y) вЙ§ T)
    (hS_T : вИА u, T вЙ§ u вЖТ |S u| вЙ§ C * Real.log u + D)
    (hInt : IntervalIntegrable
      (fun u => S u * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X)
    (hTX : T вЙ§ X) :
    |derivativeSidePartial S x y T X|
      вЙ§ вИЂ u in T..X, derivativeSideMajorant y C D u := by
  unfold derivativeSidePartial
  apply intervalIntegral_abs_le_intervalIntegral_majorant hTX hInt
    (derivativeSideMajorant_intervalIntegrable y C D T X hT hTX)
  intro u hu
  unfold derivativeSideMajorant
  rw [abs_mul]
  have hSu : |S u| вЙ§ C * Real.log u + D := hS_T u hu.1
  have hreg_u : 2 * (1 + |x| + y) вЙ§ u := le_trans hreg hu.1
  have hk : |pairedCauchyImKernelDeriv x y u| вЙ§ 18 * y / u^3 :=
    abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le hreg_u le_rfl
  have henv_nn : 0 вЙ§ C * Real.log u + D := le_trans (abs_nonneg _) hSu
  exact mul_le_mul hSu hk (abs_nonneg _) henv_nn

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ EXPLICIT `|J|` BOUND from the majorant primitive.**

Under `T` in the adaptive regime + log envelope on `S` from `T` onward
+ derivative-side integral convergence, the limit `J` satisfies

  `|J| вЙ§ вИТderivativeSideMajorantPrimitive y C D T`.

This is the explicit closed-form bound needed by the ¬І13 / ¬ІCXC
slab-chain (which currently consumes `closedFormSErrorBoundCD`-style
quantities). Combines the finite-window absolute comparison with
`le_of_tendsto_of_tendsto'` at the `X вЖТ вИЮ` limit. -/
theorem derivative_integral_limit_abs_le_majorant_tail
    {S : вДЭ вЖТ вДЭ} {C D x y T J : вДЭ}
    (hy : 0 < y) (hT : 0 < T) (hC : 0 вЙ§ C) (hD : 0 вЙ§ D)
    (hreg : 2 * (1 + |x| + y) вЙ§ T)
    (hS_T : вИА u, T вЙ§ u вЖТ |S u| вЙ§ C * Real.log u + D)
    (hInt : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hJ : Tendsto (fun X => derivativeSidePartial S x y T X)
            Filter.atTop (рЭУЭ J)) :
    |J| вЙ§ -derivativeSideMajorantPrimitive y C D T := by
  -- absolute limit
  have h_abs_J : Tendsto
      (fun X => |derivativeSidePartial S x y T X|) Filter.atTop (рЭУЭ |J|) :=
    hJ.abs
  -- explicit majorant limit
  have h_M_lim : Tendsto
      (fun X => вИЂ u in T..X, derivativeSideMajorant y C D u) Filter.atTop
      (рЭУЭ (-derivativeSideMajorantPrimitive y C D T)) :=
    derivativeSideMajorant_integral_tendsto_atTop x y T C D hT
  -- eventually pointwise bound
  have h_eventually : вИАбґ† X in Filter.atTop,
      |derivativeSidePartial S x y T X|
        вЙ§ вИЂ u in T..X, derivativeSideMajorant y C D u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact derivativeSidePartial_abs_le_majorant_partial
      C D x y T X hy hT hC hD hreg hS_T (hInt X hTX) hTX
  -- combine via le_of_tendsto_of_tendsto (вИАбґ† form, no prime)
  exact le_of_tendsto_of_tendsto h_abs_J h_M_lim h_eventually

-- =====================================================================
-- ¬ІCCXI. Real tail adapter (parallel to ¬ІCLXXXV dummy; no deletion)
-- =====================================================================
-- Combines the ¬ІCCVIII eventual improper IBP record with the ¬ІCCX
-- explicit `|J|` bound and the ¬ІCCIX tail-bound bridge into a single
-- theorem producing an `ImaginaryStieltjesTailIBPBound` directly from
-- ordered-tail data + log envelope + regularity. This is the
-- *real* tail-model adapter; it sits parallel to ¬ІCLXXXV's dummy path
-- (`linearDensityTail100`) without replacing it yet.

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ REAL TAIL MODEL ADAPTER**:
end-to-end constructor producing an `ImaginaryStieltjesTailIBPBound`
from local ordered-tail / log-envelope / adaptive-regime data.

Hypotheses:
* `OrderedTailWindowData D T m` вАФ window-invariant zero data;
* `0 < T`, `0 < y`, `0 вЙ§ C`, `0 вЙ§ Dconst`;
* `2 (1 + |x| + y) вЙ§ T` вАФ adaptive-regime threshold;
* `hS_T` вАФ log envelope `|ffP D T u| вЙ§ C¬Јlog u + Dconst` on `[T, вИЮ)`;
* `hInt` вАФ finite-window integrability of `ffP ¬Ј k'` on `[T, X]`;
* `hBbound` вАФ chosen `B : вДЭ вЖТ вДЭ` dominating `|ffP|` on `[T, вИЮ)`;
* `hmargin` вАФ the IBP-margin inequality
   `|k(T)|¬ЈB(T) + (вИТP(T)) вЙ§ modelMargin`
  (the user-controlled "model margin" obligation).

Output: an `ImaginaryStieltjesTailIBPBound` with
`integralBound := вИТderivativeSideMajorantPrimitive y C Dconst T`. -/
noncomputable def imaginaryTailIBPBound_of_orderedTail_logEnvelope
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : вДЭ) (B : вДЭ вЖТ вДЭ)
    (modelMargin : вДЭ) {m : вДХ}
    (Wtail : OrderedTailWindowData D T m)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 вЙ§ C) (hD : 0 вЙ§ Dconst)
    (_hregime : 2 * (1 + |x| + y) вЙ§ T)
    (hS_T : вИА u, T вЙ§ u вЖТ
      |finiteFluctuationPrimitive D T u| вЙ§ C * Real.log u + Dconst)
    (hInt : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    (hBbound : вИА u, T вЙ§ u вЖТ |finiteFluctuationPrimitive D T u| вЙ§ B u)
    (hmargin :
      |pairedCauchyImKernel x y T| * B T
        + (-derivativeSideMajorantPrimitive y C Dconst T) вЙ§ modelMargin) :
    ImaginaryStieltjesTailIBPBound :=
  -- Derive the eventually form from the strong form
  let hS : вИАбґ† X in Filter.atTop,
      |finiteFluctuationPrimitive D T X| вЙ§ C * Real.log X + Dconst := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    exact hS_T X hTX
  -- Build the eventual improper IBP record
  let I := eventualImproperKernelStieltjesIBP_of_orderedTail_logEnvelope
    D x y T C Dconst Wtail hT hy hC hD hS hInt
  -- Apply the ¬ІCCIX bridge with Jbound := -P(T)
  I.toImaginaryTailIBPBound B hBbound
    (-derivativeSideMajorantPrimitive y C Dconst T)
    modelMargin hmargin

/-- в≠Р **PROVED вАФ the `|J|` bound the adapter relies on.**
The `derivative_integral_limit_abs_le_majorant_tail` theorem applied
to the finite-fluctuation primitive: under the adapter's hypotheses,

  `|J| вЙ§ вИТderivativeSideMajorantPrimitive y C Dconst T`

where `J` is the derivative-side improper integral's limit.

This is the *honesty witness* that `integralBound := вИТP(T)` in the
adapter above is a valid bound on the actual `J`. (The adapter itself
doesn't enforce this вАФ it just packages the data вАФ but having this
theorem ensures the user-supplied `hmargin` is a real margin.) -/
theorem imaginaryTailIBPBound_jBound_is_valid
    (D : OrderedFluctuationMeasureData)
    (x y T C Dconst : вДЭ)
    (hT : 0 < T) (hy : 0 < y) (hC : 0 вЙ§ C) (hD : 0 вЙ§ Dconst)
    (hregime : 2 * (1 + |x| + y) вЙ§ T)
    (hS_T : вИА u, T вЙ§ u вЖТ
      |finiteFluctuationPrimitive D T u| вЙ§ C * Real.log u + Dconst)
    (hInt : вИА X, T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => finiteFluctuationPrimitive D T u
                    * pairedCauchyImKernelDeriv x y u)
        MeasureTheory.volume T X)
    {J : вДЭ}
    (hJ : Tendsto (fun X => derivativeSidePartial
                              (fun u => finiteFluctuationPrimitive D T u)
                              x y T X)
            Filter.atTop (рЭУЭ J)) :
    |J| вЙ§ -derivativeSideMajorantPrimitive y C Dconst T :=
  derivative_integral_limit_abs_le_majorant_tail
    (S := fun u => finiteFluctuationPrimitive D T u)
    (C := C) (D := Dconst) (x := x) (y := y) (T := T)
    hy hT hC hD hregime hS_T hInt hJ

end Phase1IBP

-- =====================================================================
-- ¬ІCCXII. Real-tail bridge to the dummy chain (no deletion)
-- =====================================================================
-- Bridges the real IBP majorant bound `-P(T)` to the existing
-- `closedFormErrorControlledOnFiniteBand` predicate that the ¬ІCLXXXV
-- dummy chain consumes. Key algebraic fact:
--   `-P(T) вЙ§ closedFormSErrorBoundCD C D y T`   when `0 вЙ§ C, D, y`, `T вЙ• 1`.
-- Both `-P` and `closedFormSErrorBoundCD` scale as `y/T¬≤` with similar
-- `(log T)` and constant coefficients; the `closedForm` coefficients are
-- uniformly larger (`17C` vs `9C`, `17D` vs `9D`, same `9C/2`). Difference
-- equals `8y(C¬Јlog T + D)/T¬≤ вЙ• 0`.

/-- рЯМЯ **PROVED вАФ KEY ALGEBRAIC BOUND**:
  `-derivativeSideMajorantPrimitive y C D T  вЙ§  closedFormSErrorBoundCD C D y T`
when `0 вЙ§ C, D, y` and `T вЙ• 1`. The difference is `8y(C¬Јlog T + D)/T¬≤`. -/
lemma neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
    (C D y T : вДЭ) (hC : 0 вЙ§ C) (hD : 0 вЙ§ D) (hT_ge_1 : 1 вЙ§ T) (hy : 0 вЙ§ y) :
    -Phase1IBP.derivativeSideMajorantPrimitive y C D T
      вЙ§ closedFormSErrorBoundCD C D y T := by
  have hT_pos : 0 < T := lt_of_lt_of_le zero_lt_one hT_ge_1
  have hT2_pos : 0 < T^2 := by positivity
  have hT2_ne : T^2 вЙ† 0 := ne_of_gt hT2_pos
  have hlog_T : 0 вЙ§ Real.log T := Real.log_nonneg hT_ge_1
  have h_diff :
      closedFormSErrorBoundCD C D y T
        - (-Phase1IBP.derivativeSideMajorantPrimitive y C D T)
        = 8 * y * (C * Real.log T + D) / T^2 := by
    unfold Phase1IBP.derivativeSideMajorantPrimitive closedFormSErrorBoundCD
    field_simp
    ring
  have h_diff_nn : 0 вЙ§ 8 * y * (C * Real.log T + D) / T^2 := by
    apply div_nonneg _ hT2_pos.le
    have h1 : 0 вЙ§ C * Real.log T := mul_nonneg hC hlog_T
    have h2 : 0 вЙ§ C * Real.log T + D := by linarith
    have h3 : 0 вЙ§ 8 * y := by linarith
    exact mul_nonneg h3 h2
  linarith

/-- рЯМЯрЯМЯ **PROVED вАФ discharge `closedFormErrorControlledOnFiniteBand`
from a pointwise majorant-primitive bound on `Im(error z)`.**

Given `|Im(error z)| вЙ§ -P(z.im, (slabCD T).1, (slabCD T).2, T)` on the
`[10, 140]` adaptive region, the
`closedFormErrorControlledOnFiniteBand` predicate holds. Bridges real
IBP bounds into the existing dummy-chain infrastructure. -/
theorem closedFormErrorControlled_of_majorantPrimitive_bound
    (error : вДВ вЖТ вДВ)
    (hbound : вИА {z : вДВ} {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
              2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
              |(error z).im| вЙ§
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    closedFormErrorControlledOnFiniteBand error := by
  intro z T hT10 hT140 hy hreg
  have h_input := hbound hT10 hT140 hy hreg
  have hC_nn : 0 вЙ§ (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD_nn : 0 вЙ§ (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hT_ge_1 : 1 вЙ§ T := by linarith
  have hy_nn : 0 вЙ§ z.im := le_of_lt hy
  have h_alg :
      -Phase1IBP.derivativeSideMajorantPrimitive z.im
          (slabCD T).1 (slabCD T).2 T
        вЙ§ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T :=
    neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
      (slabCD T).1 (slabCD T).2 z.im T hC_nn hD_nn hT_ge_1 hy_nn
  linarith

/-- рЯМЯрЯМЯ **PROVED вАФ DUMMY-SPECIALIZED real-tail wrapper.**
Specializes the ¬ІCCXIII model-parametric
`localXiPackage_10_140_from_majorantBound` (below) to
`xiCloudDensityModel_zeros100ceil`. Preserved for backward
compatibility with the existing dummy chain вАФ prefer the
model-parametric version for new code. -/
noncomputable def localXiPackage_10_140_from_majorantBound_zeros100ceil
    (error : вДВ вЖТ вДВ)
    (hdecomp : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
          2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (hbound : вИА {z : вДВ} {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
              2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
              |(error z).im| вЙ§
                -Phase1IBP.derivativeSideMajorantPrimitive
                  z.im (slabCD T).1 (slabCD T).2 T) :
    LocalXiCloudDensityErrorPackage :=
  localXiPackage_10_140_zeros100ceil error hdecomp
    (closedFormErrorControlled_of_majorantPrimitive_bound error hbound)

