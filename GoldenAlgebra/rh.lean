-- =====================================================================
-- ┬ºCCCXXI. Finite canonical Hadamard product scaffolds
-- =====================================================================
-- Genus-1 Weierstrass factor `EÔéü(s/¤ü) = (1 - s/¤ü) ┬À exp(s/¤ü)` and
-- the finite Hadamard product. Uses Mathlib's `logDeriv_prod` for the
-- structural log-derivative-of-product identity. The per-factor
-- log-derivative computation `logDeriv (EÔéü(┬À/¤ü)) s = 1/(s-¤ü) + 1/¤ü`
-- is deferred to a future stride.

/-- **Genus-1 Hadamard factor** `EÔéü(s/¤ü) = (1 - s/¤ü) ┬À exp(s/¤ü)`. -/
noncomputable def hadamardGenus1Factor (¤ü s : Ôäé) : Ôäé :=
  (1 - s / ¤ü) * Complex.exp (s / ¤ü)

/-- Ô¡É **PROVED ÔÇö genus-1 factor non-vanishing when `s Ôëá ¤ü` and `¤ü Ôëá 0`.** -/
lemma hadamardGenus1Factor_ne_zero {¤ü s : Ôäé} (h¤ü : ¤ü Ôëá 0) (hs¤ü : s Ôëá ¤ü) :
    hadamardGenus1Factor ¤ü s Ôëá 0 := by
  unfold hadamardGenus1Factor
  apply mul_ne_zero
  ┬À intro h
    have h1 : s / ¤ü = 1 := by linear_combination -h
    have h2 : s = ¤ü := by
      have := h1
      field_simp at this
      exact this
    exact hs¤ü h2
  ┬À exact Complex.exp_ne_zero _

/-- Ô¡É **PROVED ÔÇö genus-1 factor is differentiable everywhere.** -/
lemma hadamardGenus1Factor_differentiableAt (¤ü s : Ôäé) :
    DifferentiableAt Ôäé (hadamardGenus1Factor ¤ü) s := by
  unfold hadamardGenus1Factor
  have h_left : DifferentiableAt Ôäé (fun y : Ôäé => 1 - y / ¤ü) s :=
    (differentiableAt_const _).sub (differentiableAt_id'.div_const _)
  have h_inner : DifferentiableAt Ôäé (fun y : Ôäé => y / ¤ü) s :=
    differentiableAt_id'.div_const _
  have h_right : DifferentiableAt Ôäé (fun y : Ôäé => Complex.exp (y / ¤ü)) s :=
    h_inner.cexp
  exact h_left.mul h_right

/-- **Finite Hadamard product** over a finite list of zero ordinates. -/
noncomputable def finiteHadamardProduct (zeros : Finset Ôäé) (s : Ôäé) : Ôäé :=
  ÔêÅ ¤ü Ôêê zeros, hadamardGenus1Factor ¤ü s

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `logDeriv` of the finite Hadamard product = ╬ú of
per-factor `logDeriv`s.** Direct application of Mathlib's
`logDeriv_prod`. -/
theorem logDeriv_finiteHadamardProduct
    {zeros : Finset Ôäé} {s : Ôäé}
    (h¤ü_ne : ÔêÇ ¤ü Ôêê zeros, ¤ü Ôëá 0)
    (hs_ne : ÔêÇ ¤ü Ôêê zeros, s Ôëá ¤ü) :
    logDeriv (finiteHadamardProduct zeros) s
      = Ôêæ ¤ü Ôêê zeros, logDeriv (hadamardGenus1Factor ¤ü) s := by
  unfold finiteHadamardProduct
  exact logDeriv_prod zeros (fun ¤ü => hadamardGenus1Factor ¤ü) s
    (fun ¤ü h¤ü => hadamardGenus1Factor_ne_zero (h¤ü_ne ¤ü h¤ü) (hs_ne ¤ü h¤ü))
    (fun ¤ü _ => hadamardGenus1Factor_differentiableAt ¤ü s)

/-- Ô¡É **PROVED ÔÇö bridge between `logDeriv` (Mathlib) and
`logDerivativeResponse` (this file).** Definitionally equal. -/
theorem logDerivativeResponse_eq_logDeriv (f : Ôäé ÔåÆ Ôäé) (z : Ôäé) :
    logDerivativeResponse f z = logDeriv f z := rfl

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `logDerivativeResponse` of the finite Hadamard
product = ╬ú of per-factor responses.** Same as `logDeriv_finiteHadamardProduct`
under the definitional equality. -/
theorem logDerivativeResponse_finiteHadamardProduct
    {zeros : Finset Ôäé} {s : Ôäé}
    (h¤ü_ne : ÔêÇ ¤ü Ôêê zeros, ¤ü Ôëá 0)
    (hs_ne : ÔêÇ ¤ü Ôêê zeros, s Ôëá ¤ü) :
    logDerivativeResponse (finiteHadamardProduct zeros) s
      = Ôêæ ¤ü Ôêê zeros, logDerivativeResponse (hadamardGenus1Factor ¤ü) s := by
  simp only [logDerivativeResponse_eq_logDeriv]
  exact logDeriv_finiteHadamardProduct h¤ü_ne hs_ne

-- =====================================================================
-- ┬ºCCCXXII. Per-factor log-derivative of the genus-1 Hadamard factor
-- =====================================================================
-- Closes the explicit value of `logDeriv (hadamardGenus1Factor ¤ü) s`
-- as the classical `1/(s-¤ü) + 1/¤ü`. Combined with ┬ºCCCXXI's finite
-- product log-derivative, this gives the regularized zero-sum form of
