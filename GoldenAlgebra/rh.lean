/-- Ô¡É **PROVED ÔÇö Mathlib discharge of `AnalyticZeroAdmitsFactorization`.**
Given any function `F : Ôäé ÔåÆ Ôäé` analytic and non-degenerate at `¤ü`
with `F ¤ü = 0`, Mathlib's isolated-zeros machinery extracts a
positive multiplicity `m` and an analytic non-vanishing remainder
`g`. The proof:

* `AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff` gives
  `(n, g, hg_an, hg_ne, hg_eq)` with `F z = (z ÔêÆ ¤ü)^n ÔÇó g z` near `¤ü`;
* `n > 0` follows: if `n = 0` then `F ¤ü = g ¤ü`, contradicting
  `F ¤ü = 0` and `g ¤ü Ôëá 0`;
* `ÔÇó` becomes `*` via `smul_eq_mul` on `Ôäé`;
* `g` is differentiable in a neighborhood of `¤ü` via
  `AnalyticAt.eventually_analyticAt` + `AnalyticAt.differentiableAt`;
* `deriv g / g` is continuous at `¤ü` via `AnalyticAt.deriv` +
  `AnalyticAt.continuousAt` + `ContinuousAt.div`. -/
theorem analytic_zero_admits_factorization
    (F : Ôäé ÔåÆ Ôäé) (¤ü : Ôäé) :
    AnalyticZeroAdmitsFactorization F ¤ü := by
  intro hND hzero
  obtain Ôƒ¿n, g, hg_an, hg_ne, hg_eqÔƒ® :=
    (AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff hND.isAnalytic).mpr
      hND.not_eventually_zero
  -- Show `n > 0` from `F ¤ü = 0` and `g ¤ü Ôëá 0`.
  have hm_pos : 0 < n := by
    by_contra hcon
    push_neg at hcon
    have hn0 : n = 0 := Nat.le_zero.mp hcon
    subst hn0
    have heq : F ¤ü = (¤ü - ¤ü) ^ 0 ÔÇó g ¤ü := hg_eq.self_of_nhds
    simp at heq
    rw [hzero] at heq
    exact hg_ne heq.symm
  -- Convert `ÔÇó` to `*` (canonical Ôäé-action).
  have hfactor : ÔêÇßÂá z in ­ØôØ ¤ü, F z = (z - ¤ü) ^ n * g z := by
    filter_upwards [hg_eq] with z hz
    rw [hz, smul_eq_mul]
