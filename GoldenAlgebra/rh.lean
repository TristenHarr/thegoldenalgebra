    nlinarith
  have h_exp_11_10_le_192pi : Real.exp (11/10 : тДЭ) тЙд 19 / (2 * Real.pi) :=
    le_trans h_exp_11_10_le h_301_le_192pi
  have h_exp_pos : 0 < Real.exp (11/10 : тДЭ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_11_10_le_192pi
  rwa [Real.log_exp] at h

/-- тнР **PROVED тАФ Endpoint bound: `log(32/(2╧А)) тЙе 8/5`.**
Chain: `(exp 1)^8 < 2.7182818286^8 тЙд 5^5` тЖТ `exp(8/5) тЙд 5`
тЖТ `5 тЙд 32/(2╧А)` via `╧А < 3.15`. -/
lemma log_32_div_2pi_ge_8_5 :
    (8 / 5 : тДЭ) тЙд Real.log (32 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_nn : 0 тЙд Real.exp 1 := le_of_lt h_exp_1_pos
  have h_exp_1_8_lt : (Real.exp 1)^8 < (2.7182818286 : тДЭ)^8 :=
    pow_lt_pow_leftтВА h_exp_1_lt h_exp_1_nn (by norm_num)
  have h_27_le_5 : (2.7182818286 : тДЭ)^8 тЙд (5 : тДЭ)^5 := by norm_num
  have h_exp_1_8_le : (Real.exp 1)^8 тЙд (5 : тДЭ)^5 := by linarith
  have h_exp_8_eq : Real.exp 8 = (Real.exp 1)^8 := by
    have h := Real.exp_one_pow 8
    have h_cast : ((8 : тДХ) : тДЭ) = (8 : тДЭ) := by norm_num
    rw [тЖР h_cast]; exact h.symm
  have h_exp_8_5_pow : (Real.exp (8/5 : тДЭ))^5 = Real.exp 8 := by
    have h := Real.exp_nat_mul (8/5 : тДЭ) 5
    have h_eq : ((5 : тДХ) : тДЭ) * (8/5 : тДЭ) = 8 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_exp_8_le : Real.exp 8 тЙд (5 : тДЭ)^5 := h_exp_8_eq тЦ╕ h_exp_1_8_le
  have h_exp_8_5_le : Real.exp (8/5 : тДЭ) тЙд 5 := by
    have h_pow_5_le : (Real.exp (8/5 : тДЭ))^5 тЙд (5 : тДЭ)^5 :=
      h_exp_8_5_pow тЦ╕ h_exp_8_le
    have h_exp_pos : 0 тЙд Real.exp (8/5 : тДЭ) := le_of_lt (Real.exp_pos _)
    have h_5_pos : (0 : тДЭ) тЙд 5 := by norm_num
    exact (pow_le_pow_iff_leftтВА h_exp_pos h_5_pos
              (by norm_num : (5 : тДХ) тЙа 0)).mp h_pow_5_le
  have h_5_le_322pi : (5 : тДЭ) тЙд 32 / (2 * Real.pi) := by
    rw [le_div_iffтВА h_2pi_pos]
    nlinarith
  have h_exp_8_5_le_322pi : Real.exp (8/5 : тДЭ) тЙд 32 / (2 * Real.pi) :=
    le_trans h_exp_8_5_le h_5_le_322pi
  have h_exp_pos : 0 < Real.exp (8/5 : тДЭ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_8_5_le_322pi
  rwa [Real.log_exp] at h

/-- **Helper def**: affine log lower bound on `[19, 32]`. -/
noncomputable def logAffine_19_32 (T : тДЭ) : тДЭ :=
  (11 / 10 : тДЭ) + (T - 19) / 26

/-- тнР **PROVED тАФ Affine LB for `log(T/(2╧А))` on `[19, 32]`.**
At T=19 gives 11/10; at T=32 gives 11/10 + 13/26 = 8/5. Via `Real.secant_le_log`. -/
lemma log_T_over_2pi_ge_affine_19_32
    {T : тДЭ} (hT19 : 19 тЙд T) (hT32 : T тЙд 32) :
    logAffine_19_32 T тЙд Real.log (T / (2 * Real.pi)) := by
  unfold logAffine_19_32
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi : тДЭ) тЙа 0 := ne_of_gt h_2pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T тЙа 0 := ne_of_gt hT_pos
  have h19pos : (0 : тДЭ) < 19 := by norm_num
  have h_19_lt_32 : (19 : тДЭ) < 32 := by norm_num
  have h_secant := Real.secant_le_log h19pos h_19_lt_32 hT19 hT32
  have h_div_19 : ((32 - T) / (32 - 19) : тДЭ) = (32 - T) / 13 := by norm_num
  have h_div_T19 : ((T - 19) / (32 - 19) : тДЭ) = (T - 19) / 13 := by norm_num
  rw [h_div_19, h_div_T19] at h_secant
  have h_log_T_div : Real.log (T / (2 * Real.pi)) = Real.log T - Real.log (2 * Real.pi) :=
    Real.log_div hT_ne h_2pi_ne
  have h_log_19_div : Real.log (19 / (2 * Real.pi)) = Real.log 19 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (19 : тДЭ) тЙа 0) h_2pi_ne
  have h_log_32_div : Real.log (32 / (2 * Real.pi)) = Real.log 32 - Real.log (2 * Real.pi) :=
    Real.log_div (by norm_num : (32 : тДЭ) тЙа 0) h_2pi_ne
  have h19 := log_19_div_2pi_ge_11_10
  have h32 := log_32_div_2pi_ge_8_5
  rw [h_log_19_div] at h19
  rw [h_log_32_div] at h32
  have h32mT_nn : 0 тЙд 32 - T := by linarith
  have hTm19_nn : 0 тЙд T - 19 := by linarith
  rw [h_log_T_div]
  nlinarith [h_secant, h19, h32, h32mT_nn, hTm19_nn]

/-- тнР **PROVED тАФ Affine LB for `zeroDensityRho` on `[19, 32]`.** -/
lemma zeroDensityRho_ge_affine_19_32
    {T : тДЭ} (hT19 : 19 тЙд T) (hT32 : T тЙд 32) :
    logAffine_19_32 T / (2 * Real.pi) тЙд zeroDensityRho T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_log_ge := log_T_over_2pi_ge_affine_19_32 hT19 hT32
  rw [show (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        = Real.log (T / (2 * Real.pi)) / (2 * Real.pi) by ring]
  apply div_le_div_of_nonneg_right h_log_ge (le_of_lt h_2pi_pos)

/-- **Helper def**: `tailK_19_32 T = (22/15) ┬╖ (logAffine/(2╧А)) / T`. -/
noncomputable def tailK_19_32 (T : тДЭ) : тДЭ :=
  (22 / 15 : тДЭ) * (logAffine_19_32 T / (2 * Real.pi)) / T

/-- **Helper def**: rational tail using `1/(2╧А) тЙе 7/44`. -/
noncomputable def tailK19_rat (T : тДЭ) : тДЭ :=
