/-! ### CW23: parameterized Backlund numerical budget + pointwise extraction -/

/-- Parameterized numerical budget for Backlund's good-height estimate at
a single height `T`.  `Type`-valued so the named contributions `J`, `R`,
`H` are directly accessible; the bridge `toData` recovers the existential
`BacklundNumericalDataAt T`. -/
structure BacklundNumericalBudgetAt (T : ℝ) where
  J : ℝ
  R : ℝ
  H : ℝ
  hJ_nonneg : 0 ≤ J
  hR_nonneg : 0 ≤ R
  hH_nonneg : 0 ≤ H
  hcontrol : |concreteS T| ≤ J + R + H
  hbudget : J + R + H ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2

/-- Bridge: parameterized budget → existential numerical data. -/
noncomputable def BacklundNumericalBudgetAt.toData {T : ℝ}
    (B : BacklundNumericalBudgetAt T) :
    BacklundNumericalDataAt T :=
  ⟨B.J, B.R, B.H, B.hJ_nonneg, B.hR_nonneg, B.hH_nonneg,
    B.hbudget, B.hcontrol⟩

/-- Pointwise Backlund numerical extraction at every good height: given
the three classical estimates at `T`, produce explicit nonnegative
contributions `J`, `R`, `H` summing to at most `(1/2)·log T + 1/2` and
dominating `|concreteS T|`. -/
structure BacklundPointwiseNumericalExtractionInput where
  extract_at :
    ∀ T : ℝ, RvMGoodHeight T → (140 : ℝ) ≤ T →
      BacklundJensenRectangleEstimate T →
      BacklundRightSideArgumentVariationEstimate T →
      BacklundHorizontalBoundaryEstimate T →
        BacklundNumericalBudgetAt T

/-- Bridge: pointwise budget extraction → existential numerical
extraction input. -/
noncomputable def
    BacklundPointwiseNumericalExtractionInput.toNumericalExtraction
    (P : BacklundPointwiseNumericalExtractionInput) :
    BacklundNumericalExtractionInput where
  extract := fun T hgood hT hJ hR hH =>
    (P.extract_at T hgood hT hJ hR hH).toData

/-- **CW23 — final theorem from pointwise Backlund numerics.**  The
genuine remaining obligation is now expressed with named accessors
`J`, `R`, `H` for the three classical contributions at every good
height `T ≥ 140`. -/
theorem concreteS_halfLogPlusHalf_of_pointwiseBacklundNumerics
    (P : BacklundPointwiseNumericalExtractionInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_numericalExtraction
    P.toNumericalExtraction hT

