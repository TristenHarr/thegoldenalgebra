                       ≤ (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : ℝ) ≤ y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : ℝ) * (((2/5 : ℝ) + (T - 12) / 10) / (2 * Real.pi)) * y / T
        ≤ (22 / 15) * zeroDensityRho T * y / T := by
