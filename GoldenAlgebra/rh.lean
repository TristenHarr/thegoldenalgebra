/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ AFZ canonical (mid) tail-limit from AFZ source
+ AFZ mid_eq + Turing envelope.** -/
theorem XiCanonicalResidualAsTailLimitAwayFromZeros_of_AFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (Hsrc : XiHadamardLogDerivativeSourceAFZ)
    (HmidHigh : StieltjesMidHighTailEqualityAFZ Dzero T0 Hsrc.zeroContribution) :
    XiCanonicalResidualAsTailLimitAwayFromZeros
      Dzero T0 honestZeroDensityModelTwoPi := by
  refine тЯи?_тЯй
  intro z hy hmid hne
  obtain тЯиL, hLтЯй :=
    XiFluctuationTailValue_exists_mid_of_turing
      Dzero T0 hT0_pos hT0_le_10 hTuring hy hmid
  have hZ := HmidHigh.mid_eq hy hne hmid hL
  have hlog := Hsrc.logDeriv_eq_zeroContribution z hy hne
  have hres :
      xiResidualError honestZeroDensityModelTwoPi z = L := by
    unfold xiResidualError
    rw [hlog, hZ, honestZeroDensityModelTwoPi_model_eq]
    ring
  rw [hres]
  exact hL.tendsto_tail

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ AFZ high tail-limit from AFZ source + AFZ
high_eq + highLog envelope.** -/
theorem XiHighResidualAsTailLimitAwayFromZeros_of_AFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 тЙд 140)
