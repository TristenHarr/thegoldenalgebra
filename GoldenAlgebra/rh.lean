/-! ### BD2: boundary-sum identity (target) -/

/-- Algebraic boundary-sum identity: the sum of the four strip boundary
integrals equals the outer rectangle integral minus the inner square integral.

The proof requires expanding each strip integral, splitting at shared interior
edges, and pairwise-cancelling reversed-orientation edge contributions.
Substantial pure-algebra step, left as a target. -/
structure FourStripBoundarySumIdentity
    {R : ZetaRectangle} {a : Ôäé}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  sum_eq :
    S.topStrip.unitPrincipalKernelRectangleIntegral a
      + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
      + S.leftStrip.unitPrincipalKernelRectangleIntegral a
      + S.rightStrip.unitPrincipalKernelRectangleIntegral a =
    R.unitPrincipalKernelRectangleIntegral a -
      R.smallSquareUnitKernelIntegral S

/-! ### BD4: four-strip CG + sum identity ÔçÆ boundary cancellation -/

/-- Combining the four strip Cauchy-Goursat facts with the boundary-sum
identity yields the rectangle-equals-square cancellation. -/
theorem fourStripBoundaryCancellation_of_sumIdentity
    {R : ZetaRectangle} {a : Ôäé}
    {S : R.SmallSquareInsideRectangle a}
    (CG : FourStripCauchyGoursatData S)
    (H : FourStripBoundarySumIdentity S) :
    FourStripBoundaryCancellation S where
  rectangle_eq_square := by
    have h_top : S.topStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.topCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_bot : S.bottomStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.bottomCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_left : S.leftStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.leftCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_right : S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.rightCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have hsum_zero :
        S.topStrip.unitPrincipalKernelRectangleIntegral a
          + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
          + S.leftStrip.unitPrincipalKernelRectangleIntegral a
          + S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      rw [h_top, h_bot, h_left, h_right]; ring
    have hsub :
        R.unitPrincipalKernelRectangleIntegral a -
          R.smallSquareUnitKernelIntegral S = 0 := by
      rw [ÔåÉ H.sum_eq]; exact hsum_zero
    exact sub_eq_zero.mp hsub

/-! ### BD5: rectangle-to-square deformation (conditional on sum identity) -/

/-- Once the boundary-sum identity is inhabited, the rectangle-to-square
