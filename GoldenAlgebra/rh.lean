/-- в≠Р **PROVED вАФ Helper: `simpleCloudSum` monotone under list append.** -/
lemma simpleCloudSum_append_ge_left
    (zs extra : List вДЭ) {x y : вДЭ} (hy : 0 < y) :
    simpleCloudSum zs x y вЙ§ simpleCloudSum (zs ++ extra) x y := by
  unfold simpleCloudSum
