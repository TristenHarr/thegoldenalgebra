/-- **PROVED тАФ L2 product law (scalar form).** -/
theorem Lambda_product_law (f g df dg : тДЭ) (hf : f тЙа 0) (hg : g тЙа 0) :
    (df * g + f * dg) / (f * g) = df / f + dg / g := by
  field_simp
  ring

/-- **PROVED тАФ L3 quotient law (scalar form).** -/
theorem Lambda_quotient_law (f g df dg : тДЭ) (hf : f тЙа 0) (hg : g тЙа 0) :
    ((df * g - f * dg) / g^2) / (f / g) = df / f - dg / g := by
  field_simp
  ring

/-- **PROVED тАФ L4 power law at m=2.** -/
theorem Lambda_power_law_two (f df : тДЭ) (hf : f тЙа 0) :
    (2 * f * df) / (f^2) = 2 * (df / f) := by
  field_simp
  ring

/-- **PROVED тАФ L4 power law at m=3.** -/
theorem Lambda_power_law_three (f df : тДЭ) (hf : f тЙа 0) :
    (3 * f^2 * df) / (f^3) = 3 * (df / f) := by
  field_simp
  ring

/-- **PROVED тАФ L6 local charge for simple root (real form).** -/
theorem Lambda_local_charge_simple_root
    (z a g dg : тДЭ) (ha : z тЙа a) (hg : g тЙа 0) :
    (g + (z - a) * dg) / ((z - a) * g)
      = 1 / (z - a) + dg / g := by
  have ha' : z - a тЙа 0 := sub_ne_zero.mpr ha
  field_simp
  ring

/-- **PROVED тАФ L7 divisor field for 3 simple roots.** -/
theorem divisor_field_three_roots (z a b c : тДЭ)
    (ha : z тЙа a) (hb : z тЙа b) (hc : z тЙа c) :
    1 / (z - a) + 1 / (z - b) + 1 / (z - c)
      = ((z-b)*(z-c) + (z-a)*(z-c) + (z-a)*(z-b))
          / ((z-a)*(z-b)*(z-c)) := by
  have ha' : z - a тЙа 0 := sub_ne_zero.mpr ha
  have hb' : z - b тЙа 0 := sub_ne_zero.mpr hb
  have hc' : z - c тЙа 0 := sub_ne_zero.mpr hc
  field_simp
  ring

/-- **PROVED тАФ L8 critical equilibrium for 2 simple roots at midpoint.** -/
theorem critical_equilibrium_two_roots (a b : тДЭ) (hab : a тЙа b) :
    let z := (a + b) / 2
    1 / (z - a) + 1 / (z - b) = 0 := by
  have h1 : ((a + b) / 2 - a) = (b - a) / 2 := by ring
  have h2 : ((a + b) / 2 - b) = (a - b) / 2 := by ring
  have hba : b - a тЙа 0 := sub_ne_zero.mpr (Ne.symm hab)
  have hab' : a - b тЙа 0 := sub_ne_zero.mpr hab
  simp only [h1, h2]
  rw [div_add_div _ _ (div_ne_zero hba (by norm_num))
                      (div_ne_zero hab' (by norm_num))]
  rw [div_eq_zero_iff]
  left
  field_simp

