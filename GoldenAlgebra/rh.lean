/-! ### AK1 sub-lemma: log-derivative of `(w - s)^m` -/

/-- Logarithmic derivative of the simple power factor.  This isolates
the `m * (z-s)^(m-1) / (z-s)^m = m / (z-s)` simplification that
underlies the principal-part identity. -/
theorem logDeriv_pow_sub
    {s z : вДВ} {m : вДХ}
    (hm : 0 < m)
    (hz : z вЙ† s) :
    logDeriv (fun w : вДВ => (w - s) ^ m) z = (m : вДВ) / (z - s) := by
  have hzs_ne : z - s вЙ† 0 := sub_ne_zero.mpr hz
  have h_sub : HasDerivAt (fun w : вДВ => w - s) 1 z :=
    (hasDerivAt_id z).sub_const s
  have h_pow : HasDerivAt (fun w : вДВ => (w - s) ^ m)
                  ((m : вДВ) * (z - s) ^ (m - 1) * 1) z := h_sub.pow m
  rw [logDeriv_apply]
  show deriv (fun w : вДВ => (w - s) ^ m) z / (z - s) ^ m = (m : вДВ) / (z - s)
  rw [h_pow.deriv, mul_one]
  rcases m with _ | m'
  ¬Ј omega
  ¬Ј have h_pow_m'_ne : (z - s) ^ m' вЙ† 0 := pow_ne_zero m' hzs_ne
    simp only [Nat.succ_sub_one, pow_succ]
    field_simp
    ring

/-! ### AK1 sub-lemma: log-derivative under product factorization -/

/-- If `f` agrees with `(w - s)^m * u w` on a neighborhood of `z`, and `z вЙ† s`,
`u z вЙ† 0`, `u` is differentiable at `z`, then `logDeriv f z` splits into the
pole term `m / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_factorization
    {f u : вДВ вЖТ вДВ} {s z : вДВ} {m : вДХ}
    (hm : 0 < m)
    (hz : z вЙ† s)
    (hu : u z вЙ† 0)
    (hu_diff : DifferentiableAt вДВ u z)
    (hf : f =бґ†[рЭУЭ z] fun w : вДВ => (w - s) ^ m * u w) :
    logDeriv f z = (m : вДВ) / (z - s) + logDeriv u z := by
  have h_pow_diff : DifferentiableAt вДВ (fun w : вДВ => (w - s) ^ m) z := by
    fun_prop
  have h_pow_ne : (z - s) ^ m вЙ† 0 := pow_ne_zero m (sub_ne_zero.mpr hz)
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : вДВ => (w - s) ^ m * u w) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_mul z h_pow_ne hu h_pow_diff hu_diff,
      logDeriv_pow_sub hm hz]

/-! ### AK1: continuous principal part from analytic zero factorization -/

/-- A local analytic zero factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = m/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_factorization
    {f : вДВ вЖТ вДВ} {s : вДВ} {m : вДХ}
    (hm_pos : 0 < m)
    (H : HasAnalyticZeroFactorization f s m) :
    HasLogDerivPrincipalPartContinuous f s (m : вД§) := by
  set u : вДВ вЖТ вДВ := H.unit with hu_def
  have hu_an : AnalyticAt вДВ u s := H.unit_analytic
  have hu_ne_s : u s вЙ† 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : вИАбґ† z in рЭУЭ s, u z вЙ† 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : вИАбґ† z in рЭУЭ s, DifferentiableAt вДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hfac_eventually_nhds :
      вИАбґ† z in рЭУЭ s, f =бґ†[рЭУЭ z] fun w : вДВ => (w - s) ^ m * u w :=
    H.factorization.eventually_nhds
  have hu_ne_punct : вИАбґ† z in рЭУЭ[вЙ†] s, u z вЙ† 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : вИАбґ† z in рЭУЭ[вЙ†] s, DifferentiableAt вДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hfac_punct :
      вИАбґ† z in рЭУЭ[вЙ†] s, f =бґ†[рЭУЭ z] fun w : вДВ => (w - s) ^ m * u w :=
    hfac_eventually_nhds.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : вИАбґ† z in рЭУЭ[вЙ†] s, z вЙ† s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine вЯ®logDeriv u, ?_, ?_вЯ©
  ¬Ј show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  ¬Ј filter_upwards [hfac_punct, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (m : вДВ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_factorization hm_pos hz_ne_z huz hu_diff_z hfz
    have hcast : ((m : вД§) : вДВ) = (m : вДВ) := by push_cast; rfl
    rw [hcast]
    exact hmain

/-- At a nontrivial zeta zero, `ќґ'/ќґ` has principal coefficient equal to the
analytic multiplicity, with continuous remainder. -/
theorem zetaLogDeriv_principalPartContinuous_at_nontrivial_zero
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    HasLogDerivPrincipalPartContinuous
      riemannZeta s
      (zetaGlobalZeroMultiplicity.mult s : вД§) :=
  hasLogDerivPrincipalPartContinuous_of_factorization
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaAnalyticZeroFactorization hs)

/-! ### AL1: simple-pole factorization interface -/

/-- Local factorization of a function with a simple pole at `s`:
on a punctured neighborhood of `s`, the function equals `unit z / (z - s)`
where `unit` is analytic and nonzero at `s`.

The factorization is stated in the *local* form so that derivative
identities (which need `=бґ†[рЭУЭ z]`) compose cleanly without an extra
upgrade lemma. -/
structure HasSimplePoleFactorization (f : вДВ вЖТ вДВ) (s : вДВ) where
  unit : вДВ вЖТ вДВ
  unit_analytic : AnalyticAt вДВ unit s
  unit_ne_zero : unit s вЙ† 0
  factorization_local :
    вИАбґ† z in рЭУЭ[вЙ†] s,
      f =бґ†[рЭУЭ z] fun w : вДВ => unit w / (w - s)

/-! ### AL2: log-derivative under simple-pole product factorization -/

/-- If `f` agrees with `u w / (w - s)` on a neighborhood of `z`, and
`z вЙ† s`, `u z вЙ† 0`, `u` is differentiable at `z`, then the logarithmic
derivative splits into the pole term `-1 / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_simplePoleFactorization
    {f u : вДВ вЖТ вДВ} {s z : вДВ}
    (hz : z вЙ† s)
    (hu : u z вЙ† 0)
    (hu_diff : DifferentiableAt вДВ u z)
    (hf : f =бґ†[рЭУЭ z] fun w : вДВ => u w / (w - s)) :
    logDeriv f z = (-1 : вДВ) / (z - s) + logDeriv u z := by
  have hzs_ne : z - s вЙ† 0 := sub_ne_zero.mpr hz
  have hsub_diff : DifferentiableAt вДВ (fun w : вДВ => w - s) z := by fun_prop
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : вДВ => u w / (w - s)) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_div z hu hzs_ne hu_diff hsub_diff]
  have h_sub_log :
      logDeriv (fun w : вДВ => w - s) z = (1 : вДВ) / (z - s) := by
    have h := logDeriv_pow_sub (m := 1) (s := s) (z := z) (by norm_num) hz
    simpa [pow_one] using h
  rw [h_sub_log]
  ring

/-! ### AL3: continuous principal part from simple-pole factorization -/

/-- A local simple-pole factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = -1/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization
    {f : вДВ вЖТ вДВ} {s : вДВ}
    (H : HasSimplePoleFactorization f s) :
    HasLogDerivPrincipalPartContinuous f s (-1) := by
  set u : вДВ вЖТ вДВ := H.unit with hu_def
  have hu_an : AnalyticAt вДВ u s := H.unit_analytic
  have hu_ne_s : u s вЙ† 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : вИАбґ† z in рЭУЭ s, u z вЙ† 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : вИАбґ† z in рЭУЭ s, DifferentiableAt вДВ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hu_ne_punct : вИАбґ† z in рЭУЭ[вЙ†] s, u z вЙ† 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : вИАбґ† z in рЭУЭ[вЙ†] s, DifferentiableAt вДВ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : вИАбґ† z in рЭУЭ[вЙ†] s, z вЙ† s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine вЯ®logDeriv u, ?_, ?_вЯ©
  ¬Ј show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  ¬Ј filter_upwards
      [H.factorization_local, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (-1 : вДВ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_simplePoleFactorization
        hz_ne_z huz hu_diff_z hfz
    have hcast : ((-1 : вД§) : вДВ) = (-1 : вДВ) := by push_cast; rfl
    rw [hcast]
