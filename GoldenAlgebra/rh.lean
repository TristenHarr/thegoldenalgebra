/-- **Low finite fluctuation contribution** тАФ the RHS of B2 as a single
real-valued object. -/
noncomputable def lowFiniteFluctuationContribution
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (z : тДВ) : тДЭ :=
  lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
    + (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        11 14 z).im

/-- тнР **PROVED тАФ `StieltjesLowContributionData` iff Im equality with
the named contribution.** Compact target for the analytic equality. -/
theorem StieltjesLowContributionData_iff_lowFiniteContribution
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ} {ZC : тДВ тЖТ тДВ} :
    StieltjesLowContributionData Dzero T0 ZC тЖФ
      тИА z, lowCompactRegion z тЖТ
        (ZC z - (cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
          = lowFiniteFluctuationContribution Dzero T0 z := by
  constructor
  ┬╖ intro H z hz
    simpa [lowFiniteFluctuationContribution] using H.low_value z hz
  ┬╖ intro H
    refine тЯи?_тЯй
    intro z hz
    simpa [lowFiniteFluctuationContribution] using H z hz

