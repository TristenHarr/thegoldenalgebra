  have h48_pos : (0 : вДЭ) < 48 / (2 * Real.pi) := by positivity
  have hratio : 48 / (2 * Real.pi) вЙ§ T / (2 * Real.pi) := by
    apply div_le_div_of_nonneg_right hT48 (le_of_lt h_2pi_pos)
  have hlogmono :
      Real.log (48 / (2 * Real.pi)) вЙ§ Real.log (T / (2 * Real.pi)) :=
    Real.log_le_log h48_pos hratio
  exact le_trans log_48_div_2pi_ge_2 hlogmono

