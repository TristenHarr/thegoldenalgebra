/-! ### BG2: reverse-edge cancellation in named form -/

theorem hEdge_add_reverse_eq_zero
    (y xÔéÇ xÔéü : ÔäØ) (a : Ôäé) :
    hEdge y xÔéÇ xÔéü a + hEdge y xÔéü xÔéÇ a = 0 := by
  unfold hEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun x : ÔäØ => unitPrincipalKernel a Ôƒ¿x, yÔƒ®) xÔéÇ xÔéü

theorem vEdge_add_reverse_eq_zero
    (x yÔéÇ yÔéü : ÔäØ) (a : Ôäé) :
    vEdge x yÔéÇ yÔéü a + vEdge x yÔéü yÔéÇ a = 0 := by
  unfold vEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun y : ÔäØ => unitPrincipalKernel a Ôƒ¿x, yÔƒ® * Complex.I) yÔéÇ yÔéü

theorem hEdge_reverse_eq_neg
    (y xÔéÇ xÔéü : ÔäØ) (a : Ôäé) :
    hEdge y xÔéü xÔéÇ a = -hEdge y xÔéÇ xÔéü a := by
