-- ¬ІCDXIX. Direct proof: `gammaPoleSet` is closed
-- =====================================================================
-- Strategy:
--   gammaPoleSet = Neg.neg вБї¬є' (Set.range ((вЖС) : вДХ вЖТ вДВ))
--   Set.range ((вЖС) : вДХ вЖТ вДВ) = (Im вБї¬є' {0}) вИ© (Re вБї¬є' Set.range ((вЖС) : вДХ вЖТ вДЭ))
--   Both factors closed (singleton + Nat closed embedding to вДЭ).

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `gammaPoleSet` is closed in вДВ.** -/
theorem isClosed_gammaPoleSet : IsClosed gammaPoleSet := by
  -- Step 1: `gammaPoleSet = -¬ЈвБї¬є Set.range ((вЖС) : вДХ вЖТ вДВ)`.
  have h_eq : gammaPoleSet = Neg.neg вБї¬є' Set.range ((вЖС) : вДХ вЖТ вДВ) := by
    ext z
    constructor
    ¬Ј rintro вЯ®n, hnвЯ©
      refine вЯ®n, ?_вЯ©
      simp [hn]
    ¬Ј rintro вЯ®n, hnвЯ©
      refine вЯ®n, ?_вЯ©
      have : -((n : вДВ)) = z := by rw [hn]; ring
      exact this.symm
  rw [h_eq]
  refine IsClosed.preimage continuous_neg ?_
  -- Step 2: `Set.range ((вЖС) : вДХ вЖТ вДВ) = (ImвБї¬є{0}) вИ© (ReвБї¬є Set.range ((вЖС) : вДХ вЖТ вДЭ))`.
  have h_re_im :
      Set.range ((вЖС) : вДХ вЖТ вДВ)
        = (Complex.im вБї¬є' ({0} : Set вДЭ)) вИ©
          (Complex.re вБї¬є' Set.range ((вЖС) : вДХ вЖТ вДЭ)) := by
    ext z
    constructor
    ¬Ј rintro вЯ®n, rflвЯ©
      refine вЯ®?_, n, ?_вЯ©
      ¬Ј simp
      ¬Ј simp
    ¬Ј rintro вЯ®him, n, hreвЯ©
      refine вЯ®n, ?_вЯ©
      apply Complex.ext
      ¬Ј -- goal: ((n : вДВ)).re = z.re
        have h3 : ((n : вДВ)).re = (n : вДЭ) := by simp
        exact h3.trans hre
      ¬Ј -- goal: ((n : вДВ)).im = z.im
        have h4 : ((n : вДВ)).im = 0 := by simp
        exact h4.trans him.symm
  rw [h_re_im]
  refine IsClosed.inter ?_ ?_
  ¬Ј exact isClosed_singleton.preimage Complex.continuous_im
  ¬Ј exact Nat.isClosedEmbedding_coe_real.isClosed_range.preimage
      Complex.continuous_re

