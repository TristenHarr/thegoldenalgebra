then its `ќЫвВА` commutes with `star`. -/
theorem WeakFEPair_ќЫвВА_star_of_f_modif_ofReal
    (P : WeakFEPair вДВ) (ѕЖ : вДЭ вЖТ вДЭ)
    (h : вИА x : вДЭ, P.f_modif x = ((ѕЖ x : вДЭ) : вДВ))
    (s : вДВ) :
    P.ќЫвВА (star s) = star (P.ќЫвВА s) := by
  unfold WeakFEPair.ќЫвВА
  have h_eq : P.f_modif = fun t : вДЭ => ((ѕЖ t : вДЭ) : вДВ) := funext h
  rw [h_eq]
  exact mellin_star_ofReal ѕЖ s

