/-! ### Guarded errorMargin helpers and local-package constructors -/

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ canonical mid residual error margin from a guarded
`Rcanon`, at non-zero `z`.** The non-zero-case workhorse of the guarded
mid local package: at any `z` with `XiPullback z тЙа 0`, the guarded mid
formula data gives the residual-equals-canonical-tail identity, and the
existing closed-form + slab-cert chain delivers `|Im(error)| тЙд -Im(model)`. -/
theorem canonicalMidResidual_errorMargin_AwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (RcanonAFZ : XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : тДВ}
    (hy : 0 < z.im)
    (hmid : тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
      2 * (1 + |z.re| + z.im) тЙд T)
    (hne : XiPullback z тЙа 0) :
    |(xiResidualError M z).im| тЙд -(M.model z).im := by
  have hc := canonicalAdaptiveT_spec hmid
  have h_id := RcanonAFZ.residual_im_eq_canonical_tail hy hmid hne
  rw [h_id]
  have h_tail_bound :=
    trueKernelAdaptiveTail_im_bound
      Dzero T0 hT0_pos hT0_le_10 hTuring
      hc.1 hc.2.1 hy hc.2.2
  exact le_trans h_tail_bound
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hc.1 hc.2.1 hy hc.2.2)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ guarded mid `LocalXiCloudDensityErrorPackage`.**
Internal `by_cases hzero : XiPullback z = 0`. Zero branch:
`errorMargin_at_XiPullback_zero_of_decomp`. Non-zero branch: the guarded
mid chain via `canonicalMidResidual_errorMargin_AwayFromZeros`. -/
noncomputable def midLocalPackage_of_canonicalResidualFormulaAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List тДЭ)
    (Tsmooth : тДЭ) (hTsmooth_ge : 2 * Real.pi тЙд Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (RcanonAFZ : XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M) :
    LocalXiCloudDensityErrorPackage where
  model := HModel.M.model
  error := xiResidualError HModel.M
  region := fun z =>
    тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T
  decomp := fun z _ => xiResidualError_decomp HModel.M z
  modelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  errorMargin := by
    intro z hreg hy
    by_cases hzero : XiPullback z = 0
    ┬╖ exact errorMargin_at_XiPullback_zero_of_decomp
        (hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel)
        (xiResidualError_decomp HModel.M) hy hzero
    ┬╖ exact canonicalMidResidual_errorMargin_AwayFromZeros
        Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M HModel.hzeros RcanonAFZ
        hy hreg hzero

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ guarded `highTErrorControlledAwayFromZeros` from
guarded log-envelope identity.** Guarded analog of
`highTErrorControlled_of_highTuringLogEnvelope`. -/
theorem highTErrorControlledAwayFromZeros_of_highTuringLogEnvelope
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 тЙд 140)
    (error : тДВ тЖТ тДВ)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (herror_high :
      тИА {z : тДВ} {T : тДЭ}
        (hT140 : 140 тЙд T) (hy : 0 < z.im)
        (hregime : 2 * (1 + |z.re| + z.im) тЙд T),
        XiPullback z тЙа 0 тЖТ
        (error z).im =
          (trueKernelTailOfLogEnvelope
            Dzero T0 hT0_pos
            (le_trans hT0_le_140 hT140)
            (by linarith : (0 : тДЭ) < T)
            hy
            (by
              filter_upwards [Filter.eventually_ge_atTop T] with u hu
              exact hHighLog hT140 hy hregime hu)).im) :
    highTErrorControlledAwayFromZeros error := by
  intro z T hT140 hy hregime hne
  rw [show |(error z).im| = |(error z).im| from rfl]
  have h_id := herror_high hT140 hy hregime hne
  rw [h_id]
  unfold highTClosedFormBound
  exact trueKernelTailOfLogEnvelope_im_bound
    Dzero T0 hT0_pos
    (le_trans hT0_le_140 hT140)
    (by linarith : (0 : тДЭ) < T)
    (by linarith : (1 : тДЭ) тЙд T)
    hy
    (by norm_num : (0 : тДЭ) тЙд 1 / 2)
    (by norm_num : (0 : тДЭ) тЙд 49 / 20)
    hregime
    (fun u hu => hHighLog hT140 hy hregime hu)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ guarded `highTErrorControlledAwayFromZeros` from
guarded `XiHighResidualTailIdentityAwayFromZeros`.** Specialization of the
above to the canonical residual identity. -/
theorem highTErrorControlledAwayFromZeros_of_XiHighResidualTailIdentityAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 тЙд 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
