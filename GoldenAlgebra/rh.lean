-- =====================================================================
-- §CCCLXXX. Subtype zero index candidate + zero-at-origin hazard audit
-- =====================================================================
-- A natural candidate for `ι` is the subtype of nonzero zeros of
-- `completedXiFunction`. **Hazard**: the Γ-based `completedXiFunction`
-- definition gives `completedXiFunction 0 = 0` because of the
-- `(1/2)·s·(s-1)` polynomial prefactor in the definition. So the
-- subtype excluding 0 cannot satisfy the strong `all_completedXi_zeros`
-- field of `ConcreteCompletedXiZeroSystem` — the zero at the origin
-- is missed.
--
-- The fix (§CCCLXXXI) is `ConcreteCompletedXiNonzeroZeroSystem` whose
-- surjectivity is restricted to **nonzero** zeros, with a bridge to
-- the strong version (§CCCLXXXII) under `completedXiFunction 0 ≠ 0`.

/-- **Subtype of nonzero zeros of `completedXiFunction`.** Natural
candidate for `ι`. -/
def CompletedXiNonzeroZeroIndex : Type :=
  { s : ℂ // completedXiFunction s = 0 ∧ s ≠ 0 }

/-- The subtype's zero-location map. -/
def completedXiNonzeroZeroLoc (i : CompletedXiNonzeroZeroIndex) : ℂ := i.1

-- =====================================================================
-- §CCCLXXXI. Nonzero zero-system (sharper)
-- =====================================================================

/-- 📦 **`ConcreteCompletedXiNonzeroZeroSystem`** — like
`ConcreteCompletedXiZeroSystem` but the surjectivity field only
covers **nonzero** zeros. Avoids the zero-at-origin hazard. -/
structure ConcreteCompletedXiNonzeroZeroSystem (ι : Type) : Type where
  zeroLoc : ι → ℂ
  zeroLoc_ne_zero : ∀ i : ι, zeroLoc i ≠ 0
  zeroLoc_is_zero : ∀ i : ι, completedXiFunction (zeroLoc i) = 0
  all_nonzero_completedXi_zeros :
    ∀ s : ℂ,
      completedXiFunction s = 0 → s ≠ 0 →
      ∃ i : ι, zeroLoc i = s

-- =====================================================================
-- §CCCLXXXII. Bridge: nonzero-zero system → zero system under
--             `completedXiFunction 0 ≠ 0`
-- =====================================================================

/-- ⭐ **PROVED — `ConcreteCompletedXiZeroSystem` from the nonzero
variant under `completedXiFunction 0 ≠ 0`.** This hypothesis is
strong; for the Γ-based `completedXiFunction` it is generally false.
A future refactor should use Mathlib's `entireRiemannXi` where the
zero at the origin is absorbed into the prefactor and this
hypothesis becomes provable. -/
def ConcreteCompletedXiNonzeroZeroSystem.toZeroSystem
    {ι : Type}
    (H : ConcreteCompletedXiNonzeroZeroSystem ι)
    (h0 : completedXiFunction 0 ≠ 0) :
    ConcreteCompletedXiZeroSystem ι :=
  { zeroLoc := H.zeroLoc
    zeroLoc_ne_zero := H.zeroLoc_ne_zero
    zeroLoc_is_zero := H.zeroLoc_is_zero
    all_completedXi_zeros := by
      intro s hs
      have hs0 : s ≠ 0 := by
        intro h
        apply h0
        rw [h] at hs
        exact hs
      exact H.all_nonzero_completedXi_zeros s hs hs0 }

-- =====================================================================
-- §CCCLXXXIII. Entire-ξ log-derivative source (AFZ)
-- =====================================================================

/-- 📦 **`EntireXiLogDerivativeSourceAFZ`** — AFZ log-derivative
source for the genuine entire ξ. -/
structure EntireXiLogDerivativeSourceAFZ : Type where
  xiZeroContribution : ℂ → ℂ
  differentiable_at :
    ∀ s : ℂ, entireRiemannXi s ≠ 0 → DifferentiableAt ℂ entireRiemannXi s
  xi_logDeriv_eq :
    ∀ s : ℂ, entireRiemannXi s ≠ 0 →
      logDerivativeResponse entireRiemannXi s = xiZeroContribution s

-- =====================================================================
-- §CCCLXXXIV. Bridge: entire ξ ↔ completed ξ at log-derivative
-- =====================================================================

/-- 📦 **`EntireXiToCompletedXiLogDerivBridge`** — quarantines the
Γ-pole/zero cancellation in a single named Prop. -/
structure EntireXiToCompletedXiLogDerivBridge : Prop where
  entire_nonzero_of_completed_nonzero :
    ∀ s : ℂ, completedXiFunction s ≠ 0 → entireRiemannXi s ≠ 0
  completed_differentiable_at_nonzero :
    ∀ s : ℂ, completedXiFunction s ≠ 0 →
      DifferentiableAt ℂ completedXiFunction s
  logDeriv_completed_eq_entire :
    ∀ s : ℂ, completedXiFunction s ≠ 0 →
      logDerivativeResponse completedXiFunction s
        = logDerivativeResponse entireRiemannXi s

/-- 🌟🌟 **PROVED — `CompletedXiLogDerivativeSourceAFZ` from
entire-ξ source + bridge.** -/
noncomputable def CompletedXiLogDerivativeSourceAFZ.of_entireXi
    (Hbridge : EntireXiToCompletedXiLogDerivBridge)
    (Hsrc : EntireXiLogDerivativeSourceAFZ) :
    CompletedXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution := Hsrc.xiZeroContribution
      xi_diff_at := ?_
      xi_logDeriv_eq := ?_ }
  · intro s hs
    exact Hbridge.completed_differentiable_at_nonzero s hs
  · intro s hs
    have hs_entire : entireRiemannXi s ≠ 0 :=
      Hbridge.entire_nonzero_of_completed_nonzero s hs
    calc logDerivativeResponse completedXiFunction s
        = logDerivativeResponse entireRiemannXi s :=
          Hbridge.logDeriv_completed_eq_entire s hs
      _ = Hsrc.xiZeroContribution s :=
          Hsrc.xi_logDeriv_eq s hs_entire

-- =====================================================================
-- §CCCLXXXV. Entire-ξ zero system
-- =====================================================================

/-- 📦 **`ConcreteEntireXiZeroSystem`** — nonzero zero system for
the genuine entire ξ. -/
structure ConcreteEntireXiZeroSystem (ι : Type) : Type where
  zeroLoc : ι → ℂ
  zeroLoc_ne_zero : ∀ i : ι, zeroLoc i ≠ 0
  zeroLoc_is_zero : ∀ i : ι, entireRiemannXi (zeroLoc i) = 0
  all_nonzero_entireXi_zeros :
    ∀ s : ℂ, entireRiemannXi s = 0 → s ≠ 0 →
      ∃ i : ι, zeroLoc i = s

/-- ⭐ **PROVED — `s ≠ zeroLoc i` when `entireRiemannXi s ≠ 0`.** -/
theorem ConcreteEntireXiZeroSystem.nonzero_no_collision
    {ι : Type} (H : ConcreteEntireXiZeroSystem ι)
    {s : ℂ} (hs : entireRiemannXi s ≠ 0) :
    ∀ i : ι, s ≠ H.zeroLoc i := by
  intro i hsi
  apply hs
  rw [hsi]
  exact H.zeroLoc_is_zero i

-- =====================================================================
-- §CCCLXXXVI. Entire-ξ inverse-square zero distribution
-- =====================================================================

/-- 📦 **`EntireXiZeroInvSqDistribution`** — RvM-style zero
distribution for entire ξ. -/
structure EntireXiZeroInvSqDistribution
    {ι : Type} (HZ : ConcreteEntireXiZeroSystem ι) : Prop where
  inv_sq_summable :
    Summable fun i : ι => (‖HZ.zeroLoc i‖ ^ 2)⁻¹
  eventually_large :
    ∀ s : ℂ,
      ∀ᶠ i in Filter.cofinite, 2 * ‖s‖ ≤ ‖HZ.zeroLoc i‖

/-- ⭐ **PROVED — convert to `HadamardZeroInvSqSummability`.** -/
theorem EntireXiZeroInvSqDistribution.toHadamardZeroInvSqSummability
    {ι : Type} {HZ : ConcreteEntireXiZeroSystem ι}
    (H : EntireXiZeroInvSqDistribution HZ) :
    HadamardZeroInvSqSummability HZ.zeroLoc :=
  { zero_ne := HZ.zeroLoc_ne_zero
    inv_sq_summable := H.inv_sq_summable
    eventually_large := H.eventually_large }

-- =====================================================================
-- §CCCLXXXVII. Entire-ξ Hadamard prefactor + factorization
-- =====================================================================

/-- 📦 **`EntireXiHadamardPrefactor`** — prefactor AFZ properties. -/
structure EntireXiHadamardPrefactor (prefactor : ℂ → ℂ) : Prop where
  differentiable_at_nonzero :
    ∀ s : ℂ, entireRiemannXi s ≠ 0 → DifferentiableAt ℂ prefactor s
  nonzero_at_nonzero :
    ∀ s : ℂ, entireRiemannXi s ≠ 0 → prefactor s ≠ 0

/-- ⭐ **PROVED — `C·exp(a + b·s)` is a valid entire-ξ prefactor.** -/
theorem EntireXiHadamardPrefactor.exp_affine
    {C a b : ℂ} (hC : C ≠ 0) :
    EntireXiHadamardPrefactor
      (fun s : ℂ => C * Complex.exp (a + b * s)) := by
  refine
    { differentiable_at_nonzero := ?_
      nonzero_at_nonzero := ?_ }
  · intro s _hs
    have h_aff : DifferentiableAt ℂ (fun s : ℂ => a + b * s) s :=
      (differentiableAt_const _).add
        ((differentiableAt_const _).mul differentiableAt_id')
    exact (differentiableAt_const _).mul h_aff.cexp
  · intro s _hs
    exact mul_ne_zero hC (Complex.exp_ne_zero _)

/-- 📦 **`EntireXiHadamardFactorization`** — classical Hadamard
product identity for entire ξ. -/
structure EntireXiHadamardFactorization
    {ι : Type}
    (HZ : ConcreteEntireXiZeroSystem ι) (prefactor : ℂ → ℂ) : Prop where
  factorization :
    ∀ s : ℂ,
      entireRiemannXi s
        = prefactor s * infiniteHadamardProduct HZ.zeroLoc s

-- =====================================================================
-- §CCCLXXXVIII. Entire-ξ Hadamard theorem bundle + AFZ source
-- =====================================================================

/-- 📦 **`EntireXiClassicalHadamardTheorem`** — publication-level
Hadamard theorem for entire ξ. -/
structure EntireXiClassicalHadamardTheorem (ι : Type) : Type where
  zeroSystem : ConcreteEntireXiZeroSystem ι
  prefactor : ℂ → ℂ
  zeroDistribution : EntireXiZeroInvSqDistribution zeroSystem
  luc : HadamardProductLUCLogDerivData zeroSystem.zeroLoc
  region :
    ∀ s : ℂ, entireRiemannXi s ≠ 0 → s ∈ luc.region
  factorization :
    EntireXiHadamardFactorization zeroSystem prefactor
  prefactorData :
    EntireXiHadamardPrefactor prefactor

/-- 🌟🌟🌟 **PROVED — `EntireXiLogDerivativeSourceAFZ` from the
entire-ξ Hadamard theorem.** -/
noncomputable def EntireXiClassicalHadamardTheorem.toLogDerivativeSourceAFZ
    {ι : Type} (H : EntireXiClassicalHadamardTheorem ι) :
    EntireXiLogDerivativeSourceAFZ := by
  refine
    { xiZeroContribution :=
        fun s =>
          logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroSystem.zeroLoc s
      differentiable_at := ?_
      xi_logDeriv_eq := ?_ }
  · intro s hs
    have hs_region : s ∈ H.luc.region := H.region s hs
    have hpref_diff : DifferentiableAt ℂ H.prefactor s :=
      H.prefactorData.differentiable_at_nonzero s hs
    have hprod_diff :
        DifferentiableAt ℂ
          (infiniteHadamardProduct H.zeroSystem.zeroLoc) s :=
      H.luc.infinite_differentiable_at s hs_region
    have hfun_eq :
        entireRiemannXi
          = fun s' => H.prefactor s'
              * infiniteHadamardProduct H.zeroSystem.zeroLoc s' := by
      funext s'
      exact H.factorization.factorization s'
    rw [hfun_eq]
    exact hpref_diff.mul hprod_diff
  · intro s hs
    have hs_region : s ∈ H.luc.region := H.region s hs
    have hpref_ne : H.prefactor s ≠ 0 :=
      H.prefactorData.nonzero_at_nonzero s hs
    have hprod_ne :
        infiniteHadamardProduct H.zeroSystem.zeroLoc s ≠ 0 := by
      intro h
      apply hs
      rw [H.factorization.factorization s, h, mul_zero]
    have hpref_diff : DifferentiableAt ℂ H.prefactor s :=
      H.prefactorData.differentiable_at_nonzero s hs
    have hprod_diff :
        DifferentiableAt ℂ
          (infiniteHadamardProduct H.zeroSystem.zeroLoc) s :=
      H.luc.infinite_differentiable_at s hs_region
    have hfun_eq :
        entireRiemannXi
          = H.prefactor * infiniteHadamardProduct H.zeroSystem.zeroLoc := by
      funext s'
      simpa [Pi.mul_apply] using H.factorization.factorization s'
    calc logDerivativeResponse entireRiemannXi s
        = logDeriv entireRiemannXi s := rfl
      _ = logDeriv (H.prefactor *
            infiniteHadamardProduct H.zeroSystem.zeroLoc) s := by
            rw [hfun_eq]
      _ = logDeriv H.prefactor s
            + logDeriv (infiniteHadamardProduct H.zeroSystem.zeroLoc) s :=
          logDeriv_mul s hpref_ne hprod_ne hpref_diff hprod_diff
      _ = logDerivativeResponse H.prefactor s
            + hadamardRegularizedLogDerivSeries H.zeroSystem.zeroLoc s := by
          rw [← logDerivativeResponse_eq_logDeriv (f := H.prefactor),
              ← logDerivativeResponse_eq_logDeriv
                  (f := infiniteHadamardProduct H.zeroSystem.zeroLoc),
              H.luc.logDeriv_eq_tsum s hs_region]

/-- 🌟🌟🌟 **PROVED — `CompletedXiLogDerivativeSourceAFZ` from
entire-ξ Hadamard theorem + bridge.** -/
noncomputable def EntireXiClassicalHadamardTheorem.toCompletedXiSourceAFZ
    {ι : Type}
    (H : EntireXiClassicalHadamardTheorem ι)
    (Hbridge : EntireXiToCompletedXiLogDerivBridge) :
    CompletedXiLogDerivativeSourceAFZ :=
  CompletedXiLogDerivativeSourceAFZ.of_entireXi
    Hbridge H.toLogDerivativeSourceAFZ

