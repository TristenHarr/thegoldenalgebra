-- CLX-helpers: denominator positivity + evenness in x
-- ---------------------------------------------------------------------
-- Boilerplate used by the SDP-to-Lean certificate compiler to clear
-- denominators safely and reduce each slab cert to its `x вЙ• 0` form.

/-- в≠Р **PROVED вАФ `(x вИТ g)¬≤ + y¬≤ > 0` for `y > 0`.** -/
theorem denom_cloud_pos (x y g : вДЭ) (hy : 0 < y) :
    0 < (x - g)^2 + y^2 := by positivity

/-- в≠Р **PROVED вАФ `(x + g)¬≤ + y¬≤ > 0` for `y > 0`.** -/
theorem denom_cloud_plus_pos (x y g : вДЭ) (hy : 0 < y) :
    0 < (x + g)^2 + y^2 := by positivity

/-- в≠Р **PROVED вАФ `(T вИТ |x|)¬≤ + y¬≤ > 0` for `y > 0`.** -/
theorem smooth_tail_denom_minus_pos (x y T : вДЭ) (hy : 0 < y) :
    0 < (T - |x|)^2 + y^2 := by positivity

/-- в≠Р **PROVED вАФ `(T + |x|)¬≤ + y¬≤ > 0` for `y > 0`.** -/
theorem smooth_tail_denom_plus_pos (x y T : вДЭ) (hy : 0 < y) :
    0 < (T + |x|)^2 + y^2 := by positivity

/-- в≠Р **PROVED вАФ `cloudImNegSum` is even in `x`.**
Per-term `((-x) вИТ g)¬≤ = (x + g)¬≤` and `((-x) + g)¬≤ = (x вИТ g)¬≤`, then
swap by commutativity of `+`. -/
theorem cloudImNegSum_neg_x (zeros : List вДЭ) (x y : вДЭ) :
    cloudImNegSum zeros (-x) y = cloudImNegSum zeros x y := by
  unfold cloudImNegSum
  congr 1
  apply List.map_congr_left
  intro g _
  have h1 : ((-x) - g)^2 = (x + g)^2 := by ring
  have h2 : ((-x) + g)^2 = (x - g)^2 := by ring
  rw [h1, h2]; ring

/-- в≠Р **PROVED вАФ `smoothTailRationalLowerBoundAbs` is even in `x`** (via `|вИТx| = |x|`). -/
theorem smoothTailRationalLowerBoundAbs_neg_x (x y T : вДЭ) :
    smoothTailRationalLowerBoundAbs (-x) y T
      = smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  rw [abs_neg]

/-- в≠Р **PROVED вАФ slab cert reduction to `x вЙ• 0`.** Halves SDP certificate
complexity: it suffices to discharge the polynomial inequality for
nonneg `x`, since both `cloudImNegSum` and
`smoothTailRationalLowerBoundAbs` are even in `x`. -/
theorem slabPolyIneq_of_nonneg_x
    {zeros : List вДЭ} {Tmin Tmax C D : вДЭ}
    (H : вИА x y T : вДЭ,
        0 вЙ§ x вЖТ
        Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ 0 < y вЖТ
        2 * (1 + x + y) вЙ§ T вЖТ
          closedFormSErrorBoundCD C D y T
            вЙ§ cloudImNegSum zeros x y
              + smoothTailRationalLowerBoundAbs x y T) :
    SlabPolyIneq zeros Tmin Tmax C D := by
  intro x y T hTmin hTmax hy hreg
  by_cases hx : 0 вЙ§ x
  ¬Ј have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at hreg
    exact H x y T hx hTmin hTmax hy hreg
  ¬Ј push_neg at hx
    have hxneg : 0 вЙ§ -x := by linarith
    have habs : |x| = -x := abs_of_neg hx
    rw [habs] at hreg
    have Hneg := H (-x) y T hxneg hTmin hTmax hy hreg
    -- Hneg : closedFormSErrorBoundCD вЙ§ cloudImNegSum zeros (-x) y + smoothTail (-x) y T
    rw [вЖР cloudImNegSum_neg_x zeros x y,
        вЖР smoothTailRationalLowerBoundAbs_neg_x x y T]
    exact Hneg

