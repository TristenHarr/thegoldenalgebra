namespace OverflowResidueRH

open Complex Filter Topology

-- =====================================================================
-- ¬І1. Sign laws
-- =====================================================================

/-- **Anti-Herglotz upper-half-plane sign law.** `R : вДВ вЖТ вДВ` is
anti-Herglotz iff `Im R z вЙ§ 0` for every `z` with `Im z > 0`. The sign law
of any real-rooted residue cloud `ќ£ m_j / (z вИТ r_j)` with real `r_j` and
positive `m_j`. -/
def AntiHerglotzUHP (R : вДВ вЖТ вДВ) : Prop :=
  вИА z : вДВ, 0 < z.im вЖТ (R z).im вЙ§ 0

/-- **Positive upper imaginary escape.** Some upper-half-plane point has
strictly positive imaginary response вАФ the witness produced by a nonreal
upper-half-plane pole of the function whose log-derivative is `R`. -/
def PositiveUpperImaginaryEscape (R : вДВ вЖТ вДВ) : Prop :=
  вИГ z : вДВ, 0 < z.im вИІ 0 < (R z).im

/-- **The clean iff.** Anti-Herglotz on the upper half-plane is precisely
the absence of positive upper-imaginary escape. -/
theorem antiHerglotz_iff_no_positiveUpperEscape (R : вДВ вЖТ вДВ) :
    AntiHerglotzUHP R вЖФ ¬ђ PositiveUpperImaginaryEscape R := by
  unfold AntiHerglotzUHP PositiveUpperImaginaryEscape
  constructor
  ¬Ј intro hanti вЯ®z, hzim, hRimвЯ©
    exact absurd (hanti z hzim) (not_le.mpr hRim)
  ¬Ј intro hno z hzim
    by_contra hpos
    push_neg at hpos
    exact hno вЯ®z, hzim, hposвЯ©

/-- The logical gate вАФ restating the iff as the contradiction direction. -/
theorem positive_escape_kills_antiHerglotz
    {R : вДВ вЖТ вДВ} (h : PositiveUpperImaginaryEscape R) :
    ¬ђ AntiHerglotzUHP R :=
  fun hanti => (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti h

-- =====================================================================
-- ¬І2. Real residue clouds
-- =====================================================================

/-- **Atom.** For a real root `r` and any upper-half-plane `z`,
  Im(1 / (z вИТ r)) = вИТ(Im z) / |z вИТ r|¬≤ вЙ§ 0.
The single nonpositivity fact from which the anti-Herglotz cloud law
follows by summation. -/
theorem complex_real_root_residue_imag_nonpos
    (z : вДВ) (r : вДЭ) (hz : 0 < z.im) :
    ((1 : вДВ) / (z - (r : вДВ))).im вЙ§ 0 := by
  -- z вЙ† r since z has positive imaginary part and r is real.
  have hne : z - (r : вДВ) вЙ† 0 := by
    intro h
    rw [sub_eq_zero] at h
    have him : z.im = ((r : вДВ)).im := congr_arg Complex.im h
    rw [Complex.ofReal_im] at him
    linarith
  rw [one_div, Complex.inv_im, Complex.sub_im, Complex.ofReal_im, sub_zero]
  have hns : 0 < Complex.normSq (z - (r : вДВ)) := Complex.normSq_pos.mpr hne
  exact le_of_lt (div_neg_of_neg_of_pos (by linarith) hns)

/-- **Real residue cloud is anti-Herglotz.** For any finite list of real
roots, the cloud `z вЖ¶ ќ£_r 1 / (z вИТ r)` satisfies the anti-Herglotz
upper-half-plane sign law.

This single list theorem subsumes the GA `polynomial_one/two/three_real_roots_logDeriv_antiHerglotz`
toy cases (GA 31563вАУ31589). -/
theorem real_residue_cloud_antiHerglotz_list (rs : List вДЭ) :
    AntiHerglotzUHP
      (fun z : вДВ => (rs.map (fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ)))).sum) := by
  intro z hz
  show ((rs.map (fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ)))).sum).im вЙ§ 0
  induction rs with
  | nil => simp
  | cons r rs ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have h1 : ((1 : вДВ) / (z - (r : вДВ))).im вЙ§ 0 :=
      complex_real_root_residue_imag_nonpos z r hz
    linarith

/-- в≠Р **PROVED вАФ weighted real residue cloud is anti-Herglotz.**
Generalizes `real_residue_cloud_antiHerglotz_list` to `(root, weight)`
pairs with non-negative real weights. Useful for multiplicities (just
repeat the same root) and for finite zero clouds with arbitrary positive
masses.

Mechanism: for real `w вЙ• 0` and real root `r`,
  `Im((w : вДВ) ¬Ј (1 / (z вИТ r)))  =  w ¬Ј Im(1 / (z вИТ r))  вЙ§  0`
since `w вЙ• 0` and `Im(1/(z вИТ r)) вЙ§ 0` (the `complex_real_root_residue_imag_nonpos`
atom). Sum nonpositive contributions by induction. -/
theorem real_weighted_residue_cloud_antiHerglotz_list
    (atoms : List (вДЭ √Ч вДЭ))
    (hweights : вИА a вИИ atoms, 0 вЙ§ a.2) :
    AntiHerglotzUHP
      (fun z : вДВ =>
        (atoms.map fun a : вДЭ √Ч вДЭ =>
          (a.2 : вДВ) * ((1 : вДВ) / (z - (a.1 : вДВ)))).sum) := by
  intro z hz
  show ((atoms.map fun a : вДЭ √Ч вДЭ =>
          (a.2 : вДВ) * ((1 : вДВ) / (z - (a.1 : вДВ)))).sum).im вЙ§ 0
  induction atoms with
  | nil => simp
  | cons a atoms ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have ha_weight : 0 вЙ§ a.2 := hweights a (List.mem_cons_self ..)
    have hrest : вИА b вИИ atoms, 0 вЙ§ b.2 :=
      fun b hb => hweights b (List.mem_cons_of_mem _ hb)
    have h_residue : ((1 : вДВ) / (z - (a.1 : вДВ))).im вЙ§ 0 :=
      complex_real_root_residue_imag_nonpos z a.1 hz
    have h_atom :
        ((a.2 : вДВ) * ((1 : вДВ) / (z - (a.1 : вДВ)))).im вЙ§ 0 := by
      -- Im((w : вДВ) ¬Ј c) = w ¬Ј c.im (since (w : вДВ).im = 0).
      rw [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im,
          zero_mul, add_zero]
      exact mul_nonpos_of_nonneg_of_nonpos ha_weight h_residue
    have h_tail := ih hrest
    linarith

-- =====================================================================
-- ¬І3. Pole-witness abstraction
-- =====================================================================

/-- The **overflow field** / logarithmic derivative
  ќЫ[f](z) := f'(z) / f(z).
A signed residue cloud for any factored object. -/
noncomputable def logDerivativeResponse (f : вДВ вЖТ вДВ) : вДВ вЖТ вДВ :=
  fun z => deriv f z / f z

/-- **Log-derivative pole-witness law.** Every upper-half-plane zero of
`f` produces positive upper-imaginary escape for the response `R`. In
applications `R = logDerivativeResponse f`; the parameterization keeps
the abstraction sharp.

Discharged in concrete cases by local factorization `f(z) = (z вИТ ѕБ)^m ¬Ј g(z)`
with `g(ѕБ) вЙ† 0`, applied to `ќЫ[f](z) = m / (z вИТ ѕБ) + g'(z)/g(z)`. The
constructive discharge for any such decomposition is
`localLogDerivPoleDecomposition_forces_escape` in ¬І5. -/
structure LogDerivPoleWitnessLaw (f R : вДВ вЖТ вДВ) : Prop where
  upper_zero_forces_escape :
    вИА ѕБ : вДВ, f ѕБ = 0 вЖТ 0 < ѕБ.im вЖТ PositiveUpperImaginaryEscape R

-- =====================================================================
-- ¬І4. Probe arithmetic at an upper pole  (CXXIX)
-- =====================================================================
-- The `m / (вИТќµ¬ЈI)` blow-up family. A real residue `m` divided by `вИТќµ¬ЈI`
-- rotates onto the positive imaginary axis with magnitude `m/ќµ`, which
-- diverges as `ќµ вЖУ 0` and defeats any bounded background.

/-- **PROVED вАФ escape value `m/ќµ` exceeds any bounded `K` once `ќµ < m/K`.**
This is the analytic clincher: a bounded background cannot kill the
`m/ќµ` divergence near an upper pole. -/
theorem escape_exceeds_bounded_background
    (m K eps : вДЭ) (_hm : m > 0) (hK : K > 0) (hќµ : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps > K := by
  rw [gt_iff_lt, lt_div_iffвВА hќµ]
  have hKne : K вЙ† 0 := ne_of_gt hK
  have : K * eps < K * (m / K) := by
    apply mul_lt_mul_of_pos_left hsmall hK
  have hKK : K * (m / K) = m := by
    field_simp
  rw [hKK] at this
  linarith

/-- **PROVED вАФ escape strictly positive: `m/ќµ вИТ K > 0` once `ќµ < m/K`.** -/
theorem residual_escape_positive
    (m K eps : вДЭ) (hm : m > 0) (hK : K > 0) (hќµ : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps - K > 0 := by
  have h := escape_exceeds_bounded_background m K eps hm hK hќµ hsmall
  linarith

/-- **PROVED вАФ probe subtraction: `(a + (bвИТќµ)¬ЈI) вИТ (a + b¬ЈI) = вИТќµ¬ЈI`.** -/
theorem complex_probe_subtraction (a b eps : вДЭ) :
    ((a : вДВ) + (b - eps) * Complex.I) - ((a : вДВ) + b * Complex.I)
      = -eps * Complex.I := by
  ring

/-- **PROVED вАФ `Im(m / (вИТќµ¬ЈI)) = m / ќµ`** for `ќµ вЙ† 0`.
The central probe identity: at the probe just below an upper pole, the
residue contribution `m / (z_ќµ вИТ ѕБ)` has imaginary part `m/ќµ`. -/
theorem upper_pole_probe_imag (m eps : вДЭ) (hќµ : eps вЙ† 0) :
    ((m : вДВ) / ((-eps : вДВ) * Complex.I)).im = m / eps := by
  have hќµ2 : eps^2 вЙ† 0 := pow_ne_zero 2 hќµ
  rw [Complex.div_im]
  rw [Complex.normSq_mul, Complex.normSq_I, mul_one]
  simp only [Complex.mul_re, Complex.mul_im, Complex.I_re, Complex.I_im,
    Complex.ofReal_re, Complex.ofReal_im, Complex.neg_re, Complex.neg_im,
    Complex.normSq_neg, Complex.normSq_ofReal,
    mul_zero, mul_one, zero_mul, sub_zero, add_zero, neg_zero, zero_sub,
    neg_neg]
  field_simp
  ring

/-- **PROVED вАФ `Im(m / (вИТќµ¬ЈI)) > 0` when `m, ќµ > 0`.** -/
theorem upper_pole_probe_imag_positive
    (m eps : вДЭ) (hm : 0 < m) (hќµ : 0 < eps) :
    0 < ((m : вДВ) / ((-eps : вДВ) * Complex.I)).im := by
  rw [upper_pole_probe_imag m eps (ne_of_gt hќµ)]
  exact div_pos hm hќµ

/-- **PROVED вАФ escape exceeds bounded background (complex form):**
if `m, ќµ > 0` and `ќµ < m/K` and `|Im B| вЙ§ K` then
`Im(m / (вИТќµ¬ЈI) + B) > 0`. -/
theorem upper_pole_escape_with_background_complex
    (m eps K : вДЭ) (B : вДВ)
    (hm : 0 < m) (hK : 0 < K) (hќµ : 0 < eps)
    (hsmall : eps < m / K)
    (hB : |B.im| вЙ§ K) :
    0 < (((m : вДВ) / ((-eps : вДВ) * Complex.I)) + B).im := by
  rw [Complex.add_im, upper_pole_probe_imag m eps (ne_of_gt hќµ)]
  have hescape : m / eps > K :=
    escape_exceeds_bounded_background m K eps hm hK hќµ hsmall
  have hB_lb : -K вЙ§ B.im := neg_le_of_abs_le hB
  linarith

/-- **PROVED вАФ escape via probe formula combined: at `z_ќµ` for upper pole
`ѕБ`, the residue + background imaginary part is positive.** -/
theorem polynomial_upper_root_forces_escape_complex
    (a b eps m K : вДЭ) (B : вДВ)
    (_hb : 0 < b) (hm : 0 < m) (hK : 0 < K)
    (hќµ : 0 < eps) (_hќµ_lt_b : eps < b)
    (hsmall : eps < m / K)
    (hB : |B.im| вЙ§ K) :
    0 < (((m : вДВ) /
      (((a : вДВ) + (b - eps) * Complex.I) - ((a : вДВ) + b * Complex.I))) + B).im := by
  rw [complex_probe_subtraction]
  exact upper_pole_escape_with_background_complex m eps K B hm hK hќµ hsmall hB

-- =====================================================================
-- ¬І5. Local pole decomposition engine  (CXXXI Layers 1вАУ2)
-- =====================================================================

/-- **Local-decomposition data for a log-derivative response at an upper
pole.** The pole is at `ѕБ` with multiplicity `m`. The response equals
`m/(z вИТ ѕБ) + background z` on the probe segment `ѕБ вИТ ќµ¬ЈI` for
`0 < ќµ < ќµ0`. The background's imaginary part is uniformly bounded by `K`
on that segment. -/
structure LocalLogDerivPoleDecomposition (R : вДВ вЖТ вДВ) (ѕБ : вДВ) where
  m : вДХ
  hm_pos : 0 < m
  background : вДВ вЖТ вДВ
  ќµ0 : вДЭ
  hќµ0 : 0 < ќµ0
  hќµ0_lt : ќµ0 < ѕБ.im
  K : вДЭ
  hK_pos : 0 < K
  decomp_at_probe :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
      R (ѕБ - (ќµ : вДВ) * Complex.I) =
        ((m : вДЭ) : вДВ) / ((ѕБ - (ќµ : вДВ) * Complex.I) - ѕБ) +
        background (ѕБ - (ќµ : вДВ) * Complex.I)
  background_bounded :
    вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
      |(background (ѕБ - (ќµ : вДВ) * Complex.I)).im| вЙ§ K

/-- **PROVED вАФ THE TRUE ANALYTIC ENGINE.** A local pole decomposition at
an upper pole forces a positive upper-imaginary escape. Pick
`ќµ := min(ќµвВА/2, m/(2K))`, apply `upper_pole_escape_with_background_complex`. -/
theorem localLogDerivPoleDecomposition_forces_escape
    {R : вДВ вЖТ вДВ} {ѕБ : вДВ}
    (D : LocalLogDerivPoleDecomposition R ѕБ) :
    PositiveUpperImaginaryEscape R := by
  have hm_real_pos : (0 : вДЭ) < (D.m : вДЭ) := by exact_mod_cast D.hm_pos
  have hmK_pos : 0 < (D.m : вДЭ) / D.K := div_pos hm_real_pos D.hK_pos
  let ќµ : вДЭ := min (D.ќµ0 / 2) ((D.m : вДЭ) / D.K / 2)
  have hќµ_pos : 0 < ќµ := by
    refine lt_min ?_ ?_
    ¬Ј linarith [D.hќµ0]
    ¬Ј linarith
  have hќµ_lt_ќµ0 : ќµ < D.ќµ0 := by
    refine lt_of_le_of_lt (min_le_left _ _) ?_
    linarith [D.hќµ0]
  have hќµ_lt_mK : ќµ < (D.m : вДЭ) / D.K := by
    refine lt_of_le_of_lt (min_le_right _ _) ?_
    linarith
  refine вЯ®ѕБ - (ќµ : вДВ) * Complex.I, ?_, ?_вЯ©
  ¬Ј -- 0 < (ѕБ вИТ ќµ¬ЈI).im = ѕБ.im вИТ ќµ
    have h_im : (ѕБ - (ќµ : вДВ) * Complex.I).im = ѕБ.im - ќµ := by
      simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
            Complex.ofReal_re, Complex.ofReal_im]
    rw [h_im]
    linarith [D.hќµ0_lt]
  ¬Ј -- 0 < Im(R(ѕБ вИТ ќµ¬ЈI))
    rw [D.decomp_at_probe ќµ hќµ_pos hќµ_lt_ќµ0]
    have hsub : (ѕБ - (ќµ : вДВ) * Complex.I) - ѕБ = -(ќµ : вДВ) * Complex.I := by
      ring
    rw [hsub]
    have hB := D.background_bounded ќµ hќµ_pos hќµ_lt_ќµ0
    exact upper_pole_escape_with_background_complex
      (D.m : вДЭ) ќµ D.K (D.background (ѕБ - (ќµ : вДВ) * Complex.I))
      hm_real_pos D.hK_pos hќµ_pos hќµ_lt_mK hB

/-- **PROVED вАФ complex local-pole decomposition for a simple root.**
If `p` factors locally as `p = (X вИТ ѕБ) ¬Ј q` at `z` with `q(z) вЙ† 0`
and `z вЙ† ѕБ`, then `(p value)' / (p value) = 1/(zвИТѕБ) + q'/q`.
Stated as an algebraic identity on values. -/
theorem complex_local_pole_decomposition_simple_root
    (z ѕБ q dq : вДВ) (hѕБ : z вЙ† ѕБ) (hq : q вЙ† 0) :
    (q + (z - ѕБ) * dq) / ((z - ѕБ) * q)
      = 1 / (z - ѕБ) + dq / q := by
  have hѕБ' : z - ѕБ вЙ† 0 := sub_ne_zero.mpr hѕБ
  field_simp
  ring

/-- **PROVED вАФ complex local-pole decomposition for multiplicity 2.**
If `p = (X вИТ ѕБ)¬≤ ¬Ј q`, then at `z вЙ† ѕБ`, `q(z) вЙ† 0`:
`p'(z)/p(z) = 2/(zвИТѕБ) + q'(z)/q(z)`. -/
theorem complex_local_pole_decomposition_double_root
    (z ѕБ q dq : вДВ) (hѕБ : z вЙ† ѕБ) (hq : q вЙ† 0) :
    (2 * (z - ѕБ) * q + (z - ѕБ)^2 * dq) / ((z - ѕБ)^2 * q)
      = 2 / (z - ѕБ) + dq / q := by
  have hѕБ' : z - ѕБ вЙ† 0 := sub_ne_zero.mpr hѕБ
  have hѕБ'2 : (z - ѕБ)^2 вЙ† 0 := pow_ne_zero 2 hѕБ'
  field_simp
  ring

/-- **PROVED вАФ complex local-pole decomposition for multiplicity 3.** -/
theorem complex_local_pole_decomposition_triple_root
    (z ѕБ q dq : вДВ) (hѕБ : z вЙ† ѕБ) (hq : q вЙ† 0) :
    (3 * (z - ѕБ)^2 * q + (z - ѕБ)^3 * dq) / ((z - ѕБ)^3 * q)
      = 3 / (z - ѕБ) + dq / q := by
  have hѕБ' : z - ѕБ вЙ† 0 := sub_ne_zero.mpr hѕБ
  have hѕБ'3 : (z - ѕБ)^3 вЙ† 0 := pow_ne_zero 3 hѕБ'
  field_simp
  ring

/-- **PROVED вАФ local-pole decomposition for general multiplicity `m = k+1`
in the form `(p value)' / (p value) = m/(zвИТѕБ) + q'/q`** when supplied
with the standard derivative expansion `m¬Ј(zвИТѕБ)^(mвИТ1)¬Јq + (zвИТѕБ)^m¬Јq'`. -/
theorem complex_local_pole_decomposition_general
    (z ѕБ q dq : вДВ) (k : вДХ) (hѕБ : z вЙ† ѕБ) (hq : q вЙ† 0) :
    (((k + 1 : вДХ) : вДВ) * (z - ѕБ)^k * q + (z - ѕБ)^(k + 1) * dq)
      / ((z - ѕБ)^(k + 1) * q)
      = ((k + 1 : вДХ) : вДВ) / (z - ѕБ) + dq / q := by
  have hѕБ' : z - ѕБ вЙ† 0 := sub_ne_zero.mpr hѕБ
  have hѕБ'k : (z - ѕБ)^k вЙ† 0 := pow_ne_zero k hѕБ'
  have hѕБ'sk : (z - ѕБ)^(k + 1) вЙ† 0 := pow_ne_zero (k + 1) hѕБ'
  rw [pow_succ]
  field_simp
  ring

-- =====================================================================
-- ¬І6. Engine theorems
-- =====================================================================

/-- **Anti-Herglotz forbids upper zeros.** Pole witness + anti-Herglotz
response вЗТ `f` has no upper-half-plane zeros. One line via the iff. -/
theorem antiHerglotz_forbids_upper_zeros
    {f R : вДВ вЖТ вДВ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R) :
    вИА ѕБ : вДВ, 0 < ѕБ.im вЖТ f ѕБ вЙ† 0 := by
  intro ѕБ hupper hzero
  have hesc := hpole.upper_zero_forces_escape ѕБ hzero hupper
  exact (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti hesc

/-- `(star z).im = -z.im` вАФ the `Star`-side restatement of `Complex.conj_im`. -/
theorem complex_star_im (ѕБ : вДВ) : (star ѕБ).im = -ѕБ.im := by
  show (starRingEnd вДВ ѕБ).im = -ѕБ.im
  exact Complex.conj_im ѕБ

/-- **Anti-Herglotz + Schwarz symmetry forces real zeros.** Trichotomy on
`ѕБ.im`:

* Upper zero: killed directly by `antiHerglotz_forbids_upper_zeros`.
* Lower zero: killed via conjugate reflection вАФ `f (star ѕБ) = star (f ѕБ) = 0`
  with `(star ѕБ).im = вИТѕБ.im > 0`, again contradicting
  `antiHerglotz_forbids_upper_zeros`. -/
theorem antiHerglotz_plus_symmetry_forces_real_zeros_complex
    {f R : вДВ вЖТ вДВ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R)
    (hsym : вИА z : вДВ, f (star z) = star (f z)) :
    вИА ѕБ : вДВ, f ѕБ = 0 вЖТ ѕБ.im = 0 := by
  intro ѕБ hѕБzero
  rcases lt_trichotomy ѕБ.im 0 with hneg | hzero | hpos
  ¬Ј -- lower zero вЗТ conjugate is upper zero вЗТ contradiction
    have hconj_zero : f (star ѕБ) = 0 := by
      rw [hsym ѕБ, hѕБzero]
      simp
    have hupper_conj : 0 < (star ѕБ).im := by
      rw [complex_star_im]
      linarith
    exact absurd hconj_zero
      (antiHerglotz_forbids_upper_zeros hpole hanti (star ѕБ) hupper_conj)
  ¬Ј exact hzero
  ¬Ј -- upper zero directly contradicts the engine
    exact absurd hѕБzero
      (antiHerglotz_forbids_upper_zeros hpole hanti ѕБ hpos)

-- =====================================================================
-- ¬І6-bis. Totalization-at-zeros analysis (engine soundness)
-- =====================================================================
-- A reviewer-flagged concern: `logDerivativeResponse f z = f'(z) / f(z)`
-- evaluates to `0` at any zero of `f` because Lean uses the totalized
-- division convention `a / 0 = 0`. So the anti-Herglotz inequality
-- `Im (R z) вЙ§ 0` reads as `0 вЙ§ 0` at every zero, trivially true.
--
-- The lemmas below make precise *why this is harmless*: the
-- pole-witness engine never queries `R` at a zero вАФ it queries `R` at a
-- probe `ѕБ вИТ ќµ¬ЈI` with `ќµ > 0`, which is provably distinct from `ѕБ`
-- (`probe_ne_pole`). At the probe, `f` is genuinely nonzero (by
-- analytic continuity on a small enough neighbourhood; this is what
-- `continuousAt_implies_probe_nonzero` packages), and the value
-- `m / (z вИТ ѕБ) + bounded` is the honest analytic content the engine
-- contradicts.
--
-- So `AntiHerglotzUHP R` is consumed by the engine *at probe points,
-- never at zeros*. The totalization is bookkeeping, not load-bearing.

/-- **PROVED вАФ totalized log-derivative is `0` at any zero.**
Pure consequence of Lean's `a / 0 = 0` convention; recorded as a named
lemma so the totalization behaviour is explicit. -/
theorem logDerivativeResponse_eq_zero_at_zero
    {f : вДВ вЖТ вДВ} {ѕБ : вДВ} (hzero : f ѕБ = 0) :
    logDerivativeResponse f ѕБ = 0 := by
  unfold logDerivativeResponse
  rw [hzero, div_zero]

/-- **PROVED вАФ anti-Herglotz inequality is vacuous at any zero.**
At a zero, both sides of `(R z).im вЙ§ 0` are `0`. The substantive
content of `AntiHerglotzUHP R` therefore lies entirely on the
zero-free set. -/
theorem antiHerglotz_at_zero_is_vacuous
    {f : вДВ вЖТ вДВ} {ѕБ : вДВ} (hzero : f ѕБ = 0) :
    (logDerivativeResponse f ѕБ).im = 0 := by
  rw [logDerivativeResponse_eq_zero_at_zero hzero]
  exact Complex.zero_im

/-- **PROVED вАФ engine probe is never a zero.** The escape constructed by
`localLogDerivPoleDecomposition_forces_escape` lives at probe
`ѕБ вИТ ќµ¬ЈI` with `ќµ > 0`, and the imaginary parts differ by exactly `ќµ`.
`f` is separately ensured nonzero at the probe by
`continuousAt_implies_probe_nonzero` (defined in ¬І9), so the totalization
at `ѕБ` itself never enters the engine's contradiction. (The ¬І9 lemma
`probe_ne_pole` proves the same fact in the same form; this copy lives
here so that ¬І6-bis is self-contained and can be quoted before ¬І9.) -/
theorem engine_probe_is_not_the_zero
    (ѕБ : вДВ) (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    ѕБ - (ќµ : вДВ) * Complex.I вЙ† ѕБ := by
  intro h
  have him_diff : (ѕБ - (ќµ : вДВ) * Complex.I).im = ѕБ.im := by rw [h]
  have him_calc : (ѕБ - (ќµ : вДВ) * Complex.I).im = ѕБ.im - ќµ := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- в≠Р **PROVED вАФ sharper anti-Herglotz form, restricted to nonzero
points.** `AntiHerglotzUHP R` with totalized `R = ќЫ[f]` is *equivalent*
on its substantive content to the same inequality demanded only at points
where `f вЙ† 0`. The forward direction is trivial; the backward direction
patches in the vacuous `0 вЙ§ 0` at zeros. This formalises the claim that
the totalization adds no proof obligations. -/
theorem antiHerglotz_iff_antiHerglotz_away_from_zeros
    (f : вДВ вЖТ вДВ) :
    AntiHerglotzUHP (logDerivativeResponse f)
      вЖФ вИА z : вДВ, 0 < z.im вЖТ f z вЙ† 0 вЖТ
          (logDerivativeResponse f z).im вЙ§ 0 := by
  constructor
  ¬Ј intro h z hz _; exact h z hz
  ¬Ј intro h z hz
    by_cases hfz : f z = 0
    ¬Ј rw [antiHerglotz_at_zero_is_vacuous hfz]
    ¬Ј exact h z hz hfz

-- =====================================================================
-- ¬І7. Polynomial instantiation  (CXXXI Layers 3вАУ4)
-- =====================================================================

/-- **Polynomial logDeriv response (value form):** `ќЫ[p](z) = p'(z) / p(z)`. -/
noncomputable def polynomialLogDerivResponse (p : Polynomial вДВ) : вДВ вЖТ вДВ :=
  fun z => p.derivative.eval z / p.eval z

/-- **PROVED вАФ applied to the abstract engine: any polynomial supplying
a `LocalLogDerivPoleDecomposition` at an upper root has a positive
escape.** -/
theorem polynomial_local_pole_forces_escape
    (p : Polynomial вДВ) (ѕБ : вДВ)
    (D : LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ѕБ) :
    PositiveUpperImaginaryEscape (polynomialLogDerivResponse p) :=
  localLogDerivPoleDecomposition_forces_escape D

/-- **Polynomial pole-witness hypothesis (deferred Mathlib instantiation).**
For every upper-half-plane root `ѕБ` of `p` we have a
`LocalLogDerivPoleDecomposition` at `ѕБ`. The general construction of such
a decomposition from `p вЙ† 0` and `p.eval ѕБ = 0` requires Mathlib's
polynomial root-multiplicity + bounded-continuity machinery and lives in
CXXXII / Mathlib-side work. -/
structure PolynomialPoleWitnessHypothesis (p : Polynomial вДВ) : Prop where
  decomp_at_each_upper_root :
    вИА ѕБ : вДВ, p.eval ѕБ = 0 вЖТ 0 < ѕБ.im вЖТ
      Nonempty (LocalLogDerivPoleDecomposition
        (polynomialLogDerivResponse p) ѕБ)

/-- **PROVED вАФ polynomial log-derivative pole-witness law:** the
hypothesis package implies the abstract `LogDerivPoleWitnessLaw`. -/
theorem polynomial_logDeriv_poleWitness
    (p : Polynomial вДВ)
    (H : PolynomialPoleWitnessHypothesis p) :
    LogDerivPoleWitnessLaw
      (fun z => p.eval z)
      (polynomialLogDerivResponse p) where
  upper_zero_forces_escape := by
    intro ѕБ hroot hupper
    obtain вЯ®DвЯ© := H.decomp_at_each_upper_root ѕБ hroot hupper
    exact localLogDerivPoleDecomposition_forces_escape D

/-- в≠Р **PROVED вАФ finite RH-equivalence for polynomials.** Anti-Herglotz
of the log-derivative response + the polynomial pole-witness package +
conjugation symmetry вЗТ all roots of `p` are real. One-line composition
with ¬І6. -/
theorem polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    (p : Polynomial вДВ)
    (H : PolynomialPoleWitnessHypothesis p)
    (hanti : AntiHerglotzUHP (polynomialLogDerivResponse p))
    (hsym : вИА z : вДВ, p.eval (star z) = star (p.eval z)) :
    вИА ѕБ : вДВ, p.eval ѕБ = 0 вЖТ ѕБ.im = 0 :=
  antiHerglotz_plus_symmetry_forces_real_zeros_complex
    (polynomial_logDeriv_poleWitness p H) hanti hsym

-- =====================================================================
-- ¬І8. Discharging the polynomial pole-witness  (CXXXII AвАУD)
-- =====================================================================
-- The four steps that bring `PolynomialPoleWitnessHypothesis` within one
-- mechanical Mathlib chase of becoming an unconditional theorem:
--
--   A. Reusable analytic helper: continuity at ѕБ вЯє uniform |Im|-bound on
--      the probe segment ѕБ вИТ ќµ¬ЈI.
--   B. Polynomial logDeriv background `q'/q` is continuous away from a
--      root of `q`.
--   C. Composition of A + B: the polynomial background is probe-bounded.
--   D. Polynomial factorization `p = (X вИТ C ѕБ)^m ¬Ј q` with `q.eval ѕБ вЙ† 0`
--      and `m = rootMultiplicity ѕБ p > 0`.

/-- **CXXXII-A вАФ continuity вЯє probe boundedness.** A function continuous
at `ѕБ` is uniformly bounded (in imaginary part) along the probe segment
`ѕБ вИТ ќµ¬ЈI` for `0 < ќµ < ќµ0`. Reusable for both polynomial and xi targets:
pick metric `ќі` for radius 1, take `ќµ0 = min(ќі/2, ѕБ.im/2)`, `K = вАЦB ѕБвАЦ + 1`,
close via triangle inequality. -/
theorem continuousAt_implies_probe_bounded
    {B : вДВ вЖТ вДВ} {ѕБ : вДВ}
    (hB : ContinuousAt B ѕБ)
    (hupper : 0 < ѕБ.im) :
    вИГ K : вДЭ, 0 < K вИІ
    вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
        |(B (ѕБ - (ќµ : вДВ) * Complex.I)).im| вЙ§ K := by
  rw [Metric.continuousAt_iff] at hB
  obtain вЯ®ќі, hќі_pos, hќівЯ© := hB 1 zero_lt_one
  refine вЯ®вАЦB ѕБвАЦ + 1, by positivity,
          min (ќі/2) (ѕБ.im / 2), ?_, ?_, ?_вЯ©
  ¬Ј refine lt_min (by linarith) (by linarith)
  ¬Ј exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ќµ hќµ_pos hќµ_lt
  have hќµ_lt_ќі : ќµ < ќі := by
    have : ќµ < ќі / 2 := lt_of_lt_of_le hќµ_lt (min_le_left _ _)
    linarith
  set z : вДВ := ѕБ - (ќµ : вДВ) * Complex.I with hz_def
  have hzѕБ : z - ѕБ = -(ќµ : вДВ) * Complex.I := by
    show ѕБ - (ќµ : вДВ) * Complex.I - ѕБ = -(ќµ : вДВ) * Complex.I
    ring
  have hnorm : вАЦz - ѕБвАЦ = ќµ := by
    rw [hzѕБ, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show вАЦ((ќµ : вДЭ) : вДВ)вАЦ = ќµ
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos hќµ_pos
  have hdist : dist z ѕБ < ќі := by
    rw [dist_eq_norm, hnorm]; exact hќµ_lt_ќі
  have h_dist_B : dist (B z) (B ѕБ) < 1 := hќі hdist
  rw [dist_eq_norm] at h_dist_B
  have h_im : |(B z).im| вЙ§ вАЦB zвАЦ := Complex.abs_im_le_norm (B z)
  have h_tri : вАЦB zвАЦ вЙ§ вАЦB z - B ѕБвАЦ + вАЦB ѕБвАЦ := by
    have h_eq : B z = (B z - B ѕБ) + B ѕБ := by ring
    nth_rewrite 1 [h_eq]
    exact norm_add_le (B z - B ѕБ) (B ѕБ)
  linarith

/-- **CXXXII-B вАФ polynomial logDeriv background is continuous at any
non-root.** `q'(z)/q(z)` is continuous at `ѕБ` whenever `q.eval ѕБ вЙ† 0`. -/
theorem polynomial_logDeriv_background_continuousAt
    {q : Polynomial вДВ} {ѕБ : вДВ} (hqѕБ : q.eval ѕБ вЙ† 0) :
    ContinuousAt (fun z => q.derivative.eval z / q.eval z) ѕБ := by
  apply ContinuousAt.div
  ¬Ј exact (Polynomial.continuous q.derivative).continuousAt
  ¬Ј exact (Polynomial.continuous q).continuousAt
  ¬Ј exact hqѕБ

/-- **CXXXII-C вАФ polynomial logDeriv background is probe-bounded.**
One-line composition of CXXXII-A and CXXXII-B. -/
theorem polynomial_logDeriv_background_bounded_on_probe
    {q : Polynomial вДВ} {ѕБ : вДВ}
    (hqѕБ : q.eval ѕБ вЙ† 0)
    (hupper : 0 < ѕБ.im) :
    вИГ K : вДЭ, 0 < K вИІ
    вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
        |((q.derivative.eval (ѕБ - (ќµ : вДВ) * Complex.I)) /
           (q.eval (ѕБ - (ќµ : вДВ) * Complex.I))).im| вЙ§ K :=
  continuousAt_implies_probe_bounded
    (polynomial_logDeriv_background_continuousAt hqѕБ) hupper

/-- **CXXXII-D вАФ polynomial factorization at a root (Mathlib reduction).**
For `p вЙ† 0` with `p.eval ѕБ = 0`, there exist `m > 0` and `q` such that
`p = (X вИТ C ѕБ)^m ¬Ј q` with `q.eval ѕБ вЙ† 0`. Set `m := rootMultiplicity ѕБ p`;
positivity via `rootMultiplicity_pos`; factorization via
`pow_rootMultiplicity_dvd`; nonzero remainder by contradiction using
`dvd_iff_isRoot` + `mul_dvd_mul_left` + `pow_succ` +
`le_rootMultiplicity_iff`. -/
theorem polynomial_factor_at_root_with_nonzero_remainder
    {p : Polynomial вДВ} {ѕБ : вДВ}
    (hp : p вЙ† 0)
    (hroot : p.eval ѕБ = 0) :
    вИГ m : вДХ, 0 < m вИІ
    вИГ q : Polynomial вДВ,
      p = (Polynomial.X - Polynomial.C ѕБ)^m * q вИІ
      q.eval ѕБ вЙ† 0 := by
  set m := p.rootMultiplicity ѕБ with hm_def
  have hm_pos : 0 < m := by
    rw [hm_def]
    exact (Polynomial.rootMultiplicity_pos hp).mpr hroot
  obtain вЯ®q, hq_eqвЯ© : (Polynomial.X - Polynomial.C ѕБ)^m вИ£ p :=
    Polynomial.pow_rootMultiplicity_dvd p ѕБ
  refine вЯ®m, hm_pos, q, hq_eq, ?_вЯ©
  -- if q.eval ѕБ = 0, then (X - C ѕБ) вИ£ q, so (X - C ѕБ)^(m+1) вИ£ p,
  -- contradicting maximality of m
  intro hq_eval
  have h_dvd_q : (Polynomial.X - Polynomial.C ѕБ) вИ£ q :=
    Polynomial.dvd_iff_isRoot.mpr hq_eval
  have h_succ_dvd : (Polynomial.X - Polynomial.C ѕБ)^(m+1) вИ£ p := by
    rw [hq_eq, pow_succ]
    exact mul_dvd_mul_left _ h_dvd_q
  have h_le := (Polynomial.le_rootMultiplicity_iff hp).mpr h_succ_dvd
  rw [вЖР hm_def] at h_le
  omega

-- =====================================================================
-- ¬І9. ValueвЖТpolynomial bridge & unconditional polynomial RH  (CXXXIII)
-- =====================================================================
-- The mechanical Mathlib chase that lifts ¬І5's value-form local
-- decomposition to the polynomial log-derivative response, and discharges
-- `PolynomialPoleWitnessHypothesis` for every nonzero polynomial. After
-- this section, ¬І7's finite RH-equivalence collapses to its hypothesis-free
-- form `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`:
--
--   p вЙ† 0  +  AntiHerglotzUHP (ќЫ[p])  +  Schwarz symmetry on p
--   вЯє  every root of p is real.

/-- **PROVED вАФ probe never coincides with the pole when `ќµ > 0`.**
The imaginary parts differ by exactly `ќµ`. -/
theorem probe_ne_pole (ѕБ : вДВ) (ќµ : вДЭ) (hќµ : 0 < ќµ) :
    ѕБ - (ќµ : вДВ) * Complex.I вЙ† ѕБ := by
  intro h
  have him_diff : (ѕБ - (ќµ : вДВ) * Complex.I).im = ѕБ.im := by rw [h]
  have him_calc : (ѕБ - (ќµ : вДВ) * Complex.I).im = ѕБ.im - ќµ := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- **PROVED вАФ continuous-at-ѕБ + nonzero-at-ѕБ вЯє nonzero on probe.**
Triangle bound: `вАЦf(z)вАЦ > вАЦf ѕБвАЦ/2` on a small enough probe segment. -/
theorem continuousAt_implies_probe_nonzero
    {f : вДВ вЖТ вДВ} {ѕБ : вДВ}
    (hf : ContinuousAt f ѕБ)
    (hfѕБ : f ѕБ вЙ† 0)
    (hupper : 0 < ѕБ.im) :
    вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
        f (ѕБ - (ќµ : вДВ) * Complex.I) вЙ† 0 := by
  rw [Metric.continuousAt_iff] at hf
  have h_pos : 0 < вАЦf ѕБвАЦ := norm_pos_iff.mpr hfѕБ
  obtain вЯ®ќі, hќі_pos, hќівЯ© := hf (вАЦf ѕБвАЦ / 2) (by linarith)
  refine вЯ®min (ќі/2) (ѕБ.im / 2), ?_, ?_, ?_вЯ©
  ¬Ј refine lt_min (by linarith) (by linarith)
  ¬Ј exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ќµ hќµ_pos hќµ_lt
  have hќµ_lt_ќі : ќµ < ќі := by
    have : ќµ < ќі / 2 := lt_of_lt_of_le hќµ_lt (min_le_left _ _)
    linarith
  set z : вДВ := ѕБ - (ќµ : вДВ) * Complex.I
  have hzѕБ : z - ѕБ = -(ќµ : вДВ) * Complex.I := by
    show ѕБ - (ќµ : вДВ) * Complex.I - ѕБ = -(ќµ : вДВ) * Complex.I
    ring
  have hnorm : вАЦz - ѕБвАЦ = ќµ := by
    rw [hzѕБ, norm_mul, norm_neg, Complex.norm_I, mul_one]
    show вАЦ((ќµ : вДЭ) : вДВ)вАЦ = ќµ
    rw [Complex.norm_real, Real.norm_eq_abs]
    exact abs_of_pos hќµ_pos
  have hdist : dist z ѕБ < ќі := by
    rw [dist_eq_norm, hnorm]; exact hќµ_lt_ќі
  have h_dist : dist (f z) (f ѕБ) < вАЦf ѕБвАЦ / 2 := hќі hdist
  rw [dist_eq_norm] at h_dist
  intro hfz
  rw [hfz] at h_dist
  simp at h_dist
  linarith

/-- **PROVED вАФ THE CXXXIII BRIDGE.** Polynomial value-form pole
decomposition lifted to the log-derivative response: if
`p = (X вИТ C ѕБ)^(k+1) ¬Ј q` with `z вЙ† ѕБ` and `q(z) вЙ† 0`, then
`p'(z)/p(z) = (k+1)/(zвИТѕБ) + q'(z)/q(z)`. Reduces to ¬І5's value-form
`complex_local_pole_decomposition_general` after evaluating `eval` of
the factorization and its derivative. -/
theorem polynomial_logDeriv_local_decomposition_of_factor
    {p q : Polynomial вДВ} {ѕБ z : вДВ} {k : вДХ}
    (hfac : p = (Polynomial.X - Polynomial.C ѕБ) ^ (k + 1) * q)
    (hzѕБ : z вЙ† ѕБ)
    (hqz : q.eval z вЙ† 0) :
    polynomialLogDerivResponse p z =
      (((k + 1 : вДХ) : вДВ) / (z - ѕБ))
        + q.derivative.eval z / q.eval z := by
  unfold polynomialLogDerivResponse
  -- p.eval z = (z вИТ ѕБ)^(k+1) * q.eval z
  have hp_eval : p.eval z = (z - ѕБ)^(k+1) * q.eval z := by
    rw [hfac]
    simp [Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C]
  -- p'.eval z = (k+1) * (z вИТ ѕБ)^k * q.eval z + (z вИТ ѕБ)^(k+1) * q'.eval z
  have hp_deriv_eval : p.derivative.eval z
                    = ((k + 1 : вДХ) : вДВ) * (z - ѕБ)^k * q.eval z
                      + (z - ѕБ)^(k+1) * q.derivative.eval z := by
    rw [hfac, Polynomial.derivative_mul, Polynomial.derivative_pow_succ]
    simp [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C,
          Polynomial.derivative_sub, Polynomial.derivative_X,
          Polynomial.derivative_C]
  rw [hp_eval, hp_deriv_eval]
  exact complex_local_pole_decomposition_general z ѕБ (q.eval z)
          (q.derivative.eval z) k hzѕБ hqz

/-- **PROVED вАФ building `LocalLogDerivPoleDecomposition` from polynomial
factorization data.** Combines:

  вАҐ probe вЙ† pole (`probe_ne_pole`),
  вАҐ polynomial background continuous (¬І8) & nonzero on probe (this section),
  вАҐ the valueвЖТpolynomial bridge above. -/
noncomputable def localLogDerivPoleDecomposition_of_polynomial_factor
    {p q : Polynomial вДВ} {ѕБ : вДВ} {k : вДХ}
    (hupper : 0 < ѕБ.im)
    (hfac : p = (Polynomial.X - Polynomial.C ѕБ) ^ (k + 1) * q)
    (hqѕБ : q.eval ѕБ вЙ† 0) :
    LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ѕБ :=
  -- Background continuity:
  let hcontB := polynomial_logDeriv_background_continuousAt hqѕБ
  let hcontQ : ContinuousAt (fun z => q.eval z) ѕБ :=
    (Polynomial.continuous q).continuousAt
  -- From continuity helpers, get bounded background and nonzero q on probe:
  let hboundedB : вИГ K : вДЭ, 0 < K вИІ
      вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
        вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
          |((q.derivative.eval (ѕБ - (ќµ : вДВ) * Complex.I)) /
             (q.eval (ѕБ - (ќµ : вДВ) * Complex.I))).im| вЙ§ K :=
    continuousAt_implies_probe_bounded hcontB hupper
  let hnzQ : вИГ ќµ0' : вДЭ, 0 < ќµ0' вИІ ќµ0' < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0' вЖТ
        q.eval (ѕБ - (ќµ : вДВ) * Complex.I) вЙ† 0 :=
    continuousAt_implies_probe_nonzero hcontQ hqѕБ hupper
  -- Extract and combine
  let K := hboundedB.choose
  let hK := hboundedB.choose_spec
  let ќµ0B := hK.2.choose
  let hќµ0B := hK.2.choose_spec
  let ќµ0Q := hnzQ.choose
  let hќµ0Q := hnzQ.choose_spec
  let ќµ0 := min ќµ0B ќµ0Q
  { m := k + 1
    hm_pos := Nat.succ_pos k
    background := fun z => q.derivative.eval z / q.eval z
    ќµ0 := ќµ0
    hќµ0 := lt_min hќµ0B.1 hќµ0Q.1
    hќµ0_lt := lt_of_le_of_lt (min_le_left _ _) hќµ0B.2.1
    K := K
    hK_pos := hK.1
    decomp_at_probe := fun ќµ hќµ_pos hќµ_lt => by
      have hќµ_lt_B : ќµ < ќµ0B :=
        lt_of_lt_of_le hќµ_lt (min_le_left _ _)
      have hќµ_lt_Q : ќµ < ќµ0Q :=
        lt_of_lt_of_le hќµ_lt (min_le_right _ _)
      have hzѕБ : ѕБ - (ќµ : вДВ) * Complex.I вЙ† ѕБ := probe_ne_pole ѕБ ќµ hќµ_pos
      have hqz : q.eval (ѕБ - (ќµ : вДВ) * Complex.I) вЙ† 0 :=
        hќµ0Q.2.2 ќµ hќµ_pos hќµ_lt_Q
      have h := polynomial_logDeriv_local_decomposition_of_factor
        hfac hzѕБ hqz
      convert h using 2
    background_bounded := fun ќµ hќµ_pos hќµ_lt => by
      have hќµ_lt_B : ќµ < ќµ0B :=
        lt_of_lt_of_le hќµ_lt (min_le_left _ _)
      exact hќµ0B.2.2 ќµ hќµ_pos hќµ_lt_B }

/-- **PROVED вАФ THE DISCHARGE.** For any nonzero polynomial `p`, the
hypothesis package `PolynomialPoleWitnessHypothesis p` follows from
¬І8's root-multiplicity factorization combined with this section's
local pole decomposition. The abstract engine is no longer load-bearing
on this hypothesis. -/
theorem polynomialPoleWitnessHypothesis_of_nonzero_polynomial
    (p : Polynomial вДВ) (hp : p вЙ† 0) :
    PolynomialPoleWitnessHypothesis p := by
  constructor
  intro ѕБ hroot hupper
  obtain вЯ®m, hm, q, hfac, hqѕБвЯ© :=
    polynomial_factor_at_root_with_nonzero_remainder hp hroot
  obtain вЯ®k, rflвЯ© : вИГ k, m = k + 1 :=
    вЯ®m - 1, by omegaвЯ©
  exact вЯ®localLogDerivPoleDecomposition_of_polynomial_factor
    hupper hfac hqѕБвЯ©

/-- в≠Р **PROVED вАФ FINITE RH-EQUIVALENCE FOR POLYNOMIALS (no hypothesis).**
For any nonzero polynomial `p`, anti-Herglotz log-derivative response
plus conjugation symmetry вЯє all roots real. The hypothesis-free form of
¬І7's `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`. -/
theorem polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
    (p : Polynomial вДВ) (hp : p вЙ† 0)
    (hanti : AntiHerglotzUHP (polynomialLogDerivResponse p))
    (hsym : вИА z : вДВ, p.eval (star z) = star (p.eval z)) :
    вИА ѕБ : вДВ, p.eval ѕБ = 0 вЖТ ѕБ.im = 0 :=
  polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    p (polynomialPoleWitnessHypothesis_of_nonzero_polynomial p hp)
    hanti hsym

-- =====================================================================
-- ¬І9-bis. Polynomial converse from a real linear factorization
-- =====================================================================
-- ¬І7-¬І9 close the FORWARD direction
--   AntiHerglotzUHP (ќЫ[p]) + Schwarz вЯє all roots real.
-- The genuine converse вАФ "all roots real вЯє anti-Herglotz" вАФ is also
-- true over вДВ but requires the polynomial splitting / root-multiset
-- machinery to descend from "real roots" to "real linear factorization".
--
-- This section first proves the converse in *factorized* form (which
-- only requires polynomial product / derivative algebra, plus ¬І2's
-- residue cloud lemma) and gives a finite-factorized iff. Bridging
-- from "all roots real" to a `PolynomialRealLinearFactorization`
-- (a `Polynomial.roots`-based proof) is left to a later phase since
-- it is independent algebra rather than overflow-residue content.

/-- **Real linear factorization data for a polynomial.** Witnesses that
`p` factors over вДВ as `C c ¬Ј вИП_i (X вИТ C r_i)` with `c вЙ† 0` and real
roots `r_i` (counted with multiplicity by repetition in the list). -/
structure PolynomialRealLinearFactorization (p : Polynomial вДВ) where
  c : вДВ
  hc : c вЙ† 0
  roots : List вДЭ
  factorization :
    p =
      Polynomial.C c *
        (roots.map fun r : вДЭ =>
          Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod

/-- **PROVED вАФ evaluation of a real linear product.** -/
private theorem prodLinearReal_eval
    (roots : List вДЭ) (z : вДВ) :
    (roots.map fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod.eval z
      = (roots.map fun r : вДЭ => z - (r : вДВ)).prod := by
  induction roots with
  | nil => simp
  | cons r rs ih =>
    simp [Polynomial.eval_mul, Polynomial.eval_sub, Polynomial.eval_X,
          Polynomial.eval_C, ih]

/-- **PROVED вАФ real linear product is nonzero at a point distinct from
all roots.** -/
private theorem prodLinearReal_eval_ne_zero
    (roots : List вДЭ) {z : вДВ} (hz : вИА r вИИ roots, z вЙ† (r : вДВ)) :
    (roots.map fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod.eval z
      вЙ† 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => simp
  | cons r rs ih =>
    have h_head : z вЙ† (r : вДВ) := hz r (List.mem_cons_self ..)
    have h_tail : вИА s вИИ rs, z вЙ† (s : вДВ) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    simp only [List.map_cons, List.prod_cons]
    exact mul_ne_zero (sub_ne_zero.mpr h_head) h_rest

/-- **PROVED вАФ log-derivative of a real linear product equals the cloud
sum.** Induction on the list of roots, using the product rule
  `(p ¬Ј q)' = p' ¬Ј q + p ¬Ј q'`
to split each factor.

At each step we have `((X вИТ C r) ¬Ј q)' / ((X вИТ C r) ¬Ј q) = 1/(z вИТ r) +
q'/q` (this is `complex_local_pole_decomposition_simple_root` instantiated
on values). Iterating gives the residue cloud. -/
theorem polynomialLogDeriv_of_linearProd_eq_cloud
    (roots : List вДЭ) (z : вДВ)
    (hz : вИА r вИИ roots, z вЙ† (r : вДВ)) :
    polynomialLogDerivResponse
        (roots.map fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod z
      = (roots.map fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ))).sum := by
  induction roots with
  | nil =>
    -- empty product = 1; derivative = 0; cloud = 0
    simp [polynomialLogDerivResponse]
  | cons r rs ih =>
    have h_head : z вЙ† (r : вДВ) := hz r (List.mem_cons_self ..)
    have h_tail : вИА s вИИ rs, z вЙ† (s : вДВ) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    -- Names for the factors.
    set q : Polynomial вДВ :=
      (rs.map fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod
      with hq_def
    have hq_eval : q.eval z вЙ† 0 :=
      prodLinearReal_eval_ne_zero rs h_tail
    -- p = (X - C r) * q.  Compute p.eval and p'.eval.
    have h_p_eval :
        ((List.map (fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ))
              (r :: rs)).prod).eval z
          = (z - (r : вДВ)) * q.eval z := by
      simp [hq_def, Polynomial.eval_mul, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have h_p_deriv_eval :
        (((List.map (fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ))
              (r :: rs)).prod).derivative).eval z
          = q.eval z + (z - (r : вДВ)) * q.derivative.eval z := by
      simp [hq_def, Polynomial.derivative_mul, Polynomial.derivative_sub,
            Polynomial.derivative_X, Polynomial.derivative_C,
            Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have hr_ne : z - (r : вДВ) вЙ† 0 := sub_ne_zero.mpr h_head
    -- Compute the cloud equality directly.
    show polynomialLogDerivResponse
            (List.map (fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ))
              (r :: rs)).prod z
          = (List.map (fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ))) (r :: rs)).sum
    unfold polynomialLogDerivResponse
    rw [h_p_eval, h_p_deriv_eval]
    have h_alg :
        (q.eval z + (z - (r : вДВ)) * q.derivative.eval z) /
          ((z - (r : вДВ)) * q.eval z)
          = 1 / (z - (r : вДВ)) + q.derivative.eval z / q.eval z := by
      field_simp
      ring
    rw [h_alg, List.map_cons, List.sum_cons]
    -- Cancel matching first term, leaving `q'/q = (rs.map вА¶).sum`, which
    -- is `h_rest` (defeq through `polynomialLogDerivResponse`).
    have h_rest' : q.derivative.eval z / q.eval z
                  = (List.map (fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ))) rs).sum :=
      h_rest
    rw [h_rest']

/-- **PROVED вАФ log-derivative is invariant under nonzero constant
multiplication.** `ќЫ[C c ¬Ј q](z) = ќЫ[q](z)` when `q.eval z вЙ† 0` and
`c вЙ† 0`. -/
private theorem polynomialLogDeriv_C_mul
    (c : вДВ) (hc : c вЙ† 0) (q : Polynomial вДВ) (z : вДВ) (hq : q.eval z вЙ† 0) :
    polynomialLogDerivResponse (Polynomial.C c * q) z
      = polynomialLogDerivResponse q z := by
  unfold polynomialLogDerivResponse
  have h_eval : (Polynomial.C c * q).eval z = c * q.eval z := by
    simp [Polynomial.eval_mul, Polynomial.eval_C]
  have h_deriv :
      ((Polynomial.C c * q).derivative).eval z = c * q.derivative.eval z := by
    simp [Polynomial.derivative_mul, Polynomial.derivative_C,
          Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_C]
  rw [h_eval, h_deriv]
  field_simp
  ring

/-- **PROVED вАФ real linear product evaluates to zero at any root.** -/
private theorem prodLinearReal_eval_zero_of_mem
    (roots : List вДЭ) {z : вДВ} {r : вДЭ}
    (hr : r вИИ roots) (hz : z = (r : вДВ)) :
    (roots.map fun s : вДЭ => Polynomial.X - Polynomial.C ((s : вДЭ) : вДВ)).prod.eval z
      = 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => exact absurd hr (List.not_mem_nil)
  | cons s rs ih =>
    simp only [List.map_cons, List.prod_cons]
    rcases List.mem_cons.mp hr with rfl | hr_tail
    ¬Ј simp [hz]
    ¬Ј rw [ih hr_tail]; ring

/-- в≠Р **PROVED вАФ log-derivative of a real-linearly-factorized polynomial
equals the real residue cloud at any non-root.** -/
theorem polynomialLogDeriv_eq_real_residue_cloud_of_factorization
    {p : Polynomial вДВ}
    (F : PolynomialRealLinearFactorization p)
    (z : вДВ) (hz : p.eval z вЙ† 0) :
    polynomialLogDerivResponse p z =
      (F.roots.map fun r : вДЭ => (1 : вДВ) / (z - (r : вДВ))).sum := by
  -- Use an isolated `congrArg` for the rewrite to dodge motive issues
  -- (the goal contains `F.roots`, and naive `rw [F.factorization]` tries
  -- to rewrite `p` in `F`'s implicit type as well).
  set q : Polynomial вДВ :=
    (F.roots.map fun r : вДЭ => Polynomial.X - Polynomial.C ((r : вДЭ) : вДВ)).prod
    with hq_def
  -- 1. Recover `вИА r вИИ F.roots, z вЙ† (r : вДВ)` from `hz`.
  have h_z_ne : вИА r вИИ F.roots, z вЙ† (r : вДВ) := by
    intro r hr hz_eq
    apply hz
    have hp_eval : p.eval z = F.c * q.eval z := by
      have h := congrArg (Polynomial.eval z) F.factorization
      rw [h, Polynomial.eval_mul, Polynomial.eval_C]
    rw [hp_eval, prodLinearReal_eval_zero_of_mem F.roots hr hz_eq, mul_zero]
  -- 2. Express LHS via the factorization, isolated as a single congrArg.
  have h_q_eval : q.eval z вЙ† 0 :=
    prodLinearReal_eval_ne_zero F.roots h_z_ne
  have hp_lhs :
      polynomialLogDerivResponse p z
        = polynomialLogDerivResponse (Polynomial.C F.c * q) z :=
    congrArg (fun r => polynomialLogDerivResponse r z) F.factorization
  rw [hp_lhs, polynomialLogDeriv_C_mul F.c F.hc q z h_q_eval]
  -- 3. Apply the linear-product cloud identity.
  exact polynomialLogDeriv_of_linearProd_eq_cloud F.roots z h_z_ne

/-- в≠Р **PROVED вАФ real-linearly-factorized polynomial вЯє anti-Herglotz.**
The converse of `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`
in the factorized form. At a non-root we reduce `ќЫ[p]` to the real
residue cloud and apply ¬І2's `real_residue_cloud_antiHerglotz_list`. At
zeros, Lean's totalized `0 / 0 = 0` makes the inequality vacuous
(¬І6-bis `antiHerglotz_at_zero_is_vacuous`). -/
theorem polynomial_antiHerglotz_of_realLinearFactorization
    {p : Polynomial вДВ}
    (F : PolynomialRealLinearFactorization p) :
    AntiHerglotzUHP (polynomialLogDerivResponse p) := by
  intro z hz
  by_cases hpz : p.eval z = 0
  ¬Ј -- vacuous at a zero: totalized response is 0, so Im is 0 вЙ§ 0.
    show (polynomialLogDerivResponse p z).im вЙ§ 0
    unfold polynomialLogDerivResponse
    rw [hpz, div_zero, Complex.zero_im]
  ¬Ј rw [polynomialLogDeriv_eq_real_residue_cloud_of_factorization F z hpz]
    exact real_residue_cloud_antiHerglotz_list F.roots z hz

/-- в≠Р **PROVED вАФ finite-factorized polynomial iff.** Combining the ¬І7-¬І9
forward direction with the ¬І9-bis converse: for a real-linearly-factorized
polynomial, the anti-Herglotz target *is* equivalent to "all roots are
real". The reverse direction goes directly through the factorization
data `F`, not through "all roots real" вАФ so the `вИА ѕБ, real` premise is
not used to prove the implication, just to give the iff its honest shape
against the forward theorem. -/
theorem polynomial_realLinearFactorized_antiHerglotz_iff
    {p : Polynomial вДВ}
    (F : PolynomialRealLinearFactorization p)
    (hp : p вЙ† 0)
    (hsym : вИА z : вДВ, p.eval (star z) = star (p.eval z)) :
    AntiHerglotzUHP (polynomialLogDerivResponse p)
      вЖФ вИА ѕБ : вДВ, p.eval ѕБ = 0 вЖТ ѕБ.im = 0 := by
  constructor
  ¬Ј intro hanti
    exact polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
      p hp hanti hsym
  ¬Ј intro _
    exact polynomial_antiHerglotz_of_realLinearFactorization F

-- =====================================================================
-- ¬І10. Entire-function generalization template  (CXXXIV)
-- =====================================================================
-- Mirrors ¬І7's polynomial template, one level up. The hypothesis
-- `EntireLocalPoleDecompositionHypothesis F` says: at every upper-half-plane
-- zero of `F`, the local pole structure is good enough to package into a
-- `LocalLogDerivPoleDecomposition`. This is the natural entire-function
-- analogue of ¬І7's `PolynomialPoleWitnessHypothesis` вАФ the only
-- difference is that there's no rootMultiplicity machinery yet to
-- discharge it unconditionally (the analytic bridge from
-- `вИАбґ† z, F z = (z вИТ ѕБ)^m ¬Ј g z` is the CXXXV next-phase target).
--
-- The capstone `entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`
-- delivers the entire-function template theorem
--
--     EntireLocalPoleDecompositionHypothesis F
--     +  AntiHerglotzUHP (ќЫ[F])
--     +  Schwarz symmetry on F
--     вЯє every zero of F is real.

/-- **PROVED вАФ eventually-in-neighborhood вЯє eventually-on-probe.**
Reusable helper: if `P` holds on a neighborhood of `ѕБ`, then `P` holds
on the entire probe segment `ѕБ вИТ ќµ¬ЈI` for all small enough `ќµ`. Useful
for both polynomial and xi-pullback discharges. -/
theorem eventually_nhds_implies_probe_eventually
    {P : вДВ вЖТ Prop} {ѕБ : вДВ}
    (hP : вИАбґ† z in рЭУЭ ѕБ, P z)
    (hupper : 0 < ѕБ.im) :
    вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
        P (ѕБ - (ќµ : вДВ) * Complex.I) := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain вЯ®ќі, hќі_pos, hќівЯ© := hP
  refine вЯ®min (ќі/2) (ѕБ.im / 2), ?_, ?_, ?_вЯ©
  ¬Ј refine lt_min (by linarith) (by linarith)
  ¬Ј exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ќµ hќµ_pos hќµ_lt
  apply hќі
  rw [dist_eq_norm,
      show ѕБ - (ќµ : вДВ) * Complex.I - ѕБ = -((ќµ : вДВ) * Complex.I) by ring,
      norm_neg, norm_mul, Complex.norm_I, mul_one]
  show вАЦ((ќµ : вДЭ) : вДВ)вАЦ < ќі
  rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos hќµ_pos]
  have hќµ_lt_half : ќµ < ќі / 2 := lt_of_lt_of_le hќµ_lt (min_le_left _ _)
  linarith

/-- **PROVED вАФ eventually-in-neighborhood propagates to a nhd of the probe.**
Strengthening of `eventually_nhds_implies_probe_eventually`: not only does
`P` hold *at* the probe `ѕБ вИТ ќµ¬ЈI`, it holds on an entire neighbourhood of
it. This is the form needed when feeding the data into Mathlib lemmas of
the shape `Filter.EventuallyEq.deriv_eq`, which require eventual equality
*at* the differentiation point. -/
theorem eventually_nhds_implies_probe_eventually_nhds
    {P : вДВ вЖТ Prop} {ѕБ : вДВ}
    (hP : вИАбґ† z in рЭУЭ ѕБ, P z)
    (hupper : 0 < ѕБ.im) :
    вИГ ќµ0 : вДЭ, 0 < ќµ0 вИІ ќµ0 < ѕБ.im вИІ
      вИА ќµ : вДЭ, 0 < ќµ вЖТ ќµ < ќµ0 вЖТ
        вИАбґ† z in рЭУЭ (ѕБ - (ќµ : вДВ) * Complex.I), P z := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain вЯ®ќі, hќі_pos, hќівЯ© := hP
  refine вЯ®min (ќі / 2) (ѕБ.im / 2), ?_, ?_, ?_вЯ©
  ¬Ј exact lt_min (by linarith) (by linarith)
  ¬Ј exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ќµ hќµ_pos hќµ_lt
  have hќµ_lt_half : ќµ < ќі / 2 := lt_of_lt_of_le hќµ_lt (min_le_left _ _)
  rw [Metric.eventually_nhds_iff]
  refine вЯ®ќі / 4, by linarith, ?_вЯ©
  intro w hw
  apply hќі
  have hprobe_dist : dist (ѕБ - (ќµ : вДВ) * Complex.I) ѕБ = ќµ := by
    rw [dist_eq_norm,
        show ѕБ - (ќµ : вДВ) * Complex.I - ѕБ = -((ќµ : вДВ) * Complex.I) by ring,
        norm_neg, norm_mul, Complex.norm_I, mul_one]
    show вАЦ((ќµ : вДЭ) : вДВ)вАЦ = ќµ
    rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos hќµ_pos]
  calc dist w ѕБ
        вЙ§ dist w (ѕБ - (ќµ : вДВ) * Complex.I) +
            dist (ѕБ - (ќµ : вДВ) * Complex.I) ѕБ := dist_triangle _ _ _
    _ < ќі / 4 + ќµ := by linarith
    _ < ќі := by linarith

/-- **Entire-function local pole-decomposition hypothesis.** At every
upper-half-plane zero of `F`, the local pole structure is good enough
to supply a `LocalLogDerivPoleDecomposition` for `ќЫ[F]`. This is the
entire-function analogue of ¬І7's `PolynomialPoleWitnessHypothesis`.

Constructively building an inhabitant of this structure from the natural
factorization data `вИАбґ† z in рЭУЭ ѕБ, F z = (z вИТ ѕБ)^m ¬Ј g z` (with `g(ѕБ) вЙ† 0`
and `g` analytic) is the CXXXV next-phase target вАФ see ¬І13. -/
structure EntireLocalPoleDecompositionHypothesis (F : вДВ вЖТ вДВ) : Prop where
  decomp_at_each_upper_zero :
    вИА ѕБ : вДВ, F ѕБ = 0 вЖТ 0 < ѕБ.im вЖТ
      Nonempty (LocalLogDerivPoleDecomposition (logDerivativeResponse F) ѕБ)

/-- **PROVED вАФ entire-function pole-decomposition hypothesis discharges
the abstract `LogDerivPoleWitnessLaw`.** One-line composition with ¬І5's
`localLogDerivPoleDecomposition_forces_escape`. -/
theorem entireLocalPoleDecomposition_gives_poleWitness
    {F : вДВ вЖТ вДВ} (H : EntireLocalPoleDecompositionHypothesis F) :
    LogDerivPoleWitnessLaw F (logDerivativeResponse F) where
  upper_zero_forces_escape := by
    intro ѕБ hzero hupper
    obtain вЯ®DвЯ© := H.decomp_at_each_upper_zero ѕБ hzero hupper
    exact localLogDerivPoleDecomposition_forces_escape D

/-- в≠Р **PROVED вАФ ENTIRE-FUNCTION TEMPLATE THEOREM.** For any function `F`
satisfying the entire-function local pole-decomposition hypothesis,
anti-Herglotz log-derivative plus Schwarz symmetry вЯє every zero of `F`
is real. This is the entire-function analogue of ¬І7's polynomial
finite RH-equivalence.

Inhabiting `EntireLocalPoleDecompositionHypothesis F` for any analytic
`F` reduces to the local factorization at each zero plus the bounded
background вАФ both standard complex analysis, handled by ¬І8's reusable
`continuousAt_implies_probe_bounded`. -/
theorem entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    (F : вДВ вЖТ вДВ)
    (H : EntireLocalPoleDecompositionHypothesis F)
    (hanti : AntiHerglotzUHP (logDerivativeResponse F))
    (hsym : вИА z : вДВ, F (star z) = star (F z)) :
    вИА ѕБ : вДВ, F ѕБ = 0 вЖТ ѕБ.im = 0 :=
  antiHerglotz_plus_symmetry_forces_real_zeros_complex
    (entireLocalPoleDecomposition_gives_poleWitness H) hanti hsym

-- =====================================================================
-- ¬І10-bis. Local analytic factorization вЖТ pole-decomposition
--          (CXXXIV-A: entire-function analogue of ¬І9)
-- =====================================================================
-- Replays the ¬І9 polynomial bridge one level up:
--
--   ¬І9  (polynomial):
--     polynomial factor data           вЖТ  LocalLogDerivPoleDecomposition
--     PolynomialPoleWitnessHypothesis  (discharged unconditionally in ¬І9)
--
--   ¬І10-bis (entire-function):
--     LocalAnalyticZeroFactorization F ѕБ        (per-zero analytic data)
--     EntireZeroFactorizationHypothesis F       (quantified over zeros)
--     EntireLocalPoleDecompositionHypothesis F  (the ¬І10 target)
--
-- The only genuinely-new analytic content is `logDeriv_of_eventual_factorization`,
-- which lifts ¬І5's algebraic `complex_local_pole_decomposition_general` through
-- `Filter.EventuallyEq.deriv_eq` to the value form
--
--     ќЫ[F](z) = m/(z вИТ ѕБ) + g'(z)/g(z).
--
-- Once an analytic `F` (e.g. `XiPullback`) supplies a `LocalAnalyticZeroFactorization`
-- at each upper-half-plane zero, the ¬І10 template `entire_function_roots_real_вА¶`
-- becomes hypothesis-free for that `F`.

/-- **Local analytic factorization data at a zero.** Records the standard
analytic factorization
   F z = (z вИТ ѕБ)^m ¬Ј g z   eventually near ѕБ,
with `m вЙ• 1`, `g` nonvanishing at `ѕБ`, `g` differentiable on a neighbourhood
of `ѕБ`, and the log-derivative background `g'/g` continuous at `ѕБ`.

This is the natural complex-analytic input that any function holomorphic
on a neighbourhood of an isolated zero of multiplicity `m` provides. -/
structure LocalAnalyticZeroFactorization (F : вДВ вЖТ вДВ) (ѕБ : вДВ) where
  m : вДХ
  hm_pos : 0 < m
  g : вДВ вЖТ вДВ
  hgѕБ : g ѕБ вЙ† 0
  hg_diff_nhds : вИАбґ† z in рЭУЭ ѕБ, DifferentiableAt вДВ g z
  hcont_background : ContinuousAt (fun z => deriv g z / g z) ѕБ
  hfactor : вИАбґ† z in рЭУЭ ѕБ, F z = (z - ѕБ) ^ m * g z

/-- **PROVED вАФ log-derivative of an eventual factorization.**
If `F` agrees on a neighbourhood of `z` with `(¬Ј вИТ ѕБ)^m ¬Ј g` (with `m вЙ• 1`,
`z вЙ† ѕБ`, `g z вЙ† 0`, `g` differentiable at `z`), then the algebraic identity
of ¬І5 transfers to the actual log-derivative response:

  `ќЫ[F](z)  =  m / (z вИТ ѕБ)  +  g'(z) / g(z)`.

Mechanism: `Filter.EventuallyEq.deriv_eq` rewrites `deriv F z` to the
derivative of the factored form; the product/power rules compute the
latter; ¬І5's `complex_local_pole_decomposition_general` reduces the
resulting algebraic ratio. -/
theorem logDeriv_of_eventual_factorization
    {F g : вДВ вЖТ вДВ} {ѕБ z : вДВ} {m : вДХ}
    (hm : 0 < m)
    (hzѕБ : z вЙ† ѕБ)
    (hgz : g z вЙ† 0)
    (hF_eq : F =бґ†[рЭУЭ z] fun w => (w - ѕБ) ^ m * g w)
    (hgdiff : DifferentiableAt вДВ g z) :
    logDerivativeResponse F z =
      ((m : вДХ) : вДВ) / (z - ѕБ) + deriv g z / g z := by
  -- Rewrite m as k+1 to mesh with the ¬І5 general lemma.
  obtain вЯ®k, rflвЯ© : вИГ k, m = k + 1 := вЯ®m - 1, by omegaвЯ©
  -- Value of F at z.
  have hF_val : F z = (z - ѕБ) ^ (k + 1) * g z := hF_eq.eq_of_nhds
  -- Derivative of (¬ЈвИТѕБ)^(k+1) at z, then product with g.
  have h_sub : HasDerivAt (fun w : вДВ => w - ѕБ) 1 z := by
    simpa using (hasDerivAt_id z).sub_const ѕБ
  have h_pow : HasDerivAt (fun w : вДВ => (w - ѕБ) ^ (k + 1))
                (((k + 1 : вДХ) : вДВ) * (z - ѕБ) ^ k) z := by
    have h := h_sub.pow (k + 1)
    simpa using h
  have hg : HasDerivAt g (deriv g z) z := hgdiff.hasDerivAt
  have h_prod : HasDerivAt (fun w : вДВ => (w - ѕБ) ^ (k + 1) * g w)
                  (((k + 1 : вДХ) : вДВ) * (z - ѕБ) ^ k * g z +
                    (z - ѕБ) ^ (k + 1) * deriv g z) z := h_pow.mul hg
  have h_F_deriv : deriv F z =
      ((k + 1 : вДХ) : вДВ) * (z - ѕБ) ^ k * g z +
        (z - ѕБ) ^ (k + 1) * deriv g z := by
    rw [hF_eq.deriv_eq]; exact h_prod.deriv
  unfold logDerivativeResponse
  rw [h_F_deriv, hF_val]
  exact complex_local_pole_decomposition_general z ѕБ (g z) (deriv g z) k hzѕБ hgz

/-- **PROVED вАФ building `LocalLogDerivPoleDecomposition` from a
`LocalAnalyticZeroFactorization`.** The entire-function analogue of
¬І9's `localLogDerivPoleDecomposition_of_polynomial_factor`. Mechanism:

  вАҐ probe вЙ† pole (`probe_ne_pole`);
  вАҐ probe вЖТ background bounded (`continuousAt_implies_probe_bounded`
    applied to `H.hcont_background`);
  вАҐ probe вЖТ `g` nonzero (`continuousAt_implies_probe_nonzero` from the
    continuity of `g` at `ѕБ` together with `H.hgѕБ`);
  вАҐ probe вЖТ differentiable in a *neighbourhood* of the probe
    (`eventually_nhds_implies_probe_eventually` applied to
    `H.hg_diff_nhds`);
  вАҐ eventual factorization propagated to a nhd of the probe
    (`eventually_nhds_implies_probe_eventually_nhds`);
  вАҐ value-form bridge `logDeriv_of_eventual_factorization`.
-/
noncomputable def localAnalyticZeroFactorization_gives_LocalLogDerivPoleDecomposition
    {F : вДВ вЖТ вДВ} {ѕБ : вДВ}
    (hupper : 0 < ѕБ.im)
    (H : LocalAnalyticZeroFactorization F ѕБ) :
    LocalLogDerivPoleDecomposition (logDerivativeResponse F) ѕБ :=
  let hcontG : ContinuousAt H.g ѕБ := H.hg_diff_nhds.self_of_nhds.continuousAt
  let hnzG := continuousAt_implies_probe_nonzero hcontG H.hgѕБ hupper
  let hbg := continuousAt_implies_probe_bounded H.hcont_background hupper
  let hev_fac_nhd :=
    eventually_nhds_implies_probe_eventually_nhds H.hfactor hupper
  let hev_diff :=
    eventually_nhds_implies_probe_eventually H.hg_diff_nhds hupper
  let K := hbg.choose
  let hK := hbg.choose_spec
  let ќµ0B := hK.2.choose
  let hќµ0B := hK.2.choose_spec
  let ќµ0Q := hnzG.choose
  let hќµ0Q := hnzG.choose_spec
  let ќµ0F := hev_fac_nhd.choose
