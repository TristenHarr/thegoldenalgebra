-- =====================================================================
-- ┬ºCCLXX. Smooth-tail `-Im` as a positive real integral
-- =====================================================================
-- The honest tail's `-Im` is a real improper integral of
-- `¤ü(u) ┬À y ┬À paired-Cauchy-positive-kernel(z, u)`. This section
-- captures the structural decomposition needed by any proof of
-- `HonestSmoothTailRationalLB`. The CLV analytic estimate remains
-- as the named obligation ÔÇö the structural pieces here let an
-- analytic agent attack it on the real-integral form.
--
-- Adds:
--   neg_pairedCauchyImKernel_eq                            ÔÇö pointwise identity
--   smoothDensityTailModelPartial_neg_im_eq_real_integral  ÔÇö -Im(partial) as real integral

/-- Ô¡É **PROVED ÔÇö pointwise identity for `-pairedCauchyImKernel`.**
Writes `-pairedCauchyImKernel x y u` as the explicit positive
combination `y ┬À (1/((x-u)┬▓+y┬▓) + 1/((x+u)┬▓+y┬▓))`. -/
lemma neg_pairedCauchyImKernel_eq (x y u : ÔäØ) :
    -pairedCauchyImKernel x y u
      = y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2)) := by
  unfold pairedCauchyImKernel
  ring

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `-Im` of the smooth-density finite partial as a
real integral.** Pointwise Im identity + `Complex.imCLM.intervalIntegral_comp_comm`
yields the positive real integrand. -/
lemma smoothDensityTailModelPartial_neg_im_eq_real_integral
    (¤ü : ÔäØ ÔåÆ ÔäØ) (T X : ÔäØ) {z : Ôäé}
    (h_int : IntervalIntegrable
              (fun u =>
                (¤ü u : Ôäé) *
                  ((1 : Ôäé) / (z - (u : Ôäé)) +
                   (1 : Ôäé) / (z + (u : Ôäé))))
              MeasureTheory.volume T X) :
    -(smoothDensityTailModelPartial ¤ü T X z).im
      = Ôê½ u in T..X,
          ¤ü u * (z.im *
            (1 / ((z.re - u)^2 + z.im^2)
              + 1 / ((z.re + u)^2 + z.im^2))) := by
  unfold smoothDensityTailModelPartial
  rw [show (Ôê½ u in T..X,
              (¤ü u : Ôäé) *
                ((1 : Ôäé) / (z - (u : Ôäé)) +
                 (1 : Ôäé) / (z + (u : Ôäé)))).im
          = Complex.imCLM (Ôê½ u in T..X,
              (¤ü u : Ôäé) *
                ((1 : Ôäé) / (z - (u : Ôäé)) +
                 (1 : Ôäé) / (z + (u : Ôäé)))) from rfl,
      ÔåÉ Complex.imCLM.intervalIntegral_comp_comm h_int]
  rw [ÔåÉ intervalIntegral.integral_neg]
  refine intervalIntegral.integral_congr ?_
  intro u _
  show -(Complex.imCLM ((¤ü u : Ôäé) *
            ((1 : Ôäé) / (z - (u : Ôäé)) +
             (1 : Ôäé) / (z + (u : Ôäé)))))
    = ¤ü u * (z.im *
      (1 / ((z.re - u)^2 + z.im^2)
        + 1 / ((z.re + u)^2 + z.im^2)))
  rw [Complex.imCLM_apply]
  have hpair : (pairedCauchyKernel u z).im = pairedCauchyImKernel z.re z.im u := by
    have h := pairedCauchyKernel_im_eq_imKernel z.re z.im u
    rw [Complex.re_add_im z] at h
    exact h
  have h_im :
      ((¤ü u : Ôäé) *
        ((1 : Ôäé) / (z - (u : Ôäé)) + (1 : Ôäé) / (z + (u : Ôäé)))).im
        = ¤ü u * pairedCauchyImKernel z.re z.im u := by
    show ((¤ü u : Ôäé) * pairedCauchyKernel u z).im
          = ¤ü u * pairedCauchyImKernel z.re z.im u
    have hmul : ((¤ü u : Ôäé) * pairedCauchyKernel u z).im
            = ¤ü u * (pairedCauchyKernel u z).im := by
      simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
    rw [hmul, hpair]
  rw [h_im]
  have hneg : -pairedCauchyImKernel z.re z.im u
              = z.im * (1 / ((z.re - u)^2 + z.im^2)
                        + 1 / ((z.re + u)^2 + z.im^2)) :=
    neg_pairedCauchyImKernel_eq z.re z.im u
  linear_combination ¤ü u * hneg

