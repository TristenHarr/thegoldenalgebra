    linarith
  have h_exp71_eq : Real.exp (71 : ℝ) = (Real.exp 1)^71 := by
    have h := Real.exp_one_pow 71
    have h_cast : ((71 : ℕ) : ℝ) = (71 : ℝ) := by norm_num
    rw [← h_cast]
    exact h.symm
