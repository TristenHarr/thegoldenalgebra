-- CLX-C: FirstZeroCertified тАФ concrete first-zero assumption package
-- ---------------------------------------------------------------------

/-- **First-zero certification.** Bundles `╬│тВБ > 10` together with the
no-zero-counted property `N(u) = 0` on `[2╧А, ╬│тВБ)`. Numerically `╬│тВБ тЙИ
14.13`. -/
structure FirstZeroCertified where
  N : тДЭ тЖТ тДЭ
  gamma1 : тДЭ
  gamma1_gt_10 : 10 < gamma1
  noZerosBelow_gamma1 :
    тИА u : тДЭ, 2 * Real.pi тЙд u тЖТ u < gamma1 тЖТ N u = 0

/-- тнР **PROVED тАФ `N(u) = 0` on `[2╧А, 10]` from `FirstZeroCertified`.** -/
theorem FirstZeroCertified.noZeros_on_2pi_10
    (H : FirstZeroCertified)
    {u : тДЭ} (hlo : 2 * Real.pi тЙд u) (hhi : u тЙд 10) :
    H.N u = 0 :=
  H.noZerosBelow_gamma1 u hlo (lt_of_le_of_lt hhi H.gamma1_gt_10)

/-- тнР **PROVED тАФ `S(u) = -NтВА(u)` on `[2╧А, 10]` from `FirstZeroCertified`,**
since `S(u) = N(u) - NтВА(u)` and `N(u) = 0` there. The caller supplies
the `S = N - NтВА` definition as the `hS` argument. -/
theorem FirstZeroCertified.S_eq_neg_N0_on_2pi_10
    (H : FirstZeroCertified)
    (S : тДЭ тЖТ тДЭ)
    (hS : тИА u : тДЭ, S u = H.N u - smoothZeroCountingN0 u)
    {u : тДЭ} (hlo : 2 * Real.pi тЙд u) (hhi : u тЙд 10) :
    S u = -(smoothZeroCountingN0 u) := by
  rw [hS u, H.noZeros_on_2pi_10 hlo hhi]
  ring

