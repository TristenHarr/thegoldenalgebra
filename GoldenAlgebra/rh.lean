-- CLIV-A: Sharper geometric lower bound тАФ constant 2/3
-- ---------------------------------------------------------------------
-- The Python sweep shows the true universal constant on the adaptive
-- region is тЙИ 8/5 (worst case at r = 0, s = 1/2). The 2/5 bound is
-- extremely conservative. The 2/3 bound is still safe and drops the
-- scalar threshold from ~364 to ~236.
--
-- Decomposition via YтВБ/YтВВ:
--   YтВБ = y(TтИТ|x|)/((TтИТ|x|)┬▓ + y┬▓) тЙе y/(2T)
--     тЯ║ T┬▓ тЙе |x|┬▓ + y┬▓  (since 2T(T-|x|) тИТ ((T-|x|)┬▓ + y┬▓) = T┬▓ тИТ |x|┬▓ тИТ y┬▓),
--     which holds because (|x| + y)┬▓ тЙд T┬▓/4 тЙд T┬▓.
--   YтВВ = y(T+|x|)/((T+|x|)┬▓ + y┬▓) тЙе y/(6T)
--     via (T+|x|)┬▓ + y┬▓ тЙд 9T┬▓/4 + T┬▓/4 = 5T┬▓/2 тЙд 6T┬▓ тЙд 6T(T+|x|).
--   Sum:  YтВБ + YтВВ тЙе y/(2T) + y/(6T) = 2y/(3T).

/-- тнР **PROVED тАФ sharper rational tail lower bound, constant 2/3.**

On the canonical adaptive `A = 2` region with `T тЙе 2╧А`:
  `smoothTailRationalLowerBoundAbs x y T тЙе (2/3) ┬╖ ╧Б(T) ┬╖ y / T`.

Drops the scalar threshold from ~364 to ~236. -/
theorem smoothTailRationalLowerBoundAbs_ge_twoThirds
    {x y T : тДЭ}
    (hT : 2 * Real.pi тЙд T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) тЙд T) :
    (2 / 3) * zeroDensityRho T * y / T
      тЙд smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  have h╧Б_nn : 0 тЙд zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T тЙа 0 := ne_of_gt hT_pos
  have hT_nn : 0 тЙд T := le_of_lt hT_pos
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hx_nn : 0 тЙд |x| := abs_nonneg x
  have hx_le : |x| тЙд T / 2 := by linarith
  have hy_le : y тЙд T / 2 := by linarith
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 тЙд T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 тЙд T + |x| := le_of_lt h_tpx_pos
  have h_tpx_le : T + |x| тЙд 3 * T / 2 := by linarith
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- (|x| + y) тЙд T/2, hence (|x|+y)┬▓ тЙд T┬▓/4, hence |x|┬▓ + y┬▓ тЙд T┬▓/4 тЙд T┬▓
  have h_xy_sum_le : |x| + y тЙд T / 2 := by linarith
  have h_xy_sum_nn : 0 тЙд |x| + y := by positivity
  have h_xy_sum_sq_le : (|x| + y)^2 тЙд (T / 2)^2 :=
    pow_le_pow_leftтВА h_xy_sum_nn h_xy_sum_le 2
  have h_xy_sq_le : |x|^2 + y^2 тЙд T^2 / 4 := by
    have hexp : (|x| + y)^2 = |x|^2 + 2 * |x| * y + y^2 := by ring
    have hxy_prod_nn : 0 тЙд 2 * |x| * y := by positivity
    have h_halfT_sq : (T / 2)^2 = T^2 / 4 := by ring
    nlinarith [h_xy_sum_sq_le, hxy_prod_nn, hexp, h_halfT_sq]
  have h_T_sq_nn : 0 тЙд T^2 := sq_nonneg T
  have h_x_sq_y_sq_le_T_sq : |x|^2 + y^2 тЙд T^2 := by nlinarith
  -- Step 1: YтВБ тЙе y/(2T) via 2T(T-|x|) тИТ ((T-|x|)┬▓+y┬▓) = T┬▓ тИТ |x|┬▓ тИТ y┬▓ тЙе 0
  have h_alg1 : 2 * T * (T - |x|) - ((T - |x|)^2 + y^2)
              = T^2 - |x|^2 - y^2 := by ring
  have h_alg1_nn : 0 тЙд 2 * T * (T - |x|) - ((T - |x|)^2 + y^2) := by
    rw [h_alg1]; linarith
  have h_2T_pos : 0 < 2 * T := by linarith
  have h_Y1_ge :
      y / (2 * T) тЙд y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    rw [div_le_div_iffтВА h_2T_pos h_denom1_pos]
    have h_calc :
        y * (T - |x|) * (2 * T) - y * ((T - |x|)^2 + y^2)
          = y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) := by ring
    have h_nn :
        0 тЙд y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg1_nn
    linarith
  -- Step 2: YтВВ тЙе y/(6T) via (T+|x|)┬▓ + y┬▓ тЙд 5T┬▓/2 тЙд 6T┬▓ тЙд 6T(T+|x|)
  have h_y_sq_le : y^2 тЙд T^2 / 4 := by
    have h := pow_le_pow_leftтВА hy_nn hy_le 2
    calc y^2 тЙд (T / 2)^2 := h
      _ = T^2 / 4 := by ring
  have h_tpx_sq_le : (T + |x|)^2 тЙд 9 * T^2 / 4 := by
    have h := pow_le_pow_leftтВА h_tpx_nn h_tpx_le 2
    calc (T + |x|)^2 тЙд (3 * T / 2)^2 := h
      _ = 9 * T^2 / 4 := by ring
  have h_alg2_bound : (T + |x|)^2 + y^2 тЙд 5 * T^2 / 2 := by
    have h_id : 9 * T^2 / 4 + T^2 / 4 = 5 * T^2 / 2 := by ring
    linarith
  have h_6T_tpx_ge_6T_sq : 6 * T^2 тЙд 6 * T * (T + |x|) := by
    have h_diff_id : 6 * T * (T + |x|) - 6 * T^2 = 6 * T * |x| := by ring
    have h_diff_nn : 0 тЙд 6 * T * |x| := by positivity
    linarith
  have h_alg2_ineq : (T + |x|)^2 + y^2 тЙд 6 * T * (T + |x|) := by
    have h_52_le_6 : 5 * T^2 / 2 тЙд 6 * T^2 := by nlinarith [h_T_sq_nn]
    linarith
  have h_6T_pos : 0 < 6 * T := by linarith
  have h_Y2_ge :
      y / (6 * T) тЙд y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    rw [div_le_div_iffтВА h_6T_pos h_denom2_pos]
    have h_calc :
        y * (T + |x|) * (6 * T) - y * ((T + |x|)^2 + y^2)
          = y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) := by ring
    have h_nn :
        0 тЙд y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) :=
      mul_nonneg hy_nn (by linarith)
    linarith
  -- Step 3: Combine тАФ y/(2T) + y/(6T) = 2y/(3T)
  have h_sum_eq : y / (2 * T) + y / (6 * T) = 2 * y / (3 * T) := by
    field_simp; ring
  have h_sum_ge :
      2 * y / (3 * T)
        тЙд y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h := add_le_add h_Y1_ge h_Y2_ge
    rw [h_sum_eq] at h
    exact h
  -- Multiply by ╧Б(T) тЙе 0
  have h_mul :
      zeroDensityRho T * (2 * y / (3 * T))
        тЙд zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge h╧Б_nn
  -- Reshuffle: (2/3) ┬╖ ╧Б(T) ┬╖ y / T = ╧Б(T) ┬╖ (2y / (3T))
  have h_eq :
      (2 / 3) * zeroDensityRho T * y / T
        = zeroDensityRho T * (2 * y / (3 * T)) := by
    field_simp; ring
  rw [h_eq]
  exact h_mul

