theorem polynomialPoleWitnessHypothesis_of_nonzero_polynomial
    (p : Polynomial Ôäé) (hp : p Ôëá 0) :
    PolynomialPoleWitnessHypothesis p := by
  constructor
  intro ¤ü hroot hupper
  obtain Ôƒ¿m, hm, q, hfac, hq¤üÔƒ® :=
    polynomial_factor_at_root_with_nonzero_remainder hp hroot
  obtain Ôƒ¿k, rflÔƒ® : Ôêâ k, m = k + 1 :=
    Ôƒ¿m - 1, by omegaÔƒ®
  exact Ôƒ¿localLogDerivPoleDecomposition_of_polynomial_factor
    hupper hfac hq¤üÔƒ®

/-- Ô¡É **PROVED ÔÇö FINITE RH-EQUIVALENCE FOR POLYNOMIALS (no hypothesis).**
For any nonzero polynomial `p`, anti-Herglotz log-derivative response
plus conjugation symmetry Ôƒ╣ all roots real. The hypothesis-free form of
┬º7's `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`. -/
theorem polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
    (p : Polynomial Ôäé) (hp : p Ôëá 0)
    (hanti : AntiHerglotzUHP (polynomialLogDerivResponse p))
    (hsym : ÔêÇ z : Ôäé, p.eval (star z) = star (p.eval z)) :
    ÔêÇ ¤ü : Ôäé, p.eval ¤ü = 0 ÔåÆ ¤ü.im = 0 :=
  polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    p (polynomialPoleWitnessHypothesis_of_nonzero_polynomial p hp)
    hanti hsym

-- =====================================================================
-- ┬º9-bis. Polynomial converse from a real linear factorization
-- =====================================================================
-- ┬º7-┬º9 close the FORWARD direction
--   AntiHerglotzUHP (╬ø[p]) + Schwarz Ôƒ╣ all roots real.
-- The genuine converse ÔÇö "all roots real Ôƒ╣ anti-Herglotz" ÔÇö is also
-- true over Ôäé but requires the polynomial splitting / root-multiset
-- machinery to descend from "real roots" to "real linear factorization".
--
-- This section first proves the converse in *factorized* form (which
-- only requires polynomial product / derivative algebra, plus ┬º2's
-- residue cloud lemma) and gives a finite-factorized iff. Bridging
-- from "all roots real" to a `PolynomialRealLinearFactorization`
-- (a `Polynomial.roots`-based proof) is left to a later phase since
-- it is independent algebra rather than overflow-residue content.

/-- **Real linear factorization data for a polynomial.** Witnesses that
`p` factors over Ôäé as `C c ┬À ÔêÅ_i (X ÔêÆ C r_i)` with `c Ôëá 0` and real
roots `r_i` (counted with multiplicity by repetition in the list). -/
structure PolynomialRealLinearFactorization (p : Polynomial Ôäé) where
  c : Ôäé
  hc : c Ôëá 0
  roots : List ÔäØ
  factorization :
    p =
      Polynomial.C c *
        (roots.map fun r : ÔäØ =>
          Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod

/-- **PROVED ÔÇö evaluation of a real linear product.** -/
private theorem prodLinearReal_eval
    (roots : List ÔäØ) (z : Ôäé) :
    (roots.map fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod.eval z
      = (roots.map fun r : ÔäØ => z - (r : Ôäé)).prod := by
  induction roots with
  | nil => simp
  | cons r rs ih =>
    simp [Polynomial.eval_mul, Polynomial.eval_sub, Polynomial.eval_X,
          Polynomial.eval_C, ih]

/-- **PROVED ÔÇö real linear product is nonzero at a point distinct from
all roots.** -/
private theorem prodLinearReal_eval_ne_zero
    (roots : List ÔäØ) {z : Ôäé} (hz : ÔêÇ r Ôêê roots, z Ôëá (r : Ôäé)) :
    (roots.map fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod.eval z
      Ôëá 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => simp
  | cons r rs ih =>
    have h_head : z Ôëá (r : Ôäé) := hz r (List.mem_cons_self ..)
    have h_tail : ÔêÇ s Ôêê rs, z Ôëá (s : Ôäé) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    simp only [List.map_cons, List.prod_cons]
    exact mul_ne_zero (sub_ne_zero.mpr h_head) h_rest

/-- **PROVED ÔÇö log-derivative of a real linear product equals the cloud
sum.** Induction on the list of roots, using the product rule
  `(p ┬À q)' = p' ┬À q + p ┬À q'`
to split each factor.

At each step we have `((X ÔêÆ C r) ┬À q)' / ((X ÔêÆ C r) ┬À q) = 1/(z ÔêÆ r) +
q'/q` (this is `complex_local_pole_decomposition_simple_root` instantiated
on values). Iterating gives the residue cloud. -/
theorem polynomialLogDeriv_of_linearProd_eq_cloud
    (roots : List ÔäØ) (z : Ôäé)
    (hz : ÔêÇ r Ôêê roots, z Ôëá (r : Ôäé)) :
    polynomialLogDerivResponse
        (roots.map fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod z
      = (roots.map fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé))).sum := by
  induction roots with
  | nil =>
    -- empty product = 1; derivative = 0; cloud = 0
    simp [polynomialLogDerivResponse]
  | cons r rs ih =>
    have h_head : z Ôëá (r : Ôäé) := hz r (List.mem_cons_self ..)
    have h_tail : ÔêÇ s Ôêê rs, z Ôëá (s : Ôäé) :=
      fun s hs => hz s (List.mem_cons_of_mem _ hs)
    have h_rest := ih h_tail
    -- Names for the factors.
    set q : Polynomial Ôäé :=
      (rs.map fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod
      with hq_def
    have hq_eval : q.eval z Ôëá 0 :=
      prodLinearReal_eval_ne_zero rs h_tail
    -- p = (X - C r) * q.  Compute p.eval and p'.eval.
    have h_p_eval :
        ((List.map (fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé))
              (r :: rs)).prod).eval z
          = (z - (r : Ôäé)) * q.eval z := by
      simp [hq_def, Polynomial.eval_mul, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have h_p_deriv_eval :
        (((List.map (fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé))
              (r :: rs)).prod).derivative).eval z
          = q.eval z + (z - (r : Ôäé)) * q.derivative.eval z := by
      simp [hq_def, Polynomial.derivative_mul, Polynomial.derivative_sub,
            Polynomial.derivative_X, Polynomial.derivative_C,
            Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_sub,
            Polynomial.eval_X, Polynomial.eval_C]
    have hr_ne : z - (r : Ôäé) Ôëá 0 := sub_ne_zero.mpr h_head
    -- Compute the cloud equality directly.
    show polynomialLogDerivResponse
            (List.map (fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé))
              (r :: rs)).prod z
          = (List.map (fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé))) (r :: rs)).sum
    unfold polynomialLogDerivResponse
    rw [h_p_eval, h_p_deriv_eval]
    have h_alg :
        (q.eval z + (z - (r : Ôäé)) * q.derivative.eval z) /
          ((z - (r : Ôäé)) * q.eval z)
          = 1 / (z - (r : Ôäé)) + q.derivative.eval z / q.eval z := by
      field_simp
      ring
    rw [h_alg, List.map_cons, List.sum_cons]
    -- Cancel matching first term, leaving `q'/q = (rs.map ÔÇª).sum`, which
    -- is `h_rest` (defeq through `polynomialLogDerivResponse`).
    have h_rest' : q.derivative.eval z / q.eval z
                  = (List.map (fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé))) rs).sum :=
      h_rest
    rw [h_rest']

/-- **PROVED ÔÇö log-derivative is invariant under nonzero constant
multiplication.** `╬ø[C c ┬À q](z) = ╬ø[q](z)` when `q.eval z Ôëá 0` and
`c Ôëá 0`. -/
private theorem polynomialLogDeriv_C_mul
    (c : Ôäé) (hc : c Ôëá 0) (q : Polynomial Ôäé) (z : Ôäé) (hq : q.eval z Ôëá 0) :
    polynomialLogDerivResponse (Polynomial.C c * q) z
      = polynomialLogDerivResponse q z := by
  unfold polynomialLogDerivResponse
  have h_eval : (Polynomial.C c * q).eval z = c * q.eval z := by
    simp [Polynomial.eval_mul, Polynomial.eval_C]
  have h_deriv :
      ((Polynomial.C c * q).derivative).eval z = c * q.derivative.eval z := by
    simp [Polynomial.derivative_mul, Polynomial.derivative_C,
          Polynomial.eval_mul, Polynomial.eval_add, Polynomial.eval_C]
  rw [h_eval, h_deriv]
  field_simp
  ring

/-- **PROVED ÔÇö real linear product evaluates to zero at any root.** -/
private theorem prodLinearReal_eval_zero_of_mem
    (roots : List ÔäØ) {z : Ôäé} {r : ÔäØ}
    (hr : r Ôêê roots) (hz : z = (r : Ôäé)) :
    (roots.map fun s : ÔäØ => Polynomial.X - Polynomial.C ((s : ÔäØ) : Ôäé)).prod.eval z
      = 0 := by
  rw [prodLinearReal_eval]
  induction roots with
  | nil => exact absurd hr (List.not_mem_nil)
  | cons s rs ih =>
    simp only [List.map_cons, List.prod_cons]
    rcases List.mem_cons.mp hr with rfl | hr_tail
    ┬À simp [hz]
    ┬À rw [ih hr_tail]; ring

/-- Ô¡É **PROVED ÔÇö log-derivative of a real-linearly-factorized polynomial
equals the real residue cloud at any non-root.** -/
theorem polynomialLogDeriv_eq_real_residue_cloud_of_factorization
    {p : Polynomial Ôäé}
    (F : PolynomialRealLinearFactorization p)
    (z : Ôäé) (hz : p.eval z Ôëá 0) :
    polynomialLogDerivResponse p z =
      (F.roots.map fun r : ÔäØ => (1 : Ôäé) / (z - (r : Ôäé))).sum := by
  -- Use an isolated `congrArg` for the rewrite to dodge motive issues
  -- (the goal contains `F.roots`, and naive `rw [F.factorization]` tries
  -- to rewrite `p` in `F`'s implicit type as well).
  set q : Polynomial Ôäé :=
    (F.roots.map fun r : ÔäØ => Polynomial.X - Polynomial.C ((r : ÔäØ) : Ôäé)).prod
    with hq_def
  -- 1. Recover `ÔêÇ r Ôêê F.roots, z Ôëá (r : Ôäé)` from `hz`.
  have h_z_ne : ÔêÇ r Ôêê F.roots, z Ôëá (r : Ôäé) := by
    intro r hr hz_eq
    apply hz
    have hp_eval : p.eval z = F.c * q.eval z := by
      have h := congrArg (Polynomial.eval z) F.factorization
      rw [h, Polynomial.eval_mul, Polynomial.eval_C]
    rw [hp_eval, prodLinearReal_eval_zero_of_mem F.roots hr hz_eq, mul_zero]
  -- 2. Express LHS via the factorization, isolated as a single congrArg.
  have h_q_eval : q.eval z Ôëá 0 :=
    prodLinearReal_eval_ne_zero F.roots h_z_ne
  have hp_lhs :
      polynomialLogDerivResponse p z
        = polynomialLogDerivResponse (Polynomial.C F.c * q) z :=
    congrArg (fun r => polynomialLogDerivResponse r z) F.factorization
  rw [hp_lhs, polynomialLogDeriv_C_mul F.c F.hc q z h_q_eval]
  -- 3. Apply the linear-product cloud identity.
  exact polynomialLogDeriv_of_linearProd_eq_cloud F.roots z h_z_ne

/-- Ô¡É **PROVED ÔÇö real-linearly-factorized polynomial Ôƒ╣ anti-Herglotz.**
The converse of `polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'`
in the factorized form. At a non-root we reduce `╬ø[p]` to the real
residue cloud and apply ┬º2's `real_residue_cloud_antiHerglotz_list`. At
zeros, Lean's totalized `0 / 0 = 0` makes the inequality vacuous
(┬º6-bis `antiHerglotz_at_zero_is_vacuous`). -/
theorem polynomial_antiHerglotz_of_realLinearFactorization
    {p : Polynomial Ôäé}
    (F : PolynomialRealLinearFactorization p) :
    AntiHerglotzUHP (polynomialLogDerivResponse p) := by
  intro z hz
  by_cases hpz : p.eval z = 0
  ┬À -- vacuous at a zero: totalized response is 0, so Im is 0 Ôëñ 0.
    show (polynomialLogDerivResponse p z).im Ôëñ 0
    unfold polynomialLogDerivResponse
    rw [hpz, div_zero, Complex.zero_im]
  ┬À rw [polynomialLogDeriv_eq_real_residue_cloud_of_factorization F z hpz]
    exact real_residue_cloud_antiHerglotz_list F.roots z hz

/-- Ô¡É **PROVED ÔÇö finite-factorized polynomial iff.** Combining the ┬º7-┬º9
forward direction with the ┬º9-bis converse: for a real-linearly-factorized
polynomial, the anti-Herglotz target *is* equivalent to "all roots are
real". The reverse direction goes directly through the factorization
data `F`, not through "all roots real" ÔÇö so the `ÔêÇ ¤ü, real` premise is
not used to prove the implication, just to give the iff its honest shape
against the forward theorem. -/
theorem polynomial_realLinearFactorized_antiHerglotz_iff
    {p : Polynomial Ôäé}
    (F : PolynomialRealLinearFactorization p)
    (hp : p Ôëá 0)
    (hsym : ÔêÇ z : Ôäé, p.eval (star z) = star (p.eval z)) :
    AntiHerglotzUHP (polynomialLogDerivResponse p)
      Ôåö ÔêÇ ¤ü : Ôäé, p.eval ¤ü = 0 ÔåÆ ¤ü.im = 0 := by
  constructor
  ┬À intro hanti
    exact polynomial_roots_real_of_logDeriv_antiHerglotz_and_conjSymm'
      p hp hanti hsym
  ┬À intro _
    exact polynomial_antiHerglotz_of_realLinearFactorization F

-- =====================================================================
-- ┬º10. Entire-function generalization template  (CXXXIV)
-- =====================================================================
-- Mirrors ┬º7's polynomial template, one level up. The hypothesis
-- `EntireLocalPoleDecompositionHypothesis F` says: at every upper-half-plane
-- zero of `F`, the local pole structure is good enough to package into a
-- `LocalLogDerivPoleDecomposition`. This is the natural entire-function
-- analogue of ┬º7's `PolynomialPoleWitnessHypothesis` ÔÇö the only
-- difference is that there's no rootMultiplicity machinery yet to
-- discharge it unconditionally (the analytic bridge from
-- `ÔêÇßÂá z, F z = (z ÔêÆ ¤ü)^m ┬À g z` is the CXXXV next-phase target).
--
-- The capstone `entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`
-- delivers the entire-function template theorem
--
--     EntireLocalPoleDecompositionHypothesis F
--     +  AntiHerglotzUHP (╬ø[F])
--     +  Schwarz symmetry on F
--     Ôƒ╣ every zero of F is real.

/-- **PROVED ÔÇö eventually-in-neighborhood Ôƒ╣ eventually-on-probe.**
Reusable helper: if `P` holds on a neighborhood of `¤ü`, then `P` holds
on the entire probe segment `¤ü ÔêÆ ╬Á┬ÀI` for all small enough `╬Á`. Useful
for both polynomial and xi-pullback discharges. -/
theorem eventually_nhds_implies_probe_eventually
    {P : Ôäé ÔåÆ Prop} {¤ü : Ôäé}
    (hP : ÔêÇßÂá z in ­ØôØ ¤ü, P z)
    (hupper : 0 < ¤ü.im) :
    Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
        P (¤ü - (╬Á : Ôäé) * Complex.I) := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain Ôƒ¿╬┤, h╬┤_pos, h╬┤Ôƒ® := hP
  refine Ôƒ¿min (╬┤/2) (¤ü.im / 2), ?_, ?_, ?_Ôƒ®
  ┬À refine lt_min (by linarith) (by linarith)
  ┬À exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬Á h╬Á_pos h╬Á_lt
  apply h╬┤
  rw [dist_eq_norm,
      show ¤ü - (╬Á : Ôäé) * Complex.I - ¤ü = -((╬Á : Ôäé) * Complex.I) by ring,
      norm_neg, norm_mul, Complex.norm_I, mul_one]
  show ÔÇû((╬Á : ÔäØ) : Ôäé)ÔÇû < ╬┤
  rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos h╬Á_pos]
  have h╬Á_lt_half : ╬Á < ╬┤ / 2 := lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
  linarith

/-- **PROVED ÔÇö eventually-in-neighborhood propagates to a nhd of the probe.**
Strengthening of `eventually_nhds_implies_probe_eventually`: not only does
`P` hold *at* the probe `¤ü ÔêÆ ╬Á┬ÀI`, it holds on an entire neighbourhood of
it. This is the form needed when feeding the data into Mathlib lemmas of
the shape `Filter.EventuallyEq.deriv_eq`, which require eventual equality
*at* the differentiation point. -/
theorem eventually_nhds_implies_probe_eventually_nhds
    {P : Ôäé ÔåÆ Prop} {¤ü : Ôäé}
    (hP : ÔêÇßÂá z in ­ØôØ ¤ü, P z)
    (hupper : 0 < ¤ü.im) :
    Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
        ÔêÇßÂá z in ­ØôØ (¤ü - (╬Á : Ôäé) * Complex.I), P z := by
  rw [Metric.eventually_nhds_iff] at hP
  obtain Ôƒ¿╬┤, h╬┤_pos, h╬┤Ôƒ® := hP
  refine Ôƒ¿min (╬┤ / 2) (¤ü.im / 2), ?_, ?_, ?_Ôƒ®
  ┬À exact lt_min (by linarith) (by linarith)
  ┬À exact lt_of_le_of_lt (min_le_right _ _) (by linarith)
  intro ╬Á h╬Á_pos h╬Á_lt
  have h╬Á_lt_half : ╬Á < ╬┤ / 2 := lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
  rw [Metric.eventually_nhds_iff]
  refine Ôƒ¿╬┤ / 4, by linarith, ?_Ôƒ®
  intro w hw
  apply h╬┤
  have hprobe_dist : dist (¤ü - (╬Á : Ôäé) * Complex.I) ¤ü = ╬Á := by
    rw [dist_eq_norm,
        show ¤ü - (╬Á : Ôäé) * Complex.I - ¤ü = -((╬Á : Ôäé) * Complex.I) by ring,
        norm_neg, norm_mul, Complex.norm_I, mul_one]
    show ÔÇû((╬Á : ÔäØ) : Ôäé)ÔÇû = ╬Á
    rw [Complex.norm_real, Real.norm_eq_abs, abs_of_pos h╬Á_pos]
  calc dist w ¤ü
        Ôëñ dist w (¤ü - (╬Á : Ôäé) * Complex.I) +
            dist (¤ü - (╬Á : Ôäé) * Complex.I) ¤ü := dist_triangle _ _ _
    _ < ╬┤ / 4 + ╬Á := by linarith
    _ < ╬┤ := by linarith

/-- **Entire-function local pole-decomposition hypothesis.** At every
upper-half-plane zero of `F`, the local pole structure is good enough
to supply a `LocalLogDerivPoleDecomposition` for `╬ø[F]`. This is the
entire-function analogue of ┬º7's `PolynomialPoleWitnessHypothesis`.

Constructively building an inhabitant of this structure from the natural
factorization data `ÔêÇßÂá z in ­ØôØ ¤ü, F z = (z ÔêÆ ¤ü)^m ┬À g z` (with `g(¤ü) Ôëá 0`
and `g` analytic) is the CXXXV next-phase target ÔÇö see ┬º13. -/
structure EntireLocalPoleDecompositionHypothesis (F : Ôäé ÔåÆ Ôäé) : Prop where
  decomp_at_each_upper_zero :
    ÔêÇ ¤ü : Ôäé, F ¤ü = 0 ÔåÆ 0 < ¤ü.im ÔåÆ
      Nonempty (LocalLogDerivPoleDecomposition (logDerivativeResponse F) ¤ü)

/-- **PROVED ÔÇö entire-function pole-decomposition hypothesis discharges
the abstract `LogDerivPoleWitnessLaw`.** One-line composition with ┬º5's
`localLogDerivPoleDecomposition_forces_escape`. -/
theorem entireLocalPoleDecomposition_gives_poleWitness
    {F : Ôäé ÔåÆ Ôäé} (H : EntireLocalPoleDecompositionHypothesis F) :
    LogDerivPoleWitnessLaw F (logDerivativeResponse F) where
  upper_zero_forces_escape := by
    intro ¤ü hzero hupper
    obtain Ôƒ¿DÔƒ® := H.decomp_at_each_upper_zero ¤ü hzero hupper
    exact localLogDerivPoleDecomposition_forces_escape D

/-- Ô¡É **PROVED ÔÇö ENTIRE-FUNCTION TEMPLATE THEOREM.** For any function `F`
satisfying the entire-function local pole-decomposition hypothesis,
anti-Herglotz log-derivative plus Schwarz symmetry Ôƒ╣ every zero of `F`
is real. This is the entire-function analogue of ┬º7's polynomial
finite RH-equivalence.

Inhabiting `EntireLocalPoleDecompositionHypothesis F` for any analytic
`F` reduces to the local factorization at each zero plus the bounded
background ÔÇö both standard complex analysis, handled by ┬º8's reusable
`continuousAt_implies_probe_bounded`. -/
theorem entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm
    (F : Ôäé ÔåÆ Ôäé)
    (H : EntireLocalPoleDecompositionHypothesis F)
    (hanti : AntiHerglotzUHP (logDerivativeResponse F))
    (hsym : ÔêÇ z : Ôäé, F (star z) = star (F z)) :
    ÔêÇ ¤ü : Ôäé, F ¤ü = 0 ÔåÆ ¤ü.im = 0 :=
  antiHerglotz_plus_symmetry_forces_real_zeros_complex
    (entireLocalPoleDecomposition_gives_poleWitness H) hanti hsym

-- =====================================================================
-- ┬º10-bis. Local analytic factorization ÔåÆ pole-decomposition
--          (CXXXIV-A: entire-function analogue of ┬º9)
-- =====================================================================
-- Replays the ┬º9 polynomial bridge one level up:
--
--   ┬º9  (polynomial):
--     polynomial factor data           ÔåÆ  LocalLogDerivPoleDecomposition
--     PolynomialPoleWitnessHypothesis  (discharged unconditionally in ┬º9)
--
--   ┬º10-bis (entire-function):
--     LocalAnalyticZeroFactorization F ¤ü        (per-zero analytic data)
--     EntireZeroFactorizationHypothesis F       (quantified over zeros)
--     EntireLocalPoleDecompositionHypothesis F  (the ┬º10 target)
--
-- The only genuinely-new analytic content is `logDeriv_of_eventual_factorization`,
-- which lifts ┬º5's algebraic `complex_local_pole_decomposition_general` through
-- `Filter.EventuallyEq.deriv_eq` to the value form
--
--     ╬ø[F](z) = m/(z ÔêÆ ¤ü) + g'(z)/g(z).
--
-- Once an analytic `F` (e.g. `XiPullback`) supplies a `LocalAnalyticZeroFactorization`
-- at each upper-half-plane zero, the ┬º10 template `entire_function_roots_real_ÔÇª`
-- becomes hypothesis-free for that `F`.

/-- **Local analytic factorization data at a zero.** Records the standard
analytic factorization
   F z = (z ÔêÆ ¤ü)^m ┬À g z   eventually near ¤ü,
with `m ÔëÑ 1`, `g` nonvanishing at `¤ü`, `g` differentiable on a neighbourhood
of `¤ü`, and the log-derivative background `g'/g` continuous at `¤ü`.

This is the natural complex-analytic input that any function holomorphic
on a neighbourhood of an isolated zero of multiplicity `m` provides. -/
structure LocalAnalyticZeroFactorization (F : Ôäé ÔåÆ Ôäé) (¤ü : Ôäé) where
  m : Ôäò
  hm_pos : 0 < m
  g : Ôäé ÔåÆ Ôäé
  hg¤ü : g ¤ü Ôëá 0
  hg_diff_nhds : ÔêÇßÂá z in ­ØôØ ¤ü, DifferentiableAt Ôäé g z
  hcont_background : ContinuousAt (fun z => deriv g z / g z) ¤ü
  hfactor : ÔêÇßÂá z in ­ØôØ ¤ü, F z = (z - ¤ü) ^ m * g z

/-- **PROVED ÔÇö log-derivative of an eventual factorization.**
If `F` agrees on a neighbourhood of `z` with `(┬À ÔêÆ ¤ü)^m ┬À g` (with `m ÔëÑ 1`,
`z Ôëá ¤ü`, `g z Ôëá 0`, `g` differentiable at `z`), then the algebraic identity
of ┬º5 transfers to the actual log-derivative response:

  `╬ø[F](z)  =  m / (z ÔêÆ ¤ü)  +  g'(z) / g(z)`.

Mechanism: `Filter.EventuallyEq.deriv_eq` rewrites `deriv F z` to the
derivative of the factored form; the product/power rules compute the
latter; ┬º5's `complex_local_pole_decomposition_general` reduces the
resulting algebraic ratio. -/
theorem logDeriv_of_eventual_factorization
    {F g : Ôäé ÔåÆ Ôäé} {¤ü z : Ôäé} {m : Ôäò}
    (hm : 0 < m)
    (hz¤ü : z Ôëá ¤ü)
    (hgz : g z Ôëá 0)
    (hF_eq : F =ßÂá[­ØôØ z] fun w => (w - ¤ü) ^ m * g w)
    (hgdiff : DifferentiableAt Ôäé g z) :
    logDerivativeResponse F z =
      ((m : Ôäò) : Ôäé) / (z - ¤ü) + deriv g z / g z := by
  -- Rewrite m as k+1 to mesh with the ┬º5 general lemma.
  obtain Ôƒ¿k, rflÔƒ® : Ôêâ k, m = k + 1 := Ôƒ¿m - 1, by omegaÔƒ®
  -- Value of F at z.
  have hF_val : F z = (z - ¤ü) ^ (k + 1) * g z := hF_eq.eq_of_nhds
  -- Derivative of (┬ÀÔêÆ¤ü)^(k+1) at z, then product with g.
