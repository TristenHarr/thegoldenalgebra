-- ---------------------------------------------------------------------
-- CLX-template: slab cert factory via constant cloud LB + analytic tail
-- ---------------------------------------------------------------------
-- The single reusable lemma that converts (slab-specific constant K +
-- closed-form scalar inequality) into a `SlabSimplePolyIneq` proof.
-- One per-slab numerical fact (the constant K and the scalar discharge)
-- is all that remains to populate `NineSlabSimplePolyInequalities`.

/-- Ô¡É **PROVED ÔÇö slab cert template via constant cloud LB + analytic
tail chain.**

Single reusable lemma that proves `SlabSimplePolyIneq` on any slab
where the inequality
  `closedFormSErrorBoundCD C D y T  Ôëñ  2┬Ày┬ÀK  +  (22/15)┬À¤ü(T)┬Ày/T`
holds for all admissible probes `(y, T)` in the slab.  Here:

* `K`         = the per-slab cloud constant `Ôëñ ╬ú_╬│ 1 / (x_max┬▓ + ╬│┬▓ + y_max┬▓)`,
                where `x_max`, `y_max` bound the slab box;
* `x┬▓`, `y┬▓`  are bounded by `x_max┬▓`, `y_max┬▓` on the slab via
  the adaptive-region constraint `2(1+|x|+y) Ôëñ T Ôëñ Tmax`;
* the `22/15` tail bound comes from CLV
  `smoothTailRationalLowerBoundAbs_ge_22_15`;
* `hScalar` is the per-slab numerical fact ÔÇö a closed-form `(y, T)`
  polynomial-rational inequality at the slab's specific `(C, D, K)`.

For each of the nine `[10, 140]` slabs, the user supplies:
  (i) the cloud constant `K` and `h_const_lb : K Ôëñ ╬ú_╬│ 1/(...)`;
  (ii) a Lean proof of `hScalar`.
Once these are supplied, this lemma produces the slab cert directly. -/
theorem slabSimplePolyIneq_of_const_cloud_and_analytic_tail
    {zeros : List ÔäØ} {Tmin Tmax C D x_max y_max K : ÔäØ}
    (h_2pi_le_Tmin : 2 * Real.pi Ôëñ Tmin)
    (h_x_bound :
      ÔêÇ x y T : ÔäØ, Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ 0 < y ÔåÆ
        2 * (1 + |x| + y) Ôëñ T ÔåÆ x^2 Ôëñ x_max^2)
    (h_y_bound :
      ÔêÇ x y T : ÔäØ, Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ 0 < y ÔåÆ
        2 * (1 + |x| + y) Ôëñ T ÔåÆ y^2 Ôëñ y_max^2)
    (h_const_lb :
      K Ôëñ (zeros.map fun g => 1 / (x_max^2 + g^2 + y_max^2)).sum)
    (hScalar :
      ÔêÇ y T : ÔäØ, Tmin Ôëñ T ÔåÆ T Ôëñ Tmax ÔåÆ 0 < y ÔåÆ
        closedFormSErrorBoundCD C D y T
          Ôëñ 2 * y * K + (22 / 15 : ÔäØ) * zeroDensityRho T * y / T) :
    SlabSimplePolyIneq zeros Tmin Tmax C D := by
  intro x y T hTmin hTmax hy hreg
  have hT_2pi : 2 * Real.pi Ôëñ T := le_trans h_2pi_le_Tmin hTmin
  have hx_sq := h_x_bound x y T hTmin hTmax hy hreg
  have hy_sq := h_y_bound x y T hTmin hTmax hy hreg
  have h_cloud_const :=
    simpleCloudSum_ge_const_bound zeros x y x_max y_max hx_sq hy_sq hy
  have hy_nn : (0 : ÔäØ) Ôëñ 2 * y := by linarith
  have h_const_scaled :
      2 * y * K Ôëñ 2 * y *
          (zeros.map fun g => 1 / (x_max^2 + g^2 + y_max^2)).sum :=
    mul_le_mul_of_nonneg_left h_const_lb hy_nn
  have h_cloud_K_lb : 2 * y * K Ôëñ simpleCloudSum zeros x y :=
    le_trans h_const_scaled h_cloud_const
  have h_tail_22_15 :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg
  have h_scalar := hScalar y T hTmin hTmax hy
  linarith

-- ---------------------------------------------------------------------
-- CLX-adaptive-bounds: x Ôëñ T/2 and y Ôëñ T/2 from the slab constraint
-- ---------------------------------------------------------------------

/-- Ô¡É **PROVED ÔÇö `x Ôëñ T / 2` from the adaptive region constraint.**
For `y > 0`, `2 (1 + x + y) Ôëñ T` Ôƒ╣ `2x Ôëñ T ÔêÆ 2 ÔêÆ 2y < T` Ôƒ╣ `x Ôëñ T/2`. -/
theorem x_le_half_T_of_adaptive
    {x y T : ÔäØ} (hy : 0 < y) (hreg : 2 * (1 + x + y) Ôëñ T) :
    x Ôëñ T / 2 := by linarith

/-- Ô¡É **PROVED ÔÇö `y Ôëñ T / 2` from the adaptive region constraint.** -/
theorem y_le_half_T_of_adaptive
    {x y T : ÔäØ} (hx : 0 Ôëñ x) (hreg : 2 * (1 + x + y) Ôëñ T) :
    y Ôëñ T / 2 := by linarith

-- ---------------------------------------------------------------------
-- CLX-grouped: cloud lower bound via grouped denominator upper bounds
-- ---------------------------------------------------------------------
-- The 50-zero K-sum has denominator ~10^900 if written exactly, blowing
-- past `norm_num`/`decide`.  The fix: partition the zero list into a few
-- groups (typically 10 + 20 + 20 = 50) and bound each group's
-- denominators by a single conservative `N_i`.  The resulting cloud
-- lower bound is `10/N_A + 20/N_B + 20/N_C` ÔÇö a 3-term rational with
-- small denominators.

/-- Ô¡É **PROVED ÔÇö list-sum bound from a per-element constant upper
bound.** If every element of `zeros` has `x_max┬▓ + g┬▓ + y_max┬▓ Ôëñ N`
(with `N > 0` and `y_max > 0` for denominator positivity), then
`╬ú 1/(x_max┬▓ + g┬▓ + y_max┬▓) ÔëÑ length ┬À (1/N)`. -/
theorem cloud_const_sum_ge_uniform
    {x_max y_max N : ÔäØ} (_hN : 0 < N) (hy_max : 0 < y_max) (zeros : List ÔäØ)
    (hbnd : ÔêÇ g Ôêê zeros, x_max^2 + g^2 + y_max^2 Ôëñ N) :
    (zeros.length : ÔäØ) * (1 / N)
      Ôëñ (zeros.map fun g => 1 / (x_max^2 + g^2 + y_max^2)).sum := by
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    have h_pos : 0 < x_max^2 + g^2 + y_max^2 := by positivity
    have h_head_le : x_max^2 + g^2 + y_max^2 Ôëñ N :=
      hbnd g (List.mem_cons_self ..)
    have h_term : 1 / N Ôëñ 1 / (x_max^2 + g^2 + y_max^2) :=
      one_div_le_one_div_of_le h_pos h_head_le
    have h_rest : ÔêÇ g Ôêê rest, x_max^2 + g^2 + y_max^2 Ôëñ N :=
      fun g hg => hbnd g (List.mem_cons_of_mem _ hg)
    have h_ih := ih h_rest
    simp only [List.map_cons, List.sum_cons, List.length_cons,
               Nat.cast_succ]
    linarith

/-- Ô¡É **PROVED ÔÇö three-group cloud lower bound (the workhorse).**

For a zero list `zeros = A ++ B ++ C` with explicit group upper bounds
`N_A, N_B, N_C` on the denominator `x_max┬▓ + ╬│┬▓ + y_max┬▓`, the K-sum
is bounded below by `|A|/N_A + |B|/N_B + |C|/N_C`. -/
theorem cloud_const_sum_ge_group3
    {x_max y_max N_A N_B N_C : ÔäØ}
    (hN_A : 0 < N_A) (hN_B : 0 < N_B) (hN_C : 0 < N_C)
    (hy_max : 0 < y_max)
    {zeros A B C : List ÔäØ}
    (hzeros : zeros = A ++ B ++ C)
    (hA : ÔêÇ g Ôêê A, x_max^2 + g^2 + y_max^2 Ôëñ N_A)
    (hB : ÔêÇ g Ôêê B, x_max^2 + g^2 + y_max^2 Ôëñ N_B)
    (hC : ÔêÇ g Ôêê C, x_max^2 + g^2 + y_max^2 Ôëñ N_C) :
    (A.length : ÔäØ) * (1 / N_A) + (B.length : ÔäØ) * (1 / N_B)
      + (C.length : ÔäØ) * (1 / N_C)
