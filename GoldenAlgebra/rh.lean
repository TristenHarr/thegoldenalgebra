  have hhi : T / 2 - 1 вЙ§ (11 / 2 : вДЭ) := by linarith
  have hsq : (T / 2 - 1)^2 вЙ§ ((11 / 2 : вДЭ)^2) := sq_le_sq' (by linarith) hhi
  have hden : (T / 2 - 1)^2 + ќ≥^2 вЙ§ ((11 / 2 : вДЭ)^2) + ќ≥^2 := by linarith
  have hT_half_pos : 0 < T / 2 - 1 := by linarith
  have hTsq_pos : 0 < (T / 2 - 1)^2 := pow_pos hT_half_pos 2
  have hdenpos : 0 < (T / 2 - 1)^2 + ќ≥^2 := by
    have hќ≥2 : 0 вЙ§ ќ≥^2 := sq_nonneg _
    linarith
  exact one_div_le_one_div_of_le hdenpos hden

