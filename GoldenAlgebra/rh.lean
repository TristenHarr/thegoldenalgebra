/-! ### Smooth main-term aliases

We alias the already-proved global definitions `smoothZeroCountingN0` and
`zeroDensityRho` so this layer does not fork the meaning of the smooth
zero-counting function. -/

/-- The smooth RiemannÔÇôvon Mangoldt main term used by the Backlund/Turing
layer.  Alias of `smoothZeroCountingN0`. -/
noncomputable def smoothMainTerm (u : ÔäØ) : ÔäØ :=
  smoothZeroCountingN0 u

/-- The smooth zero-density used by the Backlund/Turing layer.  Alias of
`zeroDensityRho`. -/
noncomputable def smoothDensity (u : ÔäØ) : ÔäØ :=
  zeroDensityRho u

theorem smoothDensity_nonneg_of_ge_two_pi
    {u : ÔäØ} (hu : 2 * Real.pi Ôëñ u) :
    0 Ôëñ smoothDensity u := by
  simpa [smoothDensity] using zeroDensityRho_nonneg_of_ge_two_pi hu

theorem deriv_smoothMainTerm
    {u : ÔäØ} (hu : 0 < u) :
    deriv smoothMainTerm u = smoothDensity u := by
  simpa [smoothMainTerm, smoothDensity] using deriv_smoothZeroCountingN0 hu

/-- Derivative form for the Backlund smooth main term. -/
theorem hasDerivAt_smoothMainTerm
    {u : ÔäØ} (hu : 0 < u) :
    HasDerivAt smoothMainTerm (smoothDensity u) u := by
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have hq_pos : (0 : ÔäØ) < u / (2 * Real.pi) := div_pos hu h2pi_pos
  have hq_ne : u / (2 * Real.pi) Ôëá 0 := ne_of_gt hq_pos
  have hlin :
      HasDerivAt (fun v : ÔäØ => v / (2 * Real.pi))
        (1 / (2 * Real.pi)) u := by
    simpa using (hasDerivAt_id u).div_const (2 * Real.pi)
  have hlog :
      HasDerivAt (fun v : ÔäØ => Real.log (v / (2 * Real.pi)))
        (1 / u) u := by
    have h := (Real.hasDerivAt_log hq_ne).comp u hlin
    have hsimp :
        (u / (2 * Real.pi))Ôü╗┬╣ * (1 / (2 * Real.pi)) = 1 / u := by
      field_simp
      ring
    rw [hsimp] at h
    simpa [Function.comp_def] using h
  have hprod := hlin.mul hlog
  have hsub := hprod.sub hlin
  have hfinal := hsub.add_const (7 / 8)
  have hderiv :
      (1 / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
        + (u / (2 * Real.pi)) * (1 / u) - 1 / (2 * Real.pi)
      = smoothDensity u := by
    unfold smoothDensity zeroDensityRho
    field_simp
    ring
  have hfunc :
      (fun v : ÔäØ => (v / (2 * Real.pi)) * Real.log (v / (2 * Real.pi))
                    - v / (2 * Real.pi) + 7 / 8)
        = smoothMainTerm := by
    funext v
    rfl
  rw [ÔåÉ hfunc, ÔåÉ hderiv]
  exact hfinal

/-- The Backlund smooth main term is monotone on `[2¤Ç, Ôê×)`. -/
theorem smoothMainTerm_monotoneOn_Ici_two_pi :
    MonotoneOn smoothMainTerm (Set.Ici (2 * Real.pi)) := by
  apply monotoneOn_of_deriv_nonneg (convex_Ici _)
  ┬À intro x hx
    have hx_ge : 2 * Real.pi Ôëñ x := hx
    have hx_pos : 0 < x := lt_of_lt_of_le (by positivity) hx_ge
    exact (hasDerivAt_smoothMainTerm hx_pos).continuousAt.continuousWithinAt
  ┬À intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    exact (hasDerivAt_smoothMainTerm hx_pos).differentiableAt.differentiableWithinAt
  ┬À intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    rw [(hasDerivAt_smoothMainTerm (lt_trans (by positivity) hx_2pi)).deriv]
    exact smoothDensity_nonneg_of_ge_two_pi (le_of_lt hx_2pi)

/-- Endpoint bounds for the monotone smooth main term bound the whole
interval. -/
theorem smoothMainTerm_bounds_of_endpoint_bounds
    {A B T mainLower mainUpper : ÔäØ}
    (hA2pi : 2 * Real.pi Ôëñ A)
    (hAT : A Ôëñ T) (hTB : T Ôëñ B)
    (hlow : mainLower Ôëñ smoothMainTerm A)
    (hhigh : smoothMainTerm B Ôëñ mainUpper) :
    mainLower Ôëñ smoothMainTerm T Ôêº smoothMainTerm T Ôëñ mainUpper := by
  have hmono := smoothMainTerm_monotoneOn_Ici_two_pi
  have hT2pi : 2 * Real.pi Ôëñ T := le_trans hA2pi hAT
  have hB2pi : 2 * Real.pi Ôëñ B := le_trans hT2pi hTB
  have hleft : smoothMainTerm A Ôëñ smoothMainTerm T :=
    hmono hA2pi hT2pi hAT
  have hright : smoothMainTerm T Ôëñ smoothMainTerm B :=
    hmono hT2pi hB2pi hTB
  constructor
  ┬À exact le_trans hlow hleft
  ┬À exact le_trans hright hhigh

/-- A lower log-ratio bound gives a lower bound for the Backlund smooth
main term.  This is the reusable endpoint arithmetic step needed by the
finite `[140, 374]` slab table. -/
theorem smoothMainTerm_lower_bound_of_log_ratio_lower
    {T logLower mainLower : ÔäØ}
    (hT0 : 0 Ôëñ T)
    (hlog : logLower Ôëñ Real.log (T / (2 * Real.pi)))
    (harith :
      mainLower
        Ôëñ (T / (2 * Real.pi)) * logLower
          - T / (2 * Real.pi) + 7 / 8) :
    mainLower Ôëñ smoothMainTerm T := by
  have hratio_nonneg : 0 Ôëñ T / (2 * Real.pi) := by positivity
  have hmul :
      (T / (2 * Real.pi)) * logLower
        Ôëñ (T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left hlog hratio_nonneg
  unfold smoothMainTerm smoothZeroCountingN0
  linarith

/-- An upper log-ratio bound gives an upper bound for the Backlund smooth
main term. -/
theorem smoothMainTerm_upper_bound_of_log_ratio_upper
    {T logUpper mainUpper : ÔäØ}
    (hT0 : 0 Ôëñ T)
    (hlog : Real.log (T / (2 * Real.pi)) Ôëñ logUpper)
    (harith :
      (T / (2 * Real.pi)) * logUpper
        - T / (2 * Real.pi) + 7 / 8
          Ôëñ mainUpper) :
    smoothMainTerm T Ôëñ mainUpper := by
  have hratio_nonneg : 0 Ôëñ T / (2 * Real.pi) := by positivity
  have hmul :
      (T / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        Ôëñ (T / (2 * Real.pi)) * logUpper :=
    mul_le_mul_of_nonneg_left hlog hratio_nonneg
  unfold smoothMainTerm smoothZeroCountingN0
  linarith

/-! ### Zero-set predicates

We define the predicates needed to talk about nontrivial zeta zeros up to
a finite height.  No finiteness claim is asserted here ÔÇö finiteness will
later be packaged as a `ZeroSetUpToHeight` certificate whose existence is
a separate analytic theorem. -/

/-- A point `s Ôêê Ôäé` is a nontrivial zero of the Riemann zeta function in
the open critical strip.  This predicate does not assert RH; it only
constrains the real part to `(0, 1)`. -/
def IsNontrivialZetaZero (s : Ôäé) : Prop :=
  riemannZeta s = 0 Ôêº 0 < s.re Ôêº s.re < 1

/-- A nontrivial zeta zero with imaginary part in `(0, T]`. -/
def IsZetaZeroUpToHeight (T : ÔäØ) (s : Ôäé) : Prop :=
  IsNontrivialZetaZero s Ôêº 0 < s.im Ôêº s.im Ôëñ T

/-- A height `T` is good if no nontrivial zeta zero lies exactly on the
horizontal line `Im s = T`.  Backlund/Turing contour arguments restrict
to good heights to avoid zeros on the boundary of the counting rectangle. -/
def GoodHeight (T : ÔäØ) : Prop :=
  ÔêÇ s : Ôäé, IsNontrivialZetaZero s ÔåÆ s.im Ôëá T

/-! ### Finite zero-set certificate

`ZeroSetUpToHeight T` packages the (eventually theorem-supplied) finite
enumeration of nontrivial zeta zeros with imaginary part in `(0, T]`.
Existence of such a certificate is a later analytic theorem, not assumed
here.  Multiplicity is not yet tracked ÔÇö a later refinement should count
multiplicity using the order of vanishing of `riemannZeta`. -/

structure ZeroSetUpToHeight (T : ÔäØ) where
  zeros : Finset Ôäé
  complete :
    ÔêÇ s : Ôäé, s Ôêê zeros Ôåö IsZetaZeroUpToHeight T s

/-- The zero count from a completed zero-set certificate.  Simple
counting (no multiplicity). -/
def zeroCountFromCertificate {T : ÔäØ} (Z : ZeroSetUpToHeight T) : Ôäò :=
  Z.zeros.card

/-- Zero-counting fluctuation associated to a certified zero set.

This is the certificate-based version of

  `S(T) = N(T) - NÔéÇ(T)`. -/
noncomputable def fluctuationFromCertificate
    {T : ÔäØ} (Z : ZeroSetUpToHeight T) : ÔäØ :=
  (zeroCountFromCertificate Z : ÔäØ) - smoothMainTerm T

/-! ### Certificate algebra for zero sets

A completed zero-set certificate is uniquely determined by its height
`T` (up to equality of the underlying `Finset`).  Consequently the count
and fluctuation do not depend on the chosen certificate.  This matters
because later we may produce certificates by different routes (analytic
finiteness, computed Turing certificate, imported verified zero list,
argument-principle count) and they must all agree. -/

/-- Membership in a completed zero-set certificate is exactly the
`IsZetaZeroUpToHeight` predicate. -/
theorem mem_zeroSet_iff
    {T : ÔäØ} (Z : ZeroSetUpToHeight T) (s : Ôäé) :
    s Ôêê Z.zeros Ôåö IsZetaZeroUpToHeight T s :=
  Z.complete s

/-- Forward direction of the certificate completeness condition. -/
theorem isZetaZeroUpToHeight_of_mem_zeroSet
    {T : ÔäØ} (Z : ZeroSetUpToHeight T) {s : Ôäé}
    (hs : s Ôêê Z.zeros) :
    IsZetaZeroUpToHeight T s :=
  (Z.complete s).mp hs

/-- Backward direction of the certificate completeness condition. -/
theorem mem_zeroSet_of_isZetaZeroUpToHeight
    {T : ÔäØ} (Z : ZeroSetUpToHeight T) {s : Ôäé}
    (hs : IsZetaZeroUpToHeight T s) :
    s Ôêê Z.zeros :=
  (Z.complete s).mpr hs

/-- Any two completed zero-set certificates for the same height have the
same underlying finite set. -/
theorem zeroSetUpToHeight_zeros_unique
    {T : ÔäØ} (ZÔéü ZÔéé : ZeroSetUpToHeight T) :
    ZÔéü.zeros = ZÔéé.zeros := by
  ext s
  rw [ZÔéü.complete s, ZÔéé.complete s]

/-- The zero count is independent of the chosen completed zero-set
certificate. -/
theorem zeroCountFromCertificate_eq
    {T : ÔäØ} (ZÔéü ZÔéé : ZeroSetUpToHeight T) :
    zeroCountFromCertificate ZÔéü = zeroCountFromCertificate ZÔéé := by
  unfold zeroCountFromCertificate
  rw [zeroSetUpToHeight_zeros_unique ZÔéü ZÔéé]

/-- The fluctuation is independent of the chosen completed zero-set
certificate. -/
theorem fluctuationFromCertificate_eq
    {T : ÔäØ} (ZÔéü ZÔéé : ZeroSetUpToHeight T) :
    fluctuationFromCertificate ZÔéü = fluctuationFromCertificate ZÔéé := by
  unfold fluctuationFromCertificate
  rw [zeroCountFromCertificate_eq ZÔéü ZÔéé]

/-! ### Empty zero-set certificate below height zero

The first existence theorem for zero-set certificates: in the trivial
range `T Ôëñ 0`, the empty finite set is a complete certificate, because
`IsZetaZeroUpToHeight T` requires `0 < s.im Ôëñ T`. -/

/-- There are no zeta zeros counted up to a nonpositive height, because
the definition requires `0 < s.im Ôëñ T`. -/
theorem not_isZetaZeroUpToHeight_of_nonpos
    {T : ÔäØ} (hT : T Ôëñ 0) (s : Ôäé) :
    ┬¼ IsZetaZeroUpToHeight T s := by
  intro hs
  have hs_pos : 0 < s.im := hs.2.1
  have hs_le : s.im Ôëñ T := hs.2.2
  linarith

/-- For `T Ôëñ 0`, the empty finite set is a completed zero-set
certificate. -/
def emptyZeroSetUpToHeight_of_nonpos
    {T : ÔäØ} (hT : T Ôëñ 0) :
    ZeroSetUpToHeight T where
  zeros := Ôêà
  complete := by
    intro s
    constructor
    ┬À intro hs
      simp at hs
    ┬À intro hs
      exact False.elim ((not_isZetaZeroUpToHeight_of_nonpos hT s) hs)

/-- For `T Ôëñ 0`, every completed zero-set certificate has zero
cardinality. -/
theorem zeroCountFromCertificate_eq_zero_of_nonpos
    {T : ÔäØ} (hT : T Ôëñ 0) (Z : ZeroSetUpToHeight T) :
    zeroCountFromCertificate Z = 0 := by
  have hZ :
      Z.zeros = (emptyZeroSetUpToHeight_of_nonpos hT).zeros :=
    zeroSetUpToHeight_zeros_unique Z (emptyZeroSetUpToHeight_of_nonpos hT)
  unfold zeroCountFromCertificate
  rw [hZ]
  simp [emptyZeroSetUpToHeight_of_nonpos]

/-! ### Multiplicity-aware zero-set certificates

The simple certificate counts each zero once.  The real RiemannÔÇôvon
Mangoldt `N(T)` counts with multiplicity, so we introduce a weighted
certificate now to fix the architecture.  No analytic theorem is assumed
here; later, `mult s` should be proved equal to the order of vanishing
of `riemannZeta` at `s`. -/

/-- A multiplicity-aware finite zero-set certificate up to height `T`. -/
structure WeightedZeroSetUpToHeight (T : ÔäØ) where
  zeros : Finset Ôäé
  mult : Ôäé ÔåÆ Ôäò
  complete :
    ÔêÇ s : Ôäé, s Ôêê zeros Ôåö IsZetaZeroUpToHeight T s
  positive_on_zeros :
    ÔêÇ s : Ôäé, s Ôêê zeros ÔåÆ 0 < mult s
  zero_off_zeros :
    ÔêÇ s : Ôäé, s Ôêë zeros ÔåÆ mult s = 0

/-- Forget multiplicities and recover the underlying simple zero-set
certificate. -/
def WeightedZeroSetUpToHeight.toZeroSetUpToHeight
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) :
    ZeroSetUpToHeight T where
  zeros := W.zeros
  complete := W.complete

/-- Membership in a weighted zero-set certificate is exactly the
`IsZetaZeroUpToHeight T` predicate. -/
theorem mem_weightedZeroSet_iff
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) (s : Ôäé) :
    s Ôêê W.zeros Ôåö IsZetaZeroUpToHeight T s :=
  W.complete s

/-- A point in the weighted zero-set has positive multiplicity. -/
theorem weighted_mult_pos_of_mem
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) {s : Ôäé}
    (hs : s Ôêê W.zeros) :
    0 < W.mult s :=
  W.positive_on_zeros s hs

/-- A point satisfying the zero predicate has positive multiplicity. -/
theorem weighted_mult_pos_of_isZetaZeroUpToHeight
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) {s : Ôäé}
    (hs : IsZetaZeroUpToHeight T s) :
    0 < W.mult s :=
  W.positive_on_zeros s ((W.complete s).mpr hs)

/-- A point not satisfying the zero predicate has multiplicity zero. -/
theorem weighted_mult_eq_zero_of_not_isZetaZeroUpToHeight
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) {s : Ôäé}
    (hs : ┬¼ IsZetaZeroUpToHeight T s) :
    W.mult s = 0 := by
  apply W.zero_off_zeros
  intro hmem
  exact hs ((W.complete s).mp hmem)

/-- The multiplicity-aware zero count. -/
def weightedZeroCountFromCertificate
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) : Ôäò :=
  W.zeros.sum W.mult

/-- The multiplicity-aware zero-counting fluctuation. -/
noncomputable def weightedFluctuationFromCertificate
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T) : ÔäØ :=
  (weightedZeroCountFromCertificate W : ÔäØ) - smoothMainTerm T

/-- Any two weighted zero-set certificates for the same height have the
same underlying finite support. -/
theorem weightedZeroSet_zeros_unique
    {T : ÔäØ} (WÔéü WÔéé : WeightedZeroSetUpToHeight T) :
    WÔéü.zeros = WÔéé.zeros := by
  ext s
  rw [WÔéü.complete s, WÔéé.complete s]

/-- If two weighted certificates use the same multiplicity function on the
zero predicate, then their weighted zero counts agree. -/
theorem weightedZeroCountFromCertificate_eq_of_mult_eq
    {T : ÔäØ} (WÔéü WÔéé : WeightedZeroSetUpToHeight T)
    (hmult :
      ÔêÇ s : Ôäé, IsZetaZeroUpToHeight T s ÔåÆ
        WÔéü.mult s = WÔéé.mult s) :
    weightedZeroCountFromCertificate WÔéü =
      weightedZeroCountFromCertificate WÔéé := by
  unfold weightedZeroCountFromCertificate
  have hzeros : WÔéü.zeros = WÔéé.zeros :=
    weightedZeroSet_zeros_unique WÔéü WÔéé
  rw [hzeros]
  apply Finset.sum_congr rfl
  intro s hs
  exact hmult s ((WÔéé.complete s).mp hs)

/-- If two weighted certificates use the same multiplicity function on the
zero predicate, then their fluctuations agree. -/
theorem weightedFluctuationFromCertificate_eq_of_mult_eq
    {T : ÔäØ} (WÔéü WÔéé : WeightedZeroSetUpToHeight T)
    (hmult :
      ÔêÇ s : Ôäé, IsZetaZeroUpToHeight T s ÔåÆ
        WÔéü.mult s = WÔéé.mult s) :
    weightedFluctuationFromCertificate WÔéü =
      weightedFluctuationFromCertificate WÔéé := by
  unfold weightedFluctuationFromCertificate
  rw [weightedZeroCountFromCertificate_eq_of_mult_eq WÔéü WÔéé hmult]

/-! ### Empty weighted zero-set certificate below height zero -/

/-- For `T Ôëñ 0`, the empty weighted zero-set is complete. -/
def emptyWeightedZeroSetUpToHeight_of_nonpos
    {T : ÔäØ} (hT : T Ôëñ 0) :
    WeightedZeroSetUpToHeight T where
  zeros := Ôêà
  mult := fun _ => 0
  complete := by
    intro s
    constructor
    ┬À intro hs
      simp at hs
    ┬À intro hs
      exact False.elim ((not_isZetaZeroUpToHeight_of_nonpos hT s) hs)
  positive_on_zeros := by
    intro s hs
    simp at hs
  zero_off_zeros := by
    intro s _hs
    rfl

/-- For `T Ôëñ 0`, every weighted zero-set certificate has weighted count
zero. -/
theorem weightedZeroCountFromCertificate_eq_zero_of_nonpos
    {T : ÔäØ} (hT : T Ôëñ 0) (W : WeightedZeroSetUpToHeight T) :
    weightedZeroCountFromCertificate W = 0 := by
  unfold weightedZeroCountFromCertificate
  have hzeros :
      W.zeros = (emptyWeightedZeroSetUpToHeight_of_nonpos hT).zeros :=
    weightedZeroSet_zeros_unique W
      (emptyWeightedZeroSetUpToHeight_of_nonpos hT)
  rw [hzeros]
  simp [emptyWeightedZeroSetUpToHeight_of_nonpos]

/-! ### Compatibility of simple and weighted zero counts

If a weighted certificate assigns multiplicity `1` to every zero in its
support, then the weighted count agrees with the simple `Finset.card`
count of the underlying unweighted certificate. -/

/-- If every zero in a weighted certificate has multiplicity `1`, then the
weighted zero count agrees with the simple cardinality count. -/
theorem weightedZeroCountFromCertificate_eq_card_of_mult_one
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T)
    (hone : ÔêÇ s : Ôäé, s Ôêê W.zeros ÔåÆ W.mult s = 1) :
    weightedZeroCountFromCertificate W =
      zeroCountFromCertificate W.toZeroSetUpToHeight := by
  unfold weightedZeroCountFromCertificate
  unfold zeroCountFromCertificate
  show W.zeros.sum W.mult = W.zeros.card
  calc W.zeros.sum W.mult
      = W.zeros.sum (fun _ => 1) :=
        Finset.sum_congr rfl (fun s hs => hone s hs)
    _ = W.zeros.card := by simp

/-- If every zero in a weighted certificate has multiplicity `1`, then the
weighted fluctuation agrees with the simple fluctuation of the underlying
unweighted certificate. -/
theorem weightedFluctuationFromCertificate_eq_fluctuation_of_mult_one
    {T : ÔäØ} (W : WeightedZeroSetUpToHeight T)
    (hone : ÔêÇ s : Ôäé, s Ôêê W.zeros ÔåÆ W.mult s = 1) :
    weightedFluctuationFromCertificate W =
      fluctuationFromCertificate W.toZeroSetUpToHeight := by
  unfold weightedFluctuationFromCertificate
  unfold fluctuationFromCertificate
  rw [weightedZeroCountFromCertificate_eq_card_of_mult_one W hone]

/-! ### Monotonicity in the height parameter

Heightwise monotonicity of the zero predicate is structural: a zero
counted up to height `TÔéü` is also counted up to any larger height `TÔéé`.
The support of any certificate at the smaller height is therefore a
subset of the support of any certificate at the larger height. -/

/-- The zero predicate is monotone in the height parameter. -/
theorem isZetaZeroUpToHeight_mono
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé) {s : Ôäé}
    (hs : IsZetaZeroUpToHeight TÔéü s) :
    IsZetaZeroUpToHeight TÔéé s := by
  rcases hs with Ôƒ¿hzero, him_pos, him_leÔƒ®
  exact Ôƒ¿hzero, him_pos, le_trans him_le hTÔƒ®

/-- The finite support of a simple zero-set certificate is monotone in the
height parameter. -/
theorem zeroSet_subset_of_le
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (ZÔéü : ZeroSetUpToHeight TÔéü) (ZÔéé : ZeroSetUpToHeight TÔéé) :
    ZÔéü.zeros Ôèå ZÔéé.zeros := by
  intro s hs
  exact (ZÔéé.complete s).mpr
    (isZetaZeroUpToHeight_mono hT ((ZÔéü.complete s).mp hs))

/-- The finite support of a weighted zero-set certificate is monotone in
the height parameter. -/
theorem weightedZeroSet_subset_of_le
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (WÔéü : WeightedZeroSetUpToHeight TÔéü)
    (WÔéé : WeightedZeroSetUpToHeight TÔéé) :
    WÔéü.zeros Ôèå WÔéé.zeros := by
  intro s hs
  exact (WÔéé.complete s).mpr
    (isZetaZeroUpToHeight_mono hT ((WÔéü.complete s).mp hs))

/-! ### Monotonicity of zero counts

Support monotonicity gives `Finset.card` monotonicity for the simple
count.  For the weighted count we additionally need the multiplicities
to agree on the overlap ÔÇö packaged as the
`WeightedMultiplicityCompatible` predicate. -/

/-- The simple zero count is monotone in the height parameter. -/
theorem zeroCountFromCertificate_le_of_le
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (ZÔéü : ZeroSetUpToHeight TÔéü) (ZÔéé : ZeroSetUpToHeight TÔéé) :
    zeroCountFromCertificate ZÔéü Ôëñ zeroCountFromCertificate ZÔéé := by
  unfold zeroCountFromCertificate
  exact Finset.card_le_card (zeroSet_subset_of_le hT ZÔéü ZÔéé)

/-- Compatibility of weighted multiplicities when comparing two heights:
every zero counted at the lower height receives the same multiplicity in
both certificates. -/
def WeightedMultiplicityCompatible
    {TÔéü TÔéé : ÔäØ}
    (WÔéü : WeightedZeroSetUpToHeight TÔéü)
    (WÔéé : WeightedZeroSetUpToHeight TÔéé) : Prop :=
  ÔêÇ s : Ôäé, s Ôêê WÔéü.zeros ÔåÆ WÔéü.mult s = WÔéé.mult s

/-- The weighted zero count is monotone in the height parameter, provided
the multiplicities agree on the lower-height support. -/
theorem weightedZeroCountFromCertificate_le_of_le
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (WÔéü : WeightedZeroSetUpToHeight TÔéü)
    (WÔéé : WeightedZeroSetUpToHeight TÔéé)
    (hcompat : WeightedMultiplicityCompatible WÔéü WÔéé) :
    weightedZeroCountFromCertificate WÔéü Ôëñ
      weightedZeroCountFromCertificate WÔéé := by
  unfold weightedZeroCountFromCertificate
  calc
    WÔéü.zeros.sum WÔéü.mult = WÔéü.zeros.sum WÔéé.mult := by
      apply Finset.sum_congr rfl
      intro s hs
      exact hcompat s hs
    _ Ôëñ WÔéé.zeros.sum WÔéé.mult := by
      apply Finset.sum_le_sum_of_subset_of_nonneg
        (weightedZeroSet_subset_of_le hT WÔéü WÔéé)
      intro s _hsWÔéé _hsNotWÔéü
      exact Nat.zero_le (WÔéé.mult s)

/-! ### Equal-height weighted count and fluctuation comparison -/

/-- At the same height, compatible weighted certificates have equal
weighted zero counts. -/
theorem weightedZeroCountFromCertificate_eq_of_same_height_compatible
    {T : ÔäØ}
    (WÔéü WÔéé : WeightedZeroSetUpToHeight T)
    (hcompat : WeightedMultiplicityCompatible WÔéü WÔéé) :
    weightedZeroCountFromCertificate WÔéü =
      weightedZeroCountFromCertificate WÔéé := by
  apply le_antisymm
  ┬À exact weightedZeroCountFromCertificate_le_of_le
      (le_refl T) WÔéü WÔéé hcompat
  ┬À have hcompat' : WeightedMultiplicityCompatible WÔéé WÔéü := by
      intro s hs
      have hsÔéü : s Ôêê WÔéü.zeros := by
        rw [weightedZeroSet_zeros_unique WÔéé WÔéü] at hs
        exact hs
      exact (hcompat s hsÔéü).symm
    exact weightedZeroCountFromCertificate_le_of_le
      (le_refl T) WÔéé WÔéü hcompat'

/-- At the same height, compatible weighted certificates have equal
weighted fluctuations. -/
theorem weightedFluctuationFromCertificate_eq_of_same_height_compatible
    {T : ÔäØ}
    (WÔéü WÔéé : WeightedZeroSetUpToHeight T)
    (hcompat : WeightedMultiplicityCompatible WÔéü WÔéé) :
    weightedFluctuationFromCertificate WÔéü =
      weightedFluctuationFromCertificate WÔéé := by
  unfold weightedFluctuationFromCertificate
  rw [weightedZeroCountFromCertificate_eq_of_same_height_compatible
    WÔéü WÔéé hcompat]

/-! ### Global multiplicity models and height truncation

Bridge between abstract certificate multiplicities and a height-independent
global multiplicity function.  Eventually `M.mult` should be instantiated
as the analytic order of vanishing of `riemannZeta` at the point; this
layer does not assert that such an instantiation exists, only that *if*
it does, the resulting weighted certificates are automatically
compatible across heights. -/

/-- A global multiplicity model for nontrivial zeta zeros. -/
structure GlobalZeroMultiplicity where
  mult : Ôäé ÔåÆ Ôäò
  positive_of_isNontrivialZetaZero :
    ÔêÇ {s : Ôäé}, IsNontrivialZetaZero s ÔåÆ 0 < mult s

open Classical in
/-- The height-truncated multiplicity attached to a global model.  Points
not satisfying `IsZetaZeroUpToHeight T` receive multiplicity `0`. -/
noncomputable def truncatedMultiplicity
    (M : GlobalZeroMultiplicity) (T : ÔäØ) (s : Ôäé) : Ôäò :=
  if IsZetaZeroUpToHeight T s then M.mult s else 0

/-- On zeros up to height `T`, the truncated multiplicity equals the
global multiplicity. -/
theorem truncatedMultiplicity_eq_global
    (M : GlobalZeroMultiplicity) {T : ÔäØ} {s : Ôäé}
    (hs : IsZetaZeroUpToHeight T s) :
    truncatedMultiplicity M T s = M.mult s := by
  unfold truncatedMultiplicity
  exact if_pos hs

/-- Away from zeros up to height `T`, the truncated multiplicity is
zero. -/
theorem truncatedMultiplicity_eq_zero
    (M : GlobalZeroMultiplicity) {T : ÔäØ} {s : Ôäé}
    (hs : ┬¼ IsZetaZeroUpToHeight T s) :
    truncatedMultiplicity M T s = 0 := by
  unfold truncatedMultiplicity
  exact if_neg hs

/-- A simple zero-set certificate together with a global multiplicity
model gives a weighted zero-set certificate by truncation. -/
noncomputable def weightedZeroSetOfGlobalMultiplicity
    (M : GlobalZeroMultiplicity) {T : ÔäØ}
    (Z : ZeroSetUpToHeight T) :
    WeightedZeroSetUpToHeight T where
  zeros := Z.zeros
  mult := truncatedMultiplicity M T
  complete := Z.complete
  positive_on_zeros := by
    intro s hs
    have hsZero : IsZetaZeroUpToHeight T s := (Z.complete s).mp hs
    rw [truncatedMultiplicity_eq_global M hsZero]
    exact M.positive_of_isNontrivialZetaZero hsZero.1
  zero_off_zeros := by
    intro s hsNotMem
    apply truncatedMultiplicity_eq_zero
    intro hsZero
    exact hsNotMem ((Z.complete s).mpr hsZero)

/-- The weighted certificate built from a global multiplicity model has
the same finite support as the original simple certificate. -/
theorem weightedZeroSetOfGlobalMultiplicity_zeros
    (M : GlobalZeroMultiplicity) {T : ÔäØ}
    (Z : ZeroSetUpToHeight T) :
    (weightedZeroSetOfGlobalMultiplicity M Z).zeros = Z.zeros := rfl

/-- The weighted certificate built from a global multiplicity model has
the expected truncated multiplicity function. -/
theorem weightedZeroSetOfGlobalMultiplicity_mult
    (M : GlobalZeroMultiplicity) {T : ÔäØ}
    (Z : ZeroSetUpToHeight T) :
    (weightedZeroSetOfGlobalMultiplicity M Z).mult =
      truncatedMultiplicity M T := rfl

/-! ### Compatibility from global multiplicities

Height-truncated weighted certificates coming from the same global
multiplicity model are automatically compatible. -/

/-- Height-truncated weighted certificates from the same global model are
compatible whenever `TÔéü Ôëñ TÔéé`. -/
theorem weightedZeroSetOfGlobalMultiplicity_compatible_of_le
    (M : GlobalZeroMultiplicity)
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (ZÔéü : ZeroSetUpToHeight TÔéü)
    (ZÔéé : ZeroSetUpToHeight TÔéé) :
    WeightedMultiplicityCompatible
      (weightedZeroSetOfGlobalMultiplicity M ZÔéü)
      (weightedZeroSetOfGlobalMultiplicity M ZÔéé) := by
  intro s hs
  have hsÔéü : IsZetaZeroUpToHeight TÔéü s := (ZÔéü.complete s).mp hs
  have hsÔéé : IsZetaZeroUpToHeight TÔéé s :=
    isZetaZeroUpToHeight_mono hT hsÔéü
  change truncatedMultiplicity M TÔéü s = truncatedMultiplicity M TÔéé s
  rw [truncatedMultiplicity_eq_global M hsÔéü,
      truncatedMultiplicity_eq_global M hsÔéé]

/-- Weighted zero counts coming from the same global multiplicity model
are monotone in the height parameter. -/
theorem weightedZeroCountOfGlobalMultiplicity_le_of_le
    (M : GlobalZeroMultiplicity)
    {TÔéü TÔéé : ÔäØ} (hT : TÔéü Ôëñ TÔéé)
    (ZÔéü : ZeroSetUpToHeight TÔéü)
    (ZÔéé : ZeroSetUpToHeight TÔéé) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZÔéü)
      Ôëñ
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZÔéé) := by
  apply weightedZeroCountFromCertificate_le_of_le hT
  exact weightedZeroSetOfGlobalMultiplicity_compatible_of_le M hT ZÔéü ZÔéé

/-! ### Height-slab zero predicates and certificates

Turing's method needs counts over half-open slabs `(A, B]`, not just
cumulative counts.  We define the slab predicate and certificate and
prove that the slab count obtained by taking the set difference of two
cumulative certificates equals `N(B) ÔêÆ N(A)`. -/

/-- A nontrivial zeta zero whose imaginary part lies in the half-open
slab `A < Im(s) Ôëñ B`. -/
def IsZetaZeroInHeightSlab (A B : ÔäØ) (s : Ôäé) : Prop :=
  IsNontrivialZetaZero s Ôêº A < s.im Ôêº s.im Ôëñ B

/-- A finite zero-set certificate for the half-open height slab
`(A, B]`. -/
structure ZeroSetInHeightSlab (A B : ÔäØ) where
  zeros : Finset Ôäé
  complete :
    ÔêÇ s : Ôäé, s Ôêê zeros Ôåö IsZetaZeroInHeightSlab A B s

/-- The simple zero count in a certified height slab. -/
def zeroCountInHeightSlabFromCertificate
    {A B : ÔäØ} (Z : ZeroSetInHeightSlab A B) : Ôäò :=
  Z.zeros.card

/-- Membership in a completed slab certificate is exactly the slab
predicate. -/
theorem mem_zeroSetInHeightSlab_iff
    {A B : ÔäØ} (Z : ZeroSetInHeightSlab A B) (s : Ôäé) :
    s Ôêê Z.zeros Ôåö IsZetaZeroInHeightSlab A B s :=
  Z.complete s

/-- Any two completed slab certificates for the same slab have the same
finite set. -/
theorem zeroSetInHeightSlab_zeros_unique
    {A B : ÔäØ} (ZÔéü ZÔéé : ZeroSetInHeightSlab A B) :
    ZÔéü.zeros = ZÔéé.zeros := by
  ext s
  rw [ZÔéü.complete s, ZÔéé.complete s]

/-- The simple slab count is independent of the chosen slab
certificate. -/
theorem zeroCountInHeightSlabFromCertificate_eq
    {A B : ÔäØ} (ZÔéü ZÔéé : ZeroSetInHeightSlab A B) :
    zeroCountInHeightSlabFromCertificate ZÔéü =
      zeroCountInHeightSlabFromCertificate ZÔéé := by
  unfold zeroCountInHeightSlabFromCertificate
  rw [zeroSetInHeightSlab_zeros_unique ZÔéü ZÔéé]

/-! ### Weighted height-slab certificates -/

/-- A multiplicity-aware finite zero-set certificate for the height
slab `(A, B]`. -/
structure WeightedZeroSetInHeightSlab (A B : ÔäØ) where
  zeros : Finset Ôäé
  mult : Ôäé ÔåÆ Ôäò
  complete :
    ÔêÇ s : Ôäé, s Ôêê zeros Ôåö IsZetaZeroInHeightSlab A B s
  positive_on_zeros :
    ÔêÇ s : Ôäé, s Ôêê zeros ÔåÆ 0 < mult s
  zero_off_zeros :
    ÔêÇ s : Ôäé, s Ôêë zeros ÔåÆ mult s = 0

/-- Forget multiplicities from a weighted slab certificate. -/
def WeightedZeroSetInHeightSlab.toZeroSetInHeightSlab
    {A B : ÔäØ} (W : WeightedZeroSetInHeightSlab A B) :
    ZeroSetInHeightSlab A B where
  zeros := W.zeros
  complete := W.complete

/-- The weighted zero count in a certified height slab. -/
def weightedZeroCountInHeightSlabFromCertificate
    {A B : ÔäØ} (W : WeightedZeroSetInHeightSlab A B) : Ôäò :=
  W.zeros.sum W.mult

/-- Any two weighted slab certificates for the same slab have the same
finite support. -/
theorem weightedZeroSetInHeightSlab_zeros_unique
    {A B : ÔäØ} (WÔéü WÔéé : WeightedZeroSetInHeightSlab A B) :
    WÔéü.zeros = WÔéé.zeros := by
  ext s
  rw [WÔéü.complete s, WÔéé.complete s]

/-! ### Building slab certificates from cumulative height certificates

For `0 Ôëñ A Ôëñ B`, the slab certificate `(A, B]` is `ZB.zeros \ ZA.zeros`,
giving the count formula

  `#zeros in (A, B] = N(B) ÔêÆ N(A)`. -/

/-- If `0 Ôëñ A Ôëñ B`, the set difference `ZB.zeros \ ZA.zeros` is exactly
the set of nontrivial zeros in the slab `(A, B]`. -/
noncomputable def zeroSetInHeightSlabOfDifference
    {A B : ÔäØ} (hA_nonneg : 0 Ôëñ A) (_hAB : A Ôëñ B)
    (ZA : ZeroSetUpToHeight A) (ZB : ZeroSetUpToHeight B) :
    ZeroSetInHeightSlab A B where
  zeros := ZB.zeros \ ZA.zeros
  complete := by
    intro s
    constructor
    ┬À intro hs
      rw [Finset.mem_sdiff] at hs
      obtain Ôƒ¿hsB, hsNotAÔƒ® := hs
      have hB : IsZetaZeroUpToHeight B s := (ZB.complete s).mp hsB
      have hnotA : ┬¼ IsZetaZeroUpToHeight A s := by
        intro hA
        exact hsNotA ((ZA.complete s).mpr hA)
      rcases hB with Ôƒ¿hzero, him_pos, him_le_BÔƒ®
      have hA_lt : A < s.im := by
        by_contra hnot
        have him_le_A : s.im Ôëñ A := le_of_not_gt hnot
        exact hnotA Ôƒ¿hzero, him_pos, him_le_AÔƒ®
      exact Ôƒ¿hzero, hA_lt, him_le_BÔƒ®
    ┬À intro hs
      rcases hs with Ôƒ¿hzero, hA_lt, him_le_BÔƒ®
      apply Finset.mem_sdiff.mpr
      refine Ôƒ¿?_, ?_Ôƒ®
      ┬À have him_pos : 0 < s.im := lt_of_le_of_lt hA_nonneg hA_lt
        exact (ZB.complete s).mpr Ôƒ¿hzero, him_pos, him_le_BÔƒ®
      ┬À intro hsA
        have hA : IsZetaZeroUpToHeight A s := (ZA.complete s).mp hsA
        exact (not_le_of_gt hA_lt) hA.2.2

/-- For `0 Ôëñ A Ôëñ B`, the simple slab count obtained as `ZB.zeros \ ZA.zeros`
equals `N(B) ÔêÆ N(A)` at the certificate level. -/
theorem zeroCountInHeightSlabOfDifference_eq_sub
    {A B : ÔäØ} (hA_nonneg : 0 Ôëñ A) (hAB : A Ôëñ B)
    (ZA : ZeroSetUpToHeight A) (ZB : ZeroSetUpToHeight B) :
    zeroCountInHeightSlabFromCertificate
        (zeroSetInHeightSlabOfDifference hA_nonneg hAB ZA ZB)
      =
    zeroCountFromCertificate ZB - zeroCountFromCertificate ZA := by
  change (ZB.zeros \ ZA.zeros).card = ZB.zeros.card - ZA.zeros.card
  exact Finset.card_sdiff (zeroSet_subset_of_le hAB ZA ZB)

/-! ### Weighted slab certificates from cumulative certificates

Multiplicity-aware analogue of `zeroSetInHeightSlabOfDifference`.  The
slab support is `ZB.zeros \ ZA.zeros` and the slab multiplicity is the
global multiplicity truncated to the slab predicate. -/

open Classical in
/-- Build a weighted slab certificate from two cumulative simple
certificates and a global multiplicity model. -/
noncomputable def weightedZeroSetInHeightSlabOfDifference
    (M : GlobalZeroMultiplicity)
    {A B : ÔäØ} (hA_nonneg : 0 Ôëñ A) (_hAB : A Ôëñ B)
    (ZA : ZeroSetUpToHeight A) (ZB : ZeroSetUpToHeight B) :
    WeightedZeroSetInHeightSlab A B where
  zeros := ZB.zeros \ ZA.zeros
  mult := fun s =>
    if IsZetaZeroInHeightSlab A B s then M.mult s else 0
  complete :=
    (zeroSetInHeightSlabOfDifference hA_nonneg _hAB ZA ZB).complete
  positive_on_zeros := by
    intro s hs
    have hsSlab : IsZetaZeroInHeightSlab A B s :=
      ((zeroSetInHeightSlabOfDifference hA_nonneg _hAB ZA ZB).complete s).mp hs
    show 0 < (if IsZetaZeroInHeightSlab A B s then M.mult s else 0)
    rw [if_pos hsSlab]
    exact M.positive_of_isNontrivialZetaZero hsSlab.1
  zero_off_zeros := by
    intro s hsNot
    have hsNotSlab : ┬¼ IsZetaZeroInHeightSlab A B s := by
      intro hsSlab
      exact hsNot
        (((zeroSetInHeightSlabOfDifference hA_nonneg _hAB ZA ZB).complete s).mpr
          hsSlab)
    show (if IsZetaZeroInHeightSlab A B s then M.mult s else 0) = 0
    exact if_neg hsNotSlab

/-- For `0 Ôëñ A Ôëñ B`, the weighted slab count built from cumulative
certificates and a global multiplicity model equals the difference of
the weighted cumulative counts:

  `N_M(B) ÔêÆ N_M(A) = #_M { zeros with A < Im(s) Ôëñ B }`. -/
theorem weightedZeroCountInHeightSlabOfDifference_eq_sub
    (M : GlobalZeroMultiplicity)
    {A B : ÔäØ} (hA_nonneg : 0 Ôëñ A) (hAB : A Ôëñ B)
    (ZA : ZeroSetUpToHeight A) (ZB : ZeroSetUpToHeight B) :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference M hA_nonneg hAB ZA ZB)
      =
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZB)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZA) := by
  classical
  have hsubset : ZA.zeros Ôèå ZB.zeros := zeroSet_subset_of_le hAB ZA ZB
  -- On the slab support, the slab multiplicity agrees with the
  -- height-truncated multiplicity at `B`.
  have hslab_eq_B :
      (ZB.zeros \ ZA.zeros).sum
          (weightedZeroSetInHeightSlabOfDifference M hA_nonneg hAB ZA ZB).mult
        =
      (ZB.zeros \ ZA.zeros).sum (truncatedMultiplicity M B) := by
    apply Finset.sum_congr rfl
    intro s hs
    have hslab : IsZetaZeroInHeightSlab A B s :=
      ((weightedZeroSetInHeightSlabOfDifference M hA_nonneg hAB ZA ZB).complete s).mp
        hs
    rcases hslab with Ôƒ¿hzero, hA_lt, him_le_BÔƒ®
    have him_pos : 0 < s.im := lt_of_le_of_lt hA_nonneg hA_lt
    have hsB : IsZetaZeroUpToHeight B s := Ôƒ¿hzero, him_pos, him_le_BÔƒ®
    show (if IsZetaZeroInHeightSlab A B s then M.mult s else 0)
         = truncatedMultiplicity M B s
    rw [if_pos Ôƒ¿hzero, hA_lt, him_le_BÔƒ®,
        truncatedMultiplicity_eq_global M hsB]
  -- On `ZA.zeros`, the height-truncated multiplicities at `A` and `B`
  -- agree (every zero up to `A` is also a zero up to `B`).
  have hA_eq_B_on_ZA :
      ZA.zeros.sum (truncatedMultiplicity M A)
        =
      ZA.zeros.sum (truncatedMultiplicity M B) := by
    apply Finset.sum_congr rfl
    intro s hs
    have hsA : IsZetaZeroUpToHeight A s := (ZA.complete s).mp hs
    have hsB : IsZetaZeroUpToHeight B s := isZetaZeroUpToHeight_mono hAB hsA
    rw [truncatedMultiplicity_eq_global M hsA,
        truncatedMultiplicity_eq_global M hsB]
  -- The Finset additivity identity on `ZA Ôèå ZB`.
  have hadd :
      (ZB.zeros \ ZA.zeros).sum (truncatedMultiplicity M B)
      + ZA.zeros.sum (truncatedMultiplicity M B)
        =
      ZB.zeros.sum (truncatedMultiplicity M B) :=
    Finset.sum_sdiff hsubset
  -- Reduce the original goal to a pure Ôäò-arithmetic statement.
  show (ZB.zeros \ ZA.zeros).sum
        (weightedZeroSetInHeightSlabOfDifference M hA_nonneg hAB ZA ZB).mult
      =
      ZB.zeros.sum (truncatedMultiplicity M B)
      - ZA.zeros.sum (truncatedMultiplicity M A)
  rw [hslab_eq_B, hA_eq_B_on_ZA]
  omega

/-! ### Turing interval certificates

Packaging of the data needed to assert that the weighted number of
nontrivial zeta zeros in `(A, B]` equals a stated natural number.  Does
not yet prove how the count was obtained; that is the analytic Turing
content. -/

/-- A structural certificate for the weighted zero count in a half-open
Turing interval `(A, B]`. -/
structure TuringIntervalCertificate where
  A : ÔäØ
  B : ÔäØ
  hA_nonneg : 0 Ôëñ A
  hAB : A Ôëñ B
  ZA : ZeroSetUpToHeight A
  ZB : ZeroSetUpToHeight B
  M : GlobalZeroMultiplicity
  certifiedCount : Ôäò
  count_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference M hA_nonneg hAB ZA ZB)
      =
    certifiedCount

/-- The weighted slab certificate underlying a `TuringIntervalCertificate`. -/
noncomputable def TuringIntervalCertificate.weightedSlab
    (C : TuringIntervalCertificate) :
    WeightedZeroSetInHeightSlab C.A C.B :=
  weightedZeroSetInHeightSlabOfDifference
    C.M C.hA_nonneg C.hAB C.ZA C.ZB

/-- The simple slab certificate underlying a `TuringIntervalCertificate`. -/
noncomputable def TuringIntervalCertificate.simpleSlab
    (C : TuringIntervalCertificate) :
    ZeroSetInHeightSlab C.A C.B :=
  C.weightedSlab.toZeroSetInHeightSlab

/-- The weighted zero count of the slab underlying a Turing interval
certificate is the certificate's stated count. -/
theorem TuringIntervalCertificate.weightedSlab_count_eq
    (C : TuringIntervalCertificate) :
    weightedZeroCountInHeightSlabFromCertificate C.weightedSlab =
      C.certifiedCount :=
  C.count_eq

/-- The cumulative weighted count difference across the interval equals
the certificate's stated count. -/
theorem TuringIntervalCertificate.cumulative_count_sub_eq
    (C : TuringIntervalCertificate) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity C.M C.ZB)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity C.M C.ZA)
      =
    C.certifiedCount := by
  rw [ÔåÉ C.count_eq]
  exact
    (weightedZeroCountInHeightSlabOfDifference_eq_sub
      C.M C.hA_nonneg C.hAB C.ZA C.ZB).symm

/-- If a Turing interval certificate has certified count zero, then the
weighted slab count is zero. -/
theorem TuringIntervalCertificate.weightedSlab_count_eq_zero
    (C : TuringIntervalCertificate)
    (hC : C.certifiedCount = 0) :
    weightedZeroCountInHeightSlabFromCertificate C.weightedSlab = 0 := by
  rw [C.weightedSlab_count_eq, hC]

/-- If a Turing interval certificate has certified count zero, then no
point can belong to its weighted slab support. -/
theorem TuringIntervalCertificate.not_mem_weightedSlab_of_count_zero
    (C : TuringIntervalCertificate)
    (hC : C.certifiedCount = 0)
    {s : Ôäé} :
    s Ôêë C.weightedSlab.zeros := by
  intro hs
  have hsum_zero :
      weightedZeroCountInHeightSlabFromCertificate C.weightedSlab = 0 :=
    C.weightedSlab_count_eq_zero hC
  unfold weightedZeroCountInHeightSlabFromCertificate at hsum_zero
  have hpos : 0 < C.weightedSlab.mult s :=
    C.weightedSlab.positive_on_zeros s hs
  have hle :
      C.weightedSlab.mult s
        Ôëñ C.weightedSlab.zeros.sum C.weightedSlab.mult :=
    Finset.single_le_sum
      (f := C.weightedSlab.mult)
      (fun x _ => Nat.zero_le (C.weightedSlab.mult x))
      hs
  rw [hsum_zero] at hle
  exact Nat.not_lt_zero _ (lt_of_lt_of_le hpos hle)

/-- If a Turing interval certificate has certified count zero, then no
nontrivial zeta zero lies in the slab `(A, B]`. -/
theorem TuringIntervalCertificate.not_isZetaZeroInHeightSlab_of_count_zero
    (C : TuringIntervalCertificate)
    (hC : C.certifiedCount = 0)
    (s : Ôäé) :
    ┬¼ IsZetaZeroInHeightSlab C.A C.B s := by
  intro hs
  have hmem : s Ôêê C.weightedSlab.zeros :=
    (C.weightedSlab.complete s).mpr hs
  exact C.not_mem_weightedSlab_of_count_zero hC hmem

/-! ### Listed Turing interval certificates

Bridge between an abstract Turing interval count and an explicit finite
zero table.  `listedZeros_eq_support` says the table is exactly the
weighted slab's support ÔÇö so the underlying count, slab membership, and
the zero-in-slab predicate all coincide with the table. -/

/-- A Turing interval certificate equipped with an explicit finite list
of zeros, certified to coincide with the weighted slab support. -/
structure ListedTuringIntervalCertificate extends TuringIntervalCertificate where
  listedZeros : Finset Ôäé
  listedZeros_eq_support :
    listedZeros = toTuringIntervalCertificate.weightedSlab.zeros

/-- The listed zeros are exactly the weighted slab support. -/
theorem ListedTuringIntervalCertificate.listedZeros_eq_weightedSlab_zeros
    (C : ListedTuringIntervalCertificate) :
    C.listedZeros = C.toTuringIntervalCertificate.weightedSlab.zeros :=
  C.listedZeros_eq_support

/-- Every listed zero lies in the weighted slab support. -/
theorem ListedTuringIntervalCertificate.listedZeros_subset_weightedSlab
    (C : ListedTuringIntervalCertificate) :
    C.listedZeros Ôèå C.toTuringIntervalCertificate.weightedSlab.zeros := by
  intro s hs
  rw [C.listedZeros_eq_support] at hs
  exact hs

/-- Every weighted-slab zero is listed. -/
theorem ListedTuringIntervalCertificate.weightedSlab_subset_listedZeros
    (C : ListedTuringIntervalCertificate) :
    C.toTuringIntervalCertificate.weightedSlab.zeros Ôèå C.listedZeros := by
  intro s hs
  rw [C.listedZeros_eq_support]
  exact hs

/-- Membership in the listed zero table is equivalent to membership in
the weighted slab support. -/
theorem ListedTuringIntervalCertificate.mem_listedZeros_iff_mem_weightedSlab
    (C : ListedTuringIntervalCertificate) (s : Ôäé) :
    s Ôêê C.listedZeros Ôåö
      s Ôêê C.toTuringIntervalCertificate.weightedSlab.zeros := by
  constructor
  ┬À exact fun hs => C.listedZeros_subset_weightedSlab hs
  ┬À exact fun hs => C.weightedSlab_subset_listedZeros hs

/-- Membership in the listed zero table is equivalent to being a
nontrivial zeta zero in the interval slab. -/
theorem ListedTuringIntervalCertificate.mem_listedZeros_iff_isZetaZeroInHeightSlab
    (C : ListedTuringIntervalCertificate) (s : Ôäé) :
    s Ôêê C.listedZeros Ôåö IsZetaZeroInHeightSlab C.A C.B s := by
  rw [C.mem_listedZeros_iff_mem_weightedSlab]
  exact C.toTuringIntervalCertificate.weightedSlab.complete s

/-- The listed zero table has the same cardinality as the weighted slab
support. -/
theorem ListedTuringIntervalCertificate.listedZeros_card_eq_support_card
    (C : ListedTuringIntervalCertificate) :
    C.listedZeros.card =
      C.toTuringIntervalCertificate.weightedSlab.zeros.card := by
  rw [C.listedZeros_eq_support]

/-- If all multiplicities in the interval are one, then the listed zero
table has cardinality equal to the certified count. -/
theorem
    ListedTuringIntervalCertificate.listedZeros_card_eq_certifiedCount_of_mult_one
    (C : ListedTuringIntervalCertificate)
    (hone :
      ÔêÇ s : Ôäé,
        s Ôêê C.toTuringIntervalCertificate.weightedSlab.zeros ÔåÆ
          C.toTuringIntervalCertificate.weightedSlab.mult s = 1) :
    C.listedZeros.card = C.certifiedCount := by
  rw [C.listedZeros_card_eq_support_card]
  have hweighted_eq_card :
      weightedZeroCountInHeightSlabFromCertificate
          C.toTuringIntervalCertificate.weightedSlab
        =
      C.toTuringIntervalCertificate.weightedSlab.zeros.card := by
    unfold weightedZeroCountInHeightSlabFromCertificate
    calc
      C.toTuringIntervalCertificate.weightedSlab.zeros.sum
          C.toTuringIntervalCertificate.weightedSlab.mult
          =
        C.toTuringIntervalCertificate.weightedSlab.zeros.sum
          (fun _ => 1) := by
            apply Finset.sum_congr rfl
            intro s hs
            exact hone s hs
      _ = C.toTuringIntervalCertificate.weightedSlab.zeros.card := by simp
  rw [ÔåÉ hweighted_eq_card]
  exact C.toTuringIntervalCertificate.weightedSlab_count_eq

/-- If a listed Turing interval has certified count zero, then its listed
zero table is empty. -/
theorem
    ListedTuringIntervalCertificate.listedZeros_eq_empty_of_certifiedCount_zero
    (C : ListedTuringIntervalCertificate)
    (hC : C.certifiedCount = 0) :
    C.listedZeros = Ôêà := by
  apply Finset.eq_empty_iff_forall_notMem.mpr
  intro s hs
  have hmem :
      s Ôêê C.toTuringIntervalCertificate.weightedSlab.zeros :=
    (C.mem_listedZeros_iff_mem_weightedSlab s).mp hs
  exact
    C.toTuringIntervalCertificate.not_mem_weightedSlab_of_count_zero hC hmem

/-! ### Adjacent slab gluing

`(A, B] + (B, C] = (A, C]`.  The half-open convention makes the two
pieces disjoint at `B`, and gluing is a structural operation independent
of any analytic Turing estimate. -/

/-- A zero lies in `(A, C]` iff it lies in `(A, B]` or `(B, C]`, provided
`A Ôëñ B Ôëñ C`. -/
theorem isZetaZeroInHeightSlab_union_adjacent
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C) (s : Ôäé) :
    IsZetaZeroInHeightSlab A C s Ôåö
      IsZetaZeroInHeightSlab A B s Ôê¿ IsZetaZeroInHeightSlab B C s := by
  constructor
  ┬À intro hs
    rcases hs with Ôƒ¿hzero, hA_lt, him_le_CÔƒ®
    by_cases hleB : s.im Ôëñ B
    ┬À left
      exact Ôƒ¿hzero, hA_lt, hleBÔƒ®
    ┬À right
      have hB_lt : B < s.im := lt_of_not_ge hleB
      exact Ôƒ¿hzero, hB_lt, him_le_CÔƒ®
  ┬À intro hs
    rcases hs with hs | hs
    ┬À rcases hs with Ôƒ¿hzero, hA_lt, him_le_BÔƒ®
      exact Ôƒ¿hzero, hA_lt, le_trans him_le_B hBCÔƒ®
    ┬À rcases hs with Ôƒ¿hzero, hB_lt, him_le_CÔƒ®
      have hA_lt : A < s.im := lt_of_le_of_lt hAB hB_lt
      exact Ôƒ¿hzero, hA_lt, him_le_CÔƒ®

/-- Adjacent half-open slabs `(A, B]` and `(B, C]` are disjoint at the
predicate level. -/
theorem disjoint_isZetaZeroInHeightSlab_adjacent
    {A B C : ÔäØ} {s : Ôäé} :
    ┬¼ (IsZetaZeroInHeightSlab A B s Ôêº
        IsZetaZeroInHeightSlab B C s) := by
  intro h
  rcases h with Ôƒ¿hABslab, hBCslabÔƒ®
  exact (not_lt_of_ge hABslab.2.2) hBCslab.2.1

/-- Glue adjacent simple slab certificates into a certificate for the
larger slab `(A, C]`. -/
noncomputable def zeroSetInHeightSlabGlueAdjacent
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C)
    (ZAB : ZeroSetInHeightSlab A B)
    (ZBC : ZeroSetInHeightSlab B C) :
    ZeroSetInHeightSlab A C where
  zeros := ZAB.zeros Ôê¬ ZBC.zeros
  complete := by
    intro s
    constructor
    ┬À intro hs
      rw [Finset.mem_union] at hs
      rcases hs with hsAB | hsBC
      ┬À have hABslab : IsZetaZeroInHeightSlab A B s :=
          (ZAB.complete s).mp hsAB
        exact (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
          (Or.inl hABslab)
      ┬À have hBCslab : IsZetaZeroInHeightSlab B C s :=
          (ZBC.complete s).mp hsBC
        exact (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
          (Or.inr hBCslab)
    ┬À intro hs
      have hsplit :
          IsZetaZeroInHeightSlab A B s Ôê¿ IsZetaZeroInHeightSlab B C s :=
        (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mp hs
      rw [Finset.mem_union]
      rcases hsplit with hsAB | hsBC
      ┬À exact Or.inl ((ZAB.complete s).mpr hsAB)
      ┬À exact Or.inr ((ZBC.complete s).mpr hsBC)

/-- The supports of adjacent simple slab certificates are disjoint. -/
theorem disjoint_zeroSetInHeightSlab_adjacent
    {A B C : ÔäØ}
    (ZAB : ZeroSetInHeightSlab A B)
    (ZBC : ZeroSetInHeightSlab B C) :
    Disjoint ZAB.zeros ZBC.zeros := by
  rw [Finset.disjoint_left]
  intro s hsAB hsBC
  have hABslab : IsZetaZeroInHeightSlab A B s :=
    (ZAB.complete s).mp hsAB
  have hBCslab : IsZetaZeroInHeightSlab B C s :=
    (ZBC.complete s).mp hsBC
  exact disjoint_isZetaZeroInHeightSlab_adjacent Ôƒ¿hABslab, hBCslabÔƒ®

/-- The simple count of glued adjacent slabs is the sum of the simple
counts. -/
theorem zeroCountInHeightSlabGlueAdjacent_eq_add
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C)
    (ZAB : ZeroSetInHeightSlab A B)
    (ZBC : ZeroSetInHeightSlab B C) :
    zeroCountInHeightSlabFromCertificate
        (zeroSetInHeightSlabGlueAdjacent hAB hBC ZAB ZBC)
      =
    zeroCountInHeightSlabFromCertificate ZAB +
      zeroCountInHeightSlabFromCertificate ZBC := by
  change (ZAB.zeros Ôê¬ ZBC.zeros).card = ZAB.zeros.card + ZBC.zeros.card
  exact Finset.card_union_of_disjoint
    (disjoint_zeroSetInHeightSlab_adjacent ZAB ZBC)

/-! ### Weighted adjacent slab gluing

Both component multiplicity functions are required to agree with a
common global multiplicity model on their respective supports.  The
glued certificate re-derives its multiplicity from that global model so
that the gluing operation is associative-ready. -/

open Classical in
/-- Glue adjacent weighted slab certificates into a larger weighted
slab certificate.  Both component multiplicities must agree with the
common global model `M` on their supports. -/
noncomputable def weightedZeroSetInHeightSlabGlueAdjacent
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C)
    (WAB : WeightedZeroSetInHeightSlab A B)
    (WBC : WeightedZeroSetInHeightSlab B C)
    (_hWAB : ÔêÇ s : Ôäé, s Ôêê WAB.zeros ÔåÆ WAB.mult s = M.mult s)
    (_hWBC : ÔêÇ s : Ôäé, s Ôêê WBC.zeros ÔåÆ WBC.mult s = M.mult s) :
    WeightedZeroSetInHeightSlab A C where
  zeros := WAB.zeros Ôê¬ WBC.zeros
  mult := fun s =>
    if IsZetaZeroInHeightSlab A C s then M.mult s else 0
  complete := by
    intro s
    constructor
    ┬À intro hs
      rw [Finset.mem_union] at hs
      rcases hs with hsAB | hsBC
      ┬À have hABslab : IsZetaZeroInHeightSlab A B s :=
          (WAB.complete s).mp hsAB
        exact (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
          (Or.inl hABslab)
      ┬À have hBCslab : IsZetaZeroInHeightSlab B C s :=
          (WBC.complete s).mp hsBC
        exact (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
          (Or.inr hBCslab)
    ┬À intro hs
      have hsplit :
          IsZetaZeroInHeightSlab A B s Ôê¿ IsZetaZeroInHeightSlab B C s :=
        (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mp hs
      rw [Finset.mem_union]
      rcases hsplit with hsAB | hsBC
      ┬À exact Or.inl ((WAB.complete s).mpr hsAB)
      ┬À exact Or.inr ((WBC.complete s).mpr hsBC)
  positive_on_zeros := by
    intro s hs
    have hsSlab : IsZetaZeroInHeightSlab A C s :=
      ((zeroSetInHeightSlabGlueAdjacent hAB hBC
          WAB.toZeroSetInHeightSlab WBC.toZeroSetInHeightSlab).complete s).mp hs
    show 0 < (if IsZetaZeroInHeightSlab A C s then M.mult s else 0)
    rw [if_pos hsSlab]
    exact M.positive_of_isNontrivialZetaZero hsSlab.1
  zero_off_zeros := by
    intro s hsNot
    have hsNotSlab : ┬¼ IsZetaZeroInHeightSlab A C s := by
      intro hsSlab
      exact hsNot
        (((zeroSetInHeightSlabGlueAdjacent hAB hBC
            WAB.toZeroSetInHeightSlab
            WBC.toZeroSetInHeightSlab).complete s).mpr hsSlab)
    show (if IsZetaZeroInHeightSlab A C s then M.mult s else 0) = 0
    exact if_neg hsNotSlab

/-- The weighted count of glued adjacent slabs is the sum of the
component weighted counts, provided both components agree with the
common global multiplicity model on their supports. -/
theorem weightedZeroCountInHeightSlabGlueAdjacent_eq_add
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C)
    (WAB : WeightedZeroSetInHeightSlab A B)
    (WBC : WeightedZeroSetInHeightSlab B C)
    (hWAB : ÔêÇ s : Ôäé, s Ôêê WAB.zeros ÔåÆ WAB.mult s = M.mult s)
    (hWBC : ÔêÇ s : Ôäé, s Ôêê WBC.zeros ÔåÆ WBC.mult s = M.mult s) :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabGlueAdjacent
          M hAB hBC WAB WBC hWAB hWBC)
      =
    weightedZeroCountInHeightSlabFromCertificate WAB +
      weightedZeroCountInHeightSlabFromCertificate WBC := by
  classical
  have hdisj : Disjoint WAB.zeros WBC.zeros :=
    disjoint_zeroSetInHeightSlab_adjacent
      WAB.toZeroSetInHeightSlab
      WBC.toZeroSetInHeightSlab
  show (WAB.zeros Ôê¬ WBC.zeros).sum
        (fun s => if IsZetaZeroInHeightSlab A C s then M.mult s else 0)
      =
      WAB.zeros.sum WAB.mult + WBC.zeros.sum WBC.mult
  rw [Finset.sum_union hdisj]
  have hAB_sum :
      WAB.zeros.sum
          (fun s =>
            if IsZetaZeroInHeightSlab A C s then M.mult s else 0)
        = WAB.zeros.sum WAB.mult := by
    apply Finset.sum_congr rfl
    intro s hs
    have hABslab : IsZetaZeroInHeightSlab A B s := (WAB.complete s).mp hs
    have hACslab : IsZetaZeroInHeightSlab A C s :=
      (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr (Or.inl hABslab)
    rw [if_pos hACslab, ÔåÉ hWAB s hs]
  have hBC_sum :
      WBC.zeros.sum
          (fun s =>
            if IsZetaZeroInHeightSlab A C s then M.mult s else 0)
        = WBC.zeros.sum WBC.mult := by
    apply Finset.sum_congr rfl
    intro s hs
    have hBCslab : IsZetaZeroInHeightSlab B C s := (WBC.complete s).mp hs
    have hACslab : IsZetaZeroInHeightSlab A C s :=
      (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr (Or.inr hBCslab)
    rw [if_pos hACslab, ÔåÉ hWBC s hs]
  rw [hAB_sum, hBC_sum]

/-! ### Count arithmetic for adjacent Turing interval certificates

Arithmetic prep for gluing two adjacent Turing interval certificates.
We isolate the pure Ôäò-subtraction identity and the cumulative-count
gluing theorem.  Avoiding dependent-record / `HEq` rewriting keeps the
proofs safe; the actual `TuringIntervalCertificate.glueAdjacent`
constructor will be built on top of these once the surrounding shape
is settled. -/

/-- For monotone Ôäò-valued cumulative counts `NA Ôëñ NB Ôëñ NC`, if the
adjacent differences are `kAB` and `kBC`, then the outer difference is
`kAB + kBC`. -/
theorem nat_sub_glue_adjacent
    {NA NB NC kAB kBC : Ôäò}
    (hNA_NB : NA Ôëñ NB)
    (hNB_NC : NB Ôëñ NC)
    (hAB : NB - NA = kAB)
    (hBC : NC - NB = kBC) :
    NC - NA = kAB + kBC := by
  omega

/-- Cumulative weighted counts glue over adjacent height intervals.  The
outer count difference decomposes as the sum of the two adjacent count
differences. -/
theorem weighted_cumulative_count_glue_adjacent
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ} (hAB : A Ôëñ B) (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZC)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZA)
      =
    (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZB)
      -
     weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZA))
    +
    (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZC)
      -
     weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZB)) := by
  have hNA_NB :
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZA)
        Ôëñ
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZB) :=
    weightedZeroCountOfGlobalMultiplicity_le_of_le M hAB ZA ZB
  have hNB_NC :
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZB)
        Ôëñ
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZC) :=
    weightedZeroCountOfGlobalMultiplicity_le_of_le M hBC ZB ZC
  omega

/-! ### Explicit gluing constructor for Turing interval certificates

Avoids dependent-record rewriting by working with the raw cumulative
data `A Ôëñ B Ôëñ C`, `ZA, ZB, ZC` plus certified adjacent slab counts. -/

/-- Glue two adjacent certified Turing intervals at the raw-data level
into a certificate for `(A, C]` with count `certAB + certBC`. -/
noncomputable def TuringIntervalCertificate.glueAdjacentExplicit
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC) :
    TuringIntervalCertificate where
  A := A
  B := C
  hA_nonneg := hA_nonneg
  hAB := le_trans hAB hBC
  ZA := ZA
  ZB := ZC
  M := M
  certifiedCount := certAB + certBC
  count_eq := by
    have hOuterDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M hA_nonneg (le_trans hAB hBC) ZA ZC)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M hA_nonneg (le_trans hAB hBC) ZA ZC
    have hABDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M hA_nonneg hAB ZA ZB)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M hA_nonneg hAB ZA ZB
    have hBCDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M (le_trans hA_nonneg hAB) hBC ZB ZC)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M (le_trans hA_nonneg hAB) hBC ZB ZC
    have hABSub :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA)
          =
        certAB := by
      rw [ÔåÉ hABDiff]
      exact hCountAB
    have hBCSub :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          =
        certBC := by
      rw [ÔåÉ hBCDiff]
      exact hCountBC
    have hGlue :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA)
          =
        (weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
         weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA))
        +
        (weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
         weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)) :=
      weighted_cumulative_count_glue_adjacent M hAB hBC ZA ZB ZC
    rw [hOuterDiff, hGlue, hABSub, hBCSub]

/-- The explicit gluing constructor has the expected certified count. -/
theorem TuringIntervalCertificate.glueAdjacentExplicit_certifiedCount
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC) :
    (TuringIntervalCertificate.glueAdjacentExplicit
      M hA_nonneg hAB hBC ZA ZB ZC
      certAB certBC hCountAB hCountBC).certifiedCount
      =
    certAB + certBC := rfl

/-! ### Listed Turing interval certificate gluing -/

/-- Glue two adjacent listed zero tables into a listed certificate for
the outer interval `(A, C]`.  The resulting listed table is the union of
the two component listed tables. -/
noncomputable def ListedTuringIntervalCertificate.glueAdjacentExplicit
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC)
    (listedAB : Finset Ôäé)
    (listedBC : Finset Ôäé)
    (hlistedAB :
      listedAB =
        (weightedZeroSetInHeightSlabOfDifference
          M hA_nonneg hAB ZA ZB).zeros)
    (hlistedBC :
      listedBC =
        (weightedZeroSetInHeightSlabOfDifference
          M (le_trans hA_nonneg hAB) hBC ZB ZC).zeros) :
    ListedTuringIntervalCertificate where
  toTuringIntervalCertificate :=
    TuringIntervalCertificate.glueAdjacentExplicit
      M hA_nonneg hAB hBC ZA ZB ZC
      certAB certBC hCountAB hCountBC
  listedZeros := listedAB Ôê¬ listedBC
  listedZeros_eq_support := by
    apply Finset.ext
    intro s
    constructor
    ┬À intro hs
      rw [Finset.mem_union] at hs
      rcases hs with hsAB | hsBC
      ┬À have hsABsupport :
            s Ôêê
              (weightedZeroSetInHeightSlabOfDifference
                M hA_nonneg hAB ZA ZB).zeros := by
          rw [ÔåÉ hlistedAB]; exact hsAB
        have hsABslab : IsZetaZeroInHeightSlab A B s :=
          ((weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB).complete s).mp hsABsupport
        have hsOuter : IsZetaZeroInHeightSlab A C s :=
          (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
            (Or.inl hsABslab)
        exact
          ((TuringIntervalCertificate.glueAdjacentExplicit
            M hA_nonneg hAB hBC ZA ZB ZC
            certAB certBC hCountAB hCountBC).weightedSlab.complete s).mpr
            hsOuter
      ┬À have hsBCsupport :
            s Ôêê
              (weightedZeroSetInHeightSlabOfDifference
                M (le_trans hA_nonneg hAB) hBC ZB ZC).zeros := by
          rw [ÔåÉ hlistedBC]; exact hsBC
        have hsBCslab : IsZetaZeroInHeightSlab B C s :=
          ((weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC).complete s).mp hsBCsupport
        have hsOuter : IsZetaZeroInHeightSlab A C s :=
          (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mpr
            (Or.inr hsBCslab)
        exact
          ((TuringIntervalCertificate.glueAdjacentExplicit
            M hA_nonneg hAB hBC ZA ZB ZC
            certAB certBC hCountAB hCountBC).weightedSlab.complete s).mpr
            hsOuter
    ┬À intro hs
      have hsOuter : IsZetaZeroInHeightSlab A C s :=
        ((TuringIntervalCertificate.glueAdjacentExplicit
          M hA_nonneg hAB hBC ZA ZB ZC
          certAB certBC hCountAB hCountBC).weightedSlab.complete s).mp hs
      have hsplit :
          IsZetaZeroInHeightSlab A B s Ôê¿ IsZetaZeroInHeightSlab B C s :=
        (isZetaZeroInHeightSlab_union_adjacent hAB hBC s).mp hsOuter
      rw [Finset.mem_union]
      rcases hsplit with hsABslab | hsBCslab
      ┬À left
        rw [hlistedAB]
        exact
          ((weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB).complete s).mpr hsABslab
      ┬À right
        rw [hlistedBC]
        exact
          ((weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC).complete s).mpr hsBCslab

/-- The glued listed certificate's listed table is the union of the two
component listed tables. -/
theorem ListedTuringIntervalCertificate.glueAdjacentExplicit_listedZeros
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC)
    (listedAB : Finset Ôäé)
    (listedBC : Finset Ôäé)
    (hlistedAB :
      listedAB =
        (weightedZeroSetInHeightSlabOfDifference
          M hA_nonneg hAB ZA ZB).zeros)
    (hlistedBC :
      listedBC =
        (weightedZeroSetInHeightSlabOfDifference
          M (le_trans hA_nonneg hAB) hBC ZB ZC).zeros) :
    (ListedTuringIntervalCertificate.glueAdjacentExplicit
      M hA_nonneg hAB hBC ZA ZB ZC
      certAB certBC hCountAB hCountBC
      listedAB listedBC hlistedAB hlistedBC).listedZeros
      =
    listedAB Ôê¬ listedBC := rfl

/-- The listed tables for adjacent half-open intervals are disjoint. -/
theorem listedZeros_disjoint_of_adjacent
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (listedAB : Finset Ôäé)
    (listedBC : Finset Ôäé)
    (hlistedAB :
      listedAB =
        (weightedZeroSetInHeightSlabOfDifference
          M hA_nonneg hAB ZA ZB).zeros)
    (hlistedBC :
      listedBC =
        (weightedZeroSetInHeightSlabOfDifference
          M (le_trans hA_nonneg hAB) hBC ZB ZC).zeros) :
    Disjoint listedAB listedBC := by
  rw [hlistedAB, hlistedBC]
  exact
    disjoint_zeroSetInHeightSlab_adjacent
      (weightedZeroSetInHeightSlabOfDifference
        M hA_nonneg hAB ZA ZB).toZeroSetInHeightSlab
      (weightedZeroSetInHeightSlabOfDifference
        M (le_trans hA_nonneg hAB) hBC ZB ZC).toZeroSetInHeightSlab

/-- The cardinality of the glued listed table equals the sum of the
component listed table cardinalities. -/
theorem listedZeros_card_union_adjacent
    (M : GlobalZeroMultiplicity)
    {A B C : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (listedAB : Finset Ôäé)
    (listedBC : Finset Ôäé)
    (hlistedAB :
      listedAB =
        (weightedZeroSetInHeightSlabOfDifference
          M hA_nonneg hAB ZA ZB).zeros)
    (hlistedBC :
      listedBC =
        (weightedZeroSetInHeightSlabOfDifference
          M (le_trans hA_nonneg hAB) hBC ZB ZC).zeros) :
    (listedAB Ôê¬ listedBC).card = listedAB.card + listedBC.card :=
  Finset.card_union_of_disjoint
    (listedZeros_disjoint_of_adjacent
      M hA_nonneg hAB hBC ZA ZB ZC
      listedAB listedBC hlistedAB hlistedBC)

/-! ### Three-slab chain gluing

First scalable chain step: `(A, B] + (B, C] + (C, D] = (A, D]`.
Validates the pattern before generalizing to a recursive list API. -/

/-- Cumulative weighted counts glue over a three-slab chain:

  `N(D) ÔêÆ N(A) = (N(B) ÔêÆ N(A)) + (N(C) ÔêÆ N(B)) + (N(D) ÔêÆ N(C))`. -/
theorem weighted_cumulative_count_glue_three
    (M : GlobalZeroMultiplicity)
    {A B C D : ÔäØ}
    (hAB : A Ôëñ B) (hBC : B Ôëñ C) (hCD : C Ôëñ D)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (ZD : ZeroSetUpToHeight D) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZD)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZA)
      =
    (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZB)
      -
     weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZA))
    +
    (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZC)
      -
     weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZB))
    +
    (weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZD)
      -
     weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity M ZC)) := by
  have hNA_NB :
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZA)
        Ôëñ
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZB) :=
    weightedZeroCountOfGlobalMultiplicity_le_of_le M hAB ZA ZB
  have hNB_NC :
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZB)
        Ôëñ
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZC) :=
    weightedZeroCountOfGlobalMultiplicity_le_of_le M hBC ZB ZC
  have hNC_ND :
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZC)
        Ôëñ
      weightedZeroCountFromCertificate
          (weightedZeroSetOfGlobalMultiplicity M ZD) :=
    weightedZeroCountOfGlobalMultiplicity_le_of_le M hCD ZC ZD
  omega

/-- Glue three adjacent certified Turing intervals at the raw-data
level into a certificate for `(A, D]` with count
`certAB + certBC + certCD`. -/
noncomputable def TuringIntervalCertificate.glueThreeExplicit
    (M : GlobalZeroMultiplicity)
    {A B C D : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (hCD : C Ôëñ D)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (ZD : ZeroSetUpToHeight D)
    (certAB certBC certCD : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC)
    (hCountCD :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans (le_trans hA_nonneg hAB) hBC) hCD ZC ZD)
        =
      certCD) :
    TuringIntervalCertificate where
  A := A
  B := D
  hA_nonneg := hA_nonneg
  hAB := le_trans (le_trans hAB hBC) hCD
  ZA := ZA
  ZB := ZD
  M := M
  certifiedCount := certAB + certBC + certCD
  count_eq := by
    have hOuterDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M hA_nonneg (le_trans (le_trans hAB hBC) hCD) ZA ZD)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZD)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M hA_nonneg (le_trans (le_trans hAB hBC) hCD) ZA ZD
    have hABDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M hA_nonneg hAB ZA ZB)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M hA_nonneg hAB ZA ZB
    have hBCDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M (le_trans hA_nonneg hAB) hBC ZB ZC)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M (le_trans hA_nonneg hAB) hBC ZB ZC
    have hCDDiff :
        weightedZeroCountInHeightSlabFromCertificate
            (weightedZeroSetInHeightSlabOfDifference
              M (le_trans (le_trans hA_nonneg hAB) hBC) hCD ZC ZD)
          =
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZD)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC) :=
      weightedZeroCountInHeightSlabOfDifference_eq_sub
        M (le_trans (le_trans hA_nonneg hAB) hBC) hCD ZC ZD
    have hABSub :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA)
          =
        certAB := by
      rw [ÔåÉ hABDiff]; exact hCountAB
    have hBCSub :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          =
        certBC := by
      rw [ÔåÉ hBCDiff]; exact hCountBC
    have hCDSub :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZD)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          =
        certCD := by
      rw [ÔåÉ hCDDiff]; exact hCountCD
    have hGlue :
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZD)
          -
        weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA)
          =
        (weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB)
          -
         weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZA))
        +
        (weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)
          -
         weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZB))
        +
        (weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZD)
          -
         weightedZeroCountFromCertificate
            (weightedZeroSetOfGlobalMultiplicity M ZC)) :=
      weighted_cumulative_count_glue_three M hAB hBC hCD ZA ZB ZC ZD
    rw [hOuterDiff, hGlue, hABSub, hBCSub, hCDSub]

/-- The explicit three-slab gluing constructor has the expected
certified count. -/
theorem TuringIntervalCertificate.glueThreeExplicit_certifiedCount
    (M : GlobalZeroMultiplicity)
    {A B C D : ÔäØ}
    (hA_nonneg : 0 Ôëñ A)
    (hAB : A Ôëñ B)
    (hBC : B Ôëñ C)
    (hCD : C Ôëñ D)
    (ZA : ZeroSetUpToHeight A)
    (ZB : ZeroSetUpToHeight B)
    (ZC : ZeroSetUpToHeight C)
    (ZD : ZeroSetUpToHeight D)
    (certAB certBC certCD : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M hA_nonneg hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans hA_nonneg hAB) hBC ZB ZC)
        =
      certBC)
    (hCountCD :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (le_trans (le_trans hA_nonneg hAB) hBC) hCD ZC ZD)
        =
      certCD) :
    (TuringIntervalCertificate.glueThreeExplicit
      M hA_nonneg hAB hBC hCD ZA ZB ZC ZD
      certAB certBC certCD hCountAB hCountBC hCountCD).certifiedCount
      =
    certAB + certBC + certCD := rfl

/-! ### Height-chain endpoint bundles -/

/-- Endpoint bundle for one half-open interval `(A, B]`. -/
structure HeightChain1 where
  A : ÔäØ
  B : ÔäØ
  hA_nonneg : 0 Ôëñ A
  hAB : A Ôëñ B

/-- Endpoint bundle for two adjacent half-open intervals `(A, B]` and
`(B, C]`. -/
structure HeightChain2 extends HeightChain1 where
  C : ÔäØ
  hBC : B Ôëñ C

/-- Endpoint bundle for three adjacent half-open intervals `(A, B]`,
`(B, C]`, and `(C, D]`. -/
structure HeightChain3 extends HeightChain2 where
  D : ÔäØ
  hCD : C Ôëñ D

namespace HeightChain1

/-- The right endpoint of a one-step height chain is nonnegative. -/
theorem B_nonneg (H : HeightChain1) : 0 Ôëñ H.B :=
  le_trans H.hA_nonneg H.hAB

end HeightChain1

namespace HeightChain2

/-- The outer endpoint inequality for a two-step height chain. -/
theorem hAC (H : HeightChain2) : H.A Ôëñ H.C :=
  le_trans H.hAB H.hBC

/-- The middle endpoint is nonnegative. -/
theorem B_nonneg (H : HeightChain2) : 0 Ôëñ H.B :=
  le_trans H.hA_nonneg H.hAB

/-- The right endpoint is nonnegative. -/
theorem C_nonneg (H : HeightChain2) : 0 Ôëñ H.C :=
  le_trans H.B_nonneg H.hBC

/-- Forget the final endpoint of a two-step chain. -/
def leftChain1 (H : HeightChain2) : HeightChain1 where
  A := H.A
  B := H.B
  hA_nonneg := H.hA_nonneg
  hAB := H.hAB

/-- The right one-step chain `(B, C]`. -/
def rightChain1 (H : HeightChain2) : HeightChain1 where
  A := H.B
  B := H.C
  hA_nonneg := H.B_nonneg
  hAB := H.hBC

end HeightChain2

namespace HeightChain3

/-- The outer endpoint inequality for a three-step height chain. -/
theorem hAD (H : HeightChain3) : H.A Ôëñ H.D :=
  le_trans H.hAC H.hCD

/-- The `C` endpoint is nonnegative. -/
theorem C_nonneg (H : HeightChain3) : 0 Ôëñ H.C :=
  HeightChain2.C_nonneg H.toHeightChain2

/-- The `D` endpoint is nonnegative. -/
theorem D_nonneg (H : HeightChain3) : 0 Ôëñ H.D :=
  le_trans H.C_nonneg H.hCD

/-- The left two-step chain `(A, B]`, `(B, C]`. -/
def leftChain2 (H : HeightChain3) : HeightChain2 where
  A := H.A
  B := H.B
  C := H.C
  hA_nonneg := H.hA_nonneg
  hAB := H.hAB
  hBC := H.hBC

/-- The right two-step chain `(B, C]`, `(C, D]`. -/
def rightChain2 (H : HeightChain3) : HeightChain2 where
  A := H.B
  B := H.C
  C := H.D
  hA_nonneg := HeightChain2.B_nonneg H.toHeightChain2
  hAB := H.hBC
  hBC := H.hCD

/-- The first one-step chain `(A, B]`. -/
def chainAB (H : HeightChain3) : HeightChain1 where
  A := H.A
  B := H.B
  hA_nonneg := H.hA_nonneg
  hAB := H.hAB

/-- The second one-step chain `(B, C]`. -/
def chainBC (H : HeightChain3) : HeightChain1 where
  A := H.B
  B := H.C
  hA_nonneg := HeightChain2.B_nonneg H.toHeightChain2
  hAB := H.hBC

/-- The third one-step chain `(C, D]`. -/
def chainCD (H : HeightChain3) : HeightChain1 where
  A := H.C
  B := H.D
  hA_nonneg := H.C_nonneg
  hAB := H.hCD

end HeightChain3

/-! ### Bundled gluing constructors -/

/-- Bundled version of `TuringIntervalCertificate.glueAdjacentExplicit`
using a `HeightChain2` endpoint bundle. -/
noncomputable def TuringIntervalCertificate.glueAdjacentFromChain
    (M : GlobalZeroMultiplicity)
    (H : HeightChain2)
    (ZA : ZeroSetUpToHeight H.A)
    (ZB : ZeroSetUpToHeight H.B)
    (ZC : ZeroSetUpToHeight H.C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.hA_nonneg H.hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.B_nonneg H.hBC ZB ZC)
        =
      certBC) :
    TuringIntervalCertificate :=
  TuringIntervalCertificate.glueAdjacentExplicit
    M H.hA_nonneg H.hAB H.hBC ZA ZB ZC
    certAB certBC hCountAB hCountBC

/-- The bundled two-slab gluing constructor has the expected certified
count. -/
theorem TuringIntervalCertificate.glueAdjacentFromChain_certifiedCount
    (M : GlobalZeroMultiplicity)
    (H : HeightChain2)
    (ZA : ZeroSetUpToHeight H.A)
    (ZB : ZeroSetUpToHeight H.B)
    (ZC : ZeroSetUpToHeight H.C)
    (certAB certBC : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.hA_nonneg H.hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.B_nonneg H.hBC ZB ZC)
        =
      certBC) :
    (TuringIntervalCertificate.glueAdjacentFromChain
      M H ZA ZB ZC certAB certBC hCountAB hCountBC).certifiedCount
      =
    certAB + certBC := rfl

/-- Bundled version of `TuringIntervalCertificate.glueThreeExplicit`
using a `HeightChain3` endpoint bundle. -/
noncomputable def TuringIntervalCertificate.glueThreeFromChain
    (M : GlobalZeroMultiplicity)
    (H : HeightChain3)
    (ZA : ZeroSetUpToHeight H.A)
    (ZB : ZeroSetUpToHeight H.B)
    (ZC : ZeroSetUpToHeight H.C)
    (ZD : ZeroSetUpToHeight H.D)
    (certAB certBC certCD : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.hA_nonneg H.hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (HeightChain2.B_nonneg H.toHeightChain2) H.hBC ZB ZC)
        =
      certBC)
    (hCountCD :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.C_nonneg H.hCD ZC ZD)
        =
      certCD) :
    TuringIntervalCertificate :=
  TuringIntervalCertificate.glueThreeExplicit
    M H.hA_nonneg H.hAB H.hBC H.hCD ZA ZB ZC ZD
    certAB certBC certCD hCountAB hCountBC hCountCD

/-- The bundled three-slab gluing constructor has the expected certified
count. -/
theorem TuringIntervalCertificate.glueThreeFromChain_certifiedCount
    (M : GlobalZeroMultiplicity)
    (H : HeightChain3)
    (ZA : ZeroSetUpToHeight H.A)
    (ZB : ZeroSetUpToHeight H.B)
    (ZC : ZeroSetUpToHeight H.C)
    (ZD : ZeroSetUpToHeight H.D)
    (certAB certBC certCD : Ôäò)
    (hCountAB :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.hA_nonneg H.hAB ZA ZB)
        =
      certAB)
    (hCountBC :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M (HeightChain2.B_nonneg H.toHeightChain2) H.hBC ZB ZC)
        =
      certBC)
    (hCountCD :
      weightedZeroCountInHeightSlabFromCertificate
          (weightedZeroSetInHeightSlabOfDifference
            M H.C_nonneg H.hCD ZC ZD)
        =
      certCD) :
    (TuringIntervalCertificate.glueThreeFromChain
      M H ZA ZB ZC ZD certAB certBC certCD
      hCountAB hCountBC hCountCD).certifiedCount
      =
    certAB + certBC + certCD := rfl

/-! ### Turing slab rows

The table-row format for a verified local interval `(A, B]`.  Bundles
endpoints (via a `HeightChain1`), endpoint zero-set certificates, the
global multiplicity model, the certified count, and the proof that the
certified count matches the slab certificate. -/

/-- A single verified Turing slab row. -/
structure TuringSlabRow where
  chain : HeightChain1
  M : GlobalZeroMultiplicity
  ZA : ZeroSetUpToHeight chain.A
  ZB : ZeroSetUpToHeight chain.B
  certifiedCount : Ôäò
  count_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M chain.hA_nonneg chain.hAB ZA ZB)
      =
    certifiedCount

namespace TuringSlabRow

/-- The interval certificate associated to a slab row. -/
noncomputable def toIntervalCertificate
    (R : TuringSlabRow) :
    TuringIntervalCertificate where
  A := R.chain.A
  B := R.chain.B
  hA_nonneg := R.chain.hA_nonneg
  hAB := R.chain.hAB
  ZA := R.ZA
  ZB := R.ZB
  M := R.M
  certifiedCount := R.certifiedCount
  count_eq := R.count_eq

/-- The slab certificate underlying a row. -/
noncomputable def weightedSlab
    (R : TuringSlabRow) :
    WeightedZeroSetInHeightSlab R.chain.A R.chain.B :=
  R.toIntervalCertificate.weightedSlab

/-- A row's weighted slab count equals its certified count. -/
theorem weightedSlab_count_eq
    (R : TuringSlabRow) :
    weightedZeroCountInHeightSlabFromCertificate R.weightedSlab =
      R.certifiedCount :=
  R.toIntervalCertificate.weightedSlab_count_eq

/-- A row's cumulative count difference equals its certified count. -/
theorem cumulative_count_sub_eq
    (R : TuringSlabRow) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity R.M R.ZB)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity R.M R.ZA)
      =
    R.certifiedCount :=
  R.toIntervalCertificate.cumulative_count_sub_eq

/-- If a row certifies zero zeros, then its slab contains no nontrivial
zeta zero. -/
theorem not_isZetaZeroInHeightSlab_of_count_zero
    (R : TuringSlabRow)
    (hR : R.certifiedCount = 0)
    (s : Ôäé) :
    ┬¼ IsZetaZeroInHeightSlab R.chain.A R.chain.B s :=
  R.toIntervalCertificate.not_isZetaZeroInHeightSlab_of_count_zero hR s

end TuringSlabRow

/-! ### Listed Turing slab rows -/

/-- A Turing slab row equipped with an explicit finite zero table.  The
table must equal the support of the row's weighted slab. -/
structure ListedTuringSlabRow extends TuringSlabRow where
  listedZeros : Finset Ôäé
  listedZeros_eq_support :
    listedZeros = toTuringSlabRow.weightedSlab.zeros

namespace ListedTuringSlabRow

/-- Convert a listed row to the corresponding listed interval
certificate. -/
noncomputable def toListedIntervalCertificate
    (R : ListedTuringSlabRow) :
    ListedTuringIntervalCertificate where
  toTuringIntervalCertificate := R.toTuringSlabRow.toIntervalCertificate
  listedZeros := R.listedZeros
  listedZeros_eq_support := R.listedZeros_eq_support

/-- Membership in a listed row's zero table is equivalent to being a
nontrivial zeta zero in the row's height slab. -/
theorem mem_listedZeros_iff_isZetaZeroInHeightSlab
    (R : ListedTuringSlabRow) (s : Ôäé) :
    s Ôêê R.listedZeros Ôåö
      IsZetaZeroInHeightSlab R.chain.A R.chain.B s :=
  R.toListedIntervalCertificate.mem_listedZeros_iff_isZetaZeroInHeightSlab s

/-- If a listed row certifies zero zeros, then its listed zero table is
empty. -/
theorem listedZeros_eq_empty_of_certifiedCount_zero
    (R : ListedTuringSlabRow)
    (hR : R.certifiedCount = 0) :
    R.listedZeros = Ôêà :=
  R.toListedIntervalCertificate.listedZeros_eq_empty_of_certifiedCount_zero hR

/-- If all multiplicities in the row are one, then the listed zero table
has cardinality equal to the certified count. -/
theorem listedZeros_card_eq_certifiedCount_of_mult_one
    (R : ListedTuringSlabRow)
    (hone :
      ÔêÇ s : Ôäé,
        s Ôêê R.toTuringSlabRow.weightedSlab.zeros ÔåÆ
          R.toTuringSlabRow.weightedSlab.mult s = 1) :
    R.listedZeros.card = R.certifiedCount :=
  R.toListedIntervalCertificate.listedZeros_card_eq_certifiedCount_of_mult_one
    hone

end ListedTuringSlabRow

/-! ### Two-row Turing slab tables -/

/-- A two-row Turing slab table over adjacent intervals `(A, B]` and
`(B, C]`.  Both rows share the same global multiplicity model and the
same middle zero-set certificate. -/
structure TuringSlabTable2 where
  chain : HeightChain2
  M : GlobalZeroMultiplicity
  ZA : ZeroSetUpToHeight chain.A
  ZB : ZeroSetUpToHeight chain.B
  ZC : ZeroSetUpToHeight chain.C
  certAB : Ôäò
  certBC : Ôäò
  countAB_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M chain.hA_nonneg chain.hAB ZA ZB)
      =
    certAB
  countBC_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M chain.B_nonneg chain.hBC ZB ZC)
      =
    certBC

namespace TuringSlabTable2

/-- The left row of a two-row table. -/
noncomputable def rowAB
    (T : TuringSlabTable2) :
    TuringSlabRow where
  chain := T.chain.leftChain1
  M := T.M
  ZA := T.ZA
  ZB := T.ZB
  certifiedCount := T.certAB
  count_eq := T.countAB_eq

/-- The right row of a two-row table. -/
noncomputable def rowBC
    (T : TuringSlabTable2) :
    TuringSlabRow where
  chain := T.chain.rightChain1
  M := T.M
  ZA := T.ZB
  ZB := T.ZC
  certifiedCount := T.certBC
  count_eq := T.countBC_eq

/-- The glued interval certificate for the whole two-row table. -/
noncomputable def toIntervalCertificate
    (T : TuringSlabTable2) :
    TuringIntervalCertificate :=
  TuringIntervalCertificate.glueAdjacentFromChain
    T.M T.chain T.ZA T.ZB T.ZC
    T.certAB T.certBC
    T.countAB_eq T.countBC_eq

/-- The certified count of a two-row table is the sum of its row
counts. -/
theorem toIntervalCertificate_certifiedCount
    (T : TuringSlabTable2) :
    T.toIntervalCertificate.certifiedCount = T.certAB + T.certBC :=
  TuringIntervalCertificate.glueAdjacentFromChain_certifiedCount
    T.M T.chain T.ZA T.ZB T.ZC
    T.certAB T.certBC
    T.countAB_eq T.countBC_eq

/-- The cumulative weighted count difference across the whole table
equals the sum of the two row counts. -/
theorem cumulative_count_sub_eq
    (T : TuringSlabTable2) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity T.M T.ZC)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity T.M T.ZA)
      =
    T.certAB + T.certBC := by
  rw [ÔåÉ T.toIntervalCertificate_certifiedCount]
  exact T.toIntervalCertificate.cumulative_count_sub_eq

end TuringSlabTable2

/-! ### Three-row Turing slab tables -/

/-- A three-row Turing slab table over adjacent intervals `(A, B]`,
`(B, C]`, and `(C, D]`.  All rows share the same global multiplicity
model and the same endpoint zero-set certificates. -/
structure TuringSlabTable3 where
  chain : HeightChain3
  M : GlobalZeroMultiplicity
  ZA : ZeroSetUpToHeight chain.A
  ZB : ZeroSetUpToHeight chain.B
  ZC : ZeroSetUpToHeight chain.C
  ZD : ZeroSetUpToHeight chain.D
  certAB : Ôäò
  certBC : Ôäò
  certCD : Ôäò
  countAB_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M chain.hA_nonneg chain.hAB ZA ZB)
      =
    certAB
  countBC_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M (HeightChain2.B_nonneg chain.toHeightChain2) chain.hBC ZB ZC)
      =
    certBC
  countCD_eq :
    weightedZeroCountInHeightSlabFromCertificate
        (weightedZeroSetInHeightSlabOfDifference
          M chain.C_nonneg chain.hCD ZC ZD)
      =
    certCD

namespace TuringSlabTable3

/-- The first row `(A, B]`. -/
noncomputable def rowAB (T : TuringSlabTable3) : TuringSlabRow where
  chain := T.chain.chainAB
  M := T.M
  ZA := T.ZA
  ZB := T.ZB
  certifiedCount := T.certAB
  count_eq := T.countAB_eq

/-- The second row `(B, C]`. -/
noncomputable def rowBC (T : TuringSlabTable3) : TuringSlabRow where
  chain := T.chain.chainBC
  M := T.M
  ZA := T.ZB
  ZB := T.ZC
  certifiedCount := T.certBC
  count_eq := T.countBC_eq

/-- The third row `(C, D]`. -/
noncomputable def rowCD (T : TuringSlabTable3) : TuringSlabRow where
  chain := T.chain.chainCD
  M := T.M
  ZA := T.ZC
  ZB := T.ZD
  certifiedCount := T.certCD
  count_eq := T.countCD_eq

/-- The glued interval certificate for the whole three-row table. -/
noncomputable def toIntervalCertificate
    (T : TuringSlabTable3) :
    TuringIntervalCertificate :=
  TuringIntervalCertificate.glueThreeFromChain
    T.M T.chain T.ZA T.ZB T.ZC T.ZD
    T.certAB T.certBC T.certCD
    T.countAB_eq T.countBC_eq T.countCD_eq

/-- The certified count of a three-row table is the sum of its row
counts. -/
theorem toIntervalCertificate_certifiedCount
    (T : TuringSlabTable3) :
    T.toIntervalCertificate.certifiedCount =
      T.certAB + T.certBC + T.certCD :=
  TuringIntervalCertificate.glueThreeFromChain_certifiedCount
    T.M T.chain T.ZA T.ZB T.ZC T.ZD
    T.certAB T.certBC T.certCD
    T.countAB_eq T.countBC_eq T.countCD_eq

/-- The cumulative weighted count difference across the whole three-row
table equals the sum of the row counts. -/
theorem cumulative_count_sub_eq
    (T : TuringSlabTable3) :
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity T.M T.ZD)
      -
    weightedZeroCountFromCertificate
        (weightedZeroSetOfGlobalMultiplicity T.M T.ZA)
      =
    T.certAB + T.certBC + T.certCD := by
