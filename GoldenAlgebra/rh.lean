/-! ## CF: Global zeta-zero classification ÔåÆ safe-height data -/

/-! ### CF1: zeta-zero classification input -/

/-- Global zeta-zero classification facts (proved from the functional
equation + standard zero theory):

* `left_edge_zero_free`: `╬Â Ôëá 0` on the vertical line `Re = -1`.
* `zeros_nontrivial_of_pos_im`: every zeta zero with positive imaginary
  part is a nontrivial zero (rules out trivial and exotic zeros). -/
structure ZetaZeroClassificationInput : Prop where
  left_edge_zero_free :
    ÔêÇ y : ÔäØ, riemannZeta Ôƒ¿-1, yÔƒ® Ôëá 0
  zeros_nontrivial_of_pos_im :
    ÔêÇ z : Ôäé, 0 < z.im ÔåÆ riemannZeta z = 0 ÔåÆ IsNontrivialZetaZero z

/-! ### CF2: safe-height data from zero classification + good height -/

/-- Given the global zero-classification facts plus a good height
`T > 0`, build the safe-height data: pick a good bottom in `(0, T)` via
CB7, and discharge every classification field of `zeroClass` from `ZC`. -/
noncomputable def rvmSafeHeightDataOfZeroClassification
    (ZC : ZetaZeroClassificationInput)
    {T : ÔäØ} (hT : RvMGoodHeight T) (hTpos : 0 < T) :
    ZetaRectangle.RvMSafeHeightData T :=
  let hexists := ZetaRectangle.existsSafeBottomHeight hTpos
  let B := Classical.choose hexists
  let hspec := Classical.choose_spec hexists
  { B := B
    B_pos := hspec.1
    B_lt_T := hspec.2.1
    goodBottom := hspec.2.2
    goodTop := hT.good
    zeroClass :=
      { left_edge := ZC.left_edge_zero_free
        bottom_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; exact hspec.1) hzeta
        top_zeros_nontrivial := fun z hzIm hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by rw [hzIm]; linarith [hspec.1, hspec.2.1]) hzeta
        interior_zeros_nontrivial := fun z hzOpen hzeta =>
          ZC.zeros_nontrivial_of_pos_im z
            (by
              have hB_lt : B < z.im := hzOpen.2.2.1
              linarith [hspec.1])
            hzeta } }

/-! ## CG: Split `ZetaZeroClassificationInput` into Mathlib-facing targets -/

/-! ### CG1: split into vertical-line and positive-im classification -/

/-- No zeta zero on the vertical line `Re s = -1`.  Functional-equation
target. -/
def ZetaLeftEdgeZeroFree : Prop :=
  ÔêÇ y : ÔäØ, riemannZeta Ôƒ¿-1, yÔƒ® Ôëá 0

/-- Every zeta zero with positive imaginary part is a nontrivial zero. -/
def ZetaZeroPositiveImaginaryNontrivial : Prop :=
  ÔêÇ z : Ôäé, 0 < z.im ÔåÆ riemannZeta z = 0 ÔåÆ IsNontrivialZetaZero z

/-! ### CG2a: proven half of CG2 ÔÇö `z.re < 1` from `riemannZeta_ne_zero_of_one_le_re` -/

/-- Every zeta zero satisfies `Re z < 1` ÔÇö immediate from
`riemannZeta_ne_zero_of_one_le_re`. -/
theorem zetaZero_re_lt_one {z : Ôäé} (hzeta : riemannZeta z = 0) :
    z.re < 1 := by
  by_contra h
  push_neg at h
  exact riemannZeta_ne_zero_of_one_le_re h hzeta

/-! ### CG2b: sub-target ÔÇö `0 < z.re` for zeros with positive imaginary part -/

/-- Sub-target: every zeta zero with positive imaginary part satisfies
`0 < Re z`.  Functional-equation content (zeros with `Re z Ôëñ 0` are the
trivial zeros, which are real). -/
def ZetaZeroPosImagPosRe : Prop :=
  ÔêÇ z : Ôäé, 0 < z.im ÔåÆ riemannZeta z = 0 ÔåÆ 0 < z.re

/-- Combine the sub-target `0 < Re z` with the proved upper bound
`Re z < 1` to discharge `ZetaZeroPositiveImaginaryNontrivial`. -/
theorem ZetaZeroPositiveImaginaryNontrivial.of_posRe
    (H : ZetaZeroPosImagPosRe) :
    ZetaZeroPositiveImaginaryNontrivial :=
  fun z hzIm hzeta =>
    Ôƒ¿hzeta, H z hzIm hzeta, zetaZero_re_lt_one hzetaÔƒ®

/-! ### CG4: split combinator for the full classification input -/

/-- Inhabit `ZetaZeroClassificationInput` from the two split targets. -/
def ZetaZeroClassificationInput.of_split
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPositiveImaginaryNontrivial) :
    ZetaZeroClassificationInput where
  left_edge_zero_free := Hleft
  zeros_nontrivial_of_pos_im := Hpos

/-- Two-level split: a left-edge target plus the proved upper bound plus
the lower-bound sub-target. -/
def ZetaZeroClassificationInput.of_three_targets
    (Hleft : ZetaLeftEdgeZeroFree)
    (Hpos : ZetaZeroPosImagPosRe) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_split Hleft
    (ZetaZeroPositiveImaginaryNontrivial.of_posRe Hpos)

/-! ## CH: Functional-equation zero-transfer wrapper -/

/-- Functional-equation zero transfer package: bundles the two
functional-equation consequences `ZetaLeftEdgeZeroFree` and
`ZetaZeroPosImagPosRe`.  Either field is a direct consequence of
`riemannZeta_one_sub` plus nonvanishing of the trig/╬ô/cpow/╬Â(2-iy)
factors. -/
structure ZetaFunctionalEquationZeroTransferInput : Prop where
  left_edge : ZetaLeftEdgeZeroFree
  pos_im_pos_re : ZetaZeroPosImagPosRe

/-- Inhabit `ZetaZeroClassificationInput` from the functional-equation
zero-transfer package ÔÇö closes the entire zero-classification side
modulo two functional-equation Props. -/
def ZetaZeroClassificationInput.of_functionalEquationTransfer
    (F : ZetaFunctionalEquationZeroTransferInput) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_three_targets F.left_edge F.pos_im_pos_re

/-! ### CH (extended): standard functional-equation zero-free facts -/

/-- The standard functional-equation consequence: `╬Â` has no zeros in the
left half-plane (`Re Ôëñ 0`) at positive imaginary heights.  Equivalent to
the classical statement that `╬Â` zeros outside the critical strip are
exactly the real trivial zeros. -/
def ZetaNoZerosLeftHalfPlaneUpper : Prop :=
  ÔêÇ z : Ôäé, z.re Ôëñ 0 ÔåÆ 0 < z.im ÔåÆ riemannZeta z Ôëá 0

/-- The functional-equation no-zero fact in the left half-plane upper
half implies the sub-target `ZetaZeroPosImagPosRe`.  Contrapositive: a
zero with `Im > 0` and `Re Ôëñ 0` would contradict the no-zero fact. -/
theorem ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper
    (H : ZetaNoZerosLeftHalfPlaneUpper) :
    ZetaZeroPosImagPosRe := by
  intro z hzIm hzeta
  by_contra hzre_not
  have hzre : z.re Ôëñ 0 := le_of_not_gt hzre_not
  exact H z hzre hzIm hzeta

/-- Bundled standard functional-equation zero-free facts: the no-zero
property in the left half-plane upper half + the (broader) no-zero
property on the vertical line `Re = -1`. -/
structure ZetaFunctionalEquationStandardZeroFacts : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeZeroFree : ZetaLeftEdgeZeroFree

/-- The standard zero-free facts inhabit the transfer input package ÔÇö only
the two named functional-equation Props remain. -/
def ZetaFunctionalEquationStandardZeroFacts.toTransferInput
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaFunctionalEquationZeroTransferInput where
  left_edge := F.leftEdgeZeroFree
  pos_im_pos_re :=
    ZetaZeroPosImagPosRe.of_noZerosLeftHalfPlaneUpper F.noZerosLeftHalfPlaneUpper

/-- Top-level: inhabit `ZetaZeroClassificationInput` directly from the
standard functional-equation facts. -/
def ZetaZeroClassificationInput.of_standardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFacts) :
    ZetaZeroClassificationInput :=
  ZetaZeroClassificationInput.of_functionalEquationTransfer F.toTransferInput

/-! ## CL: Functional-equation transfer on the line `Re = -1` -/

/-! ### CL1: easy right-half nonzero + transfer Prop -/

/-- For real `y`, `(1 - Ôƒ¿-1, yÔƒ®).re = 2`, so `╬Â Ôëá 0` there via
`riemannZeta_ne_zero_of_one_lt_re`. -/
theorem zeta_one_sub_leftEdge_ne_zero (y : ÔäØ) :
    riemannZeta ((1 : Ôäé) - Ôƒ¿(-1 : ÔäØ), yÔƒ®) Ôëá 0 := by
  apply riemannZeta_ne_zero_of_one_lt_re
  show (1 : ÔäØ) < ((1 : Ôäé) - Ôƒ¿(-1 : ÔäØ), yÔƒ®).re
  simp [Complex.sub_re, Complex.one_re]

/-- Functional-equation nonzero transfer on the line `Re s = -1`: if
`╬Â(1 - z) Ôëá 0`, then `╬Â(z) Ôëá 0`, for `z = Ôƒ¿-1, yÔƒ®`.  This is the precise
Mathlib-facing analytic obligation underlying `ZetaLeftEdgeZeroFree`. -/
def ZetaFunctionalEquationLeftEdgeTransfer : Prop :=
  ÔêÇ y : ÔäØ,
    riemannZeta ((1 : Ôäé) - Ôƒ¿(-1 : ÔäØ), yÔƒ®) Ôëá 0 ÔåÆ
      riemannZeta Ôƒ¿(-1 : ÔäØ), yÔƒ® Ôëá 0

/-- `ZetaLeftEdgeZeroFree` follows from the functional-equation transfer
plus the easy right-half nonzero fact `zeta_one_sub_leftEdge_ne_zero`. -/
theorem ZetaLeftEdgeZeroFree.of_functionalEquationTransfer
    (H : ZetaFunctionalEquationLeftEdgeTransfer) :
    ZetaLeftEdgeZeroFree := fun y =>
  H y (zeta_one_sub_leftEdge_ne_zero y)

/-! ### CL4: standard zero facts via the transfer Prop -/

/-- Variant of `ZetaFunctionalEquationStandardZeroFacts` that takes the
functional-equation transfer (CL1) instead of the assembled
`leftEdgeZeroFree`.  This reduces the left-edge obligation to a single
precise FE transfer lemma. -/
structure ZetaFunctionalEquationStandardZeroFactsViaTransfer : Prop where
  noZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper
  leftEdgeTransfer : ZetaFunctionalEquationLeftEdgeTransfer

/-- The transfer-based standard facts package inhabits the original
assembled package. -/
def ZetaFunctionalEquationStandardZeroFactsViaTransfer.toStandardZeroFacts
    (F : ZetaFunctionalEquationStandardZeroFactsViaTransfer) :
    ZetaFunctionalEquationStandardZeroFacts where
  noZerosLeftHalfPlaneUpper := F.noZerosLeftHalfPlaneUpper
  leftEdgeZeroFree :=
    ZetaLeftEdgeZeroFree.of_functionalEquationTransfer F.leftEdgeTransfer

/-! ## CI: Tautological `mainEval` via `concreteS` as `Sarg` -/

/-! ### CI3: build `RvMGoodHeightAnalyticInputs` from safe-data, with `Sarg := concreteS` -/

/-- Build `RvMGoodHeightAnalyticInputs` using `concreteS` as the
correction term `Sarg`.  The `mainEval` field is then immediate from
`concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm`. -/
noncomputable def RvMGoodHeightAnalyticInputs.of_concreteS_safeData
    (safe :
      ÔêÇ T : ÔäØ, RvMGoodHeight T ÔåÆ ZetaRectangle.RvMSafeHeightData T) :
    RvMGoodHeightAnalyticInputs where
  Sarg := concreteS
  safeData := safe
  mainEval := fun T hT => by
    have h := concreteS_eq_zeta_count_sub_riemannVonMangoldtMainTerm hT.nonneg
    linarith

/-! ### CI4: top-level pipeline from zero-classification + height-positivity -/

/-- The final pipeline assembler: given the zeta-zero classification
