/-! ### CW18: discharge local finiteness from `ZetaZeroPosImagPosRe` -/

/-- **CW18 — local finiteness in the strip window from
`ZetaZeroPosImagPosRe`.**  Given the functional-equation content that
every ζ-zero with positive imaginary part has positive real part, the
strip window is contained in `zetaZerosUpToHeightSet (T + 1)`, which is
already proven finite (`zetaZerosUpToHeightSet_finite`). -/
theorem ZetaZerosLocallyFiniteInBacklundStripInput.of_posRe
    (H : ZetaZeroPosImagPosRe) :
    ZetaZerosLocallyFiniteInBacklundStripInput where
  finite_window := by
    intro T hT
    have hT1_nonneg : (0 : ℝ) ≤ T + 1 := by linarith
    have hfin : Set.Finite (zetaZerosUpToHeightSet (T + 1)) :=
      zetaZerosUpToHeightSet_finite (T + 1) hT1_nonneg
    refine hfin.subset ?_
    intro ρ hρ
    obtain ⟨hzero, _hre1, _hre2, him_lt, him_le⟩ := hρ
    have him_pos : (0 : ℝ) < ρ.im := by linarith
    have hposre : 0 < ρ.re := H ρ him_pos hzero
    have hreone : ρ.re < 1 := zetaZero_re_lt_one hzero
    exact ⟨⟨hzero, hposre, hreone⟩, him_pos, him_le⟩

/-- **CW18 — sharper final theorem.**  Replaces the local-finite-zeros
input with the smaller, more focused functional-equation classification
