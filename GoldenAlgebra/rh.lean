  have h_2718_pos : (0 : вДЭ) < 2.7182818283 := by norm_num
  have h_exp_1_18 : (2.7182818283 : вДЭ)^18 < (Real.exp 1)^18 :=
    pow_lt_pow_leftвВА h_exp_1_gt (le_of_lt h_2718_pos) (by norm_num)
  have h_36_5_le_27 : (36 : вДЭ)^5 вЙ§ (2.7182818283 : вДЭ)^18 := by norm_num
