-- =====================================================================
-- ┬ºCCXXVII. Wrapper-kernel integrability from real-derivative integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.wrap_int`:
-- The ┬ºCCXVI wrapper kernel `pairedCauchyComplexKernelDeriv u z` at
-- `z = upperHalfPoint x y` factors pointwise as
-- `pairedCauchyComplexKernelDeriv u (UHP) * (S u : Ôäé)
--      = ((S u ┬À pairedCauchyImKernelDeriv x y u : ÔäØ) : Ôäé) * I`.
-- So interval integrability of the complex integrand follows from
-- interval integrability of the real integrand (via `Integrable.ofReal`
-- + multiplication by the constant `Complex.I`).
--
-- Adds:
--   pairedDerivWrapper_integrand_eq_ofReal_mul_I        ÔÇö pointwise identity
--   intervalIntegrable_ofReal                           ÔÇö local `IntervalIntegrable.ofReal`
--   wrapKernel_intervalIntegrable_of_real_derivative_integrable
--   wrap_int_of_finiteFluctuation                       ÔÇö adaptive form

/-- Ô¡É **PROVED ÔÇö pointwise factorization of wrapper integrand.**
The ┬ºCCXVI wrapper kernel integrand at `upperHalfPoint x y` equals
`((real integrand : ÔäØ) : Ôäé) ┬À I`. -/
lemma pairedDerivWrapper_integrand_eq_ofReal_mul_I
    (S : ÔäØ ÔåÆ ÔäØ) (x y u : ÔäØ) :
    pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : Ôäé)
      = ((S u * pairedCauchyImKernelDeriv x y u : ÔäØ) : Ôäé) * Complex.I := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  push_cast
  ring

/-- Ô¡É **PROVED ÔÇö `IntervalIntegrable.ofReal` for ÔäØ ÔåÆ Ôäé.** Lifts real
interval integrability to Ôäé via the pointwise coercion. Built from
Mathlib's `MeasureTheory.Integrable.ofReal` on each of the two
`IntegrableOn` halves of `IntervalIntegrable`. -/
lemma intervalIntegrable_ofReal
    {f : ÔäØ ÔåÆ ÔäØ} {a b : ÔäØ}
    (hf : IntervalIntegrable f MeasureTheory.volume a b) :
    IntervalIntegrable (fun u => ((f u : ÔäØ) : Ôäé))
      MeasureTheory.volume a b :=
  Ôƒ¿hf.1.ofReal, hf.2.ofRealÔƒ®

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö wrapper-kernel integrand interval integrability
from real-derivative integrability.** Given that
`fun u => S u ┬À pairedCauchyImKernelDeriv x y u` is interval-integrable
on `[T, X]`, the complex wrapper integrand
`fun u => pairedCauchyComplexKernelDeriv u (UHP x y) ┬À (S u : Ôäé)` is
interval-integrable on the same interval. -/
lemma wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (S : ÔäØ ÔåÆ ÔäØ) (x y T X : ÔäØ)
    (hreal : IntervalIntegrable
              (fun u => S u * pairedCauchyImKernelDeriv x y u)
              MeasureTheory.volume T X) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : Ôäé))
      MeasureTheory.volume T X := by
  have hofReal : IntervalIntegrable
      (fun u => ((S u * pairedCauchyImKernelDeriv x y u : ÔäØ) : Ôäé))
      MeasureTheory.volume T X :=
    intervalIntegrable_ofReal hreal
  have hmul : IntervalIntegrable
      (fun u =>
        ((S u * pairedCauchyImKernelDeriv x y u : ÔäØ) : Ôäé) * Complex.I)
      MeasureTheory.volume T X :=
    hofReal.mul_const Complex.I
  refine hmul.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  exact (pairedDerivWrapper_integrand_eq_ofReal_mul_I S x y u).symm

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö adaptive wrapper integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T Ôëñ X`, the wrapper-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `wrap_int` field of `TrueKernelTailData`
for the finite-fluctuation `S`.

Note: this does *not* depend on the Turing bound ÔÇö only on
`0 < T0 Ôëñ 10` and the ┬ºCCXXV regularity inhabit theorem. -/
theorem wrap_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10) :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelDeriv u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ÔäØ) : Ôäé))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hreg := finiteFluctuationRegularityData_of_existing_integrability
    D T0 hT0_pos hT0_le_10
  have hreal : IntervalIntegrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u
                  * pairedCauchyImKernelDeriv z.re z.im u)
      MeasureTheory.volume T X :=
    finiteFluctuation_derivative_integrable_of_regular D T0 hreg
      h10 h140 hy hregime hTX
  have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hwrap := wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    z.re z.im T X hreal
  rw [hz] at hwrap
  exact hwrap

-- =====================================================================
-- ┬ºCCXXVIII. True-kernel finite-window integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.true_int` for the finite-fluctuation
-- `S = Phase1IBP.finiteFluctuationPrimitive D T0` by:
--   1. defining a per-`i` true-kernel indicator term;
--   2. proving its interval integrability (indicator ├ù continuous kernel);
--   3. summing for the discrete part;
--   4. proving smooth-part integrability via ContinuousOn;
--   5. reassembling the finite-fluctuation integrand by `sub`;
--   6. packaging the adaptive theorem `true_int_of_finiteFluctuation`.
--
-- Adds:
--   discreteCountingTrueKernelTerm                              ÔÇö per-i term def
--   discreteCountingTrueKernelTerm_intervalIntegrable           ÔÇö per-i integrability
--   discreteCountingPrimitive_trueKernel_intervalIntegrable     ÔÇö discrete sum
--   smoothCountingPrimitive_trueKernel_intervalIntegrable       ÔÇö smooth part
--   finiteFluctuationPrimitive_trueKernel_intervalIntegrable    ÔÇö reassembled
--   true_int_of_finiteFluctuation                               ÔÇö adaptive form

/-- **Per-`i` true-kernel indicator term.** Top-level definition to
keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteCountingTrueKernelTerm
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 : ÔäØ) (z : Ôäé) (i : Ôäò) : ÔäØ ÔåÆ Ôäé :=
  fun u =>
    pairedCauchyComplexKernelTrue u z
      * ((if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0) : Ôäé)

/-- Ô¡É **PROVED ÔÇö per-`i` true-kernel term is interval-integrable.**
Case-splits on `T0 Ôëñ D.Z i`: in the `Ôëñ` case, the integrand reduces to
an indicator ├ù continuous-kernel pattern (built via `.indicator
measurableSet_Ici` on each `IntegrableOn` half); in the `>` case, the
integrand is identically zero. -/
lemma discreteCountingTrueKernelTerm_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ÔäØ) (z : Ôäé) (i : Ôäò) (hz : z.im Ôëá 0) :
    IntervalIntegrable
      (discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X := by
  unfold discreteCountingTrueKernelTerm
  have hk_cont : Continuous fun u : ÔäØ => pairedCauchyComplexKernelTrue u z := by
    have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
    simpa [upperHalfPoint_re_im] using h
  by_cases h_T0 : T0 Ôëñ D.Z i
  ┬À have hfun :
        (fun u : ÔäØ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0) : Ôäé))
        = Set.indicator (Set.Ici (D.Z i))
            (fun u : ÔäØ =>
              pairedCauchyComplexKernelTrue u z * (D.mult i : Ôäé)) := by
      funext u
      by_cases h_u : D.Z i Ôëñ u
      ┬À have h_and : T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u := Ôƒ¿h_T0, h_uÔƒ®
        have hmem : u Ôêê Set.Ici (D.Z i) := h_u
        simp [h_and, Set.indicator_of_mem hmem]
      ┬À have h_nand : ┬¼ (T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u) := fun Ôƒ¿_, hÔƒ® => h_u h
        have hnmem : u Ôêë Set.Ici (D.Z i) := h_u
        simp [h_nand, Set.indicator_of_notMem hnmem]
    rw [hfun]
    have h_const_mul : IntervalIntegrable
        (fun u : ÔäØ => pairedCauchyComplexKernelTrue u z * (D.mult i : Ôäé))
        MeasureTheory.volume T X :=
      (hk_cont.intervalIntegrable T X).mul_const (D.mult i : Ôäé)
    exact Ôƒ¿h_const_mul.1.indicator measurableSet_Ici,
           h_const_mul.2.indicator measurableSet_IciÔƒ®
  ┬À have hfun :
        (fun u : ÔäØ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0) : Ôäé))
        = (fun _ : ÔäØ => (0 : Ôäé)) := by
      funext u
      have h_nand : ┬¼ (T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u) := fun Ôƒ¿h, _Ôƒ® => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `N_{T0}(u) ┬À trueKernel(u, z)` is interval-integrable
on any finite window.** Discrete counting primitive times true kernel.
Proof: sum of per-`i` indicator terms, then bridge via `Finset.mul_sum`
+ `push_cast` to identify with the primitive's defining sum. -/
lemma discreteCountingPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ÔäØ) (z : Ôäé) (hz : z.im Ôëá 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.discreteCountingPrimitive
              D.toFluctuationMeasureData T0 u : ÔäØ) : Ôäé))
      MeasureTheory.volume T X := by
  have h_sum_fun : IntervalIntegrable
      (Ôêæ i Ôêê Finset.range D.n, discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingTrueKernelTerm_intervalIntegrable D T0 T X z i hz)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  simp only [Finset.sum_apply, discreteCountingTrueKernelTerm]
  rw [ÔåÉ Finset.mul_sum]
  congr 1
  unfold Phase1IBP.discreteCountingPrimitive
  push_cast
  refine Finset.sum_congr rfl (fun i _ => ?_)
  by_cases hc : T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u
  ┬À simp [hc]
  ┬À simp [hc]

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `S_smooth(u) ┬À trueKernel(u, z)` is interval-integrable
on `[T, X]`** for `0 < T0 Ôëñ T Ôëñ X` and `z.im Ôëá 0`. Both factors are
continuous on `[T, X]`: `S_smooth` via FTC (since `T0 Ôëñ u` for every
`u Ôêê [T, X]`), `trueKernel` via ┬ºCCXX. -/
lemma smoothCountingPrimitive_trueKernel_intervalIntegrable
    (T0 T X : ÔäØ) (z : Ôäé)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 Ôëñ T) (hTX : T Ôëñ X) (hz : z.im Ôëá 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : ÔäØ) : Ôäé))
      MeasureTheory.volume T X := by
  have h_S_cont : ContinuousOn
      (fun u => ((Phase1IBP.smoothCountingPrimitive T0 u : ÔäØ) : Ôäé))
      (Set.Icc T X) := by
    intro u hu
    have hT0_le_u : T0 Ôëñ u := le_trans hT0_le_T hu.1
    have h_deriv := Phase1IBP.smoothCountingPrimitive_hasDerivAt hT0_pos hT0_le_u
    have h_real_cont : ContinuousAt
        (fun v => Phase1IBP.smoothCountingPrimitive T0 v) u :=
      h_deriv.differentiableAt.continuousAt
    exact
      (Complex.continuous_ofReal.continuousAt.comp h_real_cont).continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyComplexKernelTrue u z)
      (Set.Icc T X) := by
    have hcont : Continuous fun u : ÔäØ => pairedCauchyComplexKernelTrue u z := by
      have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
      simpa [upperHalfPoint_re_im] using h
    exact hcont.continuousOn
  have h_prod_cont : ContinuousOn
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : ÔäØ) : Ôäé))
      (Set.Icc T X) :=
    h_k_cont.mul h_S_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `finiteFluctuationPrimitive D T0 u ┬À trueKernel(u, z)`
is interval-integrable.** Reassembles the discrete and smooth parts
via `IntervalIntegrable.sub` after distributing
`trueKernel ┬À ((N - Ssmooth : ÔäØ) : Ôäé)` pointwise. -/
lemma finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : ÔäØ) (z : Ôäé)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 Ôëñ T) (hTX : T Ôëñ X) (hz : z.im Ôëá 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ÔäØ) : Ôäé))
      MeasureTheory.volume T X := by
  have hdisc := discreteCountingPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hz
  have hsmooth := smoothCountingPrimitive_trueKernel_intervalIntegrable
    T0 T X z hT0_pos hT0_le_T hTX hz
  have hfunc_eq :
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ÔäØ) : Ôäé))
      = (fun u =>
          pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.discreteCountingPrimitive
                D.toFluctuationMeasureData T0 u : ÔäØ) : Ôäé)
          - pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.smoothCountingPrimitive T0 u : ÔäØ) : Ôäé)) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    push_cast
    ring
  rw [hfunc_eq]
  exact hdisc.sub hsmooth

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö adaptive true-kernel integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T Ôëñ X`, the true-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `true_int` field of `TrueKernelTailData`
for the finite-fluctuation `S` (modulo the `T Ôëñ X` hypothesis).

Like ┬ºCCXXVII's `wrap_int_of_finiteFluctuation`, this version adds
`T Ôëñ X` as an explicit hypothesis ÔÇö the structure's field allows
arbitrary `X`, but the practical use case (improper integral partial
sums) only ever uses `T Ôëñ X`. -/
theorem true_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10) :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelTrue u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : ÔäØ) : Ôäé))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hT0_le_T : T0 Ôëñ T := le_trans hT0_le_10 h10
  exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hT0_pos hT0_le_T hTX (ne_of_gt hy)

-- =====================================================================
-- ┬ºCCXXIX. Complex improper convergence from a real norm-majorant
-- =====================================================================
-- Ôäé-valued analogue of ┬ºCCV's `improperIntegralConverges_of_absMajorant`.
-- Given a complex integrand `f : ÔäØ ÔåÆ Ôäé`, a real majorant `M : ÔäØ ÔåÆ ÔäØ`
-- whose improper integral converges, and a pointwise eventual bound
-- `ÔÇûf uÔÇû Ôëñ M u`, the complex partial integrals `Ôê½ T..X, f u` form a
-- Cauchy sequence in Ôäé and hence converge (Ôäé is complete).
--
-- This is the smallest reusable next building block for the `conv`
-- field of `TrueKernelTailData`: any concrete kernel ├ù density tail
-- with a log-envelope bound yields convergence via this lemma.
--
-- Adds:
--   improperComplexIntegralConverges_of_normMajorant

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö complex improper convergence from a real
norm-majorant.** Mirrors ┬ºCCV's real-side comparison theorem. Proof:
Cauchy criterion via `Metric.cauchy_iff`, with the key step
`ÔÇûÔê½_{Y1}^{Y2} fÔÇû Ôëñ Ôê½_{Y1}^{Y2} ÔÇûf uÔÇû du Ôëñ Ôê½_{Y1}^{Y2} M u du`
(combining `MeasureTheory.norm_integral_le_integral_norm` and
`intervalIntegral.integral_mono_on`) plus the M-tail smallness from
the M-partial Cauchy structure. -/
theorem improperComplexIntegralConverges_of_normMajorant
    {f : ÔäØ ÔåÆ Ôäé} {M : ÔäØ ÔåÆ ÔäØ} {T LM : ÔäØ}
    (hf_int : ÔêÇ X, T Ôëñ X ÔåÆ IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : ÔêÇ X, T Ôëñ X ÔåÆ IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => Ôê½ u in T..X, M u)
                    Filter.atTop (­ØôØ LM))
    (hbound : ÔêÇßÂá u in Filter.atTop, ÔÇûf uÔÇû Ôëñ M u) :
    Ôêâ L : Ôäé, Tendsto (fun X => Ôê½ u in T..X, f u) Filter.atTop (­ØôØ L) := by
  have h_cauchy :
      Cauchy (Filter.map (fun X => Ôê½ u in T..X, f u) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine Ôƒ¿Filter.map_neBot, ?_Ôƒ®
    intro ╬Á h╬Á
    have h╬Á2 : 0 < ╬Á / 2 := by linarith
    have h_M_close : ÔêÇßÂá A in Filter.atTop,
        |(Ôê½ u in T..A, M u) - LM| < ╬Á / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (╬Á / 2) h╬Á2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain Ôƒ¿N_M, hN_MÔƒ® := Filter.eventually_atTop.mp h_M_close
    obtain Ôƒ¿N0, hN0Ôƒ® := Filter.eventually_atTop.mp hbound
    let N : ÔäØ := max T (max N0 N_M)
    refine Ôƒ¿(fun X => Ôê½ u in T..X, f u) '' {X | N Ôëñ X}, ?_, ?_Ôƒ®
    ┬À exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    suffices key :
        ÔêÇ Y1 Y2 : ÔäØ, N Ôëñ Y1 ÔåÆ N Ôëñ Y2 ÔåÆ Y1 Ôëñ Y2 ÔåÆ
          ÔÇû(Ôê½ u in T..Y2, f u) - (Ôê½ u in T..Y1, f u)ÔÇû < ╬Á by
      rintro _ Ôƒ¿X1, hX1, rflÔƒ® _ Ôƒ¿X2, hX2, rflÔƒ®
      rw [dist_eq_norm]
      rcases le_total X1 X2 with hX12 | hX21
      ┬À rw [norm_sub_rev]; exact key X1 X2 hX1 hX2 hX12
      ┬À exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    have hT_Y1 : T Ôëñ Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T Ôëñ Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 Ôëñ Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M Ôëñ Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M Ôëñ Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    have hf_int_TY2 := hf_int Y2 hT_Y2
    have hf_int_TY1 : IntervalIntegrable f MeasureTheory.volume T Y1 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have hM_int_TY2 := hM_int Y2 hT_Y2
    have hM_int_TY1 : IntervalIntegrable M MeasureTheory.volume T Y1 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have h_split_f : (Ôê½ u in T..Y2, f u) =
        (Ôê½ u in T..Y1, f u) + Ôê½ u in Y1..Y2, f u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hf_int_TY1 hf_int_Y1Y2).symm
    have h_tail_f :
        (Ôê½ u in T..Y2, f u) - (Ôê½ u in T..Y1, f u) = Ôê½ u in Y1..Y2, f u := by
      rw [h_split_f]; ring
    rw [h_tail_f]
    have hbound_Y1Y2 : ÔêÇ u Ôêê Set.Icc Y1 Y2, ÔÇûf uÔÇû Ôëñ M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    have h_norm_int : ÔÇûÔê½ u in Y1..Y2, f uÔÇû Ôëñ Ôê½ u in Y1..Y2, ÔÇûf uÔÇû := by
      rw [intervalIntegral.integral_of_le hY12,
          intervalIntegral.integral_of_le hY12]
      exact MeasureTheory.norm_integral_le_integral_norm _
    have h_mono : Ôê½ u in Y1..Y2, ÔÇûf uÔÇû Ôëñ Ôê½ u in Y1..Y2, M u :=
      intervalIntegral.integral_mono_on hY12 hf_int_Y1Y2.norm hM_int_Y1Y2
        hbound_Y1Y2
    have h_comp : ÔÇûÔê½ u in Y1..Y2, f uÔÇû Ôëñ Ôê½ u in Y1..Y2, M u :=
      le_trans h_norm_int h_mono
    have h_split_M : (Ôê½ u in T..Y2, M u) =
        (Ôê½ u in T..Y1, M u) + Ôê½ u in Y1..Y2, M u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hM_int_TY1 hM_int_Y1Y2).symm
    have h_M_tail_eq : Ôê½ u in Y1..Y2, M u =
        (Ôê½ u in T..Y2, M u) - (Ôê½ u in T..Y1, M u) := by linarith
    have h_M_close_Y1 := hN_M Y1 hN_M_Y1
    have h_M_close_Y2 := hN_M Y2 hN_M_Y2
    have h_M_diff_lt :
        |(Ôê½ u in T..Y2, M u) - (Ôê½ u in T..Y1, M u)| < ╬Á := by
      calc |(Ôê½ u in T..Y2, M u) - (Ôê½ u in T..Y1, M u)|
          Ôëñ |(Ôê½ u in T..Y2, M u) - LM| + |LM - (Ôê½ u in T..Y1, M u)| :=
              abs_sub_le _ _ _
        _ = |(Ôê½ u in T..Y2, M u) - LM| + |(Ôê½ u in T..Y1, M u) - LM| := by
              rw [abs_sub_comm LM]
        _ < ╬Á / 2 + ╬Á / 2 := add_lt_add h_M_close_Y2 h_M_close_Y1
        _ = ╬Á := by ring
    rw [h_M_tail_eq] at h_comp
    have h_le_abs :
        (Ôê½ u in T..Y2, M u) - (Ôê½ u in T..Y1, M u)
          Ôëñ |(Ôê½ u in T..Y2, M u) - (Ôê½ u in T..Y1, M u)| := le_abs_self _
    linarith
  obtain Ôƒ¿L, hLÔƒ® := CompleteSpace.complete h_cauchy
  exact Ôƒ¿L, hLÔƒ®

-- =====================================================================
-- ┬ºCCXXIX-3. True-kernel norm bound on UHP probes
-- =====================================================================
-- Crude `1/u┬▓` decay bound on the true rational kernel at UHP probes
-- `(upperHalfPoint x y)`. For `u` larger than `2|x|`:
--   ÔÇó `|x ┬▒ u| ÔëÑ u/2`;
--   ÔÇó hence `ÔÇûz ┬▒ uÔÇû ÔëÑ u/2` (via `Complex.abs_re_le_norm`);
--   ÔÇó hence `ÔÇû1/(z ┬▒ u)┬▓ÔÇû Ôëñ 4/u┬▓`;
--   ÔÇó triangle inequality on the difference gives Ôëñ 8/u┬▓.
-- The `1/u┬▓` decay is enough (combined with a log envelope on `S`)
-- to apply ┬ºCCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   upperHalfPoint_sub_real_norm_ge_half
--   upperHalfPoint_add_real_norm_ge_half
--   norm_inv_sq_le_four_div_sq_of_norm_ge_half
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually

/-- Ô¡É **PROVED ÔÇö `ÔÇûUHP - uÔÇû ÔëÑ u/2` when `u ÔëÑ 2|x|`.** Lower bound on
the denominator of the first true-kernel term. -/
lemma upperHalfPoint_sub_real_norm_ge_half
    (x y u : ÔäØ) (hu : 2 * |x| Ôëñ u) :
    u / 2 Ôëñ ÔÇûupperHalfPoint x y - (u : Ôäé)ÔÇû := by
  have h_re : (upperHalfPoint x y - (u : Ôäé)).re = x - u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| Ôëñ u / 2 := by linarith
  have hu_nn : 0 Ôëñ u := by linarith [abs_nonneg x]
  have h_x_upper : x Ôëñ u / 2 := le_trans (le_abs_self x) h_abs_x
  have h_nonneg : 0 Ôëñ u - x := by linarith
  have h_abs_eq : |x - u| = u - x := by
    rw [abs_sub_comm]
    exact abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 Ôëñ |x - u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x - u| Ôëñ ÔÇûupperHalfPoint x y - (u : Ôäé)ÔÇû := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y - (u : Ôäé))
    rw [h_re] at this
    exact this
  linarith

/-- Ô¡É **PROVED ÔÇö `ÔÇûUHP + uÔÇû ÔëÑ u/2` when `u ÔëÑ 2|x|`.** Lower bound on
the denominator of the second true-kernel term. -/
lemma upperHalfPoint_add_real_norm_ge_half
    (x y u : ÔäØ) (hu : 2 * |x| Ôëñ u) :
    u / 2 Ôëñ ÔÇûupperHalfPoint x y + (u : Ôäé)ÔÇû := by
  have h_re : (upperHalfPoint x y + (u : Ôäé)).re = x + u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| Ôëñ u / 2 := by linarith
  have hu_nn : 0 Ôëñ u := by linarith [abs_nonneg x]
  have h_neg_x_le : -x Ôëñ |x| := neg_le_abs x
  have h_x_lower : -(u / 2) Ôëñ x := by linarith
  have h_nonneg : 0 Ôëñ x + u := by linarith
  have h_abs_eq : |x + u| = x + u := abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 Ôëñ |x + u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x + u| Ôëñ ÔÇûupperHalfPoint x y + (u : Ôäé)ÔÇû := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y + (u : Ôäé))
    rw [h_re] at this
    exact this
  linarith

/-- Ô¡É **PROVED ÔÇö reciprocal-square norm bound.** If `ÔÇûwÔÇû ÔëÑ u/2 > 0`,
then `ÔÇû1/w┬▓ÔÇû Ôëñ 4/u┬▓`. -/
lemma norm_inv_sq_le_four_div_sq_of_norm_ge_half
    {w : Ôäé} {u : ÔäØ} (hu : 0 < u) (hw : u / 2 Ôëñ ÔÇûwÔÇû) :
    ÔÇû(1 : Ôäé) / w^2ÔÇû Ôëñ 4 / u^2 := by
  have hu_half_pos : 0 < u / 2 := by linarith
  have hw_pos : 0 < ÔÇûwÔÇû := lt_of_lt_of_le hu_half_pos hw
  have h_sq : (u / 2)^2 Ôëñ ÔÇûwÔÇû^2 :=
    sq_le_sq' (by linarith [norm_nonneg w]) hw
  have hw_sq_pos : 0 < ÔÇûwÔÇû^2 := by positivity
  have hu_sq_pos : 0 < u^2 := by positivity
  rw [norm_div, norm_one, norm_pow, div_le_div_iffÔéÇ hw_sq_pos hu_sq_pos]
  nlinarith [h_sq]

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö true-kernel `8/u┬▓` bound for `u ÔëÑ 2|x|`.**
Triangle inequality on `1/(z-u)┬▓ - 1/(z+u)┬▓` plus the per-term `4/u┬▓`
bound from `norm_inv_sq_le_four_div_sq_of_norm_ge_half`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    (x y u : ÔäØ) (hu_pos : 0 < u) (hu_large : 2 * |x| Ôëñ u) :
    ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y)ÔÇû
      Ôëñ 8 / u^2 := by
  unfold pairedCauchyComplexKernelTrue
  have hsub :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y - (u : Ôäé)) hu_pos
      (upperHalfPoint_sub_real_norm_ge_half x y u hu_large)
  have hadd :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y + (u : Ôäé)) hu_pos
      (upperHalfPoint_add_real_norm_ge_half x y u hu_large)
  calc
    ÔÇû(1 : Ôäé) / (upperHalfPoint x y - (u : Ôäé))^2
        - (1 : Ôäé) / (upperHalfPoint x y + (u : Ôäé))^2ÔÇû
        Ôëñ ÔÇû(1 : Ôäé) / (upperHalfPoint x y - (u : Ôäé))^2ÔÇû
          + ÔÇû(1 : Ôäé) / (upperHalfPoint x y + (u : Ôäé))^2ÔÇû := norm_sub_le _ _
    _ Ôëñ 4 / u^2 + 4 / u^2 := add_le_add hsub hadd
    _ = 8 / u^2 := by ring

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö eventual `8/u┬▓` bound on the true kernel.** For
each `(x, y)`, the bound holds for all sufficiently large `u` (i.e.
`u > 0` and `u ÔëÑ 2|x|`). This is the form needed by
`improperComplexIntegralConverges_of_normMajorant`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually
    (x y : ÔäØ) :
    ÔêÇßÂá u in Filter.atTop,
      ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y)ÔÇû
        Ôëñ 8 / u^2 := by
  filter_upwards
    [Filter.eventually_gt_atTop (0 : ÔäØ),
     Filter.eventually_ge_atTop (2 * |x|)]
    with u hu_pos hu_large
  exact norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    x y u hu_pos hu_large

-- =====================================================================
-- ┬ºCCXXIX-4a. True-kernel log majorant and its convergence
-- =====================================================================
-- Defines the real majorant `(8/u┬▓)(C log u + D)` for the true-kernel
-- integrand, computes its explicit primitive `-8(C(log u + 1) + D)/u`,
-- and proves convergence of `Ôê½_T^X majorant ÔåÆ -primitive(T)`. The proof
-- mirrors ┬ºCCIII's `derivativeSideMajorantConverges` chain.
--
-- Adds:
--   trueKernelLogMajorant                     ÔÇö `(8/u┬▓)(C log u + D)`
--   trueKernelLogMajorantPrimitive            ÔÇö explicit primitive
--   hasDerivAt_trueKernelLogMajorantPrimitive ÔÇö derivative identity
--   trueKernelLogMajorant_continuousOn_Icc
--   trueKernelLogMajorant_intervalIntegrable
--   trueKernelLogMajorant_integral_eq_sub     ÔÇö FTC
--   log_div_id_atTop_tendsto_zero             ÔÇö `log x / x ÔåÆ 0`
--   trueKernelLogMajorantPrimitive_tendsto_zero
--   trueKernelLogMajorantConverges            ÔÇö improper convergence

/-- **True-kernel log majorant**: `(8/u┬▓) ┬À (C log u + D)`. Real
upper bound for `ÔÇûtrueKernel u z ┬À S uÔÇû` when `|S u| Ôëñ C log u + D`
and `u` is large enough that `ÔÇûtrueKernel u zÔÇû Ôëñ 8/u┬▓`. -/
noncomputable def trueKernelLogMajorant
    (C D : ÔäØ) (u : ÔäØ) : ÔäØ :=
  8 * (C * Real.log u + D) / u^2

/-- **Explicit primitive** of `trueKernelLogMajorant` on `u > 0`:
  `P(u) = -8(C(log u + 1) + D) / u`. -/
noncomputable def trueKernelLogMajorantPrimitive
    (C D : ÔäØ) (u : ÔäØ) : ÔäØ :=
  -8 * (C * (Real.log u + 1) + D) / u

/-- ­ƒîƒ **PROVED ÔÇö `P'(u) = M(u)`** for `u > 0`. -/
lemma hasDerivAt_trueKernelLogMajorantPrimitive
    (C D u : ÔäØ) (hu : 0 < u) :
    HasDerivAt
      (fun t => trueKernelLogMajorantPrimitive C D t)
      (trueKernelLogMajorant C D u)
      u := by
  unfold trueKernelLogMajorantPrimitive trueKernelLogMajorant
  have hu_ne : u Ôëá 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have h_log : HasDerivAt Real.log uÔü╗┬╣ u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * (Real.log t + 1) + D) (C * uÔü╗┬╣) u := by
    have h1 := h_log.add_const (1 : ÔäØ)
    have h2 := h1.const_mul C
    exact h2.add_const D
  have h_id : HasDerivAt (fun t : ÔäØ => t) (1 : ÔäØ) u := hasDerivAt_id u
  have h_div : HasDerivAt
      (fun t : ÔäØ => (C * (Real.log t + 1) + D) / t)
      ((C * uÔü╗┬╣ * u - (C * (Real.log u + 1) + D) * 1) / u^2) u :=
    h_g.div h_id hu_ne
  have h_neg8 : HasDerivAt
      (fun t : ÔäØ => -8 * ((C * (Real.log t + 1) + D) / t))
      (-8 * ((C * uÔü╗┬╣ * u - (C * (Real.log u + 1) + D) * 1) / u^2)) u :=
    h_div.const_mul (-8)
  have h_fun_eq :
      (fun t : ÔäØ => -8 * ((C * (Real.log t + 1) + D) / t))
      = (fun t : ÔäØ => -8 * (C * (Real.log t + 1) + D) / t) := by
    funext t; ring
  rw [h_fun_eq] at h_neg8
  have h_val :
      -8 * ((C * uÔü╗┬╣ * u - (C * (Real.log u + 1) + D) * 1) / u^2)
        = 8 * (C * Real.log u + D) / u^2 := by
    field_simp
    ring
  rw [h_val] at h_neg8
  exact h_neg8

/-- Ô¡É **PROVED ÔÇö majorant is continuous on `[T, X]`** for `0 < T Ôëñ X`. -/
lemma trueKernelLogMajorant_continuousOn_Icc
    (C D T X : ÔäØ) (hT : 0 < T) (_hTX : T Ôëñ X) :
    ContinuousOn (fun u => trueKernelLogMajorant C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold trueKernelLogMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.div ?_ ?_ ?_
  ┬À refine continuousAt_const.mul ?_
    refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  ┬À exact continuousAt_id.pow 2
  ┬À exact pow_ne_zero 2 (ne_of_gt hu_pos)

/-- Ô¡É **PROVED ÔÇö majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma trueKernelLogMajorant_intervalIntegrable
    (C D T X : ÔäØ) (hT : 0 < T) (hTX : T Ôëñ X) :
    IntervalIntegrable (fun u => trueKernelLogMajorant C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (trueKernelLogMajorant_continuousOn_Icc C D T X hT hTX)

/-- ­ƒîƒ **PROVED ÔÇö FTC for the majorant**:
  `Ôê½_T^X M(u) du = P(X) ÔêÆ P(T)`. -/
lemma trueKernelLogMajorant_integral_eq_sub
    (C D T X : ÔäØ) (hT : 0 < T) (hTX : T Ôëñ X) :
    (Ôê½ u in T..X, trueKernelLogMajorant C D u)
      = trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ┬À intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_trueKernelLogMajorantPrimitive C D u hu_pos
  ┬À exact trueKernelLogMajorant_intervalIntegrable C D T X hT hTX

/-- Ô¡É **PROVED ÔÇö `log X / X ÔåÆ 0`** as `X ÔåÆ Ôê×`. Via Mathlib's
`Real.tendsto_pow_log_div_mul_add_atTop` specialized to `n = 1, a = 1,
b = 0`. -/
lemma log_div_id_atTop_tendsto_zero :
    Tendsto (fun X : ÔäØ => Real.log X / X) Filter.atTop (­ØôØ 0) := by
  have := Real.tendsto_pow_log_div_mul_add_atTop (1 : ÔäØ) (0 : ÔäØ) 1
    (by norm_num : (1 : ÔäØ) Ôëá 0)
  simpa using this

/-- ­ƒîƒ **PROVED ÔÇö `P(X) ÔåÆ 0`** as `X ÔåÆ Ôê×`. The primitive splits as
constant multiples of `log X / X` and `1/X`, both vanishing. -/
lemma trueKernelLogMajorantPrimitive_tendsto_zero
    (C D : ÔäØ) :
    Tendsto (fun X : ÔäØ => trueKernelLogMajorantPrimitive C D X)
      Filter.atTop (­ØôØ 0) := by
  unfold trueKernelLogMajorantPrimitive
  have h_logterm : Tendsto (fun X : ÔäØ => (-8 * C) * (Real.log X / X))
      Filter.atTop (­ØôØ ((-8 * C) * 0)) :=
    log_div_id_atTop_tendsto_zero.const_mul (-8 * C)
  have h_constterm : Tendsto (fun X : ÔäØ => (-8 * (C + D)) * (1 / X))
      Filter.atTop (­ØôØ ((-8 * (C + D)) * 0)) :=
    (Phase1IBP.const_div_tendsto_zero_atTop (1 : ÔäØ)).const_mul (-8 * (C + D))
  have h_sum : Tendsto (fun X : ÔäØ =>
      (-8 * C) * (Real.log X / X) + (-8 * (C + D)) * (1 / X))
      Filter.atTop (­ØôØ ((-8 * C) * 0 + (-8 * (C + D)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-8 * C) * 0 + (-8 * (C + D)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : ÔäØ)] with X hX
  have hX_ne : X Ôëá 0 := ne_of_gt hX
  field_simp
  ring

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `trueKernelLogMajorantConverges`** for any `C, D,
T > 0`. The limit is `-P(T)`. -/
theorem trueKernelLogMajorantConverges
    (C D T : ÔäØ) (hT : 0 < T) :
    Tendsto (fun X : ÔäØ => Ôê½ u in T..X, trueKernelLogMajorant C D u)
      Filter.atTop (­ØôØ (-trueKernelLogMajorantPrimitive C D T)) := by
  have hprim0 := trueKernelLogMajorantPrimitive_tendsto_zero C D
  have hconst : Tendsto (fun _ : ÔäØ => trueKernelLogMajorantPrimitive C D T)
      Filter.atTop (­ØôØ (trueKernelLogMajorantPrimitive C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : ÔäØ =>
      trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T) Filter.atTop
      (­ØôØ (0 - trueKernelLogMajorantPrimitive C D T)) :=
    hprim0.sub hconst
  rw [show (0 - trueKernelLogMajorantPrimitive C D T
            = -trueKernelLogMajorantPrimitive C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  exact (trueKernelLogMajorant_integral_eq_sub C D T X hT hTX).symm

-- =====================================================================
-- ┬ºCCXXIX-4b. True-kernel adaptive complex convergence (`conv` field)
-- =====================================================================
-- Combines ┬ºCCXXIX (Cauchy comparison) + ┬ºCCXXIX-3 (kernel norm bound)
-- + ┬ºCCXXIX-4a (log majorant convergence) + ┬ºCCXXVI Turing log envelope
-- into the `conv` field of `TrueKernelTailData` for the finite-fluctuation
-- `S = finiteFluctuationPrimitive Dzero T0`.
--
-- Adds:
--   trueKernel_integrand_norm_le_logMajorant_eventually
--   trueKernelComplexTail_converges_at
--   trueKernelAdaptiveTail
--   adaptiveComplexConverges_trueKernel_of_turingBound

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö true-kernel integrand norm-majorant.** Given an
eventual log envelope on `|S u|`, the complex integrand
`ÔÇûtrueKernel u (UHP x y) ┬À (S u : Ôäé)ÔÇû` is eventually bounded by
`trueKernelLogMajorant C D u`. -/
lemma trueKernel_integrand_norm_le_logMajorant_eventually
    {S : ÔäØ ÔåÆ ÔäØ} {C D x y : ÔäØ}
    (hS : ÔêÇßÂá u in Filter.atTop, |S u| Ôëñ C * Real.log u + D) :
    ÔêÇßÂá u in Filter.atTop,
      ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : Ôäé)ÔÇû
        Ôëñ trueKernelLogMajorant C D u := by
  filter_upwards
    [norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually x y, hS]
    with u hk hSu
  have hS_norm : ÔÇû(S u : Ôäé)ÔÇû = |S u| := by simp
  have hS_bound : ÔÇû(S u : Ôäé)ÔÇû Ôëñ C * Real.log u + D := by
    rw [hS_norm]; exact hSu
  have henv_nonneg : 0 Ôëñ C * Real.log u + D :=
    le_trans (norm_nonneg ((S u : Ôäé))) hS_bound
  have h_eight_nn : 0 Ôëñ (8 : ÔäØ) / u^2 := by
    have hnn : 0 Ôëñ ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y)ÔÇû :=
      norm_nonneg _
    linarith [hnn]
  calc
    ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : Ôäé)ÔÇû
        = ÔÇûpairedCauchyComplexKernelTrue u (upperHalfPoint x y)ÔÇû
            * ÔÇû(S u : Ôäé)ÔÇû := by rw [norm_mul]
    _ Ôëñ (8 / u^2) * (C * Real.log u + D) :=
          mul_le_mul hk hS_bound (norm_nonneg _) h_eight_nn
    _ = trueKernelLogMajorant C D u := by
          unfold trueKernelLogMajorant
          ring

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö pointwise complex convergence at adaptive `(z, T)`.**
For each `(z, T)` in the adaptive band, the complex partial integrals
of `trueKernel ┬À finiteFluctuation` over `[T, X]` converge as `X ÔåÆ Ôê×`.
Routes through `improperComplexIntegralConverges_of_normMajorant` with
the log majorant from ┬ºCCXXIX-4a and the integrability from ┬ºCCXXVIII. -/
theorem trueKernelComplexTail_converges_at
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : Ôäé} {T : ÔäØ}
    (h10 : 10 Ôëñ T) (h140 : T Ôëñ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    Ôêâ L : Ôäé,
      Tendsto
        (fun X : ÔäØ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop (­ØôØ L) := by
  have hTpos : 0 < T := lt_of_lt_of_le (by norm_num : (0 : ÔäØ) < 10) h10
  have hMconv :
      Tendsto (fun X : ÔäØ =>
          Ôê½ u in T..X,
            trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u)
        Filter.atTop
        (­ØôØ (-trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)) :=
    trueKernelLogMajorantConverges (slabCD T).1 (slabCD T).2 T hTpos
  have hS_eventual :
      ÔêÇßÂá u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hTu
    exact hTuring h10 h140 hy hregime hTu
  have hbound_uhp :=
    trueKernel_integrand_norm_le_logMajorant_eventually
      (S := fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) hS_eventual
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hbound :
      ÔêÇßÂá u in Filter.atTop,
        ÔÇûpairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ÔäØ) : Ôäé)ÔÇû
          Ôëñ trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u := by
    filter_upwards [hbound_uhp] with u hu
    rw [hzUHP] at hu
    exact hu
  apply improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      pairedCauchyComplexKernelTrue u z *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ÔäØ) : Ôäé))
    (M := trueKernelLogMajorant (slabCD T).1 (slabCD T).2)
    (T := T)
    (LM := -trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)
  ┬À intro X hTX
    exact true_int_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 h10 h140 hy hregime hTX
  ┬À intro X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      (slabCD T).1 (slabCD T).2 T X hTpos hTX
  ┬À exact hMconv
  ┬À exact hbound

/-- **Adaptive tail value for the true kernel.** Uses `Classical.choose`
to extract the limit guaranteed by `trueKernelComplexTail_converges_at`
inside the adaptive band; outside the band, defined as 0. -/
noncomputable def trueKernelAdaptiveTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    (T : ÔäØ) (z : Ôäé) : Ôäé :=
  if h : 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 0 < z.im Ôêº
      2 * (1 + |z.re| + z.im) Ôëñ T then
    Classical.choose
      (trueKernelComplexTail_converges_at
        Dzero T0 hT0_pos hT0_le_10 hTuring
        h.1 h.2.1 h.2.2.1 h.2.2.2)
  else
    0

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö true-kernel adaptive complex convergence.**
The full `conv` field of `TrueKernelTailData` for the finite-fluctuation
`S`. Uses `Classical.choose_spec` to identify the tail value with the
guaranteed limit, then transports via `dif_pos` for the adaptive band. -/
noncomputable def adaptiveComplexConverges_trueKernel_of_turingBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2) :
    AdaptiveComplexDensityTailFamilyConverges
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) where
  tail := trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring
  tendsto := by
    intro T z h10 h140 hy hregime
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
    have hregion :
        10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 0 < z.im Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T :=
      Ôƒ¿h10, h140, hy, hregimeÔƒ®
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists

-- =====================================================================
-- ┬ºCCXXX. atTop-oriented `TrueKernelTailDataAtTop` + concrete inhabitation
-- =====================================================================
-- Resolves the `T Ôëñ X` mismatch: the ┬ºCCXXVII / ┬ºCCXXVIII integrability
-- proofs require `T Ôëñ X`, but `TrueKernelTailData.true_int / wrap_int`
-- quantify over all `X`. Since improper tails only use `X ÔåÆ Ôê×`, we
-- introduce an atTop-oriented data structure and build the
-- `ActualDensityTailData` / capstone chain from it directly,
-- bypassing the unnatural `X < T` case.
--
-- Adds:
--   TrueKernelTailDataAtTop                        ÔÇö atTop-oriented Type bundle
--   trueKernel_im_eq_realPartial_eventually        ÔÇö eventual Im match (atTop)
--   hbound_of_TrueKernelTailDataAtTop              ÔÇö produces hbound field
--   actualDensityTailData_of_trueKernelTailDataAtTop
--   localXiPackage_of_TrueKernelTailDataAtTop
--   trueKernelTailDataAtTop_of_finiteFluctuation   ÔÇö concrete instantiation
--   XiPullbackAntiHerglotzTarget_of_trueKernelTailDataAtTop
--                                                  ÔÇö final capstone
--   XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTailDataAtTop

/-- ­ƒôª **`TrueKernelTailDataAtTop`** ÔÇö atTop-oriented true-kernel tail
data. Mirrors `TrueKernelTailData` but with `true_int` / `wrap_int`
restricted to `T Ôëñ X` (matching the ┬ºCCXXVIIÔÇô┬ºCCXXVIII signatures and
the actual improper-tail use case `X ÔåÆ Ôê×`). -/
structure TrueKernelTailDataAtTop
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S) (error : Ôäé ÔåÆ Ôäé) where
  conv : AdaptiveComplexDensityTailFamilyConverges
            pairedCauchyComplexKernelTrue S
  true_int_atTop :
    ÔêÇ {z : Ôäé} {T X : ÔäØ},
      10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u z * (S u : Ôäé))
        MeasureTheory.volume T X
  wrap_int_atTop :
    ÔêÇ {z : Ôäé} {T X : ÔäØ},
      10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u z * (S u : Ôäé))
        MeasureTheory.volume T X
  error_im_eq_tail_im :
    ÔêÇ {z : Ôäé} {T : ÔäØ},
      10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      (error z).im = (conv.tail T z).im

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö eventual Im match for true kernel, atTop form.**
For each `(z, T)` in the adaptive band and atTop-restricted true/wrap
integrability, the imaginary part of the true-kernel complex partial
eventually equals the real derivative-side partial. -/
lemma trueKernel_im_eq_realPartial_eventually
    (S : ÔäØ ÔåÆ ÔäØ) (T : ÔäØ) (z : Ôäé)
    (htrue_int : ÔêÇ X, T Ôëñ X ÔåÆ
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelTrue u z * (S u : Ôäé))
          MeasureTheory.volume T X)
    (hwrap_int : ÔêÇ X, T Ôëñ X ÔåÆ
        IntervalIntegrable
          (fun u => pairedCauchyComplexKernelDeriv u z * (S u : Ôäé))
          MeasureTheory.volume T X) :
    ÔêÇßÂá X in Filter.atTop,
      (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im
        =
      Phase1IBP.derivativeSidePartial S z.re z.im T X := by
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have htrue_int_uhp : ÔêÇ X, T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                    * (S u : Ôäé))
        MeasureTheory.volume T X := by
    intro X hTX; rw [hzUHP]; exact htrue_int X hTX
  have hwrap_int_uhp : ÔêÇ X, T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                    * (S u : Ôäé))
        MeasureTheory.volume T X := by
    intro X hTX; rw [hzUHP]; exact hwrap_int X hTX
  have hwrap_match :=
    complexTailImaginaryPartMatchesRealIBP_pairedDeriv S z.re z.im T
  filter_upwards [hwrap_match.finite_im_eq, Filter.eventually_ge_atTop T]
    with X hwrap hTX
  have h_eq_partials :
      (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X
          (upperHalfPoint z.re z.im)).im
        =
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv S T X
          (upperHalfPoint z.re z.im)).im :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible S z.re z.im T X
      (htrue_int_uhp X hTX) (hwrap_int_uhp X hTX)
  rw [hzUHP] at h_eq_partials hwrap
  rw [h_eq_partials]
  exact hwrap

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `hbound` from `TrueKernelTailDataAtTop`.** Mirrors
`hbound_of_adaptiveComplexTailIBPBoundData` but using the eventual
finite-Im match `trueKernel_im_eq_realPartial_eventually` directly. -/
theorem hbound_of_TrueKernelTailDataAtTop
    {S : ÔäØ ÔåÆ ÔäØ} {R : RealIBPFamilyData S} {error : Ôäé ÔåÆ Ôäé}
    (D : TrueKernelTailDataAtTop S R error) :
    ÔêÇ {z : Ôäé} {T : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      |(error z).im| Ôëñ
        -Phase1IBP.derivativeSideMajorantPrimitive
          z.im (slabCD T).1 (slabCD T).2 T := by
  intro z T h10 h140 hy hregime
  obtain Ôƒ¿J, hJÔƒ® := R.deriv_tendsto h10 h140 hy hregime
  have htail_im :
      Tendsto
        (fun X : ÔäØ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im)
        Filter.atTop (­ØôØ (D.conv.tail T z).im) :=
    adaptiveComplexDensityTailFamilyPartial_im_tendsto D.conv h10 h140 hy hregime
  have hmatch_ev := trueKernel_im_eq_realPartial_eventually S T z
    (fun X hTX => D.true_int_atTop h10 h140 hy hregime hTX)
    (fun X hTX => D.wrap_int_atTop h10 h140 hy hregime hTX)
  have hmatch : Tendsto
      (fun X : ÔäØ =>
        (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im)
      Filter.atTop (­ØôØ J) := by
    have heq :
        (fun X : ÔäØ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
          =ßÂá[Filter.atTop]
        (fun X : ÔäØ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue S T X z).im) := by
      filter_upwards [hmatch_ev] with X hX
      exact hX.symm
    exact Tendsto.congr' heq hJ
  have huniq : (D.conv.tail T z).im = J :=
    tendsto_nhds_unique htail_im hmatch
  rw [D.error_im_eq_tail_im h10 h140 hy hregime, huniq]
  exact R.deriv_bound h10 h140 hy hregime hJ

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `ActualDensityTailData` from
`TrueKernelTailDataAtTop`.** Threads the atTop data into the local
package chain via `hbound_of_TrueKernelTailDataAtTop`. -/
noncomputable def actualDensityTailData_of_trueKernelTailDataAtTop
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : Ôäé ÔåÆ Ôäé)
    (hdecomp : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
          2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailDataAtTop S R error) :
    ActualDensityTailData where
  M           := M
  hM_zeros    := hM_zeros
  hmodelAnti  := hmodelAnti
  error       := error
  hdecomp     := hdecomp
  hbound      := hbound_of_TrueKernelTailDataAtTop D

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö local package from
`TrueKernelTailDataAtTop`.** -/
noncomputable def localXiPackage_of_TrueKernelTailDataAtTop
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : Ôäé ÔåÆ Ôäé)
    (hdecomp : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
          2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailDataAtTop S R error) :
