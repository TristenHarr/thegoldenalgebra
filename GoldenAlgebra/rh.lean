/-- `log(36/(2╧А)) тЙе 5/3`. Route: `exp(5/3)^3 = exp 5 = (exp 1)^5 тЙд (11/2)^3`. -/
lemma log_36_div_2pi_ge_5_3 :
    (5 / 3 : тДЭ) тЙд Real.log (36 / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.1416 := Real.pi_lt_d4
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_pow_lt :
      (Real.exp 1)^5 < (2.7182818286 : тДЭ)^5 :=
    pow_lt_pow_leftтВА h_exp_1_lt (le_of_lt h_exp_1_pos)
      (n := 5) (by norm_num)
  have h_num_pow_le : (2.7182818286 : тДЭ)^5 тЙд (11 / 2 : тДЭ)^3 := by norm_num
  have h_exp_1_pow_le : (Real.exp 1)^5 тЙд (11 / 2 : тДЭ)^3 := by linarith
  have h_exp_5_eq : Real.exp 5 = (Real.exp 1)^5 := by
    have h := Real.exp_one_pow 5
    have h_cast : ((5 : тДХ) : тДЭ) = (5 : тДЭ) := by norm_num
    rw [тЖР h_cast]; exact h.symm
  have h_exp_5_le : Real.exp 5 тЙд (11 / 2 : тДЭ)^3 := by
    rw [h_exp_5_eq]; exact h_exp_1_pow_le
  have h_exp_5_3_pow : (Real.exp (5 / 3 : тДЭ))^3 = Real.exp 5 := by
    have h := Real.exp_nat_mul (5 / 3 : тДЭ) 3
    have h_eq : ((3 : тДХ) : тДЭ) * (5 / 3 : тДЭ) = 5 := by norm_num
    rw [h_eq] at h; exact h.symm
  have h_exp_5_3_le : Real.exp (5 / 3 : тДЭ) тЙд 11 / 2 := by
    have h_pow : (Real.exp (5 / 3 : тДЭ))^3 тЙд (11 / 2 : тДЭ)^3 := by
      rw [h_exp_5_3_pow]; exact h_exp_5_le
    have h_exp_nn : 0 тЙд Real.exp (5 / 3 : тДЭ) := le_of_lt (Real.exp_pos _)
    have h_112_nn : 0 тЙд (11 / 2 : тДЭ) := by norm_num
    exact (pow_le_pow_iff_leftтВА h_exp_nn h_112_nn
      (by norm_num : (3 : тДХ) тЙа 0)).mp h_pow
  have h_112_le_36_2pi : (11 / 2 : тДЭ) тЙд 36 / (2 * Real.pi) := by
    rw [le_div_iffтВА h_2pi_pos]; nlinarith
  have h_exp_le_ratio :
      Real.exp (5 / 3 : тДЭ) тЙд 36 / (2 * Real.pi) :=
    le_trans h_exp_5_3_le h_112_le_36_2pi
  have h_exp_pos : 0 < Real.exp (5 / 3 : тДЭ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_le_ratio
  rwa [Real.log_exp] at h

