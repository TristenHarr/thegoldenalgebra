-- =====================================================================
-- ┬зCCCXIV. AFZ Stieltjes equality variants
-- =====================================================================
-- AFZ-guarded versions of B1-eq and B2-eq. These are the genuine
-- Hadamard/Stieltjes interfaces тАФ at zeros of `XiPullback`, the
-- equality has no chance of holding (Lean convention makes
-- `logDerivativeResponse XiPullback z = 0`, but the Hadamard sum
-- diverges), so the AFZ guard is what makes the hypothesis
-- mathematically inhabitable.

/-- ЁЯУж **`StieltjesMidHighTailEqualityAFZ`** тАФ AFZ B1-eq. -/
structure StieltjesMidHighTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  mid_eq :
    тИА {z : тДВ} {L : тДВ},
      0 < z.im тЖТ
      XiPullback z тЙа 0 тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L
  high_eq :
    тИА {z : тДВ} {T : тДЭ} {L : тДВ},
      140 тЙд T тЖТ
      0 < z.im тЖТ
      XiPullback z тЙа 0 тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      XiFluctuationTailValue Dzero T0 T z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- ЁЯУж **`LowFiniteStieltjesFormulaOnFirstZeroGapAFZ`** тАФ AFZ B2-eq. -/
structure LowFiniteStieltjesFormulaOnFirstZeroGapAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  formula :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      XiPullback z тЙа 0 тЖТ
      FirstZeroGapIdentityOn Dzero T0 11 14 тЖТ
      (ZC z -
          (cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = lowFiniteFluctuationContribution Dzero T0 z

/-- ЁЯУж **`XiZeroContributionStieltjesEqualitySourceAFZ`** тАФ unified AFZ
Stieltjes source. -/
structure XiZeroContributionStieltjesEqualitySourceAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
