    ┬À by_cases hU_nn : (0 : ÔäØ) Ôëñ U
      ┬À rw [dif_pos hT_nn, dif_pos hU_nn]
        simp only [Nat.cast_inj]
        change (zetaZerosUpToHeightSet_finite T hT_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity T) =
          (zetaZerosUpToHeightSet_finite U hU_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity U)
        have hfin_eq :
            (zetaZerosUpToHeightSet_finite T hT_nn).toFinset =
              (zetaZerosUpToHeightSet_finite U hU_nn).toFinset := by
          ext ¤ü
          rw [Set.Finite.mem_toFinset, Set.Finite.mem_toFinset, hset]
        refine Finset.sum_congr hfin_eq ?_
        intro ¤ü h¤ümem
        have h¤üU : ¤ü Ôêê zetaZerosUpToHeightSet U :=
          (Set.Finite.mem_toFinset _).mp h¤ümem
        have h¤üT : ¤ü Ôêê zetaZerosUpToHeightSet T := hset Ôû© h¤üU
        rw [truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity h¤üT,
            truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity h¤üU]
      ┬À push_neg at hU_nn
        rw [dif_pos hT_nn, dif_neg hU_nn.not_ge]
        have hU_empty : zetaZerosUpToHeightSet U = Ôêà := hempty_neg U hU_nn
        have hT_empty : zetaZerosUpToHeightSet T = Ôêà := hset.trans hU_empty
        have h0 : zetaWeightedZeroCountUpToHeight T hT_nn = 0 :=
          hcount_zero_of_empty hT_nn hT_empty
        rw [h0]
        norm_num
    ┬À push_neg at hT_nn
      rw [dif_neg hT_nn.not_ge]
      by_cases hU_nn : (0 : ÔäØ) Ôëñ U
      ┬À rw [dif_pos hU_nn]
        have hT_empty : zetaZerosUpToHeightSet T = Ôêà := hempty_neg T hT_nn
        have hU_empty : zetaZerosUpToHeightSet U = Ôêà := by
          rw [ÔåÉ hset]; exact hT_empty
        have h0 : zetaWeightedZeroCountUpToHeight U hU_nn = 0 :=
          hcount_zero_of_empty hU_nn hU_empty
        rw [h0]
        symm; norm_num
      ┬À push_neg at hU_nn
        rw [dif_neg hU_nn.not_ge]

