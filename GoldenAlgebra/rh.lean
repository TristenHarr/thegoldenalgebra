    rw [Complex.add_im]
    have h1 : ((1 : тДВ) / (z - (g : тДВ)) + (1 : тДВ) / (z + (g : тДВ))).im тЙд 0 :=
      paired_cauchy_kernel_im_nonpos_at z g hz
    linarith

