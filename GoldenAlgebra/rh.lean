                    Hclassical.toCompletedXiSourceAFZ)        (Stieltjes side)
+ h_Z_ge_15                                                   (trivial)
вЯє XiPullbackAntiHerglotzTarget
```

After this, the work splits cleanly:
* Hadamard side: inhabit `ClassicalPathBAnalyticInputs`.
* Stieltjes side: inhabit `XiZeroContributionStieltjesEqualitySourceAFZ`
  matched to `pullbackZeroContribution Hclassical.toCompletedXiSourceAFZ`. -/
theorem XiPullbackAntiHerglotzTarget_of_classicalPathBInputs
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    {ќє : Type}
    (h_Z_ge_15 : вИА i : вДХ, (15 : вДЭ) вЙ§ Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      вИА {z : вДВ} {T u : вДЭ},
        140 вЙ§ T вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          вЙ§ (1 / 2 : вДЭ) * Real.log u + (49 / 20 : вДЭ))
    (Hclassical : ClassicalPathBAnalyticInputs ќє)
    (Hstieltjes :
      XiZeroContributionStieltjesEqualitySourceAFZ
        Dzero 10
        (pullbackZeroContribution
          Hclassical.toCompletedXiSourceAFZ)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_completedXiHadamardAndStieltjesAFZ
    Dzero h_Z_ge_15 hTuring hHighLog
    Hclassical.toCompletedXiSourceAFZ
    Hstieltjes

