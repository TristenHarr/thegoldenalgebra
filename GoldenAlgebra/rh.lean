    have hpy_ne : (ρ ^ 2 + y ^ 2 : ℝ) ≠ 0 := ne_of_gt hpy_pos
    have h_denom : (-(ρ : ℂ) + (y : ℂ) * Complex.I) ≠ 0 := by
