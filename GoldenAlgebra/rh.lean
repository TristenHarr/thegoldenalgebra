/-- Ô¡É **PROVED ÔÇö smooth-tail LB on the full `[48, 80]` range.** Reuses
the `tailK_80_140` def since the form `(22/15)┬À(2/(2¤Ç))/T` is identical;
this lemma just establishes the underlying `2/(2¤Ç) Ôëñ ¤ü(T)` on `[48, 80]`. -/
lemma smoothTail_ge_const_48_80
    {x y T : ÔäØ}
    (hx : 0 Ôëñ x) (hT48 : 48 Ôëñ T) (hT80 : T Ôëñ 80)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) Ôëñ T) :
    y * tailK_80_140 T Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_80_140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hT_2pi : 2 * Real.pi Ôëñ T := by linarith
  have hreg' : 2 * (1 + |x| + y) Ôëñ T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : ((2 : ÔäØ) / (2 * Real.pi)) Ôëñ zeroDensityRho T :=
    zeroDensityRho_ge_const_48_80 hT48 hT80
  have h_22_15_nn : (0 : ÔäØ) Ôëñ 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : ÔäØ) * ((2 : ÔäØ) / (2 * Real.pi))
      Ôëñ (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : ÔäØ) Ôëñ y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : ÔäØ) * ((2 : ÔäØ) / (2 * Real.pi)) * y / T
        Ôëñ (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : ÔäØ) * ((2 : ÔäØ) / (2 * Real.pi)) * (y / T)
          = (22 / 15 : ÔäØ) * ((2 : ÔäØ) / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : ÔäØ) * zeroDensityRho T * (y / T)
          = (22 / 15 : ÔäØ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : ÔäØ) * zeroDensityRho T * y / T
                Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : ÔäØ) *
      ((2 : ÔäØ) / (2 * Real.pi)) / T)
      = (22 / 15 : ÔäØ) * ((2 : ÔäØ) / (2 * Real.pi)) * y / T := by ring
  rw [h_y_form]
  exact le_trans h_chain h_base

/-- Ô¡É **PROVED ÔÇö Generic tail bound `tailK_80_140 T ÔëÑ 7/(15┬ÀB)`** for
`T Ôëñ B`. Reused for each `[48, 80]` subband by setting `B` to the
subband upper endpoint. -/
lemma tailK_80_140_ge_seven_fifteen_div
    {T B : ÔäØ} (hT_pos : 0 < T) (hB_pos : 0 < B) (hT_le : T Ôëñ B) :
    (7 / (15 * B) : ÔäØ) Ôëñ tailK_80_140 T := by
  unfold tailK_80_140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_inv : (7 / 44 : ÔäØ) Ôëñ 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_inv_T : (1 / B : ÔäØ) Ôëñ 1 / T := one_div_le_one_div_of_le hT_pos hT_le
  have h_form_eq : (22 / 15 : ÔäØ) *
      ((2 : ÔäØ) / (2 * Real.pi)) / T
      = (22 / 15) * (2 : ÔäØ) * (1 / (2 * Real.pi)) * (1/T) := by ring
  rw [h_form_eq]
  have h_22_15_2_nn : (0:ÔäØ) Ôëñ (22 / 15) * (2 : ÔäØ) := by positivity
  have h_22_15_2_2pi_nn : (0:ÔäØ) Ôëñ (22 / 15) * (2 : ÔäØ) * (1 / (2 * Real.pi)) := by
    positivity
  have h2 : (22 / 15 : ÔäØ) * (2 : ÔäØ) * (7/44)
          Ôëñ (22 / 15) * (2 : ÔäØ) * (1/(2*Real.pi)) := by
    apply mul_le_mul_of_nonneg_left h_2pi_inv h_22_15_2_nn
  have h3 : (22 / 15 : ÔäØ) * (2 : ÔäØ) * (1/(2*Real.pi)) * (1/B)
          Ôëñ (22 / 15) * (2 : ÔäØ) * (1/(2*Real.pi)) * (1/T) := by
    apply mul_le_mul_of_nonneg_left h_inv_T h_22_15_2_2pi_nn
  have h_inv_B_nn : (0 : ÔäØ) Ôëñ 1/B := le_of_lt (one_div_pos.mpr hB_pos)
  have h_C_le_A :
      (22 / 15 : ÔäØ) * (2 : ÔäØ) * (7/44) * (1/B)
        Ôëñ (22 / 15) * (2 : ÔäØ) * (1/(2*Real.pi)) * (1/B) := by
    apply mul_le_mul_of_nonneg_right h2 h_inv_B_nn
  have hB_ne : B Ôëá 0 := ne_of_gt hB_pos
  have h_const_eq : (22 / 15 : ÔäØ) * (2 : ÔäØ) * (7/44) * (1/B) = 7/(15*B) := by
    field_simp
    ring
  linarith [h3, h_C_le_A, h_const_eq]

/-- Ô¡É **PROVED ÔÇö Generic closed-form upper bound for the
`(C, D) = (1/2, 49/20)` slab.**
Given `T Ôêê [A, +Ôê×)` with `Real.log T Ôëñ L`, bounds
`closedFormSErrorBoundCD (1/2) (49/20) y T` by `y ┬À ((17/2┬ÀL + 439/10)/A┬▓)`.
Each subband instantiates this with its `A` (lower endpoint) and `L`. -/
lemma closedFormSErrorBoundCD_subband_le_const
    {y T A L : ÔäØ}
    (hy : 0 Ôëñ y) (hT_pos : 0 < T) (hT_ge_one : 1 Ôëñ T)
    (hA_sq_pos : 0 < A^2) (hT2_ge : A^2 Ôëñ T^2)
    (hL_nn : 0 Ôëñ L) (hlog_le : Real.log T Ôëñ L) :
    closedFormSErrorBoundCD (1 / 2 : ÔäØ) (49 / 20 : ÔäØ) y T
      Ôëñ y * (((17/2 : ÔäØ) * L + 439/10) / A^2) := by
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have hT2pos : 0 < T^2 := by positivity
  have hlogT_nn : 0 Ôëñ Real.log T := Real.log_nonneg hT_ge_one
  have hcoeff_le :
      (17/2 : ÔäØ) * Real.log T + 439/10 Ôëñ (17/2 : ÔäØ) * L + 439/10 := by
    nlinarith
  have h_L_coeff_nn : 0 Ôëñ (17/2 : ÔäØ) * L + 439/10 := by
    have h1 : 0 Ôëñ (17/2 : ÔäØ) * L := mul_nonneg (by norm_num) hL_nn
    linarith
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  have hz_nn : 0 Ôëñ y / T^2 := div_nonneg hy (le_of_lt hT2pos)
  calc (y / T^2) * ((17/2 : ÔäØ) * Real.log T + 439/10)
        Ôëñ (y / T^2) * ((17/2 : ÔäØ) * L + 439/10) :=
          mul_le_mul_of_nonneg_left hcoeff_le hz_nn
      _ = y * (((17/2 : ÔäØ) * L + 439/10) / T^2) := by ring
      _ Ôëñ y * (((17/2 : ÔäØ) * L + 439/10) / A^2) := by
          apply mul_le_mul_of_nonneg_left _ hy
          exact div_le_div_of_nonneg_left h_L_coeff_nn hA_sq_pos hT2_ge

/-- Ô¡É **PROVED ÔÇö Generic subband assembly for `[48, 80]`.**
Given closed-form bound by a constant `C`, cloud LB `K Ôëñ cloudK_T`,
tail LB `¤ä Ôëñ tailK_80_140 T`, and scalar margin `C Ôëñ 2 K + ¤ä`,
closes the slab-cert inequality on the `x ÔëÑ 0` branch. -/
lemma slabSimple_48_80_subband_assembly
    {x y T : ÔäØ}
    (hx : 0 Ôëñ x) (hy : 0 < y)
    (hreg : 2 * (1 + x + y) Ôëñ T)
    (hT48 : 48 Ôëñ T) (hT80 : T Ôëñ 80)
    {C K ¤ä : ÔäØ}
    (hclosed_le : closedFormSErrorBoundCD (1/2 : ÔäØ) (49/20 : ÔäØ) y T Ôëñ y * C)
    (hcloud_const : K Ôëñ cloudK_T zeros100ceil T)
    (htail_const : ¤ä Ôëñ tailK_80_140 T)
    (hscalar : C Ôëñ 2 * K + ¤ä) :
    closedFormSErrorBoundCD (1/2 : ÔäØ) (49/20 : ÔäØ) y T
      Ôëñ simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hscaled : y * C Ôëñ y * (2 * K + ¤ä) :=
    mul_le_mul_of_nonneg_left hscalar hy_nn
  have hcloud : 2 * y * cloudK_T zeros100ceil T
                  Ôëñ simpleCloudSum zeros100ceil x y :=
    simpleCloudSum_ge_admissible_T_bound zeros100ceil hx hy hreg
  have htail : y * tailK_80_140 T Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_const_48_80 hx hT48 hT80 hy hreg
  have h_y_const_le_dyn :
      y * (2 * K + ¤ä)
        Ôëñ 2 * y * cloudK_T zeros100ceil T + y * tailK_80_140 T := by
    nlinarith [hy_nn, hcloud_const, htail_const]
  calc
    closedFormSErrorBoundCD (1/2 : ÔäØ) (49/20 : ÔäØ) y T
        Ôëñ y * C := hclosed_le
    _ Ôëñ y * (2 * K + ¤ä) := hscaled
    _ Ôëñ 2 * y * cloudK_T zeros100ceil T + y * tailK_80_140 T :=
        h_y_const_le_dyn
    _ Ôëñ simpleCloudSum zeros100ceil x y
          + smoothTailRationalLowerBoundAbs x y T :=
        add_le_add hcloud htail

