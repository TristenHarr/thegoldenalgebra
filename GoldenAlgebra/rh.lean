-- explicit bound function `B(u)` expected by
-- `ImaginaryStieltjesTailIBPBound`.

/-- The bound function from a `TuringStyleSBound`:
  `B(u) := C¬Јlog u + D`. -/
noncomputable def turingStyleBoundFunction
    (H : TuringStyleSBound) : вДЭ вЖТ вДЭ :=
  fun u => H.C * Real.log u + H.D

/-- в≠Р **PROVED вАФ bound function spec.** -/
theorem TuringStyleSBound.boundFunction_spec
    (H : TuringStyleSBound)
    {u : вДЭ} (hu : H.lower вЙ§ u) :
    |H.S u| вЙ§ turingStyleBoundFunction H u := by
  simpa [turingStyleBoundFunction] using H.bound u hu

/-- The bound function for the half-log-plus-half S-bound:
  `B(u) := (1/2)¬Јlog u + 1/2`. -/
noncomputable def halfLogPlusHalfBoundFunction : вДЭ вЖТ вДЭ :=
  fun u => (1 / 2 : вДЭ) * Real.log u + 1 / 2

/-- в≠Р **PROVED вАФ half-log-plus-half bound function spec.** -/
theorem HalfLogPlusHalfSBound.boundFunction_spec
    (H : HalfLogPlusHalfSBound)
    {u : вДЭ} (hu : H.lower вЙ§ u) :
    |H.S u| вЙ§ halfLogPlusHalfBoundFunction u := by
  simpa [halfLogPlusHalfBoundFunction] using H.bound u hu

-- ---------------------------------------------------------------------
-- CL-B: IBP package constructor from closed-form data
-- ---------------------------------------------------------------------
-- Inhabit `ImaginaryStieltjesTailIBPBound` from a `TuringStyleSBound`
-- plus the boundary, integral, and closed-form margin inputs. The
-- ibpMargin field is closed by the chain
--   |k(T)|¬ЈB(T) + integralBound
--     вЙ§ 8y(C¬ЈlogT + D)/T¬≤ + 18y(...)             (hboundary + hintegral)
--     = closedFormSErrorBoundCD H.C H.D y T      (rfl)
--     вЙ§ modelMargin                              (hclosed)

/-- в≠Р **PROVED вАФ IBP package constructor from a general
`TuringStyleSBound`.** Given a `TuringStyleSBound`, an adaptive cutoff
`T вЙ• H.lower`, probe coordinates `(x, y)`, a boundary term satisfying
`|k_z(T)|¬ЈB(T) вЙ§ 8y(C¬Јlog T + D)/T¬≤`, an integral upper bound
matching the IBP integral term, and a closed-form вЙ§ modelMargin
inequality, produce an `ImaginaryStieltjesTailIBPBound` whose
`ibpMargin` field is exactly the required headline IBP inequality. -/
noncomputable def ImaginaryStieltjesTailIBPBound.of_closedFormCD
    (H : TuringStyleSBound)
    (T x y integralBound modelMargin : вДЭ)
    (hTlower : H.lower вЙ§ T)
    (hboundary :
      |pairedCauchyImKernel x y T| * turingStyleBoundFunction H T
        вЙ§ 8 * y * (H.C * Real.log T + H.D) / T^2)
    (hintegral :
      integralBound вЙ§
        18 * y *
          (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
            + H.D / (2 * T^2)))
    (hclosed :
      closedFormSErrorBoundCD H.C H.D y T вЙ§ modelMargin) :
    ImaginaryStieltjesTailIBPBound where
  S := H.S
  B := turingStyleBoundFunction H
  T := T
  x := x
  y := y
  hS_bound := fun u hu =>
    H.boundFunction_spec (le_trans hTlower hu)
  integralBound := integralBound
  modelMargin := modelMargin
  ibpMargin := by
    -- Chain: |k(T)|¬ЈB(T) + integralBound
    --       вЙ§ 8y(C¬ЈlogT + D)/T¬≤ + 18y(...)
    --       = closedFormSErrorBoundCD H.C H.D y T (defn)
    --       вЙ§ modelMargin
    have h_sum_le :
        |pairedCauchyImKernel x y T| * turingStyleBoundFunction H T
            + integralBound
          вЙ§ 8 * y * (H.C * Real.log T + H.D) / T^2
              + 18 * y *
                  (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
                    + H.D / (2 * T^2)) := by
      linarith
    have h_eq :
        8 * y * (H.C * Real.log T + H.D) / T^2
            + 18 * y *
                (H.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
                  + H.D / (2 * T^2))
          = closedFormSErrorBoundCD H.C H.D y T := rfl
    linarith [h_sum_le, h_eq, hclosed]

/-- в≠Р **PROVED вАФ IBP package constructor specialized to
`HalfLogPlusHalfSBound`** (the realistic `(C = 1/2, D = 1/2)`
hypothesis). One-liner via the general constructor. -/
noncomputable def ImaginaryStieltjesTailIBPBound.of_halfLogPlusHalf
    (H : HalfLogPlusHalfSBound)
    (T x y integralBound modelMargin : вДЭ)
    (hTlower : H.lower вЙ§ T)
    (hboundary :
      |pairedCauchyImKernel x y T|
            * turingStyleBoundFunction H.toTuringStyleSBound T
        вЙ§ 8 * y * ((1 / 2 : вДЭ) * Real.log T + 1 / 2) / T^2)
    (hintegral :
      integralBound вЙ§
        18 * y *
          ((1 / 2 : вДЭ) * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
            + (1 / 2 : вДЭ) / (2 * T^2)))
    (hclosed :
      closedFormSErrorBoundCD (1 / 2 : вДЭ) (1 / 2 : вДЭ) y T вЙ§ modelMargin) :
    ImaginaryStieltjesTailIBPBound :=
  ImaginaryStieltjesTailIBPBound.of_closedFormCD
    H.toTuringStyleSBound T x y integralBound modelMargin
    hTlower hboundary hintegral hclosed

-- ---------------------------------------------------------------------
-- CLI: Per-window closed-form IBP data aggregator
-- ---------------------------------------------------------------------
-- Bundles everything an `of_closedFormCD` invocation needs into a
-- single per-window structure, plus the model / error / region /
-- modelAnti / Schwarz-symmetry-side fields needed to project onto a
-- `ZeroCountingFluctuationBound`. The intent: one inhabitant per
-- adaptive window `n`, then sequence + coverage build the family
-- structures downstream.

/-- **Per-window closed-form IBP data.** Aggregates a
`TuringStyleSBound` with the per-window decomposition data and the
analytic ingredients of an `of_closedFormCD` call. Fields:

* `S`, `model`, `error`, `region` вАФ the per-window decomp + zero-counting
  fluctuation;
* `z`, `T` вАФ the probe point and adaptive cutoff;
* `turing` + `hTlower` вАФ the Turing-style `S`-bound and `T вЙ• lower`;
* `integralBound`, `modelMargin` вАФ the abstract integral and margin
  placeholders;
* `hboundary`, `hintegral`, `hclosed` вАФ the three analytic inputs to
  `of_closedFormCD`;
* `modelMargin_eq` вАФ names the equality `modelMargin = вИТ(model z).im`;
* `modelAnti` вАФ the model is anti-Herglotz globally;
* `error_eq_S_tail` вАФ abstract `StieltjesTailIdentity`: the `error`
  contribution equals some named `tail` on the region. Refines
  what was previously the placeholder `True`.
-/
structure PerWindowClosedFormIBPData where
  S : вДЭ вЖТ вДЭ
  model : вДВ вЖТ вДВ
  error : вДВ вЖТ вДВ
  region : вДВ вЖТ Prop
  z : вДВ
  T : вДЭ
  turing : TuringStyleSBound
  hTlower : turing.lower вЙ§ T
  integralBound : вДЭ
  modelMargin : вДЭ
  hboundary :
    |pairedCauchyImKernel z.re z.im T| *
        turingStyleBoundFunction turing T
      вЙ§ 8 * z.im * (turing.C * Real.log T + turing.D) / T^2
  hintegral :
    integralBound вЙ§
      18 * z.im *
        (turing.C * (Real.log T / (2 * T^2) + 1 / (4 * T^2))
          + turing.D / (2 * T^2))
  hclosed :
    closedFormSErrorBoundCD turing.C turing.D z.im T вЙ§ modelMargin
  modelMargin_eq : modelMargin = -(model z).im
  modelAnti : AntiHerglotzUHP model
  error_eq_S_tail : StieltjesTailIdentity error region

/-- в≠Р **PROVED вАФ project per-window closed-form IBP data to an
`ImaginaryStieltjesTailIBPBound`.** One-line via CL-B
`of_closedFormCD`. -/
noncomputable def PerWindowClosedFormIBPData.toImaginaryStieltjesTailIBPBound
    (P : PerWindowClosedFormIBPData) :
    ImaginaryStieltjesTailIBPBound :=
  ImaginaryStieltjesTailIBPBound.of_closedFormCD
    P.turing P.T P.z.re P.z.im P.integralBound P.modelMargin
    P.hTlower P.hboundary P.hintegral P.hclosed

/-- в≠Р **PROVED вАФ project per-window closed-form IBP data to a
`ZeroCountingFluctuationBound`.** The `margin` field of the
fluctuation bound is the bridge hypothesis `hmargin_from_ibp` вАФ the
inequality `|Im(error z)| вЙ§ вИТIm(model z)` on the region that the IBP
machinery is meant to certify analytically. Until the explicit
Stieltjes-integral identification of `error` lands, this bridge stays
as a hypothesis. -/
noncomputable def PerWindowClosedFormIBPData.toZeroCountingFluctuationBound
    (P : PerWindowClosedFormIBPData)
    (hmargin_from_ibp :
      вИА z : вДВ, P.region z вЖТ 0 < z.im вЖТ
        |(P.error z).im| вЙ§ -(P.model z).im) :
    ZeroCountingFluctuationBound where
  S := P.S
  model := P.model
  error := P.error
  region := P.region
  modelAnti := P.modelAnti
  error_eq_S_tail := P.error_eq_S_tail
  margin := hmargin_from_ibp

-- ---------------------------------------------------------------------
-- CLII-A: Model-margin lower-bound package
-- ---------------------------------------------------------------------
-- Separates "prove a lower bound for the model margin at the probe `z`"
-- from "use that bound to close the IBP chain's `hclosed` hypothesis".

/-- **Model-margin lower bound.** Records that some explicit
`lowerBound : вДЭ` is dominated by `вИТIm(model z)` at the probe point. -/
structure ModelMarginLowerBound where
  model : вДВ вЖТ вДВ
  z : вДВ
  T : вДЭ
  lowerBound : вДЭ
  lowerBound_le : lowerBound вЙ§ -(model z).im

/-- в≠Р **PROVED вАФ lower bound on the model margin closes `hclosed`.**
If the closed-form S-error bound is dominated by the named lower bound,
it is dominated by the actual model margin `вИТIm(model z)` by transitivity. -/
theorem ModelMarginLowerBound.closes_hclosed
    (M : ModelMarginLowerBound)
    {C D : вДЭ}
    (hclosed : closedFormSErrorBoundCD C D M.z.im M.T вЙ§ M.lowerBound) :
    closedFormSErrorBoundCD C D M.z.im M.T вЙ§ -(M.model M.z).im :=
  le_trans hclosed M.lowerBound_le

-- ---------------------------------------------------------------------
-- CLII-B: Smooth-tail-only margin (model = cloud + densityTail)
-- ---------------------------------------------------------------------
-- The model splits as `cloud + densityTail` with both pieces
-- anti-Herglotz. Since `(cloud z).im вЙ§ 0`, the negative imaginary
-- margin satisfies `вИТIm(model z) вЙ• вИТIm(densityTail z)`. So it suffices
-- to lower-bound the smooth density tail alone.

/-- **Standalone smooth-tail margin lower bound.** Records that some
explicit `lowerBound` is dominated by `вИТIm(densityTail z)`. -/
structure SmoothTailMarginLowerBound where
  densityTail : вДВ вЖТ вДВ
  z : вДВ
  T : вДЭ
  lowerBound : вДЭ
  tailMargin : lowerBound вЙ§ -(densityTail z).im

/-- **Model + density-tail margin.** Aggregates a `cloud + densityTail`
decomposition with a smooth-tail-only lower bound. The cloud
contribution is allowed to be anti-Herglotz at `z` (its imaginary part
nonpositive), so the lower bound transfers from the tail to the full
model. -/
structure ModelWithDensityTailMargin where
  model : вДВ вЖТ вДВ
  cloud : вДВ вЖТ вДВ
  densityTail : вДВ вЖТ вДВ
  z : вДВ
  T : вДЭ
  lowerBound : вДЭ
  decomp : model z = cloud z + densityTail z
  cloudAntiAt : (cloud z).im вЙ§ 0
  tailMargin : lowerBound вЙ§ -(densityTail z).im

/-- в≠Р **PROVED вАФ smooth-tail-only lower bound + cloud anti-Herglotz at
`z` вЯє model-margin lower bound.**

  `вИТIm(model z) = вИТIm(cloud z) вИТ Im(densityTail z)
                вЙ• 0 + (вИТIm(densityTail z))
                вЙ• lowerBound`. -/
noncomputable def ModelWithDensityTailMargin.toModelMarginLowerBound
    (P : ModelWithDensityTailMargin) :
    ModelMarginLowerBound where
  model := P.model
  z := P.z
  T := P.T
  lowerBound := P.lowerBound
  lowerBound_le := by
    have h_im : (P.model P.z).im = (P.cloud P.z).im + (P.densityTail P.z).im := by
      rw [P.decomp, Complex.add_im]
    have h_cloud := P.cloudAntiAt
    have h_tail := P.tailMargin
    linarith

-- ---------------------------------------------------------------------
-- CLII-C: Asymptotic smooth-density-tail lower-bound skeleton
-- ---------------------------------------------------------------------

/-- **Asymptotic smooth-density-tail lower bound (named target).**
A candidate lower-bound function `bound : x y T вЖ¶ вДЭ` that dominates
`вИТIm(densityTail(x + i¬Јy))` for all `T вЙ• T0` on the canonical adaptive
`A = 2` region. Concretely, candidate forms are
  `AвВА ¬Ј y ¬Ј log T / T¬≤`  or  `AвВА ¬Ј y ¬Ј log T / T¬≤ + AвВБ ¬Ј y / T¬≤`.
The Python large-`T` tests put the candidate `AвВА` in the regime where
this bound dominates the closed-form error envelope, leaving small-`T`
to a separate finite/certificate handling.

This structure carries the candidate `bound` and a hypothesis that it
analytically lower-bounds `вИТIm densityTail` on the region. Inhabiting
it for a specific `bound` is the analytic next step. -/
structure AsymptoticSmoothDensityTailLowerBound where
  densityTail : вДВ вЖТ вДВ
  T0 : вДЭ
  bound : вДЭ вЖТ вДЭ вЖТ вДЭ вЖТ вДЭ
  hbound :
    вИА x y T : вДЭ,
      T0 вЙ§ T вЖТ 0 < y вЖТ 2 * (1 + |x| + y) вЙ§ T вЖТ
        bound x y T вЙ§ -(densityTail ((x : вДВ) + (y : вДВ) * Complex.I)).im

/-- **Projection to a per-probe `SmoothTailMarginLowerBound`** at a
specific `z = x + i¬Јy` and cutoff `T` satisfying the asymptotic
hypothesis. -/
noncomputable def AsymptoticSmoothDensityTailLowerBound.atProbe
    (A : AsymptoticSmoothDensityTailLowerBound)
    (x y T : вДЭ)
    (hT0 : A.T0 вЙ§ T) (hy : 0 < y) (hreg : 2 * (1 + |x| + y) вЙ§ T) :
    SmoothTailMarginLowerBound where
  densityTail := A.densityTail
  z := (x : вДВ) + (y : вДВ) * Complex.I
  T := T
  lowerBound := A.bound x y T
  tailMargin := A.hbound x y T hT0 hy hreg

-- ---------------------------------------------------------------------
-- CLII-D: Rational analytic lower bound for the smooth density tail
-- ---------------------------------------------------------------------
-- The Python tests identify the rational lower bound (from
-- `вИЂ_T^вИЮ y/((uвИТx)¬≤+y¬≤) du = arctan(y/(TвИТx))` and `arctan s вЙ• s/(1+s¬≤)`):
--   вИТIm D_T(z)
--     вЙ• ѕБ(T) ¬Ј ( y(TвИТ|x|)/((TвИТ|x|)¬≤+y¬≤)  +  y(T+|x|)/((T+|x|)¬≤+y¬≤) ).
-- This stays log-free inside the integral and is Lean-friendly.

/-- **Rational analytic lower bound** for `вИТIm(smooth density tail)`
at probe `(x, y)` with cutoff `T`:
  `ѕБ(T) ¬Ј ( y(T вИТ |x|)/((T вИТ |x|)¬≤ + y¬≤) + y(T + |x|)/((T + |x|)¬≤ + y¬≤) )`
where `ѕБ(T) = (1/(2ѕА))¬Јlog(T/(2ѕА))`. Pulled from
`arctan s вЙ• s/(1 + s¬≤)` applied to the elementary
`вИЂ y/((u ¬± x)¬≤ + y¬≤) du = arctan(y/(T вИУ x))`. -/
noncomputable def smoothTailRationalLowerBoundAbs (x y T : вДЭ) : вДЭ :=
  zeroDensityRho T *
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))

-- ---------------------------------------------------------------------
-- CLII-E: Smooth-tail rational margin bound package
-- ---------------------------------------------------------------------

/-- **Smooth-tail rational margin bound.** Records that the rational
lower bound dominates `вИТIm(densityTail z)` for the given probe `z` and
cutoff `T` on the canonical adaptive `A = 2` region. The analytic
content is the `lower_le_tail` field; this structure isolates it as a
single hypothesis to be discharged. -/
structure SmoothTailRationalMarginBound where
  densityTail : вДВ вЖТ вДВ
  z : вДВ
  T : вДЭ
  hT : 2 * Real.pi вЙ§ T
  hy : 0 < z.im
  hsep : |z.re| < T
  lower_le_tail :
    smoothTailRationalLowerBoundAbs z.re z.im T вЙ§ -(densityTail z).im

/-- **Projection to a per-probe `SmoothTailMarginLowerBound`.** -/
noncomputable def SmoothTailRationalMarginBound.toSmoothTailMarginLowerBound
    (P : SmoothTailRationalMarginBound) :
    SmoothTailMarginLowerBound where
  densityTail := P.densityTail
  z := P.z
  T := P.T
  lowerBound := smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T
  tailMargin := P.lower_le_tail

-- ---------------------------------------------------------------------
-- CLII-F: Closed-form S-error dominated by the rational tail
-- ---------------------------------------------------------------------

/-- **Closed-form S-error dominated by the rational smooth-tail bound.**
Records the headline numerical inequality
  `closedFormSErrorBoundCD C D z.im T вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T`
at the probe `z` and cutoff `T`. The Python adaptive sweep validates
this for `(C, D) = (1/2, 49/20)` with `T вЙ• 100` in tested regions. -/
structure ClosedFormDominatedBySmoothTail where
  z : вДВ
  T : вДЭ
  C : вДЭ
  D : вДЭ
  hdom :
    closedFormSErrorBoundCD C D z.im T
      вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T

/-- в≠Р **PROVED вАФ closed-form dominated by rational smooth-tail bound +
model-with-density-tail margin вЯє hclosed closes for the full model.**
Chain:
  `closedFormSErrorBoundCD C D z.im T`
    `вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T`  (hdom)
    `вЙ§ вИТIm(densityTail z)`                            (P.tailMargin)
    `вЙ§ вИТIm(model z)`                                  (cloud anti-Herglotz at z). -/
theorem ClosedFormDominatedBySmoothTail.closes_hclosed_via_model_decomp
    (Q : ClosedFormDominatedBySmoothTail)
    (P : SmoothTailRationalMarginBound)
    (h_z : Q.z = P.z) (h_T : Q.T = P.T)
    (cloud : вДВ вЖТ вДВ) (model : вДВ вЖТ вДВ)
    (decomp : model Q.z = cloud Q.z + P.densityTail P.z)
    (cloudAntiAt : (cloud Q.z).im вЙ§ 0) :
    closedFormSErrorBoundCD Q.C Q.D Q.z.im Q.T вЙ§ -(model Q.z).im := by
  have step1 :
      closedFormSErrorBoundCD Q.C Q.D Q.z.im Q.T
        вЙ§ smoothTailRationalLowerBoundAbs Q.z.re Q.z.im Q.T := Q.hdom
  have step2 :
      smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T
        вЙ§ -(P.densityTail P.z).im := P.lower_le_tail
  -- Identify the probes via h_z and h_T
  have h_eq : smoothTailRationalLowerBoundAbs Q.z.re Q.z.im Q.T
            = smoothTailRationalLowerBoundAbs P.z.re P.z.im P.T := by
    rw [h_z, h_T]
  have step3 :
      -(P.densityTail P.z).im вЙ§ -(model Q.z).im := by
    rw [decomp, Complex.add_im]
    linarith
  linarith [step1, step2.trans step3, h_eq]

-- ---------------------------------------------------------------------
-- CLII-G: Large-T closed-form domination target
-- ---------------------------------------------------------------------

/-- **Large-`T` closed-form domination skeleton.** Names the final
asymptotic target: for `T вЙ• T0` and the canonical adaptive `A = 2`
region, the closed-form S-error bound is dominated by the rational
smooth-tail lower bound at the same probe.

The Python evidence puts a conservative `T0 = 100` in regime where this
holds for `(C, D) = (1/2, 49/20)` and `Kd = 18`. -/
structure LargeTClosedFormDomination where
  T0 : вДЭ
  C : вДЭ
  D : вДЭ
  hdom :
    вИА x y T : вДЭ,
      T0 вЙ§ T вЖТ 0 < y вЖТ 2 * (1 + |x| + y) вЙ§ T вЖТ
        closedFormSErrorBoundCD C D y T
          вЙ§ smoothTailRationalLowerBoundAbs x y T

/-- в≠Р **PROVED вАФ large-`T` domination вЯє per-probe
`ClosedFormDominatedBySmoothTail`** for any `z = x + i¬Јy` with `T вЙ• T0`
on the canonical region. -/
noncomputable def LargeTClosedFormDomination.atProbe
    (L : LargeTClosedFormDomination)
    (x y T : вДЭ)
    (hT0 : L.T0 вЙ§ T) (hy : 0 < y) (hreg : 2 * (1 + |x| + y) вЙ§ T) :
    ClosedFormDominatedBySmoothTail where
  z := (x : вДВ) + (y : вДВ) * Complex.I
  T := T
  C := L.C
  D := L.D
  hdom := by
    have h_re : ((x : вДВ) + (y : вДВ) * Complex.I).re = x := by
      simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    have h_im : ((x : вДВ) + (y : вДВ) * Complex.I).im = y := by
      simp [Complex.add_im, Complex.mul_im, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    rw [h_re, h_im]
    exact L.hdom x y T hT0 hy hreg

-- ---------------------------------------------------------------------
-- CLIII-A: Algebraic identity for the (C, D) = (1/2, 49/20) closed form
-- ---------------------------------------------------------------------
-- Computing
--   8¬Јy¬Ј((1/2)¬Јlog T + 49/20)/T¬≤ + 18¬Јy¬Ј((1/2)¬Ј(log T/(2T¬≤) + 1/(4T¬≤)) + (49/20)/(2T¬≤))
--   = (4 + 9/2)¬Јy¬Јlog T/T¬≤ + (8¬Ј49/20 + 9/4 + 9¬Ј49/20)¬Јy/T¬≤
--   = (17/2)¬Јy¬Јlog T/T¬≤ + (98/5 + 9/4 + 441/20)¬Јy/T¬≤
--   = (17/2)¬Јy¬Јlog T/T¬≤ + (392 + 45 + 441)/20 ¬Ј y/T¬≤
--   = (17/2)¬Јy¬Јlog T/T¬≤ + (878/20)¬Јy/T¬≤
--   = (y/T¬≤) ¬Ј ((17/2)¬Јlog T + 439/10).

/-- **Closed-form S-error bound at the pinned constants `(C, D) = (1/2, 49/20)`.**
The Python validation candidate; constants chosen to match the Trudgian
envelope `|S(u)| вЙ§ (1/2)¬Јlog u + 49/20` plus the `Kd = 18` derivative
kernel. -/
noncomputable def closedFormSErrorBoundHalf4920 (y T : вДЭ) : вДЭ :=
  (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)

/-- в≠Р **PROVED вАФ `(C, D) = (1/2, 49/20)` collapse.** -/
theorem closedFormSErrorBoundCD_half_4920_eq
    {T : вДЭ} (hT : T вЙ† 0) (y : вДЭ) :
    closedFormSErrorBoundCD (1 / 2 : вДЭ) (49 / 20 : вДЭ) y T
      = closedFormSErrorBoundHalf4920 y T := by
  unfold closedFormSErrorBoundCD closedFormSErrorBoundHalf4920
  have hT2 : T^2 вЙ† 0 := pow_ne_zero 2 hT
  field_simp
  ring

-- ---------------------------------------------------------------------
-- CLIII-B: Geometric lower bound  rationalTail вЙ• (2/5)¬ЈѕБ(T)¬Јy/T
-- ---------------------------------------------------------------------
-- Discard the second term (nonnegative) and use the adaptive region:
--   |x| вЙ§ T/2,  y вЙ§ T/2,  T вИТ |x| вЙ• T/2,
--   (T вИТ |x|)¬≤ + y¬≤ вЙ§ T¬≤ + T¬≤/4 = (5/4)¬ЈT¬≤.
-- Then  y¬Ј(T вИТ |x|) / ((T вИТ |x|)¬≤ + y¬≤)  вЙ•  y¬Ј(T/2) / ((5/4)¬ЈT¬≤)  =  2y/(5T).

/-- в≠Р **PROVED вАФ rational tail dominates the elementary `(2/5)¬ЈѕБ(T)¬Јy/T`
lower bound** on the canonical adaptive `A = 2` region with `T вЙ• 2ѕА`.

This is the Lean translation of the user's "discard the second term,
bound the first" argument. -/
theorem smoothTailRationalLowerBoundAbs_ge_geometric
    {x y T : вДЭ}
    (hT : 2 * Real.pi вЙ§ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) вЙ§ T) :
    (2 / 5) * zeroDensityRho T * y / T
      вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  -- ѕБ(T) вЙ• 0 from T вЙ• 2ѕА
  have hѕБ_nn : 0 вЙ§ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_nn : 0 вЙ§ T := le_of_lt hT_pos
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  -- Adaptive вЗТ |x| вЙ§ T/2 and y вЙ§ T/2
  have hx_le : |x| вЙ§ T / 2 := by linarith
  have hy_le : y вЙ§ T / 2 := by linarith
  -- T вИТ |x| вЙ• T/2 > 0, T + |x| > 0
  have h_tmx_ge_half : T / 2 вЙ§ T - |x| := by linarith
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 вЙ§ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 вЙ§ T + |x| := le_of_lt h_tpx_pos
  have h_tmx_le_T : T - |x| вЙ§ T := by linarith
  -- Denominators positive
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- Second term вЙ• 0
  have h_term2_nn :
      0 вЙ§ y * (T + |x|) / ((T + |x|)^2 + y^2) :=
    div_nonneg (mul_nonneg hy_nn h_tpx_nn) (le_of_lt h_denom2_pos)
  -- Numerator bound: y¬Ј(T/2) вЙ§ y¬Ј(T вИТ |x|)
  have h_num_ge : y * (T / 2) вЙ§ y * (T - |x|) :=
    mul_le_mul_of_nonneg_left h_tmx_ge_half hy_nn
  -- Denominator bound: (T вИТ |x|)¬≤ + y¬≤ вЙ§ (5/4)¬ЈT¬≤
  have h_tmx_sq_le : (T - |x|)^2 вЙ§ T^2 :=
    pow_le_pow_leftвВА h_tmx_nn h_tmx_le_T 2
  have hy_sq_le : y^2 вЙ§ T^2 / 4 := by
    have h := pow_le_pow_leftвВА hy_nn hy_le 2
    calc y^2 вЙ§ (T / 2)^2 := h
      _ = T^2 / 4 := by ring
  have h_denom1_le : (T - |x|)^2 + y^2 вЙ§ (5 / 4) * T^2 := by
    have : T^2 + T^2 / 4 = (5 / 4) * T^2 := by ring
    linarith [h_tmx_sq_le, hy_sq_le]
  -- First term вЙ• y(T/2) / ((5/4)¬ЈT¬≤) via div_le_divвВА
  have h_term1_ge_raw :
      y * (T / 2) / ((5 / 4) * T^2)
        вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    apply div_le_divвВА
    ¬Ј exact mul_nonneg hy_nn h_tmx_nn
    ¬Ј exact h_num_ge
    ¬Ј exact h_denom1_pos
    ¬Ј exact h_denom1_le
  -- Simplify  y(T/2) / ((5/4)¬ЈT¬≤)  =  2y/(5T)
  have h_simp :
      y * (T / 2) / ((5 / 4) * T^2) = 2 * y / (5 * T) := by
    have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
    field_simp
    ring
  rw [h_simp] at h_term1_ge_raw
  -- Combine: 2y/(5T) вЙ§ term1 вЙ§ term1 + term2
  have h_sum_ge :
      2 * y / (5 * T)
        вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    linarith
  -- Multiply by ѕБ(T) вЙ• 0
  have h_mul_le :
      zeroDensityRho T * (2 * y / (5 * T))
        вЙ§ zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge hѕБ_nn
  -- Final reshuffle: (2/5)¬ЈѕБ(T)¬Јy/T = ѕБ(T)¬Ј(2y/(5T))
  have h_eq :
      (2 / 5) * zeroDensityRho T * y / T
        = zeroDensityRho T * (2 * y / (5 * T)) := by
    have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
    field_simp
    ring
  rw [h_eq]
  exact h_mul_le

-- ---------------------------------------------------------------------
-- CLIII-C: Scalar sufficient condition + bridge
-- ---------------------------------------------------------------------

/-- **Scalar large-`T` margin condition.** The one-variable inequality
that, on the adaptive `A = 2` region with `T вЙ• 2ѕА`, implies the full
three-variable closed-form domination at `(C, D) = (1/2, 49/20)`. -/
noncomputable def largeTScalarMarginCondition (T : вДЭ) : Prop :=
  (17 / 2) * Real.log T + 439 / 10
    вЙ§ (T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi))

/-- в≠Р **PROVED вАФ scalar condition вЯє three-variable closed-form
domination at `(C, D) = (1/2, 49/20)`.**

Chain (cancelling `y > 0` and `T > 0`):
  `(y/T¬≤) ¬Ј ((17/2)¬Јlog T + 439/10)`
    `вЙ§ (y/T¬≤) ¬Ј (T/(5ѕА)) ¬Ј log(T/(2ѕА))   (scalar condition)`
    `= (2/5) ¬Ј ѕБ(T) ¬Ј y / T              (since (T/(5ѕА))¬Јlog(T/(2ѕА)) = (2/5)¬ЈѕБ(T)¬ЈT)`
    `вЙ§ smoothTailRationalLowerBoundAbs x y T   (CLIII-B). -/
theorem largeTScalarCondition_implies_domination
    {x y T : вДЭ}
    (hT100 : 100 вЙ§ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) вЙ§ T)
    (hscalar : largeTScalarMarginCondition T) :
    closedFormSErrorBoundCD (1 / 2 : вДЭ) (49 / 20 : вДЭ) y T
      вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  -- Numerical: 2ѕА < 100
  have h_2pi_lt_100 : 2 * Real.pi < 100 := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hT2pi : 2 * Real.pi вЙ§ T := le_trans (le_of_lt h_2pi_lt_100) hT100
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT2_pos : 0 < T^2 := by positivity
  have hT2_ne : T^2 вЙ† 0 := ne_of_gt hT2_pos
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  -- Step 1: rewrite LHS at the pinned constants
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  -- Step 2: scalar bound вЗТ (y/T¬≤)¬ЈLHS вЙ§ (y/T¬≤)¬ЈRHS
  have h_yT2_nn : 0 вЙ§ y / T^2 :=
    div_nonneg hy_nn (le_of_lt hT2_pos)
  have h_step2 :
      (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)
        вЙ§ (y / T^2) * ((T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi))) :=
    mul_le_mul_of_nonneg_left hscalar h_yT2_nn
  -- Step 3: (y/T¬≤)¬Ј(T/(5ѕА))¬Јlog(T/(2ѕА)) = (2/5)¬ЈѕБ(T)¬Јy/T
  have h_step3 :
      (y / T^2) * ((T / (5 * Real.pi)) * Real.log (T / (2 * Real.pi)))
        = (2 / 5) * zeroDensityRho T * y / T := by
    unfold zeroDensityRho
    have hpi_ne : (Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_pi_pos
    field_simp
    ring
  rw [h_step3] at h_step2
  -- Step 4: chain with CLIII-B
  have h_geom :
      (2 / 5) * zeroDensityRho T * y / T
        вЙ§ smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_geometric hT2pi hy hadapt
  linarith

-- ---------------------------------------------------------------------
-- CLIII-D: LargeTClosedFormDomination from the scalar hypothesis
-- ---------------------------------------------------------------------

/-- **Scalar large-`T` margin hypothesis.** Names the single
1-variable inequality that has to be established (by hand or numerically)
to discharge `LargeTClosedFormDomination` at the pinned constants. -/
structure LargeTScalarMarginHypothesis where
  T0 : вДЭ
  T0_ge : 100 вЙ§ T0
  scalar : вИА T : вДЭ, T0 вЙ§ T вЖТ largeTScalarMarginCondition T

/-- в≠Р **PROVED вАФ `LargeTScalarMarginHypothesis` вЯє `LargeTClosedFormDomination`
at `(C, D) = (1/2, 49/20)`.**

This is the final scalar-reduction constructor: every hypothesis on the
three-variable closed-form domination is now traceable to the named
scalar inequality. -/
noncomputable def LargeTClosedFormDomination.of_scalarHypothesis
    (H : LargeTScalarMarginHypothesis) :
    LargeTClosedFormDomination where
  T0 := H.T0
  C := 1 / 2
  D := 49 / 20
  hdom := fun x y T hT0le hy hreg => by
    have hT100 : 100 вЙ§ T := le_trans H.T0_ge hT0le
    exact largeTScalarCondition_implies_domination
            hT100 hy hreg (H.scalar T hT0le)

-- ---------------------------------------------------------------------
-- CLIV-A: Sharper geometric lower bound вАФ constant 2/3
-- ---------------------------------------------------------------------
-- The Python sweep shows the true universal constant on the adaptive
-- region is вЙИ 8/5 (worst case at r = 0, s = 1/2). The 2/5 bound is
-- extremely conservative. The 2/3 bound is still safe and drops the
-- scalar threshold from ~364 to ~236.
--
-- Decomposition via YвВБ/YвВВ:
--   YвВБ = y(TвИТ|x|)/((TвИТ|x|)¬≤ + y¬≤) вЙ• y/(2T)
--     вЯЇ T¬≤ вЙ• |x|¬≤ + y¬≤  (since 2T(T-|x|) вИТ ((T-|x|)¬≤ + y¬≤) = T¬≤ вИТ |x|¬≤ вИТ y¬≤),
--     which holds because (|x| + y)¬≤ вЙ§ T¬≤/4 вЙ§ T¬≤.
--   YвВВ = y(T+|x|)/((T+|x|)¬≤ + y¬≤) вЙ• y/(6T)
--     via (T+|x|)¬≤ + y¬≤ вЙ§ 9T¬≤/4 + T¬≤/4 = 5T¬≤/2 вЙ§ 6T¬≤ вЙ§ 6T(T+|x|).
--   Sum:  YвВБ + YвВВ вЙ• y/(2T) + y/(6T) = 2y/(3T).

/-- в≠Р **PROVED вАФ sharper rational tail lower bound, constant 2/3.**

On the canonical adaptive `A = 2` region with `T вЙ• 2ѕА`:
  `smoothTailRationalLowerBoundAbs x y T вЙ• (2/3) ¬Ј ѕБ(T) ¬Ј y / T`.

Drops the scalar threshold from ~364 to ~236. -/
theorem smoothTailRationalLowerBoundAbs_ge_twoThirds
    {x y T : вДЭ}
    (hT : 2 * Real.pi вЙ§ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) вЙ§ T) :
    (2 / 3) * zeroDensityRho T * y / T
      вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  have hѕБ_nn : 0 вЙ§ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT_nn : 0 вЙ§ T := le_of_lt hT_pos
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  have hx_le : |x| вЙ§ T / 2 := by linarith
  have hy_le : y вЙ§ T / 2 := by linarith
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 вЙ§ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 вЙ§ T + |x| := le_of_lt h_tpx_pos
  have h_tpx_le : T + |x| вЙ§ 3 * T / 2 := by linarith
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- (|x| + y) вЙ§ T/2, hence (|x|+y)¬≤ вЙ§ T¬≤/4, hence |x|¬≤ + y¬≤ вЙ§ T¬≤/4 вЙ§ T¬≤
  have h_xy_sum_le : |x| + y вЙ§ T / 2 := by linarith
  have h_xy_sum_nn : 0 вЙ§ |x| + y := by positivity
  have h_xy_sum_sq_le : (|x| + y)^2 вЙ§ (T / 2)^2 :=
    pow_le_pow_leftвВА h_xy_sum_nn h_xy_sum_le 2
  have h_xy_sq_le : |x|^2 + y^2 вЙ§ T^2 / 4 := by
    have hexp : (|x| + y)^2 = |x|^2 + 2 * |x| * y + y^2 := by ring
    have hxy_prod_nn : 0 вЙ§ 2 * |x| * y := by positivity
    have h_halfT_sq : (T / 2)^2 = T^2 / 4 := by ring
    nlinarith [h_xy_sum_sq_le, hxy_prod_nn, hexp, h_halfT_sq]
  have h_T_sq_nn : 0 вЙ§ T^2 := sq_nonneg T
  have h_x_sq_y_sq_le_T_sq : |x|^2 + y^2 вЙ§ T^2 := by nlinarith
  -- Step 1: YвВБ вЙ• y/(2T) via 2T(T-|x|) вИТ ((T-|x|)¬≤+y¬≤) = T¬≤ вИТ |x|¬≤ вИТ y¬≤ вЙ• 0
  have h_alg1 : 2 * T * (T - |x|) - ((T - |x|)^2 + y^2)
              = T^2 - |x|^2 - y^2 := by ring
  have h_alg1_nn : 0 вЙ§ 2 * T * (T - |x|) - ((T - |x|)^2 + y^2) := by
    rw [h_alg1]; linarith
  have h_2T_pos : 0 < 2 * T := by linarith
  have h_Y1_ge :
      y / (2 * T) вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    rw [div_le_div_iffвВА h_2T_pos h_denom1_pos]
    have h_calc :
        y * (T - |x|) * (2 * T) - y * ((T - |x|)^2 + y^2)
          = y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) := by ring
    have h_nn :
        0 вЙ§ y * (2 * T * (T - |x|) - ((T - |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg1_nn
    linarith
  -- Step 2: YвВВ вЙ• y/(6T) via (T+|x|)¬≤ + y¬≤ вЙ§ 5T¬≤/2 вЙ§ 6T¬≤ вЙ§ 6T(T+|x|)
  have h_y_sq_le : y^2 вЙ§ T^2 / 4 := by
    have h := pow_le_pow_leftвВА hy_nn hy_le 2
    calc y^2 вЙ§ (T / 2)^2 := h
      _ = T^2 / 4 := by ring
  have h_tpx_sq_le : (T + |x|)^2 вЙ§ 9 * T^2 / 4 := by
    have h := pow_le_pow_leftвВА h_tpx_nn h_tpx_le 2
    calc (T + |x|)^2 вЙ§ (3 * T / 2)^2 := h
      _ = 9 * T^2 / 4 := by ring
  have h_alg2_bound : (T + |x|)^2 + y^2 вЙ§ 5 * T^2 / 2 := by
    have h_id : 9 * T^2 / 4 + T^2 / 4 = 5 * T^2 / 2 := by ring
    linarith
  have h_6T_tpx_ge_6T_sq : 6 * T^2 вЙ§ 6 * T * (T + |x|) := by
    have h_diff_id : 6 * T * (T + |x|) - 6 * T^2 = 6 * T * |x| := by ring
    have h_diff_nn : 0 вЙ§ 6 * T * |x| := by positivity
    linarith
  have h_alg2_ineq : (T + |x|)^2 + y^2 вЙ§ 6 * T * (T + |x|) := by
    have h_52_le_6 : 5 * T^2 / 2 вЙ§ 6 * T^2 := by nlinarith [h_T_sq_nn]
    linarith
  have h_6T_pos : 0 < 6 * T := by linarith
  have h_Y2_ge :
      y / (6 * T) вЙ§ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    rw [div_le_div_iffвВА h_6T_pos h_denom2_pos]
    have h_calc :
        y * (T + |x|) * (6 * T) - y * ((T + |x|)^2 + y^2)
          = y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) := by ring
    have h_nn :
        0 вЙ§ y * (6 * T * (T + |x|) - ((T + |x|)^2 + y^2)) :=
      mul_nonneg hy_nn (by linarith)
    linarith
  -- Step 3: Combine вАФ y/(2T) + y/(6T) = 2y/(3T)
  have h_sum_eq : y / (2 * T) + y / (6 * T) = 2 * y / (3 * T) := by
    field_simp; ring
  have h_sum_ge :
      2 * y / (3 * T)
        вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h := add_le_add h_Y1_ge h_Y2_ge
    rw [h_sum_eq] at h
    exact h
  -- Multiply by ѕБ(T) вЙ• 0
  have h_mul :
      zeroDensityRho T * (2 * y / (3 * T))
        вЙ§ zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge hѕБ_nn
  -- Reshuffle: (2/3) ¬Ј ѕБ(T) ¬Ј y / T = ѕБ(T) ¬Ј (2y / (3T))
  have h_eq :
      (2 / 3) * zeroDensityRho T * y / T
        = zeroDensityRho T * (2 * y / (3 * T)) := by
    field_simp; ring
  rw [h_eq]
  exact h_mul

-- ---------------------------------------------------------------------
-- CLIV-B: Scalar condition for the (2/3) route
-- ---------------------------------------------------------------------

/-- **Scalar large-`T` margin condition at constant `c = 2/3`.**
The improved sufficient condition: `(cT/(2ѕА))¬Јlog(T/(2ѕА)) вЙ• (17/2)¬Јlog T + 439/10`
specialized to `c = 2/3` gives `(T/(3ѕА))¬Јlog(T/(2ѕА))`.

Python: this scalar crosses zero at `T вЙИ 236`; `T0 = 250` is the clean
