    (Hstieltjes :
      XiZeroContributionStieltjesEqualitySourceAFZ
        Dzero 10 (pullbackZeroContribution Hhad)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAFZAndStieltjesAFZ
