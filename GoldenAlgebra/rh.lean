/-! ## CR: Functional-equation left-edge zero transfer (proof attempt) -/

/-- `cos(¤Ç * Ôƒ¿2, -yÔƒ® / 2) = -cosh(¤Çy/2)`.  Decomposes the argument as
`¤Ç + (-¤Çy/2)┬ÀI` and uses the angle-addition formula + `cos(x┬ÀI) = cosh x`. -/
theorem cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh (y : ÔäØ) :
    Complex.cos ((Real.pi : Ôäé) * (Ôƒ¿2, -yÔƒ® : Ôäé) / 2) =
      -((Real.cosh (Real.pi * y / 2) : ÔäØ) : Ôäé) := by
  have h_decomp :
      ((Real.pi : Ôäé) * (Ôƒ¿2, -yÔƒ® : Ôäé) / 2) =
        (Real.pi : Ôäé) + (-((Real.pi * y / 2 : ÔäØ) : Ôäé)) * Complex.I := by
    apply Complex.ext
    ┬À simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_re,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
    ┬À simp [Complex.mul_re, Complex.mul_im, Complex.div_re, Complex.div_im,
            Complex.ofReal_re, Complex.ofReal_im, Complex.add_im,
            Complex.neg_re, Complex.neg_im, Complex.I_re, Complex.I_im,
            Complex.normSq_apply]
      ring
  rw [h_decomp, Complex.cos_add]
  have h_cos_pi : Complex.cos (Real.pi : Ôäé) = -1 := by
    rw [ÔåÉ Complex.ofReal_cos, Real.cos_pi]; push_cast; rfl
  have h_sin_pi : Complex.sin (Real.pi : Ôäé) = 0 := by
    rw [ÔåÉ Complex.ofReal_sin, Real.sin_pi]; push_cast; rfl
  rw [h_cos_pi, h_sin_pi]
  rw [Complex.cos_mul_I]
  rw [show -((Real.pi * y / 2 : ÔäØ) : Ôäé) = -(((Real.pi * y / 2 : ÔäØ) : Ôäé)) from rfl,
      Complex.cosh_neg]
  rw [Complex.ofReal_cosh]
  ring

/-- Nonvanishing of the cosine factor in the FE at `s = Ôƒ¿2, -yÔƒ®`. -/
theorem cos_pi_mul_twoMinusYI_div_two_ne_zero (y : ÔäØ) :
    Complex.cos ((Real.pi : Ôäé) * (Ôƒ¿2, -yÔƒ® : Ôäé) / 2) Ôëá 0 := by
  rw [cos_pi_mul_twoMinusYI_div_two_eq_neg_cosh]
  rw [neg_ne_zero, Complex.ofReal_ne_zero]
  exact (Real.cosh_pos _).ne'

/-- **CR ÔÇö PROVED:** the functional-equation left-edge nonzero transfer.
At `s = Ôƒ¿2, -yÔƒ®` we apply `riemannZeta_one_sub` and show every factor on
the right is nonzero. -/
theorem zetaFunctionalEquationLeftEdgeTransfer :
    ZetaFunctionalEquationLeftEdgeTransfer := by
  intro y _hright
  set s : Ôäé := Ôƒ¿2, -yÔƒ® with hs_def
  have h_s_re : s.re = 2 := by simp [hs_def]
  have h_one_sub_s : (1 : Ôäé) - s = Ôƒ¿(-1 : ÔäØ), yÔƒ® := by
    apply Complex.ext
    ┬À show (1 - s).re = -1
      simp [hs_def, Complex.sub_re, Complex.one_re]
      norm_num
    ┬À show (1 - s).im = y
      simp [hs_def, Complex.sub_im, Complex.one_im]
  have h_s_ne_neg_n : ÔêÇ n : Ôäò, s Ôëá -Ôåæn := by
    intro n h
    have h_re : s.re = (-(n : Ôäé)).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (╬▒ := ÔäØ) n]
  have h_s_ne_one : s Ôëá 1 := by
    intro h
    have h_re : s.re = (1 : Ôäé).re := congrArg Complex.re h
    rw [h_s_re] at h_re
    simp at h_re
  rw [ÔåÉ h_one_sub_s, riemannZeta_one_sub h_s_ne_neg_n h_s_ne_one]
  have h_2pi_ne_C : ((2 : Ôäé) * (Real.pi : Ôäé)) Ôëá 0 := by
    have h¤Ç : (Real.pi : Ôäé) Ôëá 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) h¤Ç
  have h_2pi_pow : ((2 * (Real.pi : Ôäé)) ^ (-s)) Ôëá 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s Ôëá 0 := by
    apply Complex.Gamma_ne_zero_of_re_pos
    rw [h_s_re]; norm_num
  have h_zeta_ne : riemannZeta s Ôëá 0 := by
    apply riemannZeta_ne_zero_of_one_lt_re
    rw [h_s_re]; norm_num
  have h_cos_ne : Complex.cos ((Real.pi : Ôäé) * s / 2) Ôëá 0 := by
    rw [hs_def]
    exact cos_pi_mul_twoMinusYI_div_two_ne_zero y
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  ┬À norm_num
  ┬À exact h_2pi_pow
  ┬À exact h_gamma_ne
  ┬À exact h_cos_ne
  ┬À exact h_zeta_ne

/-! ## CS: No zeros of `╬Â` in the left half-plane upper half -/

/-- `Complex.cos w Ôëá 0` whenever `w.im Ôëá 0`.  Zeros of `cos` are real
half-odd-integer multiples of `¤Ç`, so any complex `w` with nonzero
imaginary part avoids them. -/
theorem Complex.cos_ne_zero_of_im_ne_zero
    {w : Ôäé} (hw : w.im Ôëá 0) :
    Complex.cos w Ôëá 0 := by
  rw [Complex.cos_ne_zero_iff]
  intro k heq
  have h_im_eq :
      w.im = ((2 * (k : Ôäé) + 1) * (Real.pi : Ôäé) / 2).im :=
    congrArg Complex.im heq
  have h_rhs_im : ((2 * (k : Ôäé) + 1) * (Real.pi : Ôäé) / 2).im = 0 := by
    simp [Complex.div_im, Complex.mul_im, Complex.add_im, Complex.intCast_im,
          Complex.ofReal_re, Complex.ofReal_im, Complex.one_im,
          Complex.normSq_apply]
  rw [h_rhs_im] at h_im_eq
  exact hw h_im_eq

/-- **CS ÔÇö PROVED:** `╬Â` has no zeros at points with `Re Ôëñ 0` and `Im > 0`.
Functional equation: ╬Â(1-s) = factors ┬À ╬Â(s), at `s = 1 - z` (so `Re s ÔëÑ 1`,
`Im s = -Im z < 0`).  RHS factors are all nonzero (`╬ô(s) Ôëá 0` since
`Re s > 0`; `╬Â(s) Ôëá 0` since `Re s ÔëÑ 1`; `cos(¤Çs/2) Ôëá 0` since `Im s Ôëá 0`;
`(2¤Ç)^(-s) Ôëá 0`; `2 Ôëá 0`).  Contradicts `╬Â z = ╬Â(1-s) = 0`. -/
theorem zetaNoZerosLeftHalfPlaneUpper : ZetaNoZerosLeftHalfPlaneUpper := by
  intro z hzRe hzIm hzeta
  set s : Ôäé := 1 - z with hs_def
  have hs_re : s.re = 1 - z.re := by simp [hs_def]
  have hs_im : s.im = -z.im := by simp [hs_def]
  have hs_re_ge_one : 1 Ôëñ s.re := by rw [hs_re]; linarith
  have hs_re_pos : 0 < s.re := by linarith
  have hs_im_neg : s.im < 0 := by rw [hs_im]; linarith
  have hs_im_ne : s.im Ôëá 0 := ne_of_lt hs_im_neg
  have h_zeta_s_ne : riemannZeta s Ôëá 0 :=
    riemannZeta_ne_zero_of_one_le_re hs_re_ge_one
  have hs_ne_neg_n : ÔêÇ n : Ôäò, s Ôëá -Ôåæn := by
    intro n h
    have h_re : s.re = (-(n : Ôäé)).re := congrArg Complex.re h
    rw [hs_re] at h_re
    simp at h_re
    linarith [Nat.cast_nonneg (╬▒ := ÔäØ) n]
  have hs_ne_one : s Ôëá 1 := by
    intro h
    have h_im : s.im = (1 : Ôäé).im := congrArg Complex.im h
    simp at h_im
    linarith
  have h_1s_z : (1 : Ôäé) - s = z := by simp [hs_def]
  have hFE := riemannZeta_one_sub hs_ne_neg_n hs_ne_one
  rw [h_1s_z, hzeta] at hFE
  apply absurd hFE.symm
  have h_2pi_ne_C : ((2 : Ôäé) * (Real.pi : Ôäé)) Ôëá 0 := by
    have h¤Ç : (Real.pi : Ôäé) Ôëá 0 :=
      Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
    exact mul_ne_zero (by norm_num) h¤Ç
  have h_2pi_pow : ((2 * (Real.pi : Ôäé)) ^ (-s)) Ôëá 0 :=
    Complex.cpow_ne_zero_iff.mpr (Or.inl h_2pi_ne_C)
  have h_gamma_ne : Complex.Gamma s Ôëá 0 :=
    Complex.Gamma_ne_zero_of_re_pos hs_re_pos
  have h_cos_ne : Complex.cos ((Real.pi : Ôäé) * s / 2) Ôëá 0 := by
    apply Complex.cos_ne_zero_of_im_ne_zero
    have h_arg_im : ((Real.pi : Ôäé) * s / 2).im = Real.pi * s.im / 2 := by
      simp [Complex.div_im, Complex.mul_im, Complex.ofReal_re,
            Complex.ofReal_im, Complex.normSq_apply]
    rw [h_arg_im]
    have hpi_pos : 0 < Real.pi := Real.pi_pos
    intro h
    have : Real.pi * s.im = 0 := by linarith
    rcases mul_eq_zero.mp this with h1 | h2
    ┬À exact absurd h1 hpi_pos.ne'
    ┬À exact hs_im_ne h2
  refine mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_) ?_
  ┬À norm_num
  ┬À exact h_2pi_pow
  ┬À exact h_gamma_ne
  ┬À exact h_cos_ne
  ┬À exact h_zeta_s_ne

