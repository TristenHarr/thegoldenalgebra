noncomputable def CompletedXiHadamardProductWithZeros.of_factorization_luc_invSq
    {ќє : Type} {zeroLoc : ќє вЖТ вДВ}
    {prefactor : вДВ вЖТ вДВ}
    (Hinv : HadamardZeroInvSqSummability zeroLoc)
    (Hluc : HadamardProductLUCLogDerivData zeroLoc)
    (Hregion : вИА s : вДВ, completedXiFunction s вЙ† 0 вЖТ s вИИ Hluc.region)
    (HnonzeroRegion : вИА s вИИ Hluc.region, вИА i, s вЙ† zeroLoc i)
    (Hfact :
      вИА s : вДВ,
        completedXiFunction s = prefactor s * infiniteHadamardProduct zeroLoc s)
    (Hpref_diff :
      вИА s : вДВ,
        completedXiFunction s вЙ† 0 вЖТ DifferentiableAt вДВ prefactor s)
    (Hpref_ne :
      вИА s : вДВ,
        completedXiFunction s вЙ† 0 вЖТ prefactor s вЙ† 0) :
    CompletedXiHadamardProductWithZeros ќє := by
  refine
    { zeroLoc := zeroLoc
      prefactor := prefactor
      prefactor_differentiable_at := Hpref_diff
      prefactor_ne_zero := Hpref_ne
      xi_eq_product := Hfact
      product_data := ?_ }
  exact
    HadamardLocallyUniformProductData.of_logDerivLimitData
      Hinv.product_multipliable
