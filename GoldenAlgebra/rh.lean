                      (Or.inr (List.mem_cons_self ..))))))))))
      push_neg at h6
      by_cases h7 : T Ôëñ 48
      ┬À refine Ôƒ¿s7, ?_, le_of_lt h6, h7Ôƒ®
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons.mpr
                        (Or.inr (List.mem_cons_self ..))))))))))))
      push_neg at h7
      by_cases h8 : T Ôëñ 80
      ┬À refine Ôƒ¿s8, ?_, le_of_lt h7, h8Ôƒ®
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons.mpr
                        (Or.inr (List.mem_cons.mpr
                          (Or.inr (List.mem_cons_self ..))))))))))))))
      push_neg at h8
      refine Ôƒ¿s9, ?_, le_of_lt h8, hT140Ôƒ®
      exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
              (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons.mpr
                        (Or.inr (List.mem_cons.mpr
                          (Or.inr (List.mem_cons_self ..))))))))))))))))
  }

/-- Ô¡É **PROVED ÔÇö top-level closure on `[10, 140]`.** Given the 9 slab
certificates, for any probe `(z, T)` in the band with the adaptive
constraint, the closed-form S-error bound (at the appropriate per-slab
`(C, D)`) is dominated by `ÔêÆIm(model z)`.

The witness `(C, D)` is read off from whichever slab covers `T`.
Combined with the analytic CLV/CLVII chain for `T ÔëÑ 140` and a future
`FirstZeroBandCertificate` instance for `[2¤Ç, 10]`, this gives the
unconditional `hclosed` chain on the entire admissible band. -/
theorem hclosed_on_10_140
    (model : Ôäé ÔåÆ Ôäé)
    (cert_10_12 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 10 Ôëñ T ÔåÆ T Ôëñ 12 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        closedFormSErrorBoundCD 0 (21/100 : ÔäØ) z.im T Ôëñ -(model z).im)
    (cert_12_13 : ÔêÇ z : Ôäé, ÔêÇ T : ÔäØ, 12 Ôëñ T ÔåÆ T Ôëñ 13 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
