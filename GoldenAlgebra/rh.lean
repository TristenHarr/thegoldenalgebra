          + xiCloudDensityModel_zeros100ceil.densityTail z).im вЙ§ 0
  rw [Complex.add_im]
  have hcloud : (cloudModel xiCloudDensityModel_zeros100ceil.zeros z).im вЙ§ 0 :=
    cloudModel_im_nonpos _ hz
  have htail : (xiCloudDensityModel_zeros100ceil.densityTail z).im вЙ§ 0 := by
    show (linearDensityTail100 z).im вЙ§ 0
    exact linearDensityTail100_im_nonpos hz
  linarith

/-- в≠Р **PROVED вАФ Specialized adapter for `[10, 140]` slab region.**
Specialization of `localPackage_of_finiteBandSandwich` where the sandwich is
provided by `hclosed_on_10_140_zeros100ceil` (slab bundle) plus a separately
supplied error bound from the IBP machinery.

Given an IBP-derived error bound `|Im(error z)| вЙ§ closedFormSErrorBoundCD C D z.im T`
on the `[10, 140]` adaptive region and a model with `zeros = zeros100ceil`,
this constructs the `LocalXiCloudDensityErrorPackage`. -/
noncomputable def localPackage_10_140_of_slabBundle
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : вДВ вЖТ вДВ)
    (hdecomp : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (herr_bound : вИА z : вДВ, вИА T : вДЭ,
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        вИА C D : вДЭ,
          closedFormSErrorBoundCD C D z.im T вЙ§ -(M.model z).im вЖТ
          |(error z).im| вЙ§ closedFormSErrorBoundCD C D z.im T) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_of_finiteBandSandwich
    M.model error
    (fun z => вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ 2 * (1 + |z.re| + z.im) вЙ§ T)
    hdecomp
    hmodelAnti
    (by
      intro z hreg hz
      obtain вЯ®T, hT10, hT140, hreg_TвЯ© := hreg
      obtain вЯ®C, D, hclosedвЯ© :=
        hclosed_on_10_140_zeros100ceil M hM_zeros hT10 hT140 hz hreg_T
      refine вЯ®C, D, T, ?_, hclosedвЯ©
      exact herr_bound z T hT10 hT140 hz hreg_T C D hclosed)

