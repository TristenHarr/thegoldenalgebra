lemma slabSimple_64_80_core
    {x y T : ÔäØ}
    (hx : 0 Ôëñ x) (hT64 : 64 Ôëñ T) (hT80 : T Ôëñ 80)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) Ôëñ T) :
    closedFormSErrorBoundCD (1 / 2 : ÔäØ) (49 / 20 : ÔäØ) y T
      Ôëñ simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hT48 : (48 : ÔäØ) Ôëñ T := by linarith
  have hTpos : (0 : ÔäØ) < T := by linarith
  have hT_ge_one : (1 : ÔäØ) Ôëñ T := by linarith
  have hT2_ge : ((64 : ÔäØ))^2 Ôëñ T^2 := by nlinarith
  have hlog_le : Real.log T Ôëñ 5 := log_T_le_5_of_le_140 hTpos (by linarith)
  have habs :=
    closedFormSErrorBoundCD_subband_le_const (A := (64 : ÔäØ)) (L := (5 : ÔäØ))
      (le_of_lt hy) hTpos hT_ge_one (by norm_num : (0:ÔäØ) < (64:ÔäØ)^2)
      hT2_ge (by norm_num : (0:ÔäØ) Ôëñ (5:ÔäØ)) hlog_le
  have h_const_eq : ((17/2 : ÔäØ) * 5 + 439/10) / (64 : ÔäØ)^2 = 27/1280 := by
    norm_num
  rw [h_const_eq] at habs
  have hcloud := cloudK_T_zeros100ceil_ge_const_64_80 hT64 hT80
  have htail :=
    tailK_80_140_ge_seven_fifteen_div hTpos (by norm_num : (0:ÔäØ) < 80)
      (by linarith : T Ôëñ 80)
  -- 7/(15*80) = 7/1200
  have h_tail_eq : (7 / (15 * 80) : ÔäØ) = 7/1200 := by norm_num
  rw [h_tail_eq] at htail
