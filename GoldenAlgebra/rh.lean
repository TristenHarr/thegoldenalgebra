  leftCount := S.leftCount
  mainLower := S.mainLower
  mainUpper := S.mainUpper
  left_count_eq := S.left_count_eq
  mainLower_le_left :=
    smoothMainTerm_lower_bound_of_log_ratio_lower
      (le_trans (by positivity : (0 : ÔäØ) Ôëñ 2 * Real.pi) S.hbottom_two_pi)
