-- CLVII-B: Rigorous discharge of the two CLVII-A numeric inputs
-- ---------------------------------------------------------------------
-- Two Mathlib-backed numerical bounds suffice:
--   * `Real.exp_one_lt_d9 : exp 1 < 2.7182818286` тЗТ exp 1 тЙд 2.72
--   * `Real.exp_one_gt_d9 : 2.7182818283 < exp 1` тЗТ 2.71 тЙд exp 1
--   * `Real.pi_lt_d2     : ╧А < 3.15`              тЗТ 2╧А < 6.3
--   * `Real.pi_lt_four   : ╧А < 4`                 тЗТ 22┬╖a > 255╧А for a тЙе 140

/-- тнР **PROVED тАФ `scalarGap22_15 140 > 0`.**

Chain:
  `log(140/(2╧А)) > 3` (since `140 > 2╧А┬╖e┬│ тЙд 6.3┬╖2.72┬│ тЙд 126.78`),
  `log 140 < 5`        (since `140 тЙд 2.71тБ╡ тЙд exp 1 ^ 5 = eтБ╡`),
  тЗТ LHS `тЙе (308/(3╧А))┬╖3 = 308/╧А тЙе 308/3.15 тЙИ 97.78`,
  тЗТ RHS `тЙд (17/2)┬╖5 + 43.9 = 86.4`,
  тЗТ gap `тЙе 11.38 > 0`. Python: actual gap тЙИ 15.53. -/
theorem scalarGap22_15_at_140_nonneg :
    (0 : тДЭ) тЙд scalarGap22_15 140 := by
  unfold scalarGap22_15
  -- ╧А bounds
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_d2 : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi) тЙа 0 := ne_of_gt h_2pi_pos
  have h_pi_ne : (Real.pi : тДЭ) тЙа 0 := ne_of_gt h_pi_pos
  -- exp 1 bounds
  have h_e_lt : Real.exp 1 < 2.72 := lt_trans Real.exp_one_lt_d9 (by norm_num)
  have h_e_gt : 2.71 < Real.exp 1 := lt_trans (by norm_num) Real.exp_one_gt_d9
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_e_nn : 0 тЙд Real.exp 1 := le_of_lt h_e_pos
  -- ===== Step 1: log(140 / (2╧А)) > 3 =====
  -- exp 3 = exp(1+1+1) = (exp 1)^3
  have h_exp3_eq : Real.exp 3 = Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (3 : тДЭ) = 1 + 1 + 1 from by norm_num,
        Real.exp_add, Real.exp_add]
  -- (exp 1)^3 тЙд 2.72^3 = 20.123648
  have h_e_le : Real.exp 1 тЙд 2.72 := le_of_lt h_e_lt
  have h_e_sq_le : Real.exp 1 * Real.exp 1 тЙд 2.72 * 2.72 :=
    mul_le_mul h_e_le h_e_le h_e_nn (by norm_num)
  have h_e_cube_le :
      Real.exp 1 * Real.exp 1 * Real.exp 1 тЙд 2.72 * 2.72 * 2.72 :=
    mul_le_mul h_e_sq_le h_e_le h_e_nn (by positivity)
  have h_272_cube : (2.72 : тДЭ) * 2.72 * 2.72 = 20.123648 := by norm_num
  have h_exp3_le : Real.exp 3 тЙд 20.124 := by
    rw [h_exp3_eq]; linarith
  have h_exp3_pos : 0 < Real.exp 3 := Real.exp_pos 3
  have h_exp3_nn : 0 тЙд Real.exp 3 := le_of_lt h_exp3_pos
  -- 2╧А тЙд 6.3
  have h_2pi_le : 2 * Real.pi тЙд 6.3 := by linarith
  have h_2pi_nn : 0 тЙд 2 * Real.pi := le_of_lt h_2pi_pos
  -- 2╧А ┬╖ exp 3 тЙд 6.3 ┬╖ 20.124 = 126.7812
  have h_2pi_exp3_le : 2 * Real.pi * Real.exp 3 тЙд 6.3 * 20.124 :=
    mul_le_mul h_2pi_le h_exp3_le h_exp3_nn (by norm_num)
  have h_63_201 : (6.3 : тДЭ) * 20.124 = 126.7812 := by norm_num
  have h_2pi_exp3_lt_140 : 2 * Real.pi * Real.exp 3 < 140 := by linarith
  -- 140/(2╧А) > exp 3
  have h_140_2pi_gt_e3 : Real.exp 3 < 140 / (2 * Real.pi) := by
    rw [lt_div_iffтВА h_2pi_pos]; linarith
  -- log(140/(2╧А)) > log(exp 3) = 3
  have h_log_140_2pi_gt_3 : 3 < Real.log (140 / (2 * Real.pi)) := by
    have h := Real.log_lt_log h_exp3_pos h_140_2pi_gt_e3
    rwa [Real.log_exp] at h
  -- ===== Step 2: log 140 < 5 =====
  -- exp 5 = (exp 1)^5
  have h_exp5_eq :
      Real.exp 5 = Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (5 : тДЭ) = 1 + 1 + 1 + 1 + 1 from by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add]
  -- (exp 1)^5 тЙе 2.71^5 = 146.16603...
  have h_271_nn : (0 : тДЭ) тЙд 2.71 := by norm_num
  have h_e_ge : (2.71 : тДЭ) тЙд Real.exp 1 := le_of_lt h_e_gt
  have h_e_sq_ge : (2.71 : тДЭ) * 2.71 тЙд Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_ge h_e_ge h_271_nn h_e_nn
  have h_e_cube_ge :
      (2.71 : тДЭ) * 2.71 * 2.71 тЙд Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_sq_ge h_e_ge h_271_nn (by positivity)
  have h_e_q_ge :
      (2.71 : тДЭ) * 2.71 * 2.71 * 2.71
        тЙд Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_cube_ge h_e_ge h_271_nn (by positivity)
  have h_e_5_ge :
      (2.71 : тДЭ) * 2.71 * 2.71 * 2.71 * 2.71
        тЙд Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 * Real.exp 1 :=
    mul_le_mul h_e_q_ge h_e_ge h_271_nn (by positivity)
  have h_140_lt_271_5 :
      (140 : тДЭ) < 2.71 * 2.71 * 2.71 * 2.71 * 2.71 := by norm_num
  have h_exp5_gt : (140 : тДЭ) < Real.exp 5 := by
    rw [h_exp5_eq]; linarith
  have h_140_pos : (0 : тДЭ) < 140 := by norm_num
  have h_log140_lt_5 : Real.log 140 < 5 := by
    have h := Real.log_lt_log h_140_pos h_exp5_gt
    rwa [Real.log_exp] at h
  -- ===== Step 3: combine =====
  -- LHS = ((22/15)┬╖140/(2╧А))┬╖log(140/(2╧А)) = (308/(3╧А))┬╖log(140/(2╧А))
  -- Use h_log_140_2pi_gt_3 with coefficient 308/(3╧А) > 0:
  --   LHS тЙе (308/(3╧А))┬╖3 = 308/╧А
  -- Then 308/╧А тЙе 308/3.15 (using ╧А тЙд 3.15) = 97.777...
  -- RHS = (17/2)┬╖log 140 + 439/10 < (17/2)┬╖5 + 43.9 = 86.4
  -- Gap тЙе 97.777 - 86.4 = 11.377 > 0.
  have h_coeff_pos : 0 < 308 / (3 * Real.pi) := by positivity
  -- LHS lower bound
  have h_LHS_ge : 308 / Real.pi
        тЙд ((22 / 15) * 140 / (2 * Real.pi)) * Real.log (140 / (2 * Real.pi)) := by
    have h_coeff_eq :
        (22 / 15) * 140 / (2 * Real.pi) = 308 / (3 * Real.pi) := by
      field_simp; ring
    rw [h_coeff_eq]
    -- (308/(3╧А))┬╖log(140/(2╧А)) тЙе (308/(3╧А))┬╖3 = 308/╧А
    have h_step :
        (308 / (3 * Real.pi)) * 3
          тЙд (308 / (3 * Real.pi)) * Real.log (140 / (2 * Real.pi)) :=
      mul_le_mul_of_nonneg_left (le_of_lt h_log_140_2pi_gt_3) (le_of_lt h_coeff_pos)
    have h_eq : (308 / (3 * Real.pi)) * 3 = 308 / Real.pi := by
      field_simp; ring
    linarith
  -- 308/╧А тЙе 308/3.15
  have h_pi_le : Real.pi тЙд 3.15 := le_of_lt h_pi_lt_d2
  have h_308_pi_ge : (308 : тДЭ) / 3.15 тЙд 308 / Real.pi := by
    apply div_le_div_of_nonneg_left (by norm_num) h_pi_pos h_pi_le
  have h_308_315 : (308 : тДЭ) / 3.15 = 97.777777777777777777777 тИи True := by right; trivial
  -- We'll use 97 as a clean lower bound: 308/3.15 тЙе 97 тЯ║ 308 тЙе 97┬╖3.15 = 305.55
  have h_308_315_ge_97 : (97 : тДЭ) тЙд 308 / 3.15 := by
    rw [le_div_iffтВА (by norm_num : (0:тДЭ) < 3.15)]; norm_num
  have h_LHS_ge_97 : (97 : тДЭ)
        тЙд ((22 / 15) * 140 / (2 * Real.pi)) * Real.log (140 / (2 * Real.pi)) := by
    linarith
  -- RHS upper bound: (17/2)┬╖log 140 + 439/10 тЙд (17/2)┬╖5 + 43.9 = 86.4
  have h_RHS_le : (17 / 2 : тДЭ) * Real.log 140 + 439 / 10 тЙд 86.4 := by
    have h_log_le : (17 / 2 : тДЭ) * Real.log 140 тЙд (17 / 2) * 5 :=
      mul_le_mul_of_nonneg_left (le_of_lt h_log140_lt_5) (by norm_num)
    have h_calc : (17 / 2 : тДЭ) * 5 = 42.5 := by norm_num
    linarith
  -- Combine: gap тЙе 97 - 86.4 = 10.6 > 0
  linarith

/-- тнР **PROVED тАФ `scalarGap22_15` is monotone on `[140, тИЮ)`.**

Derivative-free proof via the algebraic identity
  `scalarGap22_15(b) тИТ scalarGap22_15(a)`
   `= (11/(15╧А))┬╖(bтИТa)┬╖log(b/(2╧А))`
   ` + (11┬╖a/(15╧А) тИТ 17/2)┬╖log(b/a).`

Both terms are nonnegative on `[140, тИЮ)`:
  * `b тЙе a тЙе 140 > 2╧А`, so `log(b/(2╧А)) тЙе 0` and `log(b/a) тЙе 0`;
  * `11┬╖a/(15╧А) тИТ 17/2 тЙе 0` for `a тЙе 140`: the inequality reduces to
    `22┬╖a тЙе 255╧А`, and `22┬╖140 = 3080 тЙе 1020 тЙе 255┬╖4 > 255╧А`. -/
theorem scalarGap22_15_monotoneOn_Ici_140 :
    MonotoneOn scalarGap22_15 (Set.Ici 140) := by
  intro a ha b hb hab
  -- Unfold membership
  have ha_ge : (140 : тДЭ) тЙд a := ha
  have hb_ge : (140 : тДЭ) тЙд b := hb
  have hap : 0 < a := by linarith
  have hbp : 0 < b := by linarith
  have h_a_ne : a тЙа 0 := ne_of_gt hap
  have h_b_ne : b тЙа 0 := ne_of_gt hbp
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_ne : (2 * Real.pi) тЙа 0 := ne_of_gt h_2pi_pos
  have h_15pi_pos : 0 < 15 * Real.pi := by linarith
  have h_15pi_ne : (15 * Real.pi) тЙа 0 := ne_of_gt h_15pi_pos
  -- 2╧А < 8 < 140 тЙд a, b
  have h_2pi_lt_a : 2 * Real.pi < a := by linarith
  have h_2pi_lt_b : 2 * Real.pi < b := by linarith
  -- log(a/(2╧А)) тЙе 0, log(b/(2╧А)) тЙе 0
  have h_a_2pi_gt_1 : 1 < a / (2 * Real.pi) := by
    rw [lt_div_iffтВА h_2pi_pos]; linarith
  have h_b_2pi_gt_1 : 1 < b / (2 * Real.pi) := by
    rw [lt_div_iffтВА h_2pi_pos]; linarith
  have h_log_b_2pi_nn : 0 тЙд Real.log (b / (2 * Real.pi)) :=
    le_of_lt (Real.log_pos h_b_2pi_gt_1)
  -- log(b/a) тЙе 0 since b тЙе a > 0
  have h_b_div_a_ge_1 : 1 тЙд b / a := by
    rw [le_div_iffтВА hap]; linarith
  have h_log_ba_nn : 0 тЙд Real.log (b / a) := Real.log_nonneg h_b_div_a_ge_1
  -- 11┬╖a/(15╧А) тЙе 17/2: equivalent to 22┬╖a тЙе 255╧А, holds since 22┬╖140 = 3080 тЙе 1020 > 255┬╖╧А
  have h_╬▒_a_ge : (17 / 2 : тДЭ) тЙд 11 * a / (15 * Real.pi) := by
    rw [le_div_iffтВА h_15pi_pos]
    -- want (17/2)┬╖(15╧А) тЙд 11┬╖a, i.e., 255╧А/2 тЙд 11┬╖a, i.e., 255╧А тЙд 22a
    nlinarith [ha_ge, h_pi_lt_4]
  -- Log identities
  have h_log_a_2pi : Real.log (a / (2 * Real.pi))
                  = Real.log a - Real.log (2 * Real.pi) :=
    Real.log_div h_a_ne h_2pi_ne
  have h_log_b_2pi : Real.log (b / (2 * Real.pi))
                  = Real.log b - Real.log (2 * Real.pi) :=
    Real.log_div h_b_ne h_2pi_ne
  have h_log_ba : Real.log (b / a) = Real.log b - Real.log a :=
    Real.log_div h_b_ne h_a_ne
  -- Algebraic identity for the difference
  unfold scalarGap22_15
  have h_id :
      (((22 / 15) * b / (2 * Real.pi)) * Real.log (b / (2 * Real.pi))
        - ((17 / 2) * Real.log b + 439 / 10))
      - (((22 / 15) * a / (2 * Real.pi)) * Real.log (a / (2 * Real.pi))
        - ((17 / 2) * Real.log a + 439 / 10))
      = (11 / (15 * Real.pi)) * (b - a) * Real.log (b / (2 * Real.pi))
        + (11 * a / (15 * Real.pi) - 17 / 2) * Real.log (b / a) := by
    rw [h_log_a_2pi, h_log_b_2pi, h_log_ba]
    field_simp
    ring
  -- Both terms тЙе 0
  have h_term1_nn :
      0 тЙд (11 / (15 * Real.pi)) * (b - a) * Real.log (b / (2 * Real.pi)) := by
    apply mul_nonneg
    ┬╖ apply mul_nonneg
      ┬╖ positivity
      ┬╖ linarith
    ┬╖ exact h_log_b_2pi_nn
  have h_term2_nn :
      0 тЙд (11 * a / (15 * Real.pi) - 17 / 2) * Real.log (b / a) :=
    mul_nonneg (by linarith) h_log_ba_nn
  linarith

/-- тнР **PROVED тАФ full numerics package inhabited unconditionally.**

Both required inputs to `LargeTScalarMarginNumerics22_15_at_140` are now
discharged in Lean using only standard Mathlib lemmas (`Real.exp_one_lt_d9`,
`Real.exp_one_gt_d9`, `Real.pi_lt_d2`, `Real.pi_lt_four`, `Real.log_pos`,
`Real.log_nonneg`, `Real.log_div`, `Real.log_exp`, `Real.log_lt_log`,
plus elementary algebra). -/
def proved_numerics_22_15_at_140 : LargeTScalarMarginNumerics22_15_at_140 where
  gap_at_140_nonneg := scalarGap22_15_at_140_nonneg
  gap_monotone_from_140 := scalarGap22_15_monotoneOn_Ici_140

-- ---------------------------------------------------------------------
-- CLVI: Finite-band model-margin certificate
-- ---------------------------------------------------------------------
-- The smooth density tail bound has a structural floor: ╧Б(T) тЖТ 0 as
-- T тЖТ 2╧А. No constant `c` (even the sharp 8/5) can close the finite
-- band [2╧А, TтВА] using density-tail alone. The full model margin
-- `тИТIm(cloud + densityTail)` carries cloud margin that *is* finite at
-- `T = 2╧А`, so the residual band must be discharged at the model level,
-- typically via an interval-arithmetic / SOS certificate.
--
-- This is the named target where that certificate lands.

/-- **Finite-band model-margin certificate.** Captures the small-`T`
discharge: on the closed interval `[Tmin, Tmax]` (typically `[2╧А, 140]`
for the (22/15) route or `[2╧А, 125]` for the sharp (8/5) route) and the
canonical adaptive `A = 2` region, the closed-form `S`-error bound at
`(C, D)` is dominated by `тИТIm(model z)`.

This structure is the named slot for an interval-arithmetic certificate
or SOS proof; nothing in the file claims this is proved. Combining a
`LargeTClosedFormDomination` (large-`T` analytic discharge) with a
`FiniteBandModelMarginCertificate` (small-`T` certified discharge)
gives the full unconditional `hclosed` chain at every `T тЙе 2╧А`. -/
structure FiniteBandModelMarginCertificate where
  Tmin : тДЭ
  Tmax : тДЭ
  Tmin_ge_two_pi : 2 * Real.pi тЙд Tmin
  Tmin_le_Tmax : Tmin тЙд Tmax
  model : тДВ тЖТ тДВ
  C : тДЭ
  D : тДЭ
  cert :
    тИА z : тДВ, тИА T : тДЭ,
      Tmin тЙд T тЖТ T тЙд Tmax тЖТ
      0 < z.im тЖТ 2 * (1 + |z.re| + z.im) тЙд T тЖТ
        closedFormSErrorBoundCD C D z.im T тЙд -(model z).im

/-- тнР **PROVED тАФ certificate тЯ╣ `ModelMarginLowerBound` at every probe
in the certified band.** Mirrors the per-probe projection used for the
large-`T` route. -/
noncomputable def FiniteBandModelMarginCertificate.atProbe
    (F : FiniteBandModelMarginCertificate)
    (z : тДВ) (T : тДЭ)
    (hTmin : F.Tmin тЙд T) (hTmax : T тЙд F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

-- ---------------------------------------------------------------------
-- CLVIII: Per-slab S-bound and stitched coverage of [2╧А, T0]
-- ---------------------------------------------------------------------
-- Python feasibility scan with 50 zeros shows the global Turing-style
-- bound C=1/2, D=49/20 cannot certify slabs below T тЙИ 48, even with
-- arbitrarily many cloud zeros (the cloud margin saturates as ╬г y/╬│_k┬▓
-- converges). The actual S-fluctuation on small slabs is much smaller
-- than the global envelope. Per-slab (C, D) drops the lower edge:
--   (C=1/2, D=49/20) тЖТ feasible from T тЙИ 48
--   (C=1/2, D=1)     тЖТ feasible from T тЙИ 36
--   (C=1/2, D=1/2)   тЖТ feasible from T тЙИ 32
--   (C=0,   D=1)     тЖТ feasible from T тЙИ 19
--   (C=0,   D=1/2)   тЖТ feasible from T тЙИ 14
--   (C=0,   D=1/4)   тЖТ feasible from T тЙИ 10
-- Each `(C, D)` choice must be justified by a slab-specific S bound.

/-- **Single-slab model-margin certificate at per-slab (C, D).**
Identical shape to `FiniteBandModelMarginCertificate`, but emphasises
that each slab in a piecewise covering of `[2╧А, T0]` may choose its own
`(C, D)` pair backed by a slab-specific S envelope. -/
structure FiniteSlabModelMarginCertificate where
  Tmin : тДЭ
  Tmax : тДЭ
  Tmin_ge_two_pi : 2 * Real.pi тЙд Tmin
  Tmin_le_Tmax : Tmin тЙд Tmax
  model : тДВ тЖТ тДВ
  C : тДЭ
  D : тДЭ
  cert :
    тИА z : тДВ, тИА T : тДЭ,
      Tmin тЙд T тЖТ T тЙд Tmax тЖТ
      0 < z.im тЖТ 2 * (1 + |z.re| + z.im) тЙд T тЖТ
        closedFormSErrorBoundCD C D z.im T тЙд -(model z).im

/-- тнР **PROVED тАФ per-probe `ModelMarginLowerBound` from a single slab
certificate.** Same shape as the band-wide projection but works for any
`(C, D)` chosen by the slab. -/
noncomputable def FiniteSlabModelMarginCertificate.atProbe
    (F : FiniteSlabModelMarginCertificate)
    (z : тДВ) (T : тДЭ)
    (hTmin : F.Tmin тЙд T) (hTmax : T тЙд F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

/-- **Piecewise cover of `[Tmin_total, Tmax_total]` by a list of
slab certificates.** The list must be non-overlapping in `T` and cover
the full interval; each slab supplies its own `(C, D)`.

This package isolates the combinatorial "find the right slab for `T`"
step from the analytic content (each slab's `cert`). For the rh.lean
finite-band discharge, the typical instantiation covers `[2╧А, 140]` with
a handful of slabs, each chosen so the local S envelope is tight. -/
structure PiecewiseFiniteBandCertificate where
  slabs : List FiniteSlabModelMarginCertificate
  model : тДВ тЖТ тДВ
  /-- All slabs share the model under consideration. -/
  model_shared : тИА s тИИ slabs, s.model = model
  Tmin_total : тДЭ
  Tmax_total : тДЭ
  Tmin_ge_two_pi : 2 * Real.pi тЙд Tmin_total
  /-- For every probe in the band, some slab covers it. -/
  cover :
    тИА T : тДЭ, Tmin_total тЙд T тЖТ T тЙд Tmax_total тЖТ
      тИГ s тИИ slabs, s.Tmin тЙд T тИз T тЙд s.Tmax

/-- тнР **PROVED тАФ piecewise cover тЯ╣ per-probe `ModelMarginLowerBound`.**
For any `T` in the covered band, locate the right slab and apply its
`atProbe`. Both `тИТIm(model z)` bounds (each slab's) translate through
`model_shared`. -/
noncomputable def PiecewiseFiniteBandCertificate.atProbe
    (P : PiecewiseFiniteBandCertificate)
    (z : тДВ) (T : тДЭ)
    (hTmin : P.Tmin_total тЙд T) (hTmax : T тЙд P.Tmax_total)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    тИГ C D : тДЭ,
      closedFormSErrorBoundCD C D z.im T тЙд -(P.model z).im := by
  obtain тЯиs, hs_mem, hsTmin, hsTmaxтЯй := P.cover T hTmin hTmax
  refine тЯиs.C, s.D, ?_тЯй
  have hmodel : s.model = P.model := P.model_shared s hs_mem
  have h := s.cert z T hsTmin hsTmax hy hreg
  rw [hmodel] at h
  exact h

-- ---------------------------------------------------------------------
-- CLIX-A: Slab-local Turing-style S-bound
-- ---------------------------------------------------------------------
-- The source of per-slab (C, D) pairs. Each `SlabTuringStyleSBound`
-- asserts `|S u| тЙд C┬╖log u + D` on a finite interval `[A, B]`, in
-- contrast to the global `TuringStyleSBound` (defined elsewhere in
-- the file) which asserts the bound on the lower-unbounded tail
-- `u тЙе some lower`.

/-- **Slab-local Turing-style S-bound.** Asserts that the
zero-counting fluctuation `S(u)` is dominated by `C┬╖log u + D` on a
compact interval `[A, B]`. Each slab in a `PiecewiseFiniteBandCertificate`
typically chooses its own `(C, D)` justified by such a slab bound. -/
structure SlabTuringStyleSBound where
  S : тДЭ тЖТ тДЭ
  A : тДЭ
  B : тДЭ
  C : тДЭ
  D : тДЭ
  bound :
    тИА u : тДЭ, A тЙд u тЖТ u тЙд B тЖТ |S u| тЙд C * Real.log u + D

-- ---------------------------------------------------------------------
-- CLIX-B: First-zero direct package тАФ N(u) = 0 on [2╧А, ╬│тВБ)
-- ---------------------------------------------------------------------
-- For `u < ╬│тВБ` (first nontrivial Riemann zero, ╬│тВБ тЙИ 14.13), the
-- zero-counting function satisfies `N(u) = 0`, so `S(u) = -NтВА(u)`
-- is *explicitly known*, not just envelope-bounded. The error
-- contribution from this slab can be evaluated exactly rather than
-- bounded via the generic `closedFormSErrorBoundCD`.

/-- **First-zero gap formula.** Records the structural fact that
`N(u) = 0` on `[2╧А, ╬│тВБ)`, hence `S(u) = -NтВА(u)` is concretely
computable on this interval. -/
structure FirstZeroGapSFormula where
  N : тДЭ тЖТ тДЭ
  S : тДЭ тЖТ тДЭ
  NтВА : тДЭ тЖТ тДЭ
  gamma1 : тДЭ
  hgamma1_pos : 0 < gamma1
  noZerosBefore :
    тИА u : тДЭ, 2 * Real.pi тЙд u тЖТ u < gamma1 тЖТ N u = 0
  S_eq_neg_N0 :
    тИА u : тДЭ, 2 * Real.pi тЙд u тЖТ u < gamma1 тЖТ S u = -(NтВА u)

/-- **First-zero S envelope.** A concrete numerical bound
`|NтВА(u)| тЙд D` on `[2╧А, ╬│тВБ]`, used to feed `closedFormSErrorBoundCD`
with `(C, D) = (0, D)` in the very small slab.

Python (CLVII findings): on `[2╧А, 14]`, `|NтВА(u)| тЙд тЙИ 0.45` (the value
`|NтВА(╬│тВБ)|` just before the first-zero count jumps from 0 to 1). So
`D тЙИ 1/2` is a realistic rigorous choice. -/
structure FirstZeroGapSBound where
  NтВА : тДЭ тЖТ тДЭ
  gamma1 : тДЭ
  D : тДЭ
  bound :
    тИА u : тДЭ, 2 * Real.pi тЙд u тЖТ u тЙд gamma1 тЖТ |NтВА u| тЙд D

/-- **First-zero-band model-margin certificate.** Mirrors
`FiniteSlabModelMarginCertificate` but ties the slab to the first-zero
gap `[Tmin, Tmax] тКЖ [2╧А, ╬│тВБ]` and uses a placeholder
`closedFormFirstZeroErrorBound` that is sharper than the generic
`closedFormSErrorBoundCD` because it exploits the known `S = -NтВА`.

For the rh.lean discharge this is the *only* irreducible piece below
the piecewise SDP coverage, since the generic envelope (even with
small `D`) is inflated by the `8 + 18` IBP constants in the closed
form. -/
structure FirstZeroBandCertificate where
  Tmin : тДЭ
  Tmax : тДЭ
  gamma1 : тДЭ
  Tmin_ge_two_pi : 2 * Real.pi тЙд Tmin
  Tmin_le_Tmax : Tmin тЙд Tmax
  Tmax_le_gamma1 : Tmax тЙд gamma1
  model : тДВ тЖТ тДВ
  /-- The sharper error bound exploiting `S = -NтВА` on this slab.
  Left as a function field rather than a hard-coded formula since the
  exact polynomial form depends on the integral evaluation
  technique used. -/
  errorBound : тДЭ тЖТ тДЭ тЖТ тДЭ
  cert :
    тИА z : тДВ, тИА T : тДЭ,
      Tmin тЙд T тЖТ T тЙд Tmax тЖТ
      0 < z.im тЖТ 2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z.im T тЙд -(model z).im

-- ---------------------------------------------------------------------
-- CLIX-C: Closed-form first-zero error bound
-- ---------------------------------------------------------------------
-- The generic `closedFormSErrorBoundCD 0 D y T = 17┬╖y┬╖D / T┬▓` bounds the
-- IBP integral over `[T, тИЮ)` using `|k_z'(u)| тЙд 18y / u┬│` and
-- `тИл_T^тИЮ du/u┬│ = 1/(2 T┬▓)`. On the first-zero slab (`Tmin тЙе 2╧А`,
-- `Tmax тЙд ╬│тВБ`) the zero-counting fluctuation factors as `S = тИТNтВА` and
-- the *substantive* IBP integral runs only over `[T, ╬│тВБ]`, since the
-- `[╬│тВБ, тИЮ)` tail is folded into the explicit cloud model rather than
-- into the envelope.  The integral becomes
--
--   тИл_T^{╬│тВБ} |k_z'(u)| ┬╖ D du
--      тЙд 18 y D ┬╖ тИл_T^{╬│тВБ} du / u┬│
--      = 18 y D ┬╖ (1/(2 T┬▓) тИТ 1/(2 ╬│тВБ┬▓))
--      = 9 y D / T┬▓  тИТ  9 y D / ╬│тВБ┬▓,
--
-- saving exactly `9 y D / ╬│тВБ┬▓` over the generic bound. The closed-form
-- error bound is the algebraic sum
--
--   boundary  +  slabIntegral
--      = 8 y D / T┬▓  +  (9 y D / T┬▓ тИТ 9 y D / ╬│тВБ┬▓)
--      = 17 y D / T┬▓  тИТ  9 y D / ╬│тВБ┬▓.

/-- **Closed-form first-zero error bound.** The sharper analogue of
`closedFormSErrorBoundCD 0 D y T` valid on `[T, ╬│тВБ]`, obtained by
replacing the `тИл_T^тИЮ du/u┬│` integral with `тИл_T^{╬│тВБ} du/u┬│`.

Concretely:
  `closedFormFirstZeroErrorBound y T ╬│тВБ D := 17┬╖y┬╖D/T┬▓ тИТ 9┬╖y┬╖D/╬│тВБ┬▓`. -/
noncomputable def closedFormFirstZeroErrorBound
    (y T gamma1 D : тДЭ) : тДЭ :=
  17 * y * D / T^2 - 9 * y * D / gamma1^2

/-- тнР **PROVED тАФ algebraic equivalence: first-zero bound = generic bound тИТ
╬│тВБ-correction.** Makes the "subtract the [╬│тВБ,тИЮ) contribution"
interpretation a syntactic identity. -/
theorem closedFormFirstZeroErrorBound_eq_sub
    {T : тДЭ} (hT : T тЙа 0) (y gamma1 D : тДЭ) :
    closedFormFirstZeroErrorBound y T gamma1 D
      = closedFormSErrorBoundCD 0 D y T - 9 * y * D / gamma1^2 := by
  unfold closedFormFirstZeroErrorBound closedFormSErrorBoundCD
  have hT2 : T^2 тЙа 0 := pow_ne_zero 2 hT
  field_simp
  ring

/-- тнР **PROVED тАФ sharpness: first-zero bound dominates generic bound.**
On non-negative `(y, D)` and `╬│тВБ тЙа 0`, the first-zero bound is at most
the generic bound тАФ by exactly the saving `9┬╖y┬╖D/╬│тВБ┬▓ тЙе 0`. -/
theorem closedFormFirstZeroErrorBound_le_closedFormSErrorBoundCD_zero
    {T y D gamma1 : тДЭ}
    (hT : T тЙа 0) (hy : 0 тЙд y) (hD : 0 тЙд D) (hgamma1 : gamma1 тЙа 0) :
    closedFormFirstZeroErrorBound y T gamma1 D
      тЙд closedFormSErrorBoundCD 0 D y T := by
  rw [closedFormFirstZeroErrorBound_eq_sub hT]
  have hg2 : 0 < gamma1^2 := by positivity
  have h_sav : 0 тЙд 9 * y * D / gamma1^2 := by positivity
  linarith

/-- тнР **PROVED тАФ closed-form first-zero bound dominates a slab-IBP sum.**
Given closed-form upper bounds on the boundary term (`8 y D / T┬▓`) and on
the slab-restricted integral (`9 y D / T┬▓ тИТ 9 y D / ╬│тВБ┬▓`), their sum is
тЙд `closedFormFirstZeroErrorBound y T ╬│тВБ D`. This is the algebraic core
of the analytic claim "first-zero IBP envelope тЙд closed-form bound";
the actual IBP integral inequalities are produced by CXLIV-CL applied
on `[T, ╬│тВБ]` instead of `[T, тИЮ)`. -/
theorem slabIBP_sum_le_closedFormFirstZeroErrorBound
    {y T gamma1 D boundaryTerm slabIntegralBound : тДЭ}
    (hbdy : boundaryTerm тЙд 8 * y * D / T^2)
    (hslabInt : slabIntegralBound тЙд 9 * y * D / T^2 - 9 * y * D / gamma1^2) :
    boundaryTerm + slabIntegralBound
      тЙд closedFormFirstZeroErrorBound y T gamma1 D := by
  unfold closedFormFirstZeroErrorBound
  have h_split :
      17 * y * D / T^2 = 8 * y * D / T^2 + 9 * y * D / T^2 := by ring
  linarith

/-- тнР **PROVED тАФ first-zero band certificate from a per-probe closed-form
domination.** Wraps the per-probe `closedFormFirstZeroErrorBound тЙд
тИТIm(model z)` proof (the slab-restricted certificate the
SDP/Schm├╝dgen step produces) into a fully populated
`FirstZeroBandCertificate`. The cover-the-band closure proof is the
identity. -/
noncomputable def FirstZeroBandCertificate.ofClosedFormFirstZero
    (Tmin Tmax gamma1 D : тДЭ)
    (hTmin_ge_two_pi : 2 * Real.pi тЙд Tmin)
    (hTmin_le_Tmax : Tmin тЙд Tmax)
    (hTmax_le_gamma1 : Tmax тЙд gamma1)
    (model : тДВ тЖТ тДВ)
    (hprobe :
      тИА z : тДВ, тИА T : тДЭ,
        Tmin тЙд T тЖТ T тЙд Tmax тЖТ
        0 < z.im тЖТ 2 * (1 + |z.re| + z.im) тЙд T тЖТ
          closedFormFirstZeroErrorBound z.im T gamma1 D тЙд -(model z).im) :
    FirstZeroBandCertificate where
  Tmin := Tmin
  Tmax := Tmax
  gamma1 := gamma1
  Tmin_ge_two_pi := hTmin_ge_two_pi
  Tmin_le_Tmax := hTmin_le_Tmax
  Tmax_le_gamma1 := hTmax_le_gamma1
  model := model
  errorBound := fun y T => closedFormFirstZeroErrorBound y T gamma1 D
  cert := hprobe

-- ---------------------------------------------------------------------
-- CLX-A: HasDerivAt + MonotoneOn for smoothZeroCountingN0 on [2╧А, тИЮ)
-- ---------------------------------------------------------------------

/-- тнР **PROVED тАФ `HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u` for
`u > 0`.** The `HasDerivAt`-flavoured version of the existing
`deriv_smoothZeroCountingN0`. Needed to apply
`monotoneOn_of_deriv_nonneg`. -/
theorem hasDerivAt_smoothZeroCountingN0
    {u : тДЭ} (hu : 0 < u) :
    HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u := by
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : тДЭ) тЙа 0 := ne_of_gt h2pi_pos
  have hu_ne : u тЙа 0 := ne_of_gt hu
  have hq_pos : (0 : тДЭ) < u / (2 * Real.pi) := div_pos hu h2pi_pos
  have hq_ne : u / (2 * Real.pi) тЙа 0 := ne_of_gt hq_pos
  have h_lin : HasDerivAt (fun u : тДЭ => u / (2 * Real.pi)) (1 / (2 * Real.pi)) u := by
    simpa using (hasDerivAt_id u).div_const (2 * Real.pi)
  have h_log_inner :
      HasDerivAt (fun u : тДЭ => Real.log (u / (2 * Real.pi))) (1 / u) u := by
    have hlog := Real.hasDerivAt_log hq_ne
    have h_comp := hlog.comp u h_lin
    have h_simp : (u / (2 * Real.pi))тБ╗┬╣ * (1 / (2 * Real.pi)) = 1 / u := by
      field_simp; ring
    rw [h_simp] at h_comp
    simpa [Function.comp_def] using h_comp
  have h_prod := h_lin.mul h_log_inner
  have h_sub := h_prod.sub h_lin
  have h_final := h_sub.add_const (7 / 8)
  -- Match function form to smoothZeroCountingN0 and simplify derivative.
  have h_func_eq :
      (fun u : тДЭ => (u / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
                    - u / (2 * Real.pi) + 7 / 8)
        = smoothZeroCountingN0 := by
    funext v; rfl
  have h_deriv_eq :
      (1 / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
        + (u / (2 * Real.pi)) * (1 / u) - 1 / (2 * Real.pi)
      = zeroDensityRho u := by
    unfold zeroDensityRho
    field_simp
    ring
  rw [тЖР h_func_eq, тЖР h_deriv_eq]
  exact h_final

/-- тнР **PROVED тАФ `smoothZeroCountingN0` is monotone on `[2╧А, тИЮ)`.**

Direct from `monotoneOn_of_deriv_nonneg`:
* continuity and differentiability on the interior follow from
  `hasDerivAt_smoothZeroCountingN0`;
* the derivative `zeroDensityRho u` is `тЙе 0` for `u тЙе 2╧А`
  (`zeroDensityRho_nonneg_of_ge_two_pi`). -/
theorem smoothZeroCountingN0_monotoneOn_Ici_two_pi :
    MonotoneOn smoothZeroCountingN0 (Set.Ici (2 * Real.pi)) := by
  apply monotoneOn_of_deriv_nonneg (convex_Ici _)
  ┬╖ intro x hx
    have hx_ge : 2 * Real.pi тЙд x := hx
    have hx_pos : 0 < x := lt_of_lt_of_le (by positivity) hx_ge
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).continuousAt.continuousWithinAt
  ┬╖ intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).differentiableAt.differentiableWithinAt
  ┬╖ intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    rw [(hasDerivAt_smoothZeroCountingN0 hx_pos).deriv]
    exact zeroDensityRho_nonneg_of_ge_two_pi (le_of_lt hx_2pi)

-- ---------------------------------------------------------------------
-- CLX-B: Endpoint bounds for smoothZeroCountingN0 on [2╧А, 10]
-- ---------------------------------------------------------------------

/-- тнР **PROVED тАФ `smoothZeroCountingN0(2╧А) = -1/8`.**

Direct evaluation: `NтВА(2╧А) = 1 ┬╖ log(1) тИТ 1 + 7/8 = -1/8`. -/
theorem smoothZeroCountingN0_at_two_pi :
    smoothZeroCountingN0 (2 * Real.pi) = -(1 / 8) := by
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : тДЭ) тЙа 0 := ne_of_gt h2pi_pos
  unfold smoothZeroCountingN0
  have h_div_one : (2 * Real.pi) / (2 * Real.pi) = 1 := div_self h2pi_ne
  rw [h_div_one, Real.log_one]
  ring

/-- тнР **PROVED тАФ `smoothZeroCountingN0(10) тЙд 1/2`.**

Chain: `5/╧А тЙе 5/3.15 > 1.58` (since `╧А < 3.15`), `5/╧А < 2` (since
`╧А > 2.5`), so `log(5/╧А) тЙд log 2 тЙд 0.7` (Mathlib `Real.log_two_lt_d9`),
giving `NтВА(10) = (5/╧А)┬╖log(5/╧А) тИТ 5/╧А + 7/8 тЙд 1.58┬╖0.7 тИТ 1.58 + 7/8 тЙИ 0.40 тЙд 1/2`. -/
theorem smoothZeroCountingN0_at_10_le_half :
    smoothZeroCountingN0 10 тЙд 1 / 2 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  -- 10/(2╧А) = 5/╧А
  have h_eq : (10 : тДЭ) / (2 * Real.pi) = 5 / Real.pi := by ring
  rw [h_eq]
  have h_5_pi_pos : 0 < 5 / Real.pi := by positivity
  have h_5_pi_nn : 0 тЙд 5 / Real.pi := le_of_lt h_5_pi_pos
  -- 5/╧А > 1.58 (from ╧А < 3.15)
  have h_5_pi_gt : (1.58 : тДЭ) < 5 / Real.pi := by
    rw [lt_div_iffтВА h_pi_pos]; linarith
  -- 5/╧А < 2 (from ╧А > 5/2)
  have h_5_pi_lt_2 : 5 / Real.pi < 2 := by
    rw [div_lt_iffтВА h_pi_pos]; linarith
  -- log(5/╧А) тЙд log 2
  have h_log_le_log2 : Real.log (5 / Real.pi) тЙд Real.log 2 :=
    Real.log_le_log h_5_pi_pos (le_of_lt h_5_pi_lt_2)
  -- log 2 тЙд 0.7
  have h_log2_lt : Real.log 2 тЙд 0.7 := by
    have := Real.log_two_lt_d9
    linarith
  have h_log_le : Real.log (5 / Real.pi) тЙд 0.7 :=
    le_trans h_log_le_log2 h_log2_lt
  -- log(5/╧А) тЙе 0 since 5/╧А тЙе 1
  have h_5_pi_ge_1 : (1 : тДЭ) тЙд 5 / Real.pi := by
    rw [le_div_iffтВА h_pi_pos]; linarith
  have h_log_nn : 0 тЙд Real.log (5 / Real.pi) := Real.log_nonneg h_5_pi_ge_1
  -- (5/╧А)┬╖log(5/╧А) тЙд (5/╧А)┬╖0.7
  have h_mul_le : (5 / Real.pi) * Real.log (5 / Real.pi)
                тЙд (5 / Real.pi) * 0.7 :=
    mul_le_mul_of_nonneg_left h_log_le h_5_pi_nn
  -- Combine: closedForm тЙд -0.3┬╖(5/╧А) + 7/8 тЙд 1/2 since 0.3┬╖(5/╧А) > 0.474 тЙе 3/8
  nlinarith [h_mul_le, h_5_pi_gt]

/-- тнР **PROVED тАФ `|NтВА(u)| тЙд 1/2` for `u тИИ [2╧А, 10]`.**

By `smoothZeroCountingN0_monotoneOn_Ici_two_pi`:
  `-1/8 = NтВА(2╧А) тЙд NтВА(u) тЙд NтВА(10) тЙд 1/2`,
so `|NтВА(u)| тЙд 1/2`. -/
theorem abs_smoothZeroCountingN0_le_half_on_first_band
    {u : тДЭ} (hlo : 2 * Real.pi тЙд u) (hhi : u тЙд 10) :
    |smoothZeroCountingN0 u| тЙд 1 / 2 := by
  have h_mono := smoothZeroCountingN0_monotoneOn_Ici_two_pi
  have h_2pi_mem : (2 * Real.pi : тДЭ) тИИ Set.Ici (2 * Real.pi) := Set.left_mem_Ici
  have h_u_mem : u тИИ Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hlo
  have h_10_mem : (10 : тДЭ) тИИ Set.Ici (2 * Real.pi) := by
    rw [Set.mem_Ici]
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_low : smoothZeroCountingN0 (2 * Real.pi) тЙд smoothZeroCountingN0 u :=
    h_mono h_2pi_mem h_u_mem hlo
  have h_high : smoothZeroCountingN0 u тЙд smoothZeroCountingN0 10 :=
    h_mono h_u_mem h_10_mem hhi
  rw [smoothZeroCountingN0_at_two_pi] at h_low
  have h_high' : smoothZeroCountingN0 u тЙд 1 / 2 :=
    le_trans h_high smoothZeroCountingN0_at_10_le_half
  rw [abs_le]
  refine тЯи?_, h_high'тЯй
  linarith

