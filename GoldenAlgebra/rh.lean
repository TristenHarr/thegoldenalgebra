-- =====================================================================
-- ┬зCCLXXXIV. Bounded low IBP internal pieces
-- =====================================================================
-- Build the bounded-interval analogues of the mid/high IBP objects for
-- the first-zero gap `[T, ╬│]`. Concretely:
--
--   (A) `abs_pairedCauchyImKernel_adaptive_8` тАФ boundary kernel bound
--       `|k(T)| тЙд 8y/T┬▓` on the adaptive regime `2(1 + |x| + y) тЙд T`.
--   (B) `lowFirstZeroIBPIntegrand` тАФ the bounded IBP integrand
--       `S(u) ┬╖ k'(u)` with `S := Phase1IBP.finiteFluctuationPrimitive`.
--   (C) `lowFirstZeroDerivativeSide` тАФ bounded integral over `[T, ╬│]`
--       with a `rfl` bridge to `Phase1IBP.derivativeSidePartial`.
--   (D) `lowFirstZeroBoundaryTerm` тАФ `k(T) ┬╖ S(T)` boundary product.
--   (E) `lowFirstZeroBoundaryTerm_abs_le` тАФ boundary absolute bound
--       `тЙд 8 y D / T┬▓` under `|S(T)| тЙд D` + adaptive regime.
--   (F) `integral_eighteen_y_D_over_u3` тАФ FTC evaluation
--       `тИл_T^╬│ 18yD/u┬│ = 9yD/T┬▓ тИТ 9yD/╬│┬▓`.
--   (G) `lowFirstZeroDerivativeSide_abs_le_majorant` тАФ derivative-side
--       absolute bound `тЙд 9 y D / T┬▓ тИТ 9 y D / ╬│┬▓` under pointwise
--       `|S| тЙд D`, adaptive regime, and integrability.
--   (H) `lowFirstZeroIBP_sum_le_closedForm` тАФ combined bound
--       `|boundary| + |derivative| тЙд closedFormFirstZeroErrorBound y T ╬│ D`
--       via the existing `slabIBP_sum_le_closedFormFirstZeroErrorBound`.

/-- тнР **PROVED тАФ adaptive `8y/T┬▓` kernel bound** at the boundary.
On the adaptive regime `2(1 + |x| + y) тЙд T`,
`|pairedCauchyImKernel x y T| тЙд 8 ┬╖ y / T┬▓`. -/
lemma abs_pairedCauchyImKernel_adaptive_8
    {x y T : тДЭ} (hy : 0 тЙд y) (h_reg : 2 * (1 + |x| + y) тЙд T) :
    |pairedCauchyImKernel x y T| тЙд 8 * y / T ^ 2 := by
  have hx_nn : 0 тЙд |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_x_lt_T : |x| < T := by linarith
  have h_kbnd : |pairedCauchyImKernel x y T| тЙд 2 * y / (T - |x|) ^ 2 :=
    Phase1IBP.abs_pairedCauchyImKernel_le_quadratic_tail x y T hy h_x_lt_T
  have h_T_minus_x_ge : T / 2 тЙд T - |x| := by linarith
  have h_T_minus_x_nn : (0 : тДЭ) тЙд T / 2 := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_sq_ge : (T / 2) ^ 2 тЙд (T - |x|) ^ 2 :=
    pow_le_pow_leftтВА h_T_minus_x_nn h_T_minus_x_ge 2
  have h_half_sq_eq : (T / 2) ^ 2 = T ^ 2 / 4 := by ring
  rw [h_half_sq_eq] at h_sq_ge
  have h_sq_pos : 0 < (T - |x|) ^ 2 := pow_pos h_T_minus_x_pos 2
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_target : 2 * y / (T - |x|) ^ 2 тЙд 8 * y / T ^ 2 := by
    rw [div_le_div_iffтВА h_sq_pos h_T_sq_pos]
    nlinarith [h_sq_ge, hy]
  linarith

/-- **Bounded low IBP integrand**: `S(u) ┬╖ k'(u)` with
`S := Phase1IBP.finiteFluctuationPrimitive Dzero T0`. -/
noncomputable def lowFirstZeroIBPIntegrand
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y : тДЭ) :
    тДЭ тЖТ тДЭ :=
  fun u =>
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
      pairedCauchyImKernelDeriv x y u

/-- **Bounded low IBP derivative-side integral** over `[T, ╬│]`. -/
noncomputable def lowFirstZeroDerivativeSide
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T ╬│ : тДЭ) : тДЭ :=
  тИл u in T..╬│, lowFirstZeroIBPIntegrand Dzero T0 x y u

/-- тнР **PROVED тАФ `rfl` bridge to `Phase1IBP.derivativeSidePartial`.** -/
lemma lowFirstZeroDerivativeSide_eq_partial
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T ╬│ : тДЭ) :
    lowFirstZeroDerivativeSide Dzero T0 x y T ╬│ =
      Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) x y T ╬│ :=
  rfl

/-- **Bounded low IBP boundary term**: `k(T) ┬╖ S(T)`. -/
noncomputable def lowFirstZeroBoundaryTerm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T : тДЭ) : тДЭ :=
  pairedCauchyImKernel x y T *
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 T

/-- тнР **PROVED тАФ boundary absolute bound `тЙд 8 y D / T┬▓`** under
`|S(T)| тЙд D` and the adaptive regime. -/
theorem lowFirstZeroBoundaryTerm_abs_le
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T D : тДЭ}
    (hy : 0 тЙд y)
    (h_reg : 2 * (1 + |x| + y) тЙд T)
    (hS_T : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T| тЙд D) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T| тЙд 8 * y * D / T ^ 2 := by
  unfold lowFirstZeroBoundaryTerm
  have hx_nn : 0 тЙд |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_k_bnd : |pairedCauchyImKernel x y T| тЙд 8 * y / T ^ 2 :=
    abs_pairedCauchyImKernel_adaptive_8 hy h_reg
  have h_k_nn : 0 тЙд 8 * y / T ^ 2 := by positivity
  have h_D_nn : 0 тЙд D := le_trans (abs_nonneg _) hS_T
  rw [abs_mul]
  calc |pairedCauchyImKernel x y T|
        * |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T|
      тЙд (8 * y / T ^ 2) * D :=
        mul_le_mul h_k_bnd hS_T (abs_nonneg _) h_k_nn
    _ = 8 * y * D / T ^ 2 := by ring

/-- тнР **PROVED тАФ FTC evaluation of the majorant integral**:
`тИл_T^╬│ 18┬╖y┬╖D/u┬│ du = 9┬╖y┬╖D/T┬▓ тИТ 9┬╖y┬╖D/╬│┬▓`.

Antiderivative `F(u) := тИТ9┬╖y┬╖D/u┬▓`, with `F'(u) = 18┬╖y┬╖D/u┬│` for `u тЙа 0`.
Applies `intervalIntegral.integral_eq_sub_of_hasDerivAt`. -/
lemma integral_eighteen_y_D_over_u3
    {y D T ╬│ : тДЭ} (hT_pos : 0 < T) (hT╬│ : T тЙд ╬│) :
    тИл u in T..╬│, 18 * y * D / u ^ 3
      = 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 := by
  have h╬│_pos : 0 < ╬│ := lt_of_lt_of_le hT_pos hT╬│
  have h_deriv : тИА u тИИ Set.uIcc T ╬│,
      HasDerivAt (fun v : тДЭ => -9 * y * D / v ^ 2)
        (18 * y * D / u ^ 3) u := by
    intro u hu
    rw [Set.uIcc_of_le hT╬│] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    have hu_ne : u тЙа 0 := ne_of_gt hu_pos
    have hu_sq_ne : u ^ 2 тЙа 0 := pow_ne_zero 2 hu_ne
    have h_num : HasDerivAt (fun _ : тДЭ => -9 * y * D) 0 u :=
      hasDerivAt_const u _
    have h_den : HasDerivAt (fun v : тДЭ => v ^ 2)
                  ((2 : тДХ) * u ^ (2 - 1)) u :=
      hasDerivAt_pow 2 u
    have h_div_raw : HasDerivAt
        (fun v : тДЭ => -9 * y * D / v ^ 2)
        ((0 * u ^ 2 - (-9 * y * D) * ((2 : тДХ) * u ^ (2 - 1))) / (u ^ 2) ^ 2) u :=
      h_num.div h_den hu_sq_ne
    convert h_div_raw using 1
    have hu_cube_ne : u ^ 3 тЙа 0 := pow_ne_zero 3 hu_ne
    field_simp
    ring
  have h_cont : ContinuousOn (fun u : тДЭ => 18 * y * D / u ^ 3)
                  (Set.uIcc T ╬│) := by
    rw [Set.uIcc_of_le hT╬│]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_int : IntervalIntegrable (fun u : тДЭ => 18 * y * D / u ^ 3)
                MeasureTheory.volume T ╬│ :=
    h_cont.intervalIntegrable
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int]
  ring

/-- ЁЯМЯ **PROVED тАФ derivative-side absolute bound** `тЙд 9 y D / T┬▓ тИТ 9 y D / ╬│┬▓`
under pointwise `|S| тЙд D`, the adaptive regime, and integrability of
`|S ┬╖ k'|`. -/
theorem lowFirstZeroDerivativeSide_abs_le_majorant
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    {x y T ╬│ D : тДЭ}
    (hy : 0 < y)
    (h_reg : 2 * (1 + |x| + y) тЙд T)
    (hT╬│ : T тЙд ╬│)
    (hD : 0 тЙд D)
    (hS : тИА u, T тЙд u тЖТ u тЙд ╬│ тЖТ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| тЙд D)
    (hSint : IntervalIntegrable
              (fun u => |lowFirstZeroIBPIntegrand Dzero T0 x y u|)
              MeasureTheory.volume T ╬│) :
    |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
      тЙд 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 := by
  unfold lowFirstZeroDerivativeSide
  have hx_nn : 0 тЙд |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_abs_int :
      |тИл u in T..╬│, lowFirstZeroIBPIntegrand Dzero T0 x y u|
        тЙд тИл u in T..╬│, |lowFirstZeroIBPIntegrand Dzero T0 x y u| :=
    intervalIntegral.abs_integral_le_integral_abs hT╬│
  have h_pointwise : тИА u тИИ Set.Icc T ╬│,
      |lowFirstZeroIBPIntegrand Dzero T0 x y u| тЙд 18 * y * D / u ^ 3 := by
    intro u hu
    obtain тЯиhuT, hu╬│тЯй := hu
    unfold lowFirstZeroIBPIntegrand
    rw [abs_mul]
    have hS_u : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| тЙд D :=
      hS u huT hu╬│
    have h_k_bnd : |pairedCauchyImKernelDeriv x y u| тЙд 18 * y / u ^ 3 :=
      abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le h_reg huT
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos huT
    have h_k_nn : 0 тЙд 18 * y / u ^ 3 := by positivity
    calc |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          * |pairedCauchyImKernelDeriv x y u|
        тЙд D * (18 * y / u ^ 3) :=
          mul_le_mul hS_u h_k_bnd (abs_nonneg _) hD
      _ = 18 * y * D / u ^ 3 := by ring
  have h_maj_cont : ContinuousOn (fun u : тДЭ => 18 * y * D / u ^ 3)
                      (Set.uIcc T ╬│) := by
    rw [Set.uIcc_of_le hT╬│]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_maj_int : IntervalIntegrable (fun u : тДЭ => 18 * y * D / u ^ 3)
                    MeasureTheory.volume T ╬│ :=
    h_maj_cont.intervalIntegrable
  have h_int_mono :
      тИл u in T..╬│, |lowFirstZeroIBPIntegrand Dzero T0 x y u|
        тЙд тИл u in T..╬│, 18 * y * D / u ^ 3 :=
    intervalIntegral.integral_mono_on hT╬│ hSint h_maj_int h_pointwise
  have h_maj_eval :
      тИл u in T..╬│, 18 * y * D / u ^ 3
        = 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 :=
    integral_eighteen_y_D_over_u3 hT_pos hT╬│
  linarith [h_abs_int, h_int_mono, h_maj_eval]

/-- ЁЯМЯЁЯМЯ **PROVED тАФ closed-form combination** of boundary + derivative
absolute bounds. Direct composition with
`slabIBP_sum_le_closedFormFirstZeroErrorBound`. -/
theorem lowFirstZeroIBP_sum_le_closedForm
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T ╬│ D : тДЭ}
    (hbdy :
      |lowFirstZeroBoundaryTerm Dzero T0 x y T| тЙд 8 * y * D / T ^ 2)
    (hderiv :
      |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
        тЙд 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T|
      + |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
        тЙд closedFormFirstZeroErrorBound y T ╬│ D :=
  slabIBP_sum_le_closedFormFirstZeroErrorBound hbdy hderiv

