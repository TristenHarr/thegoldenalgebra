      вЙ§ y * (((17/2 : вДЭ) * L + 439/10) / A^2) := by
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT2pos : 0 < T^2 := by positivity
  have hlogT_nn : 0 вЙ§ Real.log T := Real.log_nonneg hT_ge_one
