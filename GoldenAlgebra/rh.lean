-- =====================================================================
-- ┬ºCCLXVI. Canonical-T mid local package + replacement front door
-- =====================================================================
-- Replaces the over-strong `XiResidualFormulaData`-based mid pathway
-- with a canonical-T-only pathway using `XiResidualCanonicalFormulaData`
-- (┬ºCCLXV). The honest mid-band local package picks `T := canonicalAdaptiveT z`
-- per `z`, so the error margin chain is consistent without invoking
-- any tail-Im T-independence claim.
--
-- Adds:
--   trueKernelAdaptiveTail_im_bound                          ÔÇö Im bound at canonical T
--   canonicalMidResidual_closedFormBound                     ÔÇö residual Ôëñ closed form
--   canonicalMidResidual_errorMargin                         ÔÇö residual Ôëñ -Im(M.model)
--   midLocalPackage_of_canonicalResidualFormula              ÔÇö Local mid package
--   XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
--                                                            ÔÇö final replacement front door

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö Im bound for `trueKernelAdaptiveTail` at any
adaptive `T`.** Routes through ┬ºCCLV-3 + Tendsto uniqueness:
`trueKernelAdaptiveTail` and `trueKernelTailOfLogEnvelope` agree at
the adaptive band (both are the XÔåÆÔê× limit of the same complex
partials), so the ┬ºCCLV-3 Im bound transfers. -/
theorem trueKernelAdaptiveTail_im_bound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : Ôäé} {T : ÔäØ}
    (h10 : 10 Ôëñ T) (h140 : T Ôëñ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) Ôëñ T) :
    |(trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im|
      Ôëñ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T := by
  have hT_pos : (0 : ÔäØ) < T := by linarith
  have hT_ge_one : (1 : ÔäØ) Ôëñ T := by linarith
  have hT0_le_T : T0 Ôëñ T := le_trans hT0_le_10 h10
  have hS_T : ÔêÇ u, T Ôëñ u ÔåÆ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2 :=
    fun u hu => hTuring h10 h140 hy hregime hu
  have hSlogEnv : ÔêÇßÂá u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hS_T u hu
  have h1 := trueKernelAdaptiveTail_tendsto
    Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
  have h2 := trueKernelTailOfLogEnvelope_tendsto
    Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv
  have h_eq : trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
            = trueKernelTailOfLogEnvelope
                Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv :=
    tendsto_nhds_unique h1 h2
  rw [h_eq]
  have hC : (0 : ÔäØ) Ôëñ (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD : (0 : ÔäØ) Ôëñ (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  exact trueKernelTailOfLogEnvelope_im_bound
    Dzero T0 hT0_pos hT0_le_T hT_pos hT_ge_one hy hC hD hregime hS_T

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö canonical mid residual closed-form bound.**
Combines `Rcanon` (residual.im = canonical tail.im) with ┬ºCCLXVI's
`trueKernelAdaptiveTail_im_bound` at `T := canonicalAdaptiveT z`. -/
theorem canonicalMidResidual_closedFormBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : Ôäé}
    (hy : 0 < z.im)
    (hmid : Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
      2 * (1 + |z.re| + z.im) Ôëñ T) :
    |(xiResidualError M z).im|
      Ôëñ closedFormSErrorBoundCD
          (slabCD (canonicalAdaptiveT z)).1
          (slabCD (canonicalAdaptiveT z)).2
          z.im
          (canonicalAdaptiveT z) := by
  have hc := canonicalAdaptiveT_spec hmid
  rw [Rcanon.residual_im_eq_canonical_tail hy hmid]
  exact trueKernelAdaptiveTail_im_bound
    Dzero T0 hT0_pos hT0_le_10 hTuring
    hc.1 hc.2.1 hy hc.2.2

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö canonical mid residual model margin.**
Chains the closed-form bound (┬ºCCLXVI step 2) with the slab cert
