-- =====================================================================
-- ┬ºCCXLV. Canonical-T `herror` formulation
-- =====================================================================
-- Mathematical correction: the raw improper tail
-- `Ôê½_T^Ôê× kernel ┬À S` genuinely depends on `T`, so a `herror`
-- quantifying `(error z).im = (trueKernelAdaptiveTail T z).im`
-- for ALL adaptive `T` (with `error` independent of `T`) is too
-- strong ÔÇö it implicitly forces tail independence.
--
-- This section provides a corrected single-`T` formulation:
-- pick one canonical adaptive `T` per `z` (deterministic, via
-- `Classical.choose` inside a `dite`), and require `herror` only
-- at that canonical `T`. The original arbitrary-`T` formulation
-- is preserved (it can still be inhabited if tail independence
-- is actually proved later).
--
-- Adds:
--   canonicalAdaptiveT                                       ÔÇö deterministic zÔåªT
--   canonicalAdaptiveT_spec                                  ÔÇö spec lemma
--   XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail      ÔÇö canonical-T constructor
--   XiPullbackAntiHerglotzTarget_of_errorFormula_canonical   ÔÇö final front door

/-- **Canonical adaptive cutoff at `z`.** A deterministic choice of `T`
satisfying the adaptive band condition `10 Ôëñ T Ôëñ 140` and
`2(1 + |z.re| + z.im) Ôëñ T`, via `Classical.choose` inside a `dite`.
Outside the adaptive region (i.e. when no such `T` exists), returns
the sentinel `10`. -/
noncomputable def canonicalAdaptiveT (z : Ôäé) : ÔäØ :=
  letI : Decidable
      (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) :=
    Classical.propDecidable _
  if h : Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T then
    Classical.choose h
  else
    10

/-- Ô¡É **PROVED ÔÇö canonical T is in the adaptive band when the band
exists for `z`.** -/
lemma canonicalAdaptiveT_spec
    {z : Ôäé}
    (h : Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) :
    10 Ôëñ canonicalAdaptiveT z Ôêº
    canonicalAdaptiveT z Ôëñ 140 Ôêº
    2 * (1 + |z.re| + z.im) Ôëñ canonicalAdaptiveT z := by
  have h_choose := Classical.choose_spec h
  unfold canonicalAdaptiveT
  simp [h, h_choose]

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `XiLogDerivativeFormulaPieces` from canonical-T
herror.** Like `ofErrorAsFluctTail` but using the canonical adaptive
`T` per `z` plus an explicit Im-independence hypothesis. The
`fluctTail_im_eq_trueTail` field is recovered by `htail_indep`
bridging from the canonical `T` to any other adaptive `T`. -/
noncomputable def XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ÔäØ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : ÔäØ) (hTsmooth_ge : 2 * Real.pi Ôëñ Tsmooth)
    (error : Ôäé ÔåÆ Ôäé)
    (hmodel : ÔêÇ z : Ôäé,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_canonical :
      ÔêÇ {z : Ôäé},
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        0 < z.im ÔåÆ
        (error z).im =
          (trueKernelAdaptiveTail
            Dzero T0 hT0_pos hT0_le_10 hTuring
            (canonicalAdaptiveT z) z).im)
    (htail_indep :
      ÔêÇ {z : Ôäé} {TÔéü TÔéé : ÔäØ},
        10 Ôëñ TÔéü ÔåÆ TÔéü Ôëñ 140 ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ TÔéü ÔåÆ
        10 Ôëñ TÔéé ÔåÆ TÔéé Ôëñ 140 ÔåÆ 2 * (1 + |z.re| + z.im) Ôëñ TÔéé ÔåÆ
        0 < z.im ÔåÆ
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TÔéü z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring TÔéé z).im) :
    XiLogDerivativeFormulaPieces
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error :=
  XiLogDerivativeFormulaPieces.ofErrorAsFluctTail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M Tsmooth hTsmooth_ge error
    hmodel hxi
    (by
      intro z T h10 h140 hy hregime
      have hExists : Ôêâ T : ÔäØ,
          10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T :=
        Ôƒ¿T, h10, h140, hregimeÔƒ®
      have hcanon := canonicalAdaptiveT_spec hExists
      have hcan_im : (error z).im =
          (trueKernelAdaptiveTail
            Dzero T0 hT0_pos hT0_le_10 hTuring
            (canonicalAdaptiveT z) z).im :=
        herror_canonical hExists hy
      rw [hcan_im]
      exact htail_indep hcanon.1 hcanon.2.1 hcanon.2.2 h10 h140 hregime hy)

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **CLEAN FRONT DOOR (canonical-T herror).**
Final form with `herror` only required at the canonical adaptive `T`
