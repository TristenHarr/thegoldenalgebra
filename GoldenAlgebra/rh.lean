  obtain Ôƒ¿V, hV_open, hV_mem_self, hV_subÔƒ® := hE_mem
  have hV_nhds : V Ôêê ­ØôØ (1 : Ôäé) := hV_open.mem_nhds hV_mem_self
  have h_bdd : BddAbove (norm Ôêÿ f '' (V \ {1})) := by
    refine Ôƒ¿2, ?_Ôƒ®
    rintro x Ôƒ¿z, Ôƒ¿hz_V, hz_ne_oneÔƒ®, rflÔƒ®
    have hz_in_E : z Ôêê E := hV_sub Ôƒ¿hz_V, hz_ne_oneÔƒ®
