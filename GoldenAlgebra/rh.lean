/-- тнР **PROVED тАФ kernel-factor polynomial bound**
`((10тИТa)┬▓+y┬▓)┬╖((10+a)┬▓+y┬▓) тЙд 116┬╖(100тИТa┬▓+y┬▓)` on `a┬▓+y┬▓ тЙд 16`. -/
lemma kernel_factor_den_le_aux
    {a y : тДЭ} (_ha_nn : 0 тЙд a) (hbox : a ^ 2 + y ^ 2 тЙд 16) :
    ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)
      тЙд 116 * (100 - a ^ 2 + y ^ 2) := by
  have hu : (0 : тДЭ) тЙд a ^ 2 := sq_nonneg a
  have hv : (0 : тДЭ) тЙд y ^ 2 := sq_nonneg y
  have hnn : (0 : тДЭ) тЙд a ^ 2 + y ^ 2 := by linarith
  have hv_le_16 : y ^ 2 тЙд 16 := by linarith
  have h_w_sq_le_256 :
      (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2) тЙд 256 := by
    have h_mul : (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2)
                тЙд (a ^ 2 + y ^ 2) * 16 :=
      mul_le_mul_of_nonneg_left hbox hnn
    linarith
  have h_lhs_expand :
      ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)
        = (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2)
          + 200 * (a ^ 2 + y ^ 2) - 400 * a ^ 2 + 10000 := by
    ring
  rw [h_lhs_expand]
  linarith [h_w_sq_le_256, hu, hv, hv_le_16]

/-- ЁЯМЯ **PROVED тАФ kernel factor uniform LB `5/29`** on the box. -/
theorem smoothKernelNormFactor_ge_five_div_twentyNine
    {x y : тДЭ} (hy : 0 < y) (hbox : x ^ 2 + y ^ 2 тЙд 16) :
    (5 / 29 : тДЭ)
      тЙд (10 - |x|) / ((10 - |x|) ^ 2 + y ^ 2)
        + (10 + |x|) / ((10 + |x|) ^ 2 + y ^ 2) := by
  set a := |x| with ha_def
  have ha_nn : (0 : тДЭ) тЙд a := abs_nonneg x
  have ha_sq : a ^ 2 = x ^ 2 := sq_abs x
  have ha_box : a ^ 2 + y ^ 2 тЙд 16 := by rw [ha_sq]; exact hbox
  have ha_sq_le_16 : a ^ 2 тЙд 16 := by
    have := sq_nonneg y; linarith
  have ha_le_4 : a тЙд 4 := by
    nlinarith [sq_nonneg (a - 4), ha_sq_le_16, ha_nn]
  have h_10_sub_a_pos : (0 : тДЭ) < 10 - a := by linarith
  have h_10_add_a_pos : (0 : тДЭ) < 10 + a := by linarith
  have h_A_pos : (0 : тДЭ) < (10 - a) ^ 2 + y ^ 2 := by positivity
  have h_B_pos : (0 : тДЭ) < (10 + a) ^ 2 + y ^ 2 := by positivity
  have h_D_pos : (0 : тДЭ) <
