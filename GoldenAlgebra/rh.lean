-- ¬ІCCCLII. Finite zero-sum Stieltjes formula (complex equality)
-- =====================================================================

/-- рЯУ¶ **`LowFiniteZeroSumStieltjesFormulaAFZ`** вАФ complex-equality
form of the low Stieltjes contribution. -/
structure LowFiniteZeroSumStieltjesFormulaAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (ZC : вДВ вЖТ вДВ) : Prop where
  zero_sum_formula :
    вИА z : вДВ,
