noncomputable def unitKernelRectangleToSquareDeformation_of_coordinateIdentity
    {R : ZetaRectangle} {a : ℂ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripCoordinateBoundarySumIdentity S) :
