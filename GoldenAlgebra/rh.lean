-- ¬ІCDXXXVI. Completed-zeta off-pole raw formula source
-- =====================================================================

/-- рЯУ¶ **`CompletedRiemannZetaRawOffPoleFormula`** вАФ Mathlib's
`completedRiemannZeta s = ѕА^(-s/2) ¬Ј ќУ(s/2) ¬Ј ќґ(s)` away from ќУ poles. -/
structure CompletedRiemannZetaRawOffPoleFormula : Prop where
  eq_raw :
    вИА s : вДВ,
      s / 2 вИЙ gammaPoleSet вЖТ
      completedRiemannZeta s
        = Complex.exp (-(s / 2) * (Real.log Real.pi : вДВ))
          * Complex.Gamma (s / 2) * riemannZeta s

/-- в≠Р **PROVED вАФ off ќУ-poles implies `s вЙ† 0`.** -/
theorem ne_zero_of_half_not_gammaPole
    {s : вДВ} (hsPole : s / 2 вИЙ gammaPoleSet) :
    s вЙ† 0 := by
  intro hs
  apply hsPole
  rw [hs]
  exact вЯ®0, by simpвЯ©

/-- в≠Р **PROVED вАФ off ќУ-poles implies the Deligne ќУ-factor is nonzero.** -/
theorem GammaReal_ne_zero_of_half_not_gammaPole
    {s : вДВ} (hsPole : s / 2 вИЙ gammaPoleSet) :
    GammaвДЭ s вЙ† 0 := by
  intro hG
  rcases Complex.GammaвДЭ_eq_zero_iff.mp hG with вЯ®n, hnвЯ©
  apply hsPole
  exact вЯ®n, by rw [hn]; ringвЯ©

/-- в≠Р **PROVED вАФ `GammaвДЭ` as the explicit exponential ќУ-factor.** -/
theorem GammaReal_eq_exp_gamma (s : вДВ) :
    GammaвДЭ s =
      Complex.exp (-(s / 2) * (Real.log Real.pi : вДВ))
        * Complex.Gamma (s / 2) := by
  rw [GammaвДЭ_def]
  congr 1
  rw [Complex.cpow_def_of_ne_zero]
  ¬Ј congr 1
    rw [Complex.ofReal_log Real.pi_pos.le]
    ring
  ¬Ј exact Complex.ofReal_ne_zero.mpr Real.pi_ne_zero

/-- рЯМЯрЯМЯ **PROVED unconditionally** вАФ Mathlib's completed zeta is the
raw ќУ¬Јќґ expression off ќУ-poles. -/
theorem completedRiemannZetaRawOffPoleFormula :
    CompletedRiemannZetaRawOffPoleFormula := by
  refine вЯ®?_вЯ©
  intro s hsPole
  have hs0 : s вЙ† 0 := ne_zero_of_half_not_gammaPole hsPole
  have hG : GammaвДЭ s вЙ† 0 := GammaReal_ne_zero_of_half_not_gammaPole hsPole
  calc
    completedRiemannZeta s
        = GammaвДЭ s * riemannZeta s := by
            have hz := riemannZeta_def_of_ne_zero (s := s) hs0
            rw [hz]
            field_simp [hG]
    _ = Complex.exp (-(s / 2) * (Real.log Real.pi : вДВ))
          * Complex.Gamma (s / 2) * riemannZeta s := by
            rw [GammaReal_eq_exp_gamma]

