/-- Ô¡É **PROVED ÔÇö sharper cloud lower bound using combined `x┬▓ + y┬▓` cap.**
For any `M ÔëÑ 0` with `x┬▓ + y┬▓ Ôëñ M┬▓` and `y > 0`:
  `simpleCloudSum zeros x y ÔëÑ 2y ┬À ╬ú 1/(M┬▓ + ╬│┬▓)`.
Tighter than the per-axis `simpleCloudSum_ge_const_bound` (which uses
`x_max┬▓ + y_max┬▓`, loose when worst-case `(x_max, y_max)` is impossible). -/
theorem simpleCloudSum_ge_T_box_bound
    (zeros : List ÔäØ) (x y M : ÔäØ)
    (h_sq : x^2 + y^2 Ôëñ M^2) (hy : 0 < y) :
    2 * y * (zeros.map fun g => 1 / (M^2 + g^2)).sum
      Ôëñ simpleCloudSum zeros x y := by
  unfold simpleCloudSum
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_den_pos : 0 < x^2 + g^2 + y^2 := by positivity
    have h_den_le : x^2 + g^2 + y^2 Ôëñ M^2 + g^2 := by linarith [sq_nonneg g]
    have h_term : 1 / (M^2 + g^2) Ôëñ 1 / (x^2 + g^2 + y^2) :=
      one_div_le_one_div_of_le h_den_pos h_den_le
    have hy_nn : (0 : ÔäØ) Ôëñ 2 * y := by linarith
    have h_term_mul : 2 * y * (1 / (M^2 + g^2))
                    Ôëñ 2 * y * (1 / (x^2 + g^2 + y^2)) :=
      mul_le_mul_of_nonneg_left h_term hy_nn
    have h_two_y_div :
        2 * y * (1 / (x^2 + g^2 + y^2)) = 2 * y / (x^2 + g^2 + y^2) := by
      field_simp
    have h_two_y_div_max :
        2 * y * (1 / (M^2 + g^2)) = 2 * y / (M^2 + g^2) := by field_simp
    have h_distrib :
        2 * y * (1 / (M^2 + g^2)
            + (List.map (fun g => 1 / (M^2 + g^2)) rest).sum)
          = 2 * y * (1 / (M^2 + g^2))
            + 2 * y * (List.map (fun g => 1 / (M^2 + g^2)) rest).sum := by
      ring
    rw [h_distrib]
    linarith [h_term_mul, h_two_y_div, h_two_y_div_max, ih]

/-- Ô¡É **PROVED ÔÇö `log T Ôëñ log TÔéÇ + (T - TÔéÇ)/TÔéÇ`** for `T, TÔéÇ > 0`.
Concavity of log; tangent at `TÔéÇ` is an upper bound. -/
theorem Real.log_le_tangent {T TÔéÇ : ÔäØ} (hT : 0 < T) (hTÔéÇ : 0 < TÔéÇ) :
    Real.log T Ôëñ Real.log TÔéÇ + (T - TÔéÇ) / TÔéÇ := by
  -- From `log (T/TÔéÇ) Ôëñ T/TÔéÇ - 1`: log T - log TÔéÇ Ôëñ (T - TÔéÇ)/TÔéÇ
  have h_ratio_pos : 0 < T / TÔéÇ := div_pos hT hTÔéÇ
  have h := Real.log_le_sub_one_of_pos h_ratio_pos
  -- h : log (T/TÔéÇ) Ôëñ T/TÔéÇ - 1
  rw [Real.log_div (ne_of_gt hT) (ne_of_gt hTÔéÇ)] at h
  -- h : log T - log TÔéÇ Ôëñ T/TÔéÇ - 1 = (T - TÔéÇ)/TÔéÇ
  have h_simp : (T - TÔéÇ) / TÔéÇ = T / TÔéÇ - 1 := by
    field_simp
  linarith [h, h_simp]

/-- Ô¡É **PROVED ÔÇö secant lower bound for `Real.log`** on `[╬▒, ╬▓] Ôèå (0, Ôê×)`. -/
theorem Real.secant_le_log
    {╬▒ ╬▓ T : ÔäØ} (h╬▒ : 0 < ╬▒) (h╬▒╬▓ : ╬▒ < ╬▓) (h╬▒T : ╬▒ Ôëñ T) (hT╬▓ : T Ôëñ ╬▓) :
    ((╬▓ - T) / (╬▓ - ╬▒)) * Real.log ╬▒ + ((T - ╬▒) / (╬▓ - ╬▒)) * Real.log ╬▓
      Ôëñ Real.log T := by
  have h╬▓ : 0 < ╬▓ := lt_trans h╬▒ h╬▒╬▓
  have h╬▓╬▒ : 0 < ╬▓ - ╬▒ := by linarith
  set a := (╬▓ - T) / (╬▓ - ╬▒) with ha_def
  set b := (T - ╬▒) / (╬▓ - ╬▒) with hb_def
  have ha_nn : 0 Ôëñ a := div_nonneg (by linarith) (le_of_lt h╬▓╬▒)
  have hb_nn : 0 Ôëñ b := div_nonneg (by linarith) (le_of_lt h╬▓╬▒)
  have hab : a + b = 1 := by
    unfold a b
    rw [div_add_div_same]
    field_simp
  have h_avg : a * ╬▒ + b * ╬▓ = T := by
    unfold a b
    field_simp
    ring
  have h╬▒_mem : ╬▒ Ôêê Set.Ioi (0 : ÔäØ) := h╬▒
  have h╬▓_mem : ╬▓ Ôêê Set.Ioi (0 : ÔäØ) := h╬▓
  have h_concave := strictConcaveOn_log_Ioi.concaveOn.2 h╬▒_mem h╬▓_mem ha_nn hb_nn hab
  simp only [smul_eq_mul] at h_concave
  rw [h_avg] at h_concave
  exact h_concave

