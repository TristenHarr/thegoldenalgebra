-- ┬зCDXIX. Direct proof: `gammaPoleSet` is closed
-- =====================================================================
-- Strategy:
--   gammaPoleSet = Neg.neg тБ╗┬╣' (Set.range ((тЖС) : тДХ тЖТ тДВ))
--   Set.range ((тЖС) : тДХ тЖТ тДВ) = (Im тБ╗┬╣' {0}) тИй (Re тБ╗┬╣' Set.range ((тЖС) : тДХ тЖТ тДЭ))
--   Both factors closed (singleton + Nat closed embedding to тДЭ).

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `gammaPoleSet` is closed in тДВ.** -/
theorem isClosed_gammaPoleSet : IsClosed gammaPoleSet := by
  -- Step 1: `gammaPoleSet = -┬╖тБ╗┬╣ Set.range ((тЖС) : тДХ тЖТ тДВ)`.
  have h_eq : gammaPoleSet = Neg.neg тБ╗┬╣' Set.range ((тЖС) : тДХ тЖТ тДВ) := by
    ext z
    constructor
    ┬╖ rintro тЯиn, hnтЯй
      refine тЯиn, ?_тЯй
      simp [hn]
    ┬╖ rintro тЯиn, hnтЯй
      refine тЯиn, ?_тЯй
      have : -((n : тДВ)) = z := by rw [hn]; ring
      exact this.symm
  rw [h_eq]
  refine IsClosed.preimage continuous_neg ?_
  -- Step 2: `Set.range ((тЖС) : тДХ тЖТ тДВ) = (ImтБ╗┬╣{0}) тИй (ReтБ╗┬╣ Set.range ((тЖС) : тДХ тЖТ тДЭ))`.
  have h_re_im :
      Set.range ((тЖС) : тДХ тЖТ тДВ)
        = (Complex.im тБ╗┬╣' ({0} : Set тДЭ)) тИй
          (Complex.re тБ╗┬╣' Set.range ((тЖС) : тДХ тЖТ тДЭ)) := by
    ext z
    constructor
    ┬╖ rintro тЯиn, rflтЯй
      refine тЯи?_, n, ?_тЯй
      ┬╖ simp
      ┬╖ simp
    ┬╖ rintro тЯиhim, n, hreтЯй
      refine тЯиn, ?_тЯй
      apply Complex.ext
      ┬╖ -- goal: ((n : тДВ)).re = z.re
        have h3 : ((n : тДВ)).re = (n : тДЭ) := by simp
        exact h3.trans hre
      ┬╖ -- goal: ((n : тДВ)).im = z.im
        have h4 : ((n : тДВ)).im = 0 := by simp
        exact h4.trans him.symm
  rw [h_re_im]
  refine IsClosed.inter ?_ ?_
  ┬╖ exact isClosed_singleton.preimage Complex.continuous_im
  ┬╖ exact Nat.isClosedEmbedding_coe_real.isClosed_range.preimage
      Complex.continuous_re

