      intro R'
      rw [ÔåÉ rectangleIntegral_unitPrincipalKernel_eq]
      exact rectangleIntegral_eq_coordinateBoundaryIntegral
        (rectangleEdgeIntegralCoordinateBridge R' (unitPrincipalKernel a))
    have h_inner :
        R.smallSquareUnitKernelIntegral S =
          S.toRectangle.coordinateBoundaryIntegral (unitPrincipalKernel a) := by
      unfold smallSquareUnitKernelIntegral
      exact h_to_coord S.toRectangle
    rw [h_to_coord S.topStrip, h_to_coord S.bottomStrip,
        h_to_coord S.leftStrip, h_to_coord S.rightStrip,
        h_to_coord R, h_inner]
    exact H.coordinate_sum_eq

