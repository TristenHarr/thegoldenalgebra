  have h_exp_pow_lt :
      (Real.exp (739 / 125 : вДЭ))^125 < (370 : вДЭ)^125 := by
    rw [h_exp_739_125_pow, h_exp739_eq]
    linarith
  have hexp_nn : 0 вЙ§ Real.exp (739 / 125 : вДЭ) :=
    le_of_lt (Real.exp_pos _)
  have h370_nn : (0 : вДЭ) вЙ§ 370 := by norm_num
  exact
    (pow_lt_pow_iff_leftвВА hexp_nn h370_nn
      (by norm_num : (125 : вДХ) вЙ† 0)).mp h_exp_pow_lt

/-- `exp (59113/10000) < 370`, so the near-optimal
Platt--Trudgian tail split still needs only the concrete finite endpoint
