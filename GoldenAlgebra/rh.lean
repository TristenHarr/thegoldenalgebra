-- §CCLXXXIV. Bounded low IBP internal pieces
-- =====================================================================
-- Build the bounded-interval analogues of the mid/high IBP objects for
-- the first-zero gap `[T, γ]`. Concretely:
--
--   (A) `abs_pairedCauchyImKernel_adaptive_8` — boundary kernel bound
--       `|k(T)| ≤ 8y/T²` on the adaptive regime `2(1 + |x| + y) ≤ T`.
--   (B) `lowFirstZeroIBPIntegrand` — the bounded IBP integrand
--       `S(u) · k'(u)` with `S := Phase1IBP.finiteFluctuationPrimitive`.
--   (C) `lowFirstZeroDerivativeSide` — bounded integral over `[T, γ]`
--       with a `rfl` bridge to `Phase1IBP.derivativeSidePartial`.
--   (D) `lowFirstZeroBoundaryTerm` — `k(T) · S(T)` boundary product.
--   (E) `lowFirstZeroBoundaryTerm_abs_le` — boundary absolute bound
--       `≤ 8 y D / T²` under `|S(T)| ≤ D` + adaptive regime.
--   (F) `integral_eighteen_y_D_over_u3` — FTC evaluation
--       `∫_T^γ 18yD/u³ = 9yD/T² − 9yD/γ²`.
--   (G) `lowFirstZeroDerivativeSide_abs_le_majorant` — derivative-side
--       absolute bound `≤ 9 y D / T² − 9 y D / γ²` under pointwise
--       `|S| ≤ D`, adaptive regime, and integrability.
--   (H) `lowFirstZeroIBP_sum_le_closedForm` — combined bound
--       `|boundary| + |derivative| ≤ closedFormFirstZeroErrorBound y T γ D`
--       via the existing `slabIBP_sum_le_closedFormFirstZeroErrorBound`.

/-- ⭐ **PROVED — adaptive `8y/T²` kernel bound** at the boundary.
On the adaptive regime `2(1 + |x| + y) ≤ T`,
`|pairedCauchyImKernel x y T| ≤ 8 · y / T²`. -/
lemma abs_pairedCauchyImKernel_adaptive_8
    {x y T : ℝ} (hy : 0 ≤ y) (h_reg : 2 * (1 + |x| + y) ≤ T) :
    |pairedCauchyImKernel x y T| ≤ 8 * y / T ^ 2 := by
  have hx_nn : 0 ≤ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_x_lt_T : |x| < T := by linarith
  have h_kbnd : |pairedCauchyImKernel x y T| ≤ 2 * y / (T - |x|) ^ 2 :=
    Phase1IBP.abs_pairedCauchyImKernel_le_quadratic_tail x y T hy h_x_lt_T
  have h_T_minus_x_ge : T / 2 ≤ T - |x| := by linarith
  have h_T_minus_x_nn : (0 : ℝ) ≤ T / 2 := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_sq_ge : (T / 2) ^ 2 ≤ (T - |x|) ^ 2 :=
    pow_le_pow_left₀ h_T_minus_x_nn h_T_minus_x_ge 2
  have h_half_sq_eq : (T / 2) ^ 2 = T ^ 2 / 4 := by ring
  rw [h_half_sq_eq] at h_sq_ge
  have h_sq_pos : 0 < (T - |x|) ^ 2 := pow_pos h_T_minus_x_pos 2
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_target : 2 * y / (T - |x|) ^ 2 ≤ 8 * y / T ^ 2 := by
    rw [div_le_div_iff₀ h_sq_pos h_T_sq_pos]
    nlinarith [h_sq_ge, hy]
  linarith

/-- **Bounded low IBP integrand**: `S(u) · k'(u)` with
`S := Phase1IBP.finiteFluctuationPrimitive Dzero T0`. -/
noncomputable def lowFirstZeroIBPIntegrand
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y : ℝ) :
    ℝ → ℝ :=
  fun u =>
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
      pairedCauchyImKernelDeriv x y u

/-- **Bounded low IBP derivative-side integral** over `[T, γ]`. -/
noncomputable def lowFirstZeroDerivativeSide
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T γ : ℝ) : ℝ :=
  ∫ u in T..γ, lowFirstZeroIBPIntegrand Dzero T0 x y u

/-- ⭐ **PROVED — `rfl` bridge to `Phase1IBP.derivativeSidePartial`.** -/
lemma lowFirstZeroDerivativeSide_eq_partial
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T γ : ℝ) :
    lowFirstZeroDerivativeSide Dzero T0 x y T γ =
      Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) x y T γ :=
  rfl

/-- **Bounded low IBP boundary term**: `k(T) · S(T)`. -/
noncomputable def lowFirstZeroBoundaryTerm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 x y T : ℝ) : ℝ :=
  pairedCauchyImKernel x y T *
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 T

/-- ⭐ **PROVED — boundary absolute bound `≤ 8 y D / T²`** under
`|S(T)| ≤ D` and the adaptive regime. -/
theorem lowFirstZeroBoundaryTerm_abs_le
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T D : ℝ}
    (hy : 0 ≤ y)
    (h_reg : 2 * (1 + |x| + y) ≤ T)
    (hS_T : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T| ≤ D) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T| ≤ 8 * y * D / T ^ 2 := by
  unfold lowFirstZeroBoundaryTerm
  have hx_nn : 0 ≤ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_k_bnd : |pairedCauchyImKernel x y T| ≤ 8 * y / T ^ 2 :=
    abs_pairedCauchyImKernel_adaptive_8 hy h_reg
  have h_k_nn : 0 ≤ 8 * y / T ^ 2 := by positivity
  have h_D_nn : 0 ≤ D := le_trans (abs_nonneg _) hS_T
  rw [abs_mul]
  calc |pairedCauchyImKernel x y T|
        * |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T|
      ≤ (8 * y / T ^ 2) * D :=
        mul_le_mul h_k_bnd hS_T (abs_nonneg _) h_k_nn
    _ = 8 * y * D / T ^ 2 := by ring

/-- ⭐ **PROVED — FTC evaluation of the majorant integral**:
`∫_T^γ 18·y·D/u³ du = 9·y·D/T² − 9·y·D/γ²`.

Antiderivative `F(u) := −9·y·D/u²`, with `F'(u) = 18·y·D/u³` for `u ≠ 0`.
Applies `intervalIntegral.integral_eq_sub_of_hasDerivAt`. -/
lemma integral_eighteen_y_D_over_u3
    {y D T γ : ℝ} (hT_pos : 0 < T) (hTγ : T ≤ γ) :
    ∫ u in T..γ, 18 * y * D / u ^ 3
      = 9 * y * D / T ^ 2 - 9 * y * D / γ ^ 2 := by
  have hγ_pos : 0 < γ := lt_of_lt_of_le hT_pos hTγ
  have h_deriv : ∀ u ∈ Set.uIcc T γ,
      HasDerivAt (fun v : ℝ => -9 * y * D / v ^ 2)
        (18 * y * D / u ^ 3) u := by
    intro u hu
    rw [Set.uIcc_of_le hTγ] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    have hu_ne : u ≠ 0 := ne_of_gt hu_pos
    have hu_sq_ne : u ^ 2 ≠ 0 := pow_ne_zero 2 hu_ne
    have h_num : HasDerivAt (fun _ : ℝ => -9 * y * D) 0 u :=
      hasDerivAt_const u _
    have h_den : HasDerivAt (fun v : ℝ => v ^ 2)
                  ((2 : ℕ) * u ^ (2 - 1)) u :=
      hasDerivAt_pow 2 u
    have h_div_raw : HasDerivAt
        (fun v : ℝ => -9 * y * D / v ^ 2)
        ((0 * u ^ 2 - (-9 * y * D) * ((2 : ℕ) * u ^ (2 - 1))) / (u ^ 2) ^ 2) u :=
      h_num.div h_den hu_sq_ne
    convert h_div_raw using 1
    have hu_cube_ne : u ^ 3 ≠ 0 := pow_ne_zero 3 hu_ne
    field_simp
    ring
  have h_cont : ContinuousOn (fun u : ℝ => 18 * y * D / u ^ 3)
                  (Set.uIcc T γ) := by
    rw [Set.uIcc_of_le hTγ]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_int : IntervalIntegrable (fun u : ℝ => 18 * y * D / u ^ 3)
                MeasureTheory.volume T γ :=
    h_cont.intervalIntegrable
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int]
  ring

/-- 🌟 **PROVED — derivative-side absolute bound** `≤ 9 y D / T² − 9 y D / γ²`
under pointwise `|S| ≤ D`, the adaptive regime, and integrability of
`|S · k'|`. -/
theorem lowFirstZeroDerivativeSide_abs_le_majorant
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    {x y T γ D : ℝ}
    (hy : 0 < y)
    (h_reg : 2 * (1 + |x| + y) ≤ T)
    (hTγ : T ≤ γ)
    (hD : 0 ≤ D)
    (hS : ∀ u, T ≤ u → u ≤ γ →
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| ≤ D)
    (hSint : IntervalIntegrable
              (fun u => |lowFirstZeroIBPIntegrand Dzero T0 x y u|)
              MeasureTheory.volume T γ) :
    |lowFirstZeroDerivativeSide Dzero T0 x y T γ|
      ≤ 9 * y * D / T ^ 2 - 9 * y * D / γ ^ 2 := by
  unfold lowFirstZeroDerivativeSide
  have hx_nn : 0 ≤ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_abs_int :
      |∫ u in T..γ, lowFirstZeroIBPIntegrand Dzero T0 x y u|
        ≤ ∫ u in T..γ, |lowFirstZeroIBPIntegrand Dzero T0 x y u| :=
    intervalIntegral.abs_integral_le_integral_abs hTγ
  have h_pointwise : ∀ u ∈ Set.Icc T γ,
      |lowFirstZeroIBPIntegrand Dzero T0 x y u| ≤ 18 * y * D / u ^ 3 := by
    intro u hu
    obtain ⟨huT, huγ⟩ := hu
    unfold lowFirstZeroIBPIntegrand
    rw [abs_mul]
    have hS_u : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| ≤ D :=
      hS u huT huγ
    have h_k_bnd : |pairedCauchyImKernelDeriv x y u| ≤ 18 * y / u ^ 3 :=
      abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le h_reg huT
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos huT
    have h_k_nn : 0 ≤ 18 * y / u ^ 3 := by positivity
    calc |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          * |pairedCauchyImKernelDeriv x y u|
        ≤ D * (18 * y / u ^ 3) :=
          mul_le_mul hS_u h_k_bnd (abs_nonneg _) hD
      _ = 18 * y * D / u ^ 3 := by ring
  have h_maj_cont : ContinuousOn (fun u : ℝ => 18 * y * D / u ^ 3)
                      (Set.uIcc T γ) := by
    rw [Set.uIcc_of_le hTγ]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_maj_int : IntervalIntegrable (fun u : ℝ => 18 * y * D / u ^ 3)
                    MeasureTheory.volume T γ :=
    h_maj_cont.intervalIntegrable
  have h_int_mono :
      ∫ u in T..γ, |lowFirstZeroIBPIntegrand Dzero T0 x y u|
        ≤ ∫ u in T..γ, 18 * y * D / u ^ 3 :=
    intervalIntegral.integral_mono_on hTγ hSint h_maj_int h_pointwise
  have h_maj_eval :
      ∫ u in T..γ, 18 * y * D / u ^ 3
        = 9 * y * D / T ^ 2 - 9 * y * D / γ ^ 2 :=
    integral_eighteen_y_D_over_u3 hT_pos hTγ
  linarith [h_abs_int, h_int_mono, h_maj_eval]

/-- 🌟🌟 **PROVED — closed-form combination** of boundary + derivative
absolute bounds. Direct composition with
`slabIBP_sum_le_closedFormFirstZeroErrorBound`. -/
theorem lowFirstZeroIBP_sum_le_closedForm
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T γ D : ℝ}
    (hbdy :
      |lowFirstZeroBoundaryTerm Dzero T0 x y T| ≤ 8 * y * D / T ^ 2)
    (hderiv :
      |lowFirstZeroDerivativeSide Dzero T0 x y T γ|
        ≤ 9 * y * D / T ^ 2 - 9 * y * D / γ ^ 2) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T|
      + |lowFirstZeroDerivativeSide Dzero T0 x y T γ|
        ≤ closedFormFirstZeroErrorBound y T γ D :=
  slabIBP_sum_le_closedFormFirstZeroErrorBound hbdy hderiv

-- =====================================================================
-- §CCLXXXII. Path B AwayFromZeros — close the `a/0=0` residue gap end to end
-- =====================================================================
-- The residual route from §CCLVII–§CCLXXX assumes its analytic hypotheses
-- pointwise at every UHP `z` in the relevant band, with no guard against
-- hypothetical zeros of `XiPullback`. Lean's `a / 0 = 0` totalization
-- then forces `xiResidualError M ρ = −M.model ρ` at any such zero, making
-- residual-equality / strict-bound hypotheses unprovable except by first
-- ruling out the zero (which is RH). The fix mirrors §6-bis / §CCL-bis:
-- weaken the public analytic input by an explicit `XiPullback z ≠ 0`
-- guard, and discharge the zero case internally with
-- `errorMargin_at_XiPullback_zero_of_decomp`.
--
-- Adds:
--   XiCanonicalResidualAsTailLimitAwayFromZeros
--   XiHighResidualAsTailLimitAwayFromZeros
--   XiResidualCanonicalFormulaDataAwayFromZeros
--   XiHighResidualFormulaDataAwayFromZeros
--   XiResidualCanonicalFormulaDataAwayFromZeros.of_complex_tendsto
--   XiHighResidualFormulaDataAwayFromZeros.of_complex_tendsto
--   Rcanon_twoPi_of_tailLimitAwayFromZeros
--   XiHighResidualFormulaData_of_tailLimitAwayFromZeros
--   canonicalMidResidual_errorMargin_AwayFromZeros
--   midLocalPackage_of_canonicalResidualFormulaAwayFromZeros
--   highLocalPackage_of_XiHighResidualFormulaDataAwayFromZeros
--   XiLowResidualExplicitDataAtAwayFromZeros
--   XiLowResidualExplicitData_11_14_halfAwayFromZeros
--   XiLowResidualMargin_of_explicitAtAwayFromZeros_and_marginAt
--   XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMidAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_honestZeroDensityAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_twoPiModelAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_tailLimitsAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicitAtAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicitAt_arithAwayFromZeros
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit_11_14_halfAwayFromZeros

/-! ### Guarded tail-limit structures -/

/-- 📦 **Guarded mid tail-limit.** Same as `XiCanonicalResidualAsTailLimit`
but the Tendsto target identity is only asserted at `z` with
`XiPullback z ≠ 0`. At totalized zeros the identity has no chance of
holding (the LHS integral is continuous in `z`, the RHS is the forced
value `−M.model(ρ)`), so this guard is what makes the hypothesis
genuinely weaker than RH. -/
structure XiCanonicalResidualAsTailLimitAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  tendsto_canonical :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      XiPullback z ≠ 0 →
      Tendsto
        (fun X : ℝ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z)
        Filter.atTop
        (𝓝 (xiResidualError M z))

/-- 📦 **Guarded high tail-limit.** -/
structure XiHighResidualAsTailLimitAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  tendsto_high :
    ∀ {z : ℂ} {T : ℝ},
      140 ≤ T → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      XiPullback z ≠ 0 →
      Tendsto
        (fun X : ℝ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop
        (𝓝 (xiResidualError M z))

/-- **Old unguarded mid tail-limit ⇒ guarded.** Trivial weakening. -/
theorem XiCanonicalResidualAsTailLimitAwayFromZeros_of_unguarded
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiCanonicalResidualAsTailLimit Dzero T0 M) :
    XiCanonicalResidualAsTailLimitAwayFromZeros Dzero T0 M :=
  ⟨fun hz hmid _ => H.tendsto_canonical hz hmid⟩

/-- **Old unguarded high tail-limit ⇒ guarded.** Trivial weakening. -/
theorem XiHighResidualAsTailLimitAwayFromZeros_of_unguarded
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiHighResidualAsTailLimit Dzero T0 M) :
    XiHighResidualAsTailLimitAwayFromZeros Dzero T0 M :=
  ⟨fun hT hy hreg _ => H.tendsto_high hT hy hreg⟩

/-! ### Guarded formula-data structures -/

/-- 📦 **Guarded mid formula data.** Same as `XiResidualCanonicalFormulaData`
but the residual-equals-canonical-tail identity only holds at
`XiPullback z ≠ 0`. -/
structure XiResidualCanonicalFormulaDataAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_canonical_tail :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      XiPullback z ≠ 0 →
      (xiResidualError M z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im

/-- **Guarded high residual tail identity.** Same as
`XiHighResidualTailIdentity` but only required at `XiPullback z ≠ 0`. -/
def XiHighResidualTailIdentityAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ)) : Prop :=
  ∀ {z : ℂ} {T : ℝ}
    (hT140 : 140 ≤ T) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T),
    XiPullback z ≠ 0 →
    (xiResidualError M z).im =
      (trueKernelTailOfLogEnvelope
        Dzero T0 hT0_pos
        (le_trans hT0_le_140 hT140)
        (by linarith : (0 : ℝ) < T)
        hy
        (by
          filter_upwards [Filter.eventually_ge_atTop T] with u hu
          exact hHighLog hT140 hy hregime hu)).im

/-- 📦 **Guarded high formula data.** -/
structure XiHighResidualFormulaDataAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ)) : Prop where
  residual_im_eq_highTail :
    XiHighResidualTailIdentityAwayFromZeros
      Dzero T0 hT0_pos hT0_le_140 M hHighLog

/-! ### Bridges: guarded Tendsto → guarded formula data -/

/-- 🌟🌟🌟 **PROVED — guarded mid formula data from guarded Tendsto.**
The proof copies `xiResidualCanonicalTailIdentity_of_complex_tendsto` but
threads the `XiPullback z ≠ 0` guard through. The guard is consumed at
the call to `hResTendsto`, not at the analysis step. -/
def XiResidualCanonicalFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hResTendsto :
      ∀ {z : ℂ},
        0 < z.im →
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        XiPullback z ≠ 0 →
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop (𝓝 (xiResidualError M z))) :
    XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring M := by
  refine ⟨?_⟩
  intro z hy hmid hne
  have hc := canonicalAdaptiveT_spec hmid
  have h_res_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop (𝓝 (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp (hResTendsto hy hmid hne)
  have h_tail_tendsto :=
    trueKernelAdaptiveTail_tendsto
      Dzero T0 hT0_pos hT0_le_10 hTuring
      hc.1 hc.2.1 hy hc.2.2
  have h_tail_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop
        (𝓝 (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

/-- 🌟🌟🌟 **PROVED — guarded high formula data from guarded Tendsto.**
Same chain as `xiHighResidualTailIdentity_of_complex_tendsto`, with the
`XiPullback z ≠ 0` guard threaded through. -/
def XiHighResidualFormulaDataAwayFromZeros.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (H : XiHighResidualAsTailLimitAwayFromZeros Dzero T0 M) :
    XiHighResidualFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_140 M hHighLog := by
  refine ⟨?_⟩
  intro z T hT140 hy hregime hne
  have hSlogEnv : ∀ᶠ u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  have h_res_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop (𝓝 (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp
      (H.tendsto_high hT140 hy hregime hne)
  have h_tail_tendsto :=
    trueKernelTailOfLogEnvelope_tendsto
      Dzero T0 hT0_pos
      (le_trans hT0_le_140 hT140)
      (by linarith : (0 : ℝ) < T) hy hSlogEnv
  have h_tail_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop
        (𝓝 (trueKernelTailOfLogEnvelope
          Dzero T0 hT0_pos
          (le_trans hT0_le_140 hT140)
          (by linarith : (0 : ℝ) < T) hy hSlogEnv).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

