/-- тнР **PROVED тАФ TOP-LEVEL one-shot via the bundle.** -/
theorem hclosed_on_10_140_of_polyBundle
    (M : CloudDensityTailModelDecomposition)
    (B : NineSlabPolyInequalities M.zeros)
    {z : тДВ} {T : тДЭ}
    (hT10 : 10 тЙд T) (hT140 : T тЙд 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
