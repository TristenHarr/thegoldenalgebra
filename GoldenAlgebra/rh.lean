  have hTÔéü_pos : 0 < TÔéü := by linarith
  have hTÔéé_pos : 0 < TÔéé := by linarith
  rw [div_le_div_iffÔéÇ hTÔéé_pos hTÔéü_pos]
  nlinarith [h_T_le, hTÔéü_19]

/-- Ô¡É **PROVED ÔÇö Uniform piece lift for `[19, 32]`.**
Given a numerical check at one piece `[a, b]`, lifts to all `T Ôêê [a, b]`. -/
lemma scalar_19_32_piece_lift
    {T a b : ÔäØ}
    (h_a_19 : 19 Ôëñ a) (h_b_32 : b Ôëñ 32) (_h_a_le_b : a Ôëñ b)
    (h_T_lo : a Ôëñ T) (h_T_hi : T Ôëñ b)
    (h_num : (17 : ÔäØ) / a^2 Ôëñ 2 * cloudK_T zeros100ceil b + tailK19_rat b) :
    (17 : ÔäØ) / T^2 Ôëñ 2 * cloudK_T zeros100ceil T + tailK19_rat T := by
  have h_a_pos : 0 < a := by linarith
  have hT_pos : 0 < T := by linarith
  have h_lhs : (17 : ÔäØ) / T^2 Ôëñ 17 / a^2 := by
    have h_a_sq_pos : 0 < a^2 := by positivity
    have h_T_sq_ge : a^2 Ôëñ T^2 := by nlinarith
    exact div_le_div_of_nonneg_left (by norm_num) h_a_sq_pos h_T_sq_ge
  have h_T_box_pos : 0 < T / 2 - 1 := by linarith
  have h_cloud : cloudK_T zeros100ceil b Ôëñ cloudK_T zeros100ceil T :=
    cloudK_T_antitone_T zeros100ceil h_T_box_pos h_T_hi
  have h_T_19 : 19 Ôëñ T := by linarith
  have h_T_32 : T Ôëñ 32 := by linarith
  have h_tail : tailK19_rat b Ôëñ tailK19_rat T :=
    tailK19_rat_antitone_T h_T_19 h_b_32 h_T_hi
  linarith [h_lhs, h_num, h_cloud, h_tail]

