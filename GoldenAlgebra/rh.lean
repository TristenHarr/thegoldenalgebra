/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö guarded `highTErrorControlledAwayFromZeros` from
guarded log-envelope identity.** Guarded analog of
`highTErrorControlled_of_highTuringLogEnvelope`. -/
theorem highTErrorControlledAwayFromZeros_of_highTuringLogEnvelope
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 Ôëñ 140)
    (error : Ôäé ÔåÆ Ôäé)
    (hHighLog :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        140 Ôëñ T ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (1 / 2 : ÔäØ) * Real.log u + (49 / 20 : ÔäØ))
    (herror_high :
      ÔêÇ {z : Ôäé} {T : ÔäØ}
        (hT140 : 140 Ôëñ T) (hy : 0 < z.im)
        (hregime : 2 * (1 + |z.re| + z.im) Ôëñ T),
        XiPullback z Ôëá 0 ÔåÆ
        (error z).im =
          (trueKernelTailOfLogEnvelope
            Dzero T0 hT0_pos
            (le_trans hT0_le_140 hT140)
            (by linarith : (0 : ÔäØ) < T)
            hy
            (by
              filter_upwards [Filter.eventually_ge_atTop T] with u hu
              exact hHighLog hT140 hy hregime hu)).im) :
    highTErrorControlledAwayFromZeros error := by
  intro z T hT140 hy hregime hne
