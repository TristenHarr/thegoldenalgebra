/-- **PROVED ÔÇö THE CXXXIII BRIDGE.** Polynomial value-form pole
decomposition lifted to the log-derivative response: if
`p = (X ÔêÆ C ¤ü)^(k+1) ┬À q` with `z Ôëá ¤ü` and `q(z) Ôëá 0`, then
`p'(z)/p(z) = (k+1)/(zÔêÆ¤ü) + q'(z)/q(z)`. Reduces to ┬º5's value-form
`complex_local_pole_decomposition_general` after evaluating `eval` of
the factorization and its derivative. -/
theorem polynomial_logDeriv_local_decomposition_of_factor
    {p q : Polynomial Ôäé} {¤ü z : Ôäé} {k : Ôäò}
    (hfac : p = (Polynomial.X - Polynomial.C ¤ü) ^ (k + 1) * q)
    (hz¤ü : z Ôëá ¤ü)
    (hqz : q.eval z Ôëá 0) :
    polynomialLogDerivResponse p z =
      (((k + 1 : Ôäò) : Ôäé) / (z - ¤ü))
        + q.derivative.eval z / q.eval z := by
  unfold polynomialLogDerivResponse
  -- p.eval z = (z ÔêÆ ¤ü)^(k+1) * q.eval z
  have hp_eval : p.eval z = (z - ¤ü)^(k+1) * q.eval z := by
    rw [hfac]
    simp [Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C]
  -- p'.eval z = (k+1) * (z ÔêÆ ¤ü)^k * q.eval z + (z ÔêÆ ¤ü)^(k+1) * q'.eval z
  have hp_deriv_eval : p.derivative.eval z
                    = ((k + 1 : Ôäò) : Ôäé) * (z - ¤ü)^k * q.eval z
                      + (z - ¤ü)^(k+1) * q.derivative.eval z := by
    rw [hfac, Polynomial.derivative_mul, Polynomial.derivative_pow_succ]
    simp [Polynomial.eval_add, Polynomial.eval_mul, Polynomial.eval_pow,
          Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_C,
          Polynomial.derivative_sub, Polynomial.derivative_X,
          Polynomial.derivative_C]
  rw [hp_eval, hp_deriv_eval]
  exact complex_local_pole_decomposition_general z ¤ü (q.eval z)
          (q.derivative.eval z) k hz¤ü hqz

/-- **PROVED ÔÇö building `LocalLogDerivPoleDecomposition` from polynomial
factorization data.** Combines:

  ÔÇó probe Ôëá pole (`probe_ne_pole`),
  ÔÇó polynomial background continuous (┬º8) & nonzero on probe (this section),
  ÔÇó the valueÔåÆpolynomial bridge above. -/
noncomputable def localLogDerivPoleDecomposition_of_polynomial_factor
    {p q : Polynomial Ôäé} {¤ü : Ôäé} {k : Ôäò}
    (hupper : 0 < ¤ü.im)
    (hfac : p = (Polynomial.X - Polynomial.C ¤ü) ^ (k + 1) * q)
    (hq¤ü : q.eval ¤ü Ôëá 0) :
    LocalLogDerivPoleDecomposition (polynomialLogDerivResponse p) ¤ü :=
  -- Background continuity:
  let hcontB := polynomial_logDeriv_background_continuousAt hq¤ü
  let hcontQ : ContinuousAt (fun z => q.eval z) ¤ü :=
    (Polynomial.continuous q).continuousAt
  -- From continuity helpers, get bounded background and nonzero q on probe:
  let hboundedB : Ôêâ K : ÔäØ, 0 < K Ôêº
      Ôêâ ╬Á0 : ÔäØ, 0 < ╬Á0 Ôêº ╬Á0 < ¤ü.im Ôêº
        ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0 ÔåÆ
          |((q.derivative.eval (¤ü - (╬Á : Ôäé) * Complex.I)) /
             (q.eval (¤ü - (╬Á : Ôäé) * Complex.I))).im| Ôëñ K :=
    continuousAt_implies_probe_bounded hcontB hupper
  let hnzQ : Ôêâ ╬Á0' : ÔäØ, 0 < ╬Á0' Ôêº ╬Á0' < ¤ü.im Ôêº
      ÔêÇ ╬Á : ÔäØ, 0 < ╬Á ÔåÆ ╬Á < ╬Á0' ÔåÆ
        q.eval (¤ü - (╬Á : Ôäé) * Complex.I) Ôëá 0 :=
    continuousAt_implies_probe_nonzero hcontQ hq¤ü hupper
  -- Extract and combine
  let K := hboundedB.choose
  let hK := hboundedB.choose_spec
  let ╬Á0B := hK.2.choose
  let h╬Á0B := hK.2.choose_spec
  let ╬Á0Q := hnzQ.choose
  let h╬Á0Q := hnzQ.choose_spec
  let ╬Á0 := min ╬Á0B ╬Á0Q
  { m := k + 1
    hm_pos := Nat.succ_pos k
    background := fun z => q.derivative.eval z / q.eval z
    ╬Á0 := ╬Á0
    h╬Á0 := lt_min h╬Á0B.1 h╬Á0Q.1
    h╬Á0_lt := lt_of_le_of_lt (min_le_left _ _) h╬Á0B.2.1
    K := K
    hK_pos := hK.1
    decomp_at_probe := fun ╬Á h╬Á_pos h╬Á_lt => by
      have h╬Á_lt_B : ╬Á < ╬Á0B :=
        lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
      have h╬Á_lt_Q : ╬Á < ╬Á0Q :=
        lt_of_lt_of_le h╬Á_lt (min_le_right _ _)
      have hz¤ü : ¤ü - (╬Á : Ôäé) * Complex.I Ôëá ¤ü := probe_ne_pole ¤ü ╬Á h╬Á_pos
      have hqz : q.eval (¤ü - (╬Á : Ôäé) * Complex.I) Ôëá 0 :=
        h╬Á0Q.2.2 ╬Á h╬Á_pos h╬Á_lt_Q
      have h := polynomial_logDeriv_local_decomposition_of_factor
        hfac hz¤ü hqz
      convert h using 2
    background_bounded := fun ╬Á h╬Á_pos h╬Á_lt => by
      have h╬Á_lt_B : ╬Á < ╬Á0B :=
        lt_of_lt_of_le h╬Á_lt (min_le_left _ _)
      exact h╬Á0B.2.2 ╬Á h╬Á_pos h╬Á_lt_B }

/-- **PROVED ÔÇö THE DISCHARGE.** For any nonzero polynomial `p`, the
hypothesis package `PolynomialPoleWitnessHypothesis p` follows from
┬º8's root-multiplicity factorization combined with this section's
local pole decomposition. The abstract engine is no longer load-bearing
