/-! ### AH1вАУAH4: integer-valued principal-part interface -/

/-- **AH1.** A natural-valued principal part lifts to integer-valued.
(Alias of `HasLogDerivIntegerPrincipalPart.of_nat` under a different
name for API convenience.) -/
theorem HasLogDerivPrincipalPart.toInteger
    {f : вДВ вЖТ вДВ} {s : вДВ} {m : вДХ}
    (h : HasLogDerivPrincipalPart f s m) :
    HasLogDerivIntegerPrincipalPart f s (m : вД§) :=
  HasLogDerivIntegerPrincipalPart.of_nat h

/-- **AH2.** Integer-valued local principal-part target at a nontrivial
zeta zero. -/
def ZetaHasIntegerLogDerivPrincipalPartAtZero (s : вДВ) : Prop :=
  HasLogDerivIntegerPrincipalPart riemannZeta s
    ((zetaGlobalZeroMultiplicity.mult s : вД§))

/-- The nat-valued zero principal-part target implies the
integer-valued one. -/
theorem ZetaHasLogDerivPrincipalPart.toInteger
    {s : вДВ}
    (h : ZetaHasLogDerivPrincipalPart s) :
    ZetaHasIntegerLogDerivPrincipalPartAtZero s :=
  HasLogDerivPrincipalPart.toInteger h

/-- **AH3.** The exact local theorem still needed (residue-free
substitute for `Complex.residue` identities).  This is the future
target that the rectangle residue theorem will consume. -/
structure ZetaLogDerivPrincipalPartTheorem where
  at_nontrivial_zero :
    вИА {s : вДВ}, IsNontrivialZetaZero s вЖТ
      ZetaHasIntegerLogDerivPrincipalPartAtZero s
  at_one : HasLogDerivIntegerPrincipalPart riemannZeta (1 : вДВ) (-1)

/-- **AH4.** Principal-part data at a point with the *expected*
integer coefficient given by `zetaLogDerivExpectedResidueIndex`. -/
def ZetaHasExpectedLogDerivPrincipalPart (s : вДВ) : Prop :=
  HasLogDerivIntegerPrincipalPart riemannZeta s
    (zetaLogDerivExpectedResidueIndex s)

/-- Extract expected-coefficient principal part at a nontrivial zero. -/
theorem ZetaLogDerivPrincipalPartTheorem.expected_at_zero
    (P : ZetaLogDerivPrincipalPartTheorem)
    {s : вДВ} (hs : IsNontrivialZetaZero s) :
    ZetaHasExpectedLogDerivPrincipalPart s := by
  unfold ZetaHasExpectedLogDerivPrincipalPart
  rw [zetaLogDerivExpectedResidueIndex_of_zero hs]
  exact P.at_nontrivial_zero hs

/-- Extract expected-coefficient principal part at the pole. -/
theorem ZetaLogDerivPrincipalPartTheorem.expected_at_one
    (P : ZetaLogDerivPrincipalPartTheorem) :
    ZetaHasExpectedLogDerivPrincipalPart (1 : вДВ) := by
  unfold ZetaHasExpectedLogDerivPrincipalPart
  rw [zetaLogDerivExpectedResidueIndex_one]
  exact P.at_one

/-! ### AI3: continuous-remainder variant (weaker fallback) -/

/-- **AI3.** Continuous-remainder variant of the integer principal-part
property.  Useful as a fallback if proving an analytic remainder is too
costly. -/
def HasLogDerivPrincipalPartContinuous
    (f : вДВ вЖТ вДВ) (s : вДВ) (k : вД§) : Prop :=
  вИГ g : вДВ вЖТ вДВ,
    ContinuousAt g s вИІ
      logDeriv f =бґ†[рЭУЭ[вЙ†] s]
        (fun z : вДВ => (k : вДВ) / (z - s) + g z)

/-- Integer-valued analytic-remainder principal-part implies the
continuous-remainder version. -/
theorem HasLogDerivIntegerPrincipalPart.toContinuous
