        Complex.conj_ofReal]
  rw [show (star s : вДВ) / 2 = star (s / 2) from by rw [star_divвВА, h_two_star]]
  rw [WeakFEPair_ќЫвВА_star_of_f_modif_ofReal _ ѕЖ hѕЖ (s / 2)]
