-- =====================================================================
-- §CCLXX. Smooth-tail `-Im` as a positive real integral
-- =====================================================================
-- The honest tail's `-Im` is a real improper integral of
-- `ρ(u) · y · paired-Cauchy-positive-kernel(z, u)`. This section
-- captures the structural decomposition needed by any proof of
-- `HonestSmoothTailRationalLB`. The CLV analytic estimate remains
-- as the named obligation — the structural pieces here let an
-- analytic agent attack it on the real-integral form.
--
-- Adds:
--   neg_pairedCauchyImKernel_eq                            — pointwise identity
--   smoothDensityTailModelPartial_neg_im_eq_real_integral  — -Im(partial) as real integral

/-- ⭐ **PROVED — pointwise identity for `-pairedCauchyImKernel`.**
Writes `-pairedCauchyImKernel x y u` as the explicit positive
combination `y · (1/((x-u)²+y²) + 1/((x+u)²+y²))`. -/
lemma neg_pairedCauchyImKernel_eq (x y u : ℝ) :
    -pairedCauchyImKernel x y u
      = y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2)) := by
  unfold pairedCauchyImKernel
  ring

/-- 🌟🌟 **PROVED — `-Im` of the smooth-density finite partial as a
real integral.** Pointwise Im identity + `Complex.imCLM.intervalIntegral_comp_comm`
yields the positive real integrand. -/
lemma smoothDensityTailModelPartial_neg_im_eq_real_integral
    (ρ : ℝ → ℝ) (T X : ℝ) {z : ℂ}
    (h_int : IntervalIntegrable
              (fun u =>
                (ρ u : ℂ) *
                  ((1 : ℂ) / (z - (u : ℂ)) +
                   (1 : ℂ) / (z + (u : ℂ))))
              MeasureTheory.volume T X) :
    -(smoothDensityTailModelPartial ρ T X z).im
      = ∫ u in T..X,
          ρ u * (z.im *
            (1 / ((z.re - u)^2 + z.im^2)
              + 1 / ((z.re + u)^2 + z.im^2))) := by
  unfold smoothDensityTailModelPartial
  rw [show (∫ u in T..X,
              (ρ u : ℂ) *
                ((1 : ℂ) / (z - (u : ℂ)) +
                 (1 : ℂ) / (z + (u : ℂ)))).im
          = Complex.imCLM (∫ u in T..X,
              (ρ u : ℂ) *
                ((1 : ℂ) / (z - (u : ℂ)) +
                 (1 : ℂ) / (z + (u : ℂ)))) from rfl,
      ← Complex.imCLM.intervalIntegral_comp_comm h_int]
  rw [← intervalIntegral.integral_neg]
  refine intervalIntegral.integral_congr ?_
  intro u _
  show -(Complex.imCLM ((ρ u : ℂ) *
            ((1 : ℂ) / (z - (u : ℂ)) +
             (1 : ℂ) / (z + (u : ℂ)))))
    = ρ u * (z.im *
      (1 / ((z.re - u)^2 + z.im^2)
        + 1 / ((z.re + u)^2 + z.im^2)))
  rw [Complex.imCLM_apply]
  have hpair : (pairedCauchyKernel u z).im = pairedCauchyImKernel z.re z.im u := by
    have h := pairedCauchyKernel_im_eq_imKernel z.re z.im u
    rw [Complex.re_add_im z] at h
    exact h
  have h_im :
      ((ρ u : ℂ) *
        ((1 : ℂ) / (z - (u : ℂ)) + (1 : ℂ) / (z + (u : ℂ)))).im
        = ρ u * pairedCauchyImKernel z.re z.im u := by
    show ((ρ u : ℂ) * pairedCauchyKernel u z).im
          = ρ u * pairedCauchyImKernel z.re z.im u
    have hmul : ((ρ u : ℂ) * pairedCauchyKernel u z).im
            = ρ u * (pairedCauchyKernel u z).im := by
      simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
    rw [hmul, hpair]
  rw [h_im]
  have hneg : -pairedCauchyImKernel z.re z.im u
              = z.im * (1 / ((z.re - u)^2 + z.im^2)
                        + 1 / ((z.re + u)^2 + z.im^2)) :=
    neg_pairedCauchyImKernel_eq z.re z.im u
  linear_combination ρ u * hneg

-- =====================================================================
-- §CCLXXI. Real-integral limit form of the smooth tail's `-Im`
-- =====================================================================
-- Bridges §CCLXX's finite-partial identity to the improper limit. The
-- end goal is the named target the CLV agent will attack:
--
--   `-Im(zeroDensitySmoothTailModel Tsmooth z)
--      = lim_{X→∞} ∫_{Tsmooth}^X ρ(u) · y · paired-pos-kernel(z, u) du`.
--
-- Adds:
--   zeroDensitySmoothTailModel_tendsto_complex                 — complex Tendsto witness
--   zeroDensitySmoothTailModel_neg_im_tendsto_real_integral    — real Tendsto bridge

/-- 🌟🌟 **PROVED — complex Tendsto witness for the honest smooth tail.**
The finite complex partials `smoothDensityTailModelPartial zeroDensityRho Tsmooth X z`
converge to `zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z` as
`X → ∞`. Extracted via the same majorant construction
`zeroDensitySmoothTailModel` is built from; proof-irrelevance makes
the two `SmoothDensityTailMajorantDataUHP` instances definitionally
equal, so the Tendsto's target matches the named tail. -/
theorem zeroDensitySmoothTailModel_tendsto_complex
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    {z : ℂ} (hz : 0 < z.im) :
    Tendsto
      (fun X : ℝ =>
        smoothDensityTailModelPartial zeroDensityRho Tsmooth X z)
      Filter.atTop
      (𝓝 (zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : ℝ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have h2pi_inv_nn : (0 : ℝ) ≤ 1 / (2 * Real.pi) := by positivity
  exact
    (smoothDensityTailModelConvergesUHP_of_majorant zeroDensityRho Tsmooth
      (smoothDensityTailMajorantDataUHP_of_logGrowth
        zeroDensityRho Tsmooth (1 / (2 * Real.pi)) 0
        h2pi_inv_nn le_rfl hTpos
        zeroDensityRho_log_growth_eventually
        (fun z X hz hTX =>
          zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
            Tsmooth X hTpos hTX hz))).tendsto z hz

/-- 🌟🌟🌟🌟 **PROVED — `-Im` of the honest smooth tail as an `atTop`
real-integral limit.** Composes §CCLXX-2 (the finite-partial real
integral form) with `zeroDensitySmoothTailModel_tendsto_complex` and
`(continuous_neg ∘ Complex.continuous_im)`. The CLV analytic agent
can now attack the target purely in real-integral language. -/
theorem zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    {z : ℂ} (hz : 0 < z.im) :
    Tendsto
      (fun X : ℝ =>
        ∫ u in Tsmooth..X,
          zeroDensityRho u *
            (z.im *
              (1 / ((z.re - u)^2 + z.im^2) +
               1 / ((z.re + u)^2 + z.im^2))))
      Filter.atTop
      (𝓝 (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : ℝ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have hcomplex :=
    zeroDensitySmoothTailModel_tendsto_complex Tsmooth hTsmooth_ge hz
  have him :
      Tendsto
        (fun X : ℝ =>
          -(smoothDensityTailModelPartial zeroDensityRho Tsmooth X z).im)
        Filter.atTop
        (𝓝 (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) :=
    (continuous_neg.tendsto _).comp
      ((Complex.continuous_im.tendsto _).comp hcomplex)
  refine him.congr' ?_
  filter_upwards [Filter.eventually_ge_atTop Tsmooth] with X hTX
  exact smoothDensityTailModelPartial_neg_im_eq_real_integral
    zeroDensityRho Tsmooth X
    (zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
      Tsmooth X hTpos hTX hz)

-- =====================================================================
-- §CCLXXII-A. Monotonicity, positivity, and pointwise lower bounds
-- =====================================================================
-- Foundation for the CLV/arctan estimate. Names the positive smooth
-- kernel and proves the pointwise comparison
-- `ρ(T) · K(u) ≤ ρ(u) · K(u)` on the tail `u ≥ T ≥ 2π`. This is the
-- single ingredient needed to factor `ρ(T)` out of the integral in
-- §CCLXXII-B.
--
-- Adds:
--   positiveSmoothKernel                          — `y·(1/((x-u)²+y²) + 1/((x+u)²+y²))`
--   positiveSmoothKernel_nonneg
--   zeroDensityRho_mono_on_tail
--   zeroDensityRho_le_of_tail
--   zeroDensity_kernel_lower_bound

/-- **Positive smooth kernel** — the absolute-value form of the paired
Cauchy kernel's imaginary part. Manifestly nonneg for `y > 0`. -/
noncomputable def positiveSmoothKernel (x y u : ℝ) : ℝ :=
  y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2))

/-- ⭐ **PROVED — `positiveSmoothKernel` is nonneg for `y > 0`.** -/
lemma positiveSmoothKernel_nonneg
    {x y u : ℝ} (hy : 0 < y) :
    0 ≤ positiveSmoothKernel x y u := by
  unfold positiveSmoothKernel
  have h1 : (0 : ℝ) < (x - u)^2 + y^2 := by positivity
  have h2 : (0 : ℝ) < (x + u)^2 + y^2 := by positivity
  have hy' : (0 : ℝ) ≤ y := le_of_lt hy
  positivity

/-- ⭐ **PROVED — `zeroDensityRho` is monotone on `[2π, ∞)`.** Follows
from `log` monotonicity on `[1, ∞)` after dividing by `2π`. -/
lemma zeroDensityRho_mono_on_tail :
    MonotoneOn zeroDensityRho (Set.Ici (2 * Real.pi)) := by
  intro a ha b hb hab
  unfold zeroDensityRho
  have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : ℝ) ≤ 1 / (2 * Real.pi) := by positivity
  have hab_div : a / (2 * Real.pi) ≤ b / (2 * Real.pi) := by
    exact div_le_div_of_nonneg_right hab (le_of_lt h2pi_pos)
  have ha_div_pos : 0 < a / (2 * Real.pi) :=
    div_pos (lt_of_lt_of_le h2pi_pos ha) h2pi_pos
  have h_log_le :
      Real.log (a / (2 * Real.pi)) ≤ Real.log (b / (2 * Real.pi)) :=
    Real.log_le_log ha_div_pos hab_div
  exact mul_le_mul_of_nonneg_left h_log_le h2pi_inv_nn

/-- ⭐ **PROVED — `ρ(T) ≤ ρ(u)` on the tail.** -/
lemma zeroDensityRho_le_of_tail
    {T u : ℝ} (hT : 2 * Real.pi ≤ T) (hTu : T ≤ u) :
    zeroDensityRho T ≤ zeroDensityRho u := by
  exact zeroDensityRho_mono_on_tail hT (le_trans hT hTu) hTu

/-- 🌟 **PROVED — pointwise weighted-kernel lower bound on the tail.**
For `u ≥ T ≥ 2π`, `ρ(T) · K(u) ≤ ρ(u) · K(u)`. -/
lemma zeroDensity_kernel_lower_bound
    {x y T u : ℝ}
    (hT : 2 * Real.pi ≤ T) (hTu : T ≤ u) (hy : 0 < y) :
    zeroDensityRho T * positiveSmoothKernel x y u
      ≤ zeroDensityRho u * positiveSmoothKernel x y u :=
  mul_le_mul_of_nonneg_right
    (zeroDensityRho_le_of_tail hT hTu)
    (positiveSmoothKernel_nonneg hy)

-- =====================================================================
-- §CCLXXII-B. Finite-window integral lower bound (`ρ(T)` factored out)
-- =====================================================================
-- Uses §CCLXXII-A pointwise lower bound + `intervalIntegral.integral_mono_on`
-- to factor `ρ(T)` out of the integral.
--
-- The hypotheses include explicit integrability of both the kernel and
-- the density-weighted kernel — these will be discharged downstream by
-- continuity on the compact `[T, X]`.
--
-- Adds:
--   zeroDensity_realIntegral_ge_constDensity_finite

/-- 🌟🌟 **PROVED — finite-window integral lower bound** factoring
`ρ(T)` outside the integral.

  `ρ(T) · ∫_T^X K(u) du ≤ ∫_T^X ρ(u) · K(u) du`

for `T ≥ 2π` and `T ≤ X`, by pointwise `ρ` monotonicity (§CCLXXII-A).
Integrability of both integrands is taken as a hypothesis here (to be
discharged downstream by continuity). -/
theorem zeroDensity_realIntegral_ge_constDensity_finite
    {x y T X : ℝ}
    (hT : 2 * Real.pi ≤ T)
    (hTX : T ≤ X)
    (hy : 0 < y)
    (hKInt : IntervalIntegrable
              (fun u => positiveSmoothKernel x y u)
              MeasureTheory.volume T X)
    (hRInt : IntervalIntegrable
              (fun u => zeroDensityRho u * positiveSmoothKernel x y u)
              MeasureTheory.volume T X) :
    zeroDensityRho T * (∫ u in T..X, positiveSmoothKernel x y u)
      ≤ ∫ u in T..X, zeroDensityRho u * positiveSmoothKernel x y u := by
  -- Rewrite the constant times the integral as an integral of the
  -- constant-scaled kernel.
  rw [← intervalIntegral.integral_const_mul]
  -- Now apply pointwise monotone comparison on `[T, X]`.
  apply intervalIntegral.integral_mono_on hTX
  · -- integrability of the LHS integrand `ρ(T) * K(u)`
    exact hKInt.const_mul (zeroDensityRho T)
  · -- integrability of the RHS integrand `ρ(u) * K(u)`
    exact hRInt
  · -- pointwise comparison: `ρ(T) * K(u) ≤ ρ(u) * K(u)` on `[T, X]`
    intro u hu
    have hTu : T ≤ u := hu.1
    exact zeroDensity_kernel_lower_bound hT hTu hy

-- =====================================================================
-- §CCLXXII-C. One-sided Cauchy kernel — arctan primitive + tail Tendsto
-- =====================================================================
-- Foundational arctan / integral facts for ONE side of the paired
-- Cauchy kernel `y / ((u - a)² + y²)`. The two-sided (paired) bound
-- in §CCLXXII-D will follow by adding the `+a` and `-a` instances.
--
-- Adds:
--   arctan_shift_deriv_algebra                              — algebra cleanup
--   hasDerivAt_arctan_shift_div                             — chain rule
--   integral_cauchy_one_side_eq_arctan_sub                  — FTC formula
--   tendsto_arctan_shift_atTop                              — atTop limit of shift
--   cauchy_one_side_tail_integral_tendsto                   — tail Tendsto

/-- ⭐ **PROVED — algebra cleanup for arctan-shift derivative.** Isolates
the field manipulation `(1/y) / (1 + ((u - a)/y)²) = y/((u - a)² + y²)`. -/
lemma arctan_shift_deriv_algebra
    {a y u : ℝ} (hy : y ≠ 0) :
    (1 / (1 + ((u - a) / y) ^ 2)) * (1 / y)
      = y / ((u - a) ^ 2 + y ^ 2) := by
  have hy2 : y ^ 2 ≠ 0 := pow_ne_zero 2 hy
  field_simp
  ring

/-- 🌟 **PROVED — chain rule: derivative of `arctan ((u - a) / y)` in `u`.** -/
lemma hasDerivAt_arctan_shift_div
    (a : ℝ) {y : ℝ} (hy : y ≠ 0) (u : ℝ) :
    HasDerivAt
      (fun v : ℝ => Real.arctan ((v - a) / y))
      (y / ((u - a) ^ 2 + y ^ 2))
      u := by
  have h_inner :
      HasDerivAt (fun v : ℝ => (v - a) / y) (1 / y) u := by
    have h_sub : HasDerivAt (fun v : ℝ => v - a) (1 : ℝ) u :=
      (hasDerivAt_id u).sub_const a
    simpa [one_div] using h_sub.div_const y
  have h_arctan :=
    (Real.hasDerivAt_arctan ((u - a) / y)).comp u h_inner
  -- h_arctan : HasDerivAt (fun v => arctan ((v - a)/y))
  --              ((1 / (1 + ((u - a)/y)^2)) * (1 / y)) u
  have h_eq := arctan_shift_deriv_algebra (a := a) (y := y) (u := u) hy
  rw [h_eq] at h_arctan
  exact h_arctan

/-- 🌟🌟 **PROVED — FTC for the one-sided Cauchy kernel.**
`∫_T^X y / ((u - a)² + y²) du = arctan((X - a)/y) − arctan((T - a)/y)`. -/
lemma integral_cauchy_one_side_eq_arctan_sub
    (a T X : ℝ) {y : ℝ} (hy : y ≠ 0) :
    (∫ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  · intro u _
    exact hasDerivAt_arctan_shift_div a hy u
  · -- The integrand is continuous, hence interval-integrable
    have h_cont : Continuous (fun u : ℝ => y / ((u - a) ^ 2 + y ^ 2)) := by
      refine continuous_const.div ?_ ?_
      · exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
      · intro u
        have h1 : (0 : ℝ) ≤ (u - a) ^ 2 := sq_nonneg _
        have h2 : (0 : ℝ) < y ^ 2 := by positivity
        linarith
    exact h_cont.intervalIntegrable T X

/-- 🌟 **PROVED — `arctan ((X - a)/y) → π/2` as `X → ∞` for `y > 0`.**
The inner shift `(X - a)/y → ∞` (since `y > 0`); compose with
`Real.tendsto_arctan_atTop`. -/
lemma tendsto_arctan_shift_atTop
    (a : ℝ) {y : ℝ} (hy : 0 < y) :
    Tendsto
      (fun X : ℝ => Real.arctan ((X - a) / y))
      Filter.atTop
      (𝓝 (Real.pi / 2)) := by
  have h_shift : Tendsto (fun X : ℝ => (X - a) / y)
      Filter.atTop Filter.atTop := by
    have h_sub : Tendsto (fun X : ℝ => X - a) Filter.atTop Filter.atTop :=
      tendsto_atTop_add_const_right Filter.atTop (-a) tendsto_id
    exact h_sub.atTop_div_const hy
  have h_arctan_at_top :
      Tendsto Real.arctan Filter.atTop (𝓝 (Real.pi / 2)) :=
    tendsto_nhds_of_tendsto_nhdsWithin Real.tendsto_arctan_atTop
  exact h_arctan_at_top.comp h_shift

/-- 🌟🌟🌟 **PROVED — one-sided Cauchy tail integral converges to
`π/2 − arctan((T - a)/y)` as `X → ∞`.** Composes the FTC formula
with the arctan-shift limit. -/
lemma cauchy_one_side_tail_integral_tendsto
    (a T : ℝ) {y : ℝ} (hy : 0 < y) :
    Tendsto
      (fun X : ℝ => ∫ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      Filter.atTop
      (𝓝 (Real.pi / 2 - Real.arctan ((T - a) / y))) := by
  have hy_ne : y ≠ 0 := ne_of_gt hy
  have h_eq : ∀ X : ℝ,
      (∫ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
        = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
    intro X
    exact integral_cauchy_one_side_eq_arctan_sub a T X hy_ne
  have h_arctan_T : Tendsto (fun _ : ℝ => Real.arctan ((T - a) / y))
      Filter.atTop (𝓝 (Real.arctan ((T - a) / y))) :=
    tendsto_const_nhds
  have h_sub :
      Tendsto
        (fun X : ℝ =>
          Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y))
        Filter.atTop
        (𝓝 (Real.pi / 2 - Real.arctan ((T - a) / y))) :=
    (tendsto_arctan_shift_atTop a hy).sub h_arctan_T
  exact (h_sub.congr' (Filter.Eventually.of_forall fun X => (h_eq X).symm))

-- =====================================================================
-- §CCLXXII-D. Paired kernel tail integral + multiplication by ρ(T)
-- =====================================================================
-- Combines two `cauchy_one_side_tail_integral_tendsto` instances at
-- `a := x` and `a := -x` into the paired `positiveSmoothKernel` tail
-- Tendsto. Then multiplies by the constant `ρ(T)`.
--
-- Adds:
--   cauchy_one_side_intervalIntegrable                       — integrability
--   positiveSmoothKernel_eq_sum_one_sides                    — paired pointwise split
--   positiveSmoothKernel_tail_integral_tendsto               — paired tail Tendsto
--   constDensity_positiveSmoothKernel_tail_tendsto           — × ρ(T) version

/-- ⭐ **PROVED — interval integrability of the one-sided Cauchy kernel.**
The integrand is continuous (denominator strictly positive for
`y ≠ 0`), hence interval-integrable on any `[T, X]`. -/
lemma cauchy_one_side_intervalIntegrable
    (a T X : ℝ) {y : ℝ} (hy : y ≠ 0) :
    IntervalIntegrable
      (fun u => y / ((u - a) ^ 2 + y ^ 2))
      MeasureTheory.volume T X := by
  have h_cont : Continuous (fun u : ℝ => y / ((u - a) ^ 2 + y ^ 2)) := by
    refine continuous_const.div ?_ ?_
    · exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
    · intro u
      have h1 : (0 : ℝ) ≤ (u - a) ^ 2 := sq_nonneg _
      have h2 : (0 : ℝ) < y ^ 2 := by positivity
      linarith
  exact h_cont.intervalIntegrable T X

/-- ⭐ **PROVED — paired positive kernel as sum of two one-sided pieces.**
Aligns with the one-sided lemma by taking `a := x` and `a := -x`. -/
lemma positiveSmoothKernel_eq_sum_one_sides
    (x y u : ℝ) :
    positiveSmoothKernel x y u
      = y / ((u - x) ^ 2 + y ^ 2)
        + y / ((u - (-x)) ^ 2 + y ^ 2) := by
  unfold positiveSmoothKernel
  have h1 : (x - u) ^ 2 = (u - x) ^ 2 := by ring
  have h2 : (x + u) ^ 2 = (u - (-x)) ^ 2 := by ring
  rw [h1, h2]
  ring

/-- 🌟🌟🌟 **PROVED — paired `positiveSmoothKernel` tail integral
Tendsto.** Sum of two one-sided arctan-shift Tendsto results
(§CCLXXII-C5) with `a := x` and `a := -x`. -/
theorem positiveSmoothKernel_tail_integral_tendsto
    (x T : ℝ) {y : ℝ} (hy : 0 < y) :
    Tendsto
      (fun X : ℝ => ∫ u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (𝓝 ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y)))) := by
  have hy_ne : y ≠ 0 := ne_of_gt hy
  have h1 := cauchy_one_side_tail_integral_tendsto x T hy
  have h2 := cauchy_one_side_tail_integral_tendsto (-x) T hy
  have h_sum := h1.add h2
  refine h_sum.congr' ?_
  refine Filter.Eventually.of_forall (fun X => ?_)
  -- ∫_T^X positiveSmoothKernel = (∫ ... a=x) + (∫ ... a=-x)
  have hpoint : ∀ u : ℝ,
      positiveSmoothKernel x y u
        = y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2) :=
    fun u => positiveSmoothKernel_eq_sum_one_sides x y u
  have hcongr_integrand :
      (∫ u in T..X, positiveSmoothKernel x y u)
        = ∫ u in T..X,
            (y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2)) :=
    intervalIntegral.integral_congr (fun u _ => hpoint u)
  have h_int_x := cauchy_one_side_intervalIntegrable x T X hy_ne
  have h_int_neg_x := cauchy_one_side_intervalIntegrable (-x) T X hy_ne
  have hsplit :
      (∫ u in T..X,
          (y / ((u - x) ^ 2 + y ^ 2)
            + y / ((u - (-x)) ^ 2 + y ^ 2)))
        = (∫ u in T..X, y / ((u - x) ^ 2 + y ^ 2))
            + ∫ u in T..X, y / ((u - (-x)) ^ 2 + y ^ 2) :=
    intervalIntegral.integral_add h_int_x h_int_neg_x
  exact (hsplit.symm.trans hcongr_integrand.symm)

/-- 🌟🌟 **PROVED — paired kernel tail integral times constant `ρ(T)`
Tendsto.** Direct `Tendsto.mul` with the constant `ρ(T)`. -/
theorem constDensity_positiveSmoothKernel_tail_tendsto
    (x T : ℝ) {y : ℝ} (hy : 0 < y) :
    Tendsto
      (fun X : ℝ =>
        zeroDensityRho T *
          ∫ u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (𝓝 (zeroDensityRho T *
        ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y))))) :=
  tendsto_const_nhds.mul
    (positiveSmoothKernel_tail_integral_tendsto x T hy)

-- =====================================================================
-- §CCLXXII-E. Arctan rational lower bound `s/(1+s²) ≤ arctan s`
-- =====================================================================
-- Mathlib doesn't have this lemma (only upper bounds and strict
-- monotonicity). Proof: let `f(t) := arctan t − t/(1+t²)`;
-- `f(0) = 0` and `f'(t) = 2t²/(1+t²)² ≥ 0`; so `f(s) ≥ 0` for `s ≥ 0`
-- by FTC + `integral_nonneg`.
--
-- Adds:
--   hasDerivAt_arctan_minus_div_one_add_sq    — derivative of f(t)
--   div_one_add_sq_le_arctan                  — rational lower bound on `arctan`
--   arctan_div_lower_rational                 — `y·A/(A²+y²) ≤ arctan(y/A)` form

/-- 🌟 **PROVED — derivative of `arctan t − t/(1+t²)` is `2t²/(1+t²)²`.**
Chain through `Real.hasDerivAt_arctan` + quotient rule. -/
lemma hasDerivAt_arctan_minus_div_one_add_sq (t : ℝ) :
    HasDerivAt
      (fun x : ℝ => Real.arctan x - x / (1 + x ^ 2))
      (2 * t ^ 2 / (1 + t ^ 2) ^ 2)
      t := by
  have h_arctan : HasDerivAt Real.arctan (1 / (1 + t ^ 2)) t :=
    Real.hasDerivAt_arctan t
  have h_id : HasDerivAt (fun x : ℝ => x) (1 : ℝ) t := hasDerivAt_id t
  have h_sq : HasDerivAt (fun x : ℝ => x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_id t).pow 2
    simpa [pow_one] using h
  have h_den : HasDerivAt (fun x : ℝ => 1 + x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_const t (1 : ℝ)).add h_sq
    rwa [zero_add] at h
  have h_ne : (1 : ℝ) + t ^ 2 ≠ 0 := by
    have h1 : (0 : ℝ) ≤ t ^ 2 := sq_nonneg t
    linarith
  have h_div :
      HasDerivAt (fun x : ℝ => x / (1 + x ^ 2))
        ((1 * (1 + t ^ 2) - t * (2 * t)) / (1 + t ^ 2) ^ 2) t :=
    h_id.div h_den h_ne
  have h_sub := h_arctan.sub h_div
  convert h_sub using 1
  field_simp
  ring

/-- 🌟🌟 **PROVED — `s/(1+s²) ≤ arctan s` for `s ≥ 0`.** Routes through
the FTC for `f(t) := arctan t − t/(1+t²)`, noting `f(0) = 0` and
`f' ≥ 0`. -/
lemma div_one_add_sq_le_arctan {s : ℝ} (hs : 0 ≤ s) :
    s / (1 + s ^ 2) ≤ Real.arctan s := by
  have h_zero : Real.arctan 0 - 0 / (1 + (0 : ℝ) ^ 2) = 0 := by
    rw [Real.arctan_zero]; simp
  have h_cont :
      Continuous (fun t : ℝ => 2 * t ^ 2 / (1 + t ^ 2) ^ 2) := by
    refine (continuous_const.mul (continuous_pow 2)).div ?_ ?_
    · exact ((continuous_const.add (continuous_pow 2)).pow 2)
    · intro t
      have h1 : (0 : ℝ) ≤ t ^ 2 := sq_nonneg t
      have h_pos : (0 : ℝ) < 1 + t ^ 2 := by linarith
      have : (0 : ℝ) < (1 + t ^ 2) ^ 2 := by positivity
      linarith
  have hFTC :
      (Real.arctan s - s / (1 + s ^ 2))
          - (Real.arctan 0 - 0 / (1 + (0 : ℝ) ^ 2))
        = ∫ t in (0 : ℝ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    have h := intervalIntegral.integral_eq_sub_of_hasDerivAt
      (fun t _ => hasDerivAt_arctan_minus_div_one_add_sq t)
      (h_cont.intervalIntegrable 0 s)
    exact h.symm
  rw [h_zero, sub_zero] at hFTC
  have h_int_nn :
      0 ≤ ∫ t in (0 : ℝ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    apply intervalIntegral.integral_nonneg hs
    intro u _
    have h_t_sq : (0 : ℝ) ≤ 2 * u ^ 2 := by nlinarith [sq_nonneg u]
    have h_den : (0 : ℝ) < (1 + u ^ 2) ^ 2 := by positivity
    exact div_nonneg h_t_sq (le_of_lt h_den)
  linarith

/-- 🌟🌟🌟 **PROVED — CLV-shaped rational lower bound on `arctan (y/A)`.**
For `A > 0`, `y ≥ 0`:

  `y · A / (A² + y²) ≤ arctan (y / A)`.

Direct application of `div_one_add_sq_le_arctan` at `s := y/A` after
the algebraic identity `(y/A)/(1+(y/A)²) = yA/(A²+y²)`. -/
lemma arctan_div_lower_rational
    {A y : ℝ} (hA : 0 < A) (hy : 0 ≤ y) :
    y * A / (A ^ 2 + y ^ 2) ≤ Real.arctan (y / A) := by
  have hA_ne : A ≠ 0 := ne_of_gt hA
  have h_div_nn : 0 ≤ y / A := div_nonneg hy (le_of_lt hA)
  have h_base : (y / A) / (1 + (y / A) ^ 2) ≤ Real.arctan (y / A) :=
    div_one_add_sq_le_arctan h_div_nn
  have h_alg : (y / A) / (1 + (y / A) ^ 2) = y * A / (A ^ 2 + y ^ 2) := by
    have hA_sq_pos : 0 < A ^ 2 := by positivity
    have hAy_sq_pos : 0 < A ^ 2 + y ^ 2 := by positivity
    field_simp
    ring
  rw [h_alg] at h_base
  exact h_base

-- =====================================================================
-- §CCLXXII-F1. Arctan complement identity + one-sided tail lower bound
-- =====================================================================
-- Adds:
--   pi_div_two_sub_arctan_eq_arctan_inv
--   pi_div_two_sub_arctan_shift_eq_arctan_div
--   one_side_tail_lower_rational

/-- ⭐ **PROVED — `π/2 − arctan s = arctan (1/s)` for `s > 0`.**
Direct from Mathlib's `Real.arctan_inv_of_pos`. -/
lemma pi_div_two_sub_arctan_eq_arctan_inv
    {s : ℝ} (hs : 0 < s) :
    Real.pi / 2 - Real.arctan s = Real.arctan (1 / s) := by
  rw [one_div]
  exact (Real.arctan_inv_of_pos hs).symm

/-- ⭐ **PROVED — `π/2 − arctan(A/y) = arctan(y/A)` for `A, y > 0`.**
CLV-shaped specialization of the complement identity. -/
lemma pi_div_two_sub_arctan_shift_eq_arctan_div
    {A y : ℝ} (hA : 0 < A) (hy : 0 < y) :
    Real.pi / 2 - Real.arctan (A / y) = Real.arctan (y / A) := by
  have hs : 0 < A / y := div_pos hA hy
  rw [pi_div_two_sub_arctan_eq_arctan_inv hs]
  congr 1
  field_simp

/-- 🌟🌟 **PROVED — one-sided tail rational lower bound.**
For `A, y > 0`:

  `y · A / (A² + y²) ≤ π/2 − arctan(A/y)`.

Combines §CCLXXII-F1's complement identity with §CCLXXII-E's
`arctan_div_lower_rational`. -/
lemma one_side_tail_lower_rational
    {A y : ℝ} (hA : 0 < A) (hy : 0 < y) :
    y * A / (A ^ 2 + y ^ 2) ≤ Real.pi / 2 - Real.arctan (A / y) := by
  rw [pi_div_two_sub_arctan_shift_eq_arctan_div hA hy]
  exact arctan_div_lower_rational hA (le_of_lt hy)

-- =====================================================================
-- §CCLXXII-F2. Paired arctan-tail rational lower bound
-- =====================================================================
-- Pairs `+|x|` and `-|x|` instances of §CCLXXII-F1. Case-split on the
-- sign of `x` aligns `T ± |x|` with `T ± x` in the arctan arguments.
--
-- Adds:
--   paired_arctan_tail_lower_rational

/-- 🌟🌟🌟 **PROVED — paired arctan-tail rational lower bound.**
For `y > 0`, `T - |x| > 0`, `T + |x| > 0`:

  `y · (T-|x|)/((T-|x|)² + y²) + y · (T+|x|)/((T+|x|)² + y²)
     ≤ (π/2 − arctan((T-x)/y)) + (π/2 − arctan((T+x)/y))`.

Each LHS term is bounded by `one_side_tail_lower_rational`; case-split
on `0 ≤ x` aligns the arctan arguments. -/
lemma paired_arctan_tail_lower_rational
    {x y T : ℝ}
    (hy : 0 < y)
    (hminus : 0 < T - |x|)
    (hplus : 0 < T + |x|) :
    y * (T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + y * (T + |x|) / ((T + |x|) ^ 2 + y ^ 2)
    ≤ (Real.pi / 2 - Real.arctan ((T - x) / y))
      + (Real.pi / 2 - Real.arctan ((T + x) / y)) := by
  have h_minus := one_side_tail_lower_rational hminus hy
  have h_plus := one_side_tail_lower_rational hplus hy
  by_cases hx : 0 ≤ x
  · have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at h_minus h_plus
    rw [habs]
    linarith
  · push_neg at hx
    have habs : |x| = -x := abs_of_neg hx
    have eq1 : T - (-x : ℝ) = T + x := by ring
    have eq2 : T + (-x : ℝ) = T - x := by ring
    rw [habs] at h_minus h_plus
    rw [eq1] at h_minus
    rw [eq2] at h_plus
    rw [habs, eq1, eq2]
    linarith

-- =====================================================================
-- §CCLXXII-F3. Final composition: `HonestSmoothTailRationalLB` at `2π`
-- =====================================================================
-- Combines all CLV pieces into the honest tail lower bound at the
-- canonical basepoint `Tsmooth := 2π`.
--
-- Adds:
--   positiveSmoothKernel_continuous
--   positiveSmoothKernel_intervalIntegrable
--   zeroDensity_mul_positiveSmoothKernel_nonneg
--   zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
--   zeroDensity_realIntegral_mono_lower_limit
--   constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im
--   HonestSmoothTailRationalLB_twoPi

/-- ⭐ **PROVED — `positiveSmoothKernel` is continuous in `u` for `y ≠ 0`.**
Denominators `(x ± u)² + y² ≥ y² > 0` are nonvanishing. -/
lemma positiveSmoothKernel_continuous {x y : ℝ} (hy : y ≠ 0) :
    Continuous (fun u : ℝ => positiveSmoothKernel x y u) := by
  have hy2 : (0 : ℝ) < y ^ 2 := by positivity
  unfold positiveSmoothKernel
  refine continuous_const.mul ?_
  refine Continuous.add ?_ ?_
  · refine continuous_const.div ?_ ?_
    · exact ((continuous_const.sub continuous_id).pow 2).add continuous_const
    · intro u
      have h : (0 : ℝ) ≤ (x - u) ^ 2 := sq_nonneg _
      linarith
  · refine continuous_const.div ?_ ?_
    · exact ((continuous_const.add continuous_id).pow 2).add continuous_const
    · intro u
      have h : (0 : ℝ) ≤ (x + u) ^ 2 := sq_nonneg _
      linarith

/-- ⭐ **PROVED — `positiveSmoothKernel` is interval-integrable.** -/
lemma positiveSmoothKernel_intervalIntegrable
    {x y : ℝ} (hy : y ≠ 0) (a b : ℝ) :
    IntervalIntegrable
      (fun u => positiveSmoothKernel x y u)
      MeasureTheory.volume a b :=
  (positiveSmoothKernel_continuous hy).intervalIntegrable a b

/-- ⭐ **PROVED — `ρ(u) · K(u) ≥ 0` on the tail.** -/
lemma zeroDensity_mul_positiveSmoothKernel_nonneg
    {u x y : ℝ} (hu : 2 * Real.pi ≤ u) (hy : 0 < y) :
    0 ≤ zeroDensityRho u * positiveSmoothKernel x y u :=
  mul_nonneg
    (zeroDensityRho_nonneg_of_ge_two_pi hu)
    (positiveSmoothKernel_nonneg hy)

/-- ⭐ **PROVED — `ρ · K` is interval-integrable on `[a, b] ⊂ (0, ∞)`.** -/
lemma zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
    {x y a b : ℝ} (ha : 0 < a) (hab : a ≤ b) (hy : y ≠ 0) :
    IntervalIntegrable
      (fun u => zeroDensityRho u * positiveSmoothKernel x y u)
      MeasureTheory.volume a b := by
  refine ContinuousOn.intervalIntegrable_of_Icc hab ?_
  refine ContinuousOn.mul ?_ ((positiveSmoothKernel_continuous hy).continuousOn)
  exact Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    (fun u hu => lt_of_lt_of_le ha hu.1)

/-- 🌟🌟 **PROVED — `∫_T^X` dominated by `∫_{2π}^X` for nonneg integrand.**
Via interval additivity `∫_{2π}^X = ∫_{2π}^T + ∫_T^X` plus
nonnegativity of `∫_{2π}^T ρ·K`. -/
lemma zeroDensity_realIntegral_mono_lower_limit
    {x y T X : ℝ}
    (hT : 2 * Real.pi ≤ T)
    (hTX : T ≤ X)
    (hy : 0 < y) :
    (∫ u in T..X, zeroDensityRho u * positiveSmoothKernel x y u)
      ≤ ∫ u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel x y u := by
  have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by positivity
  have hy_ne : y ≠ 0 := ne_of_gt hy
  have h_int_left :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) h2pi_pos hT hy_ne
  have h_int_right :=
    zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
      (x := x) (y := y) (lt_of_lt_of_le h2pi_pos hT) hTX hy_ne
  have hadd := intervalIntegral.integral_add_adjacent_intervals
    h_int_left h_int_right
  have h_nn :
      0 ≤ ∫ u in (2 * Real.pi)..T,
            zeroDensityRho u * positiveSmoothKernel x y u := by
    apply intervalIntegral.integral_nonneg hT
    intro u hu
    exact zeroDensity_mul_positiveSmoothKernel_nonneg hu.1 hy
  linarith

/-- 🌟🌟🌟🌟 **PROVED — KEY CLV BRIDGE.** The constant-density `ρ(T)`
times the paired arctan-tail integral target is dominated by
`-(zeroDensitySmoothTailModel (2π) z).im` for any adaptive `(z, T)`.

Composes:
* §CCLXXII-D's `constDensity_positiveSmoothKernel_tail_tendsto`
  (LHS Tendsto);
* §CCLXXI's `zeroDensitySmoothTailModel_neg_im_tendsto_real_integral`
  (RHS Tendsto);
* eventual finite-`X` chain: §CCLXXII-B (`ρ(T) ∫_T^X K ≤ ∫_T^X ρ·K`)
  followed by §CCLXXII-F3-3 (`∫_T^X ρ·K ≤ ∫_{2π}^X ρ·K`);
* `le_of_tendsto_of_tendsto'` to pass through the limits. -/
theorem constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im
    {z : ℂ} {T : ℝ}
    (hT : 2 * Real.pi ≤ T)
    (hy : 0 < z.im) :
    zeroDensityRho T *
      ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
        + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
      ≤ -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  have hy_ne : z.im ≠ 0 := ne_of_gt hy
  -- LHS Tendsto (§CCLXXII-D)
  have h_lhs := constDensity_positiveSmoothKernel_tail_tendsto z.re T hy
  -- RHS Tendsto, rewritten using `positiveSmoothKernel` (§CCLXXI + integral_congr)
  have h_rhs_raw :=
    zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
      (2 * Real.pi) le_rfl hy
  have h_rhs : Tendsto
      (fun X : ℝ =>
        ∫ u in (2 * Real.pi)..X,
          zeroDensityRho u * positiveSmoothKernel z.re z.im u)
      Filter.atTop
      (𝓝 (-(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im)) := by
    refine h_rhs_raw.congr' ?_
    refine Filter.Eventually.of_forall (fun X => ?_)
    apply intervalIntegral.integral_congr
    intro u _
    show zeroDensityRho u
            * (z.im * (1 / ((z.re - u) ^ 2 + z.im ^ 2)
                + 1 / ((z.re + u) ^ 2 + z.im ^ 2)))
          = zeroDensityRho u * positiveSmoothKernel z.re z.im u
    unfold positiveSmoothKernel
    ring
  -- Eventually `X ≥ T`: LHS ≤ RHS finite
  have h_ev :
      ∀ᶠ X : ℝ in Filter.atTop,
        zeroDensityRho T *
            (∫ u in T..X, positiveSmoothKernel z.re z.im u)
          ≤ ∫ u in (2 * Real.pi)..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u := by
    filter_upwards [Filter.eventually_ge_atTop T] with X hTX
    have h_kInt :=
      positiveSmoothKernel_intervalIntegrable (x := z.re) (y := z.im) hy_ne T X
    have h_rInt :=
      zeroDensity_mul_positiveSmoothKernel_intervalIntegrable
        (x := z.re) (y := z.im)
        (lt_of_lt_of_le (by positivity : (0 : ℝ) < 2 * Real.pi) hT)
        hTX hy_ne
    have h_step1 :
        zeroDensityRho T *
            (∫ u in T..X, positiveSmoothKernel z.re z.im u)
          ≤ ∫ u in T..X,
              zeroDensityRho u * positiveSmoothKernel z.re z.im u :=
      zeroDensity_realIntegral_ge_constDensity_finite
        (x := z.re) (y := z.im) hT hTX hy h_kInt h_rInt
    have h_step2 :=
      zeroDensity_realIntegral_mono_lower_limit
        (x := z.re) (y := z.im) hT hTX hy
    linarith
  -- Pass through the limits (eventual form)
  exact le_of_tendsto_of_tendsto_of_frequently h_lhs h_rhs h_ev.frequently

/-- 🌟🌟🌟🌟🌟🌟🌟🌟 **PROVED — `HonestSmoothTailRationalLB` at the
canonical basepoint `Tsmooth := 2π`.** Final composition:
* `smoothTailRationalLowerBoundAbs` unfolds to `ρ(T) · rational(T)`;
* §CCLXXII-F2 (`paired_arctan_tail_lower_rational`) replaces
  `rational(T)` by the arctan-sum;
* §CCLXXII-F3 bridge dominates the arctan-sum by the honest tail. -/
theorem HonestSmoothTailRationalLB_twoPi :
    HonestSmoothTailRationalLB (2 * Real.pi) le_rfl := by
  intro z T hT hy hregime
  -- Geometry: 2(1 + |z.re| + z.im) ≤ T ⟹ |z.re| < T/2 < T, so T - |z.re| > 0.
  have habs_nn : (0 : ℝ) ≤ |z.re| := abs_nonneg _
  have hminus : 0 < T - |z.re| := by
    have hy_nn : (0 : ℝ) ≤ z.im := le_of_lt hy
    nlinarith
  have hplus : 0 < T + |z.re| := by
    have h_pi_pos : (0 : ℝ) < Real.pi := Real.pi_pos
    have : (0 : ℝ) < 2 * Real.pi := by positivity
    linarith
  -- Unfold `smoothTailRationalLowerBoundAbs`
  have h_unfold :
      smoothTailRationalLowerBoundAbs z.re z.im T
        = zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2)) := rfl
  rw [h_unfold]
  -- Apply paired arctan rational bound
  have h_paired := paired_arctan_tail_lower_rational
    (x := z.re) (y := z.im) (T := T) hy hminus hplus
  have hρ_nn : 0 ≤ zeroDensityRho T :=
    zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_chain1 :
      zeroDensityRho T *
          (z.im * (T - |z.re|) / ((T - |z.re|) ^ 2 + z.im ^ 2)
            + z.im * (T + |z.re|) / ((T + |z.re|) ^ 2 + z.im ^ 2))
        ≤ zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T + z.re) / z.im))) :=
    mul_le_mul_of_nonneg_left h_paired hρ_nn
  -- Bridge: arctan-sum ≤ honest tail neg-Im
  have h_chain2 :
      zeroDensityRho T *
          ((Real.pi / 2 - Real.arctan ((T - z.re) / z.im))
            + (Real.pi / 2 - Real.arctan ((T - (-z.re)) / z.im)))
        ≤ -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im :=
    constDensity_arctanTail_le_zeroDensitySmoothTail_neg_im hT hy
  -- Align `T - (-z.re)` with `T + z.re`
  have hT_neg_re : T - (-z.re) = T + z.re := by ring
  rw [hT_neg_re] at h_chain2
  linarith

