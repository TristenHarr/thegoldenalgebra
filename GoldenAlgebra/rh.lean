/-! ### CW22: discharge count extensionality from `truncatedMultiplicity_eq_global` -/

/-- **CW22 — `ZetaWeightedCountExtensionalityInput` DISCHARGED.**  Unfolds
the count to a sum over a `toFinset`; the underlying finset is determined
by the set, and `truncatedMultiplicity` agrees on the common support
because both reduce to the global multiplicity on the (equal) zero sets.
Case analysis on the `0 ≤ T` guards. -/
theorem zetaWeightedCountExtensionalityInput :
    ZetaWeightedCountExtensionalityInput where
  count_eq_of_set_eq := by
    intro T U hset
    classical
    have hempty_neg : ∀ V : ℝ, V < 0 → zetaZerosUpToHeightSet V = ∅ := by
      intro V hV
      ext s
      refine ⟨fun h => ?_, fun h => h.elim⟩
      obtain ⟨_, him_pos, him_le⟩ := h
      linarith
    have hcount_zero_of_empty :
        ∀ {V : ℝ} (hV : 0 ≤ V),
          zetaZerosUpToHeightSet V = ∅ →
          zetaWeightedZeroCountUpToHeight V hV = 0 := by
      intro V hV hVempty
      change (zetaZerosUpToHeightSet_finite V hV).toFinset.sum
          (truncatedMultiplicity zetaGlobalZeroMultiplicity V) = 0
      have htofin_eq :
          (zetaZerosUpToHeightSet_finite V hV).toFinset = ∅ :=
        Set.Finite.toFinset_eq_empty.mpr hVempty
      rw [htofin_eq, Finset.sum_empty]
    unfold zetaWeightedZeroCountUpToHeightReal
    by_cases hT_nn : (0 : ℝ) ≤ T
    · by_cases hU_nn : (0 : ℝ) ≤ U
      · rw [dif_pos hT_nn, dif_pos hU_nn]
        simp only [Nat.cast_inj]
        change (zetaZerosUpToHeightSet_finite T hT_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity T) =
          (zetaZerosUpToHeightSet_finite U hU_nn).toFinset.sum
            (truncatedMultiplicity zetaGlobalZeroMultiplicity U)
        have hfin_eq :
            (zetaZerosUpToHeightSet_finite T hT_nn).toFinset =
              (zetaZerosUpToHeightSet_finite U hU_nn).toFinset := by
          ext ρ
          rw [Set.Finite.mem_toFinset, Set.Finite.mem_toFinset, hset]
        refine Finset.sum_congr hfin_eq ?_
        intro ρ hρmem
        have hρU : ρ ∈ zetaZerosUpToHeightSet U :=
          (Set.Finite.mem_toFinset _).mp hρmem
        have hρT : ρ ∈ zetaZerosUpToHeightSet T := hset ▸ hρU
        rw [truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity hρT,
            truncatedMultiplicity_eq_global zetaGlobalZeroMultiplicity hρU]
      · push_neg at hU_nn
        rw [dif_pos hT_nn, dif_neg hU_nn.not_ge]
        have hU_empty : zetaZerosUpToHeightSet U = ∅ := hempty_neg U hU_nn
        have hT_empty : zetaZerosUpToHeightSet T = ∅ := hset.trans hU_empty
        have h0 : zetaWeightedZeroCountUpToHeight T hT_nn = 0 :=
          hcount_zero_of_empty hT_nn hT_empty
        rw [h0]
        norm_num
    · push_neg at hT_nn
      rw [dif_neg hT_nn.not_ge]
      by_cases hU_nn : (0 : ℝ) ≤ U
      · rw [dif_pos hU_nn]
        have hT_empty : zetaZerosUpToHeightSet T = ∅ := hempty_neg T hT_nn
        have hU_empty : zetaZerosUpToHeightSet U = ∅ := by
          rw [← hset]; exact hT_empty
        have h0 : zetaWeightedZeroCountUpToHeight U hU_nn = 0 :=
          hcount_zero_of_empty hU_nn hU_empty
        rw [h0]
        symm; norm_num
      · push_neg at hU_nn
        rw [dif_neg hU_nn.not_ge]

/-- **CW22a — global zero-height gap → local constancy DISCHARGED.**
The global gap gives set equality for zero sets just to the right of
`T`; the already-proved weighted-count extensionality turns that set
equality into equality of the real-valued weighted counts. -/
noncomputable def zetaZeroHeightRightGapToLocalConstancyInput :
    ZetaZeroHeightRightGapToLocalConstancyInput where
  bridge := by
    intro G
    refine ⟨?_⟩
    intro T hT
    rcases G.exists_gap T hT with ⟨ε, hεpos, hgap⟩
    have hIoi :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), T < u :=
      self_mem_nhdsWithin
    have hIio :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), u < T + ε :=
      nhdsWithin_le_nhds (Iio_mem_nhds (by linarith : T < T + ε))
    have hEventually :
        ∀ᶠ u in nhdsWithin T (Set.Ioi T), T < u ∧ u ≤ T + ε := by
      filter_upwards [hIoi, hIio] with u h1 h2
      exact ⟨h1, le_of_lt h2⟩
    filter_upwards [hEventually] with u hu
    exact zetaWeightedCountExtensionalityInput.count_eq_of_set_eq u T
      (zetaZerosUpToHeightSet_eq_of_strip_gap hT hu.1 hu.2 hεpos
        (fun ρ hzero _hre_low _hre_high him him_upper =>
          hgap ρ hzero him him_upper))

/-- **CW22a — count right-local-constancy DISCHARGED.**  Combines the
unconditional global right-gap theorem with the proved gap→local-
constancy bridge. -/
noncomputable def zetaWeightedZeroCountRightLocalConstancyInput :
    ZetaWeightedZeroCountRightLocalConstancyInput :=
  zetaZeroHeightRightGapToLocalConstancyInput.bridge
    zetaZeroHeightRightGapInput

/-- **CW22a — final theorem from the Backlund good-height argument
bound alone.**  The count/right-continuity extension side is now
constructed unconditionally inside `rh.lean`; the only remaining
mathematical input here is the genuine Backlund good-height bound. -/
theorem concreteS_halfLogPlusHalf_of_backlundArgument
    (B : BacklundGoodHeightArgumentBound)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_backlundArgument_and_countLC
    B zetaWeightedZeroCountRightLocalConstancyInput hT

/-- **CW22 — strongest 1-input final theorem.**  After CW22, the entire
extension / count / continuity / compactness / classification side is
discharged.  The headline bound is reduced to the single classical
analytic obligation `BacklundNumericalExtractionInput`. -/
theorem concreteS_halfLogPlusHalf_of_numericalExtraction
    (E : BacklundNumericalExtractionInput)
    {T : ℝ} (hT : (140 : ℝ) ≤ T) :
    |concreteS T| ≤ (1 / 2 : ℝ) * Real.log T + 1 / 2 :=
