  have hle :
      Real.exp (59113 / 10000 : вДЭ) вЙ§ Real.exp (739 / 125 : вДЭ) :=
    Real.exp_le_exp.mpr (by norm_num)
  exact lt_of_le_of_lt hle backlund_exp_739_125_lt_370

