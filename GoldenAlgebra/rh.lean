      completedXiFunction s = 0 ÔåÆ s Ôëá 0 ÔåÆ
      Ôêâ i : ╬╣, zeroLoc i = s

-- =====================================================================
-- ┬ºCCCLXXXII. Bridge: nonzero-zero system ÔåÆ zero system under
--             `completedXiFunction 0 Ôëá 0`
-- =====================================================================

/-- Ô¡É **PROVED ÔÇö `ConcreteCompletedXiZeroSystem` from the nonzero
variant under `completedXiFunction 0 Ôëá 0`.** This hypothesis is
strong; for the ╬ô-based `completedXiFunction` it is generally false.
A future refactor should use Mathlib's `entireRiemannXi` where the
zero at the origin is absorbed into the prefactor and this
hypothesis becomes provable. -/
def ConcreteCompletedXiNonzeroZeroSystem.toZeroSystem
    {╬╣ : Type}
    (H : ConcreteCompletedXiNonzeroZeroSystem ╬╣)
    (h0 : completedXiFunction 0 Ôëá 0) :
    ConcreteCompletedXiZeroSystem ╬╣ :=
  { zeroLoc := H.zeroLoc
    zeroLoc_ne_zero := H.zeroLoc_ne_zero
    zeroLoc_is_zero := H.zeroLoc_is_zero
    all_completedXi_zeros := by
      intro s hs
