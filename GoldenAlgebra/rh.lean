theorem localXiPackage_10_140_regionAnti
    (error : Ôäé ÔåÆ Ôäé)
    (hdecomp : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
