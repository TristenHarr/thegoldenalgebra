/-- рЯМЯрЯМЯ **PROVED вАФ UHP-restricted closure for `AntiHerglotzUHP`.**
If `F X` is eventually anti-Herglotz and `F X z вЖТ f z` pointwise *only
on UHP*, then `f` is anti-Herglotz. Same proof structure as
`AntiHerglotzUHP.of_eventual_pointwise_tendsto` (¬ІCCXXXV), just
restricting the convergence hypothesis to `0 < z.im`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
    {F : вДЭ вЖТ вДВ вЖТ вДВ} {f : вДВ вЖТ вДВ}
    (hF : вИАбґ† X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : вИА z, 0 < z.im вЖТ
      Tendsto (fun X => F X z) Filter.atTop (рЭУЭ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto :
      Tendsto (fun X => (F X z).im) Filter.atTop (рЭУЭ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z hz)
  have hF_im_le : вИАбґ† X in Filter.atTop, (F X z).im вЙ§ 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **UHP-restricted convergence package.** Like
`SmoothDensityTailModelConverges` but with convergence required only
for `z` with `0 < z.im`. Outside UHP, `tailModel` is free (typically 0). -/
structure SmoothDensityTailModelConvergesUHP
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) where
  tailModel : вДВ вЖТ вДВ
  tendsto   : вИА z : вДВ, 0 < z.im вЖТ
    Tendsto
      (fun X : вДЭ => smoothDensityTailModelPartial ѕБ T X z)
      Filter.atTop (рЭУЭ (tailModel z))

/-- рЯУ¶ **`SmoothDensityTailMajorantDataUHP ѕБ T`** вАФ UHP-restricted
sibling of `SmoothDensityTailMajorantData`. All four fields are
quantified over `0 < z.im` to avoid the real-`z` pole non-integrability. -/
structure SmoothDensityTailMajorantDataUHP
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) where
  majorant : вДВ вЖТ вДЭ вЖТ вДЭ
  majorant_intervalIntegrable :
    вИА z X, 0 < z.im вЖТ T вЙ§ X вЖТ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    вИА z, 0 < z.im вЖТ вИГ L : вДЭ,
      Tendsto (fun X : вДЭ => вИЂ u in T..X, majorant z u)
        Filter.atTop (рЭУЭ L)
  integrand_intervalIntegrable :
    вИА z X, 0 < z.im вЖТ T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          (ѕБ u : вДВ) *
            ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    вИА z, 0 < z.im вЖТ вИАбґ† u in Filter.atTop,
      вАЦ(ѕБ u : вДВ) *
          ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ)))вАЦ
        вЙ§ majorant z u

/-- рЯМЯрЯМЯ **PROVED вАФ UHP pointwise smooth tail convergence from
majorant.** Sibling of ¬ІCCXXXVII's `smoothDensityTailModel_converges_at`
restricted to UHP `z`. -/
theorem smoothDensityTailModel_converges_at_UHP
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (H : SmoothDensityTailMajorantDataUHP ѕБ T)
    (z : вДВ) (hz : 0 < z.im) :
    вИГ L : вДВ,
      Tendsto
        (fun X : вДЭ => smoothDensityTailModelPartial ѕБ T X z)
        Filter.atTop (рЭУЭ L) := by
  rcases H.majorant_converges z hz with вЯ®LM, hLMвЯ©
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (ѕБ u : вДВ) *
        ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hz hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hz hTX)
    hLM
    (H.norm_bound_eventually z hz)

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelConvergesUHP` from
majorant data.** Uses `Classical.choose` on the UHP pointwise
existence theorem, with `tailModel z := 0` outside UHP. -/
noncomputable def smoothDensityTailModelConvergesUHP_of_majorant
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (H : SmoothDensityTailMajorantDataUHP ѕБ T) :
    SmoothDensityTailModelConvergesUHP ѕБ T where
  tailModel := fun z =>
    if hz : 0 < z.im then
      Classical.choose (smoothDensityTailModel_converges_at_UHP ѕБ T H z hz)
    else 0
  tendsto := by
    intro z hz
    have hExists := smoothDensityTailModel_converges_at_UHP ѕБ T H z hz
    have htail_val :
        (if hz' : 0 < z.im then
            Classical.choose
              (smoothDensityTailModel_converges_at_UHP ѕБ T H z hz')
          else 0)
          = Classical.choose hExists := by
      rw [dif_pos hz]
    rw [htail_val]
    exact Classical.choose_spec hExists

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelData` from UHP convergence
+ finite anti.** UHP-friendly sibling of ¬ІCCXXXV's
`smoothDensityTailModelData_of_converges`. -/
noncomputable def smoothDensityTailModelData_of_converges_UHP
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (C : SmoothDensityTailModelConvergesUHP ѕБ T)
    (Hfinite : SmoothDensityTailFiniteAntiData ѕБ T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
      (F := fun X => smoothDensityTailModelPartial ѕБ T X)
    ¬Ј filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ¬Ј exact C.tendsto

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `SmoothDensityTailModelData` from `ѕБ вЙ• 0` + UHP
norm majorant.** End-to-end UHP-restricted constructor. Mirrors
¬ІCCXXXVII's `smoothDensityTailModelData_of_majorant_nonneg`. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg_UHP
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ)
    (hѕБ_nonneg : вИА u, T вЙ§ u вЖТ 0 вЙ§ ѕБ u)
    (H : SmoothDensityTailMajorantDataUHP ѕБ T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges_UHP ѕБ T
    (smoothDensityTailModelConvergesUHP_of_majorant ѕБ T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ѕБ T hѕБ_nonneg
      (fun X z hTX hz => H.integrand_intervalIntegrable z X hz hTX))

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ UHP `SmoothDensityTailMajorantDataUHP` from log
growth.** Sibling of ¬ІCCXXXVIII restricted to UHP `z`. -/
noncomputable def smoothDensityTailMajorantDataUHP_of_logGrowth
    (ѕБ : вДЭ вЖТ вДЭ) (T : вДЭ) (A B : вДЭ)
    (_hA_nn : 0 вЙ§ A) (_hB_nn : 0 вЙ§ B)
    (hTpos : 0 < T)
    (hѕБ_bound : вИАбґ† u in Filter.atTop, |ѕБ u| вЙ§ A * Real.log u + B)
    (hѕБ_int :
      вИА z X, 0 < z.im вЖТ T вЙ§ X вЖТ
        IntervalIntegrable
          (fun u =>
            (ѕБ u : вДВ) *
              ((1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantDataUHP ѕБ T where
  majorant := fun z u =>
    trueKernelLogMajorant ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X _hz hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z _hz
    refine вЯ®-trueKernelLogMajorantPrimitive
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T, ?_вЯ©
    exact trueKernelLogMajorantConverges
      ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := hѕБ_int
  norm_bound_eventually := by
    intro z _hz
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, hѕБ_bound] with u hk hѕБu
    rw [norm_mul]
    have h_norm_ofReal : вАЦ(ѕБ u : вДВ)вАЦ = |ѕБ u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 вЙ§ A * Real.log u + B :=
      le_trans (abs_nonneg _) hѕБu
    calc |ѕБ u| * вАЦ(1 : вДВ) / (z - (u : вДВ)) + (1 : вДВ) / (z + (u : вДВ))вАЦ
        вЙ§ (A * Real.log u + B) * (4 * (вАЦzвАЦ + 1) / u^2) :=
          mul_le_mul hѕБu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((вАЦzвАЦ + 1) * A / 2) ((вАЦzвАЦ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

