-- =====================================================================
-- §CCXCII. `HlowArith` normalization (factor out `y > 0`)
-- =====================================================================
-- Both sides of `LowExplicitArithmeticBound_11_14_half` are linear in
-- `y := z.im`:
--   LHS  `closedFormFirstZeroErrorBound y 11 14 (1/2) = y · C₀`
--          where `C₀ := 17/242 − 9/392 ≈ 0.0473`,
--   RHS  `simpleCloudSum zeros100ceil x y = y · simpleCloudSumNorm ...`
--   RHS  `smoothTailRationalLowerBoundAbs x y 10 = y · smoothTailRationalLowerBoundAbsNorm x y 10`.
-- Since `y > 0` on `lowCompactRegion`, dividing both sides by `y`
-- removes the y-scaling and reduces the inequality to a single
-- constant `C₀ ≤ simpleCloudSumNorm + smoothTailRationalLowerBoundAbsNorm`
-- — independent of the small-y regime and easier to attack via
-- regional decomposition.
--
-- Adds:
--   simpleCloudSumNorm                            — `Σ 2/(x²+γ²+y²)`
--   smoothTailRationalLowerBoundAbsNorm           — smooth LB / y
--   lowArithConst_11_14_half                       — `17/242 − 9/392`
--   simpleCloudSum_eq_y_mul_norm                   — y-factorization
--   smoothTailRationalLowerBoundAbs_eq_y_mul_norm  — y-factorization
--   closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const  — y-factorization
--   LowExplicitArithmeticBoundNorm_11_14_half      — normalized Prop
--   LowExplicitArithmeticBound_11_14_half_of_norm  — bridge from normalized

/-- **Normalized `simpleCloudSum`** — divide out the leading `y` factor:
`Σ 2/(x²+γ²+y²)`. -/
noncomputable def simpleCloudSumNorm (zeros : List ℝ) (x y : ℝ) : ℝ :=
  (zeros.map fun g => 2 / (x ^ 2 + g ^ 2 + y ^ 2)).sum

/-- **Normalized `smoothTailRationalLowerBoundAbs`** — divide out the
leading `y` factor:
`ρ(T) · ((T − |x|)/((T − |x|)² + y²) + (T + |x|)/((T + |x|)² + y²))`. -/
noncomputable def smoothTailRationalLowerBoundAbsNorm (x y T : ℝ) : ℝ :=
  zeroDensityRho T *
    ((T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + (T + |x|) / ((T + |x|) ^ 2 + y ^ 2))

/-- **Path B arithmetic constant**: `closedFormFirstZeroErrorBound y 11 14 (1/2) = y · lowArithConst_11_14_half`.
Equals `17/242 − 9/392 ≈ 0.0473`. -/
noncomputable def lowArithConst_11_14_half : ℝ := 17 / 242 - 9 / 392

/-- ⭐ **PROVED — `simpleCloudSum` y-factorization.** -/
lemma simpleCloudSum_eq_y_mul_norm (zeros : List ℝ) (x y : ℝ) :
    simpleCloudSum zeros x y = y * simpleCloudSumNorm zeros x y := by
  unfold simpleCloudSum simpleCloudSumNorm
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    rw [ih]
    ring

/-- ⭐ **PROVED — `smoothTailRationalLowerBoundAbs` y-factorization.** -/
lemma smoothTailRationalLowerBoundAbs_eq_y_mul_norm (x y T : ℝ) :
    smoothTailRationalLowerBoundAbs x y T
      = y * smoothTailRationalLowerBoundAbsNorm x y T := by
  unfold smoothTailRationalLowerBoundAbs smoothTailRationalLowerBoundAbsNorm
  ring

/-- ⭐ **PROVED — `closedFormFirstZeroErrorBound y 11 14 (1/2) = y · C₀`**. -/
lemma closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const (y : ℝ) :
    closedFormFirstZeroErrorBound y 11 14 (1 / 2)
      = y * lowArithConst_11_14_half := by
  unfold closedFormFirstZeroErrorBound lowArithConst_11_14_half
  ring

/-- 📦 **`LowExplicitArithmeticBoundNorm_11_14_half`** — y-normalized
arithmetic obligation. Removes the y-scaling and reduces the problem
to a single constant inequality on the compact box. -/
def LowExplicitArithmeticBoundNorm_11_14_half : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    lowArithConst_11_14_half
      ≤ simpleCloudSumNorm zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbsNorm z.re z.im 10

/-- 🌟🌟🌟 **PROVED — bridge from normalized to original `HlowArith`.**
Multiplies the normalized inequality by `y > 0` to recover the
y-scaled form. -/
theorem LowExplicitArithmeticBound_11_14_half_of_norm
    (h : LowExplicitArithmeticBoundNorm_11_14_half) :
    LowExplicitArithmeticBound_11_14_half := by
  intro z hz
  have hy : 0 < z.im := hz.1
  have h_norm := h z hz
  -- Rewrite LHS and RHS in y-factored form
  show lowResidualExplicitBoundAt 11 14 (1 / 2) z
        ≤ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  show closedFormFirstZeroErrorBound z.im 11 14 (1 / 2)
        ≤ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im 10
  rw [closedFormFirstZeroErrorBound_11_14_half_eq_y_mul_const,
      simpleCloudSum_eq_y_mul_norm,
      smoothTailRationalLowerBoundAbs_eq_y_mul_norm]
  have h_combine :
      z.im * simpleCloudSumNorm zeros100ceil z.re z.im
        + z.im * smoothTailRationalLowerBoundAbsNorm z.re z.im 10
        = z.im * (simpleCloudSumNorm zeros100ceil z.re z.im
                  + smoothTailRationalLowerBoundAbsNorm z.re z.im 10) := by
    ring
  rw [h_combine]
  exact mul_le_mul_of_nonneg_left h_norm (le_of_lt hy)

-- =====================================================================
-- §CCXCIII-A. `HlowArith_norm` cloud lower bound
-- =====================================================================
-- On `lowCompactRegion`, `x² + y² ≤ 16` (from `|x| + y ≤ 4`), so each
-- normalized cloud term `2/(x²+γ²+y²) ≥ 2/(γ²+16)`. Summing over
-- `zeros100ceil` gives the uniform lower bound
--   `cloudLBConst := Σ_{γ ∈ zeros100ceil} 2/(γ²+16) ≈ 0.0370`.
-- Cloud alone is insufficient (`C ≈ 0.0473`, gap ≈ -0.0103). The
-- smooth lower bound (§CCXCIII-B, separate section) supplies the
-- additional ≈ 0.0125 to close with margin ≈ 0.0024.

/-- ⭐ **PROVED — `x² + y² ≤ 16` on the low compact region.** Follows
from `(|x| + y)² ≤ 16` and dropping the non-negative cross term `2|x|y`. -/
lemma lowCompactRegion_sq_re_add_sq_im_le_16
    {z : ℂ} (hz : lowCompactRegion z) :
    z.re ^ 2 + z.im ^ 2 ≤ 16 := by
  have hy : 0 < z.im := hz.1
  have h_sum : 2 * (1 + |z.re| + z.im) ≤ 10 := hz.2
  have h_xy : |z.re| + z.im ≤ 4 := by linarith
  have h_abs_nn : (0 : ℝ) ≤ |z.re| := abs_nonneg _
  have h_y_nn : (0 : ℝ) ≤ z.im := le_of_lt hy
  have h_sq_re : z.re ^ 2 = |z.re| ^ 2 := (sq_abs z.re).symm
  rw [h_sq_re]
  nlinarith [sq_nonneg (|z.re| + z.im), h_abs_nn, h_y_nn, h_xy,
             mul_nonneg h_abs_nn h_y_nn]

/-- ⭐ **PROVED — generic pointwise list sum bound.** -/
lemma list_sum_le_sum_of_pointwise
    {α : Type*} {L : List α} {f g : α → ℝ}
    (h : ∀ a ∈ L, f a ≤ g a) :
    (L.map f).sum ≤ (L.map g).sum := by
  induction L with
  | nil => simp
  | cons a rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_a : f a ≤ g a := h a (by simp)
    have h_rest : ∀ b ∈ rest, f b ≤ g b :=
      fun b hb => h b (List.mem_cons_of_mem a hb)
    have h_rest_le := ih h_rest
    linarith

/-- ⭐ **PROVED — per-zero cloud lower bound.** -/
lemma simpleCloudSumNorm_term_lower
    {x y γ : ℝ} (hxy : x ^ 2 + y ^ 2 ≤ 16) (hy : 0 < y) :
    (2 : ℝ) / (γ ^ 2 + 16) ≤ 2 / (x ^ 2 + γ ^ 2 + y ^ 2) := by
  have h_xsq_nn : (0 : ℝ) ≤ x ^ 2 := sq_nonneg x
  have h_ysq_pos : (0 : ℝ) < y ^ 2 := by positivity
  have h_gamma_sq_nn : (0 : ℝ) ≤ γ ^ 2 := sq_nonneg γ
  have h_denom_pos : (0 : ℝ) < x ^ 2 + γ ^ 2 + y ^ 2 := by linarith
  have h_denom_target_pos : (0 : ℝ) < γ ^ 2 + 16 := by positivity
  have h_denom_le : x ^ 2 + γ ^ 2 + y ^ 2 ≤ γ ^ 2 + 16 := by linarith
  rw [div_le_div_iff₀ h_denom_target_pos h_denom_pos]
  nlinarith [h_denom_le, h_denom_pos, h_denom_target_pos]

/-- **Cloud lower-bound constant**: `Σ_{γ ∈ zeros100ceil} 2/(γ² + 16) ≈ 0.0370`. -/
noncomputable def cloudLBConst : ℝ :=
  (zeros100ceil.map (fun γ : ℝ => 2 / (γ ^ 2 + 16))).sum

/-- 🌟 **PROVED — uniform cloud lower bound** on the low compact region:
`cloudLBConst ≤ simpleCloudSumNorm zeros100ceil z.re z.im`. -/
theorem simpleCloudSumNorm_zeros100ceil_lower_bound
    {z : ℂ} (hz : lowCompactRegion z) :
    cloudLBConst ≤ simpleCloudSumNorm zeros100ceil z.re z.im := by
  unfold cloudLBConst simpleCloudSumNorm
  have hy : 0 < z.im := hz.1
  have hxy : z.re ^ 2 + z.im ^ 2 ≤ 16 :=
    lowCompactRegion_sq_re_add_sq_im_le_16 hz
  exact list_sum_le_sum_of_pointwise
    (fun γ _ => simpleCloudSumNorm_term_lower hxy hy)

-- =====================================================================
-- §CCXCIII-B. Smooth uniform lower bound on `lowCompactRegion`
-- =====================================================================
-- Proves `smoothLBConst ≤ smoothTailRationalLowerBoundAbsNorm z.re z.im 10`
-- where `smoothLBConst := (259/3586)·(5/29) ≈ 0.01246`. The factor
-- `5/29` is the uniform LB for the kernel factor (equality at `(0, 4)`);
-- `259/3586` is the rational LB for `ρ(10)` via Padé `log(5/π) ≥ 74/163`
-- and `1/(2π) ≥ 7/44`.

/-- ⭐ **PROVED — Padé bound** `2(5−π)/(5+π) ≤ log(5/π)`. -/
lemma pade_log_5_div_pi :
    2 * (5 - Real.pi) / (5 + Real.pi) ≤ Real.log (5 / Real.pi) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_5_lt_pi : Real.pi < 5 := by linarith
  have hπ_ne : Real.pi ≠ 0 := ne_of_gt h_pi_pos
  have h_5_plus_pi_pos : (0 : ℝ) < 5 + Real.pi := by linarith
  have h_x_nn : (0 : ℝ) ≤ (5 - Real.pi) / Real.pi := by
    apply div_nonneg
    · linarith
    · exact le_of_lt h_pi_pos
  have h_one_add : 1 + (5 - Real.pi) / Real.pi = 5 / Real.pi := by
    field_simp
  have h_pade := Real.le_log_one_add_of_nonneg h_x_nn
  rw [h_one_add] at h_pade
  -- Multiply h_pade by ((5-π)/π + 2) > 0
  have h_inner_pos : (0 : ℝ) < (5 - Real.pi) / Real.pi + 2 := by positivity
  have h_inner_ne : ((5 - Real.pi) / Real.pi + 2) ≠ 0 := ne_of_gt h_inner_pos
  have h_step1 :
      2 * ((5 - Real.pi) / Real.pi)
        ≤ ((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_right h_pade (le_of_lt h_inner_pos)
    rw [div_mul_cancel₀ _ h_inner_ne] at h
    linarith
  -- Multiply by π > 0
  have h_step2 :
      2 * (5 - Real.pi) ≤ (5 + Real.pi) * Real.log (5 / Real.pi) := by
    have h := mul_le_mul_of_nonneg_left h_step1 (le_of_lt h_pi_pos)
    have hl : Real.pi * (2 * ((5 - Real.pi) / Real.pi)) = 2 * (5 - Real.pi) := by
      field_simp
    have h_factor :
        Real.pi * ((5 - Real.pi) / Real.pi + 2) = 5 + Real.pi := by
      field_simp; ring
    have hr :
        Real.pi * (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
          = (5 + Real.pi) * Real.log (5 / Real.pi) := by
      rw [show Real.pi *
            (((5 - Real.pi) / Real.pi + 2) * Real.log (5 / Real.pi))
            = (Real.pi * ((5 - Real.pi) / Real.pi + 2))
                * Real.log (5 / Real.pi) from by ring,
          h_factor]
    linarith [h, hl.le, hl.symm.le, hr.le, hr.symm.le]
  -- Divide by (5+π) > 0 to recover 2(5-π)/(5+π) ≤ log(5/π)
  have h5pπ_ne : (5 + Real.pi : ℝ) ≠ 0 := ne_of_gt h_5_plus_pi_pos
  rw [div_le_iff₀ h_5_plus_pi_pos]
  linarith [h_step2]

/-- ⭐ **PROVED — rational `74/163 ≤ 2(5−π)/(5+π)`** from `π ≤ 3.15`. -/
lemma pade_rational_lb_at_5_div_pi :
    (74 / 163 : ℝ) ≤ 2 * (5 - Real.pi) / (5 + Real.pi) := by
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_5_plus_pi_pos : (0 : ℝ) < 5 + Real.pi := by linarith
  rw [le_div_iff₀ h_5_plus_pi_pos]
  linarith

/-- ⭐ **PROVED — `log(5/π) ≥ 74/163`.** -/
lemma log_5_div_pi_ge_74_div_163 :
    (74 / 163 : ℝ) ≤ Real.log (5 / Real.pi) :=
  le_trans pade_rational_lb_at_5_div_pi pade_log_5_div_pi

/-- 🌟 **PROVED — `ρ(10) ≥ 259/3586`.** -/
theorem zeroDensityRho_10_ge_259_div_3586 :
    (259 / 3586 : ℝ) ≤ zeroDensityRho 10 := by
  have h_eq : (10 : ℝ) / (2 * Real.pi) = 5 / Real.pi := by ring
  have h_inv : (7 / 44 : ℝ) ≤ 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_log : (74 / 163 : ℝ) ≤ Real.log (5 / Real.pi) :=
    log_5_div_pi_ge_74_div_163
  have h_44_nn : (0 : ℝ) ≤ (74 / 163 : ℝ) := by norm_num
  have h_inv_nn : (0 : ℝ) ≤ 1 / (2 * Real.pi) := by
    have h2pi_pos : (0 : ℝ) < 2 * Real.pi := by linarith [Real.pi_pos]
    positivity
  calc (259 / 3586 : ℝ)
      = (7 / 44) * (74 / 163) := by norm_num
    _ ≤ (1 / (2 * Real.pi)) * Real.log (5 / Real.pi) :=
        mul_le_mul h_inv h_log h_44_nn h_inv_nn
    _ = zeroDensityRho 10 := by
        unfold zeroDensityRho
        rw [h_eq]

/-- ⭐ **PROVED — kernel-factor polynomial bound**
`((10−a)²+y²)·((10+a)²+y²) ≤ 116·(100−a²+y²)` on `a²+y² ≤ 16`. -/
lemma kernel_factor_den_le_aux
    {a y : ℝ} (_ha_nn : 0 ≤ a) (hbox : a ^ 2 + y ^ 2 ≤ 16) :
    ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)
      ≤ 116 * (100 - a ^ 2 + y ^ 2) := by
  have hu : (0 : ℝ) ≤ a ^ 2 := sq_nonneg a
  have hv : (0 : ℝ) ≤ y ^ 2 := sq_nonneg y
  have hnn : (0 : ℝ) ≤ a ^ 2 + y ^ 2 := by linarith
  have hv_le_16 : y ^ 2 ≤ 16 := by linarith
  have h_w_sq_le_256 :
      (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2) ≤ 256 := by
    have h_mul : (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2)
                ≤ (a ^ 2 + y ^ 2) * 16 :=
      mul_le_mul_of_nonneg_left hbox hnn
    linarith
  have h_lhs_expand :
      ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)
        = (a ^ 2 + y ^ 2) * (a ^ 2 + y ^ 2)
          + 200 * (a ^ 2 + y ^ 2) - 400 * a ^ 2 + 10000 := by
    ring
  rw [h_lhs_expand]
  linarith [h_w_sq_le_256, hu, hv, hv_le_16]

/-- 🌟 **PROVED — kernel factor uniform LB `5/29`** on the box. -/
theorem smoothKernelNormFactor_ge_five_div_twentyNine
    {x y : ℝ} (hy : 0 < y) (hbox : x ^ 2 + y ^ 2 ≤ 16) :
    (5 / 29 : ℝ)
      ≤ (10 - |x|) / ((10 - |x|) ^ 2 + y ^ 2)
        + (10 + |x|) / ((10 + |x|) ^ 2 + y ^ 2) := by
  set a := |x| with ha_def
  have ha_nn : (0 : ℝ) ≤ a := abs_nonneg x
  have ha_sq : a ^ 2 = x ^ 2 := sq_abs x
  have ha_box : a ^ 2 + y ^ 2 ≤ 16 := by rw [ha_sq]; exact hbox
  have ha_sq_le_16 : a ^ 2 ≤ 16 := by
    have := sq_nonneg y; linarith
  have ha_le_4 : a ≤ 4 := by
    nlinarith [sq_nonneg (a - 4), ha_sq_le_16, ha_nn]
  have h_10_sub_a_pos : (0 : ℝ) < 10 - a := by linarith
  have h_10_add_a_pos : (0 : ℝ) < 10 + a := by linarith
  have h_A_pos : (0 : ℝ) < (10 - a) ^ 2 + y ^ 2 := by positivity
  have h_B_pos : (0 : ℝ) < (10 + a) ^ 2 + y ^ 2 := by positivity
  have h_D_pos : (0 : ℝ) <
      ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2) :=
    mul_pos h_A_pos h_B_pos
  have h_N_pos : (0 : ℝ) < 100 - a ^ 2 + y ^ 2 := by
    have := sq_nonneg y; linarith
  have h_identity :
      (10 - a) / ((10 - a) ^ 2 + y ^ 2)
        + (10 + a) / ((10 + a) ^ 2 + y ^ 2)
        = 20 * (100 - a ^ 2 + y ^ 2)
          / (((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)) := by
    field_simp
    ring
  rw [h_identity]
  have h_den_le :
      ((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)
        ≤ 116 * (100 - a ^ 2 + y ^ 2) :=
    kernel_factor_den_le_aux ha_nn ha_box
  rw [le_div_iff₀ h_D_pos]
  nlinarith [h_den_le, h_N_pos]

/-- **Smooth uniform LB constant**: `(259/3586)·(5/29) ≈ 0.01246`. -/
noncomputable def smoothLBConst : ℝ := (259 / 3586) * (5 / 29)

/-- 🌟🌟 **PROVED — uniform smooth lower bound** on the low compact
region: `smoothLBConst ≤ smoothTailRationalLowerBoundAbsNorm z.re z.im 10`. -/
theorem smoothTailRationalLowerBoundAbsNorm_uniform_lowBox
    {z : ℂ} (hz : lowCompactRegion z) :
    smoothLBConst
      ≤ smoothTailRationalLowerBoundAbsNorm z.re z.im 10 := by
  unfold smoothLBConst smoothTailRationalLowerBoundAbsNorm
  have hy : 0 < z.im := hz.1
  have hxy : z.re ^ 2 + z.im ^ 2 ≤ 16 :=
    lowCompactRegion_sq_re_add_sq_im_le_16 hz
