    mul_pos h_A_pos h_B_pos
  have h_N_pos : (0 : ÔäØ) < 100 - a ^ 2 + y ^ 2 := by
    have := sq_nonneg y; linarith
  have h_identity :
      (10 - a) / ((10 - a) ^ 2 + y ^ 2)
        + (10 + a) / ((10 + a) ^ 2 + y ^ 2)
        = 20 * (100 - a ^ 2 + y ^ 2)
          / (((10 - a) ^ 2 + y ^ 2) * ((10 + a) ^ 2 + y ^ 2)) := by
    field_simp
