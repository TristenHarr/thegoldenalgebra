/-- тнР **PROVED тАФ `log T тЙд 18/5` on `[32, 36]`.**
Via monotonicity + `log 36 тЙд 18/5`. The endpoint check uses
`2.7182818283 < exp 1` тЖТ `(2.7182818283)^18 < exp(18)` and
`36^5 тЙд (2.7182818283)^18` (norm_num). Taking 5th roots yields
`36 тЙд exp(18/5)`, hence `log 36 тЙд 18/5`. -/
lemma log_T_le_18_5_on_32_36
    {T : тДЭ} (hT32 : 32 тЙд T) (hT36 : T тЙд 36) :
    Real.log T тЙд 18 / 5 := by
  have hTpos : 0 < T := by linarith
  have h36_pos : (0 : тДЭ) < 36 := by norm_num
  have hlog_mono : Real.log T тЙд Real.log 36 := Real.log_le_log hTpos hT36
  have h_exp_1_gt : 2.7182818283 < Real.exp 1 := Real.exp_one_gt_d9
  have h_2718_pos : (0 : тДЭ) < 2.7182818283 := by norm_num
  have h_exp_1_18 : (2.7182818283 : тДЭ)^18 < (Real.exp 1)^18 :=
    pow_lt_pow_leftтВА h_exp_1_gt (le_of_lt h_2718_pos) (by norm_num)
  have h_36_5_le_27 : (36 : тДЭ)^5 тЙд (2.7182818283 : тДЭ)^18 := by norm_num
  have h_36_5_le_exp_1_18 : (36 : тДЭ)^5 тЙд (Real.exp 1)^18 := by linarith
  have h_exp_18_eq : Real.exp 18 = (Real.exp 1)^18 := by
    have h := Real.exp_one_pow 18
    have h_cast : ((18 : тДХ) : тДЭ) = (18 : тДЭ) := by norm_num
    rw [тЖР h_cast]; exact h.symm
  have h_exp_18_5_pow : (Real.exp (18/5 : тДЭ))^5 = Real.exp 18 := by
    have h := Real.exp_nat_mul (18/5 : тДЭ) 5
    have h_eq : ((5 : тДХ) : тДЭ) * (18/5 : тДЭ) = 18 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_36_5_le_exp_18_5_pow : (36 : тДЭ)^5 тЙд (Real.exp (18/5 : тДЭ))^5 := by
    have h1 : (Real.exp 1)^18 = Real.exp 18 := h_exp_18_eq.symm
    have h2 : Real.exp 18 = (Real.exp (18/5 : тДЭ))^5 := h_exp_18_5_pow.symm
    linarith
  have h_exp_18_5_nn : (0 : тДЭ) тЙд Real.exp (18/5 : тДЭ) := le_of_lt (Real.exp_pos _)
  have h_36_le_exp : (36 : тДЭ) тЙд Real.exp (18/5 : тДЭ) :=
    (pow_le_pow_iff_leftтВА (by norm_num : (0:тДЭ) тЙд 36) h_exp_18_5_nn
              (by norm_num : (5 : тДХ) тЙа 0)).mp h_36_5_le_exp_18_5_pow
  have h_log_36_le : Real.log 36 тЙд 18/5 := by
    have h := Real.log_le_log h36_pos h_36_le_exp
    rwa [Real.log_exp] at h
  linarith [hlog_mono, h_log_36_le]

/-- тнР **PROVED тАФ Constant LB for `log(T/(2╧А))` on `[32, 36]`** via monotonicity. -/
lemma log_T_over_2pi_ge_const_32_36
    {T : тДЭ} (hT32 : 32 тЙд T) (_hT36 : T тЙд 36) :
    (8 / 5 : тДЭ) тЙд Real.log (T / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h32_pos : (0 : тДЭ) < 32 / (2 * Real.pi) := by positivity
  have hratio : 32 / (2 * Real.pi) тЙд T / (2 * Real.pi) :=
    div_le_div_of_nonneg_right hT32 (le_of_lt h_2pi_pos)
  have hlogmono :
      Real.log (32 / (2 * Real.pi)) тЙд Real.log (T / (2 * Real.pi)) :=
    Real.log_le_log h32_pos hratio
  exact le_trans log_32_div_2pi_ge_8_5 hlogmono

