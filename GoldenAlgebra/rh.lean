/-! ## BF: Interval helper lemmas for boundary cancellation -/

/-- Reverse-pair cancellation: `тИл a..b g + тИл b..a g = 0` for тДВ-valued
integrands.  Pure reversal тАФ no integrability needed. -/
theorem intervalIntegral_add_reverse_eq_zero
    (g : тДЭ тЖТ тДВ) (a b : тДЭ) :
    (тИл x in a..b, g x) + (тИл x in b..a, g x) = 0 := by
  rw [intervalIntegral.integral_symm]
  ring

/-- Reverse-pair cancellation with `* Complex.I` weight (for vertical
edges). -/
theorem intervalIntegral_add_reverse_eq_zero_with_I
    (g : тДЭ тЖТ тДВ) (a b : тДЭ) :
    (тИл x in a..b, g x * Complex.I) +
      (тИл x in b..a, g x * Complex.I) = 0 :=
  intervalIntegral_add_reverse_eq_zero (fun x => g x * Complex.I) a b

/-- Three-piece adjacent concatenation:
`тИл a..b g + тИл b..c g + тИл c..d g = тИл a..d g`, given integrability across the
three sub-intervals. -/
theorem intervalIntegral_add_three_adjacent_eq
    {g : тДЭ тЖТ тДВ} {a b c d : тДЭ}
    (hab : IntervalIntegrable g MeasureTheory.volume a b)
    (hbc : IntervalIntegrable g MeasureTheory.volume b c)
    (hcd : IntervalIntegrable g MeasureTheory.volume c d) :
    (тИл x in a..b, g x) + (тИл x in b..c, g x) + (тИл x in c..d, g x) =
      тИл x in a..d, g x := by
  rw [intervalIntegral.integral_add_adjacent_intervals hab hbc]
  exact intervalIntegral.integral_add_adjacent_intervals (hab.trans hbc) hcd

/-! ## BG: Named edge integrals + symbolic boundary identity -/

/-! ### BG1: named coordinate edge integrals -/

/-- Horizontal edge integral of the unit kernel: integrate `1/(тЯиx, yтЯй - a)`
along `x` from `xтВА` to `xтВБ` at fixed imaginary part `y`. -/
noncomputable def hEdge (y xтВА xтВБ : тДЭ) (a : тДВ) : тДВ :=
  тИл x in xтВА..xтВБ, unitPrincipalKernel a тЯиx, yтЯй

/-- Vertical edge integral of the unit kernel with `* Complex.I` weight. -/
noncomputable def vEdge (x yтВА yтВБ : тДЭ) (a : тДВ) : тДВ :=
  тИл y in yтВА..yтВБ, unitPrincipalKernel a тЯиx, yтЯй * Complex.I

theorem bottomHorizontalIntegral_eq_hEdge
    (R : ZetaRectangle) (a : тДВ) :
    R.bottomHorizontalIntegral (unitPrincipalKernel a) =
      hEdge R.bottom R.left R.right a := rfl

theorem topHorizontalIntegral_eq_hEdge
    (R : ZetaRectangle) (a : тДВ) :
    R.topHorizontalIntegral (unitPrincipalKernel a) =
      hEdge R.top R.right R.left a := rfl

theorem rightVerticalIntegral_eq_vEdge
    (R : ZetaRectangle) (a : тДВ) :
    R.rightVerticalIntegral (unitPrincipalKernel a) =
      vEdge R.right R.bottom R.top a := rfl

theorem leftVerticalIntegral_eq_vEdge
    (R : ZetaRectangle) (a : тДВ) :
    R.leftVerticalIntegral (unitPrincipalKernel a) =
      vEdge R.left R.top R.bottom a := rfl

/-! ### BG2: reverse-edge cancellation in named form -/

theorem hEdge_add_reverse_eq_zero
    (y xтВА xтВБ : тДЭ) (a : тДВ) :
    hEdge y xтВА xтВБ a + hEdge y xтВБ xтВА a = 0 := by
  unfold hEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй) xтВА xтВБ

theorem vEdge_add_reverse_eq_zero
    (x yтВА yтВБ : тДЭ) (a : тДВ) :
    vEdge x yтВА yтВБ a + vEdge x yтВБ yтВА a = 0 := by
  unfold vEdge
  exact intervalIntegral_add_reverse_eq_zero
    (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I) yтВА yтВБ

theorem hEdge_reverse_eq_neg
    (y xтВА xтВБ : тДЭ) (a : тДВ) :
    hEdge y xтВБ xтВА a = -hEdge y xтВА xтВБ a := by
  unfold hEdge
  exact intervalIntegral.integral_symm xтВА xтВБ

theorem vEdge_reverse_eq_neg
    (x yтВА yтВБ : тДЭ) (a : тДВ) :
    vEdge x yтВБ yтВА a = -vEdge x yтВА yтВБ a := by
  unfold vEdge
  exact intervalIntegral.integral_symm yтВА yтВБ

/-! ### BG3: three-piece adjacency in named form (with integrability) -/

theorem hEdge_add_three_adjacent_eq
    {y xтВА xтВБ xтВВ xтВГ : тДЭ} {a : тДВ}
    (h01 : IntervalIntegrable
            (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй)
            MeasureTheory.volume xтВА xтВБ)
    (h12 : IntervalIntegrable
            (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй)
            MeasureTheory.volume xтВБ xтВВ)
    (h23 : IntervalIntegrable
            (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй)
            MeasureTheory.volume xтВВ xтВГ) :
    hEdge y xтВА xтВБ a + hEdge y xтВБ xтВВ a + hEdge y xтВВ xтВГ a =
      hEdge y xтВА xтВГ a := by
  unfold hEdge
  exact intervalIntegral_add_three_adjacent_eq h01 h12 h23

theorem vEdge_add_three_adjacent_eq
    {x yтВА yтВБ yтВВ yтВГ : тДЭ} {a : тДВ}
    (h01 : IntervalIntegrable
            (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I)
            MeasureTheory.volume yтВА yтВБ)
    (h12 : IntervalIntegrable
            (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I)
            MeasureTheory.volume yтВБ yтВВ)
    (h23 : IntervalIntegrable
            (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I)
            MeasureTheory.volume yтВВ yтВГ) :
    vEdge x yтВА yтВБ a + vEdge x yтВБ yтВВ a + vEdge x yтВВ yтВГ a =
      vEdge x yтВА yтВГ a := by
  unfold vEdge
  exact intervalIntegral_add_three_adjacent_eq h01 h12 h23

/-! ## BH: Symbolic four-strip boundary identity -/

/-- Symbolic four-strip boundary cancellation: a pure additive-group identity
in 24 named edge integrals.  The eight hypotheses are the only analytic
facts needed (three-piece concatenations and reverse-orientation negations);
once supplied, the rest is `abel`. -/
theorem fourStripBoundarySymbolic
    (L Rgt B T xl xr yb yt : тДЭ) (a : тДВ)
    (hRight :
      vEdge Rgt B yb a + vEdge Rgt yb yt a + vEdge Rgt yt T a =
        vEdge Rgt B T a)
    (hLeft :
      vEdge L T yt a + vEdge L yt yb a + vEdge L yb B a =
        vEdge L T B a)
    (hInnerBottomJoin :
      hEdge yb L xl a + hEdge yb xl xr a + hEdge yb xr Rgt a =
        hEdge yb L Rgt a)
    (hInnerTopJoin :
      hEdge yt Rgt xr a + hEdge yt xr xl a + hEdge yt xl L a =
        hEdge yt Rgt L a)
    (hInnerBottomReverse :
      hEdge yb Rgt L a = -hEdge yb L Rgt a)
    (hInnerTopReverse :
      hEdge yt L Rgt a = -hEdge yt Rgt L a)
    (hInnerLeftReverse :
      vEdge xl yb yt a = -vEdge xl yt yb a)
    (hInnerRightReverse :
      vEdge xr yt yb a = -vEdge xr yb yt a) :
    ((hEdge B L Rgt a + vEdge Rgt B yb a
        + hEdge yb Rgt L a + vEdge L yb B a)
      +
      (hEdge yt L Rgt a + vEdge Rgt yt T a
        + hEdge T Rgt L a + vEdge L T yt a)
      +
      (hEdge yb L xl a + vEdge xl yb yt a
        + hEdge yt xl L a + vEdge L yt yb a)
      +
      (hEdge yb xr Rgt a + vEdge Rgt yb yt a
        + hEdge yt Rgt xr a + vEdge xr yt yb a)) =
    (hEdge B L Rgt a + vEdge Rgt B T a
      + hEdge T Rgt L a + vEdge L T B a) -
    (hEdge yb xl xr a + vEdge xr yb yt a
      + hEdge yt xr xl a + vEdge xl yt yb a) := by
  rw [тЖР hRight, тЖР hLeft]
  rw [hInnerBottomReverse, hInnerTopReverse,
      hInnerLeftReverse, hInnerRightReverse]
  rw [тЖР hInnerBottomJoin, тЖР hInnerTopJoin]
  abel

/-! ## BI: Integrability primitives for the unit kernel -/

/-- `(fun x => тЯиx, yтЯй : тДЭ тЖТ тДВ)` is continuous. -/
theorem continuous_complex_mk_real_horizontal (y : тДЭ) :
    Continuous (fun x : тДЭ => (тЯиx, yтЯй : тДВ)) := by
  have h_eq :
      (fun x : тДЭ => (тЯиx, yтЯй : тДВ)) =
        fun x : тДЭ => ((x : тДВ) + (y : тДВ) * Complex.I) := by
    funext x; exact Complex.mk_eq_add_mul_I x y
  rw [h_eq]
  exact Complex.continuous_ofReal.add continuous_const

/-- `(fun y => тЯиx, yтЯй : тДЭ тЖТ тДВ)` is continuous. -/
theorem continuous_complex_mk_real_vertical (x : тДЭ) :
    Continuous (fun y : тДЭ => (тЯиx, yтЯй : тДВ)) := by
  have h_eq :
      (fun y : тДЭ => (тЯиx, yтЯй : тДВ)) =
        fun y : тДЭ => ((x : тДВ) + (y : тДВ) * Complex.I) := by
    funext y; exact Complex.mk_eq_add_mul_I x y
  rw [h_eq]
  exact continuous_const.add (Complex.continuous_ofReal.mul continuous_const)

/-- The unit kernel `1/(z-a)` is continuous along the horizontal line at fixed
imaginary part `y тЙа a.im`. -/
theorem continuous_unitPrincipalKernel_horizontal
    (a : тДВ) {y : тДЭ} (hy : y тЙа a.im) :
    Continuous (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй) := by
  unfold unitPrincipalKernel
  refine Continuous.div continuous_const
    ((continuous_complex_mk_real_horizontal y).sub continuous_const) ?_
  intro x heq
  have h_eq : (тЯиx, yтЯй : тДВ) = a := sub_eq_zero.mp heq
  have hyeq : y = a.im := by
    have := congrArg Complex.im h_eq
    simpa using this
  exact hy hyeq

/-- The unit kernel `1/(z-a)` is integrable along the horizontal line at fixed
imaginary part `y тЙа a.im` over any interval. -/
theorem intervalIntegrable_unitPrincipalKernel_horizontal
    (a : тДВ) {y : тДЭ} (hy : y тЙа a.im) (xтВА xтВБ : тДЭ) :
    IntervalIntegrable
      (fun x : тДЭ => unitPrincipalKernel a тЯиx, yтЯй)
      MeasureTheory.volume xтВА xтВБ :=
  (continuous_unitPrincipalKernel_horizontal a hy).intervalIntegrable xтВА xтВБ

/-- The unit kernel times `I` is continuous along the vertical line at fixed
real part `x тЙа a.re`. -/
theorem continuous_unitPrincipalKernel_vertical_with_I
    (a : тДВ) {x : тДЭ} (hx : x тЙа a.re) :
    Continuous (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I) := by
  have h_inner : Continuous (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй) := by
    unfold unitPrincipalKernel
    refine Continuous.div continuous_const
      ((continuous_complex_mk_real_vertical x).sub continuous_const) ?_
    intro y heq
    have h_eq : (тЯиx, yтЯй : тДВ) = a := sub_eq_zero.mp heq
    have hxeq : x = a.re := by
      have := congrArg Complex.re h_eq
      simpa using this
    exact hx hxeq
  exact h_inner.mul continuous_const

/-- The unit kernel times `I` is integrable along the vertical line. -/
theorem intervalIntegrable_unitPrincipalKernel_vertical_with_I
    (a : тДВ) {x : тДЭ} (hx : x тЙа a.re) (yтВА yтВБ : тДЭ) :
    IntervalIntegrable
      (fun y : тДЭ => unitPrincipalKernel a тЯиx, yтЯй * Complex.I)
      MeasureTheory.volume yтВА yтВБ :=
  (continuous_unitPrincipalKernel_vertical_with_I a hx).intervalIntegrable yтВА yтВБ

/-! ## BJ: Final coordinate cancellation тАФ `FourStripCoordinateBoundarySumIdentity` -/

theorem fourStripCoordinateBoundarySumIdentity
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripCoordinateBoundarySumIdentity S := by
  refine тЯи?_тЯй
  have haOpen : R.ContainsOpen a := by
    apply S.square_subset_open
    refine тЯи?_, ?_тЯй
    ┬╖ show |a.re - a.re| тЙд S.r; simp; exact S.r_pos.le
    ┬╖ show |a.im - a.im| тЙд S.r; simp; exact S.r_pos.le
  have hright_ne : R.right тЙа a.re := fun h => by linarith [haOpen.2.1]
  have hleft_ne : R.left тЙа a.re := fun h => by linarith [haOpen.1]
  have hyb_ne : a.im - S.r тЙа a.im := fun h => by linarith [S.r_pos]
  have hyt_ne : a.im + S.r тЙа a.im := fun h => by linarith [S.r_pos]
  have h_sym :=
    fourStripBoundarySymbolic
      R.left R.right R.bottom R.top
      (a.re - S.r) (a.re + S.r)
      (a.im - S.r) (a.im + S.r) a
      (vEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne R.bottom (a.im - S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne (a.im - S.r) (a.im + S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hright_ne (a.im + S.r) R.top))
      (vEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne R.top (a.im + S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne (a.im + S.r) (a.im - S.r))
        (intervalIntegrable_unitPrincipalKernel_vertical_with_I
          a hleft_ne (a.im - S.r) R.bottom))
      (hEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne R.left (a.re - S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne (a.re - S.r) (a.re + S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyb_ne (a.re + S.r) R.right))
      (hEdge_add_three_adjacent_eq
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne R.right (a.re + S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne (a.re + S.r) (a.re - S.r))
        (intervalIntegrable_unitPrincipalKernel_horizontal
          a hyt_ne (a.re - S.r) R.left))
      (hEdge_reverse_eq_neg (a.im - S.r) R.left R.right a)
      (hEdge_reverse_eq_neg (a.im + S.r) R.right R.left a)
      (vEdge_reverse_eq_neg (a.re - S.r) (a.im + S.r) (a.im - S.r) a)
      (vEdge_reverse_eq_neg (a.re + S.r) (a.im - S.r) (a.im + S.r) a)
  unfold coordinateBoundaryIntegral bottomHorizontalIntegral
    topHorizontalIntegral rightVerticalIntegral leftVerticalIntegral
    SmallSquareInsideRectangle.topStrip
    SmallSquareInsideRectangle.bottomStrip
    SmallSquareInsideRectangle.leftStrip
    SmallSquareInsideRectangle.rightStrip
    SmallSquareInsideRectangle.toRectangle
  unfold hEdge vEdge at h_sym
  linear_combination h_sym

/-- The existing unit-kernel sum identity, now unconditional. -/
noncomputable def fourStripBoundarySumIdentity
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripBoundarySumIdentity S :=
  (fourStripCoordinateBoundarySumIdentity S).toBoundarySumIdentity

/-- Unconditional unit-kernel rectangle-to-square deformation. -/
noncomputable def unitKernelRectangleToSquareDeformation
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    R.UnitKernelRectangleToSquareDeformation a S :=
  unitKernelRectangleToSquareDeformation_of_coordinateIdentity
    (fourStripCoordinateBoundarySumIdentity S)

/-! ## BK: Square-from-circle construction + canonical inner target -/

/-! ### BK1: quarter-radius square sits inside the closed ball -/

/-- Geometry: if `|z.re - a.re| тЙд r/4` and `|z.im - a.im| тЙд r/4`, then
`z тИИ closedBall a r`.  Uses the triangle inequality
`тАЦz - aтАЦ тЙд |(z-a).re| + |(z-a).im|`. -/
theorem square_subset_closedBall_of_radius_quarter
    (a z : тДВ) {r : тДЭ}
    (hz : |z.re - a.re| тЙд r / 4 тИз |z.im - a.im| тЙд r / 4) :
    z тИИ Metric.closedBall a r := by
  obtain тЯиhx, hyтЯй := hz
  rw [Metric.mem_closedBall, dist_eq_norm]
  have h_bound : тАЦz - aтАЦ тЙд |(z - a).re| + |(z - a).im| :=
    Complex.norm_le_abs_re_add_abs_im (z - a)
  have h_re : (z - a).re = z.re - a.re := Complex.sub_re z a
  have h_im : (z - a).im = z.im - a.im := Complex.sub_im z a
  rw [h_re, h_im] at h_bound
  have h_re_nn : 0 тЙд |z.re - a.re| := abs_nonneg _
  have h_im_nn : 0 тЙд |z.im - a.im| := abs_nonneg _
  linarith

/-! ### BK2: small square from a small circle (radius `r/4`) -/

/-- Given a small circle of radius `r` inside the rectangle, build a small
square of side `r/4` also inside the rectangle.  The square lies inside the
closed ball of radius `r` (by BK1), which is inside the open rectangle. -/
noncomputable def SmallCircleInsideRectangle.toSmallSquare
    {R : ZetaRectangle} {a : тДВ}
    (C : R.SmallCircleInsideRectangle a) :
    R.SmallSquareInsideRectangle a where
  r := C.r / 4
  r_pos := by
    have := C.r_pos
    positivity
  square_subset_open := by
    intro z hz
    apply C.closedBall_subset_open
    exact square_subset_closedBall_of_radius_quarter a z hz

/-! ### BK3: canonical squareтЖТcircle deformation target -/

/-- Square-to-circle deformation specialized to the canonical square chosen
inside the circle.  This is the analytic obligation that closes the
unit-kernel punctured-CG chain. -/
structure UnitKernelCanonicalSquareToCircleDeformation
    (R : ZetaRectangle) (a : тДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  square_eq_circle :
    R.smallSquareUnitKernelIntegral C.toSmallSquare =
      unitKernelCircleIntegral a C.r

/-- Canonical-square deformation gives the general square-to-circle target
at the canonical square. -/
noncomputable def UnitKernelCanonicalSquareToCircleDeformation.toSquareToCircle
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.UnitKernelCanonicalSquareToCircleDeformation a C) :
    R.UnitKernelSquareToCircleDeformation a C.toSmallSquare C where
  square_eq_circle := H.square_eq_circle

/-! ### BK4: punctured CG from the canonical-square target -/

/-- Combine the unconditional rectangle-to-square deformation with the
canonical-square-to-circle deformation to obtain the punctured-rectangle
Cauchy-Goursat theorem. -/
noncomputable def PuncturedRectangleCauchyGoursat.of_canonicalSquareToCircle
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.UnitKernelCanonicalSquareToCircleDeformation a C) :
    R.PuncturedRectangleCauchyGoursat a C :=
  PuncturedRectangleCauchyGoursat.of_square_deformations
    (unitKernelRectangleToSquareDeformation C.toSmallSquare)
    H.toSquareToCircle

/-! ## BM: Centered-square reduction for the canonical-square obligation -/

/-! ### BM1: centered-square unit-kernel integral -/

/-- The unit-kernel integral around the axis-aligned square centered at the
origin with half-side `╧Б`.  Translation-invariance reduces the canonical
square integral to this concrete `╧Б`-parametrized one. -/
noncomputable def centeredSquareUnitKernelIntegral (╧Б : тДЭ) : тДВ :=
  (тИл x in (-╧Б)..╧Б, (1 : тДВ) / ((x : тДВ) - (╧Б : тДВ) * Complex.I))
    + (тИл y in (-╧Б)..╧Б, (1 : тДВ) / ((╧Б : тДВ) + (y : тДВ) * Complex.I)) * Complex.I
    + (тИл x in ╧Б..(-╧Б), (1 : тДВ) / ((x : тДВ) + (╧Б : тДВ) * Complex.I))
    + (тИл y in ╧Б..(-╧Б), (1 : тДВ) / (-(╧Б : тДВ) + (y : тДВ) * Complex.I)) * Complex.I

/-! ### BM2: target тАФ canonical square equals centered square (translation invariance) -/

/-- Translation-invariance target: the unit-kernel integral around the
canonical square centered at `a` equals the same integral around the
centered square of equal half-side.  Pure affine change-of-variable. -/
structure CanonicalSquareEqualsCenteredSquare
    (R : ZetaRectangle) (a : тДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  canonical_eq_centered :
    R.smallSquareUnitKernelIntegral C.toSmallSquare =
      centeredSquareUnitKernelIntegral C.toSmallSquare.r

/-! ### BM3: target тАФ centered square integral equals `2╧Аi` -/

/-- Centered-square integral target: for any positive half-side, the
unit-kernel integral around the centered square equals `twoPiI`.  Provable
by four real arctan computations (one per edge, each evaluating to `i╧А/2`). -/
structure CenteredSquareEqualsTwoPiI : Prop where
  eq_twoPiI :
    тИА {╧Б : тДЭ}, 0 < ╧Б тЖТ
      centeredSquareUnitKernelIntegral ╧Б = twoPiI

/-! ### BM4: combine BM2 + BM3 into the canonical squareтЖТcircle deformation -/

/-- Translation invariance + centered-square evaluation discharges the
canonical squareтЖТcircle target. -/
noncomputable def UnitKernelCanonicalSquareToCircleDeformation.of_centered_reduction
    (HCent : CenteredSquareEqualsTwoPiI)
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (HTrans : CanonicalSquareEqualsCenteredSquare R a C) :
    R.UnitKernelCanonicalSquareToCircleDeformation a C where
  square_eq_circle := by
    rw [HTrans.canonical_eq_centered]
    rw [HCent.eq_twoPiI C.toSmallSquare.r_pos]
    exact (unitKernelCircleIntegral_eq_twoPiI a C.r_pos).symm

/-! ## BN: Translation invariance тАФ `canonicalSquareEqualsCenteredSquare` -/

/-- Per-edge bottom integrand identity: shifting the integration coordinate
by `a.re` reduces the canonical bottom integrand to the centered-square form. -/
theorem canonicalSquare_bottom_eq_centered
    (a : тДВ) (╧Б : тДЭ) :
    (тИл X in (a.re - ╧Б)..(a.re + ╧Б),
      unitPrincipalKernel a тЯиX, a.im - ╧БтЯй) =
      тИл x in (-╧Б)..╧Б, (1 : тДВ) / ((x : тДВ) - (╧Б : тДВ) * Complex.I) := by
  rw [show (a.re - ╧Б : тДЭ) = a.re + (-╧Б) from by ring,
      show (a.re + ╧Б : тДЭ) = a.re + ╧Б from rfl,
      тЖР intervalIntegral.integral_comp_add_left]
  apply intervalIntegral.integral_congr
  intro x _
  show unitPrincipalKernel a тЯиa.re + x, a.im - ╧БтЯй =
       (1 : тДВ) / ((x : тДВ) - (╧Б : тДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (тЯиa.re + x, a.im - ╧БтЯй : тДВ) - a =
                 (x : тДВ) - (╧Б : тДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_top_eq_centered
    (a : тДВ) (╧Б : тДЭ) :
    (тИл X in (a.re + ╧Б)..(a.re - ╧Б),
      unitPrincipalKernel a тЯиX, a.im + ╧БтЯй) =
      тИл x in ╧Б..(-╧Б), (1 : тДВ) / ((x : тДВ) + (╧Б : тДВ) * Complex.I) := by
  rw [show (a.re - ╧Б : тДЭ) = a.re + (-╧Б) from by ring,
      show (a.re + ╧Б : тДЭ) = a.re + ╧Б from rfl,
      тЖР intervalIntegral.integral_comp_add_left]
  apply intervalIntegral.integral_congr
  intro x _
  show unitPrincipalKernel a тЯиa.re + x, a.im + ╧БтЯй =
       (1 : тДВ) / ((x : тДВ) + (╧Б : тДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (тЯиa.re + x, a.im + ╧БтЯй : тДВ) - a =
                 (x : тДВ) + (╧Б : тДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_right_eq_centered
    (a : тДВ) (╧Б : тДЭ) :
    (тИл Y in (a.im - ╧Б)..(a.im + ╧Б),
      unitPrincipalKernel a тЯиa.re + ╧Б, YтЯй * Complex.I) =
      (тИл y in (-╧Б)..╧Б, (1 : тДВ) / ((╧Б : тДВ) + (y : тДВ) * Complex.I)) *
        Complex.I := by
  rw [show (a.im - ╧Б : тДЭ) = a.im + (-╧Б) from by ring,
      show (a.im + ╧Б : тДЭ) = a.im + ╧Б from rfl,
      тЖР intervalIntegral.integral_comp_add_left]
  rw [intervalIntegral.integral_mul_const]
  apply congrArg (┬╖ * Complex.I)
  apply intervalIntegral.integral_congr
  intro y _
  show unitPrincipalKernel a тЯиa.re + ╧Б, a.im + yтЯй =
       (1 : тДВ) / ((╧Б : тДВ) + (y : тДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (тЯиa.re + ╧Б, a.im + yтЯй : тДВ) - a =
                 (╧Б : тДВ) + (y : тДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

theorem canonicalSquare_left_eq_centered
    (a : тДВ) (╧Б : тДЭ) :
    (тИл Y in (a.im + ╧Б)..(a.im - ╧Б),
      unitPrincipalKernel a тЯиa.re - ╧Б, YтЯй * Complex.I) =
      (тИл y in ╧Б..(-╧Б), (1 : тДВ) / (-(╧Б : тДВ) + (y : тДВ) * Complex.I)) *
        Complex.I := by
  rw [show (a.im - ╧Б : тДЭ) = a.im + (-╧Б) from by ring,
      show (a.im + ╧Б : тДЭ) = a.im + ╧Б from rfl,
      тЖР intervalIntegral.integral_comp_add_left]
  rw [intervalIntegral.integral_mul_const]
  apply congrArg (┬╖ * Complex.I)
  apply intervalIntegral.integral_congr
  intro y _
  show unitPrincipalKernel a тЯиa.re - ╧Б, a.im + yтЯй =
       (1 : тДВ) / (-(╧Б : тДВ) + (y : тДВ) * Complex.I)
  unfold unitPrincipalKernel
  have h_inner : (тЯиa.re - ╧Б, a.im + yтЯй : тДВ) - a =
                 -(╧Б : тДВ) + (y : тДВ) * Complex.I := by
    apply Complex.ext <;> simp
  rw [h_inner]

/-- Translation invariance: the unit-kernel integral around the canonical
square centered at `a` equals the centered-square integral of the same
half-side. -/
theorem canonicalSquareEqualsCenteredSquare
    {R : ZetaRectangle} {a : тДВ}
    (C : R.SmallCircleInsideRectangle a) :
    CanonicalSquareEqualsCenteredSquare R a C := by
  refine тЯи?_тЯй
  set ╧Б := C.toSmallSquare.r
  unfold smallSquareUnitKernelIntegral
  rw [тЖР rectangleIntegral_unitPrincipalKernel_eq]
  rw [rectangleIntegral_eq_coordinateBoundaryIntegral
        (rectangleEdgeIntegralCoordinateBridge _ _)]
  unfold coordinateBoundaryIntegral
  unfold bottomHorizontalIntegral rightVerticalIntegral
    topHorizontalIntegral leftVerticalIntegral
  unfold SmallSquareInsideRectangle.toRectangle
  unfold centeredSquareUnitKernelIntegral
  rw [canonicalSquare_bottom_eq_centered a ╧Б]
  rw [canonicalSquare_right_eq_centered a ╧Б]
  rw [canonicalSquare_top_eq_centered a ╧Б]
  rw [canonicalSquare_left_eq_centered a ╧Б]

/-! ## BO1: arctan FTC for the centered-square edge integrals -/

/-- `тИл x in -╧Б..╧Б, ╧Б/(x┬▓ + ╧Б┬▓) = ╧А/2`.  This is the core scalar
real integral underlying the centered-square edge evaluations.  The
primitive is `arctan(x/╧Б)`; endpoints give `arctan(1) - arctan(-1) = ╧А/2`. -/
theorem integral_rho_div_sq_add_sq
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл x in (-╧Б)..╧Б, ╧Б / (x ^ 2 + ╧Б ^ 2)) = Real.pi / 2 := by
  have h╧Б_ne : ╧Б тЙа 0 := ne_of_gt h╧Б
  -- Continuity / integrability.
  have h_cont : Continuous (fun x : тДЭ => ╧Б / (x ^ 2 + ╧Б ^ 2)) := by
    refine Continuous.div continuous_const ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x
      have h1 : (0 : тДЭ) тЙд x ^ 2 := sq_nonneg x
      have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
      linarith
  have h_int : IntervalIntegrable
      (fun x : тДЭ => ╧Б / (x ^ 2 + ╧Б ^ 2)) MeasureTheory.volume (-╧Б) ╧Б :=
    h_cont.intervalIntegrable _ _
  -- Chain rule: deriv of `fun y => arctan (y/╧Б)` is `╧Б/(x┬▓+╧Б┬▓)`.
  have h_deriv : тИА x тИИ Set.uIcc (-╧Б) ╧Б,
      HasDerivAt (fun y : тДЭ => Real.arctan (y / ╧Б))
        (╧Б / (x ^ 2 + ╧Б ^ 2)) x := by
    intro x _
    have h_arctan : HasDerivAt Real.arctan (1 / (1 + (x / ╧Б) ^ 2)) (x / ╧Б) :=
      Real.hasDerivAt_arctan _
    have h_div : HasDerivAt (fun y : тДЭ => y / ╧Б) (1 / ╧Б) x := by
      simpa using (hasDerivAt_id x).div_const ╧Б
    have h_comp := h_arctan.comp x h_div
    convert h_comp using 1
    field_simp
    ring
  -- FTC + endpoint arctan values.
  have hFTC := intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int
  rw [hFTC]
  have h╧Б╧Б : ╧Б / ╧Б = 1 := div_self h╧Б_ne
  have hn╧Б╧Б : (-╧Б) / ╧Б = -1 := by rw [neg_div, h╧Б╧Б]
  rw [h╧Б╧Б, hn╧Б╧Б, Real.arctan_one, Real.arctan_neg, Real.arctan_one]
  ring

/-! ## BO1.5: Odd integrand `x/(x┬▓+╧Б┬▓)` vanishes on `[-╧Б, ╧Б]` -/

/-- `тИл x in -╧Б..╧Б, x/(x┬▓ + ╧Б┬▓) = 0`.  The antiderivative `(1/2) log(x┬▓ + ╧Б┬▓)`
is even in `x`, so its values at `╧Б` and `-╧Б` agree. -/
theorem integral_x_div_sq_add_sq_symm
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл x in (-╧Б)..╧Б, x / (x ^ 2 + ╧Б ^ 2)) = 0 := by
  have h_pos : тИА x : тДЭ, (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := fun x => by
    have h1 : (0 : тДЭ) тЙд x ^ 2 := sq_nonneg x
    have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
    linarith
  have h_cont : Continuous (fun x : тДЭ => x / (x ^ 2 + ╧Б ^ 2)) := by
    refine Continuous.div continuous_id ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x; exact ne_of_gt (h_pos x)
  have h_int : IntervalIntegrable
      (fun x : тДЭ => x / (x ^ 2 + ╧Б ^ 2)) MeasureTheory.volume (-╧Б) ╧Б :=
    h_cont.intervalIntegrable _ _
  have h_deriv : тИА x тИИ Set.uIcc (-╧Б) ╧Б,
      HasDerivAt (fun y : тДЭ => (1/2 : тДЭ) * Real.log (y ^ 2 + ╧Б ^ 2))
        (x / (x ^ 2 + ╧Б ^ 2)) x := by
    intro x _
    have hpx : (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := h_pos x
    have h_ne : (x ^ 2 + ╧Б ^ 2) тЙа 0 := ne_of_gt hpx
    have h_sq : HasDerivAt (fun y : тДЭ => y ^ 2 + ╧Б ^ 2) (2 * x) x := by
      simpa using (hasDerivAt_pow 2 x).add_const (╧Б ^ 2)
    have h_log : HasDerivAt (fun y : тДЭ => Real.log (y ^ 2 + ╧Б ^ 2))
        ((2 * x) / (x ^ 2 + ╧Б ^ 2)) x := h_sq.log h_ne
    have h_half := h_log.const_mul (1/2 : тДЭ)
    convert h_half using 1
    field_simp
  have hFTC := intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int
  rw [hFTC]
  have h_eq : ((-╧Б : тДЭ)) ^ 2 + ╧Б ^ 2 = ╧Б ^ 2 + ╧Б ^ 2 := by ring
  rw [h_eq]
  ring

/-! ## BO2: Centered-square edge integrals -/

/-- Bottom edge: `тИл x in -╧Б..╧Б, 1/(x - i╧Б) = (╧А/2) * I`. -/
theorem centeredSquare_bottom_eq_pi_over_two_I
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл x in (-╧Б)..╧Б, (1 : тДВ) / ((x : тДВ) - (╧Б : тДВ) * Complex.I))
      = (Real.pi / 2 : тДВ) * Complex.I := by
  have h_pos : тИА x : тДЭ, (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := fun x => by
    have h1 : (0 : тДЭ) тЙд x ^ 2 := sq_nonneg x
    have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
    linarith
  have h_ptwise : тИА x : тДЭ,
      (1 : тДВ) / ((x : тДВ) - (╧Б : тДВ) * Complex.I) =
        ((x / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ)
          + ((╧Б / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ) * Complex.I := by
    intro x
    have hpx_pos : (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := h_pos x
    have hpx_ne : (x ^ 2 + ╧Б ^ 2 : тДЭ) тЙа 0 := ne_of_gt hpx_pos
    have h_denom : ((x : тДВ) - (╧Б : тДВ) * Complex.I) тЙа 0 := by
      intro h
      have h_im_z : ((x : тДВ) - (╧Б : тДВ) * Complex.I).im = 0 := by rw [h]; rfl
      simp at h_im_z
      linarith
    have h_sum_C_ne : ((x : тДВ) ^ 2 + (╧Б : тДВ) ^ 2) тЙа 0 := by
      have h : ((x : тДВ) ^ 2 + (╧Б : тДВ) ^ 2) = ((x ^ 2 + ╧Б ^ 2 : тДЭ) : тДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpx_ne
    have hI : (Complex.I : тДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((╧Б : тДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun x _ => h_ptwise x)]
  have h_cont1 : Continuous (fun x : тДЭ => ((x / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x; exact ne_of_gt (h_pos x)
  have h_cont2 : Continuous
      (fun x : тДЭ => ((╧Б / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x; exact ne_of_gt (h_pos x)
  have h_int1 := h_cont1.intervalIntegrable (╬╝ := MeasureTheory.volume) (-╧Б) ╧Б
  have h_int2 := h_cont2.intervalIntegrable (╬╝ := MeasureTheory.volume) (-╧Б) ╧Б
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  rw [integral_x_div_sq_add_sq_symm h╧Б, integral_rho_div_sq_add_sq h╧Б]
  push_cast
  ring

/-- Right edge: `(тИл y in -╧Б..╧Б, 1/(╧Б + iy)) ┬╖ I = (╧А/2) ┬╖ I`. -/
theorem centeredSquare_right_eq_pi_over_two_I
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл y in (-╧Б)..╧Б, (1 : тДВ) / ((╧Б : тДВ) + (y : тДВ) * Complex.I)) * Complex.I
      = (Real.pi / 2 : тДВ) * Complex.I := by
  have h_pos : тИА y : тДЭ, (0 : тДЭ) < ╧Б ^ 2 + y ^ 2 := fun y => by
    have h1 : (0 : тДЭ) тЙд y ^ 2 := sq_nonneg y
    have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
    linarith
  have h_ptwise : тИА y : тДЭ,
      (1 : тДВ) / ((╧Б : тДВ) + (y : тДВ) * Complex.I) =
        ((╧Б / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ)
          + ((-y / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ) * Complex.I := by
    intro y
    have hpy_pos : (0 : тДЭ) < ╧Б ^ 2 + y ^ 2 := h_pos y
    have hpy_ne : (╧Б ^ 2 + y ^ 2 : тДЭ) тЙа 0 := ne_of_gt hpy_pos
    have h_denom : ((╧Б : тДВ) + (y : тДВ) * Complex.I) тЙа 0 := by
      intro h
      have h_re_z : ((╧Б : тДВ) + (y : тДВ) * Complex.I).re = 0 := by rw [h]; rfl
      simp at h_re_z
      linarith
    have h_sum_C_ne : ((╧Б : тДВ) ^ 2 + (y : тДВ) ^ 2) тЙа 0 := by
      have h : ((╧Б : тДВ) ^ 2 + (y : тДВ) ^ 2) = ((╧Б ^ 2 + y ^ 2 : тДЭ) : тДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpy_ne
    have hI : (Complex.I : тДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((y : тДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun y _ => h_ptwise y)]
  have h_cont1 : Continuous (fun y : тДЭ => ((╧Б / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ┬╖ exact continuous_const.add (continuous_pow 2)
    ┬╖ intro y; exact ne_of_gt (h_pos y)
  have h_cont2 : Continuous
      (fun y : тДЭ => ((-y / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id.neg ?_ ?_
    ┬╖ exact continuous_const.add (continuous_pow 2)
    ┬╖ intro y; exact ne_of_gt (h_pos y)
  have h_int1 := h_cont1.intervalIntegrable (╬╝ := MeasureTheory.volume) (-╧Б) ╧Б
  have h_int2 := h_cont2.intervalIntegrable (╬╝ := MeasureTheory.volume) (-╧Б) ╧Б
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (тИл y in (-╧Б)..╧Б, ╧Б / (╧Б ^ 2 + y ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun y : тДЭ => ╧Б / (╧Б ^ 2 + y ^ 2))
              = (fun y : тДЭ => ╧Б / (y ^ 2 + ╧Б ^ 2)) := by
      funext y; ring
    rw [h_eq]
    exact integral_rho_div_sq_add_sq h╧Б
  have h_im : (тИл y in (-╧Б)..╧Б, -y / (╧Б ^ 2 + y ^ 2)) = 0 := by
    have h_eq : (fun y : тДЭ => -y / (╧Б ^ 2 + y ^ 2))
              = (fun y : тДЭ => -(y / (y ^ 2 + ╧Б ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg]
    rw [integral_x_div_sq_add_sq_symm h╧Б]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-- Top edge: `тИл x in ╧Б..(-╧Б), 1/(x + i╧Б) = (╧А/2) ┬╖ I`. -/
theorem centeredSquare_top_eq_pi_over_two_I
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл x in ╧Б..(-╧Б), (1 : тДВ) / ((x : тДВ) + (╧Б : тДВ) * Complex.I))
      = (Real.pi / 2 : тДВ) * Complex.I := by
  have h_pos : тИА x : тДЭ, (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := fun x => by
    have h1 : (0 : тДЭ) тЙд x ^ 2 := sq_nonneg x
    have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
    linarith
  have h_ptwise : тИА x : тДЭ,
      (1 : тДВ) / ((x : тДВ) + (╧Б : тДВ) * Complex.I) =
        ((x / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ)
          + ((-╧Б / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ) * Complex.I := by
    intro x
    have hpx_pos : (0 : тДЭ) < x ^ 2 + ╧Б ^ 2 := h_pos x
    have hpx_ne : (x ^ 2 + ╧Б ^ 2 : тДЭ) тЙа 0 := ne_of_gt hpx_pos
    have h_denom : ((x : тДВ) + (╧Б : тДВ) * Complex.I) тЙа 0 := by
      intro h
      have h_im_z : ((x : тДВ) + (╧Б : тДВ) * Complex.I).im = 0 := by rw [h]; rfl
      simp at h_im_z
      linarith
    have h_sum_C_ne : ((x : тДВ) ^ 2 + (╧Б : тДВ) ^ 2) тЙа 0 := by
      have h : ((x : тДВ) ^ 2 + (╧Б : тДВ) ^ 2) = ((x ^ 2 + ╧Б ^ 2 : тДЭ) : тДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpx_ne
    have hI : (Complex.I : тДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((╧Б : тДВ) ^ 2) * hI
  rw [intervalIntegral.integral_congr (fun x _ => h_ptwise x)]
  have h_cont1 : Continuous (fun x : тДЭ => ((x / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x; exact ne_of_gt (h_pos x)
  have h_cont2 : Continuous
      (fun x : тДЭ => ((-╧Б / (x ^ 2 + ╧Б ^ 2) : тДЭ) : тДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ┬╖ exact (continuous_pow 2).add continuous_const
    ┬╖ intro x; exact ne_of_gt (h_pos x)
  have h_int1 := h_cont1.intervalIntegrable (╬╝ := MeasureTheory.volume) ╧Б (-╧Б)
  have h_int2 := h_cont2.intervalIntegrable (╬╝ := MeasureTheory.volume) ╧Б (-╧Б)
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (тИл x in ╧Б..(-╧Б), x / (x ^ 2 + ╧Б ^ 2)) = 0 := by
    rw [intervalIntegral.integral_symm, integral_x_div_sq_add_sq_symm h╧Б]
    ring
  have h_im : (тИл x in ╧Б..(-╧Б), -╧Б / (x ^ 2 + ╧Б ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun x : тДЭ => -╧Б / (x ^ 2 + ╧Б ^ 2))
              = (fun x : тДЭ => -(╧Б / (x ^ 2 + ╧Б ^ 2))) := by
      funext x; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_rho_div_sq_add_sq h╧Б]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-- Left edge: `(тИл y in ╧Б..(-╧Б), 1/(-╧Б + iy)) ┬╖ I = (╧А/2) ┬╖ I`. -/
theorem centeredSquare_left_eq_pi_over_two_I
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    (тИл y in ╧Б..(-╧Б), (1 : тДВ) / (-(╧Б : тДВ) + (y : тДВ) * Complex.I)) * Complex.I
      = (Real.pi / 2 : тДВ) * Complex.I := by
  have h_pos : тИА y : тДЭ, (0 : тДЭ) < ╧Б ^ 2 + y ^ 2 := fun y => by
    have h1 : (0 : тДЭ) тЙд y ^ 2 := sq_nonneg y
    have h2 : (0 : тДЭ) < ╧Б ^ 2 := by positivity
    linarith
  have h_ptwise : тИА y : тДЭ,
      (1 : тДВ) / (-(╧Б : тДВ) + (y : тДВ) * Complex.I) =
        ((-╧Б / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ)
          + ((-y / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ) * Complex.I := by
    intro y
    have hpy_pos : (0 : тДЭ) < ╧Б ^ 2 + y ^ 2 := h_pos y
    have hpy_ne : (╧Б ^ 2 + y ^ 2 : тДЭ) тЙа 0 := ne_of_gt hpy_pos
    have h_denom : (-(╧Б : тДВ) + (y : тДВ) * Complex.I) тЙа 0 := by
      intro h
      have h_re_z : (-(╧Б : тДВ) + (y : тДВ) * Complex.I).re = 0 := by rw [h]; rfl
      simp at h_re_z
      linarith
    have h_sum_C_ne : ((╧Б : тДВ) ^ 2 + (y : тДВ) ^ 2) тЙа 0 := by
      have h : ((╧Б : тДВ) ^ 2 + (y : тДВ) ^ 2) = ((╧Б ^ 2 + y ^ 2 : тДЭ) : тДВ) := by
        push_cast; ring
      rw [h]
      exact Complex.ofReal_ne_zero.mpr hpy_ne
    have hI : (Complex.I : тДВ) ^ 2 = -1 := Complex.I_sq
    push_cast
    field_simp
    linear_combination ((y : тДВ) ^ 2 * ((╧Б : тДВ) ^ 2 + (y : тДВ) ^ 2)) * hI
  rw [intervalIntegral.integral_congr (fun y _ => h_ptwise y)]
  have h_cont1 : Continuous (fun y : тДЭ => ((-╧Б / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ)) := by
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_const ?_ ?_
    ┬╖ exact continuous_const.add (continuous_pow 2)
    ┬╖ intro y; exact ne_of_gt (h_pos y)
  have h_cont2 : Continuous
      (fun y : тДЭ => ((-y / (╧Б ^ 2 + y ^ 2) : тДЭ) : тДВ) * Complex.I) := by
    refine Continuous.mul ?_ continuous_const
    refine Complex.continuous_ofReal.comp ?_
    refine Continuous.div continuous_id.neg ?_ ?_
    ┬╖ exact continuous_const.add (continuous_pow 2)
    ┬╖ intro y; exact ne_of_gt (h_pos y)
  have h_int1 := h_cont1.intervalIntegrable (╬╝ := MeasureTheory.volume) ╧Б (-╧Б)
  have h_int2 := h_cont2.intervalIntegrable (╬╝ := MeasureTheory.volume) ╧Б (-╧Б)
  rw [intervalIntegral.integral_add h_int1 h_int2]
  rw [intervalIntegral.integral_mul_const]
  rw [intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal]
  have h_re : (тИл y in ╧Б..(-╧Б), -╧Б / (╧Б ^ 2 + y ^ 2)) = Real.pi / 2 := by
    have h_eq : (fun y : тДЭ => -╧Б / (╧Б ^ 2 + y ^ 2))
              = (fun y : тДЭ => -(╧Б / (y ^ 2 + ╧Б ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_rho_div_sq_add_sq h╧Б]
    ring
  have h_im : (тИл y in ╧Б..(-╧Б), -y / (╧Б ^ 2 + y ^ 2)) = 0 := by
    have h_eq : (fun y : тДЭ => -y / (╧Б ^ 2 + y ^ 2))
              = (fun y : тДЭ => -(y / (y ^ 2 + ╧Б ^ 2))) := by
      funext y; ring
    rw [h_eq]
    rw [intervalIntegral.integral_neg, intervalIntegral.integral_symm,
        integral_x_div_sq_add_sq_symm h╧Б]
    ring
  rw [h_re, h_im]
  push_cast
  ring

/-! ## BO4: Assemble the centered-square integral -/

/-- The unit-kernel integral around the centered square of half-side `╧Б > 0`
equals `2╧Аi`.  Each of the four edge integrals contributes `(╧А/2)┬╖I`. -/
theorem centeredSquareUnitKernelIntegral_eq_twoPiI
    {╧Б : тДЭ} (h╧Б : 0 < ╧Б) :
    centeredSquareUnitKernelIntegral ╧Б = twoPiI := by
  unfold centeredSquareUnitKernelIntegral twoPiI
  rw [centeredSquare_bottom_eq_pi_over_two_I h╧Б,
      centeredSquare_right_eq_pi_over_two_I h╧Б,
      centeredSquare_top_eq_pi_over_two_I h╧Б,
      centeredSquare_left_eq_pi_over_two_I h╧Б]
  ring

/-- **BO5 тАФ INHABITED:** the `CenteredSquareEqualsTwoPiI` Prop. -/
noncomputable def centeredSquareEqualsTwoPiI : CenteredSquareEqualsTwoPiI where
  eq_twoPiI := centeredSquareUnitKernelIntegral_eq_twoPiI

/-! ## AT: Residue-free argument-principle assembly -/

/-! ### AT1: unit-kernel theorem wrapper -/

/-- Convenience wrapper: punctured Cauchy-Goursat for a chosen small circle
gives the unit principal-kernel theorem. -/
noncomputable def unitPrincipalKernelIntegralTheorem_of_puncturedCG
    {R : ZetaRectangle} {a : тДВ}
    (C : R.SmallCircleInsideRectangle a)
    (HCG : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitPrincipalKernelIntegralTheorem a :=
  UnitPrincipalKernelIntegralTheorem.of_puncturedCauchyGoursat HCG

/-! ### AT2: general-coefficient kernel theorem via punctured CG -/

/-- Punctured Cauchy-Goursat for the unit kernel propagates through AQ4
linearity to give the normalized principal-kernel theorem at any integer
coefficient. -/
noncomputable def principalKernelIntegralTheorem_of_puncturedCG
    {R : ZetaRectangle} {a : тДВ} (k : тДд)
    (C : R.SmallCircleInsideRectangle a)
    (HCG : R.PuncturedRectangleCauchyGoursat a C) :
    R.PrincipalKernelIntegralTheorem k a :=
  (R.unitPrincipalKernelIntegralTheorem_of_puncturedCG C HCG).toNormalizedAtCoeff k

/-! ### AT3: per-singularity Cauchy-index data -/

/-- For each counted singularity of a rectangle principal-part package, a
small circle witness and a punctured Cauchy-Goursat theorem. -/
structure RectangleKernelIndexData
    (R : ZetaRectangle)
    (P : R.RectanglePrincipalPartData) where
  smallCircle :
    тИА s : тДВ, s тИИ P.singularities тЖТ R.SmallCircleInsideRectangle s
  puncturedCG :
    тИА s : тДВ, (hs : s тИИ P.singularities) тЖТ
      R.PuncturedRectangleCauchyGoursat s (smallCircle s hs)

/-! ### AT4: kernel contributions from Cauchy-index data -/

/-- Bundled per-singularity Cauchy-index data gives the normalized
principal-kernel contribution `= coefficient` for every singularity. -/
theorem RectangleKernelIndexData.kernelContribution
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (K : R.RectangleKernelIndexData P) :
    тИА s : тДВ, s тИИ P.singularities тЖТ
      R.normalizedPrincipalKernelRectangleIntegral
        (P.principalCoeff s) s =
      (P.principalCoeff s : тДВ) := fun s hs =>
  (R.principalKernelIntegralTheorem_of_puncturedCG
      (P.principalCoeff s) (K.smallCircle s hs) (K.puncturedCG s hs)
    ).normalized_integral_eq_coeff

/-! ### AT5: decomposition + kernel index тЗТ integral theorem -/

/-- A contour decomposition plus per-singularity Cauchy-index data assembles
into the residue-free rectangle argument-principle integral theorem. -/
noncomputable def RectanglePrincipalPartContourDecomposition.toIntegralTheorem_of_kernelData
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (D : R.RectanglePrincipalPartContourDecomposition P)
    (K : R.RectangleKernelIndexData P) :
    R.RectanglePrincipalPartIntegralTheorem :=
  D.toIntegralTheorem K.kernelContribution

/-! ### AT6: canonical residue-free argument-principle data -/

/-- Two-piece package for canonical zeta data: per-singularity Cauchy-index
data plus the contour decomposition.  These are the two remaining global
contour facts needed for the full residue-free argument principle. -/
structure CanonicalResidueFreeArgumentPrincipleData
    (R : ZetaRectangle)
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) where
  kernelIndex :
    R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z)
  decomposition :
    R.RectanglePrincipalPartContourDecomposition
      (R.countedPrincipalPartData hAdm Z)

/-! ### AT7: canonical data тЗТ canonical integral theorem -/

/-- Canonical residue-free argument-principle data inhabits the canonical
rectangle principal-part integral theorem. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toPrincipalPartIntegralTheorem
    {R : ZetaRectangle}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z) :
    R.RectanglePrincipalPartIntegralTheorem :=
  D.decomposition.toIntegralTheorem_of_kernelData D.kernelIndex

/-! ### BT4: canonical residue-free package from kernel index + remainder analyticity -/

/-- **BT4:** for canonical principal-part data, kernel index data plus
analytic-remainder data (BT2) inhabits the canonical residue-free
argument-principle package. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_remainderAnalytic
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta} {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (A : R.RectangleLogDerivRemainderAnalyticData
            (R.countedPrincipalPartData hAdm Z)) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z where
  kernelIndex := K
  decomposition := A.toPrincipalPartContourDecomposition

/-! ## BU: Analyticity of the log-derivative remainder -/

/-! ### BU1: expected-coefficient analytic principal-part wrapper -/

/-- At `s`, `╬╢'/╬╢` has the expected integer principal part with analytic
remainder (the analytic-strength counterpart of the continuous-remainder
field stored in `RectanglePrincipalPartData`). -/
def ZetaHasExpectedAnalyticPrincipalPart (s : тДВ) : Prop :=
  HasLogDerivIntegerPrincipalPart riemannZeta s (zetaLogDerivPrincipalCoeff s)

/-! ### BU4: analyticity of each piece away from counted singularities -/

/-- The principal kernel `k/(z тИТ s)` is analytic at every point `z тЙа s`. -/
theorem analyticAt_principalKernel_of_ne
    {k : тДд} {s z : тДВ} (hz : z тЙа s) :
    AnalyticAt тДВ (fun w : тДВ => principalKernel k s w) z := by
  unfold principalKernel
  refine analyticAt_const.div (analyticAt_id.sub analyticAt_const) ?_
  simpa [sub_eq_zero] using hz

/-- `╬╢'/╬╢` is analytic at every point off the pole `1` and off zeros. -/
theorem analyticAt_zetaLogDeriv_of_not_zero_not_one
    {z : тДВ} (hz1 : z тЙа 1) (hz0 : riemannZeta z тЙа 0) :
    AnalyticAt тДВ zetaLogDeriv z := by
  unfold zetaLogDeriv
  have h╬╢ : AnalyticAt тДВ riemannZeta z := riemannZeta_analyticAt_of_ne_one hz1
  exact h╬╢.deriv.div h╬╢ hz0

/-- The principal-part sum is analytic at every point not in the
singularity set. -/
theorem analyticAt_principalPartSum_of_not_mem
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {z : тДВ}
    (hz : z тИЙ P.singularities) :
    AnalyticAt тДВ (R.principalPartSum P) z := by
  unfold principalPartSum
  refine Finset.analyticAt_fun_sum (c := z) P.singularities ?_
  intro s hs
  refine analyticAt_principalKernel_of_ne ?_
  intro hzs
  subst hzs
  exact hz hs

/-- The log-derivative remainder is analytic at every point that is not
a counted singularity, provided `╬╢ тЙа 0` and `z тЙа 1` there. -/
theorem analyticAt_logDerivRemainder_of_not_singular
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {z : тДВ}
    (hz_not : z тИЙ P.singularities)
    (hz1 : z тЙа 1) (hz0 : riemannZeta z тЙа 0) :
    AnalyticAt тДВ (R.logDerivRemainder P) z := by
  unfold logDerivRemainder
  exact (analyticAt_zetaLogDeriv_of_not_zero_not_one hz1 hz0).sub
    (analyticAt_principalPartSum_of_not_mem hz_not)

/-! ### BU6: analytic-remainder input package + assembler

NOTE: Lean's `1/0 = 0` convention makes `R.logDerivRemainder P` not literally
analytic at a singularity `s` (because `zetaLogDeriv s тИТ principalKernel k s s`
equals `0 тИТ 0 = 0`, whereas the analytic extension's value `g s` is generally
nonzero).  We therefore take per-singularity analyticity as an input field,
along with the off-singularity ╬╢-nonvanishing / non-pole conditions. -/

/-- Input data for analytic-remainder on the closed rectangle: ╬╢ does not
vanish and the pole is avoided at every non-counted closed-rectangle point,
and the remainder is analytic at every counted singularity. -/
structure RectangleLogDerivRemainderAnalyticInput
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  off_singularity_zeta_nonzero :
    тИА z, R.ContainsClosed z тЖТ z тИЙ P.singularities тЖТ riemannZeta z тЙа 0
  off_singularity_not_pole :
    тИА z, R.ContainsClosed z тЖТ z тИЙ P.singularities тЖТ z тЙа 1
  analytic_at_singularity :
    тИА s, s тИИ P.singularities тЖТ
      AnalyticAt тДВ (R.logDerivRemainder P) s

/-- **BU6 тАФ ASSEMBLER:** the analytic-input package discharges the BT2
analytic-remainder target by case-splitting at each closed-rectangle
point on whether it lies in the singularity set. -/
noncomputable def RectangleLogDerivRemainderAnalyticInput.toAnalyticData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderAnalyticInput P) :
    R.RectangleLogDerivRemainderAnalyticData P where
  analytic_remainder := by
    intro z hzClosed
    by_cases hzSing : z тИИ P.singularities
    ┬╖ exact I.analytic_at_singularity z hzSing
    ┬╖ exact analyticAt_logDerivRemainder_of_not_singular hzSing
        (I.off_singularity_not_pole z hzClosed hzSing)
        (I.off_singularity_zeta_nonzero z hzClosed hzSing)

/-! ## BV: Patched analytic-remainder extension (replacing raw remainder) -/

/-! ### BV1: extension data package -/

/-- Analytic extension data for the log-derivative remainder.

The raw expression `╬╢'/╬╢ тИТ ╬г principalKernel` has the right values away
from singularities, but at a singularity Lean's totalized division gives
`0` rather than the analytic-extension value.  This package supplies a
patched function `remainderExt` that agrees with the raw remainder off
singularities and is analytic on the closed rectangle. -/
structure RectangleLogDerivRemainderExtensionData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) where
  remainderExt : тДВ тЖТ тДВ
  agrees_off_singularities :
    тИА z : тДВ, z тИЙ P.singularities тЖТ
      remainderExt z = R.logDerivRemainder P z
  analytic_remainderExt :
    тИА z, R.ContainsClosed z тЖТ AnalyticAt тДВ remainderExt z

/-! ### BV2: extension and raw remainder have equal rectangle integrals -/

/-- Because the boundary avoids all counted singularities (strong
admissibility), the patched extension agrees with the raw remainder on
the boundary; hence their rectangle integrals are equal. -/
theorem rectangleIntegral_remainderExt_eq_raw
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.rectangleIntegral E.remainderExt =
      R.rectangleIntegral (R.logDerivRemainder P) := by
  unfold rectangleIntegral
  have h_eq_bottom :
      (тИл t in (0 : тДЭ)..1,
        E.remainderExt (R.bottomEdge t) * deriv R.bottomEdge t) =
      (тИл t in (0 : тДЭ)..1,
        R.logDerivRemainder P (R.bottomEdge t) * deriv R.bottomEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : тДЭ) тЙд 1)] at ht
    have hbd : R.ContainsBoundary (R.bottomEdge t) :=
      R.bottomEdge_mem_boundary ht.1 ht.2
    have hnot : R.bottomEdge t тИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.bottomEdge t) * deriv R.bottomEdge t =
      R.logDerivRemainder P (R.bottomEdge t) * deriv R.bottomEdge t
    rw [E.agrees_off_singularities (R.bottomEdge t) hnot]
  have h_eq_right :
      (тИл t in (0 : тДЭ)..1,
        E.remainderExt (R.rightEdge t) * deriv R.rightEdge t) =
      (тИл t in (0 : тДЭ)..1,
        R.logDerivRemainder P (R.rightEdge t) * deriv R.rightEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : тДЭ) тЙд 1)] at ht
    have hbd : R.ContainsBoundary (R.rightEdge t) :=
      R.rightEdge_mem_boundary ht.1 ht.2
    have hnot : R.rightEdge t тИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.rightEdge t) * deriv R.rightEdge t =
      R.logDerivRemainder P (R.rightEdge t) * deriv R.rightEdge t
    rw [E.agrees_off_singularities (R.rightEdge t) hnot]
  have h_eq_top :
      (тИл t in (0 : тДЭ)..1,
        E.remainderExt (R.topEdge t) * deriv R.topEdge t) =
      (тИл t in (0 : тДЭ)..1,
        R.logDerivRemainder P (R.topEdge t) * deriv R.topEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : тДЭ) тЙд 1)] at ht
    have hbd : R.ContainsBoundary (R.topEdge t) :=
      R.topEdge_mem_boundary ht.1 ht.2
    have hnot : R.topEdge t тИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.topEdge t) * deriv R.topEdge t =
      R.logDerivRemainder P (R.topEdge t) * deriv R.topEdge t
    rw [E.agrees_off_singularities (R.topEdge t) hnot]
  have h_eq_left :
      (тИл t in (0 : тДЭ)..1,
        E.remainderExt (R.leftEdge t) * deriv R.leftEdge t) =
      (тИл t in (0 : тДЭ)..1,
        R.logDerivRemainder P (R.leftEdge t) * deriv R.leftEdge t) := by
    apply intervalIntegral.integral_congr
    intro t ht
    rw [Set.uIcc_of_le (by norm_num : (0 : тДЭ) тЙд 1)] at ht
    have hbd : R.ContainsBoundary (R.leftEdge t) :=
      R.leftEdge_mem_boundary ht.1 ht.2
    have hnot : R.leftEdge t тИЙ P.singularities := fun hs =>
      boundary_ne_of_mem_principalPart_singularities hs hbd rfl
    show E.remainderExt (R.leftEdge t) * deriv R.leftEdge t =
      R.logDerivRemainder P (R.leftEdge t) * deriv R.leftEdge t
    rw [E.agrees_off_singularities (R.leftEdge t) hnot]
  rw [h_eq_bottom, h_eq_right, h_eq_top, h_eq_left]

/-! ### BV3: extension data тЗТ raw remainder integral vanishes -/

/-- Cauchy-Goursat applied to the patched extension, transferred to the raw
remainder integral via boundary congruence (BV2). -/
noncomputable def RectangleLogDerivRemainderExtensionData.toVanishes
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.RectangleLogDerivRemainderIntegralVanishes P where
  integral_eq_zero := by
    have hExtZero : R.rectangleIntegral E.remainderExt = 0 :=
      globalRectangleCauchyGoursatBridge.cauchyGoursat R
        E.remainderExt E.analytic_remainderExt
    have hraw := rectangleIntegral_remainderExt_eq_raw E
    rw [тЖР hraw]
    exact hExtZero

/-! ### BV4: extension data closes the contour decomposition + canonical wrapper -/

/-- Linearity (BS6) + remainder extension data (BV1+BV3) тЗТ contour
decomposition.  This is the BV-analog of BT3, but using the patched
extension (which can actually be inhabited) in place of the raw
analytic-remainder target (which cannot, due to Lean's `1/0 = 0`). -/
noncomputable def RectangleLogDerivRemainderExtensionData.toPrincipalPartContourDecomposition
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (E : R.RectangleLogDerivRemainderExtensionData P) :
    R.RectanglePrincipalPartContourDecomposition P :=
  RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    (rectangleLogDerivContourLinearDecomposition P) E.toVanishes

/-- **BV4 тАФ CANONICAL WRAPPER:** kernel-index data + remainder extension
data discharges the canonical residue-free argument-principle package. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_remainderExtension
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta} {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (E : R.RectangleLogDerivRemainderExtensionData
            (R.countedPrincipalPartData hAdm Z)) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z where
  kernelIndex := K
  decomposition := E.toPrincipalPartContourDecomposition

/-! ## BW: Patched analytic remainder from analytic local principal parts -/

/-! ### BW1: analytic local principal-part data -/

/-- Analytic local principal-part data: at every counted singularity, the
zeta log-derivative has the expected integer principal part with **analytic**
remainder (not just continuous).  This is the strengthening of
`P.localPrincipalPart` that the patched-extension construction requires. -/
structure RectangleAnalyticPrincipalPartData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  localAnalyticPrincipalPart :
    тИА s : тДВ, s тИИ P.singularities тЖТ
      HasLogDerivIntegerPrincipalPart riemannZeta s (P.principalCoeff s)

/-! ### BW2: `countedPrincipalPartData` admits analytic principal parts -/

/-- **BW2 тАФ PROVED:** the canonical counted principal-part data admits an
analytic principal-part package, via the BX3/BX5 analytic upgrades at each
nontrivial zero and at the pole. -/
theorem countedPrincipalPartData_analyticPrincipalPartData
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} :
    R.RectangleAnalyticPrincipalPartData
      (R.countedPrincipalPartData hAdm Z) where
  localAnalyticPrincipalPart := by
    intro s hs
    have hsCounted : R.IsCountedZetaSingularityInside s :=
      ((R.countedPrincipalPartData hAdm Z).singularities_complete s).mp hs
    rcases hsCounted with hsZero | hsPole
    ┬╖ have hsNT : IsNontrivialZetaZero s := hsZero.1
      show HasLogDerivIntegerPrincipalPart riemannZeta s
        (zetaLogDerivPrincipalCoeff s)
      rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
      exact zetaLogDeriv_principalPart_at_nontrivial_zero hsNT
    ┬╖ obtain тЯи_, hs_eqтЯй := hsPole
      subst hs_eq
      show HasLogDerivIntegerPrincipalPart riemannZeta (1 : тДВ)
        (zetaLogDerivPrincipalCoeff 1)
      rw [zetaLogDerivPrincipalCoeff_one]
      exact zetaLogDeriv_principalPart_at_one_unconditional

/-! ### BW3: extract the analytic remainder function and its properties -/

/-- The chosen local analytic remainder function at a singularity. -/
noncomputable def RectangleAnalyticPrincipalPartData.localAnalyticRemainder
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    (s : тДВ) (hs : s тИИ P.singularities) : тДВ тЖТ тДВ :=
  Classical.choose (A.localAnalyticPrincipalPart s hs)

theorem RectangleAnalyticPrincipalPartData.localAnalyticRemainder_analyticAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : тДВ} (hs : s тИИ P.singularities) :
    AnalyticAt тДВ (A.localAnalyticRemainder s hs) s :=
  (Classical.choose_spec (A.localAnalyticPrincipalPart s hs)).1

theorem RectangleAnalyticPrincipalPartData.localAnalyticRemainder_eventuallyEq
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : тДВ} (hs : s тИИ P.singularities) :
    logDeriv riemannZeta =с╢а[ЁЭУЭ[тЙа] s]
      (fun z : тДВ =>
        (P.principalCoeff s : тДВ) / (z - s)
          + A.localAnalyticRemainder s hs z) :=
  (Classical.choose_spec (A.localAnalyticPrincipalPart s hs)).2

/-! ### BW4: piecewise-patched remainder -/

/-- The **full** local analytic remainder at a singularity `s`: the chosen
local analytic remainder for the `s`-pole minus all other principal kernels.
This is the value the patched remainder must take at `s` so that the patched
function equals the raw `R.logDerivRemainder P` on a punctured neighborhood
of `s`. -/
noncomputable def RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    (s : тДВ) (hs : s тИИ P.singularities) : тДВ тЖТ тДВ :=
  fun z =>
    A.localAnalyticRemainder s hs z
      - (P.singularities.erase s).sum
          (fun t => principalKernel (P.principalCoeff t) t z)

/-- The full local analytic remainder at `s` is analytic at `s`: the
chosen `g_s` is analytic there, and every kernel `k_t/(z-t)` with `t тЙа s`
is analytic at `s`. -/
theorem RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt_analyticAt
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : тДВ} (hs : s тИИ P.singularities) :
    AnalyticAt тДВ (A.fullLocalAnalyticRemainderAt s hs) s := by
  unfold RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
  have hlocal : AnalyticAt тДВ (A.localAnalyticRemainder s hs) s :=
    A.localAnalyticRemainder_analyticAt hs
  have hsum :
      AnalyticAt тДВ
        (fun z : тДВ =>
          (P.singularities.erase s).sum
            (fun t => principalKernel (P.principalCoeff t) t z)) s := by
    refine Finset.analyticAt_fun_sum (c := s) (P.singularities.erase s) ?_
    intro t ht
    have hts : t тЙа s := (Finset.mem_erase.mp ht).1
    exact analyticAt_principalKernel_of_ne (Ne.symm hts)
  exact hlocal.sub hsum

/-- The patched remainder: equal to the chosen **full** local analytic
remainder at each singularity (evaluated at that singularity), and equal
to the raw remainder elsewhere.  The `full` form ensures the patched
function equals an analytic function on a full neighborhood of each
singularity (not just a punctured one), making the BY4 eventual-equality
proof go through. -/
noncomputable def patchedLogDerivRemainder
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData)
    (A : R.RectangleAnalyticPrincipalPartData P) : тДВ тЖТ тДВ :=
  fun z =>
    if hz : z тИИ P.singularities then
      A.fullLocalAnalyticRemainderAt z hz z
    else
      R.logDerivRemainder P z

/-- Off the (finite) singularity set, the patched remainder agrees with
the raw remainder.  Immediate from the `if-then-else` definition. -/
theorem patchedLogDerivRemainder_agrees_off_singularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {z : тДВ} (hz : z тИЙ P.singularities) :
    patchedLogDerivRemainder P A z = R.logDerivRemainder P z := by
  unfold patchedLogDerivRemainder
  simp [hz]

/-! ### BW5: combined input + nonsingular-point analyticity -/

/-- Combined input data for inhabiting `RectangleLogDerivRemainderExtensionData`
from local analytic principal-part data plus the off-singularity ╬╢-nonvanishing
and non-pole conditions on the closed rectangle. -/
structure RectangleLogDerivRemainderExtensionInput
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  analyticPP : R.RectangleAnalyticPrincipalPartData P
  off_singularity_not_pole :
    тИА z : тДВ, R.ContainsClosed z тЖТ z тИЙ P.singularities тЖТ z тЙа (1 : тДВ)
  off_singularity_zeta_nonzero :
    тИА z : тДВ, R.ContainsClosed z тЖТ z тИЙ P.singularities тЖТ riemannZeta z тЙа 0

/-- The patched remainder is analytic at every closed-rectangle point that is
not a counted singularity.  The patched and raw remainders agree on an open
neighborhood (complement of the finite singularity set), so analyticity of
the raw remainder there transfers. -/
theorem patchedLogDerivRemainder_analyticAt_of_not_singular
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderExtensionInput P)
    {z : тДВ} (hzClosed : R.ContainsClosed z) (hz : z тИЙ P.singularities) :
    AnalyticAt тДВ (patchedLogDerivRemainder P I.analyticPP) z := by
  have hraw : AnalyticAt тДВ (R.logDerivRemainder P) z :=
    analyticAt_logDerivRemainder_of_not_singular hz
      (I.off_singularity_not_pole z hzClosed hz)
      (I.off_singularity_zeta_nonzero z hzClosed hz)
  have hClosed : IsClosed ((P.singularities : Set тДВ)) :=
    P.singularities.finite_toSet.isClosed
  have hOpen : IsOpen ((P.singularities : Set тДВ)с╢Ь) := hClosed.isOpen_compl
  have hAvoid : тИАс╢а w in ЁЭУЭ z, w тИЙ P.singularities := by
    have h_mem : z тИИ ((P.singularities : Set тДВ)с╢Ь) := by simpa using hz
    exact hOpen.mem_nhds h_mem
  refine hraw.congr ?_
  filter_upwards [hAvoid] with w hw
  exact (patchedLogDerivRemainder_agrees_off_singularities I.analyticPP hw).symm

/-! ### BW6: isolated singular-point analyticity target + final assembler -/

/-- Target structure isolating the remaining analytic obligation: the
patched remainder is analytic at every counted singularity. -/
structure PatchedRemainderAnalyticAtSingularities
    (R : ZetaRectangle) {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P) : Prop where
  analyticAt :
    тИА s : тДВ, s тИИ P.singularities тЖТ
      AnalyticAt тДВ (patchedLogDerivRemainder P A) s

/-- **BW6 тАФ FINAL ASSEMBLER:** combined input data (BW5) plus the isolated
singular-point analyticity (BW6 target) discharges the extension data
needed by BV1, which in turn closes the principal-part contour
decomposition via BV3/BV4. -/
noncomputable def RectangleLogDerivRemainderExtensionInput.toExtensionData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectangleLogDerivRemainderExtensionInput P)
    (S : R.PatchedRemainderAnalyticAtSingularities I.analyticPP) :
    R.RectangleLogDerivRemainderExtensionData P where
  remainderExt := patchedLogDerivRemainder P I.analyticPP
  agrees_off_singularities := fun z hz =>
    patchedLogDerivRemainder_agrees_off_singularities I.analyticPP hz
  analytic_remainderExt := by
    intro z hzClosed
    by_cases hzSing : z тИИ P.singularities
    ┬╖ exact S.analyticAt z hzSing
    ┬╖ exact patchedLogDerivRemainder_analyticAt_of_not_singular I hzClosed hzSing

/-! ## BY: Analyticity of the patched remainder at singularities -/

/-! ### BY1: finite isolation тАФ near `s`, only `s` itself can lie in `S` -/

/-- For a point `s` in a finite set `S`, near `s` the only element of `S`
encountered is `s` itself.  Uses that finite sets are closed. -/
theorem eventually_eq_or_not_mem_finset
    {S : Finset тДВ} {s : тДВ} :
    тИАс╢а z in ЁЭУЭ s, z = s тИи z тИЙ S := by
  classical
  have hs_not : s тИЙ ((S.erase s : Set тДВ)) := by
    intro h
    exact (Finset.notMem_erase s S) (by exact_mod_cast h)
  have hclosed : IsClosed ((S.erase s : Set тДВ)) :=
    (S.erase s).finite_toSet.isClosed
  have hopen : IsOpen ((S.erase s : Set тДВ)с╢Ь) := hclosed.isOpen_compl
  have hmem : ((S.erase s : Set тДВ)с╢Ь) тИИ ЁЭУЭ s := hopen.mem_nhds hs_not
  filter_upwards [hmem] with z hz
  by_cases hzs : z = s
  ┬╖ exact Or.inl hzs
  ┬╖ refine Or.inr ?_
    intro hzS
    apply hz
    show z тИИ (S.erase s : Set тДВ)
    exact_mod_cast Finset.mem_erase.mpr тЯиhzs, hzSтЯй

/-! ### BY4: patched remainder equals full local analytic remainder on a `ЁЭУЭ s` -/

/-- The key local equality: on a neighborhood of any singularity `s`, the
patched remainder equals the full local analytic remainder.  At `z = s` the
two agree by definition (the `if`-branch); at `z тЙа s` and `z тИЙ S` the raw
remainder equals the full local remainder via the punctured principal-part
equality + finite-sum split. -/
theorem patchedLogDerivRemainder_eventuallyEq_fullLocal
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : тДВ} (hs : s тИИ P.singularities) :
    patchedLogDerivRemainder P A =с╢а[ЁЭУЭ s] A.fullLocalAnalyticRemainderAt s hs := by
  classical
  have hIso : тИАс╢а z in ЁЭУЭ s, z = s тИи z тИЙ P.singularities :=
    eventually_eq_or_not_mem_finset
  have hPP_nhds : тИАс╢а z in ЁЭУЭ s, z тИИ ({s}с╢Ь : Set тДВ) тЖТ
      logDeriv riemannZeta z =
        (P.principalCoeff s : тДВ) / (z - s) + A.localAnalyticRemainder s hs z :=
    eventually_nhdsWithin_iff.mp (A.localAnalyticRemainder_eventuallyEq hs)
  filter_upwards [hIso, hPP_nhds] with z hzIso hzPPimp
  obtain hzs | hzNot := hzIso
  ┬╖ -- z = s: both sides reduce to `A.fullLocalAnalyticRemainderAt s hs s`
    rw [hzs]
    unfold patchedLogDerivRemainder
    simp [hs]
  ┬╖ -- z тИЙ P.singularities, hence z тЙа s and the raw remainder applies
    have hz_ne : z тЙа s := fun h => hzNot (h тЦ╕ hs)
    have hz_compl : z тИИ ({s}с╢Ь : Set тДВ) := hz_ne
    have hPP := hzPPimp hz_compl
    have h_patched_eq : patchedLogDerivRemainder P A z = R.logDerivRemainder P z :=
      patchedLogDerivRemainder_agrees_off_singularities A hzNot
    rw [h_patched_eq]
    -- Split the principalPartSum into s-term + erase-sum, and use hPP.
    unfold ZetaRectangle.logDerivRemainder ZetaRectangle.principalPartSum
      RectangleAnalyticPrincipalPartData.fullLocalAnalyticRemainderAt
    rw [тЖР Finset.add_sum_erase _ _ hs]
    have hzeta : zetaLogDeriv z = logDeriv riemannZeta z := rfl
    rw [hzeta, hPP]
    unfold principalKernel
    ring

/-! ### BY5: patched remainder analytic at each singularity -/

/-- The patched remainder is analytic at every counted singularity, via
`AnalyticAt.congr` on the BY4 eventual equality with the full local
analytic remainder. -/
theorem patchedLogDerivRemainder_analyticAt_singularity
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P)
    {s : тДВ} (hs : s тИИ P.singularities) :
    AnalyticAt тДВ (patchedLogDerivRemainder P A) s := by
  have h1 : AnalyticAt тДВ (A.fullLocalAnalyticRemainderAt s hs) s :=
    A.fullLocalAnalyticRemainderAt_analyticAt hs
  exact h1.congr (patchedLogDerivRemainder_eventuallyEq_fullLocal A hs).symm

/-! ### BY6: inhabit `PatchedRemainderAnalyticAtSingularities` unconditionally -/

/-- **BY6 тАФ UNCONDITIONAL INHABITATION:** the patched remainder is analytic
at every singularity, given only the analytic principal-part data.  This
closes the final analytic obligation in the rectangle decomposition. -/
theorem patchedLogDerivRemainder_analyticAtSingularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleAnalyticPrincipalPartData P) :
    R.PatchedRemainderAnalyticAtSingularities A where
  analyticAt := fun _ hs =>
    patchedLogDerivRemainder_analyticAt_singularity A hs

/-! ## BZ: Canonical-rectangle off-singularity wiring -/

/-! ### BZ0: closed = open тИк boundary -/

/-- Every point of the closed rectangle is either in the open rectangle or
on the boundary. -/
theorem containsOpen_or_boundary_of_containsClosed
    (R : ZetaRectangle) {z : тДВ}
    (hz : R.ContainsClosed z) :
    R.ContainsOpen z тИи R.ContainsBoundary z := by
  by_cases hopen : R.ContainsOpen z
  ┬╖ exact Or.inl hopen
  ┬╖ exact Or.inr тЯиhz, hopenтЯй

/-- Closed-rectangle point that is not on the boundary is in the open
rectangle. -/
theorem containsOpen_of_containsClosed_not_boundary
    (R : ZetaRectangle) {z : тДВ}
    (hz : R.ContainsClosed z) (hnb : ┬м R.ContainsBoundary z) :
    R.ContainsOpen z := by
  rcases R.containsOpen_or_boundary_of_containsClosed hz with h | h
  ┬╖ exact h
  ┬╖ exact False.elim (hnb h)

/-! ### BZ2: not in counted singularities тЗТ not the pole -/

/-- For canonical counted principal-part data: if `z` is in the closed
rectangle and is not a counted singularity, then `z тЙа 1`.  At `z = 1`, strong
admissibility's `poleNotOnBoundary` plus `ContainsClosed 1` forces
`PoleInside`, which makes `1` a counted singularity тАФ contradiction. -/
theorem not_pole_of_closed_not_mem_countedPrincipalPart_singularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} {z : тДВ}
    (hzClosed : R.ContainsClosed z)
    (hz : z тИЙ (R.countedPrincipalPartData hAdm Z).singularities) :
    z тЙа (1 : тДВ) := by
  intro hz1
  subst hz1
  have hnb : ┬м R.ContainsBoundary (1 : тДВ) := hAdm.poleNotOnBoundary
  have hOpen : R.ContainsOpen (1 : тДВ) :=
    R.containsOpen_of_containsClosed_not_boundary hzClosed hnb
  have hPoleInside : R.PoleInside := hOpen
  have hcounted : R.IsCountedZetaSingularityInside (1 : тДВ) :=
    Or.inr тЯиhPoleInside, rflтЯй
  exact hz ((R.countedPrincipalPartData hAdm Z).singularities_complete 1 |>.mpr hcounted)

/-! ### BZ3: not in counted singularities тЗТ ╬╢ тЙа 0 (given a zero-classification hypothesis) -/

/-- For canonical counted principal-part data: if `z` is not in the
singularity set and every zeta zero in the closed rectangle is a
counted nontrivial zero inside, then `╬╢ z тЙа 0`. -/
theorem zeta_nonzero_of_closed_not_mem_countedPrincipalPart_singularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside} {z : тДВ}
    (_hzClosed : R.ContainsClosed z)
    (hz : z тИЙ (R.countedPrincipalPartData hAdm Z).singularities)
    (hZeroInside : riemannZeta z = 0 тЖТ R.IsNontrivialZeroInside z) :
    riemannZeta z тЙа 0 := by
  intro hzeta
  have hInside : R.IsNontrivialZeroInside z := hZeroInside hzeta
  have hcounted : R.IsCountedZetaSingularityInside z := Or.inl hInside
  exact hz ((R.countedPrincipalPartData hAdm Z).singularities_complete z |>.mpr hcounted)

/-! ### BZ4: input package for canonical rectangles -/

/-- The clean geometric/zero-classification input for canonical residue-free
data: every zeta zero in the closed rectangle is a counted nontrivial zero
inside the rectangle.  For RvM rectangles this is concretely deducible from
positive bottom (excludes real trivial zeros) and the critical-strip bounds. -/
structure CanonicalRemainderNoUnremovedSingularities
    (R : ZetaRectangle) (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) : Prop where
  zero_inside_of_zeta_zero :
    тИА z : тДВ, R.ContainsClosed z тЖТ riemannZeta z = 0 тЖТ
      R.IsNontrivialZeroInside z

/-- Build the canonical extension input from the geometric/zero-classification
package and the unconditional BX6 analytic principal-part data. -/
noncomputable def RectangleLogDerivRemainderExtensionInput.of_canonical
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.RectangleLogDerivRemainderExtensionInput
      (R.countedPrincipalPartData hAdm Z) where
  analyticPP := countedPrincipalPartData_analyticPrincipalPartData
  off_singularity_not_pole := fun _ hzClosed hzNot =>
    not_pole_of_closed_not_mem_countedPrincipalPart_singularities
      hzClosed hzNot
  off_singularity_zeta_nonzero := fun z hzClosed hzNot =>
    zeta_nonzero_of_closed_not_mem_countedPrincipalPart_singularities
      hzClosed hzNot (N.zero_inside_of_zeta_zero z hzClosed)

/-! ### BZ5: final canonical residue-free data from the no-unremoved input -/

/-- **BZ5 тАФ UNCONDITIONAL FINAL ASSEMBLER:** kernel-index data plus the clean
no-unremoved-singularities geometric package inhabits the canonical
residue-free argument-principle data.  Every other rectangle-decomposition
obligation (analytic principal parts, patched-remainder analyticity, linearity
of contour integration, Cauchy-Goursat for the patched remainder) is now
discharged unconditionally. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.of_noUnremovedSingularities
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (K : R.RectangleKernelIndexData (R.countedPrincipalPartData hAdm Z))
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z :=
  let I : R.RectangleLogDerivRemainderExtensionInput
            (R.countedPrincipalPartData hAdm Z) :=
    RectangleLogDerivRemainderExtensionInput.of_canonical N
  let S : R.PatchedRemainderAnalyticAtSingularities I.analyticPP :=
    patchedLogDerivRemainder_analyticAtSingularities I.analyticPP
  CanonicalResidueFreeArgumentPrincipleData.of_remainderExtension K
    (I.toExtensionData S)

/-! ## CA: Canonical kernel-index data + final RvM-rectangle wiring -/

/-! ### CA1: canonical kernel-index data from the unit-kernel chain -/

/-- For every counted singularity, pick a canonical small circle inside the
rectangle and discharge the per-singularity punctured Cauchy-Goursat via
the unit-kernel chain (centered-square reduction + translation invariance
+ centered-square = 2╧Аi). -/
noncomputable def rectangleKernelIndexData_of_unitKernel
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} :
    R.RectangleKernelIndexData P := by
  classical
  let choose_circle :
      тИА s, s тИИ P.singularities тЖТ R.SmallCircleInsideRectangle s :=
    fun s hs =>
      Classical.choice (exists_smallCircleInsideRectangle (by
        have hsCounted : R.IsCountedZetaSingularityInside s :=
          (P.singularities_complete s).mp hs
        rcases hsCounted with hsZero | hsPole
        ┬╖ exact hsZero.2
        ┬╖ obtain тЯиhPoleInside, hs_eqтЯй := hsPole
          rw [hs_eq]; exact hPoleInside))
  exact {
    smallCircle := choose_circle
    puncturedCG := fun s hs =>
      PuncturedRectangleCauchyGoursat.of_canonicalSquareToCircle
        (UnitKernelCanonicalSquareToCircleDeformation.of_centered_reduction
          centeredSquareEqualsTwoPiI
          (canonicalSquareEqualsCenteredSquare (choose_circle s hs))) }

/-! ### CA2: canonical residue-free data from no-unremoved-singularities only -/

/-- Canonical residue-free argument-principle data built directly from the
no-unremoved-singularities geometric package тАФ the kernel-index data is
provided by CA1 (unit-kernel chain). -/
noncomputable def canonicalResidueFreeArgumentPrincipleData
    {R : ZetaRectangle} {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (N : R.CanonicalRemainderNoUnremovedSingularities hAdm Z) :
    R.CanonicalResidueFreeArgumentPrincipleData hAdm Z :=
  CanonicalResidueFreeArgumentPrincipleData.of_noUnremovedSingularities
    (rectangleKernelIndexData_of_unitKernel
      (R := R) (P := R.countedPrincipalPartData hAdm Z))
    N

/-! ## AU: Finite-set algebra bridge to the residue-index formula -/

/-! ### AU5: principal-coefficient sum = weighted zero count тИТ pole count -/

/-- The sum of canonical principal coefficients over counted singularities
equals the weighted zero count minus the pole count.  This is the finite-set
algebra bridge between principal-part data and the older residue-index
formula. -/
theorem countedPrincipalCoeff_sum_eq_zeroCount_sub_poleCount
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) :
    (R.countedPrincipalPartData hAdm Z).singularities.sum
        (R.countedPrincipalPartData hAdm Z).principalCoeff =
      (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : тДд)
        - (R.poleCountInside : тДд) := by
  classical
  show (R.canonicalSingularities Z).sum zetaLogDerivPrincipalCoeff =
       (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : тДд)
         - (R.poleCountInside : тДд)
  have h_zero_sum :
      Z.zeros.sum zetaLogDerivPrincipalCoeff =
        (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : тДд) := by
    unfold weightedZeroCountInside
    push_cast
    refine Finset.sum_congr rfl (fun s hs => ?_)
    have hsNT : IsNontrivialZetaZero s := ((Z.complete s).mp hs).1
    exact zetaLogDerivPrincipalCoeff_of_zero hsNT
  have h1_not_mem : (1 : тДВ) тИЙ Z.zeros := by
    intro h1
    have hNT : IsNontrivialZetaZero (1 : тДВ) := ((Z.complete 1).mp h1).1
    have hlt : (1 : тДВ).re < 1 := hNT.2.2
    norm_num at hlt
  unfold canonicalSingularities
  by_cases hpole : R.PoleInside
  ┬╖ rw [if_pos hpole, Finset.sum_insert h1_not_mem,
        zetaLogDerivPrincipalCoeff_one, h_zero_sum]
    have h_pole_one : R.poleCountInside = 1 := by
      simp [poleCountInside, hpole]
    rw [h_pole_one]
    push_cast
    ring
  ┬╖ rw [if_neg hpole, h_zero_sum]
    have h_pole_zero : R.poleCountInside = 0 := by
      simp [poleCountInside, hpole]
    rw [h_pole_zero]
    push_cast
    ring

/-! ### AU4: canonical principal-part theorem тЖТ residue-index formula -/

/-- If a principal-part integral theorem's `ppData` matches the canonical
counted data, it yields the residue-index formula via AU5. -/
noncomputable def RectanglePrincipalPartIntegralTheorem.toResidueIndexFormula_of_canonical
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 тЙд R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    (T : R.RectanglePrincipalPartIntegralTheorem)
    (hPP :
      T.ppData =
        R.countedPrincipalPartData hAdm
          (R.zeroSetInsideOfSlab hleft hright hgood
            (R.canonicalSlabZeroSet hbottom_nonneg))) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood where
  stronglyAdmissible := hAdm
  residueIndex := T.ppData.singularities.sum T.ppData.principalCoeff
  normalizedIntegral_eq_index := T.normalizedIntegral_eq_sum
  residueIndex_eq_count_sub_poles := by
    rw [hPP]
    exact countedPrincipalCoeff_sum_eq_zeroCount_sub_poleCount hAdm _

/-! ### AU6: canonical residue-free data тЖТ residue-index formula -/

/-- Canonical residue-free argument-principle data inhabits the rectangle
residue-index formula. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toResidueIndexFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 тЙд R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (hZ :
      Z =
        R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood := by
  subst hZ
  exact D.toPrincipalPartIntegralTheorem.toResidueIndexFormula_of_canonical rfl

/-! ### AU7: canonical residue-free data тЖТ Turing interval certificate -/

/-- Canonical residue-free argument-principle data on the canonical slab
yields a Turing interval certificate, the final downstream consumer. -/
noncomputable def CanonicalResidueFreeArgumentPrincipleData.toTuringIntervalCertificate
    {R : ZetaRectangle}
    {hleft : R.left < 0} {hright : 1 < R.right}
    {hbottom_nonneg : 0 тЙд R.bottom} {hgood : GoodHeight R.top}
    {hAdm : R.StronglyAdmissibleForZeta}
    {Z : R.ZeroSetInside}
    (hZ :
      Z =
        R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
    (D : R.CanonicalResidueFreeArgumentPrincipleData hAdm Z)
    (hbottom_pos : 0 < R.bottom) :
    TuringIntervalCertificate :=
  (D.toResidueIndexFormula hZ).toTuringIntervalCertificate hbottom_pos

/-! ## AV: RvM rectangle family bridge -/

/-! ### AV1: RvM rectangle data structure -/

/-- A rectangle suitable for a good-height RiemannтАУvon Mangoldt count:
positive bottom (to keep the pole off the boundary), a good top,
straddles the critical strip, and is strongly admissible. -/
structure RvMRectangleData (T : тДЭ) where
  R : ZetaRectangle
  left_lt_zero : R.left < 0
  one_lt_right : 1 < R.right
  bottom_nonneg : 0 тЙд R.bottom
  bottom_pos : 0 < R.bottom
  top_eq : R.top = T
  goodTop : GoodHeight R.top
  stronglyAdmissible : R.StronglyAdmissibleForZeta

/-! ### AV2: canonical zero set inside the RvM rectangle -/

/-- The canonical rectangle-inside zero set for an RvM rectangle. -/
noncomputable def RvMRectangleData.zeroSetInside
    {T : тДЭ} (D : RvMRectangleData T) :
    D.R.ZeroSetInside :=
  D.R.zeroSetInsideOfSlab
    D.left_lt_zero
    D.one_lt_right
    D.goodTop
    (D.R.canonicalSlabZeroSet D.bottom_nonneg)

/-! ### AV3: residue-free data for an RvM rectangle -/

/-- Residue-free argument-principle data attached to an RvM rectangle.
This bundles the two global contour obligations
(`PuncturedRectangleCauchyGoursat` and `RectanglePrincipalPartContourDecomposition`)
for the canonical singularities of this rectangle. -/
structure RvMRectangleResidueFreeData
    {T : тДЭ} (D : RvMRectangleData T) where
  data :
    D.R.CanonicalResidueFreeArgumentPrincipleData
      D.stronglyAdmissible
      D.zeroSetInside

/-! ### AV4: RvM residue-free data тЖТ Turing certificate -/

/-- Residue-free data for an RvM rectangle yields a Turing interval
certificate for the rectangle's height slab. -/
noncomputable def RvMRectangleResidueFreeData.toTuringIntervalCertificate
    {T : тДЭ}
    {D : RvMRectangleData T}
    (A : RvMRectangleResidueFreeData D) :
    TuringIntervalCertificate :=
  A.data.toTuringIntervalCertificate rfl D.bottom_pos

/-! ### CA3: RvM-rectangle no-unremoved-singularities wrapper -/

/-- RvM-rectangle wrapper for the canonical no-unremoved-singularities
geometric package. -/
structure RvMRectangleNoUnremovedSingularities
    {T : тДЭ} (D : RvMRectangleData T) : Prop where
  noUnremoved :
    D.R.CanonicalRemainderNoUnremovedSingularities
      D.stronglyAdmissible D.zeroSetInside

/-- Build the RvM residue-free data from the no-unremoved-singularities
geometric package, via CA2's canonical-residue-free constructor. -/
noncomputable def RvMRectangleResidueFreeData.of_noUnremovedSingularities
    {T : тДЭ} {D : RvMRectangleData T}
    (N : RvMRectangleNoUnremovedSingularities D) :
    RvMRectangleResidueFreeData D where
  data := canonicalResidueFreeArgumentPrincipleData N.noUnremoved

/-! ### AV6: main-term evaluation at a single height -/

/-- Per-height main-term evaluation: the weighted slab count equals
`mainTerm T + Sarg T`.  Together with the rectangle certificate, this is the
analytic input needed to inhabit the good-height RvM formula. -/
structure RvMRectangleMainTermEvaluation
    {T : тДЭ} (D : RvMRectangleData T) where
  Sarg : тДЭ тЖТ тДЭ
  evaluation :
    (zetaWeightedZeroCountInHeightSlab
        D.R.bottom D.R.top D.bottom_nonneg D.R.hbottom_lt_top.le : тДЭ) =
      riemannVonMangoldtMainTerm T + Sarg T

/-! ### AV7: good-height RvM rectangle family -/

/-- A good-height family: a rectangle and residue-free data per good height,
together with the per-height RvM main-term evaluation evaluated against
a single global `Sarg`. -/
structure RvMGoodHeightRectangleFamily where
  Sarg : тДЭ тЖТ тДЭ
  rect :
    тИА T : тДЭ, RvMGoodHeight T тЖТ RvMRectangleData T
  residueFree :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ RvMRectangleResidueFreeData (rect T hT)
  mainEval :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : тДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- A good-height rectangle family yields the good-height RvM formula
package. -/
noncomputable def RvMGoodHeightRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights where
  Sarg := F.Sarg
  formula := F.mainEval

/-! ### CA4: concrete good-height rectangle family (replacing `residueFree` with `noUnremoved`) -/

/-- Concrete good-height rectangle family: a rectangle, the
no-unremoved-singularities geometric package per good height, and the
per-height RvM main-term evaluation.  The residue-free data is built
automatically via CA3. -/
structure RvMGoodHeightConcreteRectangleFamily where
  Sarg : тДЭ тЖТ тДЭ
  rect : тИА T : тДЭ, RvMGoodHeight T тЖТ RvMRectangleData T
  noUnremoved :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ
      RvMRectangleNoUnremovedSingularities (rect T hT)
  mainEval :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : тДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Convert a concrete good-height rectangle family into the existing
`RvMGoodHeightRectangleFamily` by building the residue-free data from
the no-unremoved-singularities package. -/
noncomputable def RvMGoodHeightConcreteRectangleFamily.toRectangleFamily
    (F : RvMGoodHeightConcreteRectangleFamily) :
    RvMGoodHeightRectangleFamily where
  Sarg := F.Sarg
  rect := F.rect
  residueFree := fun T hT =>
    RvMRectangleResidueFreeData.of_noUnremovedSingularities (F.noUnremoved T hT)
  mainEval := F.mainEval

/-! ### CA5: final good-height RvM theorem from the concrete family -/

/-- **CA5 тАФ FINAL:** the concrete good-height rectangle family directly
yields the proven good-height RiemannтАУvon Mangoldt formula package. -/
noncomputable def
    RvMGoodHeightConcreteRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightConcreteRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights :=
  F.toRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights

/-! ## CB: Standard safe-height rectangle constructor for RvM data -/

/-! ### CB1: geometric rectangle with bottom `B` and top `T` -/

/-- The standard horizontal-strip rectangle with `left = -1`, `right = 2`,
bottom `B`, and top `T`.  Encloses the critical strip `0 < re < 1`. -/
noncomputable def rectangleOfSafeHeights
    {B T : тДЭ} (_hBpos : 0 < B) (hBT : B < T) :
    ZetaRectangle where
  left := -1
  right := 2
  bottom := B
  top := T
  hleft_lt_right := by norm_num
  hbottom_lt_top := hBT

/-! ## CC: Strong admissibility from edge-by-edge boundary classification -/

/-! ### CC1: boundary zero-free package (named obligations) -/

/-- The remaining zeta-zero classification facts needed to prove strong
admissibility for `rectangleOfSafeHeights`.

* `left_edge`: no zeta zero anywhere on the vertical line `re = -1`
  (needs the functional equation to push back into the convergent region).
* `bottom_zeros_nontrivial`: every zeta zero with `im = B` is a nontrivial
  zero (rules out hypothetical "exotic" zeros; follows from the standard
  classification trivial zeros тИк nontrivial zeros).
* `top_zeros_nontrivial`: same for `im = T`. -/
structure SafeHeightRectangleBoundaryZeroFree (B T : тДЭ) : Prop where
  left_edge :
    тИА y : тДЭ, riemannZeta тЯи-1, yтЯй тЙа 0
  bottom_zeros_nontrivial :
    тИА z : тДВ, z.im = B тЖТ riemannZeta z = 0 тЖТ IsNontrivialZetaZero z
  top_zeros_nontrivial :
    тИА z : тДВ, z.im = T тЖТ riemannZeta z = 0 тЖТ IsNontrivialZetaZero z

/-! ### CC2: easy edge / pole lemmas -/

/-- Right edge `re = 2` is zero-free for `╬╢` (Euler-product region). -/
theorem zeta_ne_zero_of_re_eq_two
    {z : тДВ} (hzre : z.re = (2 : тДЭ)) : riemannZeta z тЙа 0 :=
  riemannZeta_ne_zero_of_one_lt_re (by simp [hzre])

/-- The pole `1 тИИ тДВ` does not lie on the boundary of a safe-height
rectangle: `Im 1 = 0 < B` puts it strictly below the rectangle's
horizontal slab. -/
theorem pole_not_on_boundary_safeRectangle
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T) :
    ┬м (rectangleOfSafeHeights hBpos hBT).ContainsBoundary (1 : тДВ) := by
  intro h
  have hc := h.1
  have h_im : B тЙд (1 : тДВ).im := hc.2.2.1
  simp at h_im
  linarith

/-- Boundary case-split for a safe-height rectangle: any boundary point
lies on exactly one of the four edges. -/
theorem boundary_cases_safeRectangle
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T) {z : тДВ}
    (hz : (rectangleOfSafeHeights hBpos hBT).ContainsBoundary z) :
    z.re = -1 тИи z.re = 2 тИи z.im = B тИи z.im = T := by
  obtain тЯиhC, hOтЯй := hz
  have h1 : (-1 : тДЭ) тЙд z.re := hC.1
  have h2 : z.re тЙд (2 : тДЭ) := hC.2.1
  have h3 : B тЙд z.im := hC.2.2.1
  have h4 : z.im тЙд T := hC.2.2.2
  by_contra hcontra
  push_neg at hcontra
  obtain тЯиhL, hR, hBe, hTeтЯй := hcontra
  apply hO
  refine тЯи?_, ?_, ?_, ?_тЯй
  ┬╖ exact lt_of_le_of_ne h1 (Ne.symm hL)
  ┬╖ exact lt_of_le_of_ne h2 hR
  ┬╖ exact lt_of_le_of_ne h3 (Ne.symm hBe)
  ┬╖ exact lt_of_le_of_ne h4 hTe

/-! ### CC3: strong admissibility from `SafeHeightRectangleBoundaryZeroFree` -/

/-- Strong admissibility of the safe-height rectangle, derived from
`GoodHeight` on top/bottom plus the three remaining boundary
classification facts. -/
theorem stronglyAdmissible_rectangleOfSafeHeights
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleBoundaryZeroFree B T) :
    (rectangleOfSafeHeights hBpos hBT).StronglyAdmissibleForZeta where
  noZetaZerosOnBoundary := by
    intro s hsZero hsBoundary
    rcases boundary_cases_safeRectangle hBpos hBT hsBoundary with hL | hR | hB | hT'
    ┬╖ exact H.left_edge s.im (by
        have h_eq : (тЯи-1, s.imтЯй : тДВ) = s := by
          apply Complex.ext
          ┬╖ simp [hL]
          ┬╖ simp
        rw [h_eq]; exact hsZero)
    ┬╖ exact zeta_ne_zero_of_re_eq_two hR hsZero
    ┬╖ have hNT : IsNontrivialZetaZero s := H.bottom_zeros_nontrivial s hB hsZero
      exact hBgood s hNT hB
    ┬╖ have hNT : IsNontrivialZetaZero s := H.top_zeros_nontrivial s hT' hsZero
      exact hTgood s hNT hT'
  poleNotOnBoundary := pole_not_on_boundary_safeRectangle hBpos hBT

/-! ## CD: Interior zero-classification + canonical `noUnremoved` for safe rectangles -/

/-! ### CD2: zero-classification package (extends boundary package with interior) -/

/-- Full zeta-zero classification on a safe-height rectangle: combines the
boundary package (CC1) with an `interior_zeros_nontrivial` field stating
that every zeta zero in the open rectangle is a nontrivial zero. -/
structure SafeHeightRectangleZeroClassification
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T) : Prop
    extends SafeHeightRectangleBoundaryZeroFree B T where
  interior_zeros_nontrivial :
    тИА z : тДВ,
      (rectangleOfSafeHeights hBpos hBT).ContainsOpen z тЖТ
      riemannZeta z = 0 тЖТ
      IsNontrivialZetaZero z

/-! ### CD1: every closed-rectangle zeta zero is a nontrivial zero inside -/

/-- The classification package implies every zeta zero in the closed
safe-height rectangle is a nontrivial zero in the open rectangle. -/
theorem isNontrivialZeroInside_of_closed_safeRectangle_zero
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleZeroClassification hBpos hBT)
    {z : тДВ}
    (hzClosed : (rectangleOfSafeHeights hBpos hBT).ContainsClosed z)
    (hzeta : riemannZeta z = 0) :
    (rectangleOfSafeHeights hBpos hBT).IsNontrivialZeroInside z := by
  have hCases :
      (rectangleOfSafeHeights hBpos hBT).ContainsOpen z тИи
        (rectangleOfSafeHeights hBpos hBT).ContainsBoundary z :=
    (rectangleOfSafeHeights hBpos hBT).containsOpen_or_boundary_of_containsClosed hzClosed
  rcases hCases with hOpen | hBoundary
  ┬╖ -- interior: classification field handles it
    exact тЯиH.interior_zeros_nontrivial z hOpen hzeta, hOpenтЯй
  ┬╖ -- boundary: derive contradiction from the boundary classification
    exfalso
    rcases boundary_cases_safeRectangle hBpos hBT hBoundary with hL | hR | hBdry | hTop
    ┬╖ apply H.left_edge z.im
      have h_eq : (тЯи-1, z.imтЯй : тДВ) = z := by
        apply Complex.ext
        ┬╖ simpa using hL.symm
        ┬╖ simp
      rw [h_eq]
      exact hzeta
    ┬╖ exact zeta_ne_zero_of_re_eq_two hR hzeta
    ┬╖ have hNT : IsNontrivialZetaZero z := H.bottom_zeros_nontrivial z hBdry hzeta
      exact hBgood z hNT hBdry
    ┬╖ have hNT : IsNontrivialZetaZero z := H.top_zeros_nontrivial z hTop hzeta
      exact hTgood z hNT hTop

/-! ### CB3 (updated): safe-height data via the zero-classification package -/

/-- Safe-height data for an RvM rectangle: positive bottom height `B`,
both heights `Good`, and the full safe-rectangle zeta-zero classification
package (CD2). -/
structure RvMSafeHeightData (T : тДЭ) where
  B : тДЭ
  B_pos : 0 < B
  B_lt_T : B < T
  goodBottom : GoodHeight B
  goodTop : GoodHeight T
  zeroClass : SafeHeightRectangleZeroClassification B_pos B_lt_T

/-! ### CB6 (updated): build `RvMRectangleData` from safe-height data -/

/-- Construct an `RvMRectangleData` for height `T` from safe-height data,
using CC3 to discharge strong admissibility via the boundary part of the
zero-classification package. -/
noncomputable def rvmRectangleDataOfSafeHeights
    {T : тДЭ} (H : RvMSafeHeightData T) :
    RvMRectangleData T where
  R := rectangleOfSafeHeights H.B_pos H.B_lt_T
  left_lt_zero := by show (-1 : тДЭ) < 0; norm_num
  one_lt_right := by show (1 : тДЭ) < 2; norm_num
  bottom_nonneg := le_of_lt H.B_pos
  bottom_pos := H.B_pos
  top_eq := rfl
  goodTop := H.goodTop
  stronglyAdmissible :=
    stronglyAdmissible_rectangleOfSafeHeights
      H.B_pos H.B_lt_T H.goodBottom H.goodTop
      H.zeroClass.toSafeHeightRectangleBoundaryZeroFree

/-! ### CD3: canonical no-unremoved-singularities for safe rectangles -/

/-- The zero-classification package implies the canonical
`CanonicalRemainderNoUnremovedSingularities` for any admissibility/zero-set
combination on the safe-height rectangle. -/
theorem noUnremovedSingularities_rectangleOfSafeHeights
    {B T : тДЭ} (hBpos : 0 < B) (hBT : B < T)
    (hBgood : GoodHeight B) (hTgood : GoodHeight T)
    (H : SafeHeightRectangleZeroClassification hBpos hBT)
    {hAdm : (rectangleOfSafeHeights hBpos hBT).StronglyAdmissibleForZeta}
    {Z : (rectangleOfSafeHeights hBpos hBT).ZeroSetInside} :
    (rectangleOfSafeHeights hBpos hBT).CanonicalRemainderNoUnremovedSingularities
      hAdm Z where
  zero_inside_of_zeta_zero := fun _ hzClosed hzeta =>
    isNontrivialZeroInside_of_closed_safeRectangle_zero
      hBpos hBT hBgood hTgood H hzClosed hzeta

/-! ### CD5: `RvMRectangleNoUnremovedSingularities` from safe-height data -/

/-- The RvM no-unremoved-singularities wrapper directly from safe-height
data тАФ every zero-in-closed-rectangle is nontrivial-inside by CD1, hence
the canonical no-unremoved property holds. -/
noncomputable def rvmRectangleNoUnremovedSingularitiesOfSafeHeights
    {T : тДЭ} (H : RvMSafeHeightData T) :
    RvMRectangleNoUnremovedSingularities (rvmRectangleDataOfSafeHeights H) where
  noUnremoved :=
    noUnremovedSingularities_rectangleOfSafeHeights
      H.B_pos H.B_lt_T H.goodBottom H.goodTop H.zeroClass

/-! ### CB7: existence of a good bottom height strictly inside `(0, T)` -/

/-- For any positive good height `T`, there exists a good bottom height
`B тИИ (0, T)`.  Pure use of `exists_goodHeight_between` on `(T/2, T)`. -/
theorem existsSafeBottomHeight
    {T : тДЭ} (hTpos : 0 < T) :
    тИГ B : тДЭ, 0 < B тИз B < T тИз GoodHeight B := by
  have hAlt : (T / 2 : тДЭ) < T := by linarith
  have hApos : (0 : тДЭ) < T / 2 := by linarith
  obtain тЯиB, hAB, hBT, hgoodтЯй := exists_goodHeight_between hApos hAlt
  exact тЯиB, by linarith, hBT, hgoodтЯй

/-! ### CD6: safe-rectangle good-height family + conversion to concrete family -/

/-- Safe-rectangle good-height family: a global `Sarg`, a safe-height
data per good height, and a per-height main-term evaluation.  Combined
with the canonical no-unremoved conversion (CD5), this directly yields
a `RvMGoodHeightConcreteRectangleFamily`. -/
structure RvMGoodHeightSafeRectangleFamily where
  Sarg : тДЭ тЖТ тДЭ
  safeData : тИА T : тДЭ, RvMGoodHeight T тЖТ RvMSafeHeightData T
  mainEval :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : тДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Convert a safe-rectangle family into the existing concrete family
by applying CB6 to obtain `rect` and CD5 to obtain `noUnremoved`. -/
noncomputable def RvMGoodHeightSafeRectangleFamily.toConcreteRectangleFamily
    (F : RvMGoodHeightSafeRectangleFamily) :
    RvMGoodHeightConcreteRectangleFamily where
  Sarg := F.Sarg
  rect := fun T hT => rvmRectangleDataOfSafeHeights (F.safeData T hT)
  noUnremoved := fun T hT =>
    rvmRectangleNoUnremovedSingularitiesOfSafeHeights (F.safeData T hT)
  mainEval := F.mainEval

/-- **CD6 тАФ FINAL:** the safe-rectangle family directly yields the proven
good-height RiemannтАУvon Mangoldt formula package. -/
noncomputable def
    RvMGoodHeightSafeRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (F : RvMGoodHeightSafeRectangleFamily) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights :=
  F.toConcreteRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights

end ZetaRectangle

/-! ## AW: Final Backlund/Turing input package -/

/-! ### AW1: master analytic-input package -/

/-- All remaining analytic inputs needed to derive the final
Backlund/Turing bound.  Everything past this structure is mechanical. -/
structure BacklundTuringAnalyticInputs where
  goodHeightFamily : ZetaRectangle.RvMGoodHeightRectangleFamily
  goodHeightExtension :
    RvMGoodHeightExtension
      goodHeightFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights
  backlundGood :
    BacklundArgumentBoundOnGoodHeights goodHeightFamily.Sarg
  backlundExtension :
    BacklundGoodHeightBoundExtension backlundGood

/-! ### AW2: full RvM formula from analytic inputs -/

/-- The analytic input package yields the all-height RiemannтАУvon Mangoldt
formula. -/
noncomputable def BacklundTuringAnalyticInputs.toProvenRiemannVonMangoldtFormula
    (I : BacklundTuringAnalyticInputs) :
    ProvenRiemannVonMangoldtFormula :=
  I.goodHeightExtension.toProvenRiemannVonMangoldtFormula

/-! ### AW3: full Backlund argument bound from analytic inputs -/

/-- The analytic input package yields the all-height Backlund argument
bound. -/
noncomputable def BacklundTuringAnalyticInputs.toBacklundArgumentBound
    (I : BacklundTuringAnalyticInputs) :
    BacklundArgumentBound I.goodHeightFamily.Sarg :=
  I.backlundExtension.toBacklundArgumentBound

/-! ### AW4: final `ProvenBacklundTuringBound` from analytic inputs -/

/-- Final Backlund/Turing bound derived mechanically from the analytic
input package. -/
noncomputable def BacklundTuringAnalyticInputs.toProvenBacklundTuringBound
    (I : BacklundTuringAnalyticInputs) :
    ProvenBacklundTuringBound :=
  I.toProvenRiemannVonMangoldtFormula.toProvenBacklundTuringBound
    I.toBacklundArgumentBound

/-! ### AW5: concrete-`S` half-log-plus-half bound -/

/-- From the analytic input package, `concreteS` satisfies the
half-log-plus-half bound for all heights past the Backlund threshold. -/
theorem BacklundTuringAnalyticInputs.concreteS_halfLogPlusHalf
    (I : BacklundTuringAnalyticInputs)
    {T : тДЭ}
    (hT : I.backlundGood.lower тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  I.toProvenBacklundTuringBound.halfLogPlusHalf T hT

/-! ### AW6: final theorem target.

Once an inhabitant of `BacklundTuringAnalyticInputs` is constructed by
discharging the remaining analytic obligations:

```
noncomputable def provenBacklundTuringInputs :
    BacklundTuringAnalyticInputs := ...
```

the headline theorem becomes a one-liner:

```
theorem concreteS_halfLogPlusHalf_bound_from_140 :
    тИА T : тДЭ, 140 тЙд T тЖТ
      |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  fun T hT =>
    provenBacklundTuringInputs.concreteS_halfLogPlusHalf
      (by linarith [provenBacklundTuringInputs.backlundGood.lower_ge_two_pi,
                    Real.pi_pos] : provenBacklundTuringInputs.backlundGood.lower тЙд T)
```

Remaining analytic obligations to inhabit `BacklundTuringAnalyticInputs`:

1. `PuncturedRectangleCauchyGoursat` (per zeta singularity inside rectangle)
2. `RectanglePrincipalPartContourDecomposition` (per rectangle)
3. `RvMRectangleMainTermEvaluation` / per-T main-term identity
4. `RvMGoodHeightExtension` (extend from good heights to all heights)
5. `BacklundArgumentBoundOnGoodHeights`
6. `BacklundGoodHeightBoundExtension`

Items 1+2 together inhabit `CanonicalResidueFreeArgumentPrincipleData` for
each good height, which is the per-rectangle Lean-level analytic input. -/

/-! ## CE: Final RvM analytic-input package + Backlund-Turing wrapper -/

/-! ### CE1: master RvM analytic-input package -/

/-- The remaining analytic inputs to drive the RiemannтАУvon Mangoldt formula
on good heights via safe rectangles.  Concretely: a correction function
`Sarg`, the per-height safe-rectangle data (CD2/CD5), and the actual
main-term identity per good height. -/
structure RvMGoodHeightAnalyticInputs where
  Sarg : тДЭ тЖТ тДЭ
  safeData :
    тИА T : тДЭ, RvMGoodHeight T тЖТ ZetaRectangle.RvMSafeHeightData T
  mainEval :
    тИА T : тДЭ, (hT : RvMGoodHeight T) тЖТ
      (zetaWeightedZeroCountUpToHeight T hT.nonneg : тДЭ) =
        riemannVonMangoldtMainTerm T + Sarg T

/-- Bridge into the existing `RvMGoodHeightSafeRectangleFamily`. -/
noncomputable def RvMGoodHeightAnalyticInputs.toSafeRectangleFamily
    (I : RvMGoodHeightAnalyticInputs) :
    ZetaRectangle.RvMGoodHeightSafeRectangleFamily where
  Sarg := I.Sarg
  safeData := I.safeData
  mainEval := I.mainEval

/-- The all-good-height RvM formula package directly from the analytic
input package тАФ composes CE1, CD6, CA5, AV7. -/
noncomputable def
    RvMGoodHeightAnalyticInputs.toProvenRiemannVonMangoldtFormulaOnGoodHeights
    (I : RvMGoodHeightAnalyticInputs) :
    ProvenRiemannVonMangoldtFormulaOnGoodHeights :=
  I.toSafeRectangleFamily.toProvenRiemannVonMangoldtFormulaOnGoodHeights

/-! ### CE2: Backlund-Turing analytic inputs from the RvM package + extensions -/

/-- Build `BacklundTuringAnalyticInputs` from the master RvM analytic input
package plus the good-height extension and the Backlund bound + extension. -/
noncomputable def BacklundTuringAnalyticInputs.of_rvMGoodHeightInputs
    (I : RvMGoodHeightAnalyticInputs)
    (Ext : RvMGoodHeightExtension
            I.toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BGood : BacklundArgumentBoundOnGoodHeights I.Sarg)
    (BExt : BacklundGoodHeightBoundExtension BGood) :
    BacklundTuringAnalyticInputs where
  goodHeightFamily := I.toSafeRectangleFamily.toConcreteRectangleFamily.toRectangleFamily
  goodHeightExtension := Ext
  backlundGood := BGood
  backlundExtension := BExt

/-! ### CE3: concrete-`S` half-log-plus-half bound from the analytic package -/

/-- Final headline-style theorem from the RvM analytic input package +
extensions + Backlund bounds. -/
theorem RvMGoodHeightAnalyticInputs.to_concreteS_halfLogPlusHalf
    (I : RvMGoodHeightAnalyticInputs)
    (Ext : RvMGoodHeightExtension
            I.toProvenRiemannVonMangoldtFormulaOnGoodHeights)
    (BGood : BacklundArgumentBoundOnGoodHeights I.Sarg)
    (BExt : BacklundGoodHeightBoundExtension BGood)
    {T : тДЭ} (hT : BGood.lower тЙд T) :
