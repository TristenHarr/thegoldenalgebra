formula data gives the residual-equals-canonical-tail identity, and the
existing closed-form + slab-cert chain delivers `|Im(error)| Ôëñ -Im(model)`. -/
theorem canonicalMidResidual_errorMargin_AwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (RcanonAFZ : XiResidualCanonicalFormulaDataAwayFromZeros
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : Ôäé}
    (hy : 0 < z.im)
    (hmid : Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
      2 * (1 + |z.re| + z.im) Ôëñ T)
