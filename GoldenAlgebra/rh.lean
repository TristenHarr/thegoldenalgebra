Conclusion: `XiPullbackAntiHerglotzTarget`. -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailData
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : Ôäé ÔåÆ Ôäé)
    (hdecomp : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
          2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z = M.model z + error z)
    (D : TrueKernelTailData S R error)
    (extras : Ôäò ÔåÆ LocalXiCloudDensityErrorPackage)
    (covers : ÔêÇ z : Ôäé, 0 < z.im ÔåÆ
      (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) Ôê¿
      Ôêâ n : Ôäò, (extras n).region z) :
    XiPullbackAntiHerglotzTarget := by
  -- The mid-band package from the ┬ºCCXXI true-kernel chain
  let midPackage : LocalXiCloudDensityErrorPackage :=
    localXiPackage_of_trueKernelTailData
      S R M hM_zeros hmodelAnti error hdecomp D
  -- Assemble a covering family: index 0 is the mid-band, others are extras
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n => if n = 0 then midPackage else extras (n - 1)
      covers := ?_ }
  intro z hz
  rcases covers z hz with hmid | Ôƒ¿n, hnÔƒ®
  ┬À -- z is in the mid-band; package 0 = midPackage covers it
    refine Ôƒ¿0, ?_Ôƒ®
    show midPackage.region z
    exact hmid
  ┬À -- z is covered by extras n; package (n+1) = extras n covers it
    refine Ôƒ¿n + 1, ?_Ôƒ®
    show (if (n + 1) = 0 then midPackage else extras (n + 1 - 1)).region z
    simp
    exact hn

-- =====================================================================
-- ┬ºCCXXV. Bundled model / coverage data + restated capstone
-- =====================================================================
-- Replaces the loose `(M, hM_zeros, hmodelAnti)` and `(extras, covers)`
-- arguments of the ┬ºCCXXII capstone with named bundled structures.
-- Keeps the same logical content but exposes the project's final
-- dependency boundary in a cleaner, theorem-by-theorem readable form.
--
-- Adds:
--   ActualCloudDensityModelData              ÔÇö bundled model fields
--   LowHighBandCoverData                     ÔÇö bundled cover fields
--   XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
--     ÔÇö front door restated using the two bundles.
--
-- The remaining inhabit theorem
-- `finiteFluctuationRegularityData_of_existing_integrability` requires
-- generalizing the existing ┬ºCXCVIII discrete/smooth-counting ├ù kernel
-- integrability lemmas (currently OrderedWindow-restricted or aligned
-- to `T0 = T`). It is intentionally deferred ÔÇö provable in pure Lean
-- without analytic input, but a non-trivial decomposition exercise
-- and not on the critical analytic path.

/-- ­ƒôª **`ActualCloudDensityModelData`** ÔÇö bundled model fields:
the cloud + density-tail model `M`, the `zeros100ceil` compatibility,
and the anti-Herglotz model property.

These are the three "model-shaped" arguments of the ┬ºCCXXII capstone;
bundling them here makes downstream theorems read cleanly. -/
structure ActualCloudDensityModelData where
  M           : CloudDensityTailModelDecomposition
  hM_zeros    : M.zeros = zeros100ceil
  hmodelAnti  : AntiHerglotzUHP M.model

/-- ­ƒôª **`LowHighBandCoverData`** ÔÇö bundled coverage of UHP probes
outside the adaptive `[10, 140]` band.

`extras` are additional `LocalXiCloudDensityErrorPackage`s, each
controlling some non-mid-band region. `covers` is the disjunction
that every UHP probe either lies in the mid-band or in some `extras n`
region. -/
structure LowHighBandCoverData where
  extras  : Ôäò ÔåÆ LocalXiCloudDensityErrorPackage
  covers  : ÔêÇ z : Ôäé, 0 < z.im ÔåÆ
    (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) Ôê¿
    Ôêâ n : Ôäò, (extras n).region z

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **CONDITIONAL CAPSTONE (bundled form).** Restates
┬ºCCXXII's `XiPullbackAntiHerglotzTarget_of_trueKernelTailData` using
`ActualCloudDensityModelData` and `LowHighBandCoverData` bundles in
place of loose arguments. Functionally equivalent ÔÇö just the cleanest
possible statement of the project's front door.

After ┬ºCCXXV, the remaining unformalized obligations are exactly:
* `RealIBPFamilyData S` (or, via ┬ºCCXXIV, `FiniteFluctuationLogEnvelopeData D T0`),
* `TrueKernelTailData S R error`,
* `hdecomp` (xi log-derivative decomposition),
* `Model : ActualCloudDensityModelData`,
* `Cover : LowHighBandCoverData`.

All of these are explicit analytic statements about ╬¥. -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (Model : ActualCloudDensityModelData)
    (error : Ôäé ÔåÆ Ôäé)
    (hdecomp : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº
          2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (D : TrueKernelTailData S R error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailData
    S R Model.M Model.hM_zeros Model.hmodelAnti error hdecomp D
    Cover.extras Cover.covers

-- =====================================================================
-- ┬ºCCXXIII. RealIBPFamilyData from explicit log-envelope assumptions
-- =====================================================================
-- Reduces the abstract `RealIBPFamilyData S` requirement of the ┬ºCCXXII
-- capstone to a concrete, named-assumption bundle `RealIBPLogEnvelopeData`
-- combining:
--   ÔÇó a pointwise log envelope `|S u| Ôëñ (slabCD T).1┬Àlog u + (slabCD T).2`
--     on `[T, Ôê×)` for every adaptive `(z, T)` in the band;
--   ÔÇó finite-window integrability of `S ┬À pairedCauchyImKernelDeriv`.
--
-- Routes through the existing ┬ºCCVI / ┬ºCCX theorems:
--   ÔÇó `derivative_integral_tendsto_of_log_envelope` for `deriv_tendsto`,
--   ÔÇó `derivative_integral_limit_abs_le_majorant_tail` for `deriv_bound`.
--
-- Also extracts standalone slab-nonnegativity lemmas
-- (`slabCD_fst_nonneg`, `slabCD_snd_nonneg`) ÔÇö previously inlined.

/-- Ô¡É **PROVED ÔÇö `slabCD T` first component is nonnegative.** -/
lemma slabCD_fst_nonneg (T : ÔäØ) : 0 Ôëñ (slabCD T).1 := by
  unfold slabCD; split_ifs <;> norm_num

/-- Ô¡É **PROVED ÔÇö `slabCD T` second component is nonnegative.** -/
lemma slabCD_snd_nonneg (T : ÔäØ) : 0 Ôëñ (slabCD T).2 := by
  unfold slabCD; split_ifs <;> norm_num

/-- ­ƒôª **`RealIBPLogEnvelopeData S`** ÔÇö named Prop bundle of the two
analytic obligations that produce a `RealIBPFamilyData S`:

* `log_envelope_from_T` ÔÇö pointwise log envelope on `[T, Ôê×)` for every
  adaptive `(z, T)`. Strong enough to give both the `ÔêÇßÂá` form needed
  by `derivative_integral_tendsto_of_log_envelope` and the pointwise
  `[T, Ôê×)` form needed by `derivative_integral_limit_abs_le_majorant_tail`.
* `derivative_integrable` ÔÇö interval integrability of the integrand
  `S ┬À pairedCauchyImKernelDeriv z.re z.im` on every `[T, X]` with `T Ôëñ X`.

Slab nonnegativity (`(slabCD T).1, (slabCD T).2`) is already free
via `slabCD_fst_nonneg` / `slabCD_snd_nonneg`. -/
structure RealIBPLogEnvelopeData (S : ÔäØ ÔåÆ ÔäØ) : Prop where
  log_envelope_from_T :
    ÔêÇ {z : Ôäé} {T : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      ÔêÇ u, T Ôëñ u ÔåÆ
        |S u| Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `RealIBPFamilyData S` from `RealIBPLogEnvelopeData S`.**
Discharges both `deriv_tendsto` and `deriv_bound` from a single log
envelope + integrability bundle via the existing ┬ºCCVI/┬ºCCX machinery. -/
theorem realIBPFamilyData_of_logEnvelope
    (S : ÔäØ ÔåÆ ÔäØ) (H : RealIBPLogEnvelopeData S) :
    RealIBPFamilyData S where
  deriv_tendsto := by
    intro z T h10 h140 hy hregime
    have hT_pos : (0 : ÔäØ) < T := lt_of_lt_of_le (by norm_num) h10
    have hS_ev : ÔêÇßÂá u in Filter.atTop,
        |S u| Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2 := by
      filter_upwards [Filter.eventually_ge_atTop T] with u hu
      exact H.log_envelope_from_T h10 h140 hy hregime u hu
    exact Phase1IBP.derivative_integral_tendsto_of_log_envelope
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hS_ev
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
  deriv_bound := by
    intro z T J h10 h140 hy hregime hJ
    have hT_pos : (0 : ÔäØ) < T := lt_of_lt_of_le (by norm_num) h10
    exact Phase1IBP.derivative_integral_limit_abs_le_majorant_tail
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T) (J := J)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hregime
      (H.log_envelope_from_T h10 h140 hy hregime)
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
      hJ

-- =====================================================================
-- ┬ºCCXXIV. Concrete finite-fluctuation specialization
-- =====================================================================
-- Specializes ┬ºCCXXIII's `RealIBPLogEnvelopeData S` to the concrete
-- `S u := finiteFluctuationPrimitive D T0 u` of ┬ºCXCVII / ┬ºCXCIX.
-- Surfaces the exact remaining number-theoretic / regularity content
-- as two named structures:
--
--   FiniteFluctuationLogEnvelopeData D T0   ÔÇö Turing-style log envelope
--   FiniteFluctuationRegularityData D T0    ÔÇö split-by-component integrability
--
-- Adds:
--   FiniteFluctuationLogEnvelopeData                  ÔÇö concrete obligations
--   realIBPLogEnvelopeData_of_finiteFluctuation       ÔÇö concrete ÔåÆ abstract
--   realIBPFamilyData_of_finiteFluctuation            ÔÇö concrete ÔåÆ RealIBPFamilyData
--   FiniteFluctuationRegularityData                   ÔÇö finer split
--   finiteFluctuation_derivative_integrable_of_regular ÔÇö reassemble integrability

/-- ­ƒôª **`FiniteFluctuationLogEnvelopeData D T0`** ÔÇö concrete analytic
obligations for the ┬ºCXCIX finite fluctuation primitive
`finiteFluctuationPrimitive D T0`. Two fields:

* `log_envelope_from_T` ÔÇö the Turing/Backlund-style bound on the
  finite fluctuation primitive (real number theory).
* `derivative_integrable` ÔÇö finite-window interval integrability of
  the IBP derivative-side integrand. -/
structure FiniteFluctuationLogEnvelopeData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ) : Prop where
  log_envelope_from_T :
    ÔêÇ {z : Ôäé} {T u : ÔäØ},
      10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ u ÔåÆ
      |Phase1IBP.finiteFluctuationPrimitive D T0 u|
        Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    ÔêÇ {z : Ôäé} {T X : ÔäØ},
      10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- ­ƒîƒ **PROVED ÔÇö concrete ÔåÆ abstract log-envelope data.** -/
theorem realIBPLogEnvelopeData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPLogEnvelopeData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) where
  log_envelope_from_T := by
    intro z T h10 h140 hy hregime u hTu
    exact H.log_envelope_from_T h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact H.derivative_integrable h10 h140 hy hregime hTX

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `RealIBPFamilyData` for the concrete finite
fluctuation primitive.** Composes ┬ºCCXXIII's
`realIBPFamilyData_of_logEnvelope` with the concrete log-envelope
bundle. -/
theorem realIBPFamilyData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPFamilyData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) :=
  realIBPFamilyData_of_logEnvelope
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    (realIBPLogEnvelopeData_of_finiteFluctuation D T0 H)

/-- ­ƒôª **`FiniteFluctuationRegularityData D T0`** ÔÇö finer split of the
`derivative_integrable` field of `FiniteFluctuationLogEnvelopeData`,
separating the discrete-counting and smooth-counting parts of the
integrand. Either piece can in principle be discharged from existing
┬ºCXCVIII work on the discrete sum decomposition and the explicit
smooth primitive. -/
structure FiniteFluctuationRegularityData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ) : Prop where
  discrete_part_integrable :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X
  smooth_part_integrable :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö reassemble integrability from the regular split.**
Given finer per-component integrability, recovers the
`derivative_integrable` of `FiniteFluctuationLogEnvelopeData`. Uses
`(a - b) ┬À c = a┬Àc - b┬Àc` pointwise + `IntervalIntegrable.sub`. -/
theorem finiteFluctuation_derivative_integrable_of_regular
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (R : FiniteFluctuationRegularityData D T0) :
    ÔêÇ {z : Ôäé} {T X : ÔäØ}, 10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
      T Ôëñ X ÔåÆ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hN := R.discrete_part_integrable h10 h140 hy hregime hTX
  have hS := R.smooth_part_integrable h10 h140 hy hregime hTX
  have hfunc_eq :
      (fun u =>
        Phase1IBP.finiteFluctuationPrimitive D T0 u
          * pairedCauchyImKernelDeriv z.re z.im u)
      = (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u
          - Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    ring
  rw [hfunc_eq]
  exact hN.sub hS

-- =====================================================================
-- ┬ºCCXXV. Inhabiting `FiniteFluctuationRegularityData` from existing
--         integrability lemmas (no extra analytic input)
-- =====================================================================
-- Provides:
--   discreteCountingKernelDerivTermAnyWindow            ÔÇö per-i term def
--   discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
--   discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
--                                                       ÔÇö generalizes the
--                                                         ┬ºCXCVIII lemma (drops
--                                                         the `OrderedWindow`
--                                                         requirement)
--   finiteFluctuationRegularityData_of_existing_integrability
--                                                       ÔÇö produces the
--                                                         regularity bundle
--                                                         given `0 < T0` and
--                                                         `T0 Ôëñ 10`.
--
-- The discrete part is fully general (any `T0, T, X` work).
-- The smooth part reuses the existing ┬ºCXCVIII lemma via
-- `IntervalIntegrable.mono_set`, which requires `T0 Ôëñ T` over the
-- adaptive band (so `T0 Ôëñ 10` is sufficient since adaptive `T ÔëÑ 10`).

/-- **Per-`i` indicator term for the any-window discrete primitive.**
Mirrors `Phase1IBP.discreteKernelDerivIndicatorTerm` but with the
two-condition indicator that appears in
`Phase1IBP.discreteCountingPrimitive D T0 u` for arbitrary `T0`. -/
noncomputable def discreteCountingKernelDerivTermAnyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 : ÔäØ) (i : Ôäò) : ÔäØ ÔåÆ ÔäØ :=
  fun u =>
    (if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- Ô¡É **PROVED ÔÇö per-`i` term is interval-integrable on any window.**
Case-split on `T0 Ôëñ D.Z i`: in the `Ôëñ` case, the integrand reduces to
the ┬ºCXCVIII single-indicator pattern (use
`Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable`); in the
`>` case, the integrand is identically zero. -/
lemma discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : ÔäØ) (i : Ôäò) (hy : 0 < y) :
    IntervalIntegrable
      (discreteCountingKernelDerivTermAnyWindow D x y T0 i)
      MeasureTheory.volume T X := by
  unfold discreteCountingKernelDerivTermAnyWindow
  by_cases h_T0 : T0 Ôëñ D.Z i
  ┬À have hfun :
        (fun u =>
          (if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun u =>
          (D.mult i : ÔäØ) * (if D.Z i Ôëñ u then (1 : ÔäØ) else 0)
            * pairedCauchyImKernelDeriv x y u) := by
      funext u
      by_cases h_u : D.Z i Ôëñ u
      ┬À have h_and : T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u := Ôƒ¿h_T0, h_uÔƒ®
        simp [h_and, h_u]
      ┬À have h_nand : ┬¼ (T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u) := fun Ôƒ¿_, hÔƒ® => h_u h
        simp [h_nand, h_u]
    rw [hfun]
    exact Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  ┬À have hfun :
        (fun u =>
          (if T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u then (D.mult i : ÔäØ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun _ : ÔäØ => (0 : ÔäØ)) := by
      funext u
      have h_nand : ┬¼ (T0 Ôëñ D.Z i Ôêº D.Z i Ôëñ u) := fun Ôƒ¿h, _Ôƒ® => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `N_{T0}(u) ┬À k'(u)` is interval-integrable on any
finite window**, without an `OrderedWindow` hypothesis. Generalizes
┬ºCXCVIII's `Phase1IBP.discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
to the case where the primitive's lower cutoff `T0` is decoupled from
the integration window `[T, X]`. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : ÔäØ) (hy : 0 < y) :
    IntervalIntegrable
      (fun u =>
        Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun :
      IntervalIntegrable
        (Ôêæ i Ôêê Finset.range D.n,
          discreteCountingKernelDerivTermAnyWindow D x y T0 i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
        D x y T0 T X i hy)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (Ôêæ i, term i) u = Ôêæ i, term i u (Finset.sum_apply)
  -- = (Ôêæ i, (if ... then mult_i else 0)) * k'(u) (Finset.sum_mul reverse)
  -- = discreteCountingPrimitive D.toFluctuationMeasureData T0 u * k'(u) (def)
  simp only [Finset.sum_apply, discreteCountingKernelDerivTermAnyWindow]
  rw [ÔåÉ Finset.sum_mul]
  rfl

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `FiniteFluctuationRegularityData` from existing
integrability.** Given `0 < T0 Ôëñ 10`, both regularity fields are
discharged from already-landed ┬ºCXCVIII lemmas:

* `discrete_part_integrable` ÔÇö via the new
  `discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow`
  (no `OrderedWindow` needed).
* `smooth_part_integrable` ÔÇö via existing
  `Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
  on `[T0, X]` plus `IntervalIntegrable.mono_set` to shrink to
  `[T, X] Ôèå [T0, X]` (the latter inclusion needs `T0 Ôëñ T`, which
  follows from `T0 Ôëñ 10 Ôëñ T`).

After this lands, the only field of `FiniteFluctuationLogEnvelopeData`
that remains unproved is `log_envelope_from_T` (the Turing/Backlund
bound). -/
theorem finiteFluctuationRegularityData_of_existing_integrability
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10) :
    FiniteFluctuationRegularityData D T0 := by
  refine Ôƒ¿?_, ?_Ôƒ®
  ┬À intro z T X h10 h140 hy hregime hTX
    exact discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
      D z.re z.im T0 T X hy
  ┬À intro z T X h10 h140 hy hregime hTX
    have hT0_le_T : T0 Ôëñ T := le_trans hT0_le_10 h10
    have hT0_le_X : T0 Ôëñ X := le_trans hT0_le_T hTX
    have h_big : IntervalIntegrable
        (fun u => Phase1IBP.smoothCountingPrimitive T0 u
                    * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T0 X :=
      Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
        hT0_pos hT0_le_X z.re hy
    have hsubset : Set.uIcc T X Ôèå Set.uIcc T0 X := by
      rw [Set.uIcc_of_le hTX, Set.uIcc_of_le hT0_le_X]
      intro u hu
      exact Ôƒ¿le_trans hT0_le_T hu.1, hu.2Ôƒ®
    exact h_big.mono_set hsubset

-- =====================================================================
-- ┬ºCCXXVI. Finite-fluctuation RealIBP from a Turing-style bound
-- =====================================================================
-- The handoff layer: composes ┬ºCCXXIV's `FiniteFluctuationLogEnvelopeData`
-- with ┬ºCCXXV's `finiteFluctuationRegularityData_of_existing_integrability`
-- so the only remaining xi-specific input is the Turing/Backlund log
-- envelope `hTuring`.
--
-- Adds:
--   finiteFluctuationLogEnvelopeData_of_turingBound      ÔÇö assemble the bundle
--   realIBPFamilyData_of_finiteFluctuation_turingBound   ÔÇö concrete RealIBPFamilyData
--   XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTail
--                                                        ÔÇö bundled capstone with
--                                                          Turing slot exposed
--
-- After ┬ºCCXXVI, the project's front door reads:
--   `hTuring` + Model + xi `hdecomp` + `TrueKernelTailData` + `LowHighBandCoverData`
--   Ôƒ╣ `XiPullbackAntiHerglotzTarget`.
-- The `hTuring` slot is the only remaining hard analytic input on the
-- real-IBP side; the parallel agent owns it.

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `FiniteFluctuationLogEnvelopeData` from a
Turing-style log envelope.** Assembles the bundle by passing
`hTuring` directly to the `log_envelope_from_T` field and discharging
`derivative_integrable` via ┬ºCCXXIV +
`finiteFluctuationRegularityData_of_existing_integrability`. -/
theorem finiteFluctuationLogEnvelopeData_of_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          Ôëñ (slabCD T).1 * Real.log u + (slabCD T).2) :
    FiniteFluctuationLogEnvelopeData D T0 where
  log_envelope_from_T := by
    intro z T u h10 h140 hy hregime hTu
    exact hTuring h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact finiteFluctuation_derivative_integrable_of_regular D T0
      (finiteFluctuationRegularityData_of_existing_integrability
        D T0 hT0_pos hT0_le_10)
      h10 h140 hy hregime hTX

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `RealIBPFamilyData` for the finite fluctuation
primitive, gated only by the Turing bound.** Composes ┬ºCCXXIV's
`realIBPFamilyData_of_finiteFluctuation` with
`finiteFluctuationLogEnvelopeData_of_turingBound`. -/
theorem realIBPFamilyData_of_finiteFluctuation_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 Ôëñ 10)
    (hTuring :
      ÔêÇ {z : Ôäé} {T u : ÔäØ},
        10 Ôëñ T ÔåÆ T Ôëñ 140 ÔåÆ 0 < z.im ÔåÆ
        2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        T Ôëñ u ÔåÆ
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
