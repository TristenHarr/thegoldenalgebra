            (canonicalAdaptiveT z) z).im)
    (htail_indep :
      ∀ {z : ℂ} {T₁ T₂ : ℝ},
        10 ≤ T₁ → T₁ ≤ 140 → 2 * (1 + |z.re| + z.im) ≤ T₁ →
        10 ≤ T₂ → T₂ ≤ 140 → 2 * (1 + |z.re| + z.im) ≤ T₂ →
        0 < z.im →
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring T₁ z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z).im)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_formulaPieces
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error
    (XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTail
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error
      hmodel hxi herror_canonical htail_indep)
    B

-- =====================================================================
-- §CCXLVI. Tail additivity and cutoff-change formula
-- =====================================================================
-- The raw improper tail genuinely depends on `T`. Before assuming any
-- form of `htail_indep`, we expose the exact cutoff-change relation:
--
--   tail(T₁) = ∫_{T₁}^{T₂} kernel·S + tail(T₂)
--
-- On Im, this lands on the real `derivativeSidePartial` and hence on
-- the integral of `S · pairedCauchyImKernelDeriv` — the explicit
-- finite-correction term that determines when (and only when) tail Im
-- is invariant in `T`.
--
-- Adds:
--   complexDensityTailPartial_add_adjacent                    — finite splitting
--   trueKernelAdaptiveTail_eq_finite_add_tail                 — limit additivity
--   trueKernelAdaptiveTail_im_sub_eq_finite_real_integral     — Im cutoff-change

/-- 🌟🌟 **PROVED — finite partial additivity.** Splits a finite
complex partial `[T₁, X]` across an intermediate cutoff `T₂`. Direct
application of `intervalIntegral.integral_add_adjacent_intervals`
after restricting the global integrability to each subinterval via
`IntervalIntegrable.mono_set`. -/
lemma complexDensityTailPartial_add_adjacent
    (kernel : ℝ → ℂ → ℂ) (S : ℝ → ℝ)
    {T₁ T₂ X : ℝ} (z : ℂ)
    (h12 : T₁ ≤ T₂) (h2X : T₂ ≤ X)
    (hInt :
      IntervalIntegrable
        (fun u => kernel u z * (S u : ℂ))
        MeasureTheory.volume T₁ X) :
    complexDensityTailPartial kernel S T₁ X z =
      complexDensityTailPartial kernel S T₁ T₂ z +
      complexDensityTailPartial kernel S T₂ X z := by
  unfold complexDensityTailPartial
  have h1X : T₁ ≤ X := le_trans h12 h2X
  have hInt_12 : IntervalIntegrable
      (fun u => kernel u z * (S u : ℂ))
      MeasureTheory.volume T₁ T₂ := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h12, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_right h2X
  have hInt_2X : IntervalIntegrable
      (fun u => kernel u z * (S u : ℂ))
      MeasureTheory.volume T₂ X := by
    refine hInt.mono_set ?_
    rw [Set.uIcc_of_le h2X, Set.uIcc_of_le h1X]
    exact Set.Icc_subset_Icc_left h12
  exact (intervalIntegral.integral_add_adjacent_intervals hInt_12 hInt_2X).symm

/-- 🌟🌟🌟🌟 **PROVED — `trueKernelAdaptiveTail` additivity across
adaptive cutoffs.** For `T₁ ≤ T₂` both in the adaptive band at `z`,

  `trueKernelAdaptiveTail T₁ z
     = finite[T₁,T₂] partial + trueKernelAdaptiveTail T₂ z`.

Proof: both tails are pointwise limits of complex partials; for
`X ≥ T₂` the partial at `T₁` splits via §CCXLVI-1; the finite
`[T₁, T₂]` partial is constant in `X`; uniqueness of limits closes. -/
theorem trueKernelAdaptiveTail_eq_finite_add_tail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : ℂ} {T₁ T₂ : ℝ}
    (h1 : 10 ≤ T₁) (h1' : T₁ ≤ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) ≤ T₁)
    (h2 : 10 ≤ T₂) (h2' : T₂ ≤ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) ≤ T₂)
    (h12 : T₁ ≤ T₂) :
    trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₁ z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z
      + trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z := by
  -- Local helper: convergence directly to `trueKernelAdaptiveTail ... T z`
  have hconv_at : ∀ {T : ℝ}, 10 ≤ T → T ≤ 140 →
      2 * (1 + |z.re| + z.im) ≤ T →
      Tendsto (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (𝓝 (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z)) := by
    intro T hT10 hT140 hTreg
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring hT10 hT140 hy hTreg
    have hregion :
        10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
      ⟨hT10, hT140, hy, hTreg⟩
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists
  have hT1_conv := hconv_at h1 h1' hr1
  have hT2_conv := hconv_at h2 h2' hr2
  have hsplit_ev : ∀ᶠ X : ℝ in Filter.atTop,
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ X z =
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z +
      complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₂ X z := by
    filter_upwards [Filter.eventually_ge_atTop T₂] with X hT2X
    have h1X : T₁ ≤ X := le_trans h12 hT2X
    have hInt :=
      true_int_of_finiteFluctuation
        Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h1X
    exact complexDensityTailPartial_add_adjacent
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z h12 hT2X hInt
  have h_const_finite :
      Tendsto (fun _ : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T₁ T₂ z) Filter.atTop
      (𝓝 (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z)) := tendsto_const_nhds
  have h_sum_tendsto :
      Tendsto (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T₁ T₂ z +
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T₂ X z) Filter.atTop
      (𝓝 (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z)) :=
    h_const_finite.add hT2_conv
  have hT1_to_sum :
      Tendsto (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T₁ X z) Filter.atTop
      (𝓝 (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z +
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z)) :=
    h_sum_tendsto.congr' (hsplit_ev.mono (fun X hX => hX.symm))
  exact tendsto_nhds_unique hT1_conv hT1_to_sum

/-- 🌟🌟🌟🌟🌟 **PROVED — cutoff-change formula on Im (the real
finite correction term).** Subtracting `Im` across the additivity
theorem lands on the explicit real integral

  `(tail T₁).im − (tail T₂).im
     = ∫_{T₁}^{T₂} S(u) · pairedCauchyImKernelDeriv z.re z.im u du`,

where `S = Phase1IBP.finiteFluctuationPrimitive Dzero T0`. This is the
honest cutoff-dependence — `htail_indep` holds (in Im) iff the RHS
vanishes; in general it does not, and any formula combining `model`
with `error` must absorb this finite correction. -/
theorem trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : ℂ} {T₁ T₂ : ℝ}
    (h1 : 10 ≤ T₁) (h1' : T₁ ≤ 140) (hy : 0 < z.im)
    (hr1 : 2 * (1 + |z.re| + z.im) ≤ T₁)
    (h2 : 10 ≤ T₂) (h2' : T₂ ≤ 140)
    (hr2 : 2 * (1 + |z.re| + z.im) ≤ T₂)
    (h12 : T₁ ≤ T₂) :
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₁ z).im -
    (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z).im
      = ∫ u in T₁..T₂,
          Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
            pairedCauchyImKernelDeriv z.re z.im u := by
  have hadd := trueKernelAdaptiveTail_eq_finite_add_tail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    h1 h1' hy hr1 h2 h2' hr2 h12
  have him_sum := congrArg Complex.im hadd
  simp only [Complex.add_im] at him_sum
  have him_diff :
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₁ z).im -
      (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T₂ z).im =
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        T₁ T₂ z).im := by
    linarith
  rw [him_diff]
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hInt_true := true_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_wrap := wrap_int_of_finiteFluctuation
    Dzero T0 hT0_pos hT0_le_10 h1 h1' hy hr1 h12
  have hInt_true_uhp : IntervalIntegrable
      (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im) *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
      MeasureTheory.volume T₁ T₂ := by
    rw [hzUHP]; exact hInt_true
  have hInt_wrap_uhp : IntervalIntegrable
      (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im) *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
      MeasureTheory.volume T₁ T₂ := by
    rw [hzUHP]; exact hInt_wrap
  have h_im_swap_uhp :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im T₁ T₂ hInt_true_uhp hInt_wrap_uhp
  rw [hzUHP] at h_im_swap_uhp
  rw [h_im_swap_uhp]
  have h_deriv_uhp :=
    complexDensityTailPartial_im_eq_derivativeSidePartial
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im T₁ T₂
  rw [hzUHP] at h_deriv_uhp
  rw [h_deriv_uhp]
  unfold Phase1IBP.derivativeSidePartial
  rfl

-- =====================================================================
-- §CCXLVII. Corrected cutoff-dependent error interface
-- =====================================================================
-- §CCXLVI proved that the raw improper tail is genuinely cutoff-
-- dependent: `(tail T₁).im - (tail T₂).im` equals an explicit finite
-- real integral. The §CCXLV `htail_indep` assumption is therefore
-- mathematically over-strong (it only holds when the finite correction
-- vanishes for every adaptive pair, which is not generally true).
--
-- This section provides the mathematically honest interface:
-- `herror` is specified at the canonical adaptive `T` plus an explicit
-- finite correction term that transports the canonical-tail Im to any
-- other adaptive `T` via §CCXLVI's cutoff-change law. No false
-- independence assumption.
--
-- Adds:
--   trueKernelTailCorrection                                       — finite real correction
--   HErrorCanonicalCorrected                                       — corrected Im claim
--   fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected           — bridge lemma
--   XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected   — corrected constructor
--   XiPullbackAntiHerglotzTarget_of_errorFormula_canonicalCorrected — corrected front door

/-- ⭐ **PROVED — generic explicit-integrand `intervalIntegral.integral_symm`.**
Wraps `intervalIntegral.integral_symm` with `f` as an explicit
parameter, supplied via named-argument `(f := f)`. Use this everywhere
instead of the underlying lemma: the underlying lemma leaves `f`
implicit, so calling it forces the unifier to infer `f` from the goal,
which can unfold heavy named definitions (`trueKernelTailCorrection`,
`finiteFluctuationPrimitive`, …) and trigger `whnf` timeouts.

Mathlib signature: `integral_symm (a b) : ∫ x in b..a, f x ∂μ = -∫ x in a..b, f x ∂μ`.
We swap endpoints so the LHS reads `∫ x in a..b`. -/
lemma intervalIntegral_symm_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (f : ℝ → E) (a b : ℝ) :
    (∫ x in a..b, f x) = - ∫ x in b..a, f x :=
  intervalIntegral.integral_symm (f := f) b a

/-- **Named integrand for `trueKernelTailCorrection`.** Top-level
`fun u => …` so the symmetry lemma below can pass it as an explicit
argument to `intervalIntegral_symm_apply` without making Lean unfold
the heavy correction definition. -/
noncomputable def trueKernelTailCorrectionIntegrand
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ) (z : ℂ) :
    ℝ → ℝ :=
  fun u =>
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
      pairedCauchyImKernelDeriv z.re z.im u

/-- **Finite real cutoff-correction.** The explicit `[Tc, T]`
real integral whose value differs between any two adaptive-cutoff
`trueKernelAdaptiveTail` Im values at `z`. From §CCXLVI:

  `(trueKernelAdaptiveTail Tc z).im − (trueKernelAdaptiveTail T z).im
      = trueKernelTailCorrection Tc T z`     when `Tc ≤ T`.

For `T ≤ Tc`, `trueKernelTailCorrection_symm` flips the sign so the
identity recovers in the other orientation. The integrand is supplied
via the named top-level `trueKernelTailCorrectionIntegrand` so the
symmetry lemma can avoid a `whnf` explosion on Mathlib's
`intervalIntegral.integral_symm`. -/
noncomputable def trueKernelTailCorrection
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (Tc T : ℝ) (z : ℂ) : ℝ :=
  ∫ u in Tc..T, trueKernelTailCorrectionIntegrand Dzero T0 z u

/-- ⭐ **PROVED — symmetry of the cutoff correction.** Cheap proof:
the integrand is now a named top-level term, so
`intervalIntegral_symm_apply` receives `f` explicitly and Lean never
needs to unfold heavy definitions during unification. -/
theorem trueKernelTailCorrection_symm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 a b : ℝ) (z : ℂ) :
    trueKernelTailCorrection Dzero T0 a b z =
      - trueKernelTailCorrection Dzero T0 b a z := by
  unfold trueKernelTailCorrection
  exact intervalIntegral_symm_apply
    (trueKernelTailCorrectionIntegrand Dzero T0 z) a b

/-- **Corrected canonical-T herror claim.** Compared to §CCXLV's
`herror_canonical`, this version explicitly carries the finite
cutoff-correction term that absorbs the difference between the raw
tail at the canonical adaptive `T` and the raw tail at the
package-supplied `T`. No tail Im-independence is asserted. -/
def HErrorCanonicalCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : ℂ → ℂ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    10 ≤ T → T ≤ 140 → 0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
    (error z).im =
      (trueKernelAdaptiveTail
        Dzero T0 hT0_pos hT0_le_10 hTuring
        (canonicalAdaptiveT z) z).im
      -
      trueKernelTailCorrection
        Dzero T0 (canonicalAdaptiveT z) T z

/-- 🌟🌟🌟 **PROVED — bridge from `HErrorCanonicalCorrected` to
arbitrary-T Im match.** Routes through §CCXLVI's
`trueKernelAdaptiveTail_im_sub_eq_finite_real_integral` with case
analysis on whether `canonicalAdaptiveT z ≤ T` or `T ≤ canonicalAdaptiveT z`.
In the second case `intervalIntegral.integral_symm` flips the sign so
the same final formula recovers. -/
theorem fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : ℂ → ℂ)
    (herror_corr : HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error) :
    ∀ {z : ℂ} {T : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (error z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring T z).im := by
  intro z T h10 h140 hy hregime
  have hExists : ∃ T : ℝ,
      10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
    ⟨T, h10, h140, hregime⟩
  have hc := canonicalAdaptiveT_spec hExists
  have hcorr := herror_corr h10 h140 hy hregime
  rw [hcorr]
  by_cases hle : canonicalAdaptiveT z ≤ T
  · -- canonical ≤ T case: direct application of §CCXLVI
    have hadd_im :=
      trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
        Dzero T0 hT0_pos hT0_le_10 hTuring
        hc.1 hc.2.1 hy hc.2.2 h10 h140 hregime hle
    simp only [trueKernelTailCorrection, trueKernelTailCorrectionIntegrand]
    rw [← hadd_im]
    ring
  · -- T < canonical case: use §CCXLVI with swapped endpoints + the
    -- named `trueKernelTailCorrection_symm` (avoids rewriting raw
    -- `intervalIntegral.integral_symm` inside the full goal — that
    -- forces the unifier to unfold tail/kernel definitions and times out).
    push_neg at hle
    have hle' : T ≤ canonicalAdaptiveT z := le_of_lt hle
    have hadd_im :=
      trueKernelAdaptiveTail_im_sub_eq_finite_real_integral
        Dzero T0 hT0_pos hT0_le_10 hTuring
        h10 h140 hy hregime hc.1 hc.2.1 hc.2.2 hle'
    rw [trueKernelTailCorrection_symm Dzero T0 (canonicalAdaptiveT z) T z]
    simp only [trueKernelTailCorrection, trueKernelTailCorrectionIntegrand]
    rw [← hadd_im]
    ring

/-- 🌟🌟 **PROVED — `XiLogDerivativeFormulaPieces` from corrected
canonical-T herror.** Like `ofErrorAsCanonicalTail`, but uses
`HErrorCanonicalCorrected` (carrying the explicit finite correction
from §CCXLVI) instead of the over-strong `htail_indep`. The
`fluctTail_im_eq_trueTail` field is recovered through the bridge
theorem above. -/
noncomputable def XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (hmodel : ∀ z : ℂ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_corr : HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error) :
    XiLogDerivativeFormulaPieces
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error :=
  XiLogDerivativeFormulaPieces.ofErrorAsFluctTail
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M Tsmooth hTsmooth_ge error
    hmodel hxi
    (by
      intro z T h10 h140 hy hregime
      exact fluctTail_im_eq_trueTail_of_HErrorCanonicalCorrected
        Dzero T0 hT0_pos hT0_le_10 hTuring error herror_corr
        h10 h140 hy hregime)

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **CLEANEST FRONT DOOR (mathematically
honest cutoff handling).** Replaces
`XiPullbackAntiHerglotzTarget_of_errorFormula_canonical` with the
corrected cutoff-dependence interface. No `htail_indep` hypothesis —
the cutoff correction is carried explicitly by `herror_corr`
(`HErrorCanonicalCorrected`). -/
theorem XiPullbackAntiHerglotzTarget_of_errorFormula_canonicalCorrected
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (hmodel : ∀ z : ℂ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z)
    (herror_corr : HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_formulaPieces
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error
    (XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error
      hmodel hxi herror_corr)
    B

-- =====================================================================
-- §CCXLVIII. Xi log-derivative formula data (identity-decomposition scaffold)
-- =====================================================================
-- Packages the three remaining xi-specific identities into a single
-- Prop-structure `XiLogDerivativeFormulaData`, matched to the §CCXLVII
-- corrected canonical-T front door. This is the **clean final target**
-- for the xi analytic argument: a single named bundle of three
-- propositions whose inhabitation immediately yields
-- `XiPullbackAntiHerglotzTarget` (modulo Turing + LowHighBandData).
--
-- Adds:
--   ErrorMatchesCanonicalCorrectedTail    — alias of HErrorCanonicalCorrected
--   XiLogDerivativeFormulaData            — Prop-structure (3 identity fields)
--   XiLogDerivativeFormulaData.to_formulaPieces
--   XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData

/-- **Error-matches-canonical-corrected-tail.** Alias for
`HErrorCanonicalCorrected` with a name that reads as a property of
`error` rather than as a definition of a corrected hypothesis. Useful
when stating the xi analytic target. -/
def ErrorMatchesCanonicalCorrectedTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (error : ℂ → ℂ) : Prop :=
  HErrorCanonicalCorrected Dzero T0 hT0_pos hT0_le_10 hTuring error

/-- 📦 **`XiLogDerivativeFormulaData`** — the **clean final xi-specific
target** for `XiPullbackAntiHerglotzTarget` (modulo Turing/Backlund and
`LowHighBandData`). Bundles the three identities that the xi analytic
argument must produce, aligned to the §CCXLVII corrected cutoff law:

* `hmodel`     — `M.model = pairedFiniteCloud + zeroDensitySmoothTail`
* `hxi`        — `Λ[Ξ] z = pairedFiniteCloud z + zeroDensitySmoothTail z + error z`
                 on the adaptive mid-band
* `herror_corr` — `(error z).im = (canonical tail z).im − finite correction(canonical, T)(z)`

Once a single inhabitant of this structure is produced, the front-door
theorem `XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData`
closes everything. -/
structure XiLogDerivativeFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ) : Prop where
  /-- Model decomposition equation — usually definitional once `M.zeros`
  is set to `us` and `M.densityTail` is set to `zeroDensitySmoothTailModel`. -/
  hmodel :
    ∀ z : ℂ,
      M.model z =
        pairedFiniteCloudFromZeros us z +
          zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z
  /-- Main xi log-derivative formula on the adaptive mid-band. -/
  hxi :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      logDerivativeResponse XiPullback z =
        pairedFiniteCloudFromZeros us z +
          zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
            error z
  /-- Corrected canonical-T tail-imaginary identity (§CCXLVII). -/
  herror_corr :
    HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring error

/-- 🌟🌟 **PROVED — `XiLogDerivativeFormulaPieces` from
`XiLogDerivativeFormulaData`.** Forwards all three identity fields
to `XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected`. -/
noncomputable def XiLogDerivativeFormulaData.to_formulaPieces
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {hT0_pos : 0 < T0} {hT0_le_10 : T0 ≤ 10}
    {hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2}
    {us : List ℝ}
    {M : CloudDensityTailModelDecomposition}
    {Tsmooth : ℝ} {hTsmooth_ge : 2 * Real.pi ≤ Tsmooth}
    {error : ℂ → ℂ}
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error) :
    XiLogDerivativeFormulaPieces
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error :=
  XiLogDerivativeFormulaPieces.ofErrorAsCanonicalTailCorrected
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M Tsmooth hTsmooth_ge error
    F.hmodel F.hxi F.herror_corr

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **CLEANEST FINAL FRONT DOOR.**
The full Route B conditional capstone now reads:

  `XiLogDerivativeFormulaData + LowHighBandData ⟹ XiPullbackAntiHerglotzTarget`

(modulo the `hTuring` Turing/Backlund bound and `M.zeros = zeros100ceil`).
The only substantive xi-specific obligations are the three fields of
`XiLogDerivativeFormulaData`. -/
theorem XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_errorFormula_canonicalCorrected
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error
    F.hmodel F.hxi F.herror_corr B

-- =====================================================================
-- §CCXLIX. Light low/high band wrappers + geometric cover lemmas
-- =====================================================================
-- `LowHighBandData` already exists (§CCXXXIII) with the right shape:
-- `lowPackage`, `highPackage`, and an inline three-way `covers` field
-- that is propositionally identical to the `LowMidHighCover` Prop
-- introduced here. This section adds only the *names* needed for the
-- minimal Route B front door and one geometric lemma reducing the
-- cover obligation to a `high.region`-complement witness.
--
-- After §CCXLIX, the minimal Route B front door reads:
--
--   hTuring
--   + F  : XiLogDerivativeFormulaData
--   + low high : LocalXiCloudDensityErrorPackage
--   + hcover : LowMidHighCover low high
--   ⟹ XiPullbackAntiHerglotzTarget
--
-- The remaining analytic obligations:
--   (a) inhabit `F` (xi analytic formula);
--   (b) inhabit `low` and `high` analytic packages;
--   (c) prove `hcover` (geometric cover).
--
-- Adds:
--   LowMidHighCover                                                 — named cover Prop
--   LowHighBandData.ofLowHighPackages                               — raw-package constructor
--   XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_lowHighPackages
--   midRegion_iff_le_140                                            — mid-band ↔ 2(...) ≤ 140
--   lowMidHighCover_of_high_complement                              — cover from high-complement

/-- **`LowMidHighCover low high`** — for every UHP point, either it
lies in the adaptive mid-band (some `T ∈ [10, 140]` exists with
`2(1 + |z.re| + z.im) ≤ T`), or it lies in `low.region`, or it lies in
`high.region`. Propositionally identical to the inline `covers` field
of `LowHighBandData` (§CCXXXIII); kept as a named Prop so analytic
statements stay readable. -/
def LowMidHighCover
    (low high : LocalXiCloudDensityErrorPackage) : Prop :=
  ∀ z : ℂ, 0 < z.im →
    (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) ∨
    low.region z ∨
    high.region z

/-- ⭐ **PROVED — `LowHighBandData` from raw low/high packages + cover.**
The most direct interface for the analytic step: no wrapper-structure
ceremony. -/
def LowHighBandData.ofLowHighPackages
    (low high : LocalXiCloudDensityErrorPackage)
    (hcover : LowMidHighCover low high) :
    LowHighBandData where
  lowPackage  := low
  highPackage := high
  covers      := hcover

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR.**

  `hTuring + F : XiLogDerivativeFormulaData + low/high + hcover
     ⟹ XiPullbackAntiHerglotzTarget`

All scaffolding is now hidden. The substantive remaining obligations
are exactly:
  • `F` (xi log-derivative identities);
  • `low`, `high` (low/high local analytic packages);
  • `hcover` (three-way cover of the open upper half-plane). -/
theorem XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_lowHighPackages
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error)
    (low high : LocalXiCloudDensityErrorPackage)
    (hcover : LowMidHighCover low high) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error F
    (LowHighBandData.ofLowHighPackages low high hcover)

/-- ⭐ **PROVED — mid-region equivalent to a single inequality on `z`.**
The adaptive mid-band existential collapses to the simple `≤ 140`
check: if `2(1 + |z.re| + z.im) ≤ 140` then `T := max 10 …` works.
Reduces the cover obligation to a single decidable real inequality
per point. -/
lemma midRegion_iff_le_140 (z : ℂ) :
    (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T)
      ↔ 2 * (1 + |z.re| + z.im) ≤ 140 := by
  constructor
  · rintro ⟨T, _, h140, hregime⟩
    exact le_trans hregime h140
  · intro h
    refine ⟨max 10 (2 * (1 + |z.re| + z.im)), ?_, ?_, ?_⟩
    · exact le_max_left _ _
    · exact max_le (by norm_num) h
    · exact le_max_right _ _

/-- 🌟 **PROVED — cover from a `high`-region complement witness.**
If `high.region` absorbs every UHP point outside the mid-band, then
`LowMidHighCover low high` holds for any `low` whatsoever. Isolates
the cover obligation from the low-package construction. -/
lemma lowMidHighCover_of_high_complement
    (low high : LocalXiCloudDensityErrorPackage)
    (hhigh :
      ∀ z : ℂ, 0 < z.im →
        ¬ (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
              2 * (1 + |z.re| + z.im) ≤ T) →
        high.region z) :
    LowMidHighCover low high := by
  intro z hz
  by_cases hmid :
      ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T
  · exact Or.inl hmid
  · exact Or.inr (Or.inr (hhigh z hz hmid))

-- =====================================================================
-- §CCL. High-band `LocalXiCloudDensityErrorPackage` (Route A → Route B)
-- =====================================================================
-- Wraps Route A's high-band model-margin chain
-- (`highTClosedFormBound_le_neg_model_im` + `highTErrorControlled` +
-- `highT_errorMargin_of_highTErrorControlled`) into a
-- `LocalXiCloudDensityErrorPackage` whose `region` is the *complement*
-- of the adaptive mid-band. Designed to slot directly into Route B's
-- `LowMidHighCover` via §CCXLIX-5 `lowMidHighCover_of_high_complement`.
--
-- Adds:
--   highComplementRegion                                — high region (¬ mid)
--   exists_highT                                        — admissible T ≥ 140 for any UHP z
--   highLocalPackage_of_highTErrorControlled            — Route B high wrapper

/-- **High-region predicate.** The complement (within the open upper
half-plane) of the adaptive mid-band: equivalent to
`140 < 2 * (1 + |z.re| + z.im)` (via §CCXLIX.4 `midRegion_iff_le_140`).
Designed so that
`lowMidHighCover_of_high_complement` discharges the three-way cover
for the package built below. -/
def highComplementRegion (z : ℂ) : Prop :=
  ¬ ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T

/-- ⭐ **PROVED — admissible adaptive `T ≥ 140` for any UHP point.**
Take `T := max 140 (2 * (1 + |z.re| + z.im))`. Works regardless of
whether `z` is in the high-region complement; this lemma is what makes
the high-band `errorMargin` chain go through. -/
lemma exists_highT (z : ℂ) :
    ∃ T : ℝ, 140 ≤ T ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
  ⟨max 140 (2 * (1 + |z.re| + z.im)),
    le_max_left _ _, le_max_right _ _⟩

/-- 🌟🌟🌟 **PROVED — high-band `LocalXiCloudDensityErrorPackage`** from
Route A's high-band model-margin chain. Takes:
* `M, hzeros, hmodelAnti` — cloud-density model;
* `error, hdecomp` — user-supplied global decomposition;
* `hhigh : highTErrorControlled error` — IBP-side error bound on `T ≥ 140`.

Produces a local package with `region := highComplementRegion`. The
`errorMargin` field picks `T := max 140 (2(1+|z.re|+z.im))` per `z` and
applies `highT_errorMargin_of_highTErrorControlled`. -/
noncomputable def highLocalPackage_of_highTErrorControlled
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hhigh : highTErrorControlled error) :
    LocalXiCloudDensityErrorPackage where
  model := M.model
  error := error
  region := highComplementRegion
  decomp := fun z _ => hdecomp z
  modelAnti := hmodelAnti
  errorMargin := by
    intro z _ hz
    obtain ⟨T, hT140, hregime⟩ := exists_highT z
    exact highT_errorMargin_of_highTErrorControlled
      (M := M) (error := error)
      hzeros hhigh hT140 hz hregime

/-- 🌟🌟🌟 **PROVED — guarded high-band `LocalXiCloudDensityErrorPackage`.**
Same shape as `highLocalPackage_of_highTErrorControlled`, but takes the
guarded predicate `highTErrorControlledAwayFromZeros` and splits the
`errorMargin` field internally on `XiPullback z = 0`. The zero case is
discharged by `errorMargin_at_XiPullback_zero_of_decomp` (pure algebra
from the totalization `Λ[Ξ] z = 0`). The nonzero case calls the
guarded margin bridge. -/
noncomputable def highLocalPackage_of_highTErrorControlledAwayFromZeros
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hhigh : highTErrorControlledAwayFromZeros error) :
    LocalXiCloudDensityErrorPackage where
  model := M.model
  error := error
  region := highComplementRegion
  decomp := fun z _ => hdecomp z
  modelAnti := hmodelAnti
  errorMargin := by
    intro z _ hz
    by_cases hzero : XiPullback z = 0
    · exact errorMargin_at_XiPullback_zero_of_decomp
        hmodelAnti hdecomp hz hzero
    · obtain ⟨T, hT140, hregime⟩ := exists_highT z
      exact highT_errorMargin_of_highTErrorControlledAwayFromZeros
        (M := M) (error := error)
        hzeros hhigh hT140 hz hregime hzero

-- =====================================================================
-- §CCLI. Low-band `LocalXiCloudDensityErrorPackage` (abstract wrapper)
-- =====================================================================
-- Wraps a `FirstZeroDirectBandCertificate` (still uninhabited
-- analytically) + `lowTErrorControlled` IBP hypothesis into a
-- `LocalXiCloudDensityErrorPackage` with `region := lowRegion`. This
-- does **not** prove the low band — it only matches Route B's
-- interface to Route A's existing abstract low-band hypotheses.
--
-- Adds:
--   lowRegion                                           — low-band Prop on z
--   lowLocalPackage_of_firstZeroDirect                  — Route B low wrapper

/-- **Low-region predicate.** UHP points admissible by some adaptive
`T ∈ [2π, 10]` (the pre-first-zero band). Concretely equivalent to
`2 * (1 + |z.re| + z.im) ≤ 10`, but kept as the existential form to
match `FirstZeroDirectBandCertificate.cert`. -/
def lowRegion (z : ℂ) : Prop :=
  ∃ T : ℝ, 2 * Real.pi ≤ T ∧ T ≤ 10 ∧ 2 * (1 + |z.re| + z.im) ≤ T

/-- 🌟🌟 **PROVED — low-band `LocalXiCloudDensityErrorPackage`** from a
`FirstZeroDirectBandCertificate` matched to `M.model` on `[2π, 10]`
and a user-supplied `error` with global decomposition + IBP-side
`lowTErrorControlled`. Does not inhabit the underlying first-zero
certificate — that's the genuine analytic obligation. -/
noncomputable def lowLocalPackage_of_firstZeroDirect
    (M : CloudDensityTailModelDecomposition)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi) (hF_B : F.B = 10)
    (hF_model : F.model = M.model)
    (hlow : lowTErrorControlled error F.errorBound) :
    LocalXiCloudDensityErrorPackage where
  model := M.model
  error := error
  region := lowRegion
  decomp := fun z _ => hdecomp z
  modelAnti := hmodelAnti
  errorMargin := by
    intro z hreg hz
    obtain ⟨T, hT2pi, hT10, hregime⟩ := hreg
    exact lowT_errorMargin_of_firstZeroDirect
      (M := M) (error := error)
      F hF_A hF_B hF_model hlow hT2pi hT10 hz hregime

/-- 🌟🌟 **PROVED — guarded low-band `LocalXiCloudDensityErrorPackage`.**
Same shape as `lowLocalPackage_of_firstZeroDirect`, but takes the
guarded predicate `lowTErrorControlledAwayFromZeros` and splits the
`errorMargin` field internally on `XiPullback z = 0`. -/
noncomputable def lowLocalPackage_of_firstZeroDirectAwayFromZeros
    (M : CloudDensityTailModelDecomposition)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi) (hF_B : F.B = 10)
    (hF_model : F.model = M.model)
    (hlow : lowTErrorControlledAwayFromZeros error F.errorBound) :
    LocalXiCloudDensityErrorPackage where
  model := M.model
  error := error
  region := lowRegion
  decomp := fun z _ => hdecomp z
  modelAnti := hmodelAnti
  errorMargin := by
    intro z hreg hz
    by_cases hzero : XiPullback z = 0
    · exact errorMargin_at_XiPullback_zero_of_decomp
        hmodelAnti hdecomp hz hzero
    · obtain ⟨T, hT2pi, hT10, hregime⟩ := hreg
      exact lowT_errorMargin_of_firstZeroDirectAwayFromZeros
        (M := M) (error := error)
        F hF_A hF_B hF_model hlow hT2pi hT10 hz hregime hzero

-- =====================================================================
-- §CCLII. Route A bands → Route B front door
-- =====================================================================
-- Feeds Route A's mature analytic hypotheses
-- (`FirstZeroDirectBandCertificate` + `lowTErrorControlled` +
-- `highTErrorControlled`) directly into the Route B
-- `XiLogDerivativeFormulaData`-based front door. The cover obligation
-- is discharged automatically via the
-- `high.region = highComplementRegion` shape using §CCXLIX-5
-- `lowMidHighCover_of_high_complement`.
--
-- Adds:
--   XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABands

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR via
Route A bands.** Combines:
* the Route B identity layer `F : XiLogDerivativeFormulaData ...`;
* Route A's abstract low-band hypothesis
  (`FirstZeroDirectBandCertificate` + `lowTErrorControlled`);
* Route A's high-band IBP-side hypothesis (`highTErrorControlled`);
* a global decomposition `hdecomp : ∀ z, Λ[Ξ] z = M.model z + error z`
  (typically definitional via `error := Λ - M.model`).

The cover is discharged automatically by
`lowMidHighCover_of_high_complement`, since the high package's region
is `highComplementRegion` by construction. -/
theorem XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABands
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error)
    (lowCert : FirstZeroDirectBandCertificate)
    (hlowCert_A : lowCert.A = 2 * Real.pi)
    (hlowCert_B : lowCert.B = 10)
    (hlowCert_model : lowCert.model = M.model)
    (hlow : lowTErrorControlled error lowCert.errorBound)
    (hhigh : highTErrorControlled error) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_lowHighPackages
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error F
    (lowLocalPackage_of_firstZeroDirect
      M hmodelAnti error hdecomp
      lowCert hlowCert_A hlowCert_B hlowCert_model hlow)
    (highLocalPackage_of_highTErrorControlled
      M hzeros hmodelAnti error hdecomp hhigh)
    (lowMidHighCover_of_high_complement
      (lowLocalPackage_of_firstZeroDirect
        M hmodelAnti error hdecomp
        lowCert hlowCert_A hlowCert_B hlowCert_model hlow)
      (highLocalPackage_of_highTErrorControlled
        M hzeros hmodelAnti error hdecomp hhigh)
      (by
        intro z _ hmid
        -- high.region z = highComplementRegion z = ¬ mid z
        exact hmid))

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **GUARDED MINIMAL ROUTE B FRONT DOOR
via Route A bands.** Same conclusion as
`XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABands`
but the analytic error-control hypotheses `hlow` / `hhigh` are the
guarded variants `lowTErrorControlledAwayFromZeros` /
`highTErrorControlledAwayFromZeros`.

Why prefer this version. The unguarded predicates quantify through any
hypothetical UHP zero of Ξ, where Lean's `a / 0 = 0` totalization forces
`|Im(error z)| = -Im(model z)` exactly, which contradicts the
certificate's strict slack. Discharging the unguarded predicates
therefore requires ruling out UHP zeros — i.e. RH — which collapses the
reduction. The guarded predicates only ask for the analytic bound where
`XiPullback z ≠ 0`; the zero case is dispatched internally by
`errorMargin_at_XiPullback_zero_of_decomp` via the totalization algebra.
This is the version Path B should be threaded through. -/
theorem XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABandsAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge error)
    (lowCert : FirstZeroDirectBandCertificate)
    (hlowCert_A : lowCert.A = 2 * Real.pi)
    (hlowCert_B : lowCert.B = 10)
    (hlowCert_model : lowCert.model = M.model)
    (hlow : lowTErrorControlledAwayFromZeros error lowCert.errorBound)
    (hhigh : highTErrorControlledAwayFromZeros error) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_lowHighPackages
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge error F
    (lowLocalPackage_of_firstZeroDirectAwayFromZeros
      M hmodelAnti error hdecomp
      lowCert hlowCert_A hlowCert_B hlowCert_model hlow)
    (highLocalPackage_of_highTErrorControlledAwayFromZeros
      M hzeros hmodelAnti error hdecomp hhigh)
    (lowMidHighCover_of_high_complement
      (lowLocalPackage_of_firstZeroDirectAwayFromZeros
        M hmodelAnti error hdecomp
        lowCert hlowCert_A hlowCert_B hlowCert_model hlow)
      (highLocalPackage_of_highTErrorControlledAwayFromZeros
        M hzeros hmodelAnti error hdecomp hhigh)
      (by
        intro z _ hmid
        exact hmid))

-- =====================================================================
-- §CCLIII. Generic true-kernel complex tail convergence (log envelope)
-- =====================================================================
-- `trueKernelComplexTail_converges_at` (§CCXXIX-4b) is hard-wired to the
-- mid-band `10 ≤ T ≤ 140` with `slabCD T` constants. The underlying
-- infrastructure
-- (`trueKernelLogMajorantConverges`, `improperComplexIntegralConverges_of_normMajorant`,
-- `trueKernel_integrand_norm_le_logMajorant_eventually`,
-- `finiteFluctuationPrimitive_trueKernel_intervalIntegrable`) is already
-- fully generic over `C, D, T > 0`. This section lifts the convergence
-- theorem itself to that level of generality, freeing the downstream
-- high-band machinery (§CCLIV onward) from mid-band constraints.
--
-- The mid-band specialization `trueKernelComplexTail_converges_at` is
-- preserved; this is an additional, more general theorem.
--
-- Adds:
--   trueKernelComplexTail_converges_at_of_logEnvelope

/-- 🌟🌟🌟🌟 **PROVED — generic true-kernel complex tail convergence
from a log envelope.** Same conclusion as §CCXXIX-4b's
`trueKernelComplexTail_converges_at`, but with `(C, D)` arbitrary and
no mid-band constraint on `T`. Required hypotheses:

* `T0 ≤ T` so the finite-fluctuation primitive is locally integrable on
  every `[T, X]`;
* `0 < T` so the log majorant's primitive vanishes at infinity;
* `0 < z.im` so the kernel is continuous on the integration window;
* an eventual log envelope `|finiteFluctuationPrimitive Dzero T0 u| ≤
  C · log u + D` for large `u`.

Specializes to the mid-band version (with `(C, D) = slabCD T`) when
`10 ≤ T ≤ 140` and the Turing bound holds; specializes to the high-band
version (with `(C, D) = (1/2, 49/20)`) when `T ≥ 140` and the Turing
bound is available there. -/
theorem trueKernelComplexTail_converges_at_of_logEnvelope
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0)
    {C D T : ℝ} {z : ℂ}
    (hT0_le_T : T0 ≤ T) (hTpos : 0 < T) (hy : 0 < z.im)
    (hSlogEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ C * Real.log u + D) :
    ∃ L : ℂ,
      Tendsto
        (fun X : ℝ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop (𝓝 L) := by
  have hMconv :
      Tendsto (fun X : ℝ =>
          ∫ u in T..X, trueKernelLogMajorant C D u)
        Filter.atTop
        (𝓝 (-trueKernelLogMajorantPrimitive C D T)) :=
    trueKernelLogMajorantConverges C D T hTpos
  have hbound_uhp :=
    trueKernel_integrand_norm_le_logMajorant_eventually
      (S := fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (C := C) (D := D) (x := z.re) (y := z.im) hSlogEnv
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hbound :
      ∀ᶠ u in Filter.atTop,
        ‖pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ)‖
          ≤ trueKernelLogMajorant C D u := by
    filter_upwards [hbound_uhp] with u hu
    rw [hzUHP] at hu
    exact hu
  apply improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      pairedCauchyComplexKernelTrue u z *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
    (M := trueKernelLogMajorant C D)
    (T := T)
    (LM := -trueKernelLogMajorantPrimitive C D T)
  · intro X hTX
    exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
      Dzero T0 T X z hT0_pos hT0_le_T hTX (ne_of_gt hy)
  · intro X hTX
    exact trueKernelLogMajorant_intervalIntegrable C D T X hTpos hTX
  · exact hMconv
  · exact hbound

-- =====================================================================
-- §CCLIV. Generic true-kernel tail value + tendsto (log envelope)
-- =====================================================================
-- §CCLIII's `trueKernelComplexTail_converges_at_of_logEnvelope` gives
-- `∃ L, Tendsto ... (𝓝 L)`. This section pins the chosen `L` as a
-- named value `trueKernelTailOfLogEnvelope C D T z` via
-- `Classical.choose`, and exposes the spec as a tendsto lemma. The
-- subsequent §CCLV Im-bound chain targets this named value.
--
-- Adds:
--   trueKernelTailOfLogEnvelope             — Classical.choose of the limit
--   trueKernelTailOfLogEnvelope_tendsto     — choose_spec

/-- **Generic true-kernel tail value from a log envelope.** The chosen
limit of the complex partials `complexDensityTailPartial
pairedCauchyComplexKernelTrue finiteFluctuationPrimitive T X z` as
`X → ∞`, extracted from §CCLIII via `Classical.choose`. Hypotheses
pass straight through to
`trueKernelComplexTail_converges_at_of_logEnvelope`; no extra
constraints needed at this layer. -/
noncomputable def trueKernelTailOfLogEnvelope
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0)
    {C D T : ℝ} {z : ℂ}
    (hT0_le_T : T0 ≤ T) (hTpos : 0 < T) (hy : 0 < z.im)
    (hSlogEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ C * Real.log u + D) : ℂ :=
  Classical.choose
    (trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv)

/-- 🌟 **PROVED — partials converge to `trueKernelTailOfLogEnvelope`.**
Direct `Classical.choose_spec` of §CCLIII's existence theorem. -/
theorem trueKernelTailOfLogEnvelope_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0)
    {C D T : ℝ} {z : ℂ}
    (hT0_le_T : T0 ≤ T) (hTpos : 0 < T) (hy : 0 < z.im)
    (hSlogEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ C * Real.log u + D) :
    Tendsto
      (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (𝓝 (trueKernelTailOfLogEnvelope
        Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv)) :=
  Classical.choose_spec
    (trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv)

-- =====================================================================
-- §CCLV-1. Generic real integrability of `finiteFluctuationPrimitive · k'`
-- =====================================================================
-- `finiteFluctuation_derivative_integrable_of_regular` (§CCXXIV) is
-- mid-band-restricted **in its type signature**, although the proof
-- only uses `T0 ≤ T`. This section provides the lifted, fully-generic
-- version: real integrability of `finiteFluctuationPrimitive · k'` on
-- `[T, X]` for any `T0 ≤ T ≤ X` and `0 < y`.
--
-- Adds:
--   finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic

/-- 🌟🌟 **PROVED — generic real `finiteFluctuationPrimitive · k'`
integrability.** Mirrors `finiteFluctuation_derivative_integrable_of_regular`
without the `10 ≤ T ≤ 140` constraint. Uses
`discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow`
(already generic) for the discrete part and
`Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
on `[T0, X]` + `IntervalIntegrable.mono_set` for the smooth part. -/
theorem finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 T X x y : ℝ)
    (hT0_pos : 0 < T0)
    (hT0_le_T : T0 ≤ T)
    (hTX : T ≤ X)
    (hy : 0 < y) :
    IntervalIntegrable
      (fun u =>
        Phase1IBP.finiteFluctuationPrimitive Dzero T0 u *
          pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have hN : IntervalIntegrable
      (fun u =>
        Phase1IBP.discreteCountingPrimitive Dzero.toFluctuationMeasureData T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X :=
    discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
      Dzero x y T0 T X hy
  have hT0_le_X : T0 ≤ X := le_trans hT0_le_T hTX
  have hS_big : IntervalIntegrable
      (fun u =>
        Phase1IBP.smoothCountingPrimitive T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T0 X :=
    Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
      hT0_pos hT0_le_X x hy
  have hS : IntervalIntegrable
      (fun u =>
        Phase1IBP.smoothCountingPrimitive T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
    refine hS_big.mono_set ?_
    rw [Set.uIcc_of_le hTX, Set.uIcc_of_le hT0_le_X]
    exact Set.Icc_subset_Icc_left hT0_le_T
  have hfunc_eq :
      (fun u =>
        Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
          * pairedCauchyImKernelDeriv x y u)
      = (fun u =>
          Phase1IBP.discreteCountingPrimitive Dzero.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv x y u
          - Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv x y u) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    ring
  rw [hfunc_eq]
  exact hN.sub hS

-- =====================================================================
-- §CCLV-2. Im of `trueKernelTailOfLogEnvelope` ↔ real derivative partial
-- =====================================================================
-- The real derivative-side partial converges to the Im of the chosen
-- complex tail. Routes through §CCLIV (tail tendsto) + Im commuting
-- with the limit + §CCXXX-style eventual finite-Im identity. Uses
-- §CCLV-1 for the real integrability needed by the wrap-kernel bridge.
--
-- Adds:
--   trueKernelTailOfLogEnvelope_im_tendsto_realPartial

/-- 🌟🌟🌟 **PROVED — derivative-side partial tends to `Im` of the
generic true-kernel tail.** Composition:
1. complex tail tendsto (§CCLIV);
2. `Complex.continuous_im` commutes with the limit;
3. eventual finite-Im identity (`trueKernel_im_eq_realPartial_eventually`,
   fed with §CCLV-1 real integrability and the wrap-kernel bridge);
4. `Tendsto.congr'` transports the limit. -/
theorem trueKernelTailOfLogEnvelope_im_tendsto_realPartial
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0)
    {C D T : ℝ} {z : ℂ}
    (hT0_le_T : T0 ≤ T) (hTpos : 0 < T) (hy : 0 < z.im)
    (hSlogEnv :
      ∀ᶠ u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ C * Real.log u + D) :
    Tendsto
      (fun X : ℝ =>
        Phase1IBP.derivativeSidePartial
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          z.re z.im T X)
      Filter.atTop
      (𝓝 (trueKernelTailOfLogEnvelope
        Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv).im) := by
  have hcomplex := trueKernelTailOfLogEnvelope_tendsto
    Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv
  have him_complex :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop
        (𝓝 (trueKernelTailOfLogEnvelope
          Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv).im) :=
    (Complex.continuous_im.tendsto _).comp hcomplex
  have htrue_int : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
        MeasureTheory.volume T X := by
    intro X hTX
    exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
      Dzero T0 T X z hT0_pos hT0_le_T hTX (ne_of_gt hy)
  have hreal_int : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X := by
    intro X hTX
    exact finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic
      Dzero T0 T X z.re z.im hT0_pos hT0_le_T hTX hy
  have hwrap_int : ∀ X, T ≤ X →
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u z *
          ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : ℝ) : ℂ))
        MeasureTheory.volume T X := by
    intro X hTX
    have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
    have hwrap := wrapKernel_intervalIntegrable_of_real_derivative_integrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im T X (hreal_int X hTX)
    rw [hz] at hwrap
    exact hwrap
  have him_eq := trueKernel_im_eq_realPartial_eventually
    (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
    T z htrue_int hwrap_int
  exact him_complex.congr' him_eq

-- =====================================================================
-- §CCLV-3. `|Im (true-kernel tail)| ≤ closedFormSErrorBoundCD C D z.im T`
-- =====================================================================
-- The end-to-end generic Im bound on `trueKernelTailOfLogEnvelope`.
-- Chains §CCLV-2 (real partial → tail Im) with §CCX
-- (`derivative_integral_limit_abs_le_majorant_tail`, real `|J|` bound)
-- and §CCXIII (`neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD`,
-- algebraic primitive → closed-form bridge). Output:
--
--   `|(trueKernelTailOfLogEnvelope ...).im| ≤ closedFormSErrorBoundCD C D z.im T`
--
-- This is the target shape consumed by `closedFormErrorControlledOnFiniteBand`
-- and `highTErrorControlled`-style predicates downstream.
--
-- Adds:
--   trueKernelTailOfLogEnvelope_im_bound

/-- 🌟🌟🌟🌟 **PROVED — generic Im bound on the true-kernel tail.**
End-to-end composition: §CCLV-2 produces the real-partial tendsto
witness; §CCX bounds `|J|` by `-P(z.im, C, D, T)`; §CCXIII bridges
`-P ≤ closedFormSErrorBoundCD`. Hypotheses match the existing
`derivative_integral_limit_abs_le_majorant_tail` shape, plus the
algebraic bridge's `1 ≤ T` requirement. -/
theorem trueKernelTailOfLogEnvelope_im_bound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0)
    {C D T : ℝ} {z : ℂ}
    (hT0_le_T : T0 ≤ T)
    (hTpos : 0 < T)
    (hT_ge_one : 1 ≤ T)
    (hy : 0 < z.im)
    (hC : 0 ≤ C) (hD : 0 ≤ D)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T)
    (hS_T :
      ∀ u, T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ C * Real.log u + D) :
    |(trueKernelTailOfLogEnvelope
      Dzero T0 hT0_pos hT0_le_T hTpos hy
      (by
        filter_upwards [Filter.eventually_ge_atTop T] with u hu
        exact hS_T u hu)).im|
      ≤ closedFormSErrorBoundCD C D z.im T := by
  have hSlogEnv : ∀ᶠ u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        ≤ C * Real.log u + D := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hS_T u hu
  have hJ := trueKernelTailOfLogEnvelope_im_tendsto_realPartial
    Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv
  have hInt :
      ∀ X, T ≤ X →
        IntervalIntegrable
          (fun u =>
            Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
              * pairedCauchyImKernelDeriv z.re z.im u)
          MeasureTheory.volume T X := by
    intro X hTX
    exact finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic
      Dzero T0 T X z.re z.im hT0_pos hT0_le_T hTX hy
  have hmajor :
      |(trueKernelTailOfLogEnvelope
        Dzero T0 hT0_pos hT0_le_T hTpos hy hSlogEnv).im|
        ≤ -Phase1IBP.derivativeSideMajorantPrimitive z.im C D T :=
    Phase1IBP.derivative_integral_limit_abs_le_majorant_tail
      (S := fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (C := C) (D := D) (x := z.re) (y := z.im) (T := T)
      hy hTpos hC hD hregime hS_T hInt hJ
  exact le_trans hmajor
    (neg_derivativeSideMajorantPrimitive_le_closedFormSErrorBoundCD
      C D z.im T hC hD hT_ge_one (le_of_lt hy))

-- =====================================================================
-- §CCLV-4. High-band specialization: `highTErrorControlled` from
--          high-Turing log envelope + canonical-tail identity
-- =====================================================================
-- Specializes §CCLV-3 to `(C, D) = (1/2, 49/20)` on `T ≥ 140`. Takes:
--   • `hHighLog` — high-band Turing-style log envelope on
--                  `finiteFluctuationPrimitive`;
--   • `herror_high` — analytic identity tying `(error z).im` to the
--                     `Im` of the §CCLIV named tail at the same z, T,
--                     and high-band log envelope.
-- Produces `highTErrorControlled error` directly, ready to feed
-- `highLocalPackage_of_highTErrorControlled` (§CCL).
--
-- Adds:
--   highTErrorControlled_of_highTuringLogEnvelope

/-- 🌟🌟🌟🌟🌟 **PROVED — `highTErrorControlled` from a high-Turing log
envelope + canonical-tail identity for `error`.** The xi analytic
content remaining at this layer is exactly `herror_high`: it pins
`Im(error z)` to `Im(trueKernelTailOfLogEnvelope (1/2) (49/20) T z)`
on the high band. Once supplied, §CCLV-3 closes the chain. -/
theorem highTErrorControlled_of_highTuringLogEnvelope
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (error : ℂ → ℂ)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (herror_high :
      ∀ {z : ℂ} {T : ℝ}
        (hT140 : 140 ≤ T) (hy : 0 < z.im)
        (hregime : 2 * (1 + |z.re| + z.im) ≤ T),
        (error z).im =
          (trueKernelTailOfLogEnvelope
            Dzero T0 hT0_pos
            (le_trans hT0_le_140 hT140)
            (by linarith : (0 : ℝ) < T)
            hy
            (by
              filter_upwards [Filter.eventually_ge_atTop T] with u hu
              exact hHighLog hT140 hy hregime hu)).im) :
    highTErrorControlled error := by
  intro z T hT140 hy hregime
  rw [herror_high hT140 hy hregime]
  unfold highTClosedFormBound
  exact trueKernelTailOfLogEnvelope_im_bound
    Dzero T0 hT0_pos
    (le_trans hT0_le_140 hT140)
    (by linarith : (0 : ℝ) < T)
    (by linarith : (1 : ℝ) ≤ T)
    hy
    (by norm_num : (0 : ℝ) ≤ 1 / 2)
    (by norm_num : (0 : ℝ) ≤ 49 / 20)
    hregime
    (fun u hu => hHighLog hT140 hy hregime hu)

-- =====================================================================
-- §CCLVI. Low-band `FirstZeroDirectBandCertificate` scaffolding
-- =====================================================================
-- The low band `[2π, 10]` is the only remaining structural slot whose
-- analytic content is not yet exposed in a uniform shape with high/mid.
-- This section provides:
--
--   • A trivial pass-through `errorBound` candidate equal to `-Im(M.model)`,
--     which collapses the certificate's `cert` field to `le_refl`.
--   • A constructor that builds the certificate from `M`, `(A, B, γ₁)`
--     constraints, and nothing else (no analytic input).
--   • A one-shot low local-package builder consuming a direct
--     low-margin hypothesis `|Im(error z)| ≤ -Im(M.model z)` on
--     `[2π, 10]`. Mirrors the §CCLV-4 high-band pattern.
--
-- After this lands, the low band's remaining analytic content is
-- exactly the `hlowMargin` hypothesis — the same shape that the rest
-- of the chain consumes, so analytic agents can target a uniform API.
--
-- Adds:
--   firstZeroDirectErrorBoundCandidate              — trivial bound def
--   firstZeroDirectBandCertificate_pass_through     — cert wrapper
--   lowLocalPackage_of_lowMargin                    — one-shot low package

/-- **Trivial `errorBound` candidate** for `FirstZeroDirectBandCertificate`:
the model's own `-Im` value. With this choice the cert reduces to
`le_refl`, and the entire analytic content moves to
`lowTErrorControlled error (firstZeroDirectErrorBoundCandidate M)`. -/
noncomputable def firstZeroDirectErrorBoundCandidate
    (M : CloudDensityTailModelDecomposition) : ℂ → ℝ :=
  fun z => -(M.model z).im

/-- 🌟 **PROVED — pass-through `FirstZeroDirectBandCertificate`** from
`M` and `(A, B, γ₁)` constraints. No analytic input required: `cert` is
`le_refl` because `errorBound = -Im(model)` by definition. -/
noncomputable def firstZeroDirectBandCertificate_pass_through
    (M : CloudDensityTailModelDecomposition)
    (A B gamma1 : ℝ)
    (hA_ge_two_pi : 2 * Real.pi ≤ A)
    (hA_le_B : A ≤ B)
    (hB_lt_gamma1 : B < gamma1) :
    FirstZeroDirectBandCertificate where
  A := A
  B := B
  gamma1 := gamma1
  A_ge_two_pi := hA_ge_two_pi
  A_le_B := hA_le_B
  B_lt_gamma1 := hB_lt_gamma1
  model := M.model
  errorBound := firstZeroDirectErrorBoundCandidate M
  cert := by
    intro z T _ _ _ _
    exact le_refl _

/-- 🌟🌟🌟 **PROVED — one-shot low-band `LocalXiCloudDensityErrorPackage`
from a direct low-margin hypothesis.** Mirrors §CCLV-4's high-band
pattern: takes `M`, `error`, a global decomposition, and the analytic
content `|Im(error z)| ≤ -Im(M.model z)` on `[2π, 10]`. Builds the
certificate pass-through internally and feeds it to §CCLI's wrapper.
Pins the first-zero parameter to `γ₁ := 14` (any value `> 10` works;
the canonical first zeta zero ordinate is ≈ 14.13). -/
noncomputable def lowLocalPackage_of_lowMargin
    (M : CloudDensityTailModelDecomposition)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        logDerivativeResponse XiPullback z = M.model z + error z)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(error z).im| ≤ -(M.model z).im) :
    LocalXiCloudDensityErrorPackage :=
  let twoPi_le_10 : 2 * Real.pi ≤ 10 := by
    have hπ : Real.pi < 4 := Real.pi_lt_four
    linarith
  lowLocalPackage_of_firstZeroDirect
    M hmodelAnti error hdecomp
    (firstZeroDirectBandCertificate_pass_through
      M (2 * Real.pi) 10 14
      le_rfl
      twoPi_le_10
      (by norm_num : (10 : ℝ) < 14))
    rfl rfl rfl
    hlowMargin

-- =====================================================================
-- §CCLVII. Canonical residual error (`error := Λ[Ξ] − M.model`)
-- =====================================================================
-- Pins the `error : ℂ → ℂ` parameter of every Route B front door to a
-- single canonical value: the residual `Λ[Ξ] z − M.model z`. This
-- collapses the global decomposition hypothesis to a trivial
-- definitional equation (`xiResidualError_decomp`), removing one
-- degree of freedom from every downstream identity.
--
-- Adds:
--   xiResidualError                                 — canonical residual
--   xiResidualError_decomp                          — definitional decomp
--   XiPullbackAntiHerglotzTarget_of_residualFormulaData

/-- **Canonical residual error.** The unique `error` for which
`Λ[Ξ] z = M.model z + error z` holds globally and definitionally. -/
noncomputable def xiResidualError
    (M : CloudDensityTailModelDecomposition) : ℂ → ℂ :=
  fun z => logDerivativeResponse XiPullback z - M.model z

/-- ⭐ **PROVED — decomposition is definitional for the canonical
residual.** -/
theorem xiResidualError_decomp
    (M : CloudDensityTailModelDecomposition) (z : ℂ) :
    logDerivativeResponse XiPullback z =
      M.model z + xiResidualError M z := by
  unfold xiResidualError
  ring

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR (residual)**.
Specializes `routeABands` to `error := xiResidualError M`. The
`hdecomp` parameter is discharged automatically via
`xiResidualError_decomp`; all remaining inputs (`F`, `lowCert`, `hlow`,
`hhigh`) refer to the canonical residual. -/
theorem XiPullbackAntiHerglotzTarget_of_residualFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge (xiResidualError M))
    (lowCert : FirstZeroDirectBandCertificate)
    (hlowCert_A : lowCert.A = 2 * Real.pi)
    (hlowCert_B : lowCert.B = 10)
    (hlowCert_model : lowCert.model = M.model)
    (hlow : lowTErrorControlled (xiResidualError M) lowCert.errorBound)
    (hhigh : highTErrorControlled (xiResidualError M)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABands
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros hmodelAnti Tsmooth hTsmooth_ge
    (xiResidualError M)
    (xiResidualError_decomp M)
    F lowCert hlowCert_A hlowCert_B hlowCert_model hlow hhigh

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **GUARDED MINIMAL ROUTE B FRONT DOOR
(residual).** Same as `XiPullbackAntiHerglotzTarget_of_residualFormulaData`
but takes the guarded analytic predicates
`lowTErrorControlledAwayFromZeros` / `highTErrorControlledAwayFromZeros`
on the canonical residual. This is the version Path B should target —
its hypotheses are genuinely weaker than RH because the `XiPullback z ≠ 0`
guard prevents the `a/0=0` totalization from being hidden inside an
analytic obligation. -/
theorem XiPullbackAntiHerglotzTarget_of_residualFormulaDataAwayFromZeros
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (F : XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge (xiResidualError M))
    (lowCert : FirstZeroDirectBandCertificate)
    (hlowCert_A : lowCert.A = 2 * Real.pi)
    (hlowCert_B : lowCert.B = 10)
    (hlowCert_model : lowCert.model = M.model)
    (hlow : lowTErrorControlledAwayFromZeros
              (xiResidualError M) lowCert.errorBound)
    (hhigh : highTErrorControlledAwayFromZeros (xiResidualError M)) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData_routeABandsAwayFromZeros
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros hmodelAnti Tsmooth hTsmooth_ge
    (xiResidualError M)
    (xiResidualError_decomp M)
    F lowCert hlowCert_A hlowCert_B hlowCert_model hlow hhigh

-- =====================================================================
-- §CCLVIII. High residual tail identity (scaffolded target)
-- =====================================================================
-- Isolates the one remaining xi-specific analytic obligation on the
-- high band as a single named Prop:
--
--   `XiHighResidualTailIdentity` :
--     `(xiResidualError M z).im
--        = (trueKernelTailOfLogEnvelope ... (1/2) (49/20) T z).im`
--
-- The bridge `highTErrorControlled_of_XiHighResidualTailIdentity`
-- routes this identity straight into the §CCLV-4 high-band chain.
--
-- Adds:
--   XiHighResidualTailIdentity
--   highTErrorControlled_of_XiHighResidualTailIdentity

/-- **High residual tail identity.** The xi-specific high-band analytic
target after canonicalization: for every UHP `z` on the high band, the
canonical residual's `Im` agrees with the `Im` of the §CCLIV
true-kernel tail at constants `(C, D) = (1/2, 49/20)`. -/
def XiHighResidualTailIdentity
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ)) : Prop :=
  ∀ {z : ℂ} {T : ℝ}
    (hT140 : 140 ≤ T) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T),
    (xiResidualError M z).im =
      (trueKernelTailOfLogEnvelope
        Dzero T0 hT0_pos
        (le_trans hT0_le_140 hT140)
        (by linarith : (0 : ℝ) < T)
        hy
        (by
          filter_upwards [Filter.eventually_ge_atTop T] with u hu
          exact hHighLog hT140 hy hregime hu)).im

/-- 🌟🌟🌟🌟 **PROVED — `highTErrorControlled` for the canonical residual
from `XiHighResidualTailIdentity`.** Direct specialization of §CCLV-4
`highTErrorControlled_of_highTuringLogEnvelope` with
`error := xiResidualError M` and `herror_high := hIdentity`. -/
theorem highTErrorControlled_of_XiHighResidualTailIdentity
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (hIdentity :
      XiHighResidualTailIdentity Dzero T0 hT0_pos hT0_le_140 M hHighLog) :
    highTErrorControlled (xiResidualError M) :=
  highTErrorControlled_of_highTuringLogEnvelope
    Dzero T0 hT0_pos hT0_le_140 (xiResidualError M)
    (@hHighLog) hIdentity

-- =====================================================================
-- §CCLIX. Residual formula data from `hmodel + herror_corr` (drops `hxi`)
-- =====================================================================
-- For `error := xiResidualError M`, the `hxi` field of
-- `XiLogDerivativeFormulaData` is definitional: it follows from
-- `hmodel` and `xiResidualError_decomp`. This section collapses the
-- formula bundle to its two genuinely-substantive fields and provides
-- the cleanest residual-flavored front door.
--
-- Adds:
--   XiLogDerivativeFormulaData.ofResidual
--   XiPullbackAntiHerglotzTarget_of_residualModelAndCorrectedError

/-- 🌟🌟 **PROVED — `XiLogDerivativeFormulaData` for the canonical
residual from `hmodel + herror_corr`.** Drops the `hxi` obligation:
once `hmodel z : M.model z = pairedFiniteCloud + smoothTail`, the
formula `Λ[Ξ] z = pairedFiniteCloud + smoothTail + xiResidualError M z`
is the definitional `xiResidualError_decomp` rewritten through
`hmodel`. -/
theorem XiLogDerivativeFormulaData.ofResidual
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (hmodel :
      ∀ z : ℂ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (herror_corr :
      HErrorCanonicalCorrected
        Dzero T0 hT0_pos hT0_le_10 hTuring (xiResidualError M)) :
    XiLogDerivativeFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge (xiResidualError M) where
  hmodel := hmodel
  hxi := by
    intro z _
    calc
      logDerivativeResponse XiPullback z
          = M.model z + xiResidualError M z :=
            xiResidualError_decomp M z
      _ = pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z +
              xiResidualError M z := by
            rw [hmodel z]
  herror_corr := herror_corr

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR (residual
+ two-field formula).** Combines §CCLVII's residual canonicalization
with §CCLIX's `hxi`-drop. The mid-band formula obligation collapses to
just `hmodel` and `herror_corr`; `hdecomp` and `hxi` are both
definitional. Remaining inputs: `hzeros`, `hmodel`, `herror_corr`, and
a `B : LowHighBandData`. -/
theorem XiPullbackAntiHerglotzTarget_of_residualModelAndCorrectedError
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (hmodel :
      ∀ z : ℂ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (herror_corr :
      HErrorCanonicalCorrected
        Dzero T0 hT0_pos hT0_le_10 hTuring (xiResidualError M))
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_XiLogDerivativeFormulaData
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us M hzeros Tsmooth hTsmooth_ge (xiResidualError M)
    (XiLogDerivativeFormulaData.ofResidual
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us M Tsmooth hTsmooth_ge hmodel herror_corr)
    B

-- =====================================================================
-- §CCLX. Honest zeroDensity model bundle
-- =====================================================================
-- Packages the three loose model-side parameters `M, hzeros, hmodel`
-- into a single named structure. The `hmodel` field — currently the
-- last loose model-side hypothesis in the front door — becomes a
-- structural commitment rather than an arbitrary obligation.
--
-- This does NOT solve `hmodel`; it just gathers it with the model `M`
-- so the rest of the chain consumes a single honest object. A future
-- patch can construct `HonestZeroDensityModelData` from a concrete `M`
-- (e.g. via the CLV `densityTailRationalLB` chain) without touching
-- downstream consumers.
--
-- Adds:
--   HonestZeroDensityModelData                                — bundle
--   HonestZeroDensityModelData.ofModelEq                       — constructor
--   XiPullbackAntiHerglotzTarget_of_honestZeroDensityModel     — front door

/-- 📦 **`HonestZeroDensityModelData`** — bundle of the three model-side
parameters needed by Route B's residual front door:
* `M : CloudDensityTailModelDecomposition`
* `hzeros : M.zeros = zeros100ceil`
* `hmodel : M.model = pairedFiniteCloud + zeroDensitySmoothTail`

After this lands, the final theorem takes a single
`HModel : HonestZeroDensityModelData …` instead of three loose
arguments. -/
structure HonestZeroDensityModelData
    (us : List ℝ) (Tsmooth : ℝ)
    (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth) where
  M : CloudDensityTailModelDecomposition
  hzeros : M.zeros = zeros100ceil
  hmodel :
    ∀ z : ℂ,
      M.model z =
        pairedFiniteCloudFromZeros us z +
          zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z

/-- ⭐ **PROVED — `HonestZeroDensityModelData` from explicit `M` + hypotheses.**
Trivial wrapper for use when the three model-side facts are already
proved separately. -/
def HonestZeroDensityModelData.ofModelEq
    (us : List ℝ) (Tsmooth : ℝ)
    (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodel :
      ∀ z : ℂ,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z) :
    HonestZeroDensityModelData us Tsmooth hTsmooth_ge where
  M := M
  hzeros := hzeros
  hmodel := hmodel

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR
(honest model + residual).** Wraps
`XiPullbackAntiHerglotzTarget_of_residualModelAndCorrectedError` to
consume a single `HonestZeroDensityModelData` bundle instead of three
loose parameters. The remaining xi-specific obligations are:
* `herror_corr` — canonical-corrected residual identity;
* the `LowHighBandData` `B` (assembled from §CCLI/§CCL packages + cover). -/
theorem XiPullbackAntiHerglotzTarget_of_honestZeroDensityModel
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (herror_corr :
      HErrorCanonicalCorrected
        Dzero T0 hT0_pos hT0_le_10 hTuring
        (xiResidualError HModel.M))
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_residualModelAndCorrectedError
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us HModel.M HModel.hzeros Tsmooth hTsmooth_ge
    HModel.hmodel herror_corr B

-- =====================================================================
-- §CCLXI. Xi residual formula data (real xi analytic target for `herror_corr`)
-- =====================================================================
-- Repackages the `herror_corr` obligation as a single named Prop-structure
-- `XiResidualFormulaData`. Mathematically this is the central
-- xi-specific identity:
--
--   Im(Λ[Ξ](z) − model(z))
--     = Im(canonical fluctuation tail)
--       − finite cutoff correction
--
-- After this section, the final Route B front door consumes a single
-- `R : XiResidualFormulaData …` instead of a raw `herror_corr`.
--
-- Adds:
--   XiResidualFormulaData                                         — formula bundle
--   XiResidualFormulaData.to_herror_corr                          — bridge
--   XiPullbackAntiHerglotzTarget_of_honestModel_residualFormula   — front door

/-- 📦 **`XiResidualFormulaData`** — the central xi-specific analytic
target. Single field: the canonical-corrected Im identity for the
xi residual, at every adaptive `(z, T)`. Identical in content to
`HErrorCanonicalCorrected … (xiResidualError M)`, but named so the
remaining xi analytic work has a sharp single target. -/
structure XiResidualFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_canonical_tail :
    ∀ {z : ℂ} {T : ℝ},
      10 ≤ T → T ≤ 140 → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
      (xiResidualError M z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im
        -
        trueKernelTailCorrection
          Dzero T0 (canonicalAdaptiveT z) T z

/-- ⭐ **PROVED — `HErrorCanonicalCorrected` from `XiResidualFormulaData`.**
The structure's single field is propositionally identical to
`HErrorCanonicalCorrected … (xiResidualError M)`; this bridge just
forwards it. -/
theorem XiResidualFormulaData.to_herror_corr
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    {hT0_pos : 0 < T0} {hT0_le_10 : T0 ≤ 10}
    {hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2}
    {M : CloudDensityTailModelDecomposition}
    (R : XiResidualFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M) :
    HErrorCanonicalCorrected
      Dzero T0 hT0_pos hT0_le_10 hTuring (xiResidualError M) := by
  intro z T h10 h140 hy hregime
  exact R.residual_im_eq_canonical_tail h10 h140 hy hregime

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MINIMAL ROUTE B FRONT DOOR
(honest model + residual formula).** Replaces the raw `herror_corr`
input with the structured `R : XiResidualFormulaData`. Inputs:
* `HModel : HonestZeroDensityModelData …` (model identity);
* `R : XiResidualFormulaData …` (residual Im formula);
* `B : LowHighBandData` (cover + low/high local packages).

Plus the standard structural args + parallel-agent Turing/Backlund. -/
theorem XiPullbackAntiHerglotzTarget_of_honestModel_residualFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (R : XiResidualFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (B : LowHighBandData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_honestZeroDensityModel
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us Tsmooth hTsmooth_ge HModel
    (XiResidualFormulaData.to_herror_corr R) B

-- =====================================================================
-- §CCLXII. High residual formula data + master residual front door
-- =====================================================================
-- Per the user's design note: high-region points may not have a valid
-- mid cutoff (e.g. `2(1+|z.re|+z.im) > 140` means no `T ∈ [10, 140]`
-- exists), so `XiHighResidualTailIdentity` is genuinely independent
-- of the mid-band `XiResidualFormulaData`. This section adds the
-- analogous high wrapper and the master front door composing all
-- residual-flavored xi obligations.
--
-- Adds:
--   XiHighResidualFormulaData                                — high Prop wrapper
--   highLocalPackage_of_XiHighResidualFormulaData            — high local pkg builder
--   lowLocalPackage_of_residualLowMargin                     — low local pkg builder
--   XiPullbackAntiHerglotzTarget_of_residualPackages         — master front door

/-- 📦 **`XiHighResidualFormulaData`** — Prop wrapper around
`XiHighResidualTailIdentity`. Same shape as the mid-band
`XiResidualFormulaData`; kept separate because high-region `z` need
not admit any mid-band cutoff. -/
structure XiHighResidualFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ)) : Prop where
  residual_im_eq_highTail :
    XiHighResidualTailIdentity Dzero T0 hT0_pos hT0_le_140 M hHighLog

/-- 🌟🌟 **PROVED — high local package from `XiHighResidualFormulaData`.**
Composition: §CCLVIII bridges the residual Im identity into
`highTErrorControlled (xiResidualError M)`; §CCL wraps that into a
`LocalXiCloudDensityErrorPackage` with `region := highComplementRegion`. -/
noncomputable def highLocalPackage_of_XiHighResidualFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (H : XiHighResidualFormulaData Dzero T0 hT0_pos hT0_le_140 M hHighLog) :
    LocalXiCloudDensityErrorPackage :=
  highLocalPackage_of_highTErrorControlled
    M hzeros hmodelAnti (xiResidualError M)
    (xiResidualError_decomp M)
    (highTErrorControlled_of_XiHighResidualTailIdentity
      Dzero T0 hT0_pos hT0_le_140 M hHighLog H.residual_im_eq_highTail)

/-- 🌟🌟 **PROVED — low local package from a direct residual low-margin
hypothesis.** Residualized version of §CCLVI's
`lowLocalPackage_of_lowMargin`, specialized to
`error := xiResidualError M`. The decomposition is definitional via
`xiResidualError_decomp`. -/
noncomputable def lowLocalPackage_of_residualLowMargin
    (M : CloudDensityTailModelDecomposition)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(xiResidualError M z).im| ≤ -(M.model z).im) :
    LocalXiCloudDensityErrorPackage :=
  lowLocalPackage_of_lowMargin M hmodelAnti (xiResidualError M)
    (xiResidualError_decomp M) hlowMargin

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **MASTER RESIDUAL FRONT DOOR.**
Composes every residual-flavored xi obligation into one theorem
statement:

```
hTuring + hHighLog
+ HModel (honest model identity)
+ Rmid   (mid-band residual Im formula)
+ Rhigh  (high-band residual Im identity)
+ hlowMargin (low-band residual margin)
+ hmodelAnti
⟹ XiPullbackAntiHerglotzTarget
```

Internally assembles low and high local packages, discharges the
three-way cover automatically (high region IS the mid complement), and
threads through §CCLXI. -/
theorem XiPullbackAntiHerglotzTarget_of_residualPackages
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (hmodelAnti : AntiHerglotzUHP HModel.M.model)
    (Rmid : XiResidualFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (Rhigh : XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M hHighLog)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(xiResidualError HModel.M z).im| ≤ -(HModel.M.model z).im) :
    XiPullbackAntiHerglotzTarget :=
  let low : LocalXiCloudDensityErrorPackage :=
    lowLocalPackage_of_residualLowMargin HModel.M hmodelAnti hlowMargin
  let high : LocalXiCloudDensityErrorPackage :=
    highLocalPackage_of_XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M HModel.hzeros hmodelAnti hHighLog Rhigh
  let hcover : LowMidHighCover low high :=
    lowMidHighCover_of_high_complement low high
      (fun _ _ hmid => hmid)
  XiPullbackAntiHerglotzTarget_of_honestModel_residualFormula
    Dzero T0 hT0_pos hT0_le_10 hTuring
    us Tsmooth hTsmooth_ge HModel Rmid
    (LowHighBandData.ofLowHighPackages low high hcover)

-- =====================================================================
-- §CCLXIII. `hmodelAnti` from `HonestZeroDensityModelData`
-- =====================================================================
-- Closes the only remaining free hypothesis of the master front door:
-- `hmodelAnti : AntiHerglotzUHP HModel.M.model` is derivable from
-- `HModel.hmodel` + existing anti-Herglotz lemmas for the summands.
-- The honest model is `pairedFiniteCloud + zeroDensitySmoothTail`,
-- and both are anti-Herglotz; the sum is closed under anti-Herglotz.
--
-- Adds:
--   AntiHerglotzUHP.add                                 — sum closure
--   hmodelAnti_of_honestZeroDensityModel                — derived from HModel
--   XiPullbackAntiHerglotzTarget_of_honestPackages      — final 6-input front door

/-- ⭐ **PROVED — `AntiHerglotzUHP` is closed under pointwise addition.**
The sum's `.im` equals the sum of `.im`s; both summands nonpositive
implies the sum is nonpositive. -/
lemma AntiHerglotzUHP.add {R₁ R₂ : ℂ → ℂ}
    (h₁ : AntiHerglotzUHP R₁) (h₂ : AntiHerglotzUHP R₂) :
    AntiHerglotzUHP (fun z => R₁ z + R₂ z) := by
  intro z hz
  rw [Complex.add_im]
  linarith [h₁ z hz, h₂ z hz]

/-- 🌟🌟 **PROVED — `AntiHerglotzUHP HModel.M.model` from `HModel`.**
The honest model is `pairedFiniteCloud + zeroDensitySmoothTail` by
`HModel.hmodel`; both summands are anti-Herglotz (finite cloud by
`pairedFiniteCloudFromZeros_antiHerglotz`, smooth tail by
`(smoothDensityTailModelData_zeroDensityRho ...).tailAnti`); their
sum is anti-Herglotz; transfer via `hmodel`. -/
theorem hmodelAnti_of_honestZeroDensityModel
    (us : List ℝ) (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge) :
    AntiHerglotzUHP HModel.M.model := by
  intro z hz
  rw [HModel.hmodel z, Complex.add_im]
  have hcloud := pairedFiniteCloudFromZeros_antiHerglotz us z hz
  have htail : (zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im ≤ 0 :=
    (smoothDensityTailModelData_zeroDensityRho Tsmooth hTsmooth_ge).tailAnti
      z hz
  linarith

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **FINAL MASTER FRONT DOOR
(`hmodelAnti` derived).** Drops `hmodelAnti` from
`XiPullbackAntiHerglotzTarget_of_residualPackages`: it is now derived
internally via §CCLXIII's chain. The final theorem takes exactly six
named xi-specific inputs (plus the two parallel-agent Turing inputs
and the standard structural setup). -/
theorem XiPullbackAntiHerglotzTarget_of_honestPackages
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rmid : XiResidualFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (Rhigh : XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M hHighLog)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(xiResidualError HModel.M z).im| ≤ -(HModel.M.model z).im) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_residualPackages
    Dzero T0 hT0_pos hT0_le_10
    hTuring hHighLog us Tsmooth hTsmooth_ge HModel
    (hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel)
    Rmid Rhigh hlowMargin

-- =====================================================================
-- §CCLXIV. `XiHighResidualFormulaData` constructors (two attack paths)
-- =====================================================================
-- The high-band residual Im identity `XiHighResidualTailIdentity` is
-- now the single high-band xi-specific obligation. This section adds
-- two constructors:
--
--   1. Trivial wrapper from a direct `XiHighResidualTailIdentity` proof.
--   2. Tendsto-uniqueness bridge: if the residual is the limit of the
--      true-kernel complex partials at the same high `(z, T)`, then
--      the Im identity follows from `trueKernelTailOfLogEnvelope_tendsto`
--      + Tendsto uniqueness.
--
-- An analytic agent can pick whichever path matches their explicit
-- formula machinery.
--
-- Adds:
--   XiHighResidualFormulaData.of_identity
--   xiHighResidualTailIdentity_of_complex_tendsto
--   XiHighResidualFormulaData.of_complex_tendsto

/-- ⭐ **PROVED — trivial constructor** for `XiHighResidualFormulaData`
from a direct proof of `XiHighResidualTailIdentity`. -/
def XiHighResidualFormulaData.of_identity
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (H : XiHighResidualTailIdentity Dzero T0 hT0_pos hT0_le_140 M hHighLog) :
    XiHighResidualFormulaData Dzero T0 hT0_pos hT0_le_140 M hHighLog :=
  ⟨H⟩

/-- 🌟🌟🌟 **PROVED — `XiHighResidualTailIdentity` from a complex
Tendsto witness.** If the residual `xiResidualError M z` is the limit
of the true-kernel complex partials over `[T, X]` as `X → ∞` for every
high-band `(z, T)`, then the high residual Im identity follows: take
`.im` on both Tendsto witnesses (residual side and §CCLIV side) and
apply uniqueness of limits.

This is the natural shape produced by a high-band explicit formula
that derives the residual as an improper integral of the true kernel
against the finite-fluctuation primitive. -/
theorem xiHighResidualTailIdentity_of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (hResTendsto :
      ∀ {z : ℂ} {T : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              T X z)
          Filter.atTop
          (𝓝 (xiResidualError M z))) :
    XiHighResidualTailIdentity Dzero T0 hT0_pos hT0_le_140 M hHighLog := by
  intro z T hT140 hy hregime
  have hSlogEnv : ∀ᶠ u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ) := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hHighLog hT140 hy hregime hu
  have h_res_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop (𝓝 (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp (hResTendsto hT140 hy hregime)
  have h_tail_tendsto :=
    trueKernelTailOfLogEnvelope_tendsto
      Dzero T0 hT0_pos
      (le_trans hT0_le_140 hT140)
      (by linarith : (0 : ℝ) < T) hy hSlogEnv
  have h_tail_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z).im)
        Filter.atTop
        (𝓝 (trueKernelTailOfLogEnvelope
          Dzero T0 hT0_pos
          (le_trans hT0_le_140 hT140)
          (by linarith : (0 : ℝ) < T) hy hSlogEnv).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

/-- 🌟🌟🌟🌟 **PROVED — `XiHighResidualFormulaData` from a complex
Tendsto witness.** Convenience composition of
`xiHighResidualTailIdentity_of_complex_tendsto` with the trivial
structure wrapper. -/
def XiHighResidualFormulaData.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_140 : T0 ≤ 140)
    (M : CloudDensityTailModelDecomposition)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (hResTendsto :
      ∀ {z : ℂ} {T : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              T X z)
          Filter.atTop
          (𝓝 (xiResidualError M z))) :
    XiHighResidualFormulaData Dzero T0 hT0_pos hT0_le_140 M hHighLog :=
  ⟨xiHighResidualTailIdentity_of_complex_tendsto
    Dzero T0 hT0_pos hT0_le_140 M hHighLog hResTendsto⟩

-- =====================================================================
-- §CCLXV. Canonical-T Rmid target + Tendsto-uniqueness bridges
-- =====================================================================
-- **Important caveat (per design audit).** The existing
-- `XiResidualFormulaData` (§CCLXI) — and equivalently
-- `HErrorCanonicalCorrected` for the canonical residual — quantifies
-- over arbitrary adaptive `T`, and so implicitly forces tail-Im
-- T-independence (which §CCXLVI showed is generally false). It is
-- *not necessarily inhabited* by an honest xi explicit formula.
--
-- The honest mid-band target is the *canonical-T-only* identity:
--
--   `(xiResidualError M z).im
--      = (trueKernelAdaptiveTail ... (canonicalAdaptiveT z) z).im`
--
-- whenever `z` lies in the adaptive mid-band. This is the weaker and
-- mathematically defensible Prop.
--
-- Adds:
--   trueKernelAdaptiveTail_tendsto                              — choose-spec wrapper
--   XiResidualCanonicalFormulaData                              — honest canonical-only Prop
--   XiResidualCanonicalFormulaData.of_identity                  — trivial constructor
--   xiResidualCanonicalTailIdentity_of_complex_tendsto          — Tendsto-uniqueness bridge
--   XiResidualCanonicalFormulaData.of_complex_tendsto           — composed constructor

/-- 🌟 **PROVED — `trueKernelAdaptiveTail` choose-spec as a top-level
Tendsto.** Top-level wrapper around the `tendsto` field of
`adaptiveComplexConverges_trueKernel_of_turingBound`, simplifying its
reuse downstream. Direct re-extraction from
`trueKernelComplexTail_converges_at` + `dif_pos`. -/
theorem trueKernelAdaptiveTail_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : ℂ} {T : ℝ}
    (h10 : 10 ≤ T) (h140 : T ≤ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T) :
    Tendsto
      (fun X : ℝ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (𝓝 (trueKernelAdaptiveTail
        Dzero T0 hT0_pos hT0_le_10 hTuring T z)) := by
  have hExists := trueKernelComplexTail_converges_at
    Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
  have hregion :
      10 ≤ T ∧ T ≤ 140 ∧ 0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ T :=
    ⟨h10, h140, hy, hregime⟩
  have htail_val :
      trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
        = Classical.choose hExists := by
    unfold trueKernelAdaptiveTail
    rw [dif_pos hregion]
  rw [htail_val]
  exact Classical.choose_spec hExists

/-- 📦 **`XiResidualCanonicalFormulaData`** — honest mid-band xi target.
For every mid-band UHP `z`, the canonical residual's Im equals the
canonical-T true-kernel adaptive tail's Im. No T-uniform claim. -/
structure XiResidualCanonicalFormulaData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_canonical_tail :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      (xiResidualError M z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im

/-- ⭐ **PROVED — trivial constructor** for
`XiResidualCanonicalFormulaData` from a direct Im identity. -/
def XiResidualCanonicalFormulaData.of_identity
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (h : ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      (xiResidualError M z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im) :
    XiResidualCanonicalFormulaData Dzero T0 hT0_pos hT0_le_10 hTuring M :=
  ⟨h⟩

/-- 🌟🌟🌟 **PROVED — canonical-T Im identity from a complex Tendsto
witness.** If the residual is the complex `X → ∞` limit of true-kernel
partials starting at `canonicalAdaptiveT z` for every mid-band `z`,
then taking `.im` and applying `trueKernelAdaptiveTail_tendsto` +
uniqueness gives the canonical-T Im identity. -/
theorem xiResidualCanonicalTailIdentity_of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hResTendsto :
      ∀ {z : ℂ},
        0 < z.im →
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop (𝓝 (xiResidualError M z))) :
    ∀ {z : ℂ},
      0 < z.im →
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      (xiResidualError M z).im =
        (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im := by
  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  have h_res_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop (𝓝 (xiResidualError M z).im) :=
    (Complex.continuous_im.tendsto _).comp (hResTendsto hy hmid)
  have h_tail_tendsto :=
    trueKernelAdaptiveTail_tendsto
      Dzero T0 hT0_pos hT0_le_10 hTuring
      hc.1 hc.2.1 hy hc.2.2
  have h_tail_im :
      Tendsto
        (fun X : ℝ =>
          (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            (canonicalAdaptiveT z) X z).im)
        Filter.atTop
        (𝓝 (trueKernelAdaptiveTail
          Dzero T0 hT0_pos hT0_le_10 hTuring
          (canonicalAdaptiveT z) z).im) :=
    (Complex.continuous_im.tendsto _).comp h_tail_tendsto
  exact tendsto_nhds_unique h_res_im h_tail_im

/-- 🌟🌟🌟🌟 **PROVED — `XiResidualCanonicalFormulaData` from a complex
Tendsto witness.** Convenience composition of
`xiResidualCanonicalTailIdentity_of_complex_tendsto` with the trivial
structure wrapper. -/
def XiResidualCanonicalFormulaData.of_complex_tendsto
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hResTendsto :
      ∀ {z : ℂ},
        0 < z.im →
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        Tendsto
          (fun X : ℝ =>
            complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              (canonicalAdaptiveT z) X z)
          Filter.atTop (𝓝 (xiResidualError M z))) :
    XiResidualCanonicalFormulaData Dzero T0 hT0_pos hT0_le_10 hTuring M :=
  ⟨xiResidualCanonicalTailIdentity_of_complex_tendsto
    Dzero T0 hT0_pos hT0_le_10 hTuring M hResTendsto⟩

-- =====================================================================
-- §CCLXVI. Canonical-T mid local package + replacement front door
-- =====================================================================
-- Replaces the over-strong `XiResidualFormulaData`-based mid pathway
-- with a canonical-T-only pathway using `XiResidualCanonicalFormulaData`
-- (§CCLXV). The honest mid-band local package picks `T := canonicalAdaptiveT z`
-- per `z`, so the error margin chain is consistent without invoking
-- any tail-Im T-independence claim.
--
-- Adds:
--   trueKernelAdaptiveTail_im_bound                          — Im bound at canonical T
--   canonicalMidResidual_closedFormBound                     — residual ≤ closed form
--   canonicalMidResidual_errorMargin                         — residual ≤ -Im(M.model)
--   midLocalPackage_of_canonicalResidualFormula              — Local mid package
--   XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
--                                                            — final replacement front door

/-- 🌟🌟 **PROVED — Im bound for `trueKernelAdaptiveTail` at any
adaptive `T`.** Routes through §CCLV-3 + Tendsto uniqueness:
`trueKernelAdaptiveTail` and `trueKernelTailOfLogEnvelope` agree at
the adaptive band (both are the X→∞ limit of the same complex
partials), so the §CCLV-3 Im bound transfers. -/
theorem trueKernelAdaptiveTail_im_bound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : ℂ} {T : ℝ}
    (h10 : 10 ≤ T) (h140 : T ≤ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im|
      ≤ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T := by
  have hT_pos : (0 : ℝ) < T := by linarith
  have hT_ge_one : (1 : ℝ) ≤ T := by linarith
  have hT0_le_T : T0 ≤ T := le_trans hT0_le_10 h10
  have hS_T : ∀ u, T ≤ u →
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        ≤ (slabCD T).1 * Real.log u + (slabCD T).2 :=
    fun u hu => hTuring h10 h140 hy hregime hu
  have hSlogEnv : ∀ᶠ u in Filter.atTop,
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
        ≤ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hu
    exact hS_T u hu
  have h1 := trueKernelAdaptiveTail_tendsto
    Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
  have h2 := trueKernelTailOfLogEnvelope_tendsto
    Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv
  have h_eq : trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
            = trueKernelTailOfLogEnvelope
                Dzero T0 hT0_pos hT0_le_T hT_pos hy hSlogEnv :=
    tendsto_nhds_unique h1 h2
  rw [h_eq]
  have hC : (0 : ℝ) ≤ (slabCD T).1 := by
    unfold slabCD
    split_ifs <;> norm_num
  have hD : (0 : ℝ) ≤ (slabCD T).2 := by
    unfold slabCD
    split_ifs <;> norm_num
  exact trueKernelTailOfLogEnvelope_im_bound
    Dzero T0 hT0_pos hT0_le_T hT_pos hT_ge_one hy hC hD hregime hS_T

/-- 🌟🌟🌟 **PROVED — canonical mid residual closed-form bound.**
Combines `Rcanon` (residual.im = canonical tail.im) with §CCLXVI's
`trueKernelAdaptiveTail_im_bound` at `T := canonicalAdaptiveT z`. -/
theorem canonicalMidResidual_closedFormBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : ℂ}
    (hy : 0 < z.im)
    (hmid : ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
      2 * (1 + |z.re| + z.im) ≤ T) :
    |(xiResidualError M z).im|
      ≤ closedFormSErrorBoundCD
          (slabCD (canonicalAdaptiveT z)).1
          (slabCD (canonicalAdaptiveT z)).2
          z.im
          (canonicalAdaptiveT z) := by
  have hc := canonicalAdaptiveT_spec hmid
  rw [Rcanon.residual_im_eq_canonical_tail hy hmid]
  exact trueKernelAdaptiveTail_im_bound
    Dzero T0 hT0_pos hT0_le_10 hTuring
    hc.1 hc.2.1 hy hc.2.2

/-- 🌟🌟🌟🌟 **PROVED — canonical mid residual model margin.**
Chains the closed-form bound (§CCLXVI step 2) with the slab cert
(§CLXXXIVa `hclosed_on_10_140_zeros100ceil_slabCD`) at `T := canonicalAdaptiveT z`. -/
theorem canonicalMidResidual_errorMargin
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (M : CloudDensityTailModelDecomposition)
    (hzeros : M.zeros = zeros100ceil)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring M)
    {z : ℂ}
    (hy : 0 < z.im)
    (hmid : ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
      2 * (1 + |z.re| + z.im) ≤ T) :
    |(xiResidualError M z).im| ≤ -(M.model z).im := by
  have hc := canonicalAdaptiveT_spec hmid
  have h_closed_bound :=
    canonicalMidResidual_closedFormBound
      Dzero T0 hT0_pos hT0_le_10 hTuring M Rcanon hy hmid
  exact le_trans h_closed_bound
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hc.1 hc.2.1 hy hc.2.2)

/-- 🌟🌟🌟🌟🌟 **PROVED — canonical mid `LocalXiCloudDensityErrorPackage`.**
Bundles the canonical mid residual into a `LocalXiCloudDensityErrorPackage`
whose `region` is the mid existential. No `Rmid` over-strong hypothesis;
the canonical-T choice handles arbitrary `T` in the region via
`canonicalAdaptiveT z`. -/
noncomputable def midLocalPackage_of_canonicalResidualFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M) :
    LocalXiCloudDensityErrorPackage where
  model := HModel.M.model
  error := xiResidualError HModel.M
  region := fun z =>
    ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T
  decomp := fun z _ => xiResidualError_decomp HModel.M z
  modelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  errorMargin := fun _ hreg hy =>
    canonicalMidResidual_errorMargin
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M HModel.hzeros Rcanon
      hy hreg

/-- 🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟 **HONEST MASTER FRONT
DOOR (canonical mid).** Replaces `XiPullbackAntiHerglotzTarget_of_honestPackages`
with a version using `Rcanon : XiResidualCanonicalFormulaData` instead
of the over-strong `Rmid : XiResidualFormulaData`. Assembles three
local packages (low, mid via canonical, high) into a `XiCloudDensityCoveringFamily`
covered by `low.region ∨ mid.region ∨ highComplementRegion`. -/
theorem XiPullbackAntiHerglotzTarget_of_honestPackages_canonicalMid
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 ≤ 10)
    (hTuring :
      ∀ {z : ℂ} {T u : ℝ},
        10 ≤ T → T ≤ 140 → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      ∀ {z : ℂ} {T u : ℝ},
        140 ≤ T → 0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        T ≤ u →
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          ≤ (1 / 2 : ℝ) * Real.log u + (49 / 20 : ℝ))
    (us : List ℝ)
    (Tsmooth : ℝ) (hTsmooth_ge : 2 * Real.pi ≤ Tsmooth)
    (HModel : HonestZeroDensityModelData us Tsmooth hTsmooth_ge)
    (Rcanon : XiResidualCanonicalFormulaData
      Dzero T0 hT0_pos hT0_le_10 hTuring HModel.M)
    (Rhigh : XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M hHighLog)
    (hlowMargin :
      ∀ {z : ℂ} {T : ℝ},
        2 * Real.pi ≤ T → T ≤ 10 →
        0 < z.im →
        2 * (1 + |z.re| + z.im) ≤ T →
        |(xiResidualError HModel.M z).im| ≤ -(HModel.M.model z).im) :
    XiPullbackAntiHerglotzTarget := by
  have hmodelAnti :=
    hmodelAnti_of_honestZeroDensityModel us Tsmooth hTsmooth_ge HModel
  let mid : LocalXiCloudDensityErrorPackage :=
    midLocalPackage_of_canonicalResidualFormula
      Dzero T0 hT0_pos hT0_le_10 hTuring
      us Tsmooth hTsmooth_ge HModel Rcanon
  let high : LocalXiCloudDensityErrorPackage :=
    highLocalPackage_of_XiHighResidualFormulaData
      Dzero T0 hT0_pos
      (le_trans hT0_le_10 (by norm_num : (10 : ℝ) ≤ 140))
      HModel.M HModel.hzeros hmodelAnti hHighLog Rhigh
  let low : LocalXiCloudDensityErrorPackage :=
    lowLocalPackage_of_residualLowMargin HModel.M hmodelAnti hlowMargin
  refine XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget
    { package := fun n =>
        if n = 0 then mid else if n = 1 then high else low
      covers := ?_ }
  intro z hz
  by_cases hmid :
      ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T
  · refine ⟨0, ?_⟩
    show mid.region z
    exact hmid
  · refine ⟨1, ?_⟩
    show high.region z
    exact hmid

-- =====================================================================
-- §CCLXVII. Compact low-band residual margin target
-- =====================================================================
-- The `hlowMargin` obligation is `T`-parametric, but the low-band
-- constraint `2(1 + |z.re| + z.im) ≤ T ≤ 10` collapses the geometry
-- to `0 < z.im ∧ |z.re| + z.im ≤ 4`. This section repackages the
-- obligation as a compact-region inequality so the analytic agent
-- has a single clean target.
--
-- Adds:
--   lowCompactRegion                              — `0 < z.im ∧ 2(1+|z.re|+z.im) ≤ 10`
--   lowCompactRegion_of_lowT                      — `T`-parametric → compact
--   XiLowResidualMargin                           — Prop over `lowCompactRegion`
--   hlowMargin_of_XiLowResidualMargin             — bridge to old shape
--   XiPullbackAntiHerglotzTarget_of_honestPackages_lowCompact
--                                                 — final front door consuming `Hlow`

/-- **Low-band compact region predicate.** Equivalent to the
adaptive-band condition for any `T ∈ [2π, 10]`: `0 < z.im ∧
2(1 + |z.re| + z.im) ≤ 10`. -/
def lowCompactRegion (z : ℂ) : Prop :=
  0 < z.im ∧ 2 * (1 + |z.re| + z.im) ≤ 10

/-- ⭐ **PROVED — low `T`-parametric region ⟹ low compact region.** -/
lemma lowCompactRegion_of_lowT
    {z : ℂ} {T : ℝ}
    (_hTlo : 2 * Real.pi ≤ T)
    (hThi : T ≤ 10)
    (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) ≤ T) :
    lowCompactRegion z :=
  ⟨hy, le_trans hregime hThi⟩

/-- 📦 **`XiLowResidualMargin M`** — the actual low-band analytic
target. Says: on the compact low region (`0 < z.im` and
`2(1 + |z.re| + z.im) ≤ 10`), the canonical residual's imaginary part
is dominated by the model margin. A single compact-region inequality. -/
def XiLowResidualMargin
    (M : CloudDensityTailModelDecomposition) : Prop :=
  ∀ z : ℂ,
    lowCompactRegion z →
    |(xiResidualError M z).im| ≤ -(M.model z).im

/-- ⭐ **PROVED — `hlowMargin` (T-parametric) from `XiLowResidualMargin`.**
The compact target subsumes the T-parametric obligation via
`lowCompactRegion_of_lowT`. -/
