-- ¬І16. Phase 1 + Phase 2 scaffolding (codifying ¬І15.A)
-- =====================================================================
-- The four sub-targets of the ¬І15.A roadmap, laid down as named Prop
-- structures with bridge theorems into the existing ¬І13/¬І10 pipeline.
-- Style mirrors ¬І13: define the data, expose Prop-field obligations,
-- and compose into the upstream chain
-- (`PerWindowClosedFormIBPData` / `ZeroCountingFluctuationBound` /
-- `LocalAnalyticZeroFactorization` /
-- `EntireLocalPoleDecompositionHypothesis`).

-- ---------------------------------------------------------------------
-- ¬І16.1. Fluctuation measure data (Phase 1.1)
-- ---------------------------------------------------------------------
-- The pair `(N, NвВА)` of the discrete zero-counting function and the
-- smooth model. The signed-measure `dS = dN вИТ dNвВА` is encoded by the
-- difference `S(u) = N(u) вИТ NвВА(u)` at the function level (the existing
-- ¬І13 `ZeroCountingFluctuationBound` already carries `S` in this
-- form). The structure below pins down the concrete construction of
-- `S` from a zero list `Z : вДХ вЖТ вДЭ` with multiplicities
-- `mult : вДХ вЖТ вДХ` and a smooth `NвВА : вДЭ вЖТ вДЭ` (e.g.
-- `smoothZeroCountingN0`). Once Mathlib's
-- `MeasureTheory.SignedMeasure вДЭ` packaging of
-- `dS = ќ£_{j<n} (mult j) вАҐ dirac (Z j) вИТ volume.withDensity ѕБ` lands,
-- this structure is the function-level bridge.

/-- **Discrete zero-counting function** for a list of zero ordinates
`Z : вДХ вЖТ вДЭ` with multiplicities `mult : вДХ вЖТ вДХ`, truncated to the
first `n` entries:
`N_{Z, mult, n}(u) = ќ£_{j < n, Z j вЙ§ u} mult j`. -/
noncomputable def discreteZeroCounting
    (Z : вДХ вЖТ вДЭ) (mult : вДХ вЖТ вДХ) (n : вДХ) (u : вДЭ) : вДЭ :=
  (Finset.range n).sum
    (fun j => if Z j вЙ§ u then (mult j : вДЭ) else 0)

/-- **Concrete fluctuation function** `S = N вИТ NвВА` from a zero list
and the smooth model. -/
noncomputable def concreteFluctuation
    (Z : вДХ вЖТ вДЭ) (mult : вДХ вЖТ вДХ) (n : вДХ) (NвВА : вДЭ вЖТ вДЭ) (u : вДЭ) : вДЭ :=
  discreteZeroCounting Z mult n u - NвВА u

/-- **Fluctuation measure data.** Packages the inputs to the
signed-measure construction `dS = dN вИТ dNвВА` together with the
function-level fluctuation `S : вДЭ вЖТ вДЭ`. Fields:

* `Z` вАФ zero ordinates (e.g. positive imaginary parts of the
  nontrivial zeros of `XiPullback`);
* `mult` вАФ algebraic multiplicities;
* `n` вАФ number of zeros included in the window;
* `NвВА` вАФ smooth model (concretely `smoothZeroCountingN0`);
* `S` вАФ the named fluctuation function;
* `S_eq` вАФ `S` agrees with the concrete `N вИТ NвВА` construction.

This is the input the ¬І13 `ZeroCountingFluctuationBound.S` field
expects, once the measure-theoretic side of Phase 1.1 lands. -/
structure FluctuationMeasureData where
  Z : вДХ вЖТ вДЭ
  mult : вДХ вЖТ вДХ
  n : вДХ
  NвВА : вДЭ вЖТ вДЭ
  S : вДЭ вЖТ вДЭ
  S_eq : вИА u : вДЭ, S u = concreteFluctuation Z mult n NвВА u

/-- в≠Р **PROVED вАФ fluctuation measure data unfolds to `N вИТ NвВА`.** -/
theorem FluctuationMeasureData.S_def
    (D : FluctuationMeasureData) (u : вДЭ) :
    D.S u =
      (Finset.range D.n).sum
        (fun j => if D.Z j вЙ§ u then (D.mult j : вДЭ) else 0)
      - D.NвВА u := by
  rw [D.S_eq u]; rfl

/-- в≠Р **PROVED вАФ canonical xi-facing instance.** Given any zero list
`Z` with multiplicities `mult`, truncated to `n` entries, the
fluctuation `S = N вИТ smoothZeroCountingN0` (the ¬І13 smooth model) is
a `FluctuationMeasureData`. -/
noncomputable def FluctuationMeasureData.ofXiSmooth
    (Z : вДХ вЖТ вДЭ) (mult : вДХ вЖТ вДХ) (n : вДХ) :
    FluctuationMeasureData where
  Z := Z
  mult := mult
  n := n
  NвВА := smoothZeroCountingN0
  S := fun u => concreteFluctuation Z mult n smoothZeroCountingN0 u
  S_eq := fun _ => rfl

-- ---------------------------------------------------------------------
-- ¬І16.2. Improper Stieltjes integral wrapper (Phase 1.2)
-- ---------------------------------------------------------------------
-- The improper integral `вИЂ_T^вИЮ f(u) dS(u)` is the `atTop` limit of the
-- finite Stieltjes integrals `F(X) = вИЂ_T^X f(u) dS(u)`. At the
-- function level (`S = N вИТ NвВА` as in ¬І16.1), the finite Stieltjes
-- integral splits as
--   `вИЂ_T^X f(u) dS(u)
--      = ќ£_{j: T вЙ§ Z j вЙ§ X} mult j ¬Ј f(Z j)  вИТ  вИЂ_T^X f(u) ¬Ј ѕБ(u) du`.
-- The Prop-level abstraction below names the limit value without
-- committing to that explicit split; the ¬І16.3 IBP bridge uses it.

/-- **Improper Stieltjes integral, function-level convergence.**
`ImproperStieltjesConverges F L` says the partial integral
`F : вДЭ вЖТ вДЭ` tends to `L` as the upper cutoff `X вЖТ вИЮ`. The function
`F` is a parameter so this abstraction is agnostic to whether the
partial integral is encoded via RiemannвАУStieltjes sums,
`intervalIntegral` against a signed measure, or any explicit split. -/
def ImproperStieltjesConverges (F : вДЭ вЖТ вДЭ) (L : вДЭ) : Prop :=
  Tendsto F (Filter.atTop : Filter вДЭ) (рЭУЭ L)

/-- **Improper Stieltjes integral data.** Bundles a candidate
partial-integral function `F : вДЭ вЖТ вДЭ`, a basepoint `T`, and a limit
value `L`, with the proof that `F X вЖТ L` as `X вЖТ вИЮ`. -/
structure ImproperStieltjesIntegralData where
  F : вДЭ вЖТ вДЭ
  T : вДЭ
  L : вДЭ
  converges : ImproperStieltjesConverges F L

/-- **PROVED вАФ extract the limit value.** -/
theorem ImproperStieltjesIntegralData.tendsto
    (I : ImproperStieltjesIntegralData) :
    Tendsto I.F (Filter.atTop : Filter вДЭ) (рЭУЭ I.L) := I.converges

/-- **Imaginary-kernel improper Stieltjes integral.** Specialization
to the integrand `pairedCauchyImKernel x y ¬Ј = Im K_¬Ј(z)` at a fixed
probe `z = x + i¬Јy` and basepoint `T`. The convergence target `L` is
the value of `Im (вИЂ_T^вИЮ K_u(z) dS(u))`. -/
structure ImaginaryKernelImproperIntegral where
  x : вДЭ
  y : вДЭ
  T : вДЭ
  partialIntegral : вДЭ вЖТ вДЭ         -- X вЖ¶ вИЂ_T^X k_z(u) dS(u)
  L : вДЭ                           -- limiting value Im вИЂ_T^вИЮ K dS
  converges : ImproperStieltjesConverges partialIntegral L

-- ---------------------------------------------------------------------
-- ¬І16.2-A. Function-level Stieltjes split (Phase 1 concretization)
-- ---------------------------------------------------------------------
-- The Mathlib signed measure `ќЉ_S = dN вИТ dNвВА` has the awkward feature
-- that `dNвВА = volume.withDensity ѕБ` is infinite on `вДЭ`, so direct
-- subtraction as a `SignedMeasure вДЭ` requires either restricting to a
-- bounded interval or going through localized measures. The
-- *function-level* equivalent вАФ splitting the Stieltjes integral as
--   `вИЂ_T^X f dS = (ќ£_{j: T вЙ§ Z j вЙ§ X} mult j ¬Ј f (Z j))
--                 вИТ (вИЂ_T^X f(u) ¬Ј ѕБ(u) du)`
-- вАФ sidesteps that completely. The discrete partial is computable; the
-- smooth partial is a named field so downstream code can supply it via
-- either an explicit `intervalIntegral` or any other encoding.

/-- **Discrete Stieltjes partial integral.** The contribution to
`вИЂ_T^X f dS` from the discrete Dirac part `dN = ќ£_j mult j ¬Ј ќі_{Z j}`:
  `discreteStieltjesPartial Z mult n f T X
     = ќ£_{j < n : T вЙ§ Z j вЙ§ X} mult j ¬Ј f (Z j)`. -/
noncomputable def discreteStieltjesPartial
    (Z : вДХ вЖТ вДЭ) (mult : вДХ вЖТ вДХ) (n : вДХ) (f : вДЭ вЖТ вДЭ) (T X : вДЭ) : вДЭ :=
  (Finset.range n).sum (fun j =>
    if T вЙ§ Z j вИІ Z j вЙ§ X then (mult j : вДЭ) * f (Z j) else 0)

/-- **Function-level Stieltjes partial integral split.** Encodes
`вИЂ_T^X f dS = (discrete part against `dN`) вИТ (smooth part against `dѕБ`)`
as named data. The `smoothPart` field stays abstract so it can be
either an explicit `intervalIntegral` or a Prop-level commitment to a
downstream integral computation. -/
structure StieltjesPartialSplit where
  Z : вДХ вЖТ вДЭ
  mult : вДХ вЖТ вДХ
  n : вДХ
  f : вДЭ вЖТ вДЭ
  T : вДЭ
  smoothPart : вДЭ вЖТ вДЭ      -- X вЖ¶ вИЂ_T^X f(u) ¬Ј ѕБ(u) du
  total : вДЭ вЖТ вДЭ           -- X вЖ¶ вИЂ_T^X f dS
  total_eq :
    вИА X : вДЭ,
      total X = discreteStieltjesPartial Z mult n f T X - smoothPart X

/-- в≠Р **PROVED вАФ function-level split projects to the abstract
improper-Stieltjes wrapper.** Given a `StieltjesPartialSplit` together
with a limit value `L` and a convergence proof for the `total` field,
construct the `ImproperStieltjesIntegralData` of ¬І16.2. -/
noncomputable def StieltjesPartialSplit.toImproperStieltjesIntegralData
    (S : StieltjesPartialSplit) (L : вДЭ)
    (hconv : ImproperStieltjesConverges S.total L) :
    ImproperStieltjesIntegralData where
  F := S.total
  T := S.T
  L := L
  converges := hconv

/-- в≠Р **PROVED вАФ discrete partial is nonneg when `f вЙ• 0`.** Used in
positivity arguments: the discrete part of any Stieltjes integral
against a nonnegative integrand is nonnegative. -/
theorem discreteStieltjesPartial_nonneg_of_nonneg_f
    {Z : вДХ вЖТ вДЭ} {mult : вДХ вЖТ вДХ} {n : вДХ} {f : вДЭ вЖТ вДЭ} {T X : вДЭ}
    (hf : вИА u : вДЭ, 0 вЙ§ f u) :
    0 вЙ§ discreteStieltjesPartial Z mult n f T X := by
  unfold discreteStieltjesPartial
  apply Finset.sum_nonneg
  intro j _
  by_cases h : T вЙ§ Z j вИІ Z j вЙ§ X
  ¬Ј rw [if_pos h]
    have : (0 : вДЭ) вЙ§ (mult j : вДЭ) := by positivity
    exact mul_nonneg this (hf _)
  ¬Ј rw [if_neg h]

/-- в≠Р **PROVED вАФ discrete partial telescope at `X = T вИТ 1`** (or any
`X < min Z j`): the partial is `0` when the upper cutoff is below all
zero ordinates. Trivially the empty-window case of the discrete
Stieltjes integral. -/
theorem discreteStieltjesPartial_eq_zero_of_X_lt
    {Z : вДХ вЖТ вДЭ} {mult : вДХ вЖТ вДХ} {n : вДХ} {f : вДЭ вЖТ вДЭ} {T X : вДЭ}
    (hX : вИА j : вДХ, j < n вЖТ X < Z j) :
    discreteStieltjesPartial Z mult n f T X = 0 := by
  unfold discreteStieltjesPartial
  apply Finset.sum_eq_zero
  intro j hj
  have hj_lt : j < n := Finset.mem_range.mp hj
  rw [if_neg]
  intro вЯ®_, hZjвЯ©
  exact absurd hZj (not_le_of_gt (hX j hj_lt))

-- ---------------------------------------------------------------------
-- ¬І16.3. IBP bound + `hmargin_from_ibp` bridge (Phase 1.3)
-- ---------------------------------------------------------------------
-- Bundles a `PerWindowClosedFormIBPData` together with the
-- identification `(error z).im = improper Stieltjes integral of
-- Im K_u(z) against dS(u) on [T, вИЮ)`. This is the data the existing
-- `PerWindowClosedFormIBPData.toZeroCountingFluctuationBound` needs to
-- have its `hmargin_from_ibp` hypothesis discharged constructively.

/-- **Stieltjes IBP data for a per-window package.** Given a
`PerWindowClosedFormIBPData` `P`, the analytic content required to
discharge `P.toZeroCountingFluctuationBound`'s `hmargin_from_ibp`
hypothesis splits into:

* `modelMargin_eq` вАФ for every `z` in `P.region` with `Im z > 0`,
  `P.modelMargin = вИТIm(model z)`. (Already a per-probe fact at `P.z`
  via `P.modelMargin_eq`; here we lift it to the whole region.)
* `tail_bound` вАФ for every `z` in `P.region` with `Im z > 0`,
  `|(P.error z).im| вЙ§ P.modelMargin`. This is exactly the IBP-side
  estimate certified by the ¬І13 closed-form S-error bound combined
  with `Im(error z) = вИЂ_T^вИЮ Im K_u(z) dS(u)`.

Together they yield the margin hypothesis required upstream. -/
structure StieltjesIBPDataFor (P : PerWindowClosedFormIBPData) where
  modelMargin_eq :
    вИА z : вДВ, P.region z вЖТ 0 < z.im вЖТ
      P.modelMargin = -(P.model z).im
  tail_bound :
    вИА z : вДВ, P.region z вЖТ 0 < z.im вЖТ
      |(P.error z).im| вЙ§ P.modelMargin

/-- в≠Р **PROVED вАФ Stieltjes IBP data discharges `hmargin_from_ibp`.**
Combine `tail_bound` (IBP-side estimate from ¬І13) and `modelMargin_eq`
(identification of `P.modelMargin` with `вИТIm(model z)`) to get the
margin hypothesis required by
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`. -/
theorem StieltjesIBPDataFor.hmargin
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    вИА z : вДВ, P.region z вЖТ 0 < z.im вЖТ
      |(P.error z).im| вЙ§ -(P.model z).im := by
  intro z hz hzim
  have h1 := D.tail_bound z hz hzim
  rw [D.modelMargin_eq z hz hzim] at h1
  exact h1

/-- в≠Р **PROVED вАФ Stieltjes IBP data + per-window data вЯє
zero-counting fluctuation bound.** Discharges the `hmargin_from_ibp`
hypothesis of the existing
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`
constructively. -/
noncomputable def StieltjesIBPDataFor.toZeroCountingFluctuationBound
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    ZeroCountingFluctuationBound :=
  P.toZeroCountingFluctuationBound D.hmargin

/-- **PROVED вАФ `modelMargin_eq` specializes to the per-probe fact at
`P.z`.** Sanity check: the region-wise generalization `modelMargin_eq`
that `StieltjesIBPDataFor` carries reduces, at the specific probe `P.z`,
to the per-window equality `P.modelMargin = вИТIm(P.model P.z)` that
`PerWindowClosedFormIBPData.modelMargin_eq` already guarantees. -/
theorem StieltjesIBPDataFor.modelMargin_eq_at_probe
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P)
    (hzReg : P.region P.z) (hzim : 0 < P.z.im) :
    P.modelMargin = -(P.model P.z).im :=
  D.modelMargin_eq P.z hzReg hzim

-- ---------------------------------------------------------------------
-- ¬І16.4. Entire-function pole-decomposition data (Phase 2.1)
-- ---------------------------------------------------------------------
-- Mathlib's analyticity machinery вАФ `AnalyticAt`, isolated-zeros via
-- `eventually = 0 вИ® eventually вЙ† 0`, and `HasFPowerSeriesAt` вАФ
-- discharges the local factorization `F z = (z вИТ ѕБ)^m ¬Ј g z` with
-- `g ѕБ вЙ† 0` at any non-degenerate zero of an analytic function. The
-- ¬І10 pipeline already has `LocalAnalyticZeroFactorization вЖТ
-- LocalLogDerivPoleDecomposition`
-- (`localAnalyticZeroFactorization_gives_LocalLogDerivPoleDecomposition`)
-- and `EntireZeroFactorizationHypothesis вЖТ
-- EntireLocalPoleDecompositionHypothesis`
-- (`entireZeroFactorization_gives_EntireLocalPoleDecompositionHypothesis`).
-- The Prop-field structure below isolates exactly what the Mathlib
-- discharge owes: "every analytic non-degenerate zero admits a
-- `LocalAnalyticZeroFactorization`".

/-- **Analytic-zero non-degeneracy.** `F` is analytic at `ѕБ` and is
not eventually zero near `ѕБ`. By Mathlib's
`AnalyticAt.eventuallyEq_zero_or_eventually_ne_zero` (or the
power-series formulation), this is exactly the hypothesis under which
a positive-order vanishing is well-defined. -/
structure AnalyticZeroNonDegenerate (F : вДВ вЖТ вДВ) (ѕБ : вДВ) : Prop where
  isAnalytic : AnalyticAt вДВ F ѕБ
  not_eventually_zero : ¬ђ (вИАбґ† z in рЭУЭ ѕБ, F z = 0)

/-- **Promise: every analytic non-degenerate zero admits a local
factorization.** This is the Mathlib content of Phase 2.1 вАФ for any
`F` analytic at `ѕБ` with `F ѕБ = 0` and `F` not locally identically
zero, there exist `m > 0` and an analytic `g` with `g ѕБ вЙ† 0` and
`F z = (z вИТ ѕБ)^m ¬Ј g z` near `ѕБ`. Isolated here as a `Prop` for
discharge against `Mathlib.Analysis.Analytic.IsolatedZeros`. -/
def AnalyticZeroAdmitsFactorization (F : вДВ вЖТ вДВ) (ѕБ : вДВ) : Prop :=
  AnalyticZeroNonDegenerate F ѕБ вЖТ
  F ѕБ = 0 вЖТ
  Nonempty (LocalAnalyticZeroFactorization F ѕБ)

/-- **Global form: every zero of `F` admits the factorization.** Per
zero, this is the Mathlib content; collected over all of `вДВ`, this is
the entire-function-level promise. -/
def EntireAnalyticZerosAdmitFactorization (F : вДВ вЖТ вДВ) : Prop :=
  вИА ѕБ : вДВ, AnalyticZeroAdmitsFactorization F ѕБ

/-- **Upper-half-plane non-degenerate zero data for `F`.** At every
upper-half-plane zero of `F`, the function is analytic and not locally
identically zero. For any non-identically-zero analytic function on a
connected open set containing the UHP, this is automatic from
`AnalyticAt.eventuallyEq_zero_or_eventually_ne_zero`. -/
def EntireZerosNonDegenerate (F : вДВ вЖТ вДВ) : Prop :=
  вИА ѕБ : вДВ, F ѕБ = 0 вЖТ 0 < ѕБ.im вЖТ AnalyticZeroNonDegenerate F ѕБ

/-- в≠Р **PROVED вАФ Mathlib-promise + non-degeneracy вЯє entire-function
zero-factorization hypothesis.** One-line composition: at each
upper-half-plane zero, the non-degeneracy gate gives an
`AnalyticZeroNonDegenerate`, the global promise produces a
`LocalAnalyticZeroFactorization`, and the existing pipeline carries
it the rest of the way. -/
theorem entireZeroFactorization_of_analytic
    {F : вДВ вЖТ вДВ}
    (h_admits : EntireAnalyticZerosAdmitFactorization F)
    (h_nondeg : EntireZerosNonDegenerate F) :
    EntireZeroFactorizationHypothesis F where
  factor_at_each_upper_zero ѕБ hzero hupper :=
    h_admits ѕБ (h_nondeg ѕБ hzero hupper) hzero

/-- в≠Р **PROVED вАФ composed bridge: analytic + non-degenerate UHP zeros
вЯє ¬І10 entire-function pole-decomposition hypothesis.** Composes
`entireZeroFactorization_of_analytic` (¬І16.4) with the existing ¬І10
`entireZeroFactorization_gives_EntireLocalPoleDecompositionHypothesis`. -/
theorem entireLocalPoleDecomposition_of_analytic
    {F : вДВ вЖТ вДВ}
    (h_admits : EntireAnalyticZerosAdmitFactorization F)
    (h_nondeg : EntireZerosNonDegenerate F) :
    EntireLocalPoleDecompositionHypothesis F :=
  entireZeroFactorization_gives_EntireLocalPoleDecompositionHypothesis
    (entireZeroFactorization_of_analytic h_admits h_nondeg)

/-- в≠Р **PROVED вАФ full Phase 2.1 composition: anti-Herglotz + Schwarz
symmetry + analyticity + UHP-zero non-degeneracy вЯє all zeros real.**
The ¬І10 entire-function template
(`entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm`)
takes `EntireLocalPoleDecompositionHypothesis`, which ¬І16.4 now
discharges from the natural analytic inputs. -/
theorem entire_function_roots_real_of_analytic_inputs
    (F : вДВ вЖТ вДВ)
    (h_admits : EntireAnalyticZerosAdmitFactorization F)
    (h_nondeg : EntireZerosNonDegenerate F)
    (hanti : AntiHerglotzUHP (logDerivativeResponse F))
    (hsym : вИА z : вДВ, F (star z) = star (F z)) :
    вИА ѕБ : вДВ, F ѕБ = 0 вЖТ ѕБ.im = 0 :=
  entire_function_roots_real_of_logDeriv_antiHerglotz_and_conjSymm F
    (entireLocalPoleDecomposition_of_analytic h_admits h_nondeg)
    hanti hsym

-- ---------------------------------------------------------------------
-- ¬І16.4-A. Mathlib discharge of the analytic factorization promise
-- ---------------------------------------------------------------------
-- The Prop `AnalyticZeroAdmitsFactorization F ѕБ` from ¬І16.4 is the
-- isolated-zero content of complex analysis: every analytic
-- non-degenerate zero admits the local factorization
-- `F z = (z вИТ ѕБ)^m ¬Ј g z` with `g ѕБ вЙ† 0`. Mathlib's
-- `AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff`
-- (`Mathlib.Analysis.Analytic.IsolatedZeros`) supplies this directly;
-- this subsection wires it in and reduces `AnalyticZeroAdmitsFactorization`
-- to a *theorem*, not a hypothesis. The downstream effect: the
-- `h_admits` field of `entire_function_roots_real_of_analytic_inputs`
-- is now automatic вАФ see
-- `entire_function_roots_real_of_analytic_nondeg` below.

/-- в≠Р **PROVED вАФ Mathlib discharge of `AnalyticZeroAdmitsFactorization`.**
Given any function `F : вДВ вЖТ вДВ` analytic and non-degenerate at `ѕБ`
with `F ѕБ = 0`, Mathlib's isolated-zeros machinery extracts a
positive multiplicity `m` and an analytic non-vanishing remainder
`g`. The proof:

* `AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff` gives
  `(n, g, hg_an, hg_ne, hg_eq)` with `F z = (z вИТ ѕБ)^n вАҐ g z` near `ѕБ`;
* `n > 0` follows: if `n = 0` then `F ѕБ = g ѕБ`, contradicting
  `F ѕБ = 0` and `g ѕБ вЙ† 0`;
* `вАҐ` becomes `*` via `smul_eq_mul` on `вДВ`;
* `g` is differentiable in a neighborhood of `ѕБ` via
  `AnalyticAt.eventually_analyticAt` + `AnalyticAt.differentiableAt`;
* `deriv g / g` is continuous at `ѕБ` via `AnalyticAt.deriv` +
  `AnalyticAt.continuousAt` + `ContinuousAt.div`. -/
theorem analytic_zero_admits_factorization
    (F : вДВ вЖТ вДВ) (ѕБ : вДВ) :
    AnalyticZeroAdmitsFactorization F ѕБ := by
  intro hND hzero
  obtain вЯ®n, g, hg_an, hg_ne, hg_eqвЯ© :=
    (AnalyticAt.exists_eventuallyEq_pow_smul_nonzero_iff hND.isAnalytic).mpr
      hND.not_eventually_zero
  -- Show `n > 0` from `F ѕБ = 0` and `g ѕБ вЙ† 0`.
  have hm_pos : 0 < n := by
    by_contra hcon
    push_neg at hcon
    have hn0 : n = 0 := Nat.le_zero.mp hcon
    subst hn0
    have heq : F ѕБ = (ѕБ - ѕБ) ^ 0 вАҐ g ѕБ := hg_eq.self_of_nhds
    simp at heq
    rw [hzero] at heq
    exact hg_ne heq.symm
  -- Convert `вАҐ` to `*` (canonical вДВ-action).
  have hfactor : вИАбґ† z in рЭУЭ ѕБ, F z = (z - ѕБ) ^ n * g z := by
    filter_upwards [hg_eq] with z hz
    rw [hz, smul_eq_mul]
  -- `g` is differentiable in a neighborhood of `ѕБ`.
  have hg_diff_nhds : вИАбґ† z in рЭУЭ ѕБ, DifferentiableAt вДВ g z := by
    filter_upwards [hg_an.eventually_analyticAt] with z hz
    exact hz.differentiableAt
  -- `deriv g / g` is continuous at `ѕБ`.
  have hcont_background : ContinuousAt (fun z => deriv g z / g z) ѕБ :=
    hg_an.deriv.continuousAt.div hg_an.continuousAt hg_ne
  exact вЯ®{ m := n
           hm_pos := hm_pos
           g := g
           hgѕБ := hg_ne
           hg_diff_nhds := hg_diff_nhds
           hcont_background := hcont_background
           hfactor := hfactor }вЯ©

/-- в≠Р **PROVED вАФ entire-function Mathlib discharge.** The global form:
every `F : вДВ вЖТ вДВ` automatically inhabits
`EntireAnalyticZerosAdmitFactorization`. -/
theorem entireAnalyticZerosAdmitFactorization_holds
    (F : вДВ вЖТ вДВ) :
    EntireAnalyticZerosAdmitFactorization F :=
  fun ѕБ => analytic_zero_admits_factorization F ѕБ

/-- в≠Р **PROVED вАФ strengthened Phase 2.1 capstone.** With the Mathlib
discharge `entireAnalyticZerosAdmitFactorization_holds` in hand, the
`h_admits` hypothesis of
`entire_function_roots_real_of_analytic_inputs` is automatic. The
remaining open inputs are exactly:

* `h_nondeg` вАФ `F` is not eventually zero at any upper-half-plane zero
  (automatic for any entire `F вЙҐ 0`);
* `hanti` вАФ `ќЫ[F]` is anti-Herglotz on the UHP (the genuine analytic
  mountain);
* `hsym` вАФ `F(zћД) = conj F(z)` (Schwarz reflection; classical for `ќЮ`).

Specializing `F := XiPullback` and supplying these three is the
remaining open content of RH-via-overflow-residue. -/
theorem entire_function_roots_real_of_analytic_nondeg
    (F : вДВ вЖТ вДВ)
    (h_nondeg : EntireZerosNonDegenerate F)
    (hanti : AntiHerglotzUHP (logDerivativeResponse F))
    (hsym : вИА z : вДВ, F (star z) = star (F z)) :
    вИА ѕБ : вДВ, F ѕБ = 0 вЖТ ѕБ.im = 0 :=
  entire_function_roots_real_of_analytic_inputs F
    (entireAnalyticZerosAdmitFactorization_holds F) h_nondeg hanti hsym

