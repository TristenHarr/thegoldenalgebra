    {T : тДЭ} (hT32 : 32 тЙд T) (_hT36 : T тЙд 36) :
    tailK32_rat T тЙд tailK_32_36 T := by
  unfold tailK32_rat tailK_32_36
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have h_pi_inv : (7 / 44 : тДЭ) тЙд 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_factor_nn : (0 : тДЭ) тЙд (22 / 15 : тДЭ) * (8 / 5) := by norm_num
  have h_step1 :
      (22 / 15 : тДЭ) * (8 / 5) * (7 / 44)
        тЙд (22 / 15 : тДЭ) * (8 / 5) * (1 / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_pi_inv h_factor_nn
  have h_form_eq :
      (22 / 15 : тДЭ) * ((8 / 5 : тДЭ) / (2 * Real.pi)) / T
        = (22 / 15 : тДЭ) * (8 / 5) * (1 / (2 * Real.pi)) / T := by ring
  rw [h_form_eq]
  apply div_le_div_of_nonneg_right h_step1 (le_of_lt hT_pos)

/-- тнР **PROVED тАФ `tailK32_rat` is anti-monotone in `T`.** -/
lemma tailK32_rat_antitone_T {TтВБ TтВВ : тДЭ}
    (hTтВБ_pos : 0 < TтВБ) (h_T_le : TтВБ тЙд TтВВ) :
    tailK32_rat TтВВ тЙд tailK32_rat TтВБ := by
  unfold tailK32_rat
  have hTтВВ_pos : 0 < TтВВ := by linarith
  have hinv : 1 / TтВВ тЙд 1 / TтВБ := one_div_le_one_div_of_le hTтВБ_pos h_T_le
  have h_pos_factor : (0 : тДЭ) тЙд (22 / 15) * (8 / 5) * (7 / 44) := by norm_num
  have h_formтВБ : (22 / 15 : тДЭ) * (8/5) * (7/44) / TтВБ
                  = (22 / 15) * (8/5) * (7/44) * (1/TтВБ) := by ring
  have h_formтВВ : (22 / 15 : тДЭ) * (8/5) * (7/44) / TтВВ
                  = (22 / 15) * (8/5) * (7/44) * (1/TтВВ) := by ring
