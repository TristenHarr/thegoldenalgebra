/-! ### CW15: discharge `rightLogDerivPlain` via compactness + analyticity -/

/-- Compactness wrapper: if `y вЖ¶ вАЦ(deriv ќґ / ќґ)(2 + iy)вАЦ` is continuous
on `[T, T + 1]`, then it is bounded there. -/
theorem exists_bound_zeta_logDeriv_rightSide_of_continuousOn
    (T : вДЭ)
    (hcont :
      ContinuousOn
        (fun y : вДЭ =>
          вАЦderiv riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) /
              riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I)вАЦ)
        (Set.Icc T (T + 1))) :
    вИГ C : вДЭ, 0 вЙ§ C вИІ
      вИА y : вДЭ, T вЙ§ y вЖТ y вЙ§ T + 1 вЖТ
        вАЦderiv riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) /
            riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I)вАЦ вЙ§ C := by
  have hcomp : IsCompact (Set.Icc T (T + 1)) := isCompact_Icc
  have hne : (Set.Icc T (T + 1)).Nonempty :=
    Set.nonempty_Icc.mpr (by linarith)
  obtain вЯ®yвВА, _hyвВАmem, hyвВАmaxвЯ© :=
    hcomp.exists_isMaxOn hne hcont
  set M : вДЭ :=
    вАЦderiv riemannZeta ((2 : вДВ) + (yвВА : вДВ) * Complex.I) /
        riemannZeta ((2 : вДВ) + (yвВА : вДВ) * Complex.I)вАЦ with hM_def
  refine вЯ®max M 0, le_max_right _ _, ?_вЯ©
  intro y hyT hyT1
  have hmem : y вИИ Set.Icc T (T + 1) := вЯ®hyT, hyT1вЯ©
  have hle :
      вАЦderiv riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) /
          riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I)вАЦ вЙ§ M :=
    hyвВАmax hmem
  exact le_trans hle (le_max_left _ _)

/-- For every `T вЙ• 140`, the function `y вЖ¶ вАЦ(deriv ќґ / ќґ)(2 + iy)вАЦ` is
continuous on `[T, T + 1]`.  Uses analyticity of `ќґ` away from `1`
(`riemannZeta_analyticAt_of_ne_one`), the derived continuity of
`deriv ќґ`, and the nonvanishing of `ќґ` on `Re s = 2`. -/
theorem continuousOn_zeta_logDeriv_rightSide
    (T : вДЭ) (_hT : (140 : вДЭ) вЙ§ T) :
    ContinuousOn
      (fun y : вДЭ =>
        вАЦderiv riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) /
            riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I)вАЦ)
      (Set.Icc T (T + 1)) := by
  intro y _hy
  refine ContinuousAt.continuousWithinAt ?_
  -- Re(2 + iy) = 2.
  have hre :
      ((2 : вДВ) + (y : вДВ) * Complex.I).re = 2 := by
    simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
          Complex.ofReal_re, Complex.ofReal_im]
  have hne : ((2 : вДВ) + (y : вДВ) * Complex.I) вЙ† 1 := by
    intro heq
    have h1re : ((1 : вДВ).re) = 2 := by rw [вЖР hre, heq]
    norm_num at h1re
  have hzeta_ne :
      riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) вЙ† 0 :=
    riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)
  have hAn :
      AnalyticAt вДВ riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) :=
    riemannZeta_analyticAt_of_ne_one hne
  -- Continuity of `z вЖ¶ (deriv ќґ / ќґ) z` at 2 + iy.
  have hquot_at :
      ContinuousAt
        (fun z : вДВ => deriv riemannZeta z / riemannZeta z)
        ((2 : вДВ) + (y : вДВ) * Complex.I) :=
    (hAn.deriv.continuousAt).div hAn.continuousAt hzeta_ne
  -- Line y вЖ¶ 2 + iy is continuous.
  have hline_cont :
      Continuous (fun y : вДЭ => (2 : вДВ) + (y : вДВ) * Complex.I) :=
    continuous_const.add
      (Complex.continuous_ofReal.mul continuous_const)
  -- Compose into a real вЖТ вДВ function and take norm.
  have hcompose_at :
      ContinuousAt
        (fun y : вДЭ =>
          deriv riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I) /
            riemannZeta ((2 : вДВ) + (y : вДВ) * Complex.I)) y := by
    change ContinuousAt
      ((fun z : вДВ => deriv riemannZeta z / riemannZeta z) вИШ
        (fun y : вДЭ => (2 : вДВ) + (y : вДВ) * Complex.I)) y
    refine ContinuousAt.comp ?_ hline_cont.continuousAt
    exact hquot_at
  exact hcompose_at.norm

/-- **CW15 вАФ `ZetaLogDerivPlainBoundOnBacklundRightSideInput` DISCHARGED.**
Compactness of `[T, T + 1]` + continuity of `y вЖ¶ вАЦ(deriv ќґ / ќґ)(2 + iy)вАЦ`. -/
theorem zetaLogDerivPlainBoundOnBacklundRightSideInput :
    ZetaLogDerivPlainBoundOnBacklundRightSideInput where
  bound := by
    intro T hT
    exact exists_bound_zeta_logDeriv_rightSide_of_continuousOn T
      (continuousOn_zeta_logDeriv_rightSide T hT)

