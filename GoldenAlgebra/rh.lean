-- =====================================================================
-- ┬зCCC. Master xi explicit-formula source тАФ tail (high + mid)
-- =====================================================================
-- All remaining xi-side targets share one conceptual source:
--   ╬Ы[╬Ю](z) = honest model(z) + fluctuation contribution
-- where the fluctuation contribution is a tail Stieltjes integral
-- (mid/high) or a bounded boundary-plus-finite integral (low).
--
-- This section defines `XiModelTailExplicitFormula` тАФ the master source
-- for high + mid тАФ and exhibits the bridges to `decomp_high` and
-- `decomp_mid` of ┬зCCXCVII's `XiLogDerivativeModelTailDecomposition`.

/-- ЁЯУж **`XiFluctuationTailValue`** тАФ names the tail-limit value `L` of
the true-kernel partials against the fluctuation primitive starting at
cutoff `T`. Used to avoid premature `Classical.choose` while still
referring to a specific limit. -/
structure XiFluctuationTailValue
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 T : тДЭ)
    (z L : тДВ) : Prop where
  tendsto_tail :
    Tendsto
      (fun X : тДЭ =>
        complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          T X z)
      Filter.atTop
      (ЁЭУЭ L)

/-- ЁЯУж **`XiModelTailExplicitFormula`** тАФ master source for both `decomp_high`
and `decomp_mid`. Says for every `(z, T)` in the adaptive regime,
there is a tail-limit value `L` with `╬Ы[╬Ю](z) = M.model z + L`. -/
structure XiModelTailExplicitFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  explicit_formula :
    тИА {z : тДВ} {T : тДЭ},
      0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 T z L тИз
        logDerivativeResponse XiPullback z = M.model z + L

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `decomp_high` bridge from `XiModelTailExplicitFormula`.**
Specializes the master formula to `T тЙе 140`. -/
theorem decomp_high_of_modelTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
