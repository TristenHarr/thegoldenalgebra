    XiFluctuationTailValue_exists_high_of_highLog
      Dzero T0 hT0_pos hT0_le_140 hHighLog hT140 hy hregime
  have hZ := HmidHigh.high_eq hT140 hy hne hregime hL
  have hlog := Hsrc.logDeriv_eq_zeroContribution z hy hne
  have hres :
      xiResidualError honestZeroDensityModelTwoPi z = L := by
    unfold xiResidualError
    rw [hlog, hZ, honestZeroDensityModelTwoPi_model_eq]
    ring
