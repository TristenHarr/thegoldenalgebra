      (n := 5) (by norm_num)
  have h_num_pow_le : (2.7182818286 : ÔäØ)^5 Ôëñ (11 / 2 : ÔäØ)^3 := by norm_num
  have h_exp_1_pow_le : (Real.exp 1)^5 Ôëñ (11 / 2 : ÔäØ)^3 := by linarith
  have h_exp_5_eq : Real.exp 5 = (Real.exp 1)^5 := by
    have h := Real.exp_one_pow 5
    have h_cast : ((5 : Ôäò) : ÔäØ) = (5 : ÔäØ) := by norm_num
    rw [ÔåÉ h_cast]; exact h.symm
  have h_exp_5_le : Real.exp 5 Ôëñ (11 / 2 : ÔäØ)^3 := by
