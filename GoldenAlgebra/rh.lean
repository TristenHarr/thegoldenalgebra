  тИА {z : тДВ} {T : тДЭ},
    10 тЙд T тЖТ T тЙд 140 тЖТ
    0 < z.im тЖТ
    2 * (1 + |z.re| + z.im) тЙд T тЖТ
      |(error z).im|
        тЙд closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T

/-- ЁЯМЯ **PROVED тАФ Finite-band error margin** via `slabCD`. Direct `le_trans`
chaining the IBP-side error bound with the slab-side model-margin
domination тАФ BOTH using the same `(slabCD T).1, (slabCD T).2`. -/
theorem finiteBand_errorMargin_of_slabCD
    {M : CloudDensityTailModelDecomposition}
    {error : тДВ тЖТ тДВ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : closedFormErrorControlledOnFiniteBand error)
    {z : тДВ} {T : тДЭ}
    (hT10 : 10 тЙд T) (hT140 : T тЙд 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    |(error z).im| тЙд -(M.model z).im :=
  le_trans (herr hT10 hT140 hy hreg)
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hT10 hT140 hy hreg)

-- =====================================================================
-- CLXXXV: Concrete `xiCloudDensityModel_zeros100ceil`
-- =====================================================================
-- A trivial-but-valid concrete `CloudDensityTailModelDecomposition`
-- with `zeros = zeros100ceil`. Uses a deliberately massive linear density
-- tail `densityTail z := -i ┬╖ (100 ┬╖ z.im)` so the `densityTailRationalLB`
-- obligation reduces to the crude bound `smoothTail тЙд 100┬╖y` on the
-- adaptive region. Plumbing only тАФ the real analytic decomposition and
-- IBP/Stieltjes error bound remain open.

/-- **Trivial massive-margin density tail.** `-i ┬╖ 100┬╖z.im` so its
`-Im` is `100┬╖z.im`, which trivially dominates any reasonable
`smoothTailRationalLowerBoundAbs` on the admissible region. -/
noncomputable def linearDensityTail100 : тДВ тЖТ тДВ :=
  fun z => -Complex.I * ((100 * z.im : тДЭ) : тДВ)

/-- тнР **PROVED тАФ `-Im(linearDensityTail100 z) = 100┬╖z.im`.** -/
lemma linearDensityTail100_neg_im (z : тДВ) :
    -(linearDensityTail100 z).im = 100 * z.im := by
  unfold linearDensityTail100
  simp [Complex.mul_im, Complex.neg_im, Complex.I_re, Complex.I_im,
        Complex.ofReal_re, Complex.ofReal_im]

/-- тнР **PROVED тАФ `(linearDensityTail100 z).im = -100┬╖z.im тЙд 0`** for `0 < z.im`. -/
lemma linearDensityTail100_im_nonpos
    {z : тДВ} (hz : 0 < z.im) :
    (linearDensityTail100 z).im тЙд 0 := by
  have h := linearDensityTail100_neg_im z
  linarith

/-- тнР **PROVED тАФ `zeroDensityRho T тЙд T`** for `T тЙе 2╧А`.
Via `log x тЙд x` applied to `x = T/(2╧А)`, then `log(T/(2╧А))/(2╧А) тЙд T/(4╧А┬▓) тЙд T`
(since `4╧А┬▓ > 1`). -/
lemma zeroDensityRho_le_T
    {T : тДЭ} (hT2pi : 2 * Real.pi тЙд T) :
    zeroDensityRho T тЙд T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_pos : 0 < T / (2 * Real.pi) := by positivity
  have h_log_le : Real.log (T / (2 * Real.pi)) тЙд T / (2 * Real.pi) - 1 :=
    Real.log_le_sub_one_of_pos hT_2pi_pos
  have h_log_le_T_2pi : Real.log (T / (2 * Real.pi)) тЙд T / (2 * Real.pi) := by
    linarith
  have h_inv_pos : (0 : тДЭ) < 1 / (2 * Real.pi) := by positivity
  have h_step :
      (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        тЙд (1 / (2 * Real.pi)) * (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_log_le_T_2pi (le_of_lt h_inv_pos)
  -- (1/(2╧А))┬╖(T/(2╧А)) = T/(4╧А┬▓)
  have h_2pi_ne : (2 * Real.pi : тДЭ) тЙа 0 := ne_of_gt h_2pi_pos
  have h_eq :
      (1 / (2 * Real.pi)) * (T / (2 * Real.pi))
        = T / ((2 * Real.pi)^2) := by
    rw [sq, mul_comm (2 * Real.pi) (2 * Real.pi)]
    field_simp
  have h_2pi_sq_gt_1 : (1 : тДЭ) тЙд (2 * Real.pi)^2 := by
    nlinarith [h_pi_gt_d2]
  have h_T_div_le : T / ((2 * Real.pi)^2) тЙд T := by
    rw [div_le_iffтВА (by positivity : (0:тДЭ) < (2 * Real.pi)^2)]
    nlinarith [hT_pos, h_2pi_sq_gt_1]
  linarith [h_step, h_eq, h_T_div_le]

/-- тнР **PROVED тАФ Crude smooth-tail kernel bound.**
On the admissible region, each kernel term `y┬╖U/(U┬▓+y┬▓) тЙд y/U`, and
`T-|x|, T+|x| тЙе T/2` gives `y/U тЙд 2y/T`. So the sum is `тЙд 4y/T`,
which we round up to `5y/T` for safety margin (any bound suffices). -/
lemma smoothTail_kernel_le_five_y_div_T
    {x y T : тДЭ}
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) тЙд T) :
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))
      тЙд 5 * y / T := by
  have h_absx_nn : 0 тЙд |x| := abs_nonneg _
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hT_ge : T тЙе 2 := by linarith
  have hT_pos : 0 < T := by linarith
  have hTpos2 : 0 < T / 2 := by linarith
  -- |x| тЙд T/2 - 1, y тЙд T/2 - 1, so T - |x| тЙе T/2 + 1 > T/2
  have h_T_minus_x_lo : T / 2 тЙд T - |x| := by linarith
  have h_T_plus_x_lo : T тЙд T + |x| := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_T_plus_x_pos : 0 < T + |x| := by linarith
  -- First term: y┬╖(T-|x|)/((T-|x|)┬▓+y┬▓) тЙд y/(T-|x|)
  have h_term1_bound : y * (T - |x|) / ((T - |x|)^2 + y^2) тЙд y / (T - |x|) := by
    rw [div_le_div_iffтВА (by positivity : 0 < (T - |x|)^2 + y^2) h_T_minus_x_pos]
    nlinarith [sq_nonneg (T - |x|), sq_nonneg y]
  have h_term2_bound : y * (T + |x|) / ((T + |x|)^2 + y^2) тЙд y / (T + |x|) := by
    rw [div_le_div_iffтВА (by positivity : 0 < (T + |x|)^2 + y^2) h_T_plus_x_pos]
    nlinarith [sq_nonneg (T + |x|), sq_nonneg y]
  -- y/(T-|x|) тЙд y/(T/2) = 2y/T
  have h_term1_le_2yT : y / (T - |x|) тЙд 2 * y / T := by
    rw [div_le_div_iffтВА h_T_minus_x_pos hT_pos]
    nlinarith [h_T_minus_x_lo, hy_nn]
  have h_term2_le_yT : y / (T + |x|) тЙд y / T :=
    div_le_div_of_nonneg_left hy_nn hT_pos h_T_plus_x_lo
  -- Combine: total тЙд 2y/T + y/T = 3y/T тЙд 5y/T
  have h_total : y / (T - |x|) + y / (T + |x|) тЙд 3 * y / T := by
    have : 2 * y / T + y / T = 3 * y / T := by ring
    linarith [h_term1_le_2yT, h_term2_le_yT]
  have h3le5 : 3 * y / T тЙд 5 * y / T := by
    apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
    nlinarith
  linarith [h_term1_bound, h_term2_bound, h_total, h3le5]

/-- тнР **PROVED тАФ Crude smooth-tail upper bound on the adaptive region.**
`smoothTail тЙд ╧Б(T)┬╖5y/T тЙд T┬╖5y/T = 5y тЙд 100┬╖y`. -/
lemma smoothTailRationalLowerBoundAbs_le_100y
    {x y T : тДЭ}
    (hT2pi : 2 * Real.pi тЙд T)
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) тЙд T) :
    smoothTailRationalLowerBoundAbs x y T тЙд 100 * y := by
  unfold smoothTailRationalLowerBoundAbs
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 тЙд y := le_of_lt hy
  have h_rho_le : zeroDensityRho T тЙд T := zeroDensityRho_le_T hT2pi
  have h_rho_nn : 0 тЙд zeroDensityRho T := by
    unfold zeroDensityRho
    have h_2pi_pos : 0 < 2 * Real.pi := by linarith
    have hT_2pi_ge_one : (1 : тДЭ) тЙд T / (2 * Real.pi) := by
      rw [le_div_iffтВА h_2pi_pos]; linarith
    have h_log_nn : 0 тЙд Real.log (T / (2 * Real.pi)) := Real.log_nonneg hT_2pi_ge_one
    positivity
  have h_kernel : (y * (T - |x|) / ((T - |x|)^2 + y^2)
                    + y * (T + |x|) / ((T + |x|)^2 + y^2))
                    тЙд 5 * y / T :=
    smoothTail_kernel_le_five_y_div_T hy hreg
  have h_kernel_nn :
      0 тЙд y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h_absx_nn : 0 тЙд |x| := abs_nonneg _
    have hT_ge : T тЙе 2 := by linarith
    have h_T_minus_x_pos : 0 < T - |x| := by linarith
    have h_T_plus_x_pos : 0 < T + |x| := by linarith
    have h1 : 0 тЙд y * (T - |x|) / ((T - |x|)^2 + y^2) := by
      apply div_nonneg
      ┬╖ exact mul_nonneg hy_nn (le_of_lt h_T_minus_x_pos)
      ┬╖ positivity
    have h2 : 0 тЙд y * (T + |x|) / ((T + |x|)^2 + y^2) := by
      apply div_nonneg
      ┬╖ exact mul_nonneg hy_nn (le_of_lt h_T_plus_x_pos)
      ┬╖ positivity
    linarith
  have h_combine :
      zeroDensityRho T * (y * (T - |x|) / ((T - |x|)^2 + y^2)
        + y * (T + |x|) / ((T + |x|)^2 + y^2))
        тЙд T * (5 * y / T) := by
    apply mul_le_mul h_rho_le h_kernel h_kernel_nn (by linarith)
  have h_T5y : T * (5 * y / T) = 5 * y := by
    field_simp
  have h_5y_le : 5 * y тЙд 100 * y := by linarith
  linarith

/-- тнР **PROVED тАФ `linearDensityTail100` discharges the rational LB obligation.** -/
theorem linearDensityTail100_rationalLB :
    тИА z : тДВ, тИА T : тДЭ, 2 * Real.pi тЙд T тЖТ 0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
        smoothTailRationalLowerBoundAbs z.re z.im T
          тЙд -(linearDensityTail100 z).im := by
  intro z T hT2pi hy hreg
  rw [linearDensityTail100_neg_im]
  exact smoothTailRationalLowerBoundAbs_le_100y hT2pi hy hreg

