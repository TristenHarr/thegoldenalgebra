  unfold centeredSquareUnitKernelIntegral twoPiI
  rw [centeredSquare_bottom_eq_pi_over_two_I h¤ü,
      centeredSquare_right_eq_pi_over_two_I h¤ü,
      centeredSquare_top_eq_pi_over_two_I h¤ü,
