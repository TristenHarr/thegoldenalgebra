/-- Platt/Trudgian-style finite-range computational bound for `S(T)`.
The published numerical form used here is `|S(T)| вЙ§ 2.5167` through a
very large verified zero range; the upper endpoint is included so this
can later be tied to the exact certificate/database used. -/
structure PlattTrudgianFiniteRangeSBoundInput : Prop where
  bound :
    вИА T : вДЭ, 0 вЙ§ T вЖТ T вЙ§ (30610046000 : вДЭ) вЖТ
      |concreteS T| вЙ§ (25167 / 10000 : вДЭ)

/-- `exp (24/5) < 140`, used to show the target half-log budget already
dominates `2.5167` at `T = 140`. -/
theorem backlund_exp_24_5_lt_140 : Real.exp (24 / 5 : вДЭ) < 140 := by
  have h_e_lt : Real.exp 1 < 2.72 :=
    lt_trans Real.exp_one_lt_d9 (by norm_num)
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_pow_lt : (Real.exp 1)^24 < (2.72 : вДЭ)^24 :=
    pow_lt_pow_leftвВА h_e_lt (le_of_lt h_e_pos) (by norm_num)
  have h_exp24_eq : Real.exp (24 : вДЭ) = (Real.exp 1)^24 := by
    have h := Real.exp_one_pow 24
    have h_cast : ((24 : вДХ) : вДЭ) = (24 : вДЭ) := by norm_num
    rw [вЖР h_cast]
    exact h.symm
  have h_exp_24_5_pow : (Real.exp (24 / 5 : вДЭ))^5 = Real.exp 24 := by
    have h := Real.exp_nat_mul (24 / 5 : вДЭ) 5
    have h_eq : ((5 : вДХ) : вДЭ) * (24 / 5 : вДЭ) = 24 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h_pow_num : (2.72 : вДЭ)^24 < (140 : вДЭ)^5 := by norm_num
  have h_exp_pow_lt :
      (Real.exp (24 / 5 : вДЭ))^5 < (140 : вДЭ)^5 := by
    rw [h_exp_24_5_pow, h_exp24_eq]
    linarith
  have hexp_nn : 0 вЙ§ Real.exp (24 / 5 : вДЭ) :=
    le_of_lt (Real.exp_pos _)
  have h140_nn : (0 : вДЭ) вЙ§ 140 := by norm_num
  exact
    (pow_lt_pow_iff_leftвВА hexp_nn h140_nn
      (by norm_num : (5 : вДХ) вЙ† 0)).mp h_exp_pow_lt

/-- For `T вЙ• 140`, `log T вЙ• 24/5`. -/
theorem backlund_log_ge_24_5_of_ge_140
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    (24 / 5 : вДЭ) вЙ§ Real.log T := by
  have h_exp_lt : Real.exp (24 / 5 : вДЭ) < T :=
    lt_of_lt_of_le backlund_exp_24_5_lt_140 hT
  have h_exp_pos : 0 < Real.exp (24 / 5 : вДЭ) := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos (le_of_lt h_exp_lt)
  rwa [Real.log_exp] at h

/-- At every `T вЙ• 140`, the target budget dominates `2.5167`. -/
theorem plattTrudgianFiniteBound_le_halfLogPlusHalf_of_ge_140
    {T : вДЭ} (hT : (140 : вДЭ) вЙ§ T) :
    (25167 / 10000 : вДЭ)
      вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 := by
  have hlog := backlund_log_ge_24_5_of_ge_140 hT
  linarith

/-- The Platt/Trudgian finite-range `2.5167` bound supplies the compact
check on `[140, 1200]`. -/
noncomputable def BacklundFiniteBandCheck140_1200.of_plattTrudgian
    (H : PlattTrudgianFiniteRangeSBoundInput) :
    BacklundFiniteBandCheck140_1200 where
  bound := by
    intro T hT140 hT1200
    have hT0 : 0 вЙ§ T := by linarith
    have hTbig : T вЙ§ (30610046000 : вДЭ) := by linarith
    exact le_trans (H.bound T hT0 hTbig)
      (plattTrudgianFiniteBound_le_halfLogPlusHalf_of_ge_140 hT140)

/-- Local copy of the standard tangent upper bound for `log`, kept inside
the Backlund section so the large-height arithmetic is self-contained. -/
theorem backlund_log_le_tangent
    {T TвВА : вДЭ} (hT : 0 < T) (hTвВА : 0 < TвВА) :
    Real.log T вЙ§ Real.log TвВА + (T - TвВА) / TвВА := by
  have h_ratio_pos : 0 < T / TвВА := div_pos hT hTвВА
  have h := Real.log_le_sub_one_of_pos h_ratio_pos
  rw [Real.log_div (ne_of_gt hT) (ne_of_gt hTвВА)] at h
  have h_simp : (T - TвВА) / TвВА = T / TвВА - 1 := by
    field_simp
  linarith [h, h_simp]

/-- `exp 7 < 1200`, a convenient numerical endpoint for the Trudgian
large-height split. -/
theorem backlund_exp_seven_lt_1200 : Real.exp (7 : вДЭ) < 1200 := by
  have h_e_lt : Real.exp 1 < 2.72 :=
    lt_trans Real.exp_one_lt_d9 (by norm_num)
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_pow_lt : (Real.exp 1)^7 < (2.72 : вДЭ)^7 :=
    pow_lt_pow_leftвВА h_e_lt (le_of_lt h_e_pos) (by norm_num)
  have h_exp7_eq : Real.exp (7 : вДЭ) = (Real.exp 1)^7 := by
    have h := Real.exp_one_pow 7
    have h_cast : ((7 : вДХ) : вДЭ) = (7 : вДЭ) := by norm_num
    rw [вЖР h_cast]
    exact h.symm
  have h_pow_num : (2.72 : вДЭ)^7 < 1200 := by norm_num
  rw [h_exp7_eq]
  linarith

/-- For `T вЙ• 1200`, `log T вЙ• 7`. -/
theorem backlund_log_ge_seven_of_ge_1200
    {T : вДЭ} (hT : (1200 : вДЭ) вЙ§ T) :
    (7 : вДЭ) вЙ§ Real.log T := by
  have h_exp_lt : Real.exp (7 : вДЭ) < T :=
    lt_of_lt_of_le backlund_exp_seven_lt_1200 hT
  have h_exp_pos : 0 < Real.exp (7 : вДЭ) := Real.exp_pos 7
  have h := Real.log_le_log h_exp_pos (le_of_lt h_exp_lt)
  rwa [Real.log_exp] at h

/-- `log 10 вЙ§ 12/5`, used in the tangent estimate for `log log T`. -/
theorem backlund_log_ten_le_twelve_fifths :
    Real.log (10 : вДЭ) вЙ§ 12 / 5 := by
  have h_e_gt : (2.71 : вДЭ) < Real.exp 1 :=
    lt_trans (by norm_num : (2.71 : вДЭ) < 2.7182818283)
      Real.exp_one_gt_d9
  have h_pow_lt : (2.71 : вДЭ)^12 < (Real.exp 1)^12 :=
    pow_lt_pow_leftвВА h_e_gt (by norm_num) (by norm_num)
  have h_10_pow : (10 : вДЭ)^5 < (2.71 : вДЭ)^12 := by norm_num
  have h_10_pow_lt_exp12 : (10 : вДЭ)^5 < (Real.exp 1)^12 := by
    linarith
  have h_exp12_eq : Real.exp (12 : вДЭ) = (Real.exp 1)^12 := by
    have h := Real.exp_one_pow 12
    have h_cast : ((12 : вДХ) : вДЭ) = (12 : вДЭ) := by norm_num
    rw [вЖР h_cast]
    exact h.symm
  have h_exp_12_5_pow : (Real.exp (12 / 5 : вДЭ))^5 = Real.exp 12 := by
    have h := Real.exp_nat_mul (12 / 5 : вДЭ) 5
    have h_eq : ((5 : вДХ) : вДЭ) * (12 / 5 : вДЭ) = 12 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h10_nonneg : (0 : вДЭ) вЙ§ 10 := by norm_num
  have hexp_nonneg : 0 вЙ§ Real.exp (12 / 5 : вДЭ) :=
    le_of_lt (Real.exp_pos _)
  have h10_le_exp : (10 : вДЭ) вЙ§ Real.exp (12 / 5 : вДЭ) := by
    apply
      (pow_le_pow_iff_leftвВА h10_nonneg hexp_nonneg
        (by norm_num : (5 : вДХ) вЙ† 0)).mp
    rw [h_exp_12_5_pow, h_exp12_eq]
    exact le_of_lt h_10_pow_lt_exp12
  have h := Real.log_le_log (by norm_num : (0 : вДЭ) < 10) h10_le_exp
  rwa [Real.log_exp] at h

/-- For `T вЙ• 1200`, `log log T вЙ§ (3/10) log T`. -/
theorem backlund_log_log_le_three_tenths_log_of_ge_1200
    {T : вДЭ} (hT : (1200 : вДЭ) вЙ§ T) :
    Real.log (Real.log T) вЙ§ (3 / 10 : вДЭ) * Real.log T := by
  have hL7 : (7 : вДЭ) вЙ§ Real.log T :=
    backlund_log_ge_seven_of_ge_1200 hT
  have hLpos : 0 < Real.log T := by linarith
  have htangent :=
    backlund_log_le_tangent
      (T := Real.log T) (TвВА := (10 : вДЭ)) hLpos (by norm_num)
  have h1 :
      Real.log (Real.log T) вЙ§
        Real.log 10 + (Real.log T - 10) / 10 :=
    htangent
  have h2 :
      Real.log 10 + (Real.log T - 10) / 10
        вЙ§ (3 / 10 : вДЭ) * Real.log T := by
    have hlog10 := backlund_log_ten_le_twelve_fifths
    linarith
  exact le_trans h1 h2

/-- The Trudgian envelope is below the target half-log-plus-half budget
for all `T вЙ• 1200`. -/
theorem trudgianBacklundEnvelope_le_halfLogPlusHalf_of_ge_1200
    {T : вДЭ} (hT : (1200 : вДЭ) вЙ§ T) :
    trudgianBacklundEnvelope T
      вЙ§ (1 / 2 : вДЭ) * Real.log T + 1 / 2 := by
  have hL7 : (7 : вДЭ) вЙ§ Real.log T :=
    backlund_log_ge_seven_of_ge_1200 hT
  have hloglog :=
    backlund_log_log_le_three_tenths_log_of_ge_1200 hT
  have hmul :
