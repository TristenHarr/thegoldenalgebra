/-! ### AJ1–AJ5: analytic-order factorization interface -/

/-- **AJ1.** Local factorization of an analytic function at a zero of
order `m`.  Bundles the analytic unit factor, its nonvanishing, and the
eventual identity `f z = (z - s)^m * unit z`. -/
structure HasAnalyticZeroFactorization
    (f : ℂ → ℂ) (s : ℂ) (m : ℕ) where
  unit : ℂ → ℂ
  unit_analytic : AnalyticAt ℂ unit s
  unit_ne_zero : unit s ≠ 0
  factorization :
    f =ᶠ[𝓝 s] fun z : ℂ => (z - s) ^ m * unit z

/-- **AJ4.** Specialize Mathlib's `AnalyticAt.analyticOrderAt_eq_natCast`
to produce a `HasAnalyticZeroFactorization`.  The factorization theorem
gives `(z - s)^m • g`; we convert `•` to `*` via `smul_eq_mul`.
`Classical.choose` extracts the analytic unit from the existential. -/
noncomputable def hasAnalyticZeroFactorization_of_analyticOrderAt_eq_nat
    {f : ℂ → ℂ} {s : ℂ} {m : ℕ}
    (hAn : AnalyticAt ℂ f s)
    (_hm_pos : 0 < m)
    (horder : analyticOrderAt f s = (m : ℕ∞))
    (_hnotLocal : ¬ f =ᶠ[𝓝 s] 0) :
    HasAnalyticZeroFactorization f s m :=
  let hExists :
      ∃ g : ℂ → ℂ, AnalyticAt ℂ g s ∧ g s ≠ 0 ∧
        ∀ᶠ z in 𝓝 s, f z = (z - s) ^ m • g z :=
    hAn.analyticOrderAt_eq_natCast.mp horder
  let u := Classical.choose hExists
  let hspec := Classical.choose_spec hExists
  { unit := u
    unit_analytic := hspec.1
    unit_ne_zero := hspec.2.1
    factorization := by
      filter_upwards [hspec.2.2] with z hz
      simpa using hz }

/-- **AJ5.** Zeta-specialized factorization at a nontrivial zero. -/
noncomputable def zetaAnalyticZeroFactorization
    {s : ℂ} (hs : IsNontrivialZetaZero s) :
    HasAnalyticZeroFactorization
      riemannZeta s
      (zetaGlobalZeroMultiplicity.mult s) :=
  hasAnalyticZeroFactorization_of_analyticOrderAt_eq_nat
    (riemannZeta_analyticAt_of_isNontrivialZetaZero hs)
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaGlobalZeroMultiplicity_order_eq hs)
    (riemannZeta_not_eventuallyEq_zero_at_nontrivial_zero hs)

