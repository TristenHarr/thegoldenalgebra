theorem lowFirstZeroBoundaryTerm_abs_le
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T D : ÔäØ}
    (hy : 0 Ôëñ y)
    (h_reg : 2 * (1 + |x| + y) Ôëñ T)
    (hS_T : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T| Ôëñ D) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T| Ôëñ 8 * y * D / T ^ 2 := by
  unfold lowFirstZeroBoundaryTerm
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_T_sq_pos : 0 < T ^ 2 := by positivity
  have h_k_bnd : |pairedCauchyImKernel x y T| Ôëñ 8 * y / T ^ 2 :=
    abs_pairedCauchyImKernel_adaptive_8 hy h_reg
  have h_k_nn : 0 Ôëñ 8 * y / T ^ 2 := by positivity
  have h_D_nn : 0 Ôëñ D := le_trans (abs_nonneg _) hS_T
  rw [abs_mul]
  calc |pairedCauchyImKernel x y T|
        * |Phase1IBP.finiteFluctuationPrimitive Dzero T0 T|
      Ôëñ (8 * y / T ^ 2) * D :=
        mul_le_mul h_k_bnd hS_T (abs_nonneg _) h_k_nn
    _ = 8 * y * D / T ^ 2 := by ring

/-- Ô¡É **PROVED ÔÇö FTC evaluation of the majorant integral**:
`Ôê½_T^╬│ 18┬Ày┬ÀD/u┬│ du = 9┬Ày┬ÀD/T┬▓ ÔêÆ 9┬Ày┬ÀD/╬│┬▓`.

Antiderivative `F(u) := ÔêÆ9┬Ày┬ÀD/u┬▓`, with `F'(u) = 18┬Ày┬ÀD/u┬│` for `u Ôëá 0`.
Applies `intervalIntegral.integral_eq_sub_of_hasDerivAt`. -/
lemma integral_eighteen_y_D_over_u3
    {y D T ╬│ : ÔäØ} (hT_pos : 0 < T) (hT╬│ : T Ôëñ ╬│) :
    Ôê½ u in T..╬│, 18 * y * D / u ^ 3
      = 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 := by
  have h╬│_pos : 0 < ╬│ := lt_of_lt_of_le hT_pos hT╬│
  have h_deriv : ÔêÇ u Ôêê Set.uIcc T ╬│,
      HasDerivAt (fun v : ÔäØ => -9 * y * D / v ^ 2)
        (18 * y * D / u ^ 3) u := by
    intro u hu
    rw [Set.uIcc_of_le hT╬│] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    have hu_ne : u Ôëá 0 := ne_of_gt hu_pos
    have hu_sq_ne : u ^ 2 Ôëá 0 := pow_ne_zero 2 hu_ne
    have h_num : HasDerivAt (fun _ : ÔäØ => -9 * y * D) 0 u :=
      hasDerivAt_const u _
    have h_den : HasDerivAt (fun v : ÔäØ => v ^ 2)
                  ((2 : Ôäò) * u ^ (2 - 1)) u :=
      hasDerivAt_pow 2 u
    have h_div_raw : HasDerivAt
        (fun v : ÔäØ => -9 * y * D / v ^ 2)
        ((0 * u ^ 2 - (-9 * y * D) * ((2 : Ôäò) * u ^ (2 - 1))) / (u ^ 2) ^ 2) u :=
      h_num.div h_den hu_sq_ne
    convert h_div_raw using 1
    have hu_cube_ne : u ^ 3 Ôëá 0 := pow_ne_zero 3 hu_ne
    field_simp
    ring
  have h_cont : ContinuousOn (fun u : ÔäØ => 18 * y * D / u ^ 3)
                  (Set.uIcc T ╬│) := by
    rw [Set.uIcc_of_le hT╬│]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_int : IntervalIntegrable (fun u : ÔäØ => 18 * y * D / u ^ 3)
                MeasureTheory.volume T ╬│ :=
    h_cont.intervalIntegrable
  rw [intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int]
  ring

/-- ­ƒîƒ **PROVED ÔÇö derivative-side absolute bound** `Ôëñ 9 y D / T┬▓ ÔêÆ 9 y D / ╬│┬▓`
under pointwise `|S| Ôëñ D`, the adaptive regime, and integrability of
`|S ┬À k'|`. -/
theorem lowFirstZeroDerivativeSide_abs_le_majorant
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ÔäØ)
    {x y T ╬│ D : ÔäØ}
    (hy : 0 < y)
    (h_reg : 2 * (1 + |x| + y) Ôëñ T)
    (hT╬│ : T Ôëñ ╬│)
    (hD : 0 Ôëñ D)
    (hS : ÔêÇ u, T Ôëñ u ÔåÆ u Ôëñ ╬│ ÔåÆ
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| Ôëñ D)
    (hSint : IntervalIntegrable
              (fun u => |lowFirstZeroIBPIntegrand Dzero T0 x y u|)
              MeasureTheory.volume T ╬│) :
    |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
      Ôëñ 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 := by
  unfold lowFirstZeroDerivativeSide
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  have hT_pos : 0 < T := by linarith
  have h_abs_int :
      |Ôê½ u in T..╬│, lowFirstZeroIBPIntegrand Dzero T0 x y u|
        Ôëñ Ôê½ u in T..╬│, |lowFirstZeroIBPIntegrand Dzero T0 x y u| :=
    intervalIntegral.abs_integral_le_integral_abs hT╬│
  have h_pointwise : ÔêÇ u Ôêê Set.Icc T ╬│,
      |lowFirstZeroIBPIntegrand Dzero T0 x y u| Ôëñ 18 * y * D / u ^ 3 := by
    intro u hu
    obtain Ôƒ¿huT, hu╬│Ôƒ® := hu
    unfold lowFirstZeroIBPIntegrand
    rw [abs_mul]
    have hS_u : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| Ôëñ D :=
      hS u huT hu╬│
    have h_k_bnd : |pairedCauchyImKernelDeriv x y u| Ôëñ 18 * y / u ^ 3 :=
      abs_pairedCauchyImKernelDeriv_le_adaptive_18 hy.le h_reg huT
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos huT
    have h_k_nn : 0 Ôëñ 18 * y / u ^ 3 := by positivity
    calc |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          * |pairedCauchyImKernelDeriv x y u|
        Ôëñ D * (18 * y / u ^ 3) :=
          mul_le_mul hS_u h_k_bnd (abs_nonneg _) hD
      _ = 18 * y * D / u ^ 3 := by ring
  have h_maj_cont : ContinuousOn (fun u : ÔäØ => 18 * y * D / u ^ 3)
                      (Set.uIcc T ╬│) := by
    rw [Set.uIcc_of_le hT╬│]
    apply ContinuousOn.div continuousOn_const
      ((continuous_id.pow 3).continuousOn)
    intro u hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT_pos hu.1
    exact pow_ne_zero 3 (ne_of_gt hu_pos)
  have h_maj_int : IntervalIntegrable (fun u : ÔäØ => 18 * y * D / u ^ 3)
                    MeasureTheory.volume T ╬│ :=
    h_maj_cont.intervalIntegrable
  have h_int_mono :
      Ôê½ u in T..╬│, |lowFirstZeroIBPIntegrand Dzero T0 x y u|
        Ôëñ Ôê½ u in T..╬│, 18 * y * D / u ^ 3 :=
    intervalIntegral.integral_mono_on hT╬│ hSint h_maj_int h_pointwise
  have h_maj_eval :
      Ôê½ u in T..╬│, 18 * y * D / u ^ 3
        = 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2 :=
    integral_eighteen_y_D_over_u3 hT_pos hT╬│
  linarith [h_abs_int, h_int_mono, h_maj_eval]

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö closed-form combination** of boundary + derivative
absolute bounds. Direct composition with
`slabIBP_sum_le_closedFormFirstZeroErrorBound`. -/
theorem lowFirstZeroIBP_sum_le_closedForm
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 x y T ╬│ D : ÔäØ}
    (hbdy :
      |lowFirstZeroBoundaryTerm Dzero T0 x y T| Ôëñ 8 * y * D / T ^ 2)
    (hderiv :
      |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
        Ôëñ 9 * y * D / T ^ 2 - 9 * y * D / ╬│ ^ 2) :
    |lowFirstZeroBoundaryTerm Dzero T0 x y T|
      + |lowFirstZeroDerivativeSide Dzero T0 x y T ╬│|
        Ôëñ closedFormFirstZeroErrorBound y T ╬│ D :=
  slabIBP_sum_le_closedFormFirstZeroErrorBound hbdy hderiv

