/-- Ô¡É **PROVED ÔÇö `log T Ôëñ 5` for `T Ôëñ 140`** via `2.71ÔüÁ ÔëÑ 140`. -/
theorem log_T_le_5_of_le_140 {T : ÔäØ} (hT_pos : 0 < T) (hT : T Ôëñ 140) :
    Real.log T Ôëñ 5 := by
  have h_e_gt : 2.71 < Real.exp 1 := lt_trans (by norm_num) Real.exp_one_gt_d9
  have h_e_pos : 0 < Real.exp 1 := Real.exp_pos 1
  have h_e_nn : 0 Ôëñ Real.exp 1 := le_of_lt h_e_pos
