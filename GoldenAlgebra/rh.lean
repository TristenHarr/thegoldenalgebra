theorem zeroDensitySmoothTailModel_tendsto_complex
    (Tsmooth : ÔäØ) (hTsmooth_ge : 2 * Real.pi Ôëñ Tsmooth)
    {z : Ôäé} (hz : 0 < z.im) :
    Tendsto
      (fun X : ÔäØ =>
        smoothDensityTailModelPartial zeroDensityRho Tsmooth X z)
      Filter.atTop
      (­ØôØ (zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : ÔäØ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have h2pi_inv_nn : (0 : ÔäØ) Ôëñ 1 / (2 * Real.pi) := by positivity
  exact
    (smoothDensityTailModelConvergesUHP_of_majorant zeroDensityRho Tsmooth
      (smoothDensityTailMajorantDataUHP_of_logGrowth
        zeroDensityRho Tsmooth (1 / (2 * Real.pi)) 0
        h2pi_inv_nn le_rfl hTpos
        zeroDensityRho_log_growth_eventually
        (fun z X hz hTX =>
          zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
            Tsmooth X hTpos hTX hz))).tendsto z hz

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `-Im` of the honest smooth tail as an `atTop`
real-integral limit.** Composes ┬ºCCLXX-2 (the finite-partial real
integral form) with `zeroDensitySmoothTailModel_tendsto_complex` and
`(continuous_neg Ôêÿ Complex.continuous_im)`. The CLV analytic agent
can now attack the target purely in real-integral language. -/
theorem zeroDensitySmoothTailModel_neg_im_tendsto_real_integral
    (Tsmooth : ÔäØ) (hTsmooth_ge : 2 * Real.pi Ôëñ Tsmooth)
    {z : Ôäé} (hz : 0 < z.im) :
    Tendsto
      (fun X : ÔäØ =>
        Ôê½ u in Tsmooth..X,
          zeroDensityRho u *
            (z.im *
              (1 / ((z.re - u)^2 + z.im^2) +
               1 / ((z.re + u)^2 + z.im^2))))
      Filter.atTop
      (­ØôØ (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) := by
  have hTpos : 0 < Tsmooth := by
    have hpi : (0 : ÔäØ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hTsmooth_ge
  have hcomplex :=
    zeroDensitySmoothTailModel_tendsto_complex Tsmooth hTsmooth_ge hz
  have him :
      Tendsto
        (fun X : ÔäØ =>
          -(smoothDensityTailModelPartial zeroDensityRho Tsmooth X z).im)
        Filter.atTop
        (­ØôØ (-(zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z).im)) :=
    (continuous_neg.tendsto _).comp
      ((Complex.continuous_im.tendsto _).comp hcomplex)
  refine him.congr' ?_
  filter_upwards [Filter.eventually_ge_atTop Tsmooth] with X hTX
  exact smoothDensityTailModelPartial_neg_im_eq_real_integral
    zeroDensityRho Tsmooth X
    (zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
      Tsmooth X hTpos hTX hz)

-- =====================================================================
-- ┬ºCCLXXII-A. Monotonicity, positivity, and pointwise lower bounds
-- =====================================================================
-- Foundation for the CLV/arctan estimate. Names the positive smooth
-- kernel and proves the pointwise comparison
-- `¤ü(T) ┬À K(u) Ôëñ ¤ü(u) ┬À K(u)` on the tail `u ÔëÑ T ÔëÑ 2¤Ç`. This is the
-- single ingredient needed to factor `¤ü(T)` out of the integral in
-- ┬ºCCLXXII-B.
--
-- Adds:
--   positiveSmoothKernel                          ÔÇö `y┬À(1/((x-u)┬▓+y┬▓) + 1/((x+u)┬▓+y┬▓))`
--   positiveSmoothKernel_nonneg
--   zeroDensityRho_mono_on_tail
--   zeroDensityRho_le_of_tail
--   zeroDensity_kernel_lower_bound

/-- **Positive smooth kernel** ÔÇö the absolute-value form of the paired
Cauchy kernel's imaginary part. Manifestly nonneg for `y > 0`. -/
noncomputable def positiveSmoothKernel (x y u : ÔäØ) : ÔäØ :=
  y * (1 / ((x - u)^2 + y^2) + 1 / ((x + u)^2 + y^2))

/-- Ô¡É **PROVED ÔÇö `positiveSmoothKernel` is nonneg for `y > 0`.** -/
lemma positiveSmoothKernel_nonneg
    {x y u : ÔäØ} (hy : 0 < y) :
    0 Ôëñ positiveSmoothKernel x y u := by
  unfold positiveSmoothKernel
  have h1 : (0 : ÔäØ) < (x - u)^2 + y^2 := by positivity
  have h2 : (0 : ÔäØ) < (x + u)^2 + y^2 := by positivity
  have hy' : (0 : ÔäØ) Ôëñ y := le_of_lt hy
  positivity

/-- Ô¡É **PROVED ÔÇö `zeroDensityRho` is monotone on `[2¤Ç, Ôê×)`.** Follows
from `log` monotonicity on `[1, Ôê×)` after dividing by `2¤Ç`. -/
lemma zeroDensityRho_mono_on_tail :
    MonotoneOn zeroDensityRho (Set.Ici (2 * Real.pi)) := by
  intro a ha b hb hab
  unfold zeroDensityRho
  have h2pi_pos : (0 : ÔäØ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : ÔäØ) Ôëñ 1 / (2 * Real.pi) := by positivity
  have hab_div : a / (2 * Real.pi) Ôëñ b / (2 * Real.pi) := by
    exact div_le_div_of_nonneg_right hab (le_of_lt h2pi_pos)
  have ha_div_pos : 0 < a / (2 * Real.pi) :=
    div_pos (lt_of_lt_of_le h2pi_pos ha) h2pi_pos
  have h_log_le :
      Real.log (a / (2 * Real.pi)) Ôëñ Real.log (b / (2 * Real.pi)) :=
    Real.log_le_log ha_div_pos hab_div
  exact mul_le_mul_of_nonneg_left h_log_le h2pi_inv_nn

/-- Ô¡É **PROVED ÔÇö `¤ü(T) Ôëñ ¤ü(u)` on the tail.** -/
lemma zeroDensityRho_le_of_tail
    {T u : ÔäØ} (hT : 2 * Real.pi Ôëñ T) (hTu : T Ôëñ u) :
    zeroDensityRho T Ôëñ zeroDensityRho u := by
  exact zeroDensityRho_mono_on_tail hT (le_trans hT hTu) hTu

/-- ­ƒîƒ **PROVED ÔÇö pointwise weighted-kernel lower bound on the tail.**
For `u ÔëÑ T ÔëÑ 2¤Ç`, `¤ü(T) ┬À K(u) Ôëñ ¤ü(u) ┬À K(u)`. -/
lemma zeroDensity_kernel_lower_bound
    {x y T u : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T) (hTu : T Ôëñ u) (hy : 0 < y) :
    zeroDensityRho T * positiveSmoothKernel x y u
      Ôëñ zeroDensityRho u * positiveSmoothKernel x y u :=
  mul_le_mul_of_nonneg_right
    (zeroDensityRho_le_of_tail hT hTu)
    (positiveSmoothKernel_nonneg hy)

-- =====================================================================
-- ┬ºCCLXXII-B. Finite-window integral lower bound (`¤ü(T)` factored out)
-- =====================================================================
-- Uses ┬ºCCLXXII-A pointwise lower bound + `intervalIntegral.integral_mono_on`
-- to factor `¤ü(T)` out of the integral.
--
-- The hypotheses include explicit integrability of both the kernel and
-- the density-weighted kernel ÔÇö these will be discharged downstream by
-- continuity on the compact `[T, X]`.
--
-- Adds:
--   zeroDensity_realIntegral_ge_constDensity_finite

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö finite-window integral lower bound** factoring
`¤ü(T)` outside the integral.

  `¤ü(T) ┬À Ôê½_T^X K(u) du Ôëñ Ôê½_T^X ¤ü(u) ┬À K(u) du`

for `T ÔëÑ 2¤Ç` and `T Ôëñ X`, by pointwise `¤ü` monotonicity (┬ºCCLXXII-A).
Integrability of both integrands is taken as a hypothesis here (to be
discharged downstream by continuity). -/
theorem zeroDensity_realIntegral_ge_constDensity_finite
    {x y T X : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hTX : T Ôëñ X)
    (hy : 0 < y)
    (hKInt : IntervalIntegrable
              (fun u => positiveSmoothKernel x y u)
              MeasureTheory.volume T X)
    (hRInt : IntervalIntegrable
              (fun u => zeroDensityRho u * positiveSmoothKernel x y u)
              MeasureTheory.volume T X) :
    zeroDensityRho T * (Ôê½ u in T..X, positiveSmoothKernel x y u)
      Ôëñ Ôê½ u in T..X, zeroDensityRho u * positiveSmoothKernel x y u := by
  -- Rewrite the constant times the integral as an integral of the
  -- constant-scaled kernel.
  rw [ÔåÉ intervalIntegral.integral_const_mul]
  -- Now apply pointwise monotone comparison on `[T, X]`.
  apply intervalIntegral.integral_mono_on hTX
  ┬À -- integrability of the LHS integrand `¤ü(T) * K(u)`
    exact hKInt.const_mul (zeroDensityRho T)
  ┬À -- integrability of the RHS integrand `¤ü(u) * K(u)`
    exact hRInt
  ┬À -- pointwise comparison: `¤ü(T) * K(u) Ôëñ ¤ü(u) * K(u)` on `[T, X]`
    intro u hu
    have hTu : T Ôëñ u := hu.1
    exact zeroDensity_kernel_lower_bound hT hTu hy

-- =====================================================================
-- ┬ºCCLXXII-C. One-sided Cauchy kernel ÔÇö arctan primitive + tail Tendsto
-- =====================================================================
-- Foundational arctan / integral facts for ONE side of the paired
-- Cauchy kernel `y / ((u - a)┬▓ + y┬▓)`. The two-sided (paired) bound
-- in ┬ºCCLXXII-D will follow by adding the `+a` and `-a` instances.
--
-- Adds:
--   arctan_shift_deriv_algebra                              ÔÇö algebra cleanup
--   hasDerivAt_arctan_shift_div                             ÔÇö chain rule
--   integral_cauchy_one_side_eq_arctan_sub                  ÔÇö FTC formula
--   tendsto_arctan_shift_atTop                              ÔÇö atTop limit of shift
--   cauchy_one_side_tail_integral_tendsto                   ÔÇö tail Tendsto

/-- Ô¡É **PROVED ÔÇö algebra cleanup for arctan-shift derivative.** Isolates
the field manipulation `(1/y) / (1 + ((u - a)/y)┬▓) = y/((u - a)┬▓ + y┬▓)`. -/
lemma arctan_shift_deriv_algebra
    {a y u : ÔäØ} (hy : y Ôëá 0) :
    (1 / (1 + ((u - a) / y) ^ 2)) * (1 / y)
      = y / ((u - a) ^ 2 + y ^ 2) := by
  have hy2 : y ^ 2 Ôëá 0 := pow_ne_zero 2 hy
  field_simp
  ring

/-- ­ƒîƒ **PROVED ÔÇö chain rule: derivative of `arctan ((u - a) / y)` in `u`.** -/
lemma hasDerivAt_arctan_shift_div
    (a : ÔäØ) {y : ÔäØ} (hy : y Ôëá 0) (u : ÔäØ) :
    HasDerivAt
      (fun v : ÔäØ => Real.arctan ((v - a) / y))
      (y / ((u - a) ^ 2 + y ^ 2))
      u := by
  have h_inner :
      HasDerivAt (fun v : ÔäØ => (v - a) / y) (1 / y) u := by
    have h_sub : HasDerivAt (fun v : ÔäØ => v - a) (1 : ÔäØ) u :=
      (hasDerivAt_id u).sub_const a
    simpa [one_div] using h_sub.div_const y
  have h_arctan :=
    (Real.hasDerivAt_arctan ((u - a) / y)).comp u h_inner
  -- h_arctan : HasDerivAt (fun v => arctan ((v - a)/y))
  --              ((1 / (1 + ((u - a)/y)^2)) * (1 / y)) u
  have h_eq := arctan_shift_deriv_algebra (a := a) (y := y) (u := u) hy
  rw [h_eq] at h_arctan
  exact h_arctan

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö FTC for the one-sided Cauchy kernel.**
`Ôê½_T^X y / ((u - a)┬▓ + y┬▓) du = arctan((X - a)/y) ÔêÆ arctan((T - a)/y)`. -/
lemma integral_cauchy_one_side_eq_arctan_sub
    (a T X : ÔäØ) {y : ÔäØ} (hy : y Ôëá 0) :
    (Ôê½ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ┬À intro u _
    exact hasDerivAt_arctan_shift_div a hy u
  ┬À -- The integrand is continuous, hence interval-integrable
    have h_cont : Continuous (fun u : ÔäØ => y / ((u - a) ^ 2 + y ^ 2)) := by
      refine continuous_const.div ?_ ?_
      ┬À exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
      ┬À intro u
        have h1 : (0 : ÔäØ) Ôëñ (u - a) ^ 2 := sq_nonneg _
        have h2 : (0 : ÔäØ) < y ^ 2 := by positivity
        linarith
    exact h_cont.intervalIntegrable T X

/-- ­ƒîƒ **PROVED ÔÇö `arctan ((X - a)/y) ÔåÆ ¤Ç/2` as `X ÔåÆ Ôê×` for `y > 0`.**
The inner shift `(X - a)/y ÔåÆ Ôê×` (since `y > 0`); compose with
`Real.tendsto_arctan_atTop`. -/
lemma tendsto_arctan_shift_atTop
    (a : ÔäØ) {y : ÔäØ} (hy : 0 < y) :
    Tendsto
      (fun X : ÔäØ => Real.arctan ((X - a) / y))
      Filter.atTop
      (­ØôØ (Real.pi / 2)) := by
  have h_shift : Tendsto (fun X : ÔäØ => (X - a) / y)
      Filter.atTop Filter.atTop := by
    have h_sub : Tendsto (fun X : ÔäØ => X - a) Filter.atTop Filter.atTop :=
      tendsto_atTop_add_const_right Filter.atTop (-a) tendsto_id
    exact h_sub.atTop_div_const hy
  have h_arctan_at_top :
      Tendsto Real.arctan Filter.atTop (­ØôØ (Real.pi / 2)) :=
    tendsto_nhds_of_tendsto_nhdsWithin Real.tendsto_arctan_atTop
  exact h_arctan_at_top.comp h_shift

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö one-sided Cauchy tail integral converges to
`¤Ç/2 ÔêÆ arctan((T - a)/y)` as `X ÔåÆ Ôê×`.** Composes the FTC formula
with the arctan-shift limit. -/
lemma cauchy_one_side_tail_integral_tendsto
    (a T : ÔäØ) {y : ÔäØ} (hy : 0 < y) :
    Tendsto
      (fun X : ÔäØ => Ôê½ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
      Filter.atTop
      (­ØôØ (Real.pi / 2 - Real.arctan ((T - a) / y))) := by
  have hy_ne : y Ôëá 0 := ne_of_gt hy
  have h_eq : ÔêÇ X : ÔäØ,
      (Ôê½ u in T..X, y / ((u - a) ^ 2 + y ^ 2))
        = Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y) := by
    intro X
    exact integral_cauchy_one_side_eq_arctan_sub a T X hy_ne
  have h_arctan_T : Tendsto (fun _ : ÔäØ => Real.arctan ((T - a) / y))
      Filter.atTop (­ØôØ (Real.arctan ((T - a) / y))) :=
    tendsto_const_nhds
  have h_sub :
      Tendsto
        (fun X : ÔäØ =>
          Real.arctan ((X - a) / y) - Real.arctan ((T - a) / y))
        Filter.atTop
        (­ØôØ (Real.pi / 2 - Real.arctan ((T - a) / y))) :=
    (tendsto_arctan_shift_atTop a hy).sub h_arctan_T
  exact (h_sub.congr' (Filter.Eventually.of_forall fun X => (h_eq X).symm))

-- =====================================================================
-- ┬ºCCLXXII-D. Paired kernel tail integral + multiplication by ¤ü(T)
-- =====================================================================
-- Combines two `cauchy_one_side_tail_integral_tendsto` instances at
-- `a := x` and `a := -x` into the paired `positiveSmoothKernel` tail
-- Tendsto. Then multiplies by the constant `¤ü(T)`.
--
-- Adds:
--   cauchy_one_side_intervalIntegrable                       ÔÇö integrability
--   positiveSmoothKernel_eq_sum_one_sides                    ÔÇö paired pointwise split
--   positiveSmoothKernel_tail_integral_tendsto               ÔÇö paired tail Tendsto
--   constDensity_positiveSmoothKernel_tail_tendsto           ÔÇö ├ù ¤ü(T) version

/-- Ô¡É **PROVED ÔÇö interval integrability of the one-sided Cauchy kernel.**
The integrand is continuous (denominator strictly positive for
`y Ôëá 0`), hence interval-integrable on any `[T, X]`. -/
lemma cauchy_one_side_intervalIntegrable
    (a T X : ÔäØ) {y : ÔäØ} (hy : y Ôëá 0) :
    IntervalIntegrable
      (fun u => y / ((u - a) ^ 2 + y ^ 2))
      MeasureTheory.volume T X := by
  have h_cont : Continuous (fun u : ÔäØ => y / ((u - a) ^ 2 + y ^ 2)) := by
    refine continuous_const.div ?_ ?_
    ┬À exact ((continuous_id.sub continuous_const).pow 2).add continuous_const
    ┬À intro u
      have h1 : (0 : ÔäØ) Ôëñ (u - a) ^ 2 := sq_nonneg _
      have h2 : (0 : ÔäØ) < y ^ 2 := by positivity
      linarith
  exact h_cont.intervalIntegrable T X

/-- Ô¡É **PROVED ÔÇö paired positive kernel as sum of two one-sided pieces.**
Aligns with the one-sided lemma by taking `a := x` and `a := -x`. -/
lemma positiveSmoothKernel_eq_sum_one_sides
    (x y u : ÔäØ) :
    positiveSmoothKernel x y u
      = y / ((u - x) ^ 2 + y ^ 2)
        + y / ((u - (-x)) ^ 2 + y ^ 2) := by
  unfold positiveSmoothKernel
  have h1 : (x - u) ^ 2 = (u - x) ^ 2 := by ring
  have h2 : (x + u) ^ 2 = (u - (-x)) ^ 2 := by ring
  rw [h1, h2]
  ring

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö paired `positiveSmoothKernel` tail integral
Tendsto.** Sum of two one-sided arctan-shift Tendsto results
(┬ºCCLXXII-C5) with `a := x` and `a := -x`. -/
theorem positiveSmoothKernel_tail_integral_tendsto
    (x T : ÔäØ) {y : ÔäØ} (hy : 0 < y) :
    Tendsto
      (fun X : ÔäØ => Ôê½ u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (­ØôØ ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y)))) := by
  have hy_ne : y Ôëá 0 := ne_of_gt hy
  have h1 := cauchy_one_side_tail_integral_tendsto x T hy
  have h2 := cauchy_one_side_tail_integral_tendsto (-x) T hy
  have h_sum := h1.add h2
  refine h_sum.congr' ?_
  refine Filter.Eventually.of_forall (fun X => ?_)
  -- Ôê½_T^X positiveSmoothKernel = (Ôê½ ... a=x) + (Ôê½ ... a=-x)
  have hpoint : ÔêÇ u : ÔäØ,
      positiveSmoothKernel x y u
        = y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2) :=
    fun u => positiveSmoothKernel_eq_sum_one_sides x y u
  have hcongr_integrand :
      (Ôê½ u in T..X, positiveSmoothKernel x y u)
        = Ôê½ u in T..X,
            (y / ((u - x) ^ 2 + y ^ 2) + y / ((u - (-x)) ^ 2 + y ^ 2)) :=
    intervalIntegral.integral_congr (fun u _ => hpoint u)
  have h_int_x := cauchy_one_side_intervalIntegrable x T X hy_ne
  have h_int_neg_x := cauchy_one_side_intervalIntegrable (-x) T X hy_ne
  have hsplit :
      (Ôê½ u in T..X,
          (y / ((u - x) ^ 2 + y ^ 2)
            + y / ((u - (-x)) ^ 2 + y ^ 2)))
        = (Ôê½ u in T..X, y / ((u - x) ^ 2 + y ^ 2))
            + Ôê½ u in T..X, y / ((u - (-x)) ^ 2 + y ^ 2) :=
    intervalIntegral.integral_add h_int_x h_int_neg_x
  exact (hsplit.symm.trans hcongr_integrand.symm)

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö paired kernel tail integral times constant `¤ü(T)`
Tendsto.** Direct `Tendsto.mul` with the constant `¤ü(T)`. -/
theorem constDensity_positiveSmoothKernel_tail_tendsto
    (x T : ÔäØ) {y : ÔäØ} (hy : 0 < y) :
    Tendsto
      (fun X : ÔäØ =>
        zeroDensityRho T *
          Ôê½ u in T..X, positiveSmoothKernel x y u)
      Filter.atTop
      (­ØôØ (zeroDensityRho T *
        ((Real.pi / 2 - Real.arctan ((T - x) / y))
          + (Real.pi / 2 - Real.arctan ((T - (-x)) / y))))) :=
  tendsto_const_nhds.mul
    (positiveSmoothKernel_tail_integral_tendsto x T hy)

-- =====================================================================
-- ┬ºCCLXXII-E. Arctan rational lower bound `s/(1+s┬▓) Ôëñ arctan s`
-- =====================================================================
-- Mathlib doesn't have this lemma (only upper bounds and strict
-- monotonicity). Proof: let `f(t) := arctan t ÔêÆ t/(1+t┬▓)`;
-- `f(0) = 0` and `f'(t) = 2t┬▓/(1+t┬▓)┬▓ ÔëÑ 0`; so `f(s) ÔëÑ 0` for `s ÔëÑ 0`
-- by FTC + `integral_nonneg`.
--
-- Adds:
--   hasDerivAt_arctan_minus_div_one_add_sq    ÔÇö derivative of f(t)
--   div_one_add_sq_le_arctan                  ÔÇö rational lower bound on `arctan`
--   arctan_div_lower_rational                 ÔÇö `y┬ÀA/(A┬▓+y┬▓) Ôëñ arctan(y/A)` form

/-- ­ƒîƒ **PROVED ÔÇö derivative of `arctan t ÔêÆ t/(1+t┬▓)` is `2t┬▓/(1+t┬▓)┬▓`.**
Chain through `Real.hasDerivAt_arctan` + quotient rule. -/
lemma hasDerivAt_arctan_minus_div_one_add_sq (t : ÔäØ) :
    HasDerivAt
      (fun x : ÔäØ => Real.arctan x - x / (1 + x ^ 2))
      (2 * t ^ 2 / (1 + t ^ 2) ^ 2)
      t := by
  have h_arctan : HasDerivAt Real.arctan (1 / (1 + t ^ 2)) t :=
    Real.hasDerivAt_arctan t
  have h_id : HasDerivAt (fun x : ÔäØ => x) (1 : ÔäØ) t := hasDerivAt_id t
  have h_sq : HasDerivAt (fun x : ÔäØ => x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_id t).pow 2
    simpa [pow_one] using h
  have h_den : HasDerivAt (fun x : ÔäØ => 1 + x ^ 2) (2 * t) t := by
    have h := (hasDerivAt_const t (1 : ÔäØ)).add h_sq
    rwa [zero_add] at h
  have h_ne : (1 : ÔäØ) + t ^ 2 Ôëá 0 := by
    have h1 : (0 : ÔäØ) Ôëñ t ^ 2 := sq_nonneg t
    linarith
  have h_div :
      HasDerivAt (fun x : ÔäØ => x / (1 + x ^ 2))
        ((1 * (1 + t ^ 2) - t * (2 * t)) / (1 + t ^ 2) ^ 2) t :=
    h_id.div h_den h_ne
  have h_sub := h_arctan.sub h_div
  convert h_sub using 1
  field_simp
  ring

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö `s/(1+s┬▓) Ôëñ arctan s` for `s ÔëÑ 0`.** Routes through
the FTC for `f(t) := arctan t ÔêÆ t/(1+t┬▓)`, noting `f(0) = 0` and
`f' ÔëÑ 0`. -/
lemma div_one_add_sq_le_arctan {s : ÔäØ} (hs : 0 Ôëñ s) :
    s / (1 + s ^ 2) Ôëñ Real.arctan s := by
  have h_zero : Real.arctan 0 - 0 / (1 + (0 : ÔäØ) ^ 2) = 0 := by
    rw [Real.arctan_zero]; simp
  have h_cont :
      Continuous (fun t : ÔäØ => 2 * t ^ 2 / (1 + t ^ 2) ^ 2) := by
    refine (continuous_const.mul (continuous_pow 2)).div ?_ ?_
    ┬À exact ((continuous_const.add (continuous_pow 2)).pow 2)
    ┬À intro t
      have h1 : (0 : ÔäØ) Ôëñ t ^ 2 := sq_nonneg t
      have h_pos : (0 : ÔäØ) < 1 + t ^ 2 := by linarith
      have : (0 : ÔäØ) < (1 + t ^ 2) ^ 2 := by positivity
      linarith
  have hFTC :
      (Real.arctan s - s / (1 + s ^ 2))
          - (Real.arctan 0 - 0 / (1 + (0 : ÔäØ) ^ 2))
        = Ôê½ t in (0 : ÔäØ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    have h := intervalIntegral.integral_eq_sub_of_hasDerivAt
      (fun t _ => hasDerivAt_arctan_minus_div_one_add_sq t)
      (h_cont.intervalIntegrable 0 s)
    exact h.symm
  rw [h_zero, sub_zero] at hFTC
  have h_int_nn :
      0 Ôëñ Ôê½ t in (0 : ÔäØ)..s, 2 * t ^ 2 / (1 + t ^ 2) ^ 2 := by
    apply intervalIntegral.integral_nonneg hs
    intro u _
    have h_t_sq : (0 : ÔäØ) Ôëñ 2 * u ^ 2 := by nlinarith [sq_nonneg u]
    have h_den : (0 : ÔäØ) < (1 + u ^ 2) ^ 2 := by positivity
    exact div_nonneg h_t_sq (le_of_lt h_den)
  linarith

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö CLV-shaped rational lower bound on `arctan (y/A)`.**
For `A > 0`, `y ÔëÑ 0`:

  `y ┬À A / (A┬▓ + y┬▓) Ôëñ arctan (y / A)`.

Direct application of `div_one_add_sq_le_arctan` at `s := y/A` after
the algebraic identity `(y/A)/(1+(y/A)┬▓) = yA/(A┬▓+y┬▓)`. -/
lemma arctan_div_lower_rational
    {A y : ÔäØ} (hA : 0 < A) (hy : 0 Ôëñ y) :
    y * A / (A ^ 2 + y ^ 2) Ôëñ Real.arctan (y / A) := by
  have hA_ne : A Ôëá 0 := ne_of_gt hA
  have h_div_nn : 0 Ôëñ y / A := div_nonneg hy (le_of_lt hA)
  have h_base : (y / A) / (1 + (y / A) ^ 2) Ôëñ Real.arctan (y / A) :=
    div_one_add_sq_le_arctan h_div_nn
  have h_alg : (y / A) / (1 + (y / A) ^ 2) = y * A / (A ^ 2 + y ^ 2) := by
    have hA_sq_pos : 0 < A ^ 2 := by positivity
    have hAy_sq_pos : 0 < A ^ 2 + y ^ 2 := by positivity
    field_simp
    ring
  rw [h_alg] at h_base
  exact h_base

-- =====================================================================
-- ┬ºCCLXXII-F1. Arctan complement identity + one-sided tail lower bound
-- =====================================================================
-- Adds:
--   pi_div_two_sub_arctan_eq_arctan_inv
--   pi_div_two_sub_arctan_shift_eq_arctan_div
--   one_side_tail_lower_rational

/-- Ô¡É **PROVED ÔÇö `¤Ç/2 ÔêÆ arctan s = arctan (1/s)` for `s > 0`.**
Direct from Mathlib's `Real.arctan_inv_of_pos`. -/
lemma pi_div_two_sub_arctan_eq_arctan_inv
    {s : ÔäØ} (hs : 0 < s) :
    Real.pi / 2 - Real.arctan s = Real.arctan (1 / s) := by
  rw [one_div]
  exact (Real.arctan_inv_of_pos hs).symm

/-- Ô¡É **PROVED ÔÇö `¤Ç/2 ÔêÆ arctan(A/y) = arctan(y/A)` for `A, y > 0`.**
CLV-shaped specialization of the complement identity. -/
lemma pi_div_two_sub_arctan_shift_eq_arctan_div
    {A y : ÔäØ} (hA : 0 < A) (hy : 0 < y) :
    Real.pi / 2 - Real.arctan (A / y) = Real.arctan (y / A) := by
  have hs : 0 < A / y := div_pos hA hy
  rw [pi_div_two_sub_arctan_eq_arctan_inv hs]
  congr 1
  field_simp

/-- ­ƒîƒ­ƒîƒ **PROVED ÔÇö one-sided tail rational lower bound.**
For `A, y > 0`:

  `y ┬À A / (A┬▓ + y┬▓) Ôëñ ¤Ç/2 ÔêÆ arctan(A/y)`.

Combines ┬ºCCLXXII-F1's complement identity with ┬ºCCLXXII-E's
`arctan_div_lower_rational`. -/
lemma one_side_tail_lower_rational
    {A y : ÔäØ} (hA : 0 < A) (hy : 0 < y) :
    y * A / (A ^ 2 + y ^ 2) Ôëñ Real.pi / 2 - Real.arctan (A / y) := by
  rw [pi_div_two_sub_arctan_shift_eq_arctan_div hA hy]
  exact arctan_div_lower_rational hA (le_of_lt hy)

-- =====================================================================
-- ┬ºCCLXXII-F2. Paired arctan-tail rational lower bound
-- =====================================================================
-- Pairs `+|x|` and `-|x|` instances of ┬ºCCLXXII-F1. Case-split on the
-- sign of `x` aligns `T ┬▒ |x|` with `T ┬▒ x` in the arctan arguments.
--
-- Adds:
--   paired_arctan_tail_lower_rational

/-- ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö paired arctan-tail rational lower bound.**
For `y > 0`, `T - |x| > 0`, `T + |x| > 0`:

  `y ┬À (T-|x|)/((T-|x|)┬▓ + y┬▓) + y ┬À (T+|x|)/((T+|x|)┬▓ + y┬▓)
     Ôëñ (¤Ç/2 ÔêÆ arctan((T-x)/y)) + (¤Ç/2 ÔêÆ arctan((T+x)/y))`.

Each LHS term is bounded by `one_side_tail_lower_rational`; case-split
on `0 Ôëñ x` aligns the arctan arguments. -/
lemma paired_arctan_tail_lower_rational
    {x y T : ÔäØ}
    (hy : 0 < y)
    (hminus : 0 < T - |x|)
    (hplus : 0 < T + |x|) :
    y * (T - |x|) / ((T - |x|) ^ 2 + y ^ 2)
      + y * (T + |x|) / ((T + |x|) ^ 2 + y ^ 2)
    Ôëñ (Real.pi / 2 - Real.arctan ((T - x) / y))
      + (Real.pi / 2 - Real.arctan ((T + x) / y)) := by
  have h_minus := one_side_tail_lower_rational hminus hy
  have h_plus := one_side_tail_lower_rational hplus hy
  by_cases hx : 0 Ôëñ x
  ┬À have habs : |x| = x := abs_of_nonneg hx
    rw [habs] at h_minus h_plus
    rw [habs]
    linarith
  ┬À push_neg at hx
    have habs : |x| = -x := abs_of_neg hx
    have eq1 : T - (-x : ÔäØ) = T + x := by ring
    have eq2 : T + (-x : ÔäØ) = T - x := by ring
    rw [habs] at h_minus h_plus
    rw [eq1] at h_minus
    rw [eq2] at h_plus
    rw [habs, eq1, eq2]
    linarith

