/-- Ô¡É **PROVED ÔÇö Full scalar cert for `[19, 32]` via 3-piece split.** -/
lemma scalar_19_32_full100_rat_cert
    {T : ÔäØ} (hT19 : 19 Ôëñ T) (hT32 : T Ôëñ 32) :
    (17 : ÔäØ) / T^2 Ôëñ 2 * cloudK_T zeros100ceil T + tailK19_rat T := by
