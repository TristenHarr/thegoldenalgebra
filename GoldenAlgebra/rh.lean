/-- в≠Р **PROVED вАФ `cloudModel` is anti-Herglotz on the upper half-plane.**
Direct list induction over `zeros` using `paired_cauchy_kernel_im_nonpos_at`
per element. -/
theorem cloudModel_im_nonpos (zeros : List вДЭ) {z : вДВ} (hz : 0 < z.im) :
    (cloudModel zeros z).im вЙ§ 0 := by
  unfold cloudModel
  induction zeros with
  | nil => simp
  | cons g rest ih =>
    simp only [List.map_cons, List.sum_cons]
    rw [Complex.add_im]
    have h1 : ((1 : вДВ) / (z - (g : вДВ)) + (1 : вДВ) / (z + (g : вДВ))).im вЙ§ 0 :=
      paired_cauchy_kernel_im_nonpos_at z g hz
    linarith

/-- **T-dependent first-zero band cert inputs bundle.** Parallel to
`FirstZeroBandCertInputs` but with a T-dependent `model : вДЭ вЖТ вДВ вЖТ вДВ`,
matching the `CloudDensityTailModelDecompositionT` shape from CLXIII-A.

The error bound is `вДВ вЖТ вДЭ вЖТ вДЭ` (full `z`, not just `y`) so concrete
inhabitants can use `smoothTailRationalLowerBoundAbs z.re z.im T`,
which depends on `x`. -/
structure FirstZeroBandCertInputsT
    (model : вДЭ вЖТ вДВ вЖТ вДВ) (errorBound : вДВ вЖТ вДЭ вЖТ вДЭ) where
  cert_2pi_7 : вИА z : вДВ, вИА T : вДЭ,
      2 * Real.pi вЙ§ T вЖТ T вЙ§ 7 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z T вЙ§ -(model T z).im
  cert_7_8 : вИА z : вДВ, вИА T : вДЭ,
      7 вЙ§ T вЖТ T вЙ§ 8 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z T вЙ§ -(model T z).im
  cert_8_9 : вИА z : вДВ, вИА T : вДЭ,
      8 вЙ§ T вЖТ T вЙ§ 9 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z T вЙ§ -(model T z).im
  cert_9_10 : вИА z : вДВ, вИА T : вДЭ,
      9 вЙ§ T вЖТ T вЙ§ 10 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z T вЙ§ -(model T z).im

/-- в≠Р **PROVED вАФ T-dependent first-zero band dispatcher.**
Four sub-certs вЯє full first-zero-band cert at any probe `T вИИ [2ѕА, 10]`. -/
theorem firstZeroBand_modelMarginT_of_inputs
    (model : вДЭ вЖТ вДВ вЖТ вДВ) (errorBound : вДВ вЖТ вДЭ вЖТ вДЭ)
    (I : FirstZeroBandCertInputsT model errorBound)
    {z : вДВ} {T : вДЭ}
    (hTmin : 2 * Real.pi вЙ§ T) (hTmax : T вЙ§ 10)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    errorBound z T вЙ§ -(model T z).im := by
  by_cases h1 : T вЙ§ 7
  ¬Ј exact I.cert_2pi_7 z T hTmin h1 hy hreg
  push_neg at h1
  by_cases h2 : T вЙ§ 8
  ¬Ј exact I.cert_7_8 z T (le_of_lt h1) h2 hy hreg
  push_neg at h2
  by_cases h3 : T вЙ§ 9
  ¬Ј exact I.cert_8_9 z T (le_of_lt h2) h3 hy hreg
  push_neg at h3
  exact I.cert_9_10 z T (le_of_lt h3) hTmax hy hreg

/-- в≠Р **PROVED вАФ concrete `FirstZeroBandCertInputsT` for the demo
T-dependent model `cloud + demoDensityTailT`** with error bound
`fun z T => smoothTailRationalLowerBoundAbs z.re z.im T`.

All four sub-certs share the same proof: from `demoDensityTailT_neg_im`,
`smoothTail = вИТ(demoDensityTailT T z).im`; combined with
`cloudModel_im_nonpos`, the model-margin inequality follows by
