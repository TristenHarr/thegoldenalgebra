/-- ⭐ **PROVED — generic zero-list extension for `SlabSimplePolyIneq`.**
If a cert holds over a list `zs`, it holds over any extension `zs ++ extra`
since `simpleCloudSum` is monotone under list append. -/
lemma SlabSimplePolyIneq.extend_zeros
    {zs extra : List ℝ} {Tmin Tmax C D : ℝ}
    (h : SlabSimplePolyIneq zs Tmin Tmax C D) :
    SlabSimplePolyIneq (zs ++ extra) Tmin Tmax C D := by
  intro x y T hTmin hTmax hy hreg
  have hbase := h x y T hTmin hTmax hy hreg
  have hmono : simpleCloudSum zs x y ≤ simpleCloudSum (zs ++ extra) x y :=
    simpleCloudSum_append_ge_left zs extra hy
  linarith

