    cert_14_19  := slabCert_of_SlabPolyIneq M (by linarith) poly_14_19
    cert_19_32  := slabCert_of_SlabPolyIneq M (by linarith) poly_19_32
    cert_32_36  := slabCert_of_SlabPolyIneq M (by linarith) poly_32_36
