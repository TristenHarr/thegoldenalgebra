-- =====================================================================
-- ┬зCCXXXIV. Xi log-derivative decomposition packaging
-- =====================================================================
-- Splits the opaque `hdecomp` field of `XiActualTailDecompositionData`
-- into the three analytic pieces actually expected from the xi
-- log-derivative formula:
--   тАв finite real-zero cloud
--   тАв smooth density tail model
--   тАв fluctuation/error tail
-- The model `M.model` equals (cloud + smooth tail), and `error` equals
-- the fluctuation tail. The unpacked `xi_decomp` field is exactly the
-- theorem an analytic prover wants to discharge.
--
-- Adds:
--   XiLogDerivativeDecompositionPieces                  тАФ three-piece bundle
--   hdecomp_of_XiLogDerivativeDecompositionPieces       тАФ bridge to hdecomp
--   XiActualTailDecompositionData.ofPieces              тАФ clean constructor

/-- ЁЯУж **`XiLogDerivativeDecompositionPieces M error`** тАФ three-piece
unpacking of the xi log-derivative decomposition:

* `finiteCloudPart` тАФ the finite real-zero cloud sum;
* `smoothTailPart` тАФ the smooth density-tail model;
* `fluctTailPart` тАФ the residual fluctuation tail;
* `model_eq` тАФ `M.model = finiteCloudPart + smoothTailPart`;
* `error_eq` тАФ `error = fluctTailPart`;
* `xi_decomp` тАФ `╬Ы[╬Ю] z = finiteCloudPart z + smoothTailPart z + fluctTailPart z`
  on the adaptive band.

This is the natural shape produced by an actual xi log-derivative
formula. The `hdecomp` field of `XiActualTailDecompositionData` then
follows by associativity (see `hdecomp_of_XiLogDerivativeDecompositionPieces`). -/
structure XiLogDerivativeDecompositionPieces
    (M : CloudDensityTailModelDecomposition)
    (error : тДВ тЖТ тДВ) where
  finiteCloudPart : тДВ тЖТ тДВ
  smoothTailPart  : тДВ тЖТ тДВ
  fluctTailPart   : тДВ тЖТ тДВ
  model_eq :
    тИА z : тДВ, M.model z = finiteCloudPart z + smoothTailPart z
  error_eq :
    тИА z : тДВ, error z = fluctTailPart z
  xi_decomp :
    тИА z : тДВ,
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      logDerivativeResponse XiPullback z =
        finiteCloudPart z + smoothTailPart z + fluctTailPart z

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `hdecomp` from three-piece decomposition.**
Combines `model_eq`, `error_eq`, `xi_decomp` via associativity. -/
theorem hdecomp_of_XiLogDerivativeDecompositionPieces
    {M : CloudDensityTailModelDecomposition} {error : тДВ тЖТ тДВ}
    (P : XiLogDerivativeDecompositionPieces M error) :
    тИА z : тДВ,
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз 2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      logDerivativeResponse XiPullback z = M.model z + error z := by
  intro z hz
  rw [P.model_eq z, P.error_eq z]
  exact P.xi_decomp z hz

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `XiActualTailDecompositionData` from the
three-piece decomposition.** End-to-end constructor: takes the
`Model`, `error`, three-piece `P`, and the `herror` Im-identity;
produces the full `XiActualTailDecompositionData`. Discharges
`hdecomp` automatically via `hdecomp_of_XiLogDerivativeDecompositionPieces`. -/
noncomputable def XiActualTailDecompositionData.ofPieces
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : тДВ тЖТ тДВ)
    (P : XiLogDerivativeDecompositionPieces Model.M error)
    (herror :
      тИА {z : тДВ} {T : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        (error z).im =
          (trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z).im) :
    XiActualTailDecompositionData Dzero T0 hT0_pos hT0_le_10 hTuring where
  Model   := Model
  error   := error
  hdecomp := hdecomp_of_XiLogDerivativeDecompositionPieces P
  herror  := by
    intro z T h10 h140 hy hregime
    exact herror h10 h140 hy hregime

-- =====================================================================
-- ┬зCCXXXV. Smooth density tail model + anti-Herglotz closure
-- =====================================================================
-- Reduces `SmoothDensityTailModelData.tailAnti` to: a partial-integral
-- definition of the smooth tail at finite cutoffs `[T, X]`, an eventual
-- anti-Herglotz property of those partials, and pointwise convergence
-- of the partials to a candidate tail. The limit closure follows from
-- the fact that `AntiHerglotzUHP R := тИА z (hz : 0 < z.im), (R z).im тЙд 0`
-- is a pointwise sign condition closed under pointwise limits.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto     тАФ reusable closure
--   smoothDensityTailModelPartial                     тАФ finite partial def
--   SmoothDensityTailModelConverges                   тАФ convergence package
--   SmoothDensityTailFiniteAntiData                   тАФ finite anti-Herglotz
--   smoothDensityTailModelData_of_converges           тАФ assembled tailModel

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `AntiHerglotzUHP` closes under eventual pointwise
limits.** If `F X` is eventually anti-Herglotz and `F X z тЖТ f z`
pointwise, then `f` is anti-Herglotz. This is a pure order/topology
lemma: the imaginary part is continuous, so `(F X z).im тЙд 0`
eventually transfers to `(f z).im тЙд 0` via `le_of_tendsto_of_tendsto`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto
    {F : тДЭ тЖТ тДВ тЖТ тДВ} {f : тДВ тЖТ тДВ}
    (hF : тИАс╢а X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : тИА z, Tendsto (fun X => F X z) Filter.atTop (ЁЭУЭ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto : Tendsto (fun X => (F X z).im) Filter.atTop (ЁЭУЭ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z)
  have hF_im_le : тИАс╢а X in Filter.atTop, (F X z).im тЙд 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **Smooth density tail partial.** Finite `[T, X]` integral of
`╧Б(u) ┬╖ (1/(z-u) + 1/(z+u))`. -/
noncomputable def smoothDensityTailModelPartial
    (╧Б : тДЭ тЖТ тДЭ) (T X : тДЭ) : тДВ тЖТ тДВ :=
  fun z : тДВ =>
    тИл u in T..X,
      ((╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) +
         (1 : тДВ) / (z + (u : тДВ))))

/-- **Smooth density tail convergence package.** Bundles a candidate
`tailModel : тДВ тЖТ тДВ` with pointwise convergence of the finite partials
as `X тЖТ тИЮ`. -/
structure SmoothDensityTailModelConverges
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) where
  tailModel : тДВ тЖТ тДВ
  tendsto   : тИА z : тДВ,
    Tendsto
      (fun X : тДЭ => smoothDensityTailModelPartial ╧Б T X z)
      Filter.atTop (ЁЭУЭ (tailModel z))

/-- **Smooth density tail finite-window anti-Herglotz data.** Asserts
that each finite partial `smoothDensityTailModelPartial ╧Б T X` is
anti-Herglotz (for `X тЙе T`). This is the analytic obligation a Lean
proof of the integral identity must discharge тАФ for a nonnegative
density `╧Б` and a paired Cauchy kernel, this follows by linearity of
the integral and pointwise anti-Herglotz of each `(1/(z-u) + 1/(z+u))`. -/
structure SmoothDensityTailFiniteAntiData
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) : Prop where
  finiteAnti :
    тИА X, T тЙд X тЖТ AntiHerglotzUHP (smoothDensityTailModelPartial ╧Б T X)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelData` from finite-partial
data + convergence.** Composes the ┬зCCXXXV closure theorem with the
finite-anti-Herglotz hypothesis (restricted to `X тЙе T` via
`Filter.eventually_ge_atTop`). -/
noncomputable def smoothDensityTailModelData_of_converges
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (C : SmoothDensityTailModelConverges ╧Б T)
    (Hfinite : SmoothDensityTailFiniteAntiData ╧Б T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto
      (F := fun X => smoothDensityTailModelPartial ╧Б T X)
    ┬╖ filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ┬╖ exact C.tendsto

-- =====================================================================
-- ┬зCCXXXVI. Finite smooth-density partial anti-Herglotz from ╧Б тЙе 0
-- =====================================================================
-- Discharges `SmoothDensityTailFiniteAntiData` for any nonnegative
-- density `╧Б`:
--   тАв each `(1/(z-u) + 1/(z+u))` has Im тЙд 0 on UHP (existing
--     `pairedCauchyKernel_im_nonpos_at` from ┬з12-C);
--   тАв multiplied by `(╧Б u : тДВ)` with `╧Б u тЙе 0`, the integrand Im тЙд 0;
--   тАв integrating preserves the sign (Im commutes with the integral
--     via `Complex.imCLM.intervalIntegral_comp_comm`, then
--     `intervalIntegral.integral_nonneg` applied to the negation).
--
-- Adds:
--   smoothDensityTail_integrand_im_nonpos
--   smoothDensityTailModelPartial_im_nonpos
--   smoothDensityTailFiniteAntiData_of_nonneg

/-- тнР **PROVED тАФ smooth density integrand has Im тЙд 0 on UHP.**
For `╧Б u тЙе 0` and `z.im > 0`:
  `Im[(╧Б u : тДВ) ┬╖ (1/(z-u) + 1/(z+u))] = ╧Б u ┬╖ Im[тАж] тЙд 0`. -/
lemma smoothDensityTail_integrand_im_nonpos
    (╧Б : тДЭ тЖТ тДЭ) (T u : тДЭ) {z : тДВ}
    (hTu : T тЙд u)
    (h╧Б : тИА v, T тЙд v тЖТ 0 тЙд ╧Б v)
    (hz : 0 < z.im) :
    (((╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im) тЙд 0 := by
  have h╧Бu : 0 тЙд ╧Б u := h╧Б u hTu
  -- The paired kernel at z is exactly `pairedCauchyKernel u z`.
  have hk_eq : (1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))
             = pairedCauchyKernel u z := rfl
  have hk : ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))).im тЙд 0 := by
    rw [hk_eq]
    exact pairedCauchyKernel_im_nonpos_at z u hz
  -- Im of (real : тДВ) ┬╖ w = real ┬╖ w.im
  have him_eq :
      (((╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im)
        = ╧Б u * ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))).im := by
    simp [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im]
  rw [him_eq]
  exact mul_nonpos_of_nonneg_of_nonpos h╧Бu hk

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `(smoothDensityTailModelPartial ╧Б T X z).im тЙд 0`**
for `T тЙд X`, `0 < z.im`, and `╧Б тЙе 0` on `[T, тИЮ)`. Routes Im through
the integral via `Complex.imCLM.intervalIntegral_comp_comm`, then
applies `intervalIntegral.integral_nonneg` to the negation. -/
lemma smoothDensityTailModelPartial_im_nonpos
    (╧Б : тДЭ тЖТ тДЭ) (T X : тДЭ) {z : тДВ}
    (hTX : T тЙд X) (hz : 0 < z.im)
    (h╧Б_nonneg : тИА u, T тЙд u тЖТ 0 тЙд ╧Б u)
    (hInt :
      IntervalIntegrable
        (fun u =>
          (╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
        MeasureTheory.volume T X) :
    (smoothDensityTailModelPartial ╧Б T X z).im тЙд 0 := by
  unfold smoothDensityTailModelPartial
  -- Pull `.im` inside the integral via Complex.imCLM commutation
  have h_imCLM_comm := Complex.imCLM.intervalIntegral_comp_comm
    (╬╝ := MeasureTheory.volume) (a := T) (b := X) hInt
  -- Both sides written with Complex.imCLM, then simp to .im
  have him_eq :
      (тИл u in T..X,
        (╧Б u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im
        =
      тИл u in T..X,
        ((╧Б u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im := by
    simpa [Complex.imCLM_apply] using h_imCLM_comm.symm
  rw [him_eq]
  -- Apply nonnegativity to the negation
  have h_neg_nonneg :
      0 тЙд тИл u in T..X,
        -(((╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im) := by
    apply intervalIntegral.integral_nonneg hTX
    intro u hu
    have hTu : T тЙд u := hu.1
    have hpt := smoothDensityTail_integrand_im_nonpos ╧Б T u hTu h╧Б_nonneg hz
    linarith
  have h_int_neg :
      (тИл u in T..X,
        -(((╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im))
        =
      -(тИл u in T..X,
        ((╧Б u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))).im) :=
    intervalIntegral.integral_neg
  linarith

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailFiniteAntiData` from
nonnegative ╧Б + finite-window integrability.** Each finite partial
`smoothDensityTailModelPartial ╧Б T X` is anti-Herglotz on UHP. -/
theorem smoothDensityTailFiniteAntiData_of_nonneg
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (h╧Б_nonneg : тИА u, T тЙд u тЖТ 0 тЙд ╧Б u)
    (hInt :
      тИА X z, T тЙд X тЖТ 0 < z.im тЖТ
        IntervalIntegrable
          (fun u =>
            (╧Б u : тДВ) *
              ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailFiniteAntiData ╧Б T where
  finiteAnti := by
    intro X hTX z hz
    exact smoothDensityTailModelPartial_im_nonpos
      ╧Б T X hTX hz h╧Б_nonneg (hInt X z hTX hz)

-- =====================================================================
-- ┬зCCXXXVII. Smooth density tail convergence from a norm majorant
-- =====================================================================
-- Discharges `SmoothDensityTailModelConverges ╧Б T` from a real-valued
-- pointwise majorant whose improper integral converges. Routes through
-- ┬зCCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   SmoothDensityTailMajorantData                       тАФ majorant bundle
--   smoothDensityTailModel_converges_at                 тАФ pointwise existence
--   smoothDensityTailModelConverges_of_majorant         тАФ adaptive package
--   smoothDensityTailModelData_of_majorant_nonneg       тАФ full SmoothTail data

/-- ЁЯУж **`SmoothDensityTailMajorantData ╧Б T`** тАФ bundles the analytic
input needed to apply `improperComplexIntegralConverges_of_normMajorant`
to the smooth density integrand `(╧Б u : тДВ) ┬╖ (1/(z-u) + 1/(z+u))`:

* `majorant z u` тАФ real majorant function (typically `O(log u / u┬▓)`);
* `majorant_intervalIntegrable` тАФ finite-window integrability;
* `majorant_converges` тАФ improper integral converges;
* `integrand_intervalIntegrable` тАФ finite-window integrability of the
  complex integrand;
* `norm_bound_eventually` тАФ `тАЦintegrandтАЦ тЙд majorant z u` eventually. -/
structure SmoothDensityTailMajorantData
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) where
  majorant : тДВ тЖТ тДЭ тЖТ тДЭ
  majorant_intervalIntegrable :
    тИА z X, T тЙд X тЖТ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    тИА z, тИГ L : тДЭ,
      Tendsto (fun X : тДЭ => тИл u in T..X, majorant z u)
        Filter.atTop (ЁЭУЭ L)
  integrand_intervalIntegrable :
    тИА z X, T тЙд X тЖТ
      IntervalIntegrable
        (fun u =>
          (╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    тИА z, тИАс╢а u in Filter.atTop,
      тАЦ(╧Б u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))тАЦ
        тЙд majorant z u

/-- ЁЯМЯЁЯМЯ **PROVED тАФ pointwise smooth tail convergence from majorant.**
At each `z`, the smooth density partials converge as `X тЖТ тИЮ`. -/
theorem smoothDensityTailModel_converges_at
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (H : SmoothDensityTailMajorantData ╧Б T) (z : тДВ) :
    тИГ L : тДВ,
      Tendsto
        (fun X : тДЭ => smoothDensityTailModelPartial ╧Б T X z)
        Filter.atTop (ЁЭУЭ L) := by
  rcases H.majorant_converges z with тЯиLM, hLMтЯй
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hTX)
    hLM
    (H.norm_bound_eventually z)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelConverges` from majorant
data.** Uses `Classical.choose` on the pointwise existence theorem. -/
noncomputable def smoothDensityTailModelConverges_of_majorant
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (H : SmoothDensityTailMajorantData ╧Б T) :
    SmoothDensityTailModelConverges ╧Б T where
  tailModel := fun z =>
    Classical.choose (smoothDensityTailModel_converges_at ╧Б T H z)
  tendsto := fun z =>
    Classical.choose_spec (smoothDensityTailModel_converges_at ╧Б T H z)

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelData` from `╧Б тЙе 0` +
norm majorant.** End-to-end constructor: nonnegative density + complex
majorant data тЯ╣ full smooth-tail model data (including
anti-Herglotz). Composes ┬зCCXXXVI's finite-anti discharger with
┬зCCXXXVII's convergence theorem. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (h╧Б_nonneg : тИА u, T тЙд u тЖТ 0 тЙд ╧Б u)
    (H : SmoothDensityTailMajorantData ╧Б T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges ╧Б T
    (smoothDensityTailModelConverges_of_majorant ╧Б T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ╧Б T h╧Б_nonneg
      (fun X z hTX _hz => H.integrand_intervalIntegrable z X hTX))

-- =====================================================================
-- ┬зCCXXXVIII. Smooth density majorant from log-growth + paired kernel
-- =====================================================================
-- Provides a real theorem-producing bridge: a log-growth bound on `|╧Б|`
-- plus the paired-Cauchy kernel cancellation `1/(z-u) + 1/(z+u) =
-- 2z/(z┬▓ - u┬▓)` gives a `1/u┬▓` decay on the kernel norm, hence a
-- log-over-`u┬▓` majorant for the smooth density integrand. Combined
-- with ┬зCCXXIX-4a's `trueKernelLogMajorant` machinery, this discharges
-- `SmoothDensityTailMajorantData ╧Б T`.
--
-- Adds:
--   norm_pairedCauchyKernel_le_const_div_sq_eventually
--     тАФ `тАЦ1/(z-u) + 1/(z+u)тАЦ тЙд 4(тАЦzтАЦ+1)/u┬▓` for `u` eventually large
--   smoothDensityTailMajorantData_of_logGrowth
--     тАФ full constructor with explicit log envelope on `|╧Б|`

/-- ЁЯМЯЁЯМЯ **PROVED тАФ paired Cauchy kernel norm `1/u┬▓` decay.** For each
fixed `z`, eventually `тАЦ1/(z-u) + 1/(z+u)тАЦ тЙд 4(тАЦzтАЦ+1)/u┬▓`. Proof: use
the cancellation identity `1/(z-u) + 1/(z+u) = 2z/(z┬▓-u┬▓)` (existing
`pairedCauchyKernel_eq_two_mul`), bound `тАЦz┬▓ - u┬▓тАЦ тЙе u┬▓/2` for `u`
large via reverse triangle, and conclude. -/
lemma norm_pairedCauchyKernel_le_const_div_sq_eventually
    (z : тДВ) :
    тИАс╢а u : тДЭ in Filter.atTop,
      тАЦ(1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))тАЦ
        тЙд 4 * (тАЦzтАЦ + 1) / u^2 := by
  filter_upwards
    [Filter.eventually_ge_atTop (2 * (тАЦzтАЦ + 1)),
     Filter.eventually_gt_atTop (0 : тДЭ)]
    with u hu_large hu_pos
  have h_z_nn : 0 тЙд тАЦzтАЦ := norm_nonneg z
  have h_u_pos_sq : 0 < u^2 := by positivity
  have h_2_zp1_nn : (0 : тДЭ) тЙд 2 * (тАЦzтАЦ + 1) := by linarith
  have h_u_sq_ge : (2 * (тАЦzтАЦ + 1))^2 тЙд u^2 := by
    have := mul_self_le_mul_self h_2_zp1_nn hu_large
    nlinarith [this]
  have h_diff_bound : u^2 / 2 тЙд u^2 - тАЦzтАЦ^2 := by
    nlinarith [h_u_sq_ge, h_z_nn]
  have h_norm_u_sq : тАЦ((u : тДВ))^2тАЦ = u^2 := by
    have h_pow : ((u : тДВ))^2 = ((u^2 : тДЭ) : тДВ) := by push_cast; ring
    rw [h_pow, Complex.norm_real, Real.norm_eq_abs,
        abs_of_nonneg (sq_nonneg u)]
  have h_norm_z_sq : тАЦz^2тАЦ = тАЦzтАЦ^2 := by
    rw [pow_two, pow_two, norm_mul]
  have h_rev_tri : u^2 - тАЦzтАЦ^2 тЙд тАЦz^2 - (u : тДВ)^2тАЦ := by
    have h := norm_sub_norm_le ((u : тДВ)^2) (z^2)
    rw [h_norm_u_sq, h_norm_z_sq, тЖР norm_sub_rev] at h
    exact h
  have h_diff_lower : u^2 / 2 тЙд тАЦz^2 - (u : тДВ)^2тАЦ :=
    le_trans h_diff_bound h_rev_tri
  have h_u_half_pos : 0 < u^2 / 2 := by linarith
  have h_diff_norm_pos : 0 < тАЦz^2 - (u : тДВ)^2тАЦ :=
    lt_of_lt_of_le h_u_half_pos h_diff_lower
  have h_diff_ne : z^2 - (u : тДВ)^2 тЙа 0 := norm_pos_iff.mp h_diff_norm_pos
  have h_z_sq_ne : z^2 тЙа (u : тДВ)^2 := sub_ne_zero.mp h_diff_ne
  have h_kernel_eq :
      (1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))
        = 2 * z / (z^2 - (u : тДВ)^2) := by
    have := pairedCauchyKernel_eq_two_mul u z h_z_sq_ne
    unfold pairedCauchyKernel at this
    exact this
  rw [h_kernel_eq, norm_div]
  have h_num_norm : тАЦ(2 : тДВ) * zтАЦ = 2 * тАЦzтАЦ := by
    rw [norm_mul]; simp
  rw [h_num_norm]
  have h_2z_nn : 0 тЙд 2 * тАЦzтАЦ := by linarith
  calc 2 * тАЦzтАЦ / тАЦz^2 - (u : тДВ)^2тАЦ
      тЙд 2 * тАЦzтАЦ / (u^2 / 2) :=
        div_le_div_of_nonneg_left h_2z_nn h_u_half_pos h_diff_lower
    _ = 4 * тАЦzтАЦ / u^2 := by field_simp; ring
    _ тЙд 4 * (тАЦzтАЦ + 1) / u^2 := by
        gcongr
        linarith

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailMajorantData` from log growth.**
Given a log envelope `|╧Б u| тЙд A log u + B` and finite-window
integrability of the integrand, produces the full majorant bundle.
The constructed majorant is
`majorant z u := trueKernelLogMajorant ((тАЦzтАЦ+1)┬╖A/2) ((тАЦzтАЦ+1)┬╖B/2) u`
= `4(тАЦzтАЦ+1)┬╖(A log u + B)/u┬▓`. -/
noncomputable def smoothDensityTailMajorantData_of_logGrowth
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) (A B : тДЭ)
    (_hA_nn : 0 тЙд A) (_hB_nn : 0 тЙд B)
    (hTpos : 0 < T)
    (h╧Б_bound : тИАс╢а u in Filter.atTop, |╧Б u| тЙд A * Real.log u + B)
    (h╧Б_int :
      тИА z X, T тЙд X тЖТ
        IntervalIntegrable
          (fun u =>
            (╧Б u : тДВ) *
              ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantData ╧Б T where
  majorant := fun z u =>
    trueKernelLogMajorant ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z
    refine тЯи-trueKernelLogMajorantPrimitive
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T, ?_тЯй
    exact trueKernelLogMajorantConverges
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := h╧Б_int
  norm_bound_eventually := by
    intro z
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, h╧Б_bound] with u hk h╧Бu
    rw [norm_mul]
    have h_norm_ofReal : тАЦ(╧Б u : тДВ)тАЦ = |╧Б u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 тЙд A * Real.log u + B :=
      le_trans (abs_nonneg _) h╧Бu
    calc |╧Б u| * тАЦ(1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))тАЦ
        тЙд (A * Real.log u + B) * (4 * (тАЦzтАЦ + 1) / u^2) :=
          mul_le_mul h╧Бu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

-- =====================================================================
-- ┬зCCXXXIX. `zeroDensityRho` log-growth bound
-- =====================================================================
-- Concrete deliverable for the `zeroDensityRho` density:
-- `|zeroDensityRho u| тЙд (1/(2╧А)) ┬╖ log u` for `u тЙе 2╧А` (the positivity
-- threshold). This is exactly the `h╧Б_bound` field shape required by
-- ┬зCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`.
--
-- Note: the full `SmoothDensityTailMajorantData` for `zeroDensityRho`
-- additionally requires per-`(z, X)` integrability of the integrand
-- `(zeroDensityRho u : тДВ) ┬╖ (1/(z-u) + 1/(z+u))`. That field is
-- universally quantified over `z` in the structure, but the kernel
-- has poles for real `z` lying in `[T, X]`, so integrability genuinely
-- fails there. A full instantiation would require either restricting
-- the structure to UHP `z` or providing the integrability as an
-- additional explicit hypothesis (deferred).
--
-- Adds:
--   zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
--   zeroDensityRho_log_growth_eventually

/-- тнР **PROVED тАФ `|zeroDensityRho u| тЙд (1/(2╧А)) ┬╖ log u` for `u тЙе 2╧А`.**
For `u тЙе 2╧А`, `╧Б u = (1/(2╧А))┬╖(log u - log(2╧А)) тЙе 0` and `log(2╧А) тЙе 0`
(since `2╧А тЙе 1`), so `|╧Б u| = ╧Б u тЙд (1/(2╧А)) log u`. -/
lemma zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi
    {u : тДЭ} (hu : 2 * Real.pi тЙд u) :
    |zeroDensityRho u| тЙд (1 / (2 * Real.pi)) * Real.log u := by
  have h_nn : 0 тЙд zeroDensityRho u := zeroDensityRho_nonneg_of_ge_two_pi hu
  rw [abs_of_nonneg h_nn]
  unfold zeroDensityRho
  have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by positivity
  have h2pi_inv_nn : (0 : тДЭ) тЙд 1 / (2 * Real.pi) := by positivity
  have h2pi_ge_one : (1 : тДЭ) тЙд 2 * Real.pi := by
    have := Real.pi_gt_three
    linarith
  have h_log_2pi_nn : 0 тЙд Real.log (2 * Real.pi) := Real.log_nonneg h2pi_ge_one
  have h_log_eq : Real.log (u / (2 * Real.pi))
                  = Real.log u - Real.log (2 * Real.pi) := by
    have h_u_pos : 0 < u := lt_of_lt_of_le h2pi_pos hu
    rw [Real.log_div (ne_of_gt h_u_pos) (ne_of_gt h2pi_pos)]
  rw [h_log_eq]
  -- (1/(2╧А)) * (log u - log(2╧А)) тЙд (1/(2╧А)) * log u
  -- since -(1/(2╧А)) * log(2╧А) тЙд 0
  have h_diff_nn :
      (1 / (2 * Real.pi)) * Real.log u -
        (1 / (2 * Real.pi)) * (Real.log u - Real.log (2 * Real.pi))
        = (1 / (2 * Real.pi)) * Real.log (2 * Real.pi) := by ring
  nlinarith [mul_nonneg h2pi_inv_nn h_log_2pi_nn]

/-- тнР **PROVED тАФ eventual log-growth bound for `zeroDensityRho`.**
For `A := 1/(2╧А)`, `B := 0`, eventually `|╧Б u| тЙд A ┬╖ log u + B`. Direct
form for plugging into ┬зCCXXXVIII's `smoothDensityTailMajorantData_of_logGrowth`. -/
lemma zeroDensityRho_log_growth_eventually :
    тИАс╢а u : тДЭ in Filter.atTop,
      |zeroDensityRho u| тЙд (1 / (2 * Real.pi)) * Real.log u + 0 := by
  filter_upwards [Filter.eventually_ge_atTop (2 * Real.pi)] with u hu
  have := zeroDensityRho_abs_le_log_div_two_pi_of_ge_two_pi hu
  linarith

-- =====================================================================
-- ┬зCCXL. UHP-restricted smooth density majorant chain
-- =====================================================================
-- Compatibility refinement: the existing ┬зCCXXXV / ┬зCCXXXVII universal-`z`
-- structures `SmoothDensityTailModelConverges` and
-- `SmoothDensityTailMajorantData` are too strong for densities like
-- `zeroDensityRho` whose paired-kernel integrand has poles at real
-- `z тИИ [T, X]`. This section adds UHP-restricted siblings that quantify
-- the convergence / integrability fields over `0 < z.im` only тАФ which
-- is what the downstream `AntiHerglotzUHP` actually consumes.
--
-- Adds:
--   AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
--   SmoothDensityTailModelConvergesUHP
--   SmoothDensityTailMajorantDataUHP
--   smoothDensityTailModel_converges_at_UHP
--   smoothDensityTailModelConvergesUHP_of_majorant
--   smoothDensityTailModelData_of_converges_UHP
--   smoothDensityTailModelData_of_majorant_nonneg_UHP
--   smoothDensityTailMajorantDataUHP_of_logGrowth

/-- ЁЯМЯЁЯМЯ **PROVED тАФ UHP-restricted closure for `AntiHerglotzUHP`.**
If `F X` is eventually anti-Herglotz and `F X z тЖТ f z` pointwise *only
on UHP*, then `f` is anti-Herglotz. Same proof structure as
`AntiHerglotzUHP.of_eventual_pointwise_tendsto` (┬зCCXXXV), just
restricting the convergence hypothesis to `0 < z.im`. -/
theorem AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
    {F : тДЭ тЖТ тДВ тЖТ тДВ} {f : тДВ тЖТ тДВ}
    (hF : тИАс╢а X in Filter.atTop, AntiHerglotzUHP (F X))
    (hlim : тИА z, 0 < z.im тЖТ
      Tendsto (fun X => F X z) Filter.atTop (ЁЭУЭ (f z))) :
    AntiHerglotzUHP f := by
  intro z hz
  have him_tendsto :
      Tendsto (fun X => (F X z).im) Filter.atTop (ЁЭУЭ (f z).im) :=
    (Complex.continuous_im.tendsto _).comp (hlim z hz)
  have hF_im_le : тИАс╢а X in Filter.atTop, (F X z).im тЙд 0 := by
    filter_upwards [hF] with X hFX
    exact hFX z hz
  exact le_of_tendsto him_tendsto hF_im_le

/-- **UHP-restricted convergence package.** Like
`SmoothDensityTailModelConverges` but with convergence required only
for `z` with `0 < z.im`. Outside UHP, `tailModel` is free (typically 0). -/
structure SmoothDensityTailModelConvergesUHP
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) where
  tailModel : тДВ тЖТ тДВ
  tendsto   : тИА z : тДВ, 0 < z.im тЖТ
    Tendsto
      (fun X : тДЭ => smoothDensityTailModelPartial ╧Б T X z)
      Filter.atTop (ЁЭУЭ (tailModel z))

/-- ЁЯУж **`SmoothDensityTailMajorantDataUHP ╧Б T`** тАФ UHP-restricted
sibling of `SmoothDensityTailMajorantData`. All four fields are
quantified over `0 < z.im` to avoid the real-`z` pole non-integrability. -/
structure SmoothDensityTailMajorantDataUHP
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) where
  majorant : тДВ тЖТ тДЭ тЖТ тДЭ
  majorant_intervalIntegrable :
    тИА z X, 0 < z.im тЖТ T тЙд X тЖТ
      IntervalIntegrable (majorant z) MeasureTheory.volume T X
  majorant_converges :
    тИА z, 0 < z.im тЖТ тИГ L : тДЭ,
      Tendsto (fun X : тДЭ => тИл u in T..X, majorant z u)
        Filter.atTop (ЁЭУЭ L)
  integrand_intervalIntegrable :
    тИА z X, 0 < z.im тЖТ T тЙд X тЖТ
      IntervalIntegrable
        (fun u =>
          (╧Б u : тДВ) *
            ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
        MeasureTheory.volume T X
  norm_bound_eventually :
    тИА z, 0 < z.im тЖТ тИАс╢а u in Filter.atTop,
      тАЦ(╧Б u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))тАЦ
        тЙд majorant z u

/-- ЁЯМЯЁЯМЯ **PROVED тАФ UHP pointwise smooth tail convergence from
majorant.** Sibling of ┬зCCXXXVII's `smoothDensityTailModel_converges_at`
restricted to UHP `z`. -/
theorem smoothDensityTailModel_converges_at_UHP
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (H : SmoothDensityTailMajorantDataUHP ╧Б T)
    (z : тДВ) (hz : 0 < z.im) :
    тИГ L : тДВ,
      Tendsto
        (fun X : тДЭ => smoothDensityTailModelPartial ╧Б T X z)
        Filter.atTop (ЁЭУЭ L) := by
  rcases H.majorant_converges z hz with тЯиLM, hLMтЯй
  exact improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      (╧Б u : тДВ) *
        ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
    (M := H.majorant z) (T := T) (LM := LM)
    (fun X hTX => H.integrand_intervalIntegrable z X hz hTX)
    (fun X hTX => H.majorant_intervalIntegrable z X hz hTX)
    hLM
    (H.norm_bound_eventually z hz)

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelConvergesUHP` from
majorant data.** Uses `Classical.choose` on the UHP pointwise
existence theorem, with `tailModel z := 0` outside UHP. -/
noncomputable def smoothDensityTailModelConvergesUHP_of_majorant
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (H : SmoothDensityTailMajorantDataUHP ╧Б T) :
    SmoothDensityTailModelConvergesUHP ╧Б T where
  tailModel := fun z =>
    if hz : 0 < z.im then
      Classical.choose (smoothDensityTailModel_converges_at_UHP ╧Б T H z hz)
    else 0
  tendsto := by
    intro z hz
    have hExists := smoothDensityTailModel_converges_at_UHP ╧Б T H z hz
    have htail_val :
        (if hz' : 0 < z.im then
            Classical.choose
              (smoothDensityTailModel_converges_at_UHP ╧Б T H z hz')
          else 0)
          = Classical.choose hExists := by
      rw [dif_pos hz]
    rw [htail_val]
    exact Classical.choose_spec hExists

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelData` from UHP convergence
+ finite anti.** UHP-friendly sibling of ┬зCCXXXV's
`smoothDensityTailModelData_of_converges`. -/
noncomputable def smoothDensityTailModelData_of_converges_UHP
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (C : SmoothDensityTailModelConvergesUHP ╧Б T)
    (Hfinite : SmoothDensityTailFiniteAntiData ╧Б T) :
    SmoothDensityTailModelData where
  tailModel := C.tailModel
  tailAnti  := by
    apply AntiHerglotzUHP.of_eventual_pointwise_tendsto_UHP
      (F := fun X => smoothDensityTailModelPartial ╧Б T X)
    ┬╖ filter_upwards [Filter.eventually_ge_atTop T] with X hTX
      exact Hfinite.finiteAnti X hTX
    ┬╖ exact C.tendsto

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelData` from `╧Б тЙе 0` + UHP
norm majorant.** End-to-end UHP-restricted constructor. Mirrors
┬зCCXXXVII's `smoothDensityTailModelData_of_majorant_nonneg`. -/
noncomputable def smoothDensityTailModelData_of_majorant_nonneg_UHP
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ)
    (h╧Б_nonneg : тИА u, T тЙд u тЖТ 0 тЙд ╧Б u)
    (H : SmoothDensityTailMajorantDataUHP ╧Б T) :
    SmoothDensityTailModelData :=
  smoothDensityTailModelData_of_converges_UHP ╧Б T
    (smoothDensityTailModelConvergesUHP_of_majorant ╧Б T H)
    (smoothDensityTailFiniteAntiData_of_nonneg ╧Б T h╧Б_nonneg
      (fun X z hTX hz => H.integrand_intervalIntegrable z X hz hTX))

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ UHP `SmoothDensityTailMajorantDataUHP` from log
growth.** Sibling of ┬зCCXXXVIII restricted to UHP `z`. -/
noncomputable def smoothDensityTailMajorantDataUHP_of_logGrowth
    (╧Б : тДЭ тЖТ тДЭ) (T : тДЭ) (A B : тДЭ)
    (_hA_nn : 0 тЙд A) (_hB_nn : 0 тЙд B)
    (hTpos : 0 < T)
    (h╧Б_bound : тИАс╢а u in Filter.atTop, |╧Б u| тЙд A * Real.log u + B)
    (h╧Б_int :
      тИА z X, 0 < z.im тЖТ T тЙд X тЖТ
        IntervalIntegrable
          (fun u =>
            (╧Б u : тДВ) *
              ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
          MeasureTheory.volume T X) :
    SmoothDensityTailMajorantDataUHP ╧Б T where
  majorant := fun z u =>
    trueKernelLogMajorant ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) u
  majorant_intervalIntegrable := by
    intro z X _hz hTX
    exact trueKernelLogMajorant_intervalIntegrable
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T X hTpos hTX
  majorant_converges := by
    intro z _hz
    refine тЯи-trueKernelLogMajorantPrimitive
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T, ?_тЯй
    exact trueKernelLogMajorantConverges
      ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) T hTpos
  integrand_intervalIntegrable := h╧Б_int
  norm_bound_eventually := by
    intro z _hz
    have hk_bound := norm_pairedCauchyKernel_le_const_div_sq_eventually z
    filter_upwards [hk_bound, h╧Б_bound] with u hk h╧Бu
    rw [norm_mul]
    have h_norm_ofReal : тАЦ(╧Б u : тДВ)тАЦ = |╧Б u| := by simp
    rw [h_norm_ofReal]
    have h_log_env_nn : 0 тЙд A * Real.log u + B :=
      le_trans (abs_nonneg _) h╧Бu
    calc |╧Б u| * тАЦ(1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))тАЦ
        тЙд (A * Real.log u + B) * (4 * (тАЦzтАЦ + 1) / u^2) :=
          mul_le_mul h╧Бu hk (norm_nonneg _) h_log_env_nn
      _ = trueKernelLogMajorant
            ((тАЦzтАЦ + 1) * A / 2) ((тАЦzтАЦ + 1) * B / 2) u := by
          unfold trueKernelLogMajorant
          ring

