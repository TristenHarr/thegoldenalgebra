-- CLV-A: Tighter geometric lower bound ÔÇö constant 22/15 Ôëê 1.467
-- ---------------------------------------------------------------------
-- Term-by-term analysis on the adaptive A = 2 region.
-- Substitute r = |x|/T, s = y/T. Then r + s Ôëñ 1/2 and
--   smoothTailRationalLowerBoundAbs = ¤ü(T) ┬À (y/T) ┬À q(r, s),
-- where
--   q(r, s) = (1-r)/((1-r)┬▓ + s┬▓) + (1+r)/((1+r)┬▓ + s┬▓).
-- Term-by-term minimization (each decreasing in s):
--   first term ÔëÑ a/(a┬▓ + (a-1/2)┬▓) ÔëÑ 4/5  at a = 1   (a Ôêê [1/2, 1]);
--   second term ÔëÑ b/(b┬▓ + (3/2-b)┬▓) ÔëÑ 2/3 at b = 3/2 (b Ôêê [1, 3/2]).
-- Therefore q ÔëÑ 4/5 + 2/3 = 22/15.
--
-- Unscaled-variable proof (used below):
--   YÔéü := y(TÔêÆ|x|)/((TÔêÆ|x|)┬▓ + y┬▓) ÔëÑ 4y/(5T)
--     Ôƒ║ 5T(TÔêÆ|x|) ÔëÑ 4((TÔêÆ|x|)┬▓ + y┬▓)
--     Ôƒ║ (TÔêÆ|x|)(T+4|x|) ÔëÑ 4y┬▓,
--     via (TÔêÆ|x|)(T+4|x|) ÔëÑ (TÔêÆ2|x|)┬▓ ÔëÑ 4y┬▓
--     (first using |x|(7T ÔêÆ 8|x|) ÔëÑ 0, second using 2y Ôëñ T ÔêÆ 2|x|).
--   YÔéé := y(T+|x|)/((T+|x|)┬▓ + y┬▓) ÔëÑ 2y/(3T)
--     Ôƒ║ 3T(T+|x|) ÔëÑ 2((T+|x|)┬▓ + y┬▓)
--     Ôƒ║ (T+|x|)(TÔêÆ2|x|) ÔëÑ 2y┬▓,
--     via 2(T+|x|)(TÔêÆ2|x|) ÔëÑ (TÔêÆ2|x|)┬▓ ÔëÑ 4y┬▓
--     (first using (TÔêÆ2|x|)(T+4|x|) ÔëÑ 0).
--   Sum: 4y/(5T) + 2y/(3T) = 22y/(15T).

/-- Ô¡É **PROVED ÔÇö tighter rational tail lower bound, constant 22/15.**

On the canonical adaptive `A = 2` region with `T ÔëÑ 2¤Ç`:
  `smoothTailRationalLowerBoundAbs x y T ÔëÑ (22/15) ┬À ¤ü(T) ┬À y / T`.

Drops the scalar threshold from ~236 to ~135. -/
theorem smoothTailRationalLowerBoundAbs_ge_22_15
    {x y T : ÔäØ}
    (hT : 2 * Real.pi Ôëñ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) Ôëñ T) :
    (22 / 15) * zeroDensityRho T * y / T
      Ôëñ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  have h¤ü_nn : 0 Ôëñ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hT_pos
  have hT_nn : 0 Ôëñ T := le_of_lt hT_pos
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hx_nn : 0 Ôëñ |x| := abs_nonneg x
  -- Adaptive ÔçÆ |x| Ôëñ T/2 ÔêÆ 1, y Ôëñ T/2 ÔêÆ 1 ÔêÆ |x|, hence 2y Ôëñ T ÔêÆ 2|x|
  have hx_le : |x| Ôëñ T / 2 - 1 := by linarith
  have hy_le_x : y Ôëñ T / 2 - 1 - |x| := by linarith
  have h_2y_le : 2 * y Ôëñ T - 2 * |x| := by linarith
  have h_Tm2x_pos : 0 < T - 2 * |x| := by linarith
  have h_Tm2x_nn : 0 Ôëñ T - 2 * |x| := le_of_lt h_Tm2x_pos
  -- Standard positivity
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 Ôëñ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 Ôëñ T + |x| := le_of_lt h_tpx_pos
  -- 7T ÔëÑ 8|x| (from |x| Ôëñ T/2, so 8|x| Ôëñ 4T Ôëñ 7T)
  have h_7T_ge_8x : 8 * |x| Ôëñ 7 * T := by linarith
  have h_T_p_4x_nn : 0 Ôëñ T + 4 * |x| := by linarith
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- (2y)┬▓ Ôëñ (T ÔêÆ 2|x|)┬▓ from 2y Ôëñ T ÔêÆ 2|x|, both nonneg
  have h_2y_nn : 0 Ôëñ 2 * y := by linarith
  have h_4y_sq_le : 4 * y^2 Ôëñ (T - 2 * |x|)^2 := by
    have h := pow_le_pow_leftÔéÇ h_2y_nn h_2y_le 2
    have h_2y_eq : (2 * y)^2 = 4 * y^2 := by ring
    linarith [h, h_2y_eq]
  -- ----- Lemma 1: YÔéü ÔëÑ 4y/(5T) -----
  -- (TÔêÆ|x|)(T+4|x|) ÔêÆ (TÔêÆ2|x|)┬▓ = |x|┬À(7T ÔêÆ 8|x|) ÔëÑ 0
  have h_alg1 :
      (T - |x|) * (T + 4 * |x|) - (T - 2 * |x|)^2
        = |x| * (7 * T - 8 * |x|) := by ring
  have h_alg1_diff_nn :
      0 Ôëñ |x| * (7 * T - 8 * |x|) :=
    mul_nonneg hx_nn (by linarith)
  have h_step1a : (T - 2 * |x|)^2 Ôëñ (T - |x|) * (T + 4 * |x|) := by
    linarith [h_alg1, h_alg1_diff_nn]
  have h_step1b : 4 * y^2 Ôëñ (T - |x|) * (T + 4 * |x|) := by
    linarith [h_4y_sq_le, h_step1a]
  -- 5T(T ÔêÆ |x|) ÔêÆ 4((TÔêÆ|x|)┬▓ + y┬▓) = (TÔêÆ|x|)(T+4|x|) ÔêÆ 4y┬▓
  have h_alg1_full :
      5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)
        = (T - |x|) * (T + 4 * |x|) - 4 * y^2 := by ring
  have h_alg1_full_nn :
      0 Ôëñ 5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2) := by
    linarith [h_alg1_full, h_step1b]
  have h_5T_pos : 0 < 5 * T := by linarith
  have h_Y1_ge :
      4 * y / (5 * T) Ôëñ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    rw [div_le_div_iffÔéÇ h_5T_pos h_denom1_pos]
    have h_calc :
        y * (T - |x|) * (5 * T) - 4 * y * ((T - |x|)^2 + y^2)
          = y * (5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)) := by ring
    have h_nn :
        0 Ôëñ y * (5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg1_full_nn
    linarith
  -- ----- Lemma 2: YÔéé ÔëÑ 2y/(3T) -----
  -- 2(T+|x|)(TÔêÆ2|x|) ÔêÆ (TÔêÆ2|x|)┬▓ = (TÔêÆ2|x|)┬À(T + 4|x|) ÔëÑ 0
  have h_alg2 :
      2 * ((T + |x|) * (T - 2 * |x|)) - (T - 2 * |x|)^2
        = (T - 2 * |x|) * (T + 4 * |x|) := by ring
  have h_alg2_diff_nn :
      0 Ôëñ (T - 2 * |x|) * (T + 4 * |x|) :=
    mul_nonneg h_Tm2x_nn h_T_p_4x_nn
  have h_step2a :
      (T - 2 * |x|)^2 Ôëñ 2 * ((T + |x|) * (T - 2 * |x|)) := by
    linarith [h_alg2, h_alg2_diff_nn]
  have h_step2b : 2 * y^2 Ôëñ (T + |x|) * (T - 2 * |x|) := by
    linarith [h_4y_sq_le, h_step2a]
  -- 3T(T+|x|) ÔêÆ 2((T+|x|)┬▓ + y┬▓) = (T+|x|)(TÔêÆ2|x|) ÔêÆ 2y┬▓
  have h_alg2_full :
      3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2)
        = (T + |x|) * (T - 2 * |x|) - 2 * y^2 := by ring
  have h_alg2_full_nn :
      0 Ôëñ 3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2) := by
    linarith [h_alg2_full, h_step2b]
  have h_3T_pos : 0 < 3 * T := by linarith
  have h_Y2_ge :
