-- ┬з6. Engine theorems
-- =====================================================================

/-- **Anti-Herglotz forbids upper zeros.** Pole witness + anti-Herglotz
response тЗТ `f` has no upper-half-plane zeros. One line via the iff. -/
theorem antiHerglotz_forbids_upper_zeros
    {f R : тДВ тЖТ тДВ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R) :
    тИА ╧Б : тДВ, 0 < ╧Б.im тЖТ f ╧Б тЙа 0 := by
  intro ╧Б hupper hzero
  have hesc := hpole.upper_zero_forces_escape ╧Б hzero hupper
  exact (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti hesc

/-- `(star z).im = -z.im` тАФ the `Star`-side restatement of `Complex.conj_im`. -/
theorem complex_star_im (╧Б : тДВ) : (star ╧Б).im = -╧Б.im := by
  show (starRingEnd тДВ ╧Б).im = -╧Б.im
  exact Complex.conj_im ╧Б

/-- **Anti-Herglotz + Schwarz symmetry forces real zeros.** Trichotomy on
`╧Б.im`:

* Upper zero: killed directly by `antiHerglotz_forbids_upper_zeros`.
* Lower zero: killed via conjugate reflection тАФ `f (star ╧Б) = star (f ╧Б) = 0`
  with `(star ╧Б).im = тИТ╧Б.im > 0`, again contradicting
  `antiHerglotz_forbids_upper_zeros`. -/
theorem antiHerglotz_plus_symmetry_forces_real_zeros_complex
    {f R : тДВ тЖТ тДВ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R)
    (hsym : тИА z : тДВ, f (star z) = star (f z)) :
    тИА ╧Б : тДВ, f ╧Б = 0 тЖТ ╧Б.im = 0 := by
  intro ╧Б h╧Бzero
  rcases lt_trichotomy ╧Б.im 0 with hneg | hzero | hpos
  ┬╖ -- lower zero тЗТ conjugate is upper zero тЗТ contradiction
    have hconj_zero : f (star ╧Б) = 0 := by
      rw [hsym ╧Б, h╧Бzero]
      simp
    have hupper_conj : 0 < (star ╧Б).im := by
      rw [complex_star_im]
      linarith
    exact absurd hconj_zero
      (antiHerglotz_forbids_upper_zeros hpole hanti (star ╧Б) hupper_conj)
  ┬╖ exact hzero
  ┬╖ -- upper zero directly contradicts the engine
    exact absurd h╧Бzero
      (antiHerglotz_forbids_upper_zeros hpole hanti ╧Б hpos)

-- =====================================================================
-- ┬з6-bis. Totalization-at-zeros analysis (engine soundness)
-- =====================================================================
-- A reviewer-flagged concern: `logDerivativeResponse f z = f'(z) / f(z)`
-- evaluates to `0` at any zero of `f` because Lean uses the totalized
-- division convention `a / 0 = 0`. So the anti-Herglotz inequality
-- `Im (R z) тЙд 0` reads as `0 тЙд 0` at every zero, trivially true.
--
-- The lemmas below make precise *why this is harmless*: the
-- pole-witness engine never queries `R` at a zero тАФ it queries `R` at a
-- probe `╧Б тИТ ╬╡┬╖I` with `╬╡ > 0`, which is provably distinct from `╧Б`
-- (`probe_ne_pole`). At the probe, `f` is genuinely nonzero (by
-- analytic continuity on a small enough neighbourhood; this is what
-- `continuousAt_implies_probe_nonzero` packages), and the value
-- `m / (z тИТ ╧Б) + bounded` is the honest analytic content the engine
-- contradicts.
--
-- So `AntiHerglotzUHP R` is consumed by the engine *at probe points,
-- never at zeros*. The totalization is bookkeeping, not load-bearing.

/-- **PROVED тАФ totalized log-derivative is `0` at any zero.**
Pure consequence of Lean's `a / 0 = 0` convention; recorded as a named
lemma so the totalization behaviour is explicit. -/
theorem logDerivativeResponse_eq_zero_at_zero
    {f : тДВ тЖТ тДВ} {╧Б : тДВ} (hzero : f ╧Б = 0) :
    logDerivativeResponse f ╧Б = 0 := by
  unfold logDerivativeResponse
  rw [hzero, div_zero]

/-- **PROVED тАФ anti-Herglotz inequality is vacuous at any zero.**
At a zero, both sides of `(R z).im тЙд 0` are `0`. The substantive
content of `AntiHerglotzUHP R` therefore lies entirely on the
zero-free set. -/
theorem antiHerglotz_at_zero_is_vacuous
    {f : тДВ тЖТ тДВ} {╧Б : тДВ} (hzero : f ╧Б = 0) :
    (logDerivativeResponse f ╧Б).im = 0 := by
  rw [logDerivativeResponse_eq_zero_at_zero hzero]
  exact Complex.zero_im

/-- **PROVED тАФ engine probe is never a zero.** The escape constructed by
`localLogDerivPoleDecomposition_forces_escape` lives at probe
`╧Б тИТ ╬╡┬╖I` with `╬╡ > 0`, and the imaginary parts differ by exactly `╬╡`.
`f` is separately ensured nonzero at the probe by
`continuousAt_implies_probe_nonzero` (defined in ┬з9), so the totalization
at `╧Б` itself never enters the engine's contradiction. (The ┬з9 lemma
`probe_ne_pole` proves the same fact in the same form; this copy lives
here so that ┬з6-bis is self-contained and can be quoted before ┬з9.) -/
theorem engine_probe_is_not_the_zero
    (╧Б : тДВ) (╬╡ : тДЭ) (h╬╡ : 0 < ╬╡) :
    ╧Б - (╬╡ : тДВ) * Complex.I тЙа ╧Б := by
  intro h
  have him_diff : (╧Б - (╬╡ : тДВ) * Complex.I).im = ╧Б.im := by rw [h]
  have him_calc : (╧Б - (╬╡ : тДВ) * Complex.I).im = ╧Б.im - ╬╡ := by
    simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
          Complex.ofReal_re, Complex.ofReal_im]
  rw [him_calc] at him_diff
  linarith

/-- тнР **PROVED тАФ sharper anti-Herglotz form, restricted to nonzero
points.** `AntiHerglotzUHP R` with totalized `R = ╬Ы[f]` is *equivalent*
on its substantive content to the same inequality demanded only at points
where `f тЙа 0`. The forward direction is trivial; the backward direction
patches in the vacuous `0 тЙд 0` at zeros. This formalises the claim that
the totalization adds no proof obligations. -/
theorem antiHerglotz_iff_antiHerglotz_away_from_zeros
    (f : тДВ тЖТ тДВ) :
    AntiHerglotzUHP (logDerivativeResponse f)
      тЖФ тИА z : тДВ, 0 < z.im тЖТ f z тЙа 0 тЖТ
          (logDerivativeResponse f z).im тЙд 0 := by
  constructor
  ┬╖ intro h z hz _; exact h z hz
  ┬╖ intro h z hz
    by_cases hfz : f z = 0
    ┬╖ rw [antiHerglotz_at_zero_is_vacuous hfz]
    ┬╖ exact h z hz hfz

