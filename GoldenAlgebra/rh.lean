  differentiable_at_nonzero :
    вИА s : вДВ, entireRiemannXi s вЙ† 0 вЖТ DifferentiableAt вДВ prefactor s
  nonzero_at_nonzero :
    вИА s : вДВ, entireRiemannXi s вЙ† 0 вЖТ prefactor s вЙ† 0

/-- в≠Р **PROVED вАФ `C¬Јexp(a + b¬Јs)` is a valid entire-ќЊ prefactor.** -/
theorem EntireXiHadamardPrefactor.exp_affine
    {C a b : вДВ} (hC : C вЙ† 0) :
    EntireXiHadamardPrefactor
      (fun s : вДВ => C * Complex.exp (a + b * s)) := by
  refine
    { differentiable_at_nonzero := ?_
      nonzero_at_nonzero := ?_ }
  ¬Ј intro s _hs
    have h_aff : DifferentiableAt вДВ (fun s : вДВ => a + b * s) s :=
      (differentiableAt_const _).add
        ((differentiableAt_const _).mul differentiableAt_id')
    exact (differentiableAt_const _).mul h_aff.cexp
  ¬Ј intro s _hs
    exact mul_ne_zero hC (Complex.exp_ne_zero _)

