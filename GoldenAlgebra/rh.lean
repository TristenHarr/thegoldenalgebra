/-- **First-zero band cert inputs bundle.** Four sub-certs covering
`[2ѕА, 10]` via `[2ѕА, 7] вИ™ [7, 8] вИ™ [8, 9] вИ™ [9, 10]`. The model and
error bound are caller-supplied; the four `cert_*` fields are the
sub-band-specific polynomial inequalities. -/
structure FirstZeroBandCertInputs (model : вДВ вЖТ вДВ) (errorBound : вДЭ вЖТ вДЭ вЖТ вДЭ) where
  cert_2pi_7 : вИА z : вДВ, вИА T : вДЭ,
      2 * Real.pi вЙ§ T вЖТ T вЙ§ 7 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z.im T вЙ§ -(model z).im
  cert_7_8 : вИА z : вДВ, вИА T : вДЭ,
      7 вЙ§ T вЖТ T вЙ§ 8 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z.im T вЙ§ -(model z).im
  cert_8_9 : вИА z : вДВ, вИА T : вДЭ,
      8 вЙ§ T вЖТ T вЙ§ 9 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z.im T вЙ§ -(model z).im
  cert_9_10 : вИА z : вДВ, вИА T : вДЭ,
      9 вЙ§ T вЖТ T вЙ§ 10 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z.im T вЙ§ -(model z).im

/-- в≠Р **PROVED вАФ bundle вЯє `FirstZeroBandCertificate`** at `gamma1`
(any `ќ≥вВБ вЙ• 10`). Dispatches by 4-way case analysis on `T`. -/
noncomputable def firstZeroBandCert_from_inputs
    (model : вДВ вЖТ вДВ) (errorBound : вДЭ вЖТ вДЭ вЖТ вДЭ)
    (gamma1 : вДЭ) (h_10_le_gamma1 : 10 вЙ§ gamma1)
    (I : FirstZeroBandCertInputs model errorBound) :
    FirstZeroBandCertificate where
  Tmin := 2 * Real.pi
  Tmax := 10
  gamma1 := gamma1
  Tmin_ge_two_pi := le_refl _
  Tmin_le_Tmax := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  Tmax_le_gamma1 := h_10_le_gamma1
  model := model
  errorBound := errorBound
  cert := by
    intro z T hTmin hTmax hy hreg
    by_cases h1 : T вЙ§ 7
    ¬Ј exact I.cert_2pi_7 z T hTmin h1 hy hreg
    push_neg at h1
    by_cases h2 : T вЙ§ 8
    ¬Ј exact I.cert_7_8 z T (le_of_lt h1) h2 hy hreg
    push_neg at h2
    by_cases h3 : T вЙ§ 9
    ¬Ј exact I.cert_8_9 z T (le_of_lt h2) h3 hy hreg
    push_neg at h3
    exact I.cert_9_10 z T (le_of_lt h3) hTmax hy hreg

/-- в≠Р **PROVED вАФ top-level: `FirstZeroBandCertInputs` вЯє per-probe
`ModelMarginLowerBound`** in the first-zero band. -/
theorem firstZeroBand_modelMargin_of_inputs
    (model : вДВ вЖТ вДВ) (errorBound : вДЭ вЖТ вДЭ вЖТ вДЭ)
    (gamma1 : вДЭ) (h_10_le_gamma1 : 10 вЙ§ gamma1)
    (I : FirstZeroBandCertInputs model errorBound)
    {z : вДВ} {T : вДЭ}
    (hTmin : 2 * Real.pi вЙ§ T) (hTmax : T вЙ§ 10)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    errorBound z.im T вЙ§ -(model z).im :=
  (firstZeroBandCert_from_inputs model errorBound gamma1 h_10_le_gamma1 I).cert
    z T hTmin hTmax hy hreg

