      (le_trans (by positivity : (0 : ℝ) ≤ 2 * Real.pi)
        (backlund_two_pi_le_of_ge_140 hbottom_ge_140))
      hgood
  leftCount : ℕ
  rightCount : ℕ
  mainLower : ℝ
  mainUpper : ℝ
  bottomRatioLower : ℝ
  topRatioUpper : ℝ
  bottomLogLower : ℝ
  topLogUpper : ℝ
  left_count_eq :
