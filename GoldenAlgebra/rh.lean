-- =====================================================================
-- ┬зCCXCVIII. Low finite IBP тАФ equality vs domination + A/B split
-- =====================================================================
-- `Hlow : XiLowResidualFiniteIBPDomination` says `|Im(residual)| тЙд
-- |boundary| + |deriv side|`. The cleaner analytic target is the
-- equality `Im(residual) = boundary + deriv side`, from which the
-- domination follows by `abs_add`. The equality further splits into:
--   A. residual `Im` equals true-kernel finite integral `Im` on `[11, 14]`
--   B. the true-kernel finite integral `Im` equals boundary + deriv side
-- Piece A is the xi explicit-formula content for the bounded interval.
-- Piece B is finite IBP тАФ uses existing `finiteFluctuationKernelPartial_true_ibp`.
--
-- This section names both A and B, the equality тЖТ domination bridge,
-- and the final front door consuming the equality form.

/-- ЁЯУж **`XiLowResidualFiniteIBPEquality`** тАФ equality form of the low
finite IBP target. Says `Im(residual) = boundary + deriv side` on
`lowCompactRegion`. Strictly stronger than `XiLowResidualFiniteIBPDomination`
(which gives only the absolute-value inequality). -/
structure XiLowResidualFiniteIBPEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_boundary_add_deriv :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (xiResidualError M z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14

/-- тнР **PROVED тАФ equality тЯ╣ domination.** Direct via `abs_add`. -/
theorem XiLowResidualFiniteIBPDomination_of_equality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiLowResidualFiniteIBPEquality Dzero T0 M) :
    XiLowResidualFiniteIBPDomination Dzero T0 M := by
  refine тЯи?_тЯй
  intro z hz
  rw [H.residual_im_eq_boundary_add_deriv z hz]
  exact abs_add _ _

/-- ЁЯУж **`XiLowResidualFiniteIntegralEquality`** тАФ piece A of the
equality split. Says `Im(residual) = Im(finite true-kernel integral
on [11, 14])`. This is the xi explicit-formula content; piece B
converts the integral into boundary + derivative side via IBP. -/
structure XiLowResidualFiniteIntegralEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_integral :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (xiResidualError M z).im
        = (complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            11 14 z).im

/-- ЁЯУж **`LowFiniteIntegralIBPEquality`** тАФ piece B of the split.
Pure IBP identity: the finite true-kernel integral `Im` over `[11, 14]`
equals `boundary + deriv side`. Independent of `M` (the residual);
purely a Stieltjes-IBP identity for the kernel against the
fluctuation primitive. -/
structure LowFiniteIntegralIBPEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ) : Prop where
  integral_im_eq_boundary_add_deriv :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
          11 14 z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14

/-- тнР **PROVED тАФ equality from A + B.** Composes the xi-side integral
identification (A) with the IBP integral-to-boundary identity (B). -/
theorem XiLowResidualFiniteIBPEquality_of_integralEquality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
    (HA : XiLowResidualFiniteIntegralEquality Dzero T0 M)
    (HB : LowFiniteIntegralIBPEquality Dzero T0) :
    XiLowResidualFiniteIBPEquality Dzero T0 M := by
  refine тЯи?_тЯй
  intro z hz
  rw [HA.residual_im_eq_integral z hz, HB.integral_im_eq_boundary_add_deriv z hz]

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PATH B
FINAL FRONT DOOR (low equality form)**. Replaces the low domination
input with the cleaner equality form.

```
