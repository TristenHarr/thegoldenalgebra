-- =====================================================================
-- ┬зCCLXXXI. Extend `smoothZeroCountingN0` half-bound to `[2╧А, 14]`
-- =====================================================================
-- Path B requires `|NтВА(u)| тЙд 1/2` on `[2╧А, 14]` (since the inner cutoff
-- is `T = 11` and `╬│тВБ = 14`). The existing `[2╧А, 10]` infrastructure
-- (`abs_smoothZeroCountingN0_le_half_on_first_band`) covers only up to
-- 10. This section extends it.
--
-- The proof of the new endpoint `smoothZeroCountingN0_at_14_le_half`
-- adapts the `_at_10_le_half` template: replace the `log(5/╧А) тЙд log 2`
-- trick (which used `5/╧А < 2`) by the tangent-line bound
-- `log(q) тЙд log 2 + q/2 тИТ 1` (obtained from
-- `Real.log_le_sub_one_of_pos` applied to `q/2`), valid for any `q > 0`,
-- which is sharper near `q = 2`. Numerical margin to `1/2`: тЙИ 0.068.
--
-- This section does NOT build the xiтЖФfirst-zero bridge тАФ that is a
-- separate analytic step. It only provides the clean monotonicity /
-- endpoint extensions needed downstream.
--
-- Adds:
--   smoothZeroCountingN0_at_14_le_half                   тАФ NтВА(14) тЙд 1/2
--   abs_smoothZeroCountingN0_le_half_on_first_band_param тАФ generic [2╧А, U]
--   abs_smoothZeroCountingN0_le_half_on_first_band_14    тАФ [2╧А, 14] specialization
--   firstZeroGapSBound_14_half                           тАФ `FirstZeroGapSBound`
--                                                          inhabitant at (╬│тВБ=14, D=1/2)

/-- тнР **PROVED тАФ `smoothZeroCountingN0(14) тЙд 1/2`.**

Chain (with `q := 7/╧А`):
* `7/╧А тИИ (2.222, 2.23)` from `Real.pi_lt_d2` / `Real.pi_gt_d2`;
* tangent at `q = 2`: `log q тЙд log 2 + q/2 тИТ 1` via
  `Real.log_le_sub_one_of_pos` applied to `q/2`;
* `log 2 тЙд 0.6932` via `Real.log_two_lt_d9`;
* `q ┬╖ q тЙд q ┬╖ 2.23` from `q тЙд 2.23`;
* combine: `q ┬╖ log q тЙд q ┬╖ 0.6932 + q ┬╖ 1.115 тИТ q = q ┬╖ 0.8082`;
* `NтВА(14) = q ┬╖ log q тИТ q + 7/8 тЙд тИТ0.1918 ┬╖ q + 7/8`;
* `q > 2.222 тЯ╣ тИТ0.1918 ┬╖ q < тИТ0.4262`, so `NтВА(14) < 0.449 тЙд 1/2`. -/
theorem smoothZeroCountingN0_at_14_le_half :
    smoothZeroCountingN0 14 тЙд 1 / 2 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  -- 14/(2╧А) = 7/╧А
  have h_eq : (14 : тДЭ) / (2 * Real.pi) = 7 / Real.pi := by ring
  rw [h_eq]
  -- 7/╧А positivity and bounds
  have h_7pi_pos : 0 < 7 / Real.pi := by positivity
  have h_7pi_nn : 0 тЙд 7 / Real.pi := le_of_lt h_7pi_pos
  -- 7/╧А < 2.23 (from ╧А > 3.14: 2.23 ┬╖ 3.14 = 7.0022 > 7)
  have h_7pi_lt : 7 / Real.pi < 2.23 := by
    rw [div_lt_iffтВА h_pi_pos]; linarith
  -- 7/╧А > 2.222 (from ╧А < 3.15: 2.222 ┬╖ 3.15 = 6.9993 < 7)
  have h_7pi_gt : (2.222 : тДЭ) < 7 / Real.pi := by
    rw [lt_div_iffтВА h_pi_pos]; linarith
  -- (7/╧А)/2 > 0 for `log_le_sub_one_of_pos`
  have h_7pi_half_pos : 0 < 7 / Real.pi / 2 := by linarith
  -- Tangent at q=2: log(q/2) тЙд q/2 - 1
  have h_log_qhalf_le : Real.log (7 / Real.pi / 2) тЙд 7 / Real.pi / 2 - 1 :=
    Real.log_le_sub_one_of_pos h_7pi_half_pos
  -- log(q/2) = log q - log 2
  have h_log_div : Real.log (7 / Real.pi / 2)
                = Real.log (7 / Real.pi) - Real.log 2 :=
    Real.log_div (ne_of_gt h_7pi_pos) (by norm_num : (2 : тДЭ) тЙа 0)
  -- log q тЙд log 2 + q/2 - 1
  have h_log_q_bound :
      Real.log (7 / Real.pi) тЙд Real.log 2 + 7 / Real.pi / 2 - 1 := by
    linarith
  -- log 2 тЙд 0.6932
  have h_log2_lt : Real.log 2 тЙд 0.6932 := by
    have := Real.log_two_lt_d9
    linarith
  -- q ┬╖ log q тЙд q ┬╖ (log 2 + q/2 - 1) = q ┬╖ log 2 + q┬▓/2 - q
  have h_mul1 : (7 / Real.pi) * Real.log (7 / Real.pi)
              тЙд (7 / Real.pi) * (Real.log 2 + 7 / Real.pi / 2 - 1) :=
    mul_le_mul_of_nonneg_left h_log_q_bound h_7pi_nn
  -- q ┬╖ log 2 тЙд q ┬╖ 0.6932
  have h_mul2 : (7 / Real.pi) * Real.log 2 тЙд (7 / Real.pi) * 0.6932 :=
    mul_le_mul_of_nonneg_left h_log2_lt h_7pi_nn
  -- q ┬╖ q тЙд q ┬╖ 2.23
  have h_qsq : (7 / Real.pi) * (7 / Real.pi) тЙд (7 / Real.pi) * 2.23 :=
    mul_le_mul_of_nonneg_left h_7pi_lt.le h_7pi_nn
  nlinarith [h_mul1, h_mul2, h_qsq, h_7pi_lt, h_7pi_gt, h_7pi_pos]

/-- тнР **PROVED тАФ `|NтВА(u)| тЙд 1/2` for `u тИИ [2╧А, U]`** given the right
endpoint bound `NтВА(U) тЙд 1/2`. Parameterized generalization of
`abs_smoothZeroCountingN0_le_half_on_first_band` (which fixes `U = 10`).

Lower bound is automatic from `smoothZeroCountingN0_at_two_pi`
(`NтВА(2╧А) = -1/8 тЙе -1/2`) and monotonicity on `[2╧А, тИЮ)`. -/
theorem abs_smoothZeroCountingN0_le_half_on_first_band_param
    {U : тДЭ} (hU_ge_two_pi : 2 * Real.pi тЙд U)
    (hN0_U_le_half : smoothZeroCountingN0 U тЙд 1 / 2)
    {u : тДЭ}
    (hlo : 2 * Real.pi тЙд u) (hhi : u тЙд U) :
    |smoothZeroCountingN0 u| тЙд (1 / 2 : тДЭ) := by
  have h_mono := smoothZeroCountingN0_monotoneOn_Ici_two_pi
  have h_2pi_mem : (2 * Real.pi : тДЭ) тИИ Set.Ici (2 * Real.pi) := Set.left_mem_Ici
  have h_u_mem : u тИИ Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hlo
  have h_U_mem : U тИИ Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hU_ge_two_pi
  have h_low : smoothZeroCountingN0 (2 * Real.pi) тЙд smoothZeroCountingN0 u :=
    h_mono h_2pi_mem h_u_mem hlo
  have h_high : smoothZeroCountingN0 u тЙд smoothZeroCountingN0 U :=
    h_mono h_u_mem h_U_mem hhi
  rw [smoothZeroCountingN0_at_two_pi] at h_low
  have h_high' : smoothZeroCountingN0 u тЙд 1 / 2 :=
    le_trans h_high hN0_U_le_half
  rw [abs_le]
  refine тЯи?_, h_high'тЯй
  linarith

/-- ЁЯМЯ **PROVED тАФ `|NтВА(u)| тЙд 1/2` for `u тИИ [2╧А, 14]`.**
Specialization of `abs_smoothZeroCountingN0_le_half_on_first_band_param`
