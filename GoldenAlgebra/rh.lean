/-! ### AB: local residue bookkeeping for `╬╢'/╬╢` -/

/-- **AB.** Local residue contribution of the logarithmic derivative
`╬╢'/╬╢`.  At a nontrivial zero of multiplicity `m`, the residue equals `m`;
at the pole `1`, the residue equals `-1`; elsewhere, `0`. -/
structure ZetaLogDerivLocalResidueData where
  residueAt : тДВ тЖТ тДд
  residue_zero :
    тИА s : тДВ, IsNontrivialZetaZero s тЖТ
      residueAt s = zetaGlobalZeroMultiplicity.mult s
  residue_pole_one : residueAt (1 : тДВ) = -1
  residue_elsewhere_zero :
    тИА s : тДВ, ┬м IsNontrivialZetaZero s тЖТ s тЙа 1 тЖТ residueAt s = 0

namespace ZetaRectangle

/-! ### ACтАУAD: Mathlib-facing residue theorem output and conversion -/

/-- **AC.** Raw Mathlib residue-theorem output for `╬╢'/╬╢` on a
rectangle: the normalized rectangle integral equals the finite sum of
local residues over the singularities (zeros plus possibly the pole)
inside the rectangle. -/
structure ZetaRectangleResidueTheoremOutput (R : ZetaRectangle) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  singularities : Finset тДВ
  residueAt : тДВ тЖТ тДд
  normalizedIntegral_eq_sum :
    R.normalizedRectangleLogDerivIntegral =
      ((singularities.sum residueAt : тДд) : тДВ)
  singularities_complete :
    тИА s : тДВ,
      s тИИ singularities тЖФ
        (R.ContainsOpen s тИз (riemannZeta s = 0 тИи s = 1))

/-- **AD.** Convert a raw residue-theorem output into the rectangle
residue-index formula used by the Turing/Backlund pipeline.  The caller
must supply the algebraic identity matching the residue sum to
`zeros тИТ poles`. -/
noncomputable def ZetaRectangleResidueTheoremOutput.toResidueIndexFormula
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 тЙд R.bottom}
    {hgood : GoodHeight R.top}
    (O : R.ZetaRectangleResidueTheoremOutput)
    (_Hloc : ZetaLogDerivLocalResidueData)
    (hSingularitiesMatch :
      O.singularities.sum O.residueAt =
        (R.weightedZeroCountInside
            (R.zeroSetInsideOfSlab hleft hright hgood
              (R.canonicalSlabZeroSet hbottom_nonneg))
            zetaGlobalZeroMultiplicity : тДд)
          -
        (R.poleCountInside : тДд)) :
    R.ZetaRectangleResidueIndexFormula
      hleft hright hbottom_nonneg hgood where
  stronglyAdmissible := O.stronglyAdmissible
  residueIndex := O.singularities.sum O.residueAt
  normalizedIntegral_eq_index := O.normalizedIntegral_eq_sum
  residueIndex_eq_count_sub_poles := hSingularitiesMatch

/-! ### AE: canonical singularities + positive-bottom simplification -/

open Classical in
/-- The canonical singularity set inside a rectangle: zeros inside plus
the pole if it lies inside. -/
noncomputable def canonicalSingularities
    (R : ZetaRectangle) (Z : R.ZeroSetInside) : Finset тДВ :=
  if R.PoleInside then insert (1 : тДВ) Z.zeros else Z.zeros

/-- For a positive-bottom rectangle, the canonical singularities are
just the zeros inside (no pole). -/
theorem canonicalSingularities_eq_zeros_of_positive_bottom
    {R : ZetaRectangle}
    (Z : R.ZeroSetInside)
    (hbottom_pos : 0 < R.bottom) :
    R.canonicalSingularities Z = Z.zeros := by
  unfold canonicalSingularities
  simp [not_poleInside_of_positive_bottom hbottom_pos]

/-- If local residues at zeros agree with analytic multiplicity, the
residue sum over the zero support equals the weighted zero count. -/
theorem residue_sum_eq_weightedZeroCountInside
    {R : ZetaRectangle}
    (Z : R.ZeroSetInside)
    (residueAt : тДВ тЖТ тДд)
    (hres :
      тИА s : тДВ, s тИИ Z.zeros тЖТ
        residueAt s = (zetaGlobalZeroMultiplicity.mult s : тДд)) :
    Z.zeros.sum residueAt =
      (R.weightedZeroCountInside Z zetaGlobalZeroMultiplicity : тДд) := by
  unfold weightedZeroCountInside
  push_cast
  exact Finset.sum_congr rfl hres

end ZetaRectangle

