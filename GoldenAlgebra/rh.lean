theorem XiLowResidualMargin_of_explicitAtAwayFromZeros_and_marginAt
    {T gamma1 D : вДЭ}
    (Hexplicit : XiLowResidualExplicitDataAtAwayFromZeros T gamma1 D
                    honestZeroDensityModelTwoPi)
