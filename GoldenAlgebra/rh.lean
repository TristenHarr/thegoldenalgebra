        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (Hstieltjes :
      ZeroContributionStieltjesFormula
        Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardSourceAndZeroSplit
    Dzero h_Z_ge_15 hTuring hHighLog Hsrc
    (XiZeroContributionSplit_of_stieltjesFormula Hstieltjes)

-- =====================================================================
-- ┬зCCCVIII. Stieltjes tail/low data тАФ independent Prop pieces
-- =====================================================================
-- Splits `ZeroContributionStieltjesFormula` into two independently
-- provable Props (tail-only and low-only) so the high/mid Stieltjes
-- theorem and the low Stieltjes theorem can be developed separately.

/-- ЁЯУж **`StieltjesTailContributionData`** тАФ tail-only Stieltjes
identification of the zero contribution. Mirrors
`ZeroContributionTailStieltjesFormula.formula` as a standalone Prop. -/
structure StieltjesTailContributionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  tail_value :
    тИА {z : тДВ} {T : тДЭ},
      0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 T z L тИз
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L

/-- ЁЯУж **`StieltjesLowContributionData`** тАФ low-only Stieltjes
identification of the zero contribution. Mirrors
`ZeroContributionLowFiniteStieltjesFormula.formula` as a standalone Prop. -/
structure StieltjesLowContributionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  low_value :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (ZC z -
          (cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `ZeroContributionStieltjesFormula` from tail + low
data.** -/
theorem ZeroContributionStieltjesFormula_of_tail_low_data
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (Htail : StieltjesTailContributionData Dzero T0 ZC)
    (Hlow : StieltjesLowContributionData Dzero T0 ZC) :
    ZeroContributionStieltjesFormula Dzero T0 ZC :=
  { tail_formula := тЯиHtail.tail_valueтЯй
    low_formula := тЯиHlow.low_valueтЯй }

-- =====================================================================
-- ┬зCCCIX. Stieltjes data object (Type-level bundle) + final front door
-- =====================================================================
-- The `Type`-level bundle pairs the zero-contribution function `ZC`
-- with the tail + low identifications. Convenient when the future
-- analytic proof produces `ZC` and its identifications in one go.

/-- ЁЯУж **`StieltjesZeroContributionData`** тАФ `Type`-level Stieltjes
data: a zero contribution `ZC : тДВ тЖТ тДВ` together with the tail and
low Stieltjes identifications. -/
structure StieltjesZeroContributionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ) : Type where
  ZC : тДВ тЖТ тДВ
  tail_value :
    тИА {z : тДВ} {T : тДЭ},
