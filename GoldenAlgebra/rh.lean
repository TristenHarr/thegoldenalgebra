/-- ­ƒîƒ **PROVED ÔÇö regression: the zero-branch margin guard.** Names the
exact algebra step every guarded local-package constructor relies on in
its `XiPullback z = 0` branch. -/
theorem lowResidualMargin_zero_branch_guard_test
    {M : CloudDensityTailModelDecomposition}
    {z : Ôäé}
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hdecomp :
      ÔêÇ z : Ôäé,
        logDerivativeResponse XiPullback z =
          M.model z + xiResidualError M z)
    (hz : 0 < z.im)
    (hzero : XiPullback z = 0) :
    |(xiResidualError M z).im| Ôëñ -(M.model z).im :=
  errorMargin_at_XiPullback_zero_of_decomp
    hmodelAnti hdecomp hz hzero

/-! ### Taint convention

`logDerivativeResponse XiPullback z` is the `a / 0 = 0` totalization of
`deriv (XiPullback) z / XiPullback z`. At any `z` with
`XiPullback z = 0`, the value collapses to `0` ÔÇö *not* the analytic
limit. `xiResidualError M z := logDerivativeResponse XiPullback z ÔêÆ
M.model z` inherits this taint: at a zero, the residual is
*definitionally* `ÔêÆM.model z`, regardless of any analytic interpretation.

Rule of thumb. Any public analytic input that mentions either
`logDerivativeResponse XiPullback z` or `xiResidualError M z` for `z`
ranging over a region of UHP must carry an explicit
`XiPullback z Ôëá 0 ÔåÆ` guard. The only places allowed to drop the guard
are trusted wrapper constructors that internally do
```
by_cases hzero : XiPullback z = 0
┬À exact errorMargin_at_XiPullback_zero_of_decomp ...
┬À exact analytic_input ... hzero
```
The ┬ºCCL-bis / ┬ºCCLXXXII / ┬ºCCLXXXVII chain implements this convention.
Discharge of an unguarded analytic input cannot proceed at a zero
without circularity. -/

-- =====================================================================
-- ┬ºCCLXXXVII. Discharge `Hgap` via structural `DzeroStartsAfter` + NÔéÇ-root
-- =====================================================================
-- The ┬ºCCLXXXV `FirstZeroGapForDzero` Prop says
-- `finiteFluctuationPrimitive Dzero T0 u = -smoothZeroCountingN0 u`
-- on `[2¤Ç, ╬│]`. Under `DzeroStartsAfter ╬│` (no fluctuation atoms in
-- `[T0, ╬│]`) the discrete part vanishes and the structural identity
-- reduces to
--   `finiteFluctuationPrimitive Dzero T0 u
--      = smoothZeroCountingN0 T0 ÔêÆ smoothZeroCountingN0 u`.
-- So the ┬ºCCLXXXV shape `= -NÔéÇ(u)` holds **iff** `smoothZeroCountingN0 T0 = 0`,
-- i.e., iff `T0` is the unique root `uÔéÇ Ôëê 9.74` of `NÔéÇ` in `(2¤Ç, Ôê×)`.
-- This section honestly carries that constraint as the `hN0_T0`
-- hypothesis. A future refactor could replace `FirstZeroGapForDzero`
-- with a basepoint-adjusted shape `S(T0, u) = NÔéÇ(T0) ÔêÆ NÔéÇ(u)` that
-- accepts arbitrary `T0 Ôëñ 2¤Ç`.
--
-- Adds:
--   DzeroStartsAfter                                      ÔÇö no atoms below ╬│
--   discreteCountingPrimitive_eq_zero_of_startsAfter      ÔÇö discrete vanishes
--   smoothCountingPrimitive_eq_N0_diff                    ÔÇö FTC bridge
--   finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter  ÔÇö structural identity
--   FirstZeroGapForDzero_of_startsAfter_at_root           ÔÇö inhabit Hgap
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowFiniteIBP_11_14_half_startsAfter
--                                                          ÔÇö Hgap-free front door

/-- ­ƒôª **`DzeroStartsAfter Dzero ╬│`** ÔÇö strict structural condition:
every zero ordinate in `Dzero.Z` is strictly greater than `╬│`. For
`zeros100ceil` with first entry `15`, `DzeroStartsAfter Dzero 14`
holds (`14 < 15`). The strict inequality avoids edge cases at `u = ╬│`. -/
structure DzeroStartsAfter
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (╬│ : ÔäØ) : Prop where
  z_gt_gamma : ÔêÇ i : Ôäò, ╬│ < Dzero.toFluctuationMeasureData.Z i

/-- Ô¡É **PROVED ÔÇö discrete counting primitive vanishes on `[T0, u]`** when
all atoms lie strictly above `╬│ ÔëÑ u`. Each `if T0 Ôëñ Z_j Ôêº Z_j Ôëñ u`
term is false because `u < Z_j`. -/
lemma discreteCountingPrimitive_eq_zero_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ u : ÔäØ}
    (H : DzeroStartsAfter Dzero ╬│) (hu : u Ôëñ ╬│) :
    Phase1IBP.discreteCountingPrimitive
        Dzero.toFluctuationMeasureData T0 u = 0 := by
  classical
  unfold Phase1IBP.discreteCountingPrimitive
  apply Finset.sum_eq_zero
  intro j _
  have hZj : ╬│ < Dzero.toFluctuationMeasureData.Z j := H.z_gt_gamma j
  have hu_Zj : u < Dzero.toFluctuationMeasureData.Z j :=
    lt_of_le_of_lt hu hZj
  have hnot :
      ┬¼ (T0 Ôëñ Dzero.toFluctuationMeasureData.Z j Ôêº
         Dzero.toFluctuationMeasureData.Z j Ôëñ u) := by
    intro Ôƒ¿_, hÔƒ®
    exact (not_lt.mpr h) hu_Zj
  simp [hnot]

/-- Ô¡É **PROVED ÔÇö `smoothCountingPrimitive T0 u = NÔéÇ(u) ÔêÆ NÔéÇ(T0)`** for
positive `T0 Ôëñ u`, via FTC and `hasDerivAt_smoothZeroCountingN0`. -/
lemma smoothCountingPrimitive_eq_N0_diff
    {T0 u : ÔäØ} (hT0 : 0 < T0) (hT0u : T0 Ôëñ u) :
    Phase1IBP.smoothCountingPrimitive T0 u
      = smoothZeroCountingN0 u - smoothZeroCountingN0 T0 := by
  unfold Phase1IBP.smoothCountingPrimitive
  have h_deriv : ÔêÇ v Ôêê Set.uIcc T0 u,
      HasDerivAt smoothZeroCountingN0 (zeroDensityRho v) v := by
    intro v hv
    rw [Set.uIcc_of_le hT0u] at hv
    exact hasDerivAt_smoothZeroCountingN0
      (lt_of_lt_of_le hT0 hv.1)
  have h_int : IntervalIntegrable zeroDensityRho MeasureTheory.volume T0 u :=
    Phase1IBP.zeroDensityRho_intervalIntegrable hT0 hT0u
  exact intervalIntegral.integral_eq_sub_of_hasDerivAt h_deriv h_int

/-- Ô¡É **PROVED ÔÇö structural identity for `finiteFluctuationPrimitive`**
on the first-zero gap under `DzeroStartsAfter`:
`S(T0, u) = NÔéÇ(T0) ÔêÆ NÔéÇ(u)`. -/
theorem finiteFluctuationPrimitive_eq_N0_diff_of_startsAfter
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 ╬│ u : ÔäØ}
    (H : DzeroStartsAfter Dzero ╬│)
    (hT0_pos : 0 < T0) (hT0u : T0 Ôëñ u) (hu : u Ôëñ ╬│) :
    Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
      = smoothZeroCountingN0 T0 - smoothZeroCountingN0 u := by
  unfold Phase1IBP.finiteFluctuationPrimitive
  rw [discreteCountingPrimitive_eq_zero_of_startsAfter H hu,
