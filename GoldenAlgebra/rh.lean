/-- Bridge: the classical combination input supplies the bare `combine`
field expected by `BacklundSeparatedAnalyticInputs`. -/
noncomputable def BacklundClassicalCombinationInput.toCombineField
    (C : BacklundClassicalCombinationInput) :
    вИА T : вДЭ, RvMGoodHeight T вЖТ (140 : вДЭ) вЙ§ T вЖТ
