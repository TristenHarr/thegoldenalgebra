theorem slabSimple_19_32_cert :
    SlabSimplePolyIneq zeros100ceil 19 32 0 (1 : тДЭ) := by
  apply slabSimplePolyIneq_of_nonneg_x
  intro x y T hx hT19 hT32 hy hreg
  exact slabSimple_19_32_core hx hT19 hT32 hy hreg

