theorem exists_smallSquareInsideRectangle
    {R : ZetaRectangle} {a : тДВ}
    (ha : R.ContainsOpen a) :
    Nonempty (R.SmallSquareInsideRectangle a) := by
  obtain тЯиhL, hRt, hB, hTтЯй := ha
  set r : тДЭ :=
    min (min ((a.re - R.left) / 2) ((R.right - a.re) / 2))
      (min ((a.im - R.bottom) / 2) ((R.top - a.im) / 2)) with hr_def
  have hr_pos : 0 < r := by
    refine lt_min (lt_min ?_ ?_) (lt_min ?_ ?_) <;> linarith
  refine тЯитЯиr, hr_pos, ?_тЯйтЯй
  intro z hz
  obtain тЯиhre_abs, him_absтЯй := hz
  obtain тЯиhre_low, hre_highтЯй := abs_le.mp hre_abs
  obtain тЯиhim_low, him_highтЯй := abs_le.mp him_abs
  have hr_le_left : r тЙд (a.re - R.left) / 2 :=
    (min_le_left _ _).trans (min_le_left _ _)
  have hr_le_right : r тЙд (R.right - a.re) / 2 :=
    (min_le_left _ _).trans (min_le_right _ _)
  have hr_le_bottom : r тЙд (a.im - R.bottom) / 2 :=
    (min_le_right _ _).trans (min_le_left _ _)
  have hr_le_top : r тЙд (R.top - a.im) / 2 :=
    (min_le_right _ _).trans (min_le_right _ _)
  refine тЯи?_, ?_, ?_, ?_тЯй <;> linarith

/-! ### AX3: the small square as its own `ZetaRectangle` and its unit-kernel
integral -/

/-- The small square viewed as a `ZetaRectangle`. -/
def SmallSquareInsideRectangle.toRectangle
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := a.re - S.r
  right := a.re + S.r
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by linarith [S.r_pos]
  hbottom_lt_top := by linarith [S.r_pos]

/-- Unit-kernel rectangle integral over the inner square. -/
noncomputable def smallSquareUnitKernelIntegral
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : тДВ :=
  S.toRectangle.unitPrincipalKernelRectangleIntegral a

/-! ### AX4: outer-rectangle = inner-square deformation target -/

/-- Cauchy-Goursat deformation from the outer rectangle to the small inner
square around `a`.  Splits the punctured-rectangle theorem into two halves;
this half decomposes the annular region into ordinary holomorphic rectangles. -/
structure UnitKernelRectangleToSquareDeformation
    (R : ZetaRectangle) (a : тДВ)
    (S : R.SmallSquareInsideRectangle a) : Prop where
  rectangle_eq_square :
    R.unitPrincipalKernelRectangleIntegral a =
      R.smallSquareUnitKernelIntegral S

/-! ### AX5: inner-square = circle deformation target -/

/-- Cauchy-Goursat deformation from the inner square to the small circle
around `a`. -/
structure UnitKernelSquareToCircleDeformation
    (R : ZetaRectangle) (a : тДВ)
    (S : R.SmallSquareInsideRectangle a)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  square_eq_circle :
    R.smallSquareUnitKernelIntegral S =
      unitKernelCircleIntegral a C.r

/-! ### AX6: assemble punctured CG from square deformations -/

/-- Composing the two square-staged deformations gives the punctured-rectangle
Cauchy-Goursat theorem. -/
noncomputable def PuncturedRectangleCauchyGoursat.of_square_deformations
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    {S : R.SmallSquareInsideRectangle a}
    (DтВБ : R.UnitKernelRectangleToSquareDeformation a S)
    (DтВВ : R.UnitKernelSquareToCircleDeformation a S C) :
    R.PuncturedRectangleCauchyGoursat a C where
  boundary_integral_eq := by
    rw [DтВБ.rectangle_eq_square, DтВВ.square_eq_circle]

/-! ## AY: Four-strip decomposition for rectangle тЖТ inner square -/

/-! ### AY1: the four strip rectangles -/

/-- Top strip: above the inner square, full width of the outer rectangle. -/
def SmallSquareInsideRectangle.topStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := R.right
  bottom := a.im + S.r
  top := R.top
  hleft_lt_right := R.hleft_lt_right
  hbottom_lt_top := by
    have hcorner : R.ContainsOpen тЯиa.re, a.im + S.rтЯй := by
      apply S.square_subset_open
      refine тЯи?_, ?_тЯй
      ┬╖ show |a.re - a.re| тЙд S.r
        simp; exact S.r_pos.le
      ┬╖ show |(a.im + S.r) - a.im| тЙд S.r
        rw [add_sub_cancel_left]
        exact (abs_of_pos S.r_pos).le
    exact hcorner.2.2.2

/-- Bottom strip: below the inner square, full width of the outer rectangle. -/
def SmallSquareInsideRectangle.bottomStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := R.right
  bottom := R.bottom
  top := a.im - S.r
  hleft_lt_right := R.hleft_lt_right
  hbottom_lt_top := by
    have hcorner : R.ContainsOpen тЯиa.re, a.im - S.rтЯй := by
      apply S.square_subset_open
      refine тЯи?_, ?_тЯй
      ┬╖ show |a.re - a.re| тЙд S.r
        simp; exact S.r_pos.le
      ┬╖ show |(a.im - S.r) - a.im| тЙд S.r
        have h : (a.im - S.r) - a.im = -S.r := by ring
        rw [h, abs_neg, abs_of_pos S.r_pos]
    exact hcorner.2.2.1

/-- Left strip: to the left of the inner square, vertical extent of the square. -/
def SmallSquareInsideRectangle.leftStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := R.left
  right := a.re - S.r
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by
    have hcorner : R.ContainsOpen тЯиa.re - S.r, a.imтЯй := by
      apply S.square_subset_open
      refine тЯи?_, ?_тЯй
      ┬╖ show |(a.re - S.r) - a.re| тЙд S.r
        have h : (a.re - S.r) - a.re = -S.r := by ring
        rw [h, abs_neg, abs_of_pos S.r_pos]
      ┬╖ show |a.im - a.im| тЙд S.r
        simp; exact S.r_pos.le
    exact hcorner.1
  hbottom_lt_top := by linarith [S.r_pos]

/-- Right strip: to the right of the inner square, vertical extent of the square. -/
def SmallSquareInsideRectangle.rightStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : ZetaRectangle where
  left := a.re + S.r
  right := R.right
  bottom := a.im - S.r
  top := a.im + S.r
  hleft_lt_right := by
    have hcorner : R.ContainsOpen тЯиa.re + S.r, a.imтЯй := by
      apply S.square_subset_open
      refine тЯи?_, ?_тЯй
      ┬╖ show |(a.re + S.r) - a.re| тЙд S.r
        rw [add_sub_cancel_left]
        exact (abs_of_pos S.r_pos).le
      ┬╖ show |a.im - a.im| тЙд S.r
        simp; exact S.r_pos.le
    exact hcorner.2.1
  hbottom_lt_top := by linarith [S.r_pos]

/-! ### AY2: `a` is not in any strip тАФ unit kernel is analytic on each -/

theorem unitKernel_analyticOn_topStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    тИА z тИИ {z : тДВ | S.topStrip.ContainsClosed z},
      AnalyticAt тДВ (fun w : тДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hbot : a.im + S.r тЙд a.im := hz.2.2.1
  linarith [S.r_pos]

theorem unitKernel_analyticOn_bottomStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    тИА z тИИ {z : тДВ | S.bottomStrip.ContainsClosed z},
      AnalyticAt тДВ (fun w : тДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have htop : a.im тЙд a.im - S.r := hz.2.2.2
  linarith [S.r_pos]

theorem unitKernel_analyticOn_leftStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    тИА z тИИ {z : тДВ | S.leftStrip.ContainsClosed z},
      AnalyticAt тДВ (fun w : тДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hright : a.re тЙд a.re - S.r := hz.2.1
  linarith [S.r_pos]

theorem unitKernel_analyticOn_rightStrip
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    тИА z тИИ {z : тДВ | S.rightStrip.ContainsClosed z},
      AnalyticAt тДВ (fun w : тДВ => unitPrincipalKernel a w) z := by
  intro z hz
  apply analyticAt_unitPrincipalKernel_of_ne
  intro hza
  rw [hza] at hz
  have hleft : a.re + S.r тЙд a.re := hz.1
  linarith [S.r_pos]

/-! ### AY3: generic rectangle integral + Cauchy-Goursat target -/

/-- Generic boundary integral of `f` around a rectangle, summing the four
edge interval integrals. -/
noncomputable def rectangleIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  (тИл t in (0 : тДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t)
  + (тИл t in (0 : тДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t)
  + (тИл t in (0 : тДЭ)..1, f (R.topEdge t) * deriv R.topEdge t)
  + (тИл t in (0 : тДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t)

/-- The generic rectangle integral specialized to the unit kernel agrees
with `unitPrincipalKernelRectangleIntegral`. -/
theorem rectangleIntegral_unitPrincipalKernel_eq
    (R : ZetaRectangle) (a : тДВ) :
    R.rectangleIntegral (unitPrincipalKernel a) =
      R.unitPrincipalKernelRectangleIntegral a := by
  unfold rectangleIntegral unitPrincipalKernelRectangleIntegral
    principalKernelRectangleIntegral principalKernel unitPrincipalKernel
  push_cast
  ring

/-- Rectangle Cauchy-Goursat: boundary integral of a holomorphic function
on the closed rectangle is zero.  Target structure. -/
structure RectangleCauchyGoursat
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : Prop where
  integral_eq_zero : R.rectangleIntegral f = 0

/-! ## BP: Function-form principal-part decomposition (linearity + remainder vanishing) -/

/-! ### BP1: principal-part sum and log-derivative remainder as `тДВ тЖТ тДВ` -/

/-- The pointwise principal-part sum: `╬г_s principalCoeff(s) / (z тИТ s)` summed
over the counted singularity set in `P`.  Its rectangle integral equals the
sum of per-singularity principal-kernel integrals by linearity. -/
noncomputable def principalPartSum
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : тДВ) : тДВ :=
  P.singularities.sum (fun s => principalKernel (P.principalCoeff s) s z)

/-- The log-derivative remainder: `╬╢'/╬╢ тИТ principalPartSum`.  Holomorphic on
the closed rectangle by construction once strong admissibility separates the
counted singularities from the boundary. -/
noncomputable def logDerivRemainder
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : тДВ) : тДВ :=
  zetaLogDeriv z - R.principalPartSum P z

/-! ### BP2: Linear-decomposition target (algebra of integrals) -/

/-- Linear decomposition: the normalized `╬╢'/╬╢` rectangle integral equals
the sum of normalized principal-kernel integrals plus a `(twoPiI)тБ╗┬╣`-scaled
unnormalized rectangle integral of the remainder.  Pure linearity of
integration over the contour; no analyticity is used. -/
structure RectangleLogDerivContourLinearDecomposition
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  decomposition :
    R.normalizedRectangleLogDerivIntegral =
      P.singularities.sum
        (fun s =>
          R.normalizedPrincipalKernelRectangleIntegral
            (P.principalCoeff s) s)
        + (twoPiI)тБ╗┬╣ * R.rectangleIntegral (R.logDerivRemainder P)

/-! ### BP3: Remainder integral vanishing (Cauchy-Goursat content) -/

/-- The unnormalized rectangle integral of the holomorphic remainder
`╬╢'/╬╢ тИТ principalPartSum` vanishes.  This is the Cauchy-Goursat statement
for the function-form remainder: subtracting the local principal part at
every counted singularity yields a function analytic on the closed
rectangle, whose boundary integral is zero. -/
structure RectangleLogDerivRemainderIntegralVanishes
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  integral_eq_zero :
    R.rectangleIntegral (R.logDerivRemainder P) = 0

/-! ### BP4: Assembler тАФ linearity + vanishing тЗТ contour decomposition -/

/-- Combine the linear decomposition (BP2) with the remainder-vanishing
fact (BP3) to discharge the contour decomposition target. -/
noncomputable def RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (L : R.RectangleLogDerivContourLinearDecomposition P)
    (V : R.RectangleLogDerivRemainderIntegralVanishes P) :
    R.RectanglePrincipalPartContourDecomposition P where
  integral_decomposition := by
    rw [L.decomposition, V.integral_eq_zero, mul_zero, add_zero]

/-! ## BQ: Linearity assembler for the contour decomposition -/

/-! ### BQ1: Pointwise log-derivative split тАФ `╬╢'/╬╢ = principalPartSum + remainder` -/

/-- By definition of the remainder, `╬╢'/╬╢(z) = principalPartSum(z) + remainder(z)`. -/
theorem zetaLogDeriv_eq_principalPartSum_add_remainder
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) (z : тДВ) :
    zetaLogDeriv z =
      R.principalPartSum P z + R.logDerivRemainder P z := by
  unfold logDerivRemainder
  ring

/-! ### BQ2: Rectangle-integral version of the log-derivative -/

/-- Rewriting `rectangleLogDerivIntegral` as the generic `rectangleIntegral`
applied to `zetaLogDeriv`.  Pure unfolding of edge integrals. -/
theorem rectangleLogDerivIntegral_eq_rectangleIntegral
    (R : ZetaRectangle) :
    R.rectangleLogDerivIntegral = R.rectangleIntegral zetaLogDeriv := by
  unfold rectangleLogDerivIntegral rectangleIntegral
    bottomLogDerivIntegral rightLogDerivIntegral
    topLogDerivIntegral leftLogDerivIntegral
  rfl

/-! ### BQ3: Linearity-input package + assembler to BP2 -/

/-- The two purely-algebraic linearity inputs needed to inhabit
`RectangleLogDerivContourLinearDecomposition` from contour-integral
additivity.  Decoupled from analyticity / Cauchy-Goursat. -/
structure RectanglePrincipalPartLinearityData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  add :
    R.rectangleIntegral
      (fun z => R.principalPartSum P z + R.logDerivRemainder P z)
    =
      R.rectangleIntegral (R.principalPartSum P)
        + R.rectangleIntegral (R.logDerivRemainder P)
  sum :
    R.rectangleIntegral (R.principalPartSum P) =
      P.singularities.sum
        (fun s => R.principalKernelRectangleIntegral
          (P.principalCoeff s) s)

/-- **BQ4 тАФ ASSEMBLER:** Given the rectangle-integral addition and finite-sum
linearity facts, inhabit the BP2 linear-decomposition target. -/
noncomputable def RectangleLogDerivContourLinearDecomposition.of_linearityData
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (L : R.RectanglePrincipalPartLinearityData P) :
    R.RectangleLogDerivContourLinearDecomposition P where
  decomposition := by
    unfold normalizedRectangleLogDerivIntegral
      normalizedPrincipalKernelRectangleIntegral
    rw [rectangleLogDerivIntegral_eq_rectangleIntegral R]
    have hpoint : zetaLogDeriv =
        fun z => R.principalPartSum P z + R.logDerivRemainder P z := by
      funext z
      exact zetaLogDeriv_eq_principalPartSum_add_remainder R P z
    rw [hpoint, L.add, mul_add, L.sum, Finset.mul_sum]

/-! ## BR: Rectangle-integral linearity from boundary integrability -/

/-! ### BR1: generic rectangle-integral additivity from edge integrability -/

/-- Additivity of the rectangle integral, conditional on integrability of
both integrands along each of the four edges.  Pure linearity of the
interval integral. -/
theorem rectangleIntegral_add_of_integrable
    (R : ZetaRectangle) (f g : тДВ тЖТ тДВ)
    (hf_bottom :
      IntervalIntegrable
        (fun t : тДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t)
        MeasureTheory.volume 0 1)
    (hg_bottom :
      IntervalIntegrable
        (fun t : тДЭ => g (R.bottomEdge t) * deriv R.bottomEdge t)
        MeasureTheory.volume 0 1)
    (hf_right :
      IntervalIntegrable
        (fun t : тДЭ => f (R.rightEdge t) * deriv R.rightEdge t)
        MeasureTheory.volume 0 1)
    (hg_right :
      IntervalIntegrable
        (fun t : тДЭ => g (R.rightEdge t) * deriv R.rightEdge t)
        MeasureTheory.volume 0 1)
    (hf_top :
      IntervalIntegrable
        (fun t : тДЭ => f (R.topEdge t) * deriv R.topEdge t)
        MeasureTheory.volume 0 1)
    (hg_top :
      IntervalIntegrable
        (fun t : тДЭ => g (R.topEdge t) * deriv R.topEdge t)
        MeasureTheory.volume 0 1)
    (hf_left :
      IntervalIntegrable
        (fun t : тДЭ => f (R.leftEdge t) * deriv R.leftEdge t)
        MeasureTheory.volume 0 1)
    (hg_left :
      IntervalIntegrable
        (fun t : тДЭ => g (R.leftEdge t) * deriv R.leftEdge t)
        MeasureTheory.volume 0 1) :
    R.rectangleIntegral (fun z => f z + g z) =
      R.rectangleIntegral f + R.rectangleIntegral g := by
  unfold rectangleIntegral
  simp only [add_mul]
  rw [intervalIntegral.integral_add hf_bottom hg_bottom,
      intervalIntegral.integral_add hf_right hg_right,
      intervalIntegral.integral_add hf_top hg_top,
      intervalIntegral.integral_add hf_left hg_left]
  abel

/-! ### BR2: integrability package -/

/-- Integrability of a function along the four rectangle edges. -/
structure RectangleIntegralIntegrable
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : Prop where
  bottom :
    IntervalIntegrable
      (fun t : тДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t)
      MeasureTheory.volume 0 1
  right :
    IntervalIntegrable
      (fun t : тДЭ => f (R.rightEdge t) * deriv R.rightEdge t)
      MeasureTheory.volume 0 1
  top :
    IntervalIntegrable
      (fun t : тДЭ => f (R.topEdge t) * deriv R.topEdge t)
      MeasureTheory.volume 0 1
  left :
    IntervalIntegrable
      (fun t : тДЭ => f (R.leftEdge t) * deriv R.leftEdge t)
      MeasureTheory.volume 0 1

/-- Packaged BR1 that consumes the integrability data structurally. -/
theorem rectangleIntegral_add_of_integrable_package
    (R : ZetaRectangle) (f g : тДВ тЖТ тДВ)
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.rectangleIntegral (fun z => f z + g z) =
      R.rectangleIntegral f + R.rectangleIntegral g :=
  rectangleIntegral_add_of_integrable R f g
    hf.bottom hg.bottom
    hf.right hg.right
    hf.top hg.top
    hf.left hg.left

/-! ### BR3: zero / add closures for `RectangleIntegralIntegrable` -/

/-- The constant zero function is rectangle-integrable. -/
theorem RectangleIntegralIntegrable.zero (R : ZetaRectangle) :
    R.RectangleIntegralIntegrable (fun _ : тДВ => 0) where
  bottom := by simp
  right := by simp
  top := by simp
  left := by simp

/-- Sum of rectangle-integrable functions is rectangle-integrable. -/
theorem RectangleIntegralIntegrable.add
    {R : ZetaRectangle} {f g : тДВ тЖТ тДВ}
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.RectangleIntegralIntegrable (fun z => f z + g z) where
  bottom := by simpa [add_mul] using hf.bottom.add hg.bottom
  right := by simpa [add_mul] using hf.right.add hg.right
  top := by simpa [add_mul] using hf.top.add hg.top
  left := by simpa [add_mul] using hf.left.add hg.left

/-! ### BR4: finite-sum closures + finite-sum linearity -/

/-- A finite sum of rectangle-integrable functions is rectangle-integrable. -/
theorem rectangleIntegralIntegrable_finset_sum
    (R : ZetaRectangle) (F : тДВ тЖТ тДВ тЖТ тДВ) (S : Finset тДВ)
    (hF : тИА s тИИ S, R.RectangleIntegralIntegrable (F s)) :
    R.RectangleIntegralIntegrable (fun z => S.sum (fun s => F s z)) := by
  classical
  revert hF
  induction S using Finset.induction_on with
  | empty =>
    intro _
    have h : (fun z : тДВ => (тИЕ : Finset тДВ).sum (fun s => F s z)) = (fun _ : тДВ => 0) := by
      funext z; exact Finset.sum_empty
    rw [h]
    exact RectangleIntegralIntegrable.zero R
  | insert a S' ha ih =>
    intro hF
    have hFa : R.RectangleIntegralIntegrable (F a) :=
      hF a (Finset.mem_insert_self a S')
    have hF' : тИА t тИИ S', R.RectangleIntegralIntegrable (F t) := fun t ht =>
      hF t (Finset.mem_insert_of_mem ht)
    have h_rest := ih hF'
    have h_eq : (fun z : тДВ => (insert a S').sum (fun t => F t z))
              = fun z => F a z + S'.sum (fun t => F t z) := by
      funext z
      exact Finset.sum_insert ha
    rw [h_eq]
    exact hFa.add h_rest

/-- Rectangle integral of a finite sum equals the finite sum of rectangle
integrals, given integrability of each summand. -/
theorem rectangleIntegral_finset_sum
    (R : ZetaRectangle) (F : тДВ тЖТ тДВ тЖТ тДВ) (S : Finset тДВ)
    (hF : тИА s тИИ S, R.RectangleIntegralIntegrable (F s)) :
    R.rectangleIntegral (fun z => S.sum (fun s => F s z)) =
      S.sum (fun s => R.rectangleIntegral (F s)) := by
  classical
  revert hF
  induction S using Finset.induction_on with
  | empty =>
    intro _
    simp only [Finset.sum_empty]
    unfold rectangleIntegral
    simp
  | insert a S' ha ih =>
    intro hF
    have hFa : R.RectangleIntegralIntegrable (F a) :=
      hF a (Finset.mem_insert_self a S')
    have hF' : тИА t тИИ S', R.RectangleIntegralIntegrable (F t) := fun t ht =>
      hF t (Finset.mem_insert_of_mem ht)
    have hSumInt :
        R.RectangleIntegralIntegrable (fun z => S'.sum (fun t => F t z)) :=
      rectangleIntegralIntegrable_finset_sum R F S' hF'
    have h_eq : (fun z : тДВ => (insert a S').sum (fun t => F t z))
              = fun z => F a z + S'.sum (fun t => F t z) := by
      funext z
      exact Finset.sum_insert ha
    rw [h_eq]
    rw [rectangleIntegral_add_of_integrable_package R (F a)
        (fun z => S'.sum (fun t => F t z)) hFa hSumInt]
    rw [Finset.sum_insert ha, ih hF']

/-! ### BR5: integrability-data package + linearity-data assembler -/

/-- Integrability data for a principal-part package: each per-singularity
principal kernel and the log-derivative remainder are rectangle-integrable. -/
structure RectanglePrincipalPartIntegrabilityData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  kernels :
    тИА s тИИ P.singularities,
      R.RectangleIntegralIntegrable
        (fun z => principalKernel (P.principalCoeff s) s z)
  remainder :
    R.RectangleIntegralIntegrable (R.logDerivRemainder P)

/-- **BR5 тАФ ASSEMBLER:** Integrability data implies the linearity inputs
needed to inhabit `RectangleLogDerivContourLinearDecomposition` via BQ4. -/
noncomputable def RectanglePrincipalPartIntegrabilityData.toLinearityData
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (I : R.RectanglePrincipalPartIntegrabilityData P) :
    R.RectanglePrincipalPartLinearityData P where
  add := by
    have hsumInt :
        R.RectangleIntegralIntegrable (R.principalPartSum P) := by
      unfold principalPartSum
      exact rectangleIntegralIntegrable_finset_sum R
        (fun s z => principalKernel (P.principalCoeff s) s z)
        P.singularities I.kernels
    exact rectangleIntegral_add_of_integrable_package R
      (R.principalPartSum P) (R.logDerivRemainder P)
      hsumInt I.remainder
  sum := by
    unfold principalPartSum
    exact rectangleIntegral_finset_sum R
      (fun s z => principalKernel (P.principalCoeff s) s z)
      P.singularities I.kernels

/-! ## BS: Inhabit `RectanglePrincipalPartIntegrabilityData` from continuity -/

/-! ### BS1: counted singularities avoid the boundary -/

/-- Every counted principal-part singularity lies off the rectangle
boundary.  Combines `singularities_complete` with strong admissibility's
`noZetaZerosOnBoundary` / `poleNotOnBoundary`. -/
theorem boundary_ne_of_mem_principalPart_singularities
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s z : тДВ}
    (hs : s тИИ P.singularities) (hz : R.ContainsBoundary z) :
    z тЙа s := by
  have hsCounted : R.IsCountedZetaSingularityInside s :=
    (P.singularities_complete s).mp hs
  intro hzs
  subst z
  rcases hsCounted with hsZero | hsPole
  ┬╖ exact P.stronglyAdmissible.noZetaZerosOnBoundary s hsZero.1.1 hz
  ┬╖ obtain тЯи_, hs_eqтЯй := hsPole
    subst hs_eq
    exact P.stronglyAdmissible.poleNotOnBoundary hz

/-! ### BS2: continuity of `principalKernel` off the singularity -/

/-- `principalKernel k s` is continuous at every point `z тЙа s`. -/
theorem continuousAt_principalKernel_of_ne
    {k : тДд} {s z : тДВ} (hz : z тЙа s) :
    ContinuousAt (fun w : тДВ => principalKernel k s w) z := by
  unfold principalKernel
  refine continuousAt_const.div (continuousAt_id.sub continuousAt_const) ?_
  simpa [sub_eq_zero] using hz

/-! ### BS3: per-edge interval-integrability of `principalKernel тИШ ╬│ * deriv ╬│` -/

/-- Per-edge integrability of the principal-kernel integrand, for any
continuous parametrization `╬│ : тДЭ тЖТ тДВ` of a rectangle edge that stays on
the rectangle boundary (so it stays off every counted singularity). -/
theorem intervalIntegrable_principalKernel_on_edge
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s : тДВ}
    (hs : s тИИ P.singularities) (╬│ : тДЭ тЖТ тДВ)
    (h╬│_cont : Continuous ╬│)
    (h╬│_deriv_cont : ContinuousOn (fun t : тДЭ => deriv ╬│ t) (Set.Icc 0 1))
    (h╬│_boundary :
      тИА t : тДЭ, 0 тЙд t тЖТ t тЙд 1 тЖТ R.ContainsBoundary (╬│ t)) :
    IntervalIntegrable
      (fun t : тДЭ =>
        principalKernel (P.principalCoeff s) s (╬│ t) * deriv ╬│ t)
      MeasureTheory.volume 0 1 := by
  have hkernel :
      ContinuousOn
        (fun t : тДЭ => principalKernel (P.principalCoeff s) s (╬│ t))
        (Set.Icc 0 1) := by
    intro t ht
    have hzbd : R.ContainsBoundary (╬│ t) := h╬│_boundary t ht.1 ht.2
    have hz_ne : ╬│ t тЙа s :=
      boundary_ne_of_mem_principalPart_singularities hs hzbd
    exact
      ((continuousAt_principalKernel_of_ne hz_ne).comp
        h╬│_cont.continuousAt).continuousWithinAt
  exact (hkernel.mul h╬│_deriv_cont).intervalIntegrable_of_Icc
    (by norm_num : (0 : тДЭ) тЙд 1)

/-- Each per-singularity principal kernel is rectangle-integrable. -/
theorem rectangleIntegralIntegrable_principalKernel
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData} {s : тДВ}
    (hs : s тИИ P.singularities) :
    R.RectangleIntegralIntegrable
      (fun z => principalKernel (P.principalCoeff s) s z) where
  bottom :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.bottomEdge R.continuous_bottomEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).bottom
      (fun _ ht0 ht1 => R.bottomEdge_mem_boundary ht0 ht1)
  right :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.rightEdge R.continuous_rightEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).right
      (fun _ ht0 ht1 => R.rightEdge_mem_boundary ht0 ht1)
  top :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.topEdge R.continuous_topEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).top
      (fun _ ht0 ht1 => R.topEdge_mem_boundary ht0 ht1)
  left :=
    intervalIntegrable_principalKernel_on_edge (R := R) (P := P) hs
      R.leftEdge R.continuous_leftEdge
      (ZetaRectangleEdgeDerivContinuous.of_affine_edges R).left
      (fun _ ht0 ht1 => R.leftEdge_mem_boundary ht0 ht1)

/-! ### BS4: integrability of the principal-part sum -/

/-- The principal-part sum `╬г_s principalKernel (P.coeff s) s` is
rectangle-integrable, by finite-sum closure on the per-kernel case. -/
theorem rectangleIntegralIntegrable_principalPartSum
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleIntegralIntegrable (R.principalPartSum P) := by
  unfold principalPartSum
  exact rectangleIntegralIntegrable_finset_sum R
    (fun s z => principalKernel (P.principalCoeff s) s z)
    P.singularities
    (fun s hs => rectangleIntegralIntegrable_principalKernel hs)

/-! ### BS5: integrability of the log-derivative remainder via negation / subtraction -/

/-- Bridge from `ZetaRectangleLogDerivIntegrable` (existing) to
`RectangleIntegralIntegrable zetaLogDeriv` (new package). -/
theorem rectangleIntegralIntegrable_zetaLogDeriv
    {R : ZetaRectangle} (hAdm : R.StronglyAdmissibleForZeta) :
    R.RectangleIntegralIntegrable zetaLogDeriv :=
  let H := ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine hAdm
  тЯиH.bottom, H.right, H.top, H.leftтЯй

/-- Negation closure for rectangle-integrability. -/
theorem RectangleIntegralIntegrable.neg
    {R : ZetaRectangle} {f : тДВ тЖТ тДВ}
    (hf : R.RectangleIntegralIntegrable f) :
    R.RectangleIntegralIntegrable (fun z => -f z) where
  bottom := by simpa [neg_mul] using hf.bottom.neg
  right := by simpa [neg_mul] using hf.right.neg
  top := by simpa [neg_mul] using hf.top.neg
  left := by simpa [neg_mul] using hf.left.neg

/-- Subtraction closure for rectangle-integrability. -/
theorem RectangleIntegralIntegrable.sub
    {R : ZetaRectangle} {f g : тДВ тЖТ тДВ}
    (hf : R.RectangleIntegralIntegrable f)
    (hg : R.RectangleIntegralIntegrable g) :
    R.RectangleIntegralIntegrable (fun z => f z - g z) := by
  simpa [sub_eq_add_neg] using hf.add hg.neg

/-- The log-derivative remainder is rectangle-integrable, via
`zetaLogDeriv тИТ principalPartSum`. -/
theorem rectangleIntegralIntegrable_logDerivRemainder
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleIntegralIntegrable (R.logDerivRemainder P) := by
  unfold logDerivRemainder
  exact
    (rectangleIntegralIntegrable_zetaLogDeriv P.stronglyAdmissible).sub
      (rectangleIntegralIntegrable_principalPartSum P)

/-! ### BS6: final integrability-data construction -/

/-- **BS6 тАФ INHABITED:** the principal-part integrability data is built
unconditionally from the local kernel-continuity proof (BS3) and the
log-derivative remainder integrability (BS5). -/
noncomputable def rectanglePrincipalPartIntegrabilityData
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectanglePrincipalPartIntegrabilityData P where
  kernels := fun _ hs => rectangleIntegralIntegrable_principalKernel hs
  remainder := rectangleIntegralIntegrable_logDerivRemainder P

/-- **BS6 тАФ DOWNSTREAM:** the linear-decomposition target (BP2) is now
inhabited unconditionally for any `RectanglePrincipalPartData`. -/
noncomputable def rectangleLogDerivContourLinearDecomposition
    {R : ZetaRectangle} (P : R.RectanglePrincipalPartData) :
    R.RectangleLogDerivContourLinearDecomposition P :=
  RectangleLogDerivContourLinearDecomposition.of_linearityData
    ((rectanglePrincipalPartIntegrabilityData P).toLinearityData)

/-! ### AY4: four-strip boundary-cancellation target -/

/-- Algebraic boundary cancellation: if all four annular strip integrals
of `1/(z - a)` are zero (Cauchy-Goursat) and the edge-integrals over shared
interior edges cancel, then the outer rectangle integral equals the inner
square integral. -/
structure FourStripBoundaryCancellation
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  rectangle_eq_square :
    R.unitPrincipalKernelRectangleIntegral a =
      R.smallSquareUnitKernelIntegral S

/-- Boundary cancellation yields the rectangle-to-square deformation. -/
noncomputable def FourStripBoundaryCancellation.toRectangleToSquare
    {R : ZetaRectangle} {a : тДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripBoundaryCancellation S) :
    R.UnitKernelRectangleToSquareDeformation a S where
  rectangle_eq_square := H.rectangle_eq_square

/-! ## AZ: Mathlib rectangle Cauchy-Goursat adapter -/

/-! ### AZ1 тАФ probe results.

Mathlib's relevant theorem:

```
theorem Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn
    (f : тДВ тЖТ E) (z w : тДВ)
    (Hc : ContinuousOn f ([[z.re, w.re]] ├ЧтДВ [[z.im, w.im]]))
    (Hd : DifferentiableOn тДВ f
      (Ioo (min z.re w.re) (max z.re w.re) ├ЧтДВ
       Ioo (min z.im w.im) (max z.im w.im))) :
    (тИл x : тДЭ in z.re..w.re, f (x + z.im * I)) -
      (тИл x : тДЭ in z.re..w.re, f (x + w.im * I)) +
      I тАв (тИл y : тДЭ in z.im..w.im, f (w.re + y * I)) -
      I тАв (тИл y : тДЭ in z.im..w.im, f (z.re + y * I)) = 0
```

It uses opposite-corner coordinates `z, w : тДВ` and integrates over straight
real-axis (or imaginary-axis) intervals at fixed `z.im` / `w.im` / `z.re`
/ `w.re`, with explicit `IтАв` weights for vertical edges.

Our `rectangleIntegral R f` parameterizes each edge over `t тИИ [0,1]` via
`R.bottomEdge`, `R.rightEdge`, `R.topEdge`, `R.leftEdge` and multiplies by
the path derivative.  Equivalence holds termwise after change of variable
`x := R.left + t┬╖(R.right тИТ R.left)` (etc.), but the proof crosses several
Mathlib API surfaces (`intervalIntegral.integral_comp_mul_add`, realтЖФcomplex
casting, `Complex.mk = re + im┬╖I`) and is a substantial bookkeeping proof.

We package the resulting equality as the target structure
`RectangleCauchyGoursatBridge` below.  Once inhabited, every strip's
Cauchy-Goursat follows by AZ4. -/

/-! ### AZ2 тАФ Mathlib rectangle Cauchy-Goursat bridge target -/

/-- The analytic bridge from Mathlib's rectangle Cauchy-Goursat theorem to
our 4-edge `rectangleIntegral` form.  Inhabiting this single target
discharges Cauchy-Goursat for every rectangle and every analytic function. -/
structure RectangleCauchyGoursatBridge : Prop where
  cauchyGoursat :
    тИА (R : ZetaRectangle) (f : тДВ тЖТ тДВ),
      (тИА z тИИ {z : тДВ | R.ContainsClosed z}, AnalyticAt тДВ f z) тЖТ
      R.rectangleIntegral f = 0

/-! ### AZ3 тАФ generic rectangle Cauchy-Goursat (conditional on the bridge) -/

/-- Generic rectangle Cauchy-Goursat: analytic on closed rectangle тЗТ
boundary integral is zero.  Conditional on `RectangleCauchyGoursatBridge`. -/
noncomputable def rectangleCauchyGoursat_of_analyticOn_closed
    (B : RectangleCauchyGoursatBridge)
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ)
    (hf : тИА z тИИ {z : тДВ | R.ContainsClosed z}, AnalyticAt тДВ f z) :
    R.RectangleCauchyGoursat f where
  integral_eq_zero := B.cauchyGoursat R f hf

/-! ### AZ4 тАФ the four strip Cauchy-Goursat specializations -/

/-- Top-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_topStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.topStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_topStrip S)

/-- Bottom-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_bottomStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.bottomStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_bottomStrip S)

/-- Left-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_leftStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.leftStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_leftStrip S)

/-- Right-strip Cauchy-Goursat for the unit kernel. -/
noncomputable def rectangleCauchyGoursat_rightStrip_unitKernel
    (B : RectangleCauchyGoursatBridge)
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    S.rightStrip.RectangleCauchyGoursat (unitPrincipalKernel a) :=
  rectangleCauchyGoursat_of_analyticOn_closed B _ _
    (unitKernel_analyticOn_rightStrip S)

/-! ## BA: Coordinate-form bridge for the Mathlib rectangle theorem -/

/-! ### BA1: direct-coordinate edge integrals -/

/-- Bottom horizontal edge integral, parameterized by real `x` at fixed
imaginary `R.bottom`. -/
noncomputable def bottomHorizontalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  тИл x in R.left..R.right, f тЯиx, R.bottomтЯй

/-- Top horizontal edge integral oriented right-to-left as in the positive
rectangle boundary. -/
noncomputable def topHorizontalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  тИл x in R.right..R.left, f тЯиx, R.topтЯй

/-- Right vertical edge integral, parameterized by real `y` at fixed real
`R.right`, with the `I` weight built in. -/
noncomputable def rightVerticalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  тИл y in R.bottom..R.top, f тЯиR.right, yтЯй * Complex.I

/-- Left vertical edge integral oriented top-to-bottom. -/
noncomputable def leftVerticalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  тИл y in R.top..R.bottom, f тЯиR.left, yтЯй * Complex.I

/-- Direct-coordinate rectangle boundary integral (sum of four edge
integrals above). -/
noncomputable def coordinateBoundaryIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : тДВ :=
  R.bottomHorizontalIntegral f
    + R.rightVerticalIntegral f
    + R.topHorizontalIntegral f
    + R.leftVerticalIntegral f

/-! ### BA2: per-rectangle edge-bridge target -/

/-- Per-rectangle equality between our `t`-parametrized edge integrals and
the direct-coordinate edge integrals.  Each component is a one-line affine
change-of-variable that we factor out as a separate target. -/
structure RectangleEdgeIntegralCoordinateBridge
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) : Prop where
  bottom :
    (тИл t in (0 : тДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t)
      = R.bottomHorizontalIntegral f
  right :
    (тИл t in (0 : тДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t)
      = R.rightVerticalIntegral f
  top :
    (тИл t in (0 : тДЭ)..1, f (R.topEdge t) * deriv R.topEdge t)
      = R.topHorizontalIntegral f
  left :
    (тИл t in (0 : тДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t)
      = R.leftVerticalIntegral f

/-- The four edge equalities assemble into `rectangleIntegral = coordinateBoundaryIntegral`. -/
theorem rectangleIntegral_eq_coordinateBoundaryIntegral
    {R : ZetaRectangle} {f : тДВ тЖТ тДВ}
    (E : R.RectangleEdgeIntegralCoordinateBridge f) :
    R.rectangleIntegral f = R.coordinateBoundaryIntegral f := by
  unfold rectangleIntegral coordinateBoundaryIntegral
  rw [E.bottom, E.right, E.top, E.left]

/-! ### BA3: coordinate-to-Mathlib bridge + combiner to AZ2 -/

/-- Per-rectangle bridge connecting the direct-coordinate boundary integral
to whatever specific expression Mathlib's rectangle Cauchy-Goursat returns. -/
structure CoordinateBoundaryIntegralMathlibBridge
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) where
  mathlibBoundaryIntegral : тДВ
  coordinate_eq_mathlib :
    R.coordinateBoundaryIntegral f = mathlibBoundaryIntegral

/-- If per-(R, f) coordinate adapters and per-(R, f) Mathlib bridges exist,
and Mathlib's boundary integral is zero whenever `f` is analytic on the
closed rectangle, then the global `RectangleCauchyGoursatBridge` follows. -/
noncomputable def RectangleCauchyGoursatBridge.of_coordinate_adapters
    (edgeBridge :
      тИА (R : ZetaRectangle) (f : тДВ тЖТ тДВ),
        R.RectangleEdgeIntegralCoordinateBridge f)
    (mathlibBridge :
      тИА (R : ZetaRectangle) (f : тДВ тЖТ тДВ),
        R.CoordinateBoundaryIntegralMathlibBridge f)
    (mathlibCauchyGoursat :
      тИА (R : ZetaRectangle) (f : тДВ тЖТ тДВ),
        (тИА z тИИ {z : тДВ | R.ContainsClosed z}, AnalyticAt тДВ f z) тЖТ
        (mathlibBridge R f).mathlibBoundaryIntegral = 0) :
    RectangleCauchyGoursatBridge where
  cauchyGoursat R f hf := by
    rw [rectangleIntegral_eq_coordinateBoundaryIntegral (edgeBridge R f)]
    rw [(mathlibBridge R f).coordinate_eq_mathlib]
    exact mathlibCauchyGoursat R f hf

/-! ## BB: Affine change-of-variable lemmas + four edge bridges -/

/-! ### BB1: generic horizontal affine substitution for тДВ-valued integrands -/

/-- Affine change of variable for a тДВ-valued integrand:
`тИл t in 0..1, g((b-a)*t + a) * ((b-a):тДВ) = тИл x in a..b, g x`.

The integrand has an explicit `(b-a):тДВ` factor (the Jacobian as a real cast
into тДВ).  This is the core affine substitution used by each of the four
edge bridges. -/
theorem intervalIntegral_affine_horizontal_complex
    (g : тДЭ тЖТ тДВ) (a b : тДЭ) :
    (тИл t in (0 : тДЭ)..1, g ((b - a) * t + a) * ((b - a : тДЭ) : тДВ)) =
      тИл x in a..b, g x := by
  have h_smul :
      (fun t : тДЭ => g ((b - a) * t + a) * ((b - a : тДЭ) : тДВ)) =
        (fun t : тДЭ => (b - a : тДЭ) тАв g ((b - a) * t + a)) := by
    funext t
    rw [Complex.real_smul, mul_comm]
  rw [h_smul, intervalIntegral.integral_smul,
      intervalIntegral.smul_integral_comp_mul_add]
  simp only [mul_zero, mul_one, zero_add, sub_add_cancel]

/-! ### BB2: bottom edge bridge -/

/-- Bottom-edge change-of-variable from `t тИИ [0, 1]` to `x тИИ [R.left, R.right]`. -/
theorem bottomEdgeIntegral_eq_bottomHorizontalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    (тИл t in (0 : тДЭ)..1, f (R.bottomEdge t) * deriv R.bottomEdge t) =
      R.bottomHorizontalIntegral f := by
  unfold bottomHorizontalIntegral
  have h_pointwise :
      (fun t : тДЭ => f (R.bottomEdge t) * deriv R.bottomEdge t) =
        (fun t : тДЭ =>
          (fun x : тДЭ => f тЯиx, R.bottomтЯй) ((R.right - R.left) * t + R.left) *
            ((R.right - R.left : тДЭ) : тДВ)) := by
    funext t
    rw [R.deriv_bottomEdge t]
    have he : R.bottomEdge t = тЯи(R.right - R.left) * t + R.left, R.bottomтЯй := by
      unfold ZetaRectangle.bottomEdge
      congr 1
      ring
    rw [he]
  rw [h_pointwise]
  exact intervalIntegral_affine_horizontal_complex
    (fun x : тДЭ => f тЯиx, R.bottomтЯй) R.left R.right

/-! ### BB3: generic vertical affine substitution + right edge bridge -/

/-- Vertical affine substitution: same as `intervalIntegral_affine_horizontal_complex`
but with an extra `* Complex.I` weight, matching vertical edge integrals. -/
theorem intervalIntegral_affine_vertical_complex
    (g : тДЭ тЖТ тДВ) (a b : тДЭ) :
    (тИл t in (0 : тДЭ)..1,
      g ((b - a) * t + a) * (((b - a : тДЭ) : тДВ) * Complex.I)) =
      тИл y in a..b, g y * Complex.I := by
  have h := intervalIntegral_affine_horizontal_complex
    (fun y : тДЭ => g y * Complex.I) a b
  have h_eq :
      (fun t : тДЭ =>
        g ((b - a) * t + a) * (((b - a : тДЭ) : тДВ) * Complex.I)) =
      (fun t : тДЭ =>
        (fun y : тДЭ => g y * Complex.I) ((b - a) * t + a) *
          ((b - a : тДЭ) : тДВ)) := by
    funext t; ring
  rw [h_eq]
  exact h

/-- Right-edge change-of-variable from `t тИИ [0, 1]` to `y тИИ [R.bottom, R.top]`. -/
theorem rightEdgeIntegral_eq_rightVerticalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    (тИл t in (0 : тДЭ)..1, f (R.rightEdge t) * deriv R.rightEdge t) =
      R.rightVerticalIntegral f := by
  unfold rightVerticalIntegral
  have h_pointwise :
      (fun t : тДЭ => f (R.rightEdge t) * deriv R.rightEdge t) =
        (fun t : тДЭ =>
          (fun y : тДЭ => f тЯиR.right, yтЯй)
            ((R.top - R.bottom) * t + R.bottom) *
            (((R.top - R.bottom : тДЭ) : тДВ) * Complex.I)) := by
    funext t
    rw [R.deriv_rightEdge t]
    have he : R.rightEdge t = тЯиR.right, (R.top - R.bottom) * t + R.bottomтЯй := by
      unfold ZetaRectangle.rightEdge
      congr 1
      ring
    rw [he]
  rw [h_pointwise]
  exact intervalIntegral_affine_vertical_complex
    (fun y : тДЭ => f тЯиR.right, yтЯй) R.bottom R.top

/-! ### BB4: top + left edges via the horizontal/vertical affine lemmas -/

/-- Top-edge change-of-variable; uses reversed orientation `R.right..R.left`. -/
theorem topEdgeIntegral_eq_topHorizontalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    (тИл t in (0 : тДЭ)..1, f (R.topEdge t) * deriv R.topEdge t) =
      R.topHorizontalIntegral f := by
  unfold topHorizontalIntegral
  have h_pointwise :
      (fun t : тДЭ => f (R.topEdge t) * deriv R.topEdge t) =
        (fun t : тДЭ =>
          (fun x : тДЭ => f тЯиx, R.topтЯй) ((R.left - R.right) * t + R.right) *
            ((R.left - R.right : тДЭ) : тДВ)) := by
    funext t
    rw [R.deriv_topEdge t]
    have he : R.topEdge t = тЯи(R.left - R.right) * t + R.right, R.topтЯй := by
      unfold ZetaRectangle.topEdge
      congr 1
      ring
    rw [he]
    push_cast
    ring
  rw [h_pointwise]
  exact intervalIntegral_affine_horizontal_complex
    (fun x : тДЭ => f тЯиx, R.topтЯй) R.right R.left

/-- Left-edge change-of-variable; uses reversed orientation `R.top..R.bottom`. -/
theorem leftEdgeIntegral_eq_leftVerticalIntegral
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    (тИл t in (0 : тДЭ)..1, f (R.leftEdge t) * deriv R.leftEdge t) =
      R.leftVerticalIntegral f := by
  unfold leftVerticalIntegral
  have h_pointwise :
      (fun t : тДЭ => f (R.leftEdge t) * deriv R.leftEdge t) =
        (fun t : тДЭ =>
          (fun y : тДЭ => f тЯиR.left, yтЯй) ((R.bottom - R.top) * t + R.top) *
            (((R.bottom - R.top : тДЭ) : тДВ) * Complex.I)) := by
    funext t
    rw [R.deriv_leftEdge t]
    have he : R.leftEdge t = тЯиR.left, (R.bottom - R.top) * t + R.topтЯй := by
      unfold ZetaRectangle.leftEdge
      congr 1
      ring
    rw [he]
    push_cast
    ring
  rw [h_pointwise]
  exact intervalIntegral_affine_vertical_complex
    (fun y : тДЭ => f тЯиR.left, yтЯй) R.top R.bottom

/-! ### BB5: assembler тАФ `RectangleEdgeIntegralCoordinateBridge` is inhabited -/

/-- The four per-edge change-of-variable equalities assemble into the
per-(R, f) edge bridge.  This is the analytic discharge needed by AZ's
combiner for the global Cauchy-Goursat bridge. -/
theorem rectangleEdgeIntegralCoordinateBridge
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    R.RectangleEdgeIntegralCoordinateBridge f where
  bottom := bottomEdgeIntegral_eq_bottomHorizontalIntegral R f
  right := rightEdgeIntegral_eq_rightVerticalIntegral R f
  top := topEdgeIntegral_eq_topHorizontalIntegral R f
  left := leftEdgeIntegral_eq_leftVerticalIntegral R f

/-! ## BC: Coordinate тЖТ Mathlib boundary bridge + final hook -/

/-! ### BC2: trivial coordinate тЖФ Mathlib bridge -/

/-- Trivial coordinate-to-Mathlib bridge: define the "Mathlib boundary
integral" as our `coordinateBoundaryIntegral`.  This makes the bridge a
pure renaming. -/
noncomputable def coordinateBoundaryIntegralMathlibBridge
    (R : ZetaRectangle) (f : тДВ тЖТ тДВ) :
    R.CoordinateBoundaryIntegralMathlibBridge f where
  mathlibBoundaryIntegral := R.coordinateBoundaryIntegral f
  coordinate_eq_mathlib := rfl

/-! ### BC3: Mathlib Cauchy-Goursat hook (target) -/

/-- Final analytic obligation: for every rectangle and every function analytic
on its closed rectangle, the coordinate boundary integral vanishes.  This is
the direct invocation of `Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn`
plus the algebraic rearrangement matching our coordinate form. -/
structure MathlibCauchyGoursatHook : Prop where
  vanishes :
    тИА (R : ZetaRectangle) (f : тДВ тЖТ тДВ),
      (тИА z тИИ {z : тДВ | R.ContainsClosed z}, AnalyticAt тДВ f z) тЖТ
      R.coordinateBoundaryIntegral f = 0

/-! ### BC4: from hook to global `RectangleCauchyGoursatBridge` -/

/-- The Mathlib Cauchy-Goursat hook plus the proved edge/coordinate adapters
gives the global `RectangleCauchyGoursatBridge`.  Once `MathlibCauchyGoursatHook`
is inhabited, every rectangle/function CG follows mechanically. -/
noncomputable def RectangleCauchyGoursatBridge.of_mathlibHook
    (M : MathlibCauchyGoursatHook) :
    RectangleCauchyGoursatBridge :=
  RectangleCauchyGoursatBridge.of_coordinate_adapters
    (fun R f => rectangleEdgeIntegralCoordinateBridge R f)
    (fun R f => coordinateBoundaryIntegralMathlibBridge R f)
    (fun R f hf => M.vanishes R f hf)

/-! ### BC5: inhabit `MathlibCauchyGoursatHook` from Mathlib's theorem -/

/-- The Mathlib Cauchy-Goursat hook is inhabited by direct invocation of
`Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn`
plus the per-edge coordinate rewrites. -/
theorem mathlibCauchyGoursatHook : MathlibCauchyGoursatHook where
  vanishes R f hf := by
    have hLR : R.left тЙд R.right := R.hleft_lt_right.le
    have hBT : R.bottom тЙд R.top := R.hbottom_lt_top.le
    set zтВА : тДВ := тЯиR.left, R.bottomтЯй
    set wтВА : тДВ := тЯиR.right, R.topтЯй
    have hz_re : zтВА.re = R.left := rfl
    have hz_im : zтВА.im = R.bottom := rfl
    have hw_re : wтВА.re = R.right := rfl
    have hw_im : wтВА.im = R.top := rfl
    -- Continuity on Mathlib's closed rectangle
    have hcont : ContinuousOn f
        (Set.uIcc zтВА.re wтВА.re ├ЧтДВ Set.uIcc zтВА.im wтВА.im) := by
      intro p hp
      have hp_mem := mem_reProdIm.mp hp
      have hp_re : p.re тИИ Set.uIcc zтВА.re wтВА.re := hp_mem.1
      have hp_im : p.im тИИ Set.uIcc zтВА.im wтВА.im := hp_mem.2
      rw [show zтВА.re = R.left from rfl, show wтВА.re = R.right from rfl,
          Set.uIcc_of_le hLR, Set.mem_Icc] at hp_re
      rw [show zтВА.im = R.bottom from rfl, show wтВА.im = R.top from rfl,
          Set.uIcc_of_le hBT, Set.mem_Icc] at hp_im
      have hp_closed : R.ContainsClosed p :=
        тЯиhp_re.1, hp_re.2, hp_im.1, hp_im.2тЯй
      exact (hf p hp_closed).continuousAt.continuousWithinAt
    -- Differentiability on Mathlib's open rectangle
    have hdiff : DifferentiableOn тДВ f
        (Set.Ioo (min zтВА.re wтВА.re) (max zтВА.re wтВА.re) ├ЧтДВ
         Set.Ioo (min zтВА.im wтВА.im) (max zтВА.im wтВА.im)) := by
      intro p hp
      have hp_mem := mem_reProdIm.mp hp
      have hp_re : p.re тИИ Set.Ioo (min zтВА.re wтВА.re) (max zтВА.re wтВА.re) :=
        hp_mem.1
      have hp_im : p.im тИИ Set.Ioo (min zтВА.im wтВА.im) (max zтВА.im wтВА.im) :=
        hp_mem.2
      rw [show zтВА.re = R.left from rfl, show wтВА.re = R.right from rfl,
          min_eq_left hLR, max_eq_right hLR, Set.mem_Ioo] at hp_re
      rw [show zтВА.im = R.bottom from rfl, show wтВА.im = R.top from rfl,
          min_eq_left hBT, max_eq_right hBT, Set.mem_Ioo] at hp_im
      have hp_closed : R.ContainsClosed p :=
        тЯиhp_re.1.le, hp_re.2.le, hp_im.1.le, hp_im.2.leтЯй
      exact (hf p hp_closed).differentiableAt.differentiableWithinAt
    -- Apply Mathlib's rectangle Cauchy-Goursat theorem
    have h_mathlib :=
      Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn
        f zтВА wтВА hcont hdiff
    rw [hz_re, hz_im, hw_re, hw_im] at h_mathlib
    -- Convert each of our four edge integrals
    have h_bot_eq :
        R.bottomHorizontalIntegral f =
          тИл x in R.left..R.right, f (тЖСx + тЖСR.bottom * Complex.I) := by
      unfold bottomHorizontalIntegral
      apply intervalIntegral.integral_congr
      intro x _
      show f тЯиx, R.bottomтЯй = f (тЖСx + тЖСR.bottom * Complex.I)
      rw [Complex.mk_eq_add_mul_I]
    have h_top_eq :
        R.topHorizontalIntegral f =
          -(тИл x in R.left..R.right, f (тЖСx + тЖСR.top * Complex.I)) := by
      unfold topHorizontalIntegral
      rw [intervalIntegral.integral_symm]
      congr 1
      apply intervalIntegral.integral_congr
      intro x _
      show f тЯиx, R.topтЯй = f (тЖСx + тЖСR.top * Complex.I)
      rw [Complex.mk_eq_add_mul_I]
    have h_right_eq :
        R.rightVerticalIntegral f =
          Complex.I тАв (тИл y in R.bottom..R.top, f (тЖСR.right + тЖСy * Complex.I)) := by
      unfold rightVerticalIntegral
      rw [intervalIntegral.integral_mul_const]
      have h_inner :
          (тИл y in R.bottom..R.top, f тЯиR.right, yтЯй) =
            тИл y in R.bottom..R.top, f (тЖСR.right + тЖСy * Complex.I) := by
        apply intervalIntegral.integral_congr
        intro y _
        show f тЯиR.right, yтЯй = f (тЖСR.right + тЖСy * Complex.I)
        rw [Complex.mk_eq_add_mul_I]
      rw [h_inner, smul_eq_mul]
      exact mul_comm _ _
    have h_left_eq :
        R.leftVerticalIntegral f =
          -(Complex.I тАв (тИл y in R.bottom..R.top, f (тЖСR.left + тЖСy * Complex.I))) := by
      unfold leftVerticalIntegral
      rw [intervalIntegral.integral_symm]
      rw [intervalIntegral.integral_mul_const]
      have h_inner :
          (тИл y in R.bottom..R.top, f тЯиR.left, yтЯй) =
            тИл y in R.bottom..R.top, f (тЖСR.left + тЖСy * Complex.I) := by
        apply intervalIntegral.integral_congr
        intro y _
        show f тЯиR.left, yтЯй = f (тЖСR.left + тЖСy * Complex.I)
        rw [Complex.mk_eq_add_mul_I]
      rw [h_inner, smul_eq_mul]
      ring
    -- Assemble
    have h_sum : R.coordinateBoundaryIntegral f =
        (тИл x in R.left..R.right, f (тЖСx + тЖСR.bottom * Complex.I)) -
          (тИл x in R.left..R.right, f (тЖСx + тЖСR.top * Complex.I)) +
          Complex.I тАв (тИл y in R.bottom..R.top, f (тЖСR.right + тЖСy * Complex.I)) -
          Complex.I тАв (тИл y in R.bottom..R.top, f (тЖСR.left + тЖСy * Complex.I)) := by
      unfold coordinateBoundaryIntegral
      rw [h_bot_eq, h_right_eq, h_top_eq, h_left_eq]
      ring
    rw [h_sum]
    exact h_mathlib

/-! ## BD: Four-strip boundary cancellation -/

/-! ### BD0: unconditional global rectangle Cauchy-Goursat bridge -/

/-- The global rectangle Cauchy-Goursat bridge, now unconditional via
`mathlibCauchyGoursatHook`. -/
noncomputable def globalRectangleCauchyGoursatBridge : RectangleCauchyGoursatBridge :=
  RectangleCauchyGoursatBridge.of_mathlibHook mathlibCauchyGoursatHook

/-! ## BT: Cauchy-Goursat closure of the principal-part contour decomposition -/

/-! ### BT1: vanishing of the remainder integral from analyticity -/

/-- If the log-derivative remainder is analytic at every point of the closed
rectangle, then its rectangle boundary integral vanishes (Mathlib
Cauchy-Goursat via the unconditional global bridge). -/
noncomputable def rectangleLogDerivRemainderIntegralVanishes_of_analyticOn
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (hAn : тИА z тИИ {z : тДВ | R.ContainsClosed z},
      AnalyticAt тДВ (R.logDerivRemainder P) z) :
    R.RectangleLogDerivRemainderIntegralVanishes P where
  integral_eq_zero :=
    globalRectangleCauchyGoursatBridge.cauchyGoursat R
      (R.logDerivRemainder P) hAn

/-! ### BT2: analytic-remainder data package -/

/-- The analytic content needed for the remainder: after subtracting all
local principal parts, `╬╢'/╬╢` is analytic at every closed-rectangle point. -/
structure RectangleLogDerivRemainderAnalyticData
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop where
  analytic_remainder :
    тИА z тИИ {z : тДВ | R.ContainsClosed z},
      AnalyticAt тДВ (R.logDerivRemainder P) z

/-- Analytic-remainder data discharges the remainder-vanishing target. -/
noncomputable def RectangleLogDerivRemainderAnalyticData.toVanishes
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleLogDerivRemainderAnalyticData P) :
    R.RectangleLogDerivRemainderIntegralVanishes P :=
  rectangleLogDerivRemainderIntegralVanishes_of_analyticOn A.analytic_remainder

/-! ### BT3: analyticity of remainder closes the contour decomposition -/

/-- **BT3 тАФ UNCONDITIONAL ASSEMBLER:** linearity (BS6) + analyticity of the
remainder (BT2) тЗТ principal-part contour decomposition.  The remainder
analytic-data field is the only outstanding analytic obligation. -/
noncomputable def RectangleLogDerivRemainderAnalyticData.toPrincipalPartContourDecomposition
    {R : ZetaRectangle} {P : R.RectanglePrincipalPartData}
    (A : R.RectangleLogDerivRemainderAnalyticData P) :
    R.RectanglePrincipalPartContourDecomposition P :=
  RectanglePrincipalPartContourDecomposition.of_remainder_vanishes
    (rectangleLogDerivContourLinearDecomposition P) A.toVanishes


/-- Bundles the four strip Cauchy-Goursat facts. -/
structure FourStripCauchyGoursatData
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  topCG : S.topStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  bottomCG : S.bottomStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  leftCG : S.leftStrip.RectangleCauchyGoursat (unitPrincipalKernel a)
  rightCG : S.rightStrip.RectangleCauchyGoursat (unitPrincipalKernel a)

/-- The four strip Cauchy-Goursat facts are now unconditional. -/
theorem fourStripCauchyGoursatData
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) :
    FourStripCauchyGoursatData S where
  topCG :=
    rectangleCauchyGoursat_topStrip_unitKernel globalRectangleCauchyGoursatBridge S
  bottomCG :=
    rectangleCauchyGoursat_bottomStrip_unitKernel globalRectangleCauchyGoursatBridge S
  leftCG :=
    rectangleCauchyGoursat_leftStrip_unitKernel globalRectangleCauchyGoursatBridge S
  rightCG :=
    rectangleCauchyGoursat_rightStrip_unitKernel globalRectangleCauchyGoursatBridge S

/-! ### BD2: boundary-sum identity (target) -/

/-- Algebraic boundary-sum identity: the sum of the four strip boundary
integrals equals the outer rectangle integral minus the inner square integral.

The proof requires expanding each strip integral, splitting at shared interior
edges, and pairwise-cancelling reversed-orientation edge contributions.
Substantial pure-algebra step, left as a target. -/
structure FourStripBoundarySumIdentity
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  sum_eq :
    S.topStrip.unitPrincipalKernelRectangleIntegral a
      + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
      + S.leftStrip.unitPrincipalKernelRectangleIntegral a
      + S.rightStrip.unitPrincipalKernelRectangleIntegral a =
    R.unitPrincipalKernelRectangleIntegral a -
      R.smallSquareUnitKernelIntegral S

/-! ### BD4: four-strip CG + sum identity тЗТ boundary cancellation -/

/-- Combining the four strip Cauchy-Goursat facts with the boundary-sum
identity yields the rectangle-equals-square cancellation. -/
theorem fourStripBoundaryCancellation_of_sumIdentity
    {R : ZetaRectangle} {a : тДВ}
    {S : R.SmallSquareInsideRectangle a}
    (CG : FourStripCauchyGoursatData S)
    (H : FourStripBoundarySumIdentity S) :
    FourStripBoundaryCancellation S where
  rectangle_eq_square := by
    have h_top : S.topStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.topCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_bot : S.bottomStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.bottomCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_left : S.leftStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.leftCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have h_right : S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      have := CG.rightCG.integral_eq_zero
      rwa [rectangleIntegral_unitPrincipalKernel_eq] at this
    have hsum_zero :
        S.topStrip.unitPrincipalKernelRectangleIntegral a
          + S.bottomStrip.unitPrincipalKernelRectangleIntegral a
          + S.leftStrip.unitPrincipalKernelRectangleIntegral a
          + S.rightStrip.unitPrincipalKernelRectangleIntegral a = 0 := by
      rw [h_top, h_bot, h_left, h_right]; ring
    have hsub :
        R.unitPrincipalKernelRectangleIntegral a -
          R.smallSquareUnitKernelIntegral S = 0 := by
      rw [тЖР H.sum_eq]; exact hsum_zero
    exact sub_eq_zero.mp hsub

/-! ### BD5: rectangle-to-square deformation (conditional on sum identity) -/

/-- Once the boundary-sum identity is inhabited, the rectangle-to-square
deformation follows mechanically. -/
noncomputable def unitKernelRectangleToSquareDeformation_of_sumIdentity
    {R : ZetaRectangle} {a : тДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripBoundarySumIdentity S) :
    R.UnitKernelRectangleToSquareDeformation a S :=
  (fourStripBoundaryCancellation_of_sumIdentity
      (fourStripCauchyGoursatData S) H).toRectangleToSquare

/-! ## BE: Coordinate-form boundary cancellation -/

/-! ### BE1: coordinate-form sum identity (target) -/

/-- Coordinate-form four-strip boundary cancellation: in the
`coordinateBoundaryIntegral` form, the sum of strip boundary integrals equals
the outer rectangle integral minus the inner square integral.

This is the pure-algebra step: 16 strip-edge integrals cancel pairwise at
shared interior edges, leaving the outer boundary minus the inner. -/
structure FourStripCoordinateBoundarySumIdentity
    {R : ZetaRectangle} {a : тДВ}
    (S : R.SmallSquareInsideRectangle a) : Prop where
  coordinate_sum_eq :
    S.topStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.bottomStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.leftStrip.coordinateBoundaryIntegral (unitPrincipalKernel a)
      + S.rightStrip.coordinateBoundaryIntegral (unitPrincipalKernel a) =
    R.coordinateBoundaryIntegral (unitPrincipalKernel a)
      - S.toRectangle.coordinateBoundaryIntegral (unitPrincipalKernel a)

/-! ### BE2: coordinate identity тЗТ existing `FourStripBoundarySumIdentity` -/

/-- Conversion: a coordinate-form sum identity inhabits the existing unit-kernel
sum-identity target.  Uses the rectangle-integral / coordinate-integral bridge
for each of the six rectangles involved. -/
theorem FourStripCoordinateBoundarySumIdentity.toBoundarySumIdentity
    {R : ZetaRectangle} {a : тДВ}
    {S : R.SmallSquareInsideRectangle a}
    (H : FourStripCoordinateBoundarySumIdentity S) :
    FourStripBoundarySumIdentity S where
  sum_eq := by
    -- Convert each unit-kernel rectangle integral to coordinate form
    have h_to_coord : тИА (R' : ZetaRectangle),
        R'.unitPrincipalKernelRectangleIntegral a =
          R'.coordinateBoundaryIntegral (unitPrincipalKernel a) := by
      intro R'
      rw [тЖР rectangleIntegral_unitPrincipalKernel_eq]
      exact rectangleIntegral_eq_coordinateBoundaryIntegral
        (rectangleEdgeIntegralCoordinateBridge R' (unitPrincipalKernel a))
    have h_inner :
        R.smallSquareUnitKernelIntegral S =
          S.toRectangle.coordinateBoundaryIntegral (unitPrincipalKernel a) := by
      unfold smallSquareUnitKernelIntegral
      exact h_to_coord S.toRectangle
    rw [h_to_coord S.topStrip, h_to_coord S.bottomStrip,
        h_to_coord S.leftStrip, h_to_coord S.rightStrip,
        h_to_coord R, h_inner]
    exact H.coordinate_sum_eq

