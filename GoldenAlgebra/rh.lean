-- ---------------------------------------------------------------------
-- CLVI: Finite-band model-margin certificate
-- ---------------------------------------------------------------------
-- The smooth density tail bound has a structural floor: ѕБ(T) вЖТ 0 as
-- T вЖТ 2ѕА. No constant `c` (even the sharp 8/5) can close the finite
-- band [2ѕА, TвВА] using density-tail alone. The full model margin
-- `вИТIm(cloud + densityTail)` carries cloud margin that *is* finite at
-- `T = 2ѕА`, so the residual band must be discharged at the model level,
-- typically via an interval-arithmetic / SOS certificate.
--
-- This is the named target where that certificate lands.

/-- **Finite-band model-margin certificate.** Captures the small-`T`
discharge: on the closed interval `[Tmin, Tmax]` (typically `[2ѕА, 140]`
for the (22/15) route or `[2ѕА, 125]` for the sharp (8/5) route) and the
canonical adaptive `A = 2` region, the closed-form `S`-error bound at
`(C, D)` is dominated by `вИТIm(model z)`.

This structure is the named slot for an interval-arithmetic certificate
or SOS proof; nothing in the file claims this is proved. Combining a
`LargeTClosedFormDomination` (large-`T` analytic discharge) with a
`FiniteBandModelMarginCertificate` (small-`T` certified discharge)
gives the full unconditional `hclosed` chain at every `T вЙ• 2ѕА`. -/
structure FiniteBandModelMarginCertificate where
  Tmin : вДЭ
  Tmax : вДЭ
  Tmin_ge_two_pi : 2 * Real.pi вЙ§ Tmin
  Tmin_le_Tmax : Tmin вЙ§ Tmax
  model : вДВ вЖТ вДВ
  C : вДЭ
  D : вДЭ
  cert :
    вИА z : вДВ, вИА T : вДЭ,
      Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ
      0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        closedFormSErrorBoundCD C D z.im T вЙ§ -(model z).im

/-- в≠Р **PROVED вАФ certificate вЯє `ModelMarginLowerBound` at every probe
in the certified band.** Mirrors the per-probe projection used for the
large-`T` route. -/
noncomputable def FiniteBandModelMarginCertificate.atProbe
    (F : FiniteBandModelMarginCertificate)
    (z : вДВ) (T : вДЭ)
    (hTmin : F.Tmin вЙ§ T) (hTmax : T вЙ§ F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

-- ---------------------------------------------------------------------
-- CLVIII: Per-slab S-bound and stitched coverage of [2ѕА, T0]
-- ---------------------------------------------------------------------
-- Python feasibility scan with 50 zeros shows the global Turing-style
-- bound C=1/2, D=49/20 cannot certify slabs below T вЙИ 48, even with
-- arbitrarily many cloud zeros (the cloud margin saturates as ќ£ y/ќ≥_k¬≤
-- converges). The actual S-fluctuation on small slabs is much smaller
-- than the global envelope. Per-slab (C, D) drops the lower edge:
--   (C=1/2, D=49/20) вЖТ feasible from T вЙИ 48
--   (C=1/2, D=1)     вЖТ feasible from T вЙИ 36
--   (C=1/2, D=1/2)   вЖТ feasible from T вЙИ 32
--   (C=0,   D=1)     вЖТ feasible from T вЙИ 19
--   (C=0,   D=1/2)   вЖТ feasible from T вЙИ 14
--   (C=0,   D=1/4)   вЖТ feasible from T вЙИ 10
-- Each `(C, D)` choice must be justified by a slab-specific S bound.

/-- **Single-slab model-margin certificate at per-slab (C, D).**
Identical shape to `FiniteBandModelMarginCertificate`, but emphasises
that each slab in a piecewise covering of `[2ѕА, T0]` may choose its own
`(C, D)` pair backed by a slab-specific S envelope. -/
structure FiniteSlabModelMarginCertificate where
  Tmin : вДЭ
  Tmax : вДЭ
  Tmin_ge_two_pi : 2 * Real.pi вЙ§ Tmin
  Tmin_le_Tmax : Tmin вЙ§ Tmax
  model : вДВ вЖТ вДВ
  C : вДЭ
  D : вДЭ
  cert :
    вИА z : вДВ, вИА T : вДЭ,
      Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ
      0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        closedFormSErrorBoundCD C D z.im T вЙ§ -(model z).im

/-- в≠Р **PROVED вАФ per-probe `ModelMarginLowerBound` from a single slab
certificate.** Same shape as the band-wide projection but works for any
`(C, D)` chosen by the slab. -/
noncomputable def FiniteSlabModelMarginCertificate.atProbe
    (F : FiniteSlabModelMarginCertificate)
    (z : вДВ) (T : вДЭ)
    (hTmin : F.Tmin вЙ§ T) (hTmax : T вЙ§ F.Tmax)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := closedFormSErrorBoundCD F.C F.D z.im T
  lowerBound_le := F.cert z T hTmin hTmax hy hreg

/-- **Piecewise cover of `[Tmin_total, Tmax_total]` by a list of
slab certificates.** The list must be non-overlapping in `T` and cover
the full interval; each slab supplies its own `(C, D)`.

This package isolates the combinatorial "find the right slab for `T`"
step from the analytic content (each slab's `cert`). For the rh.lean
finite-band discharge, the typical instantiation covers `[2ѕА, 140]` with
a handful of slabs, each chosen so the local S envelope is tight. -/
structure PiecewiseFiniteBandCertificate where
  slabs : List FiniteSlabModelMarginCertificate
  model : вДВ вЖТ вДВ
  /-- All slabs share the model under consideration. -/
  model_shared : вИА s вИИ slabs, s.model = model
  Tmin_total : вДЭ
  Tmax_total : вДЭ
  Tmin_ge_two_pi : 2 * Real.pi вЙ§ Tmin_total
  /-- For every probe in the band, some slab covers it. -/
  cover :
    вИА T : вДЭ, Tmin_total вЙ§ T вЖТ T вЙ§ Tmax_total вЖТ
      вИГ s вИИ slabs, s.Tmin вЙ§ T вИІ T вЙ§ s.Tmax

/-- в≠Р **PROVED вАФ piecewise cover вЯє per-probe `ModelMarginLowerBound`.**
For any `T` in the covered band, locate the right slab and apply its
`atProbe`. Both `вИТIm(model z)` bounds (each slab's) translate through
`model_shared`. -/
noncomputable def PiecewiseFiniteBandCertificate.atProbe
    (P : PiecewiseFiniteBandCertificate)
    (z : вДВ) (T : вДЭ)
    (hTmin : P.Tmin_total вЙ§ T) (hTmax : T вЙ§ P.Tmax_total)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    вИГ C D : вДЭ,
      closedFormSErrorBoundCD C D z.im T вЙ§ -(P.model z).im := by
  obtain вЯ®s, hs_mem, hsTmin, hsTmaxвЯ© := P.cover T hTmin hTmax
  refine вЯ®s.C, s.D, ?_вЯ©
  have hmodel : s.model = P.model := P.model_shared s hs_mem
  have h := s.cert z T hsTmin hsTmax hy hreg
  rw [hmodel] at h
  exact h

-- ---------------------------------------------------------------------
-- CLIX-A: Slab-local Turing-style S-bound
-- ---------------------------------------------------------------------
-- The source of per-slab (C, D) pairs. Each `SlabTuringStyleSBound`
-- asserts `|S u| вЙ§ C¬Јlog u + D` on a finite interval `[A, B]`, in
-- contrast to the global `TuringStyleSBound` (defined elsewhere in
-- the file) which asserts the bound on the lower-unbounded tail
-- `u вЙ• some lower`.

/-- **Slab-local Turing-style S-bound.** Asserts that the
zero-counting fluctuation `S(u)` is dominated by `C¬Јlog u + D` on a
compact interval `[A, B]`. Each slab in a `PiecewiseFiniteBandCertificate`
typically chooses its own `(C, D)` justified by such a slab bound. -/
structure SlabTuringStyleSBound where
  S : вДЭ вЖТ вДЭ
  A : вДЭ
  B : вДЭ
  C : вДЭ
  D : вДЭ
  bound :
    вИА u : вДЭ, A вЙ§ u вЖТ u вЙ§ B вЖТ |S u| вЙ§ C * Real.log u + D

-- ---------------------------------------------------------------------
-- CLIX-B: First-zero direct package вАФ N(u) = 0 on [2ѕА, ќ≥вВБ)
-- ---------------------------------------------------------------------
-- For `u < ќ≥вВБ` (first nontrivial Riemann zero, ќ≥вВБ вЙИ 14.13), the
-- zero-counting function satisfies `N(u) = 0`, so `S(u) = -NвВА(u)`
-- is *explicitly known*, not just envelope-bounded. The error
-- contribution from this slab can be evaluated exactly rather than
-- bounded via the generic `closedFormSErrorBoundCD`.

/-- **First-zero gap formula.** Records the structural fact that
`N(u) = 0` on `[2ѕА, ќ≥вВБ)`, hence `S(u) = -NвВА(u)` is concretely
computable on this interval. -/
structure FirstZeroGapSFormula where
  N : вДЭ вЖТ вДЭ
  S : вДЭ вЖТ вДЭ
  NвВА : вДЭ вЖТ вДЭ
  gamma1 : вДЭ
  hgamma1_pos : 0 < gamma1
  noZerosBefore :
    вИА u : вДЭ, 2 * Real.pi вЙ§ u вЖТ u < gamma1 вЖТ N u = 0
  S_eq_neg_N0 :
    вИА u : вДЭ, 2 * Real.pi вЙ§ u вЖТ u < gamma1 вЖТ S u = -(NвВА u)

/-- **First-zero S envelope.** A concrete numerical bound
`|NвВА(u)| вЙ§ D` on `[2ѕА, ќ≥вВБ]`, used to feed `closedFormSErrorBoundCD`
with `(C, D) = (0, D)` in the very small slab.

Python (CLVII findings): on `[2ѕА, 14]`, `|NвВА(u)| вЙ§ вЙИ 0.45` (the value
`|NвВА(ќ≥вВБ)|` just before the first-zero count jumps from 0 to 1). So
`D вЙИ 1/2` is a realistic rigorous choice. -/
structure FirstZeroGapSBound where
  NвВА : вДЭ вЖТ вДЭ
  gamma1 : вДЭ
  D : вДЭ
  bound :
    вИА u : вДЭ, 2 * Real.pi вЙ§ u вЖТ u вЙ§ gamma1 вЖТ |NвВА u| вЙ§ D

/-- **First-zero-band model-margin certificate.** Mirrors
`FiniteSlabModelMarginCertificate` but ties the slab to the first-zero
gap `[Tmin, Tmax] вКЖ [2ѕА, ќ≥вВБ]` and uses a placeholder
`closedFormFirstZeroErrorBound` that is sharper than the generic
`closedFormSErrorBoundCD` because it exploits the known `S = -NвВА`.

For the rh.lean discharge this is the *only* irreducible piece below
the piecewise SDP coverage, since the generic envelope (even with
small `D`) is inflated by the `8 + 18` IBP constants in the closed
form. -/
structure FirstZeroBandCertificate where
  Tmin : вДЭ
  Tmax : вДЭ
  gamma1 : вДЭ
  Tmin_ge_two_pi : 2 * Real.pi вЙ§ Tmin
  Tmin_le_Tmax : Tmin вЙ§ Tmax
  Tmax_le_gamma1 : Tmax вЙ§ gamma1
  model : вДВ вЖТ вДВ
  /-- The sharper error bound exploiting `S = -NвВА` on this slab.
  Left as a function field rather than a hard-coded formula since the
  exact polynomial form depends on the integral evaluation
  technique used. -/
  errorBound : вДЭ вЖТ вДЭ вЖТ вДЭ
  cert :
    вИА z : вДВ, вИА T : вДЭ,
      Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ
      0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z.im T вЙ§ -(model z).im

-- ---------------------------------------------------------------------
-- CLIX-C: Closed-form first-zero error bound
-- ---------------------------------------------------------------------
-- The generic `closedFormSErrorBoundCD 0 D y T = 17¬Јy¬ЈD / T¬≤` bounds the
-- IBP integral over `[T, вИЮ)` using `|k_z'(u)| вЙ§ 18y / u¬≥` and
-- `вИЂ_T^вИЮ du/u¬≥ = 1/(2 T¬≤)`. On the first-zero slab (`Tmin вЙ• 2ѕА`,
-- `Tmax вЙ§ ќ≥вВБ`) the zero-counting fluctuation factors as `S = вИТNвВА` and
-- the *substantive* IBP integral runs only over `[T, ќ≥вВБ]`, since the
-- `[ќ≥вВБ, вИЮ)` tail is folded into the explicit cloud model rather than
-- into the envelope.  The integral becomes
--
--   вИЂ_T^{ќ≥вВБ} |k_z'(u)| ¬Ј D du
--      вЙ§ 18 y D ¬Ј вИЂ_T^{ќ≥вВБ} du / u¬≥
--      = 18 y D ¬Ј (1/(2 T¬≤) вИТ 1/(2 ќ≥вВБ¬≤))
--      = 9 y D / T¬≤  вИТ  9 y D / ќ≥вВБ¬≤,
--
-- saving exactly `9 y D / ќ≥вВБ¬≤` over the generic bound. The closed-form
-- error bound is the algebraic sum
--
--   boundary  +  slabIntegral
--      = 8 y D / T¬≤  +  (9 y D / T¬≤ вИТ 9 y D / ќ≥вВБ¬≤)
--      = 17 y D / T¬≤  вИТ  9 y D / ќ≥вВБ¬≤.

/-- **Closed-form first-zero error bound.** The sharper analogue of
`closedFormSErrorBoundCD 0 D y T` valid on `[T, ќ≥вВБ]`, obtained by
replacing the `вИЂ_T^вИЮ du/u¬≥` integral with `вИЂ_T^{ќ≥вВБ} du/u¬≥`.

Concretely:
  `closedFormFirstZeroErrorBound y T ќ≥вВБ D := 17¬Јy¬ЈD/T¬≤ вИТ 9¬Јy¬ЈD/ќ≥вВБ¬≤`. -/
noncomputable def closedFormFirstZeroErrorBound
    (y T gamma1 D : вДЭ) : вДЭ :=
  17 * y * D / T^2 - 9 * y * D / gamma1^2

/-- в≠Р **PROVED вАФ algebraic equivalence: first-zero bound = generic bound вИТ
ќ≥вВБ-correction.** Makes the "subtract the [ќ≥вВБ,вИЮ) contribution"
interpretation a syntactic identity. -/
theorem closedFormFirstZeroErrorBound_eq_sub
    {T : вДЭ} (hT : T вЙ† 0) (y gamma1 D : вДЭ) :
    closedFormFirstZeroErrorBound y T gamma1 D
      = closedFormSErrorBoundCD 0 D y T - 9 * y * D / gamma1^2 := by
  unfold closedFormFirstZeroErrorBound closedFormSErrorBoundCD
  have hT2 : T^2 вЙ† 0 := pow_ne_zero 2 hT
  field_simp
  ring

/-- в≠Р **PROVED вАФ sharpness: first-zero bound dominates generic bound.**
On non-negative `(y, D)` and `ќ≥вВБ вЙ† 0`, the first-zero bound is at most
the generic bound вАФ by exactly the saving `9¬Јy¬ЈD/ќ≥вВБ¬≤ вЙ• 0`. -/
theorem closedFormFirstZeroErrorBound_le_closedFormSErrorBoundCD_zero
    {T y D gamma1 : вДЭ}
    (hT : T вЙ† 0) (hy : 0 вЙ§ y) (hD : 0 вЙ§ D) (hgamma1 : gamma1 вЙ† 0) :
    closedFormFirstZeroErrorBound y T gamma1 D
      вЙ§ closedFormSErrorBoundCD 0 D y T := by
  rw [closedFormFirstZeroErrorBound_eq_sub hT]
  have hg2 : 0 < gamma1^2 := by positivity
  have h_sav : 0 вЙ§ 9 * y * D / gamma1^2 := by positivity
  linarith

/-- в≠Р **PROVED вАФ closed-form first-zero bound dominates a slab-IBP sum.**
Given closed-form upper bounds on the boundary term (`8 y D / T¬≤`) and on
the slab-restricted integral (`9 y D / T¬≤ вИТ 9 y D / ќ≥вВБ¬≤`), their sum is
вЙ§ `closedFormFirstZeroErrorBound y T ќ≥вВБ D`. This is the algebraic core
of the analytic claim "first-zero IBP envelope вЙ§ closed-form bound";
the actual IBP integral inequalities are produced by CXLIV-CL applied
on `[T, ќ≥вВБ]` instead of `[T, вИЮ)`. -/
theorem slabIBP_sum_le_closedFormFirstZeroErrorBound
    {y T gamma1 D boundaryTerm slabIntegralBound : вДЭ}
    (hbdy : boundaryTerm вЙ§ 8 * y * D / T^2)
    (hslabInt : slabIntegralBound вЙ§ 9 * y * D / T^2 - 9 * y * D / gamma1^2) :
    boundaryTerm + slabIntegralBound
      вЙ§ closedFormFirstZeroErrorBound y T gamma1 D := by
  unfold closedFormFirstZeroErrorBound
  have h_split :
      17 * y * D / T^2 = 8 * y * D / T^2 + 9 * y * D / T^2 := by ring
  linarith

/-- в≠Р **PROVED вАФ first-zero band certificate from a per-probe closed-form
domination.** Wraps the per-probe `closedFormFirstZeroErrorBound вЙ§
вИТIm(model z)` proof (the slab-restricted certificate the
SDP/Schm√Љdgen step produces) into a fully populated
`FirstZeroBandCertificate`. The cover-the-band closure proof is the
identity. -/
noncomputable def FirstZeroBandCertificate.ofClosedFormFirstZero
    (Tmin Tmax gamma1 D : вДЭ)
    (hTmin_ge_two_pi : 2 * Real.pi вЙ§ Tmin)
    (hTmin_le_Tmax : Tmin вЙ§ Tmax)
    (hTmax_le_gamma1 : Tmax вЙ§ gamma1)
    (model : вДВ вЖТ вДВ)
    (hprobe :
      вИА z : вДВ, вИА T : вДЭ,
        Tmin вЙ§ T вЖТ T вЙ§ Tmax вЖТ
        0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
          closedFormFirstZeroErrorBound z.im T gamma1 D вЙ§ -(model z).im) :
    FirstZeroBandCertificate where
  Tmin := Tmin
  Tmax := Tmax
  gamma1 := gamma1
  Tmin_ge_two_pi := hTmin_ge_two_pi
  Tmin_le_Tmax := hTmin_le_Tmax
  Tmax_le_gamma1 := hTmax_le_gamma1
  model := model
  errorBound := fun y T => closedFormFirstZeroErrorBound y T gamma1 D
  cert := hprobe

-- ---------------------------------------------------------------------
-- CLX-A: HasDerivAt + MonotoneOn for smoothZeroCountingN0 on [2ѕА, вИЮ)
-- ---------------------------------------------------------------------

/-- в≠Р **PROVED вАФ `HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u` for
`u > 0`.** The `HasDerivAt`-flavoured version of the existing
`deriv_smoothZeroCountingN0`. Needed to apply
`monotoneOn_of_deriv_nonneg`. -/
theorem hasDerivAt_smoothZeroCountingN0
    {u : вДЭ} (hu : 0 < u) :
    HasDerivAt smoothZeroCountingN0 (zeroDensityRho u) u := by
  have h2pi_pos : (0 : вДЭ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : вДЭ) вЙ† 0 := ne_of_gt h2pi_pos
  have hu_ne : u вЙ† 0 := ne_of_gt hu
  have hq_pos : (0 : вДЭ) < u / (2 * Real.pi) := div_pos hu h2pi_pos
  have hq_ne : u / (2 * Real.pi) вЙ† 0 := ne_of_gt hq_pos
  have h_lin : HasDerivAt (fun u : вДЭ => u / (2 * Real.pi)) (1 / (2 * Real.pi)) u := by
    simpa using (hasDerivAt_id u).div_const (2 * Real.pi)
  have h_log_inner :
      HasDerivAt (fun u : вДЭ => Real.log (u / (2 * Real.pi))) (1 / u) u := by
    have hlog := Real.hasDerivAt_log hq_ne
    have h_comp := hlog.comp u h_lin
    have h_simp : (u / (2 * Real.pi))вБї¬є * (1 / (2 * Real.pi)) = 1 / u := by
      field_simp; ring
    rw [h_simp] at h_comp
    simpa [Function.comp_def] using h_comp
  have h_prod := h_lin.mul h_log_inner
  have h_sub := h_prod.sub h_lin
  have h_final := h_sub.add_const (7 / 8)
  -- Match function form to smoothZeroCountingN0 and simplify derivative.
  have h_func_eq :
      (fun u : вДЭ => (u / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
                    - u / (2 * Real.pi) + 7 / 8)
        = smoothZeroCountingN0 := by
    funext v; rfl
  have h_deriv_eq :
      (1 / (2 * Real.pi)) * Real.log (u / (2 * Real.pi))
        + (u / (2 * Real.pi)) * (1 / u) - 1 / (2 * Real.pi)
      = zeroDensityRho u := by
    unfold zeroDensityRho
    field_simp
    ring
  rw [вЖР h_func_eq, вЖР h_deriv_eq]
  exact h_final

/-- в≠Р **PROVED вАФ `smoothZeroCountingN0` is monotone on `[2ѕА, вИЮ)`.**

Direct from `monotoneOn_of_deriv_nonneg`:
* continuity and differentiability on the interior follow from
  `hasDerivAt_smoothZeroCountingN0`;
* the derivative `zeroDensityRho u` is `вЙ• 0` for `u вЙ• 2ѕА`
  (`zeroDensityRho_nonneg_of_ge_two_pi`). -/
theorem smoothZeroCountingN0_monotoneOn_Ici_two_pi :
    MonotoneOn smoothZeroCountingN0 (Set.Ici (2 * Real.pi)) := by
  apply monotoneOn_of_deriv_nonneg (convex_Ici _)
  ¬Ј intro x hx
    have hx_ge : 2 * Real.pi вЙ§ x := hx
    have hx_pos : 0 < x := lt_of_lt_of_le (by positivity) hx_ge
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).continuousAt.continuousWithinAt
  ¬Ј intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    exact (hasDerivAt_smoothZeroCountingN0 hx_pos).differentiableAt.differentiableWithinAt
  ¬Ј intro x hx
    rw [interior_Ici] at hx
    have hx_2pi : 2 * Real.pi < x := hx
    have hx_pos : 0 < x := lt_trans (by positivity) hx_2pi
    rw [(hasDerivAt_smoothZeroCountingN0 hx_pos).deriv]
    exact zeroDensityRho_nonneg_of_ge_two_pi (le_of_lt hx_2pi)

-- ---------------------------------------------------------------------
-- CLX-B: Endpoint bounds for smoothZeroCountingN0 on [2ѕА, 10]
-- ---------------------------------------------------------------------

/-- в≠Р **PROVED вАФ `smoothZeroCountingN0(2ѕА) = -1/8`.**

Direct evaluation: `NвВА(2ѕА) = 1 ¬Ј log(1) вИТ 1 + 7/8 = -1/8`. -/
theorem smoothZeroCountingN0_at_two_pi :
    smoothZeroCountingN0 (2 * Real.pi) = -(1 / 8) := by
  have h2pi_pos : (0 : вДЭ) < 2 * Real.pi := by positivity
  have h2pi_ne : (2 * Real.pi : вДЭ) вЙ† 0 := ne_of_gt h2pi_pos
  unfold smoothZeroCountingN0
  have h_div_one : (2 * Real.pi) / (2 * Real.pi) = 1 := div_self h2pi_ne
  rw [h_div_one, Real.log_one]
  ring

/-- в≠Р **PROVED вАФ `smoothZeroCountingN0(10) вЙ§ 1/2`.**

Chain: `5/ѕА вЙ• 5/3.15 > 1.58` (since `ѕА < 3.15`), `5/ѕА < 2` (since
`ѕА > 2.5`), so `log(5/ѕА) вЙ§ log 2 вЙ§ 0.7` (Mathlib `Real.log_two_lt_d9`),
giving `NвВА(10) = (5/ѕА)¬Јlog(5/ѕА) вИТ 5/ѕА + 7/8 вЙ§ 1.58¬Ј0.7 вИТ 1.58 + 7/8 вЙИ 0.40 вЙ§ 1/2`. -/
theorem smoothZeroCountingN0_at_10_le_half :
    smoothZeroCountingN0 10 вЙ§ 1 / 2 := by
  unfold smoothZeroCountingN0
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_gt : 3.14 < Real.pi := Real.pi_gt_d2
  -- 10/(2ѕА) = 5/ѕА
  have h_eq : (10 : вДЭ) / (2 * Real.pi) = 5 / Real.pi := by ring
  rw [h_eq]
  have h_5_pi_pos : 0 < 5 / Real.pi := by positivity
  have h_5_pi_nn : 0 вЙ§ 5 / Real.pi := le_of_lt h_5_pi_pos
  -- 5/ѕА > 1.58 (from ѕА < 3.15)
  have h_5_pi_gt : (1.58 : вДЭ) < 5 / Real.pi := by
    rw [lt_div_iffвВА h_pi_pos]; linarith
  -- 5/ѕА < 2 (from ѕА > 5/2)
  have h_5_pi_lt_2 : 5 / Real.pi < 2 := by
    rw [div_lt_iffвВА h_pi_pos]; linarith
  -- log(5/ѕА) вЙ§ log 2
  have h_log_le_log2 : Real.log (5 / Real.pi) вЙ§ Real.log 2 :=
    Real.log_le_log h_5_pi_pos (le_of_lt h_5_pi_lt_2)
  -- log 2 вЙ§ 0.7
  have h_log2_lt : Real.log 2 вЙ§ 0.7 := by
    have := Real.log_two_lt_d9
    linarith
  have h_log_le : Real.log (5 / Real.pi) вЙ§ 0.7 :=
    le_trans h_log_le_log2 h_log2_lt
  -- log(5/ѕА) вЙ• 0 since 5/ѕА вЙ• 1
  have h_5_pi_ge_1 : (1 : вДЭ) вЙ§ 5 / Real.pi := by
    rw [le_div_iffвВА h_pi_pos]; linarith
  have h_log_nn : 0 вЙ§ Real.log (5 / Real.pi) := Real.log_nonneg h_5_pi_ge_1
  -- (5/ѕА)¬Јlog(5/ѕА) вЙ§ (5/ѕА)¬Ј0.7
  have h_mul_le : (5 / Real.pi) * Real.log (5 / Real.pi)
                вЙ§ (5 / Real.pi) * 0.7 :=
    mul_le_mul_of_nonneg_left h_log_le h_5_pi_nn
  -- Combine: closedForm вЙ§ -0.3¬Ј(5/ѕА) + 7/8 вЙ§ 1/2 since 0.3¬Ј(5/ѕА) > 0.474 вЙ• 3/8
  nlinarith [h_mul_le, h_5_pi_gt]

/-- в≠Р **PROVED вАФ `|NвВА(u)| вЙ§ 1/2` for `u вИИ [2ѕА, 10]`.**

By `smoothZeroCountingN0_monotoneOn_Ici_two_pi`:
  `-1/8 = NвВА(2ѕА) вЙ§ NвВА(u) вЙ§ NвВА(10) вЙ§ 1/2`,
so `|NвВА(u)| вЙ§ 1/2`. -/
theorem abs_smoothZeroCountingN0_le_half_on_first_band
    {u : вДЭ} (hlo : 2 * Real.pi вЙ§ u) (hhi : u вЙ§ 10) :
    |smoothZeroCountingN0 u| вЙ§ 1 / 2 := by
  have h_mono := smoothZeroCountingN0_monotoneOn_Ici_two_pi
  have h_2pi_mem : (2 * Real.pi : вДЭ) вИИ Set.Ici (2 * Real.pi) := Set.left_mem_Ici
  have h_u_mem : u вИИ Set.Ici (2 * Real.pi) := Set.mem_Ici.mpr hlo
  have h_10_mem : (10 : вДЭ) вИИ Set.Ici (2 * Real.pi) := by
    rw [Set.mem_Ici]
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_low : smoothZeroCountingN0 (2 * Real.pi) вЙ§ smoothZeroCountingN0 u :=
    h_mono h_2pi_mem h_u_mem hlo
  have h_high : smoothZeroCountingN0 u вЙ§ smoothZeroCountingN0 10 :=
    h_mono h_u_mem h_10_mem hhi
  rw [smoothZeroCountingN0_at_two_pi] at h_low
  have h_high' : smoothZeroCountingN0 u вЙ§ 1 / 2 :=
    le_trans h_high smoothZeroCountingN0_at_10_le_half
  rw [abs_le]
  refine вЯ®?_, h_high'вЯ©
  linarith

-- ---------------------------------------------------------------------
-- CLX-C: FirstZeroCertified вАФ concrete first-zero assumption package
-- ---------------------------------------------------------------------

/-- **First-zero certification.** Bundles `ќ≥вВБ > 10` together with the
no-zero-counted property `N(u) = 0` on `[2ѕА, ќ≥вВБ)`. Numerically `ќ≥вВБ вЙИ
14.13`. -/
structure FirstZeroCertified where
  N : вДЭ вЖТ вДЭ
  gamma1 : вДЭ
  gamma1_gt_10 : 10 < gamma1
  noZerosBelow_gamma1 :
    вИА u : вДЭ, 2 * Real.pi вЙ§ u вЖТ u < gamma1 вЖТ N u = 0

/-- в≠Р **PROVED вАФ `N(u) = 0` on `[2ѕА, 10]` from `FirstZeroCertified`.** -/
theorem FirstZeroCertified.noZeros_on_2pi_10
    (H : FirstZeroCertified)
    {u : вДЭ} (hlo : 2 * Real.pi вЙ§ u) (hhi : u вЙ§ 10) :
    H.N u = 0 :=
  H.noZerosBelow_gamma1 u hlo (lt_of_le_of_lt hhi H.gamma1_gt_10)

/-- в≠Р **PROVED вАФ `S(u) = -NвВА(u)` on `[2ѕА, 10]` from `FirstZeroCertified`,**
since `S(u) = N(u) - NвВА(u)` and `N(u) = 0` there. The caller supplies
the `S = N - NвВА` definition as the `hS` argument. -/
theorem FirstZeroCertified.S_eq_neg_N0_on_2pi_10
    (H : FirstZeroCertified)
    (S : вДЭ вЖТ вДЭ)
    (hS : вИА u : вДЭ, S u = H.N u - smoothZeroCountingN0 u)
    {u : вДЭ} (hlo : 2 * Real.pi вЙ§ u) (hhi : u вЙ§ 10) :
    S u = -(smoothZeroCountingN0 u) := by
  rw [hS u, H.noZeros_on_2pi_10 hlo hhi]
  ring

-- ---------------------------------------------------------------------
-- CLX-D + CLX-E: FirstZeroDirectBandCertificate (slot)
-- ---------------------------------------------------------------------
-- Bypasses the `closedFormSErrorBoundCD` envelope (whose `8 + 18` IBP
-- constants inflate any `D` by ~17√Ч, blocking even `D = 0.125` on
-- `[2ѕА, 10]`). The `errorBound` field is a function `вДВ вЖТ вДЭ` so the
-- closed-form can target a concrete integral against `-NвВА(u)` rather
-- than the generic `(C¬Јlog u + D)`-envelope expression.

/-- **First-zero direct-band model-margin certificate.** A slot for a
sharper error formula on a slab `[A, B] вКЖ [2ѕА, ќ≥вВБ)`. The crucial
difference from `FiniteSlabModelMarginCertificate` is the
function-valued `errorBound : вДВ вЖТ вДЭ`, which can target a concrete
integral expression against `-NвВА(u)` rather than the generic
`(C¬Јlog u + D)`-envelope. -/
structure FirstZeroDirectBandCertificate where
  A : вДЭ
  B : вДЭ
  gamma1 : вДЭ
  A_ge_two_pi : 2 * Real.pi вЙ§ A
  A_le_B : A вЙ§ B
  B_lt_gamma1 : B < gamma1
  model : вДВ вЖТ вДВ
  errorBound : вДВ вЖТ вДЭ
  cert :
    вИА z : вДВ, вИА T : вДЭ,
      A вЙ§ T вЖТ T вЙ§ B вЖТ
      0 < z.im вЖТ 2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        errorBound z вЙ§ -(model z).im

/-- в≠Р **PROVED вАФ `FirstZeroDirectBandCertificate вЯє ModelMarginLowerBound`**
for any probe in the certified slab. Same shape as the per-probe
projections on the other certificate structures. -/
noncomputable def FirstZeroDirectBandCertificate.atProbe
    (F : FirstZeroDirectBandCertificate)
    (z : вДВ) (T : вДЭ)
    (hAT : F.A вЙ§ T) (hTB : T вЙ§ F.B)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := F.errorBound z
  lowerBound_le := F.cert z T hAT hTB hy hreg

