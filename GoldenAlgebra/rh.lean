/-! ### X1тАУX5: derivative continuity for affine edges -/

/-- **X2 bottom.** `HasDerivAt R.bottomEdge ((R.right - R.left : тДВ)) t`. -/
theorem hasDerivAt_bottomEdge (R : ZetaRectangle) (t : тДЭ) :
    HasDerivAt R.bottomEdge (((R.right - R.left : тДЭ) : тДВ)) t := by
  have heq : R.bottomEdge = fun s : тДЭ =>
      ((R.left : тДВ) + (R.bottom : тДВ) * Complex.I)
        + (s : тДВ) * ((R.right - R.left : тДЭ) : тДВ) := by
    funext s
    apply Complex.ext <;> simp [bottomEdge]
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : тДЭ => (s : тДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const ((R.right - R.left : тДЭ) : тДВ)
  have h_add := h_mul.const_add ((R.left : тДВ) + (R.bottom : тДВ) * Complex.I)
  simpa using h_add

/-- **X2 right.** `HasDerivAt R.rightEdge` is `((R.top - R.bottom : тДВ) * I)`. -/
theorem hasDerivAt_rightEdge (R : ZetaRectangle) (t : тДЭ) :
    HasDerivAt R.rightEdge (((R.top - R.bottom : тДЭ) : тДВ) * Complex.I) t := by
  have heq : R.rightEdge = fun s : тДЭ =>
      ((R.right : тДВ) + (R.bottom : тДВ) * Complex.I)
        + (s : тДВ) * (((R.top - R.bottom : тДЭ) : тДВ) * Complex.I) := by
    funext s
    apply Complex.ext <;> simp [rightEdge]
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : тДЭ => (s : тДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (((R.top - R.bottom : тДЭ) : тДВ) * Complex.I)
  have h_add := h_mul.const_add ((R.right : тДВ) + (R.bottom : тДВ) * Complex.I)
  simpa using h_add

/-- **X2 top.** `HasDerivAt R.topEdge` is `-((R.right - R.left : тДВ))`. -/
theorem hasDerivAt_topEdge (R : ZetaRectangle) (t : тДЭ) :
    HasDerivAt R.topEdge (-((R.right - R.left : тДЭ) : тДВ)) t := by
  have heq : R.topEdge = fun s : тДЭ =>
      ((R.right : тДВ) + (R.top : тДВ) * Complex.I)
        + (s : тДВ) * (-((R.right - R.left : тДЭ) : тДВ)) := by
    funext s
    apply Complex.ext <;> simp [topEdge]
    ring
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : тДЭ => (s : тДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (-((R.right - R.left : тДЭ) : тДВ))
  have h_add := h_mul.const_add ((R.right : тДВ) + (R.top : тДВ) * Complex.I)
  simpa using h_add

/-- **X2 left.** `HasDerivAt R.leftEdge` is `-((R.top - R.bottom : тДВ) * I)`. -/
theorem hasDerivAt_leftEdge (R : ZetaRectangle) (t : тДЭ) :
    HasDerivAt R.leftEdge (-(((R.top - R.bottom : тДЭ) : тДВ) * Complex.I)) t := by
  have heq : R.leftEdge = fun s : тДЭ =>
      ((R.left : тДВ) + (R.top : тДВ) * Complex.I)
        + (s : тДВ) * (-(((R.top - R.bottom : тДЭ) : тДВ) * Complex.I)) := by
    funext s
    apply Complex.ext <;> simp [leftEdge]
    ring
  rw [heq]
  have h_ofReal : HasDerivAt (fun s : тДЭ => (s : тДВ)) 1 t := by
    have := Complex.ofRealCLM.hasDerivAt (x := t)
    simpa using this
  have h_mul := h_ofReal.mul_const (-(((R.top - R.bottom : тДЭ) : тДВ) * Complex.I))
  have h_add := h_mul.const_add ((R.left : тДВ) + (R.top : тДВ) * Complex.I)
  simpa using h_add

/-- Closed-form derivative of the bottom edge. -/
theorem deriv_bottomEdge (R : ZetaRectangle) (t : тДЭ) :
    deriv R.bottomEdge t = ((R.right - R.left : тДЭ) : тДВ) :=
  (R.hasDerivAt_bottomEdge t).deriv

/-- Closed-form derivative of the right edge. -/
theorem deriv_rightEdge (R : ZetaRectangle) (t : тДЭ) :
    deriv R.rightEdge t = ((R.top - R.bottom : тДЭ) : тДВ) * Complex.I :=
  (R.hasDerivAt_rightEdge t).deriv

/-- Closed-form derivative of the top edge. -/
theorem deriv_topEdge (R : ZetaRectangle) (t : тДЭ) :
    deriv R.topEdge t = -((R.right - R.left : тДЭ) : тДВ) :=
  (R.hasDerivAt_topEdge t).deriv

/-- Closed-form derivative of the left edge. -/
theorem deriv_leftEdge (R : ZetaRectangle) (t : тДЭ) :
    deriv R.leftEdge t = -(((R.top - R.bottom : тДЭ) : тДВ) * Complex.I) :=
  (R.hasDerivAt_leftEdge t).deriv

/-- **X3.** Derivative-continuity package for the four affine edges. -/
theorem ZetaRectangleEdgeDerivContinuous.of_affine_edges
    (R : ZetaRectangle) :
    R.ZetaRectangleEdgeDerivContinuous where
  bottom := by
    rw [show (fun t : тДЭ => deriv R.bottomEdge t)
          = fun _ : тДЭ => ((R.right - R.left : тДЭ) : тДВ) from
        funext fun t => R.deriv_bottomEdge t]
    exact continuousOn_const
  right := by
    rw [show (fun t : тДЭ => deriv R.rightEdge t)
          = fun _ : тДЭ => ((R.top - R.bottom : тДЭ) : тДВ) * Complex.I from
        funext fun t => R.deriv_rightEdge t]
    exact continuousOn_const
  top := by
    rw [show (fun t : тДЭ => deriv R.topEdge t)
          = fun _ : тДЭ => -((R.right - R.left : тДЭ) : тДВ) from
        funext fun t => R.deriv_topEdge t]
    exact continuousOn_const
  left := by
    rw [show (fun t : тДЭ => deriv R.leftEdge t)
          = fun _ : тДЭ => -(((R.top - R.bottom : тДЭ) : тДВ) * Complex.I) from
        funext fun t => R.deriv_leftEdge t]
    exact continuousOn_const

/-- **X4.** A strongly admissible zeta rectangle has interval-integrable
log-derivative integrands on all four edges. -/
theorem ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleLogDerivIntegrable :=
  ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible hAdm
    (ZetaRectangleEdgeDerivContinuous.of_affine_edges R)

/-- **X5.** A strongly admissible zeta rectangle is ready for the
logarithmic-derivative contour integral. -/
theorem ZetaRectangleContourIntegralReady.of_stronglyAdmissible
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta) :
    R.ZetaRectangleContourIntegralReady where
  stronglyAdmissible := hAdm
  integrable := ZetaRectangleLogDerivIntegrable.of_stronglyAdmissible_affine hAdm

/-! ### Y1тАУY5: argument-principle theorem target -/

/-- **Y1.** The exact analytic theorem needed from the argument
principle for `riemannZeta` on a strongly admissible rectangle.  Not
asserted to be inhabited; future Mathlib argument-principle work must
construct an inhabitant. -/
structure ZetaRectangleArgumentPrincipleTheorem
    (R : ZetaRectangle)
    (hleft : R.left < 0)
    (hright : 1 < R.right)
    (hbottom_nonneg : 0 тЙд R.bottom)
    (hgood : GoodHeight R.top) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  argumentIndex : тДд
  normalizedIntegral_eq_index :
    R.normalizedRectangleLogDerivIntegral = (argumentIndex : тДВ)
  formula :
    (R.weightedZeroCountInside
        (R.zeroSetInsideOfSlab hleft hright hgood
          (R.canonicalSlabZeroSet hbottom_nonneg))
        zetaGlobalZeroMultiplicity : тДд)
      -
    (R.poleCountInside : тДд)
      =
    argumentIndex

/-- **Y2.** The argument-principle theorem target produces actual
normalized argument-principle data. -/
noncomputable def ZetaRectangleArgumentPrincipleTheorem.toActualNormalizedData
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 тЙд R.bottom}
    {hgood : GoodHeight R.top}
