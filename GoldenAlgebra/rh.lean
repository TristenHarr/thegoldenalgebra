-- ┬зCCXLI. `zeroDensityRho` smooth-tail UHP integrability + concrete data
-- =====================================================================
-- Final piece needed to fully discharge `SmoothDensityTailModelData` for
-- `zeroDensityRho`: continuity-based interval integrability of the
-- integrand `(zeroDensityRho u : тДВ) ┬╖ (1/(z-u) + 1/(z+u))` on `[T, X]`
-- for UHP `z`, then composition with ┬зCCXL's UHP majorant chain.
--
-- Adds:
--   complex_sub_real_ne_zero_of_im_pos
--   complex_add_real_ne_zero_of_im_pos
--   continuous_pairedCauchyKernel_u_of_im_pos
--   zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
--   smoothDensityTailModelData_zeroDensityRho

/-- тнР **PROVED тАФ `z - (u : тДВ) тЙа 0` when `0 < z.im`.** -/
lemma complex_sub_real_ne_zero_of_im_pos
    {z : тДВ} (hz : 0 < z.im) (u : тДЭ) :
    z - (u : тДВ) тЙа 0 := by
  intro h
  have him : (z - (u : тДВ)).im = 0 := by rw [h]; rfl
  have him' : (z - (u : тДВ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- тнР **PROVED тАФ `z + (u : тДВ) тЙа 0` when `0 < z.im`.** -/
lemma complex_add_real_ne_zero_of_im_pos
    {z : тДВ} (hz : 0 < z.im) (u : тДЭ) :
    z + (u : тДВ) тЙа 0 := by
  intro h
  have him : (z + (u : тДВ)).im = 0 := by rw [h]; rfl
  have him' : (z + (u : тДВ)).im = z.im := by simp
  rw [him'] at him
  linarith

/-- ЁЯМЯЁЯМЯ **PROVED тАФ paired Cauchy kernel continuous in `u` for UHP `z`.**
For `0 < z.im`, the map `u тЖж 1/(z - u) + 1/(z + u)` is continuous on тДЭ,
since both denominators are non-vanishing. -/
lemma continuous_pairedCauchyKernel_u_of_im_pos
    {z : тДВ} (hz : 0 < z.im) :
    Continuous fun u : тДЭ =>
      (1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)) := by
  refine Continuous.add ?_ ?_
  ┬╖ apply Continuous.divтВА continuous_const
    ┬╖ exact continuous_const.sub Complex.continuous_ofReal
    ┬╖ intro u
      exact complex_sub_real_ne_zero_of_im_pos hz u
  ┬╖ apply Continuous.divтВА continuous_const
    ┬╖ exact continuous_const.add Complex.continuous_ofReal
    ┬╖ intro u
      exact complex_add_real_ne_zero_of_im_pos hz u

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ UHP interval integrability of
`zeroDensityRho ├Ч paired Cauchy kernel`.** For `0 < T тЙд X` and
`0 < z.im`, the integrand is continuous on `[T, X]` (both factors
continuous + denominators non-vanishing), hence interval-integrable. -/
theorem zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
    (T X : тДЭ) {z : тДВ}
    (hTpos : 0 < T) (hTX : T тЙд X) (hz : 0 < z.im) :
    IntervalIntegrable
      (fun u =>
        (zeroDensityRho u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
      MeasureTheory.volume T X := by
  -- ╧Б continuous on Icc T X (subset of Ioi 0)
  have h╧Б_real : ContinuousOn zeroDensityRho (Set.Icc T X) := by
    apply Phase1IBP.zeroDensityRho_continuousOn_Ioi.mono
    intro u hu
    exact lt_of_lt_of_le hTpos hu.1
  have h╧Б : ContinuousOn (fun u : тДЭ => (zeroDensityRho u : тДВ))
      (Set.Icc T X) :=
    Complex.continuous_ofReal.comp_continuousOn h╧Б_real
  -- Kernel continuous on UHP for fixed z
  have hk : ContinuousOn
      (fun u : тДЭ =>
        (1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ)))
      (Set.Icc T X) :=
    (continuous_pairedCauchyKernel_u_of_im_pos hz).continuousOn
  have hprod : ContinuousOn
      (fun u =>
        (zeroDensityRho u : тДВ) *
          ((1 : тДВ) / (z - (u : тДВ)) + (1 : тДВ) / (z + (u : тДВ))))
      (Set.Icc T X) :=
    h╧Б.mul hk
  exact ContinuousOn.intervalIntegrable_of_Icc hTX hprod

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `SmoothDensityTailModelData` for the concrete
`zeroDensityRho` density.** Given `T тЙе 2╧А`, produces a full
`SmoothDensityTailModelData` by composing ┬зCCXLI's integrability
discharger with ┬зCCXL's UHP majorant chain and ┬зCCXXXIX's log-growth
bound. -/
noncomputable def smoothDensityTailModelData_zeroDensityRho
    (T : тДЭ) (hT_ge : 2 * Real.pi тЙд T) :
    SmoothDensityTailModelData := by
  have hTpos : 0 < T := by
    have hpi : (0 : тДЭ) < 2 * Real.pi := by positivity
    exact lt_of_lt_of_le hpi hT_ge
  have h2pi_inv_nn : (0 : тДЭ) тЙд 1 / (2 * Real.pi) := by positivity
  exact smoothDensityTailModelData_of_majorant_nonneg_UHP
    zeroDensityRho T
    (fun u hTu =>
      zeroDensityRho_nonneg_of_ge_two_pi (le_trans hT_ge hTu))
    (smoothDensityTailMajorantDataUHP_of_logGrowth
      zeroDensityRho T
      (1 / (2 * Real.pi)) 0
      h2pi_inv_nn le_rfl hTpos
      zeroDensityRho_log_growth_eventually
      (fun z X hz hTX =>
        zeroDensityRho_pairedCauchyKernel_intervalIntegrable_UHP
          T X hTpos hTX hz))

