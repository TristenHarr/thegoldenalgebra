theorem EntireXiHadamardPrefactor.exp_affine
    {C a b : тДВ} (hC : C тЙа 0) :
    EntireXiHadamardPrefactor
      (fun s : тДВ => C * Complex.exp (a + b * s)) := by
  refine
    { differentiable_at_nonzero := ?_
      nonzero_at_nonzero := ?_ }
  ┬╖ intro s _hs
    have h_aff : DifferentiableAt тДВ (fun s : тДВ => a + b * s) s :=
