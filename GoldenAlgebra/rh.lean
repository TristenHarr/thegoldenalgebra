      XiPullback z вЙ† 0 вЖТ
      (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
        2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L вЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- рЯУ¶ **`StieltjesHighTailEqualityAFZ`** вАФ AFZ Stieltjes equality
in the HIGH band (`T вЙ• 140`). -/
structure StieltjesHighTailEqualityAFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (ZC : вДВ вЖТ вДВ) : Prop where
