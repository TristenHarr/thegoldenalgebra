/-! ### CW13: geometric zero-discreteness anchor -/

/-- Discreteness of zeta zero heights: immediately to the right of any
height `T тЙе 140`, there are no new ╬╢-zero heights.  Geometric reason
behind right-local-constancy of the zero-counting function.  Anchor
only тАФ turning it into `ZetaWeightedZeroCountRightLocalConstancyInput`
requires unfolding certificate-based count machinery and is deferred. -/
structure ZetaZeroHeightRightGapInput : Prop where
  exists_gap :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      тИГ ╬╡ : тДЭ, 0 < ╬╡ тИз
        тИА ╧Б : тДВ,
          riemannZeta ╧Б = 0 тЖТ
          T < ╧Б.im тЖТ
          ╧Б.im тЙд T + ╬╡ тЖТ
          False

/-! ### CW13: discharge of the horizontal ╬╢ bound via compactness -/

/-- Convenience: scale an unscaled uniform bound `тАЦ╬╢(╧Г + iT)тАЦ тЙд C` (on
`╧Г тИИ [-1, 2]`) to the form required by `BacklundHorizontalBoundaryEstimate`,
namely `тАЦ╬╢(╧Г + iT)тАЦ тЙд C┬╖(T + 1)`.  The factor `T + 1` is `тЙе 1` because
`T тЙе 140`. -/
theorem BacklundHorizontalBoundaryEstimate.of_abs_bound
    {T C : тДЭ}
    (hT : (140 : тДЭ) тЙд T)
    (hC : 0 тЙд C)
    (hbound :
      тИА ╧Г : тДЭ, (-1 : тДЭ) тЙд ╧Г тЖТ ╧Г тЙд 2 тЖТ
        тАЦriemannZeta ((╧Г : тДВ) + (T : тДВ) * Complex.I)тАЦ тЙд C) :
    BacklundHorizontalBoundaryEstimate T := by
  refine тЯиC, hC, ?_тЯй
  intro ╧Г h╧ГтВБ h╧ГтВВ
  have hTp1 : (1 : тДЭ) тЙд T + 1 := by linarith
  have hCmul : C тЙд C * (T + 1) := by nlinarith
  exact le_trans (hbound ╧Г h╧ГтВБ h╧ГтВВ) hCmul

/-- **CW13 тАФ `BacklundHorizontalZetaBoundInput` DISCHARGED.**

For every `T тЙе 140`, the function `╧Г тЖж тАЦ╬╢(╧Г + iT)тАЦ` is continuous on `тДЭ`
(since `╧Г + iT тЙа 1` for any real `╧Г` when `T тЙе 140 > 0`), so attains a
maximum on the compact interval `[-1, 2]`; that maximum supplies the
horizontal bound constant. -/
theorem backlundHorizontalZetaBoundInput :
    BacklundHorizontalZetaBoundInput where
  bound := by
    intro T _hgood hT
    have hT_pos : (0 : тДЭ) < T :=
      lt_of_lt_of_le (by norm_num : (0 : тДЭ) < 140) hT
    have hne : тИА ╧Г : тДЭ,
        ((╧Г : тДВ) + (T : тДВ) * Complex.I) тЙа 1 := by
      intro ╧Г heq
      have h_im :
          ((╧Г : тДВ) + (T : тДВ) * Complex.I).im = T := by simp
      rw [heq, Complex.one_im] at h_im
      linarith
    have hline_cont :
        Continuous (fun ╧Г : тДЭ => (╧Г : тДВ) + (T : тДВ) * Complex.I) :=
      Complex.continuous_ofReal.add continuous_const
    have hzeta_cont :
        Continuous (fun ╧Г : тДЭ =>
            riemannZeta ((╧Г : тДВ) + (T : тДВ) * Complex.I)) := by
      refine continuous_iff_continuousAt.mpr (fun ╧Г => ?_)
      change ContinuousAt
        (riemannZeta тИШ (fun ╧Г' : тДЭ => (╧Г' : тДВ) + (T : тДВ) * Complex.I)) ╧Г
      refine ContinuousAt.comp ?_ hline_cont.continuousAt
      exact (differentiableAt_riemannZeta (hne ╧Г)).continuousAt
    have hnorm_cont :
        Continuous (fun ╧Г : тДЭ =>
            тАЦriemannZeta ((╧Г : тДВ) + (T : тДВ) * Complex.I)тАЦ) :=
      continuous_norm.comp hzeta_cont
    have hnonempty : (Set.Icc (-1 : тДЭ) 2).Nonempty :=
      тЯи0, by norm_numтЯй
    obtain тЯи╧ГтВА, _h╧ГтВАmem, h╧ГтВАmaxтЯй :=
      (isCompact_Icc (a := (-1 : тДЭ)) (b := 2)).exists_isMaxOn hnonempty
        hnorm_cont.continuousOn
    set C : тДЭ :=
      тАЦriemannZeta ((╧ГтВА : тДВ) + (T : тДВ) * Complex.I)тАЦ with hC_def
    have hC_nonneg : (0 : тДЭ) тЙд C := norm_nonneg _
    refine BacklundHorizontalBoundaryEstimate.of_abs_bound hT hC_nonneg ?_
    intro ╧Г h╧ГтВБ h╧ГтВВ
    exact h╧ГтВАmax тЯиh╧ГтВБ, h╧ГтВВтЯй

/-! ### CW14: big reduction pass over the remaining analytic obligations -/

/-- Nonvanishing of `╬╢` along Backlund's right vertical side `Re s = 2`,
on every short window `[T, T + 1]` for `T тЙе 140`. -/
structure ZetaNonzeroOnBacklundRightSideInput : Prop where
  nonzero :
    тИА T y : тДЭ,
      (140 : тДЭ) тЙд T тЖТ T тЙд y тЖТ y тЙд T + 1 тЖТ
        riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 0

/-- **CW14 тАФ `ZetaNonzeroOnBacklundRightSideInput` DISCHARGED.**
Follows from `riemannZeta_ne_zero_of_one_lt_re` since `Re(2 + iy) = 2 > 1`. -/
theorem zetaNonzeroOnBacklundRightSideInput :
    ZetaNonzeroOnBacklundRightSideInput where
  nonzero := by
    intro T y _hT _hyT _hyT1
    have hre : ((2 : тДВ) + (y : тДВ) * Complex.I).re = 2 := by
      simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
            Complex.ofReal_re, Complex.ofReal_im]
    exact riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)

/-- Plain (unscaled) compact bound on the zeta logarithmic derivative on
the right-side window.  Strictly weaker than the `log(T+2)`-scaled form
used in `BacklundRightSideArgumentVariationEstimate`; can be lifted to
the scaled form by dividing the existential constant. -/
structure ZetaLogDerivPlainBoundOnBacklundRightSideInput : Prop where
  bound :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      тИГ C : тДЭ, 0 тЙд C тИз
        тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
          тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
              riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд C

/-- Convenience: lift a plain bound `тАЦlogDerivтАЦ тЙд C` to the scaled form
`тАЦlogDerivтАЦ тЙд (C/log(T+2))┬╖log(T+2) = C` required by
`BacklundRightSideArgumentVariationEstimate`. -/
theorem BacklundRightSideArgumentVariationEstimate.of_abs_logDeriv_bound'
    {T C : тДЭ}
    (hT : (140 : тДЭ) тЙд T)
    (hnonzero :
      тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
        riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 0)
    (hC : 0 тЙд C)
    (hbound :
      тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
        тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
            riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд C) :
    BacklundRightSideArgumentVariationEstimate T := by
  have hlogpos : 0 < Real.log (T + 2) := Real.log_pos (by linarith)
  have hlogne : Real.log (T + 2) тЙа 0 := ne_of_gt hlogpos
  refine BacklundRightSideArgumentVariationEstimate.of_logDeriv_bound
    hnonzero (div_nonneg hC hlogpos.le) ?_
  intro y hyT hyT1
  have hb := hbound y hyT hyT1
  have hmul :
      C / Real.log (T + 2) * Real.log (T + 2) = C :=
    div_mul_cancelтВА C hlogne
  rw [hmul]; exact hb

/-- Bridge: nonvanishing + plain compact log-derivative bound supply the
right-side argument-variation input. -/
noncomputable def BacklundRightSideArgumentVariationInput.of_nonzero_and_plainLogDeriv
    (NZ : ZetaNonzeroOnBacklundRightSideInput)
    (LD : ZetaLogDerivPlainBoundOnBacklundRightSideInput) :
    BacklundRightSideArgumentVariationInput where
  bound := by
    intro T _hgood hT
    rcases LD.bound T hT with тЯиC, hC, hboundтЯй
    exact BacklundRightSideArgumentVariationEstimate.of_abs_logDeriv_bound'
      hT
      (fun y hyT hyT1 => NZ.nonzero T y hT hyT hyT1)
      hC hbound

/-- Finite-window form of the Jensen input.  Weaker than the classical
sharp Backlund estimate but enough for the existential-constant
`BacklundJensenRectangleEstimate`. -/
structure ZetaCountWindowFiniteInput : Prop where
  finite_window_bound :
    тИА T : тДЭ, (140 : тДЭ) тЙд T тЖТ
      тИГ M : тДЭ, 0 тЙд M тИз
        zetaWeightedZeroCountUpToHeightReal (T + 1)
          - zetaWeightedZeroCountUpToHeightReal T тЙд M

/-- Bridge: finite window тЖТ Jensen via division by `log(T + 2)`. -/
noncomputable def BacklundJensenRectangleInput.of_finite_window
    (F : ZetaCountWindowFiniteInput) :
    BacklundJensenRectangleInput where
  bound := by
    intro T _hgood hT
    rcases F.finite_window_bound T hT with тЯиM, hM, hboundтЯй
    have hlogpos : 0 < Real.log (T + 2) := Real.log_pos (by linarith)
    have hlogne : Real.log (T + 2) тЙа 0 := ne_of_gt hlogpos
    refine BacklundJensenRectangleEstimate.of_window_bound
      (div_nonneg hM hlogpos.le) ?_
    have hmul :
        M / Real.log (T + 2) * Real.log (T + 2) = M :=
      div_mul_cancelтВА M hlogne
    calc zetaWeightedZeroCountUpToHeightReal (T + 1)
            - zetaWeightedZeroCountUpToHeightReal T
          тЙд M := hbound
        _ = M / Real.log (T + 2) * Real.log (T + 2) := hmul.symm

/-- **CW14 тАФ `ZetaCountWindowFiniteInput` DISCHARGED.**  Choose
`M = max(count(T+1) тИТ count(T), 0)`. -/
noncomputable def zetaCountWindowFiniteInput :
    ZetaCountWindowFiniteInput where
  finite_window_bound := by
    intro T _hT
    refine тЯиmax
      (zetaWeightedZeroCountUpToHeightReal (T + 1)
        - zetaWeightedZeroCountUpToHeightReal T) 0,
      le_max_right _ _, ?_тЯй
    exact le_max_left _ _

/-- Reduced Backlund analytic inputs: horizontal bound is now proved
(CW13); Jensen is discharged from the trivial count-window finiteness
input; right-side is split into nonvanishing (discharged in CW14) plus
the plain log-derivative compactness input.  Only `rightLogDerivPlain`
and `combination` survive as analytic obligations. -/
structure BacklundReducedAnalyticInputs : Prop where
  countWindowFinite : ZetaCountWindowFiniteInput
  rightNonzero : ZetaNonzeroOnBacklundRightSideInput
  rightLogDerivPlain : ZetaLogDerivPlainBoundOnBacklundRightSideInput
  combination : BacklundClassicalCombinationInput

/-- Bridge: reduced тЖТ V2. -/
noncomputable def BacklundReducedAnalyticInputs.toSeparatedV2
    (I : BacklundReducedAnalyticInputs) :
    BacklundSeparatedAnalyticInputsV2 where
  jensen := BacklundJensenRectangleInput.of_finite_window I.countWindowFinite
  rightSide :=
    BacklundRightSideArgumentVariationInput.of_nonzero_and_plainLogDeriv
      I.rightNonzero I.rightLogDerivPlain
  horizontal := backlundHorizontalZetaBoundInput
  combination := I.combination

/-- **CW14 тАФ final theorem from reduced inputs + LC.**  After CW14, the
genuine open obligations are only `combination`, `rightLogDerivPlain`,
and `LC`; the two trivially-discharged fields (`countWindowFinite`,
`rightNonzero`) can be supplied unconditionally. -/
theorem concreteS_halfLogPlusHalf_of_reducedBacklund_and_countLC
    (I : BacklundReducedAnalyticInputs)
    (LC : ZetaWeightedZeroCountRightLocalConstancyInput)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
  concreteS_halfLogPlusHalf_of_separatedBacklund_and_countLC
    I.toSeparatedV2.toSeparatedInputs LC hT

/-! ### CW15: discharge `rightLogDerivPlain` via compactness + analyticity -/

/-- Compactness wrapper: if `y тЖж тАЦ(deriv ╬╢ / ╬╢)(2 + iy)тАЦ` is continuous
on `[T, T + 1]`, then it is bounded there. -/
theorem exists_bound_zeta_logDeriv_rightSide_of_continuousOn
    (T : тДЭ)
    (hcont :
      ContinuousOn
        (fun y : тДЭ =>
          тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
              riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ)
        (Set.Icc T (T + 1))) :
    тИГ C : тДЭ, 0 тЙд C тИз
      тИА y : тДЭ, T тЙд y тЖТ y тЙд T + 1 тЖТ
        тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
            riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд C := by
  have hcomp : IsCompact (Set.Icc T (T + 1)) := isCompact_Icc
  have hne : (Set.Icc T (T + 1)).Nonempty :=
    Set.nonempty_Icc.mpr (by linarith)
  obtain тЯиyтВА, _hyтВАmem, hyтВАmaxтЯй :=
    hcomp.exists_isMaxOn hne hcont
  set M : тДЭ :=
    тАЦderiv riemannZeta ((2 : тДВ) + (yтВА : тДВ) * Complex.I) /
        riemannZeta ((2 : тДВ) + (yтВА : тДВ) * Complex.I)тАЦ with hM_def
  refine тЯиmax M 0, le_max_right _ _, ?_тЯй
  intro y hyT hyT1
  have hmem : y тИИ Set.Icc T (T + 1) := тЯиhyT, hyT1тЯй
  have hle :
      тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
          riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ тЙд M :=
    hyтВАmax hmem
  exact le_trans hle (le_max_left _ _)

/-- For every `T тЙе 140`, the function `y тЖж тАЦ(deriv ╬╢ / ╬╢)(2 + iy)тАЦ` is
continuous on `[T, T + 1]`.  Uses analyticity of `╬╢` away from `1`
(`riemannZeta_analyticAt_of_ne_one`), the derived continuity of
`deriv ╬╢`, and the nonvanishing of `╬╢` on `Re s = 2`. -/
theorem continuousOn_zeta_logDeriv_rightSide
    (T : тДЭ) (_hT : (140 : тДЭ) тЙд T) :
    ContinuousOn
      (fun y : тДЭ =>
        тАЦderiv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
            riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)тАЦ)
      (Set.Icc T (T + 1)) := by
  intro y _hy
  refine ContinuousAt.continuousWithinAt ?_
  -- Re(2 + iy) = 2.
  have hre :
      ((2 : тДВ) + (y : тДВ) * Complex.I).re = 2 := by
    simp [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im,
          Complex.ofReal_re, Complex.ofReal_im]
  have hne : ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 1 := by
    intro heq
    have h1re : ((1 : тДВ).re) = 2 := by rw [тЖР hre, heq]
    norm_num at h1re
  have hzeta_ne :
      riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) тЙа 0 :=
    riemannZeta_ne_zero_of_one_lt_re (by rw [hre]; norm_num)
  have hAn :
      AnalyticAt тДВ riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) :=
    riemannZeta_analyticAt_of_ne_one hne
  -- Continuity of `z тЖж (deriv ╬╢ / ╬╢) z` at 2 + iy.
  have hquot_at :
      ContinuousAt
        (fun z : тДВ => deriv riemannZeta z / riemannZeta z)
        ((2 : тДВ) + (y : тДВ) * Complex.I) :=
    (hAn.deriv.continuousAt).div hAn.continuousAt hzeta_ne
  -- Line y тЖж 2 + iy is continuous.
  have hline_cont :
      Continuous (fun y : тДЭ => (2 : тДВ) + (y : тДВ) * Complex.I) :=
    continuous_const.add
      (Complex.continuous_ofReal.mul continuous_const)
  -- Compose into a real тЖТ тДВ function and take norm.
  have hcompose_at :
      ContinuousAt
        (fun y : тДЭ =>
          deriv riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I) /
            riemannZeta ((2 : тДВ) + (y : тДВ) * Complex.I)) y := by
    change ContinuousAt
      ((fun z : тДВ => deriv riemannZeta z / riemannZeta z) тИШ
        (fun y : тДЭ => (2 : тДВ) + (y : тДВ) * Complex.I)) y
    refine ContinuousAt.comp ?_ hline_cont.continuousAt
    exact hquot_at
  exact hcompose_at.norm

