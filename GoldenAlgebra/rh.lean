-- ┬зCCXCIII-A. `HlowArith_norm` cloud lower bound
-- =====================================================================
-- On `lowCompactRegion`, `x┬▓ + y┬▓ тЙд 16` (from `|x| + y тЙд 4`), so each
-- normalized cloud term `2/(x┬▓+╬│┬▓+y┬▓) тЙе 2/(╬│┬▓+16)`. Summing over
-- `zeros100ceil` gives the uniform lower bound
--   `cloudLBConst := ╬г_{╬│ тИИ zeros100ceil} 2/(╬│┬▓+16) тЙИ 0.0370`.
-- Cloud alone is insufficient (`C тЙИ 0.0473`, gap тЙИ -0.0103). The
-- smooth lower bound (┬зCCXCIII-B, separate section) supplies the
-- additional тЙИ 0.0125 to close with margin тЙИ 0.0024.

/-- тнР **PROVED тАФ `x┬▓ + y┬▓ тЙд 16` on the low compact region.** Follows
from `(|x| + y)┬▓ тЙд 16` and dropping the non-negative cross term `2|x|y`. -/
lemma lowCompactRegion_sq_re_add_sq_im_le_16
    {z : тДВ} (hz : lowCompactRegion z) :
    z.re ^ 2 + z.im ^ 2 тЙд 16 := by
  have hy : 0 < z.im := hz.1
  have h_sum : 2 * (1 + |z.re| + z.im) тЙд 10 := hz.2
  have h_xy : |z.re| + z.im тЙд 4 := by linarith
  have h_abs_nn : (0 : тДЭ) тЙд |z.re| := abs_nonneg _
  have h_y_nn : (0 : тДЭ) тЙд z.im := le_of_lt hy
  have h_sq_re : z.re ^ 2 = |z.re| ^ 2 := (sq_abs z.re).symm
  rw [h_sq_re]
  nlinarith [sq_nonneg (|z.re| + z.im), h_abs_nn, h_y_nn, h_xy,
             mul_nonneg h_abs_nn h_y_nn]

/-- тнР **PROVED тАФ generic pointwise list sum bound.** -/
lemma list_sum_le_sum_of_pointwise
    {╬▒ : Type*} {L : List ╬▒} {f g : ╬▒ тЖТ тДЭ}
    (h : тИА a тИИ L, f a тЙд g a) :
    (L.map f).sum тЙд (L.map g).sum := by
  induction L with
  | nil => simp
  | cons a rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_a : f a тЙд g a := h a (by simp)
    have h_rest : тИА b тИИ rest, f b тЙд g b :=
      fun b hb => h b (List.mem_cons_of_mem a hb)
    have h_rest_le := ih h_rest
    linarith

/-- тнР **PROVED тАФ per-zero cloud lower bound.** -/
lemma simpleCloudSumNorm_term_lower
    {x y ╬│ : тДЭ} (hxy : x ^ 2 + y ^ 2 тЙд 16) (hy : 0 < y) :
    (2 : тДЭ) / (╬│ ^ 2 + 16) тЙд 2 / (x ^ 2 + ╬│ ^ 2 + y ^ 2) := by
  have h_xsq_nn : (0 : тДЭ) тЙд x ^ 2 := sq_nonneg x
  have h_ysq_pos : (0 : тДЭ) < y ^ 2 := by positivity
  have h_gamma_sq_nn : (0 : тДЭ) тЙд ╬│ ^ 2 := sq_nonneg ╬│
  have h_denom_pos : (0 : тДЭ) < x ^ 2 + ╬│ ^ 2 + y ^ 2 := by linarith
  have h_denom_target_pos : (0 : тДЭ) < ╬│ ^ 2 + 16 := by positivity
  have h_denom_le : x ^ 2 + ╬│ ^ 2 + y ^ 2 тЙд ╬│ ^ 2 + 16 := by linarith
  rw [div_le_div_iffтВА h_denom_target_pos h_denom_pos]
  nlinarith [h_denom_le, h_denom_pos, h_denom_target_pos]

/-- **Cloud lower-bound constant**: `╬г_{╬│ тИИ zeros100ceil} 2/(╬│┬▓ + 16) тЙИ 0.0370`. -/
noncomputable def cloudLBConst : тДЭ :=
  (zeros100ceil.map (fun ╬│ : тДЭ => 2 / (╬│ ^ 2 + 16))).sum

/-- ЁЯМЯ **PROVED тАФ uniform cloud lower bound** on the low compact region:
`cloudLBConst тЙд simpleCloudSumNorm zeros100ceil z.re z.im`. -/
theorem simpleCloudSumNorm_zeros100ceil_lower_bound
    {z : тДВ} (hz : lowCompactRegion z) :
    cloudLBConst тЙд simpleCloudSumNorm zeros100ceil z.re z.im := by
  unfold cloudLBConst simpleCloudSumNorm
  have hy : 0 < z.im := hz.1
  have hxy : z.re ^ 2 + z.im ^ 2 тЙд 16 :=
    lowCompactRegion_sq_re_add_sq_im_le_16 hz
  exact list_sum_le_sum_of_pointwise
    (fun ╬│ _ => simpleCloudSumNorm_term_lower hxy hy)

