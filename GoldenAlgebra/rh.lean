/-- Requires `1 ≤ A` so we get `1 ≤ T` and thus `Real.log T ≥ 0`. -/
lemma closedFormSErrorBoundCD_36_48_subband_le_const
    {A L y T : ℝ}
    (hy : 0 ≤ y)
    (hA_ge_one : 1 ≤ A)
    (hTA : A ≤ T)
    (hlog : Real.log T ≤ L) :
    closedFormSErrorBoundCD (1 / 2 : ℝ) 1 y T
      ≤ y * (((17 / 2 : ℝ) * L + 77 / 4) / A^2) := by
