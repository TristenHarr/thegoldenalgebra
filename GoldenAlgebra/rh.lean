structure BacklundCountRangeMainSlabCertificate where
  A : ÔäØ
  B : ÔäØ
  countLower : Ôäò
  countUpper : Ôäò
  mainLower : ÔäØ
  mainUpper : ÔäØ
  count_bounds :
    ÔêÇ (T : ÔäØ) (hT0 : 0 Ôëñ T), A Ôëñ T ÔåÆ T Ôëñ B ÔåÆ
      countLower Ôëñ zetaWeightedZeroCountUpToHeight T hT0 Ôêº
        zetaWeightedZeroCountUpToHeight T hT0 Ôëñ countUpper
  main_bounds :
    ÔêÇ T : ÔäØ, A Ôëñ T ÔåÆ T Ôëñ B ÔåÆ
      mainLower Ôëñ smoothMainTerm T Ôêº smoothMainTerm T Ôëñ mainUpper
  upperCount_minus_lowerMain_le :
    (countUpper : ÔäØ) - mainLower Ôëñ (25167 / 10000 : ÔäØ)
  upperMain_minus_lowerCount_le :
    mainUpper - (countLower : ÔäØ) Ôëñ (25167 / 10000 : ÔäØ)

/-- A count-range/main-term slab certificate gives the uniform `2.5167`
bound on its slab. -/
theorem BacklundCountRangeMainSlabCertificate.uniform25167
    (S : BacklundCountRangeMainSlabCertificate)
    {T : ÔäØ} (hT0 : 0 Ôëñ T) (hA : S.A Ôëñ T) (hB : T Ôëñ S.B) :
    |concreteS T| Ôëñ (25167 / 10000 : ÔäØ) := by
  have hcount := S.count_bounds T hT0 hA hB
  have hmain := S.main_bounds T hA hB
  have h_upper :
      (zetaWeightedZeroCountUpToHeight T hT0 : ÔäØ) - smoothMainTerm T
        Ôëñ (25167 / 10000 : ÔäØ) := by
    have hcount_upper :
        (zetaWeightedZeroCountUpToHeight T hT0 : ÔäØ)
          Ôëñ (S.countUpper : ÔäØ) := by
      exact_mod_cast hcount.2
    linarith [hcount_upper, hmain.1, S.upperCount_minus_lowerMain_le]
  have h_lower :
      smoothMainTerm T - (zetaWeightedZeroCountUpToHeight T hT0 : ÔäØ)
        Ôëñ (25167 / 10000 : ÔäØ) := by
    have hcount_lower :
        (S.countLower : ÔäØ)
          Ôëñ (zetaWeightedZeroCountUpToHeight T hT0 : ÔäØ) := by
      exact_mod_cast hcount.1
    linarith [hcount_lower, hmain.2, S.upperMain_minus_lowerCount_le]
  rw [concreteS_eq_weighted_count_sub_smoothMainTerm hT0]
  rw [abs_le]
  constructor
  ┬À linarith
  ┬À exact h_upper

