/-- **Raw completed-ξ formula** (matches `completedXiFunction` definition). -/
noncomputable def rawCompletedXiFormula (s : ℂ) : ℂ :=
  (1 / 2 : ℂ) * s * (s - 1)
    * Complex.exp (-(s / 2) * (Real.log Real.pi : ℂ))
    * Complex.Gamma (s / 2)
    * riemannZeta s

/-- ⭐ **PROVED — `completedXiFunction = rawCompletedXiFormula` by `rfl`.** -/
