/-! ### AQ4: linearity of the kernel integral in the coefficient -/

/-- The principal-kernel rectangle integral is linear in the integer
coefficient: `тИо k/(z-a) dz = k ┬╖ тИо 1/(z-a) dz`. -/
theorem principalKernelRectangleIntegral_eq_int_mul_unit
    (R : ZetaRectangle) (k : тДд) (a : тДВ) :
    R.principalKernelRectangleIntegral k a =
      (k : тДВ) * R.unitPrincipalKernelRectangleIntegral a := by
  have h_kernel : тИА z : тДВ,
      principalKernel k a z = (k : тДВ) * principalKernel 1 a z := by
    intro z; unfold principalKernel; ring
  have edge_eq : тИА edge : тДЭ тЖТ тДВ,
      (тИл t in (0 : тДЭ)..1, principalKernel k a (edge t) * deriv edge t) =
        (k : тДВ) *
          тИл t in (0 : тДЭ)..1, principalKernel 1 a (edge t) * deriv edge t := by
    intro edge
    rw [тЖР intervalIntegral.integral_const_mul]
    refine intervalIntegral.integral_congr (fun t _ => ?_)
    rw [h_kernel]; ring
  unfold principalKernelRectangleIntegral unitPrincipalKernelRectangleIntegral
  rw [edge_eq R.bottomEdge, edge_eq R.rightEdge,
      edge_eq R.topEdge, edge_eq R.leftEdge]
  -- `ring_nf` normalizes the LHS but leaves `R.principalKernelRectangleIntegral 1 a`
  -- folded on the RHS; unfold it once more, then `ring` closes by
  -- distributivity over the four-edge sum.
  unfold principalKernelRectangleIntegral
  ring

/-! ### AQ4 (continued): unit theorem implies general-`k` theorem -/

/-- Given the unit-kernel Cauchy index, the general-`k` unnormalized
Cauchy index follows by linearity. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.toUnnormalized
    {R : ZetaRectangle} {a : тДВ}
    (H : R.UnitPrincipalKernelIntegralTheorem a) (k : тДд) :
    R.PrincipalKernelUnnormalizedIntegralTheorem k a where
  inside := H.inside
  boundary_avoids := H.boundary_avoids
  integral_eq := by
    rw [principalKernelRectangleIntegral_eq_int_mul_unit, H.integral_eq]
    ring

/-- Given the unit-kernel Cauchy index, the general-`k` normalized
Cauchy index follows. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.toNormalizedAtCoeff
    {R : ZetaRectangle} {a : тДВ}
    (H : R.UnitPrincipalKernelIntegralTheorem a) (k : тДд) :
    R.PrincipalKernelIntegralTheorem k a :=
  (H.toUnnormalized k).toNormalized

/-! ## AR: Unit-kernel theorem via deformation to a small interior circle -/

/-! ### AR1: small circle inside the rectangle -/

/-- A small closed disk centered at `a` lying strictly inside the open
rectangle.  The radius `r` is positive and the closed ball avoids the
boundary. -/
structure SmallCircleInsideRectangle
    (R : ZetaRectangle) (a : тДВ) where
  r : тДЭ
  r_pos : 0 < r
  closedBall_subset_open :
    Metric.closedBall a r тКЖ {z : тДВ | R.ContainsOpen z}

/-- The set of points strictly inside the rectangle is open in `тДВ`. -/
theorem isOpen_containsOpen (R : ZetaRectangle) :
    IsOpen {z : тДВ | R.ContainsOpen z} := by
  have h1 : IsOpen {z : тДВ | R.left < z.re} :=
    isOpen_Ioi.preimage Complex.continuous_re
  have h2 : IsOpen {z : тДВ | z.re < R.right} :=
    isOpen_Iio.preimage Complex.continuous_re
  have h3 : IsOpen {z : тДВ | R.bottom < z.im} :=
    isOpen_Ioi.preimage Complex.continuous_im
  have h4 : IsOpen {z : тДВ | z.im < R.top} :=
    isOpen_Iio.preimage Complex.continuous_im
  exact h1.inter (h2.inter (h3.inter h4))

/-- Every point strictly inside the rectangle admits a small interior
disk. -/
theorem exists_smallCircleInsideRectangle
    {R : ZetaRectangle} {a : тДВ}
    (ha : R.ContainsOpen a) :
    Nonempty (R.SmallCircleInsideRectangle a) := by
  have hopen := isOpen_containsOpen R
  rw [Metric.isOpen_iff] at hopen
  obtain тЯи╬╡, h╬╡_pos, h╬╡_subтЯй := hopen a ha
  refine тЯи{ r := ╬╡ / 2, r_pos := by linarith, closedBall_subset_open := ?_ }тЯй
  intro z hz
  rw [Metric.mem_closedBall] at hz
  apply h╬╡_sub
  rw [Metric.mem_ball]
  linarith

/-! ### AR2: unit-kernel circle integral -/

/-- Integral of the unit kernel `1/(z - a)` around the positively oriented
circle centered at `a` with radius `r`. -/
noncomputable def unitKernelCircleIntegral (a : тДВ) (r : тДЭ) : тДВ :=
  тИо z in C(a, r), (z - a)тБ╗┬╣

/-! ### AR3: circle integral evaluates to `2╧Аi` -/

/-- The unit-kernel circle integral around `a` equals `2╧Аi` for any positive
radius.  This is `circleIntegral.integral_sub_inv_of_mem_ball` applied at
the center. -/
theorem unitKernelCircleIntegral_eq_twoPiI
    (a : тДВ) {r : тДЭ} (hr : 0 < r) :
    unitKernelCircleIntegral a r = twoPiI := by
  unfold unitKernelCircleIntegral twoPiI
  rw [circleIntegral.integral_sub_inv_of_mem_ball (Metric.mem_ball_self hr)]

/-! ### AR4: punctured-rectangle deformation theorem target -/

/-- Cauchy-Goursat-on-punctured-rectangle: the rectangle boundary integral of
`1/(z - a)` equals the corresponding small-circle integral around `a`.

This is the last hard analytic piece in the unit-kernel chain.  It is left
as a target (Prop) to be inhabited later by an annular Cauchy-Goursat
argument. -/
structure UnitKernelRectangleToCircleDeformation
    (R : ZetaRectangle) (a : тДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  rectangle_eq_circle :
    R.unitPrincipalKernelRectangleIntegral a =
      unitKernelCircleIntegral a C.r

/-! ### AR5: deformation + circle theorem тЗТ unit Cauchy index -/

/-- A rectangle-to-circle deformation, combined with the proved circle
integral, gives the unit principal-kernel Cauchy-index theorem. -/
noncomputable def UnitKernelRectangleToCircleDeformation.toUnitPrincipalKernelIntegralTheorem
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (D : R.UnitKernelRectangleToCircleDeformation a C) :
    R.UnitPrincipalKernelIntegralTheorem a where
  inside :=
    C.closedBall_subset_open (Metric.mem_closedBall_self C.r_pos.le)
  boundary_avoids := by
    intro z hz heq
    subst heq
    exact hz.2
      (C.closedBall_subset_open (Metric.mem_closedBall_self C.r_pos.le))
  integral_eq := by
    rw [D.rectangle_eq_circle]
    exact unitKernelCircleIntegral_eq_twoPiI a C.r_pos

/-! ## AS: Punctured-rectangle Cauchy-Goursat target -/

/-! ### AS1: punctured rectangle region (closed rectangle minus open ball) -/

/-- Closed rectangle with the open ball `ball a r` removed.  This is the
region on which the unit kernel `1/(z-a)` is holomorphic. -/
def puncturedRectangleRegion
    (R : ZetaRectangle) (a : тДВ) (r : тДЭ) : Set тДВ :=
  {z : тДВ | R.ContainsClosed z тИз z тИЙ Metric.ball a r}

/-! ### AS2: analyticity of the unit kernel away from the singularity -/

/-- The unit principal kernel `1/(z - a)` is analytic at any point `z тЙа a`. -/
theorem analyticAt_unitPrincipalKernel_of_ne
    {a z : тДВ} (hz : z тЙа a) :
    AnalyticAt тДВ (fun w : тДВ => unitPrincipalKernel a w) z := by
  unfold unitPrincipalKernel
  have h_id : AnalyticAt тДВ (fun w : тДВ => w) z := analyticAt_id
  have h_const_a : AnalyticAt тДВ (fun _ : тДВ => a) z := analyticAt_const
  have h_den : AnalyticAt тДВ (fun w : тДВ => w - a) z := h_id.sub h_const_a
  have h_num : AnalyticAt тДВ (fun _ : тДВ => (1 : тДВ)) z := analyticAt_const
  exact h_num.div h_den (sub_ne_zero.mpr hz)

/-! ### AS3: Cauchy-Goursat-on-punctured-rectangle target -/

/-- Cauchy-Goursat on the rectangle with a circular hole around `a`:
the outer rectangle boundary integral of the unit kernel equals the inner
small-circle boundary integral. -/
structure PuncturedRectangleCauchyGoursat
    (R : ZetaRectangle) (a : тДВ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  boundary_integral_eq :
    R.unitPrincipalKernelRectangleIntegral a =
      unitKernelCircleIntegral a C.r

/-- The Cauchy-Goursat-on-punctured-rectangle theorem upgrades to the
deformation interface. -/
noncomputable def PuncturedRectangleCauchyGoursat.toDeformation
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitKernelRectangleToCircleDeformation a C where
  rectangle_eq_circle := H.boundary_integral_eq

/-! ### AS4: combined constructor тАФ punctured CG тЗТ unit Cauchy index -/

/-- A punctured-rectangle Cauchy-Goursat inhabitant gives the unit
principal-kernel Cauchy-index theorem directly. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.of_puncturedCauchyGoursat
    {R : ZetaRectangle} {a : тДВ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitPrincipalKernelIntegralTheorem a :=
  H.toDeformation.toUnitPrincipalKernelIntegralTheorem

