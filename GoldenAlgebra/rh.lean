    have h_eq : ((5 : ℕ) : ℝ) * (12 / 5 : ℝ) = 12 := by norm_num
    rw [h_eq] at h
    exact h.symm
  have h10_nonneg : (0 : ℝ) ≤ 10 := by norm_num
  have hexp_nonneg : 0 ≤ Real.exp (12 / 5 : ℝ) :=
    le_of_lt (Real.exp_pos _)
  have h10_le_exp : (10 : ℝ) ≤ Real.exp (12 / 5 : ℝ) := by
