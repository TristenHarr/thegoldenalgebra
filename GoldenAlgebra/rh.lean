    вИГ n : вДХ, (extras n).region z

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **CONDITIONAL CAPSTONE (bundled form).** Restates
¬ІCCXXII's `XiPullbackAntiHerglotzTarget_of_trueKernelTailData` using
`ActualCloudDensityModelData` and `LowHighBandCoverData` bundles in
place of loose arguments. Functionally equivalent вАФ just the cleanest
possible statement of the project's front door.

After ¬ІCCXXV, the remaining unformalized obligations are exactly:
* `RealIBPFamilyData S` (or, via ¬ІCCXXIV, `FiniteFluctuationLogEnvelopeData D T0`),
* `TrueKernelTailData S R error`,
* `hdecomp` (xi log-derivative decomposition),
* `Model : ActualCloudDensityModelData`,
* `Cover : LowHighBandCoverData`.

All of these are explicit analytic statements about ќЊ. -/
theorem XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
    (S : вДЭ вЖТ вДЭ) (R : RealIBPFamilyData S)
    (Model : ActualCloudDensityModelData)
    (error : вДВ вЖТ вДВ)
    (hdecomp : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
          2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (D : TrueKernelTailData S R error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailData
    S R Model.M Model.hM_zeros Model.hmodelAnti error hdecomp D
    Cover.extras Cover.covers

-- =====================================================================
-- ¬ІCCXXIII. RealIBPFamilyData from explicit log-envelope assumptions
-- =====================================================================
-- Reduces the abstract `RealIBPFamilyData S` requirement of the ¬ІCCXXII
-- capstone to a concrete, named-assumption bundle `RealIBPLogEnvelopeData`
-- combining:
--   вАҐ a pointwise log envelope `|S u| вЙ§ (slabCD T).1¬Јlog u + (slabCD T).2`
--     on `[T, вИЮ)` for every adaptive `(z, T)` in the band;
--   вАҐ finite-window integrability of `S ¬Ј pairedCauchyImKernelDeriv`.
--
-- Routes through the existing ¬ІCCVI / ¬ІCCX theorems:
--   вАҐ `derivative_integral_tendsto_of_log_envelope` for `deriv_tendsto`,
--   вАҐ `derivative_integral_limit_abs_le_majorant_tail` for `deriv_bound`.
--
-- Also extracts standalone slab-nonnegativity lemmas
-- (`slabCD_fst_nonneg`, `slabCD_snd_nonneg`) вАФ previously inlined.

/-- в≠Р **PROVED вАФ `slabCD T` first component is nonnegative.** -/
lemma slabCD_fst_nonneg (T : вДЭ) : 0 вЙ§ (slabCD T).1 := by
  unfold slabCD; split_ifs <;> norm_num

/-- в≠Р **PROVED вАФ `slabCD T` second component is nonnegative.** -/
lemma slabCD_snd_nonneg (T : вДЭ) : 0 вЙ§ (slabCD T).2 := by
  unfold slabCD; split_ifs <;> norm_num

/-- рЯУ¶ **`RealIBPLogEnvelopeData S`** вАФ named Prop bundle of the two
analytic obligations that produce a `RealIBPFamilyData S`:

* `log_envelope_from_T` вАФ pointwise log envelope on `[T, вИЮ)` for every
  adaptive `(z, T)`. Strong enough to give both the `вИАбґ†` form needed
  by `derivative_integral_tendsto_of_log_envelope` and the pointwise
  `[T, вИЮ)` form needed by `derivative_integral_limit_abs_le_majorant_tail`.
* `derivative_integrable` вАФ interval integrability of the integrand
  `S ¬Ј pairedCauchyImKernelDeriv z.re z.im` on every `[T, X]` with `T вЙ§ X`.

Slab nonnegativity (`(slabCD T).1, (slabCD T).2`) is already free
via `slabCD_fst_nonneg` / `slabCD_snd_nonneg`. -/
structure RealIBPLogEnvelopeData (S : вДЭ вЖТ вДЭ) : Prop where
  log_envelope_from_T :
    вИА {z : вДВ} {T : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      вИА u, T вЙ§ u вЖТ
        |S u| вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u => S u * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `RealIBPFamilyData S` from `RealIBPLogEnvelopeData S`.**
Discharges both `deriv_tendsto` and `deriv_bound` from a single log
envelope + integrability bundle via the existing ¬ІCCVI/¬ІCCX machinery. -/
theorem realIBPFamilyData_of_logEnvelope
    (S : вДЭ вЖТ вДЭ) (H : RealIBPLogEnvelopeData S) :
    RealIBPFamilyData S where
  deriv_tendsto := by
    intro z T h10 h140 hy hregime
    have hT_pos : (0 : вДЭ) < T := lt_of_lt_of_le (by norm_num) h10
    have hS_ev : вИАбґ† u in Filter.atTop,
        |S u| вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2 := by
      filter_upwards [Filter.eventually_ge_atTop T] with u hu
      exact H.log_envelope_from_T h10 h140 hy hregime u hu
    exact Phase1IBP.derivative_integral_tendsto_of_log_envelope
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hS_ev
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
  deriv_bound := by
    intro z T J h10 h140 hy hregime hJ
    have hT_pos : (0 : вДЭ) < T := lt_of_lt_of_le (by norm_num) h10
    exact Phase1IBP.derivative_integral_limit_abs_le_majorant_tail
      (S := S) (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) (T := T) (J := J)
      hy hT_pos (slabCD_fst_nonneg T) (slabCD_snd_nonneg T) hregime
      (H.log_envelope_from_T h10 h140 hy hregime)
      (fun X hTX => H.derivative_integrable h10 h140 hy hregime hTX)
      hJ

-- =====================================================================
-- ¬ІCCXXIV. Concrete finite-fluctuation specialization
-- =====================================================================
-- Specializes ¬ІCCXXIII's `RealIBPLogEnvelopeData S` to the concrete
-- `S u := finiteFluctuationPrimitive D T0 u` of ¬ІCXCVII / ¬ІCXCIX.
-- Surfaces the exact remaining number-theoretic / regularity content
-- as two named structures:
--
--   FiniteFluctuationLogEnvelopeData D T0   вАФ Turing-style log envelope
--   FiniteFluctuationRegularityData D T0    вАФ split-by-component integrability
--
-- Adds:
--   FiniteFluctuationLogEnvelopeData                  вАФ concrete obligations
--   realIBPLogEnvelopeData_of_finiteFluctuation       вАФ concrete вЖТ abstract
--   realIBPFamilyData_of_finiteFluctuation            вАФ concrete вЖТ RealIBPFamilyData
--   FiniteFluctuationRegularityData                   вАФ finer split
--   finiteFluctuation_derivative_integrable_of_regular вАФ reassemble integrability

/-- рЯУ¶ **`FiniteFluctuationLogEnvelopeData D T0`** вАФ concrete analytic
obligations for the ¬ІCXCIX finite fluctuation primitive
`finiteFluctuationPrimitive D T0`. Two fields:

* `log_envelope_from_T` вАФ the Turing/Backlund-style bound on the
  finite fluctuation primitive (real number theory).
* `derivative_integrable` вАФ finite-window interval integrability of
  the IBP derivative-side integrand. -/
structure FiniteFluctuationLogEnvelopeData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ) : Prop where
  log_envelope_from_T :
    вИА {z : вДВ} {T u : вДЭ},
      10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ u вЖТ
      |Phase1IBP.finiteFluctuationPrimitive D T0 u|
        вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2
  derivative_integrable :
    вИА {z : вДВ} {T X : вДЭ},
      10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- рЯМЯ **PROVED вАФ concrete вЖТ abstract log-envelope data.** -/
theorem realIBPLogEnvelopeData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPLogEnvelopeData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) where
  log_envelope_from_T := by
    intro z T h10 h140 hy hregime u hTu
    exact H.log_envelope_from_T h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact H.derivative_integrable h10 h140 hy hregime hTX

/-- рЯМЯрЯМЯ **PROVED вАФ `RealIBPFamilyData` for the concrete finite
fluctuation primitive.** Composes ¬ІCCXXIII's
`realIBPFamilyData_of_logEnvelope` with the concrete log-envelope
bundle. -/
theorem realIBPFamilyData_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (H : FiniteFluctuationLogEnvelopeData D T0) :
    RealIBPFamilyData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) :=
  realIBPFamilyData_of_logEnvelope
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    (realIBPLogEnvelopeData_of_finiteFluctuation D T0 H)

/-- рЯУ¶ **`FiniteFluctuationRegularityData D T0`** вАФ finer split of the
`derivative_integrable` field of `FiniteFluctuationLogEnvelopeData`,
separating the discrete-counting and smooth-counting parts of the
integrand. Either piece can in principle be discharged from existing
¬ІCXCVIII work on the discrete sum decomposition and the explicit
smooth primitive. -/
structure FiniteFluctuationRegularityData
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ) : Prop where
  discrete_part_integrable :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X
  smooth_part_integrable :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X

/-- рЯМЯрЯМЯ **PROVED вАФ reassemble integrability from the regular split.**
Given finer per-component integrability, recovers the
`derivative_integrable` of `FiniteFluctuationLogEnvelopeData`. Uses
`(a - b) ¬Ј c = a¬Јc - b¬Јc` pointwise + `IntervalIntegrable.sub`. -/
theorem finiteFluctuation_derivative_integrable_of_regular
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (R : FiniteFluctuationRegularityData D T0) :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          Phase1IBP.finiteFluctuationPrimitive D T0 u
            * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hN := R.discrete_part_integrable h10 h140 hy hregime hTX
  have hS := R.smooth_part_integrable h10 h140 hy hregime hTX
  have hfunc_eq :
      (fun u =>
        Phase1IBP.finiteFluctuationPrimitive D T0 u
          * pairedCauchyImKernelDeriv z.re z.im u)
      = (fun u =>
          Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
            * pairedCauchyImKernelDeriv z.re z.im u
          - Phase1IBP.smoothCountingPrimitive T0 u
            * pairedCauchyImKernelDeriv z.re z.im u) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    ring
  rw [hfunc_eq]
  exact hN.sub hS

-- =====================================================================
-- ¬ІCCXXV. Inhabiting `FiniteFluctuationRegularityData` from existing
--         integrability lemmas (no extra analytic input)
-- =====================================================================
-- Provides:
--   discreteCountingKernelDerivTermAnyWindow            вАФ per-i term def
--   discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
--   discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
--                                                       вАФ generalizes the
--                                                         ¬ІCXCVIII lemma (drops
--                                                         the `OrderedWindow`
--                                                         requirement)
--   finiteFluctuationRegularityData_of_existing_integrability
--                                                       вАФ produces the
--                                                         regularity bundle
--                                                         given `0 < T0` and
--                                                         `T0 вЙ§ 10`.
--
-- The discrete part is fully general (any `T0, T, X` work).
-- The smooth part reuses the existing ¬ІCXCVIII lemma via
-- `IntervalIntegrable.mono_set`, which requires `T0 вЙ§ T` over the
-- adaptive band (so `T0 вЙ§ 10` is sufficient since adaptive `T вЙ• 10`).

/-- **Per-`i` indicator term for the any-window discrete primitive.**
Mirrors `Phase1IBP.discreteKernelDerivIndicatorTerm` but with the
two-condition indicator that appears in
`Phase1IBP.discreteCountingPrimitive D T0 u` for arbitrary `T0`. -/
noncomputable def discreteCountingKernelDerivTermAnyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 : вДЭ) (i : вДХ) : вДЭ вЖТ вДЭ :=
  fun u =>
    (if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0)
      * pairedCauchyImKernelDeriv x y u

/-- в≠Р **PROVED вАФ per-`i` term is interval-integrable on any window.**
Case-split on `T0 вЙ§ D.Z i`: in the `вЙ§` case, the integrand reduces to
the ¬ІCXCVIII single-indicator pattern (use
`Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable`); in the
`>` case, the integrand is identically zero. -/
lemma discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : вДЭ) (i : вДХ) (hy : 0 < y) :
    IntervalIntegrable
      (discreteCountingKernelDerivTermAnyWindow D x y T0 i)
      MeasureTheory.volume T X := by
  unfold discreteCountingKernelDerivTermAnyWindow
  by_cases h_T0 : T0 вЙ§ D.Z i
  ¬Ј have hfun :
        (fun u =>
          (if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun u =>
          (D.mult i : вДЭ) * (if D.Z i вЙ§ u then (1 : вДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u) := by
      funext u
      by_cases h_u : D.Z i вЙ§ u
      ¬Ј have h_and : T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u := вЯ®h_T0, h_uвЯ©
        simp [h_and, h_u]
      ¬Ј have h_nand : ¬ђ (T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u) := fun вЯ®_, hвЯ© => h_u h
        simp [h_nand, h_u]
    rw [hfun]
    exact Phase1IBP.indicator_kernel_deriv_term_intervalIntegrable D x y T X i hy
  ¬Ј have hfun :
        (fun u =>
          (if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0)
            * pairedCauchyImKernelDeriv x y u)
        = (fun _ : вДЭ => (0 : вДЭ)) := by
      funext u
      have h_nand : ¬ђ (T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u) := fun вЯ®h, _вЯ© => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- рЯМЯрЯМЯ **PROVED вАФ `N_{T0}(u) ¬Ј k'(u)` is interval-integrable on any
finite window**, without an `OrderedWindow` hypothesis. Generalizes
¬ІCXCVIII's `Phase1IBP.discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
to the case where the primitive's lower cutoff `T0` is decoupled from
the integration window `[T, X]`. -/
lemma discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (x y T0 T X : вДЭ) (hy : 0 < y) :
    IntervalIntegrable
      (fun u =>
        Phase1IBP.discreteCountingPrimitive D.toFluctuationMeasureData T0 u
          * pairedCauchyImKernelDeriv x y u)
      MeasureTheory.volume T X := by
  have h_sum_fun :
      IntervalIntegrable
        (вИС i вИИ Finset.range D.n,
          discreteCountingKernelDerivTermAnyWindow D x y T0 i)
        MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingKernelDerivTermAnyWindow_intervalIntegrable
        D x y T0 T X i hy)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  -- (вИС i, term i) u = вИС i, term i u (Finset.sum_apply)
  -- = (вИС i, (if ... then mult_i else 0)) * k'(u) (Finset.sum_mul reverse)
  -- = discreteCountingPrimitive D.toFluctuationMeasureData T0 u * k'(u) (def)
  simp only [Finset.sum_apply, discreteCountingKernelDerivTermAnyWindow]
  rw [вЖР Finset.sum_mul]
  rfl

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `FiniteFluctuationRegularityData` from existing
integrability.** Given `0 < T0 вЙ§ 10`, both regularity fields are
discharged from already-landed ¬ІCXCVIII lemmas:

* `discrete_part_integrable` вАФ via the new
  `discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow`
  (no `OrderedWindow` needed).
* `smooth_part_integrable` вАФ via existing
  `Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable`
  on `[T0, X]` plus `IntervalIntegrable.mono_set` to shrink to
  `[T, X] вКЖ [T0, X]` (the latter inclusion needs `T0 вЙ§ T`, which
  follows from `T0 вЙ§ 10 вЙ§ T`).

After this lands, the only field of `FiniteFluctuationLogEnvelopeData`
that remains unproved is `log_envelope_from_T` (the Turing/Backlund
bound). -/
theorem finiteFluctuationRegularityData_of_existing_integrability
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10) :
    FiniteFluctuationRegularityData D T0 := by
  refine вЯ®?_, ?_вЯ©
  ¬Ј intro z T X h10 h140 hy hregime hTX
    exact discreteCountingPrimitive_mul_kernelDeriv_intervalIntegrable_anyWindow
      D z.re z.im T0 T X hy
  ¬Ј intro z T X h10 h140 hy hregime hTX
    have hT0_le_T : T0 вЙ§ T := le_trans hT0_le_10 h10
    have hT0_le_X : T0 вЙ§ X := le_trans hT0_le_T hTX
    have h_big : IntervalIntegrable
        (fun u => Phase1IBP.smoothCountingPrimitive T0 u
                    * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume T0 X :=
      Phase1IBP.smoothCountingPrimitive_mul_kernelDeriv_intervalIntegrable
        hT0_pos hT0_le_X z.re hy
    have hsubset : Set.uIcc T X вКЖ Set.uIcc T0 X := by
      rw [Set.uIcc_of_le hTX, Set.uIcc_of_le hT0_le_X]
      intro u hu
      exact вЯ®le_trans hT0_le_T hu.1, hu.2вЯ©
    exact h_big.mono_set hsubset

-- =====================================================================
-- ¬ІCCXXVI. Finite-fluctuation RealIBP from a Turing-style bound
-- =====================================================================
-- The handoff layer: composes ¬ІCCXXIV's `FiniteFluctuationLogEnvelopeData`
-- with ¬ІCCXXV's `finiteFluctuationRegularityData_of_existing_integrability`
-- so the only remaining xi-specific input is the Turing/Backlund log
-- envelope `hTuring`.
--
-- Adds:
--   finiteFluctuationLogEnvelopeData_of_turingBound      вАФ assemble the bundle
--   realIBPFamilyData_of_finiteFluctuation_turingBound   вАФ concrete RealIBPFamilyData
--   XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTail
--                                                        вАФ bundled capstone with
--                                                          Turing slot exposed
--
-- After ¬ІCCXXVI, the project's front door reads:
--   `hTuring` + Model + xi `hdecomp` + `TrueKernelTailData` + `LowHighBandCoverData`
--   вЯє `XiPullbackAntiHerglotzTarget`.
-- The `hTuring` slot is the only remaining hard analytic input on the
-- real-IBP side; the parallel agent owns it.

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `FiniteFluctuationLogEnvelopeData` from a
Turing-style log envelope.** Assembles the bundle by passing
`hTuring` directly to the `log_envelope_from_T` field and discharging
`derivative_integrable` via ¬ІCCXXIV +
`finiteFluctuationRegularityData_of_existing_integrability`. -/
theorem finiteFluctuationLogEnvelopeData_of_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2) :
    FiniteFluctuationLogEnvelopeData D T0 where
  log_envelope_from_T := by
    intro z T u h10 h140 hy hregime hTu
    exact hTuring h10 h140 hy hregime hTu
  derivative_integrable := by
    intro z T X h10 h140 hy hregime hTX
    exact finiteFluctuation_derivative_integrable_of_regular D T0
      (finiteFluctuationRegularityData_of_existing_integrability
        D T0 hT0_pos hT0_le_10)
      h10 h140 hy hregime hTX

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ `RealIBPFamilyData` for the finite fluctuation
primitive, gated only by the Turing bound.** Composes ¬ІCCXXIV's
`realIBPFamilyData_of_finiteFluctuation` with
`finiteFluctuationLogEnvelopeData_of_turingBound`. -/
theorem realIBPFamilyData_of_finiteFluctuation_turingBound
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2) :
    RealIBPFamilyData
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u) :=
  realIBPFamilyData_of_finiteFluctuation D T0
    (finiteFluctuationLogEnvelopeData_of_turingBound
      D T0 hT0_pos hT0_le_10 hTuring)

/-- рЯМЯрЯМЯрЯМЯрЯМЯрЯМЯрЯМЯ **CONDITIONAL CAPSTONE (concrete finite-fluctuation
form).** The ¬ІCCXXII bundled capstone instantiated to
`S = finiteFluctuationPrimitive D T0`, with the `R` slot supplied
internally from the Turing bound.

Final dependency surface for the finite-fluctuation route:
* `hTuring` вАФ the Turing/Backlund log envelope (parallel agent);
* `Model` вАФ `ActualCloudDensityModelData` (actual xi cloud-density model);
* `hdecomp` вАФ xi log-derivative decomposition;
* `Dtail` вАФ `TrueKernelTailData` for the finite-fluctuation `S`;
* `Cover` вАФ `LowHighBandCoverData` for non-mid-band probes.

Conclusion: `XiPullbackAntiHerglotzTarget`. -/
theorem XiPullbackAntiHerglotzTarget_of_finiteFluctuation_trueKernelTail
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive D T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (Model : ActualCloudDensityModelData)
    (error : вДВ вЖТ вДВ)
    (hdecomp : вИА z : вДВ,
        (вИГ T : вДЭ, 10 вЙ§ T вИІ T вЙ§ 140 вИІ
          2 * (1 + |z.re| + z.im) вЙ§ T) вЖТ
        logDerivativeResponse XiPullback z = Model.M.model z + error z)
    (Dtail :
      TrueKernelTailData
        (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
        (realIBPFamilyData_of_finiteFluctuation_turingBound
          D T0 hT0_pos hT0_le_10 hTuring)
        error)
    (Cover : LowHighBandCoverData) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_trueKernelTailData'
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    (realIBPFamilyData_of_finiteFluctuation_turingBound
      D T0 hT0_pos hT0_le_10 hTuring)
    Model error hdecomp Dtail Cover

-- =====================================================================
-- ¬ІCCXXVII. Wrapper-kernel integrability from real-derivative integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.wrap_int`:
-- The ¬ІCCXVI wrapper kernel `pairedCauchyComplexKernelDeriv u z` at
-- `z = upperHalfPoint x y` factors pointwise as
-- `pairedCauchyComplexKernelDeriv u (UHP) * (S u : вДВ)
--      = ((S u ¬Ј pairedCauchyImKernelDeriv x y u : вДЭ) : вДВ) * I`.
-- So interval integrability of the complex integrand follows from
-- interval integrability of the real integrand (via `Integrable.ofReal`
-- + multiplication by the constant `Complex.I`).
--
-- Adds:
--   pairedDerivWrapper_integrand_eq_ofReal_mul_I        вАФ pointwise identity
--   intervalIntegrable_ofReal                           вАФ local `IntervalIntegrable.ofReal`
--   wrapKernel_intervalIntegrable_of_real_derivative_integrable
--   wrap_int_of_finiteFluctuation                       вАФ adaptive form

/-- в≠Р **PROVED вАФ pointwise factorization of wrapper integrand.**
The ¬ІCCXVI wrapper kernel integrand at `upperHalfPoint x y` equals
`((real integrand : вДЭ) : вДВ) ¬Ј I`. -/
lemma pairedDerivWrapper_integrand_eq_ofReal_mul_I
    (S : вДЭ вЖТ вДЭ) (x y u : вДЭ) :
    pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : вДВ)
      = ((S u * pairedCauchyImKernelDeriv x y u : вДЭ) : вДВ) * Complex.I := by
  unfold pairedCauchyComplexKernelDeriv
  have h1 : (upperHalfPoint x y).re = x := by simp [upperHalfPoint]
  have h2 : (upperHalfPoint x y).im = y := by simp [upperHalfPoint]
  rw [h1, h2]
  push_cast
  ring

/-- в≠Р **PROVED вАФ `IntervalIntegrable.ofReal` for вДЭ вЖТ вДВ.** Lifts real
interval integrability to вДВ via the pointwise coercion. Built from
Mathlib's `MeasureTheory.Integrable.ofReal` on each of the two
`IntegrableOn` halves of `IntervalIntegrable`. -/
lemma intervalIntegrable_ofReal
    {f : вДЭ вЖТ вДЭ} {a b : вДЭ}
    (hf : IntervalIntegrable f MeasureTheory.volume a b) :
    IntervalIntegrable (fun u => ((f u : вДЭ) : вДВ))
      MeasureTheory.volume a b :=
  вЯ®hf.1.ofReal, hf.2.ofRealвЯ©

/-- рЯМЯрЯМЯ **PROVED вАФ wrapper-kernel integrand interval integrability
from real-derivative integrability.** Given that
`fun u => S u ¬Ј pairedCauchyImKernelDeriv x y u` is interval-integrable
on `[T, X]`, the complex wrapper integrand
`fun u => pairedCauchyComplexKernelDeriv u (UHP x y) ¬Ј (S u : вДВ)` is
interval-integrable on the same interval. -/
lemma wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (S : вДЭ вЖТ вДЭ) (x y T X : вДЭ)
    (hreal : IntervalIntegrable
              (fun u => S u * pairedCauchyImKernelDeriv x y u)
              MeasureTheory.volume T X) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelDeriv u (upperHalfPoint x y) * (S u : вДВ))
      MeasureTheory.volume T X := by
  have hofReal : IntervalIntegrable
      (fun u => ((S u * pairedCauchyImKernelDeriv x y u : вДЭ) : вДВ))
      MeasureTheory.volume T X :=
    intervalIntegrable_ofReal hreal
  have hmul : IntervalIntegrable
      (fun u =>
        ((S u * pairedCauchyImKernelDeriv x y u : вДЭ) : вДВ) * Complex.I)
      MeasureTheory.volume T X :=
    hofReal.mul_const Complex.I
  refine hmul.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  exact (pairedDerivWrapper_integrand_eq_ofReal_mul_I S x y u).symm

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ adaptive wrapper integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T вЙ§ X`, the wrapper-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `wrap_int` field of `TrueKernelTailData`
for the finite-fluctuation `S`.

Note: this does *not* depend on the Turing bound вАФ only on
`0 < T0 вЙ§ 10` and the ¬ІCCXXV regularity inhabit theorem. -/
theorem wrap_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10) :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelDeriv u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : вДЭ) : вДВ))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hreg := finiteFluctuationRegularityData_of_existing_integrability
    D T0 hT0_pos hT0_le_10
  have hreal : IntervalIntegrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u
                  * pairedCauchyImKernelDeriv z.re z.im u)
      MeasureTheory.volume T X :=
    finiteFluctuation_derivative_integrable_of_regular D T0 hreg
      h10 h140 hy hregime hTX
  have hz : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hwrap := wrapKernel_intervalIntegrable_of_real_derivative_integrable
    (fun u => Phase1IBP.finiteFluctuationPrimitive D T0 u)
    z.re z.im T X hreal
  rw [hz] at hwrap
  exact hwrap

-- =====================================================================
-- ¬ІCCXXVIII. True-kernel finite-window integrability
-- =====================================================================
-- Chips away at `TrueKernelTailData.true_int` for the finite-fluctuation
-- `S = Phase1IBP.finiteFluctuationPrimitive D T0` by:
--   1. defining a per-`i` true-kernel indicator term;
--   2. proving its interval integrability (indicator √Ч continuous kernel);
--   3. summing for the discrete part;
--   4. proving smooth-part integrability via ContinuousOn;
--   5. reassembling the finite-fluctuation integrand by `sub`;
--   6. packaging the adaptive theorem `true_int_of_finiteFluctuation`.
--
-- Adds:
--   discreteCountingTrueKernelTerm                              вАФ per-i term def
--   discreteCountingTrueKernelTerm_intervalIntegrable           вАФ per-i integrability
--   discreteCountingPrimitive_trueKernel_intervalIntegrable     вАФ discrete sum
--   smoothCountingPrimitive_trueKernel_intervalIntegrable       вАФ smooth part
--   finiteFluctuationPrimitive_trueKernel_intervalIntegrable    вАФ reassembled
--   true_int_of_finiteFluctuation                               вАФ adaptive form

/-- **Per-`i` true-kernel indicator term.** Top-level definition to
keep the elaborator cheap inside `IntervalIntegrable.sum`. -/
noncomputable def discreteCountingTrueKernelTerm
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 : вДЭ) (z : вДВ) (i : вДХ) : вДЭ вЖТ вДВ :=
  fun u =>
    pairedCauchyComplexKernelTrue u z
      * ((if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0) : вДВ)

/-- в≠Р **PROVED вАФ per-`i` true-kernel term is interval-integrable.**
Case-splits on `T0 вЙ§ D.Z i`: in the `вЙ§` case, the integrand reduces to
an indicator √Ч continuous-kernel pattern (built via `.indicator
measurableSet_Ici` on each `IntegrableOn` half); in the `>` case, the
integrand is identically zero. -/
lemma discreteCountingTrueKernelTerm_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : вДЭ) (z : вДВ) (i : вДХ) (hz : z.im вЙ† 0) :
    IntervalIntegrable
      (discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X := by
  unfold discreteCountingTrueKernelTerm
  have hk_cont : Continuous fun u : вДЭ => pairedCauchyComplexKernelTrue u z := by
    have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
    simpa [upperHalfPoint_re_im] using h
  by_cases h_T0 : T0 вЙ§ D.Z i
  ¬Ј have hfun :
        (fun u : вДЭ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0) : вДВ))
        = Set.indicator (Set.Ici (D.Z i))
            (fun u : вДЭ =>
              pairedCauchyComplexKernelTrue u z * (D.mult i : вДВ)) := by
      funext u
      by_cases h_u : D.Z i вЙ§ u
      ¬Ј have h_and : T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u := вЯ®h_T0, h_uвЯ©
        have hmem : u вИИ Set.Ici (D.Z i) := h_u
        simp [h_and, Set.indicator_of_mem hmem]
      ¬Ј have h_nand : ¬ђ (T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u) := fun вЯ®_, hвЯ© => h_u h
        have hnmem : u вИЙ Set.Ici (D.Z i) := h_u
        simp [h_nand, Set.indicator_of_notMem hnmem]
    rw [hfun]
    have h_const_mul : IntervalIntegrable
        (fun u : вДЭ => pairedCauchyComplexKernelTrue u z * (D.mult i : вДВ))
        MeasureTheory.volume T X :=
      (hk_cont.intervalIntegrable T X).mul_const (D.mult i : вДВ)
    exact вЯ®h_const_mul.1.indicator measurableSet_Ici,
           h_const_mul.2.indicator measurableSet_IciвЯ©
  ¬Ј have hfun :
        (fun u : вДЭ =>
          pairedCauchyComplexKernelTrue u z
            * ((if T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u then (D.mult i : вДЭ) else 0) : вДВ))
        = (fun _ : вДЭ => (0 : вДВ)) := by
      funext u
      have h_nand : ¬ђ (T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u) := fun вЯ®h, _вЯ© => h_T0 h
      simp [h_nand]
    rw [hfun]
    exact intervalIntegrable_const

/-- рЯМЯрЯМЯ **PROVED вАФ `N_{T0}(u) ¬Ј trueKernel(u, z)` is interval-integrable
on any finite window.** Discrete counting primitive times true kernel.
Proof: sum of per-`i` indicator terms, then bridge via `Finset.mul_sum`
+ `push_cast` to identify with the primitive's defining sum. -/
lemma discreteCountingPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : вДЭ) (z : вДВ) (hz : z.im вЙ† 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.discreteCountingPrimitive
              D.toFluctuationMeasureData T0 u : вДЭ) : вДВ))
      MeasureTheory.volume T X := by
  have h_sum_fun : IntervalIntegrable
      (вИС i вИИ Finset.range D.n, discreteCountingTrueKernelTerm D T0 z i)
      MeasureTheory.volume T X :=
    IntervalIntegrable.sum (Finset.range D.n) (fun i _ =>
      discreteCountingTrueKernelTerm_intervalIntegrable D T0 T X z i hz)
  refine h_sum_fun.congr ?_
  refine Filter.Eventually.of_forall ?_
  intro u
  simp only [Finset.sum_apply, discreteCountingTrueKernelTerm]
  rw [вЖР Finset.mul_sum]
  congr 1
  unfold Phase1IBP.discreteCountingPrimitive
  push_cast
  refine Finset.sum_congr rfl (fun i _ => ?_)
  by_cases hc : T0 вЙ§ D.Z i вИІ D.Z i вЙ§ u
  ¬Ј simp [hc]
  ¬Ј simp [hc]

/-- рЯМЯрЯМЯ **PROVED вАФ `S_smooth(u) ¬Ј trueKernel(u, z)` is interval-integrable
on `[T, X]`** for `0 < T0 вЙ§ T вЙ§ X` and `z.im вЙ† 0`. Both factors are
continuous on `[T, X]`: `S_smooth` via FTC (since `T0 вЙ§ u` for every
`u вИИ [T, X]`), `trueKernel` via ¬ІCCXX. -/
lemma smoothCountingPrimitive_trueKernel_intervalIntegrable
    (T0 T X : вДЭ) (z : вДВ)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 вЙ§ T) (hTX : T вЙ§ X) (hz : z.im вЙ† 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : вДЭ) : вДВ))
      MeasureTheory.volume T X := by
  have h_S_cont : ContinuousOn
      (fun u => ((Phase1IBP.smoothCountingPrimitive T0 u : вДЭ) : вДВ))
      (Set.Icc T X) := by
    intro u hu
    have hT0_le_u : T0 вЙ§ u := le_trans hT0_le_T hu.1
    have h_deriv := Phase1IBP.smoothCountingPrimitive_hasDerivAt hT0_pos hT0_le_u
    have h_real_cont : ContinuousAt
        (fun v => Phase1IBP.smoothCountingPrimitive T0 v) u :=
      h_deriv.differentiableAt.continuousAt
    exact
      (Complex.continuous_ofReal.continuousAt.comp h_real_cont).continuousWithinAt
  have h_k_cont : ContinuousOn (fun u => pairedCauchyComplexKernelTrue u z)
      (Set.Icc T X) := by
    have hcont : Continuous fun u : вДЭ => pairedCauchyComplexKernelTrue u z := by
      have h := continuous_pairedCauchyComplexKernelTrue_u z.re z.im hz
      simpa [upperHalfPoint_re_im] using h
    exact hcont.continuousOn
  have h_prod_cont : ContinuousOn
      (fun u =>
        pairedCauchyComplexKernelTrue u z
          * ((Phase1IBP.smoothCountingPrimitive T0 u : вДЭ) : вДВ))
      (Set.Icc T X) :=
    h_k_cont.mul h_S_cont
  exact ContinuousOn.intervalIntegrable_of_Icc hTX h_prod_cont

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `finiteFluctuationPrimitive D T0 u ¬Ј trueKernel(u, z)`
is interval-integrable.** Reassembles the discrete and smooth parts
via `IntervalIntegrable.sub` after distributing
`trueKernel ¬Ј ((N - Ssmooth : вДЭ) : вДВ)` pointwise. -/
lemma finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    (D : Phase1IBP.OrderedFluctuationMeasureData)
    (T0 T X : вДЭ) (z : вДВ)
    (hT0_pos : 0 < T0) (hT0_le_T : T0 вЙ§ T) (hTX : T вЙ§ X) (hz : z.im вЙ† 0) :
    IntervalIntegrable
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : вДЭ) : вДВ))
      MeasureTheory.volume T X := by
  have hdisc := discreteCountingPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hz
  have hsmooth := smoothCountingPrimitive_trueKernel_intervalIntegrable
    T0 T X z hT0_pos hT0_le_T hTX hz
  have hfunc_eq :
      (fun u =>
        pairedCauchyComplexKernelTrue u z *
          ((Phase1IBP.finiteFluctuationPrimitive D T0 u : вДЭ) : вДВ))
      = (fun u =>
          pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.discreteCountingPrimitive
                D.toFluctuationMeasureData T0 u : вДЭ) : вДВ)
          - pairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.smoothCountingPrimitive T0 u : вДЭ) : вДВ)) := by
    funext u
    unfold Phase1IBP.finiteFluctuationPrimitive
    push_cast
    ring
  rw [hfunc_eq]
  exact hdisc.sub hsmooth

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ adaptive true-kernel integrability for the finite
fluctuation primitive.** For every `(z, T, X)` in the adaptive band
with `T вЙ§ X`, the true-kernel integrand at `z` is interval-integrable
on `[T, X]`. Discharges the `true_int` field of `TrueKernelTailData`
for the finite-fluctuation `S` (modulo the `T вЙ§ X` hypothesis).

Like ¬ІCCXXVII's `wrap_int_of_finiteFluctuation`, this version adds
`T вЙ§ X` as an explicit hypothesis вАФ the structure's field allows
arbitrary `X`, but the practical use case (improper integral partial
sums) only ever uses `T вЙ§ X`. -/
theorem true_int_of_finiteFluctuation
    (D : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10) :
    вИА {z : вДВ} {T X : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      T вЙ§ X вЖТ
      IntervalIntegrable
        (fun u =>
          pairedCauchyComplexKernelTrue u z *
            ((Phase1IBP.finiteFluctuationPrimitive D T0 u : вДЭ) : вДВ))
        MeasureTheory.volume T X := by
  intro z T X h10 h140 hy hregime hTX
  have hT0_le_T : T0 вЙ§ T := le_trans hT0_le_10 h10
  exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
    D T0 T X z hT0_pos hT0_le_T hTX (ne_of_gt hy)

-- =====================================================================
-- ¬ІCCXXIX. Complex improper convergence from a real norm-majorant
-- =====================================================================
-- вДВ-valued analogue of ¬ІCCV's `improperIntegralConverges_of_absMajorant`.
-- Given a complex integrand `f : вДЭ вЖТ вДВ`, a real majorant `M : вДЭ вЖТ вДЭ`
-- whose improper integral converges, and a pointwise eventual bound
-- `вАЦf uвАЦ вЙ§ M u`, the complex partial integrals `вИЂ T..X, f u` form a
-- Cauchy sequence in вДВ and hence converge (вДВ is complete).
--
-- This is the smallest reusable next building block for the `conv`
-- field of `TrueKernelTailData`: any concrete kernel √Ч density tail
-- with a log-envelope bound yields convergence via this lemma.
--
-- Adds:
--   improperComplexIntegralConverges_of_normMajorant

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ complex improper convergence from a real
norm-majorant.** Mirrors ¬ІCCV's real-side comparison theorem. Proof:
Cauchy criterion via `Metric.cauchy_iff`, with the key step
`вАЦвИЂ_{Y1}^{Y2} fвАЦ вЙ§ вИЂ_{Y1}^{Y2} вАЦf uвАЦ du вЙ§ вИЂ_{Y1}^{Y2} M u du`
(combining `MeasureTheory.norm_integral_le_integral_norm` and
`intervalIntegral.integral_mono_on`) plus the M-tail smallness from
the M-partial Cauchy structure. -/
theorem improperComplexIntegralConverges_of_normMajorant
    {f : вДЭ вЖТ вДВ} {M : вДЭ вЖТ вДЭ} {T LM : вДЭ}
    (hf_int : вИА X, T вЙ§ X вЖТ IntervalIntegrable f MeasureTheory.volume T X)
    (hM_int : вИА X, T вЙ§ X вЖТ IntervalIntegrable M MeasureTheory.volume T X)
    (hM_tendsto : Tendsto (fun X => вИЂ u in T..X, M u)
                    Filter.atTop (рЭУЭ LM))
    (hbound : вИАбґ† u in Filter.atTop, вАЦf uвАЦ вЙ§ M u) :
    вИГ L : вДВ, Tendsto (fun X => вИЂ u in T..X, f u) Filter.atTop (рЭУЭ L) := by
  have h_cauchy :
      Cauchy (Filter.map (fun X => вИЂ u in T..X, f u) Filter.atTop) := by
    rw [Metric.cauchy_iff]
    refine вЯ®Filter.map_neBot, ?_вЯ©
    intro ќµ hќµ
    have hќµ2 : 0 < ќµ / 2 := by linarith
    have h_M_close : вИАбґ† A in Filter.atTop,
        |(вИЂ u in T..A, M u) - LM| < ќµ / 2 := by
      have h := (Metric.tendsto_nhds.mp hM_tendsto) (ќµ / 2) hќµ2
      filter_upwards [h] with A hdist
      rwa [Real.dist_eq] at hdist
    obtain вЯ®N_M, hN_MвЯ© := Filter.eventually_atTop.mp h_M_close
    obtain вЯ®N0, hN0вЯ© := Filter.eventually_atTop.mp hbound
    let N : вДЭ := max T (max N0 N_M)
    refine вЯ®(fun X => вИЂ u in T..X, f u) '' {X | N вЙ§ X}, ?_, ?_вЯ©
    ¬Ј exact Filter.image_mem_map (Filter.eventually_ge_atTop N)
    suffices key :
        вИА Y1 Y2 : вДЭ, N вЙ§ Y1 вЖТ N вЙ§ Y2 вЖТ Y1 вЙ§ Y2 вЖТ
          вАЦ(вИЂ u in T..Y2, f u) - (вИЂ u in T..Y1, f u)вАЦ < ќµ by
      rintro _ вЯ®X1, hX1, rflвЯ© _ вЯ®X2, hX2, rflвЯ©
      rw [dist_eq_norm]
      rcases le_total X1 X2 with hX12 | hX21
      ¬Ј rw [norm_sub_rev]; exact key X1 X2 hX1 hX2 hX12
      ¬Ј exact key X2 X1 hX2 hX1 hX21
    intro Y1 Y2 hY1 hY2 hY12
    have hT_Y1 : T вЙ§ Y1 := le_trans (le_max_left T _) hY1
    have hT_Y2 : T вЙ§ Y2 := le_trans (le_max_left T _) hY2
    have hN0_Y1 : N0 вЙ§ Y1 :=
      le_trans (le_trans (le_max_left N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y1 : N_M вЙ§ Y1 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY1
    have hN_M_Y2 : N_M вЙ§ Y2 :=
      le_trans (le_trans (le_max_right N0 N_M) (le_max_right T _)) hY2
    have hf_int_TY2 := hf_int Y2 hT_Y2
    have hf_int_TY1 : IntervalIntegrable f MeasureTheory.volume T Y1 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hf_int_Y1Y2 : IntervalIntegrable f MeasureTheory.volume Y1 Y2 :=
      hf_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have hM_int_TY2 := hM_int Y2 hT_Y2
    have hM_int_TY1 : IntervalIntegrable M MeasureTheory.volume T Y1 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hT_Y1, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_right hY12)
    have hM_int_Y1Y2 : IntervalIntegrable M MeasureTheory.volume Y1 Y2 :=
      hM_int_TY2.mono_set (by
        rw [Set.uIcc_of_le hY12, Set.uIcc_of_le hT_Y2]
        exact Set.Icc_subset_Icc_left hT_Y1)
    have h_split_f : (вИЂ u in T..Y2, f u) =
        (вИЂ u in T..Y1, f u) + вИЂ u in Y1..Y2, f u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hf_int_TY1 hf_int_Y1Y2).symm
    have h_tail_f :
        (вИЂ u in T..Y2, f u) - (вИЂ u in T..Y1, f u) = вИЂ u in Y1..Y2, f u := by
      rw [h_split_f]; ring
    rw [h_tail_f]
    have hbound_Y1Y2 : вИА u вИИ Set.Icc Y1 Y2, вАЦf uвАЦ вЙ§ M u := by
      intro u hu
      exact hN0 u (le_trans hN0_Y1 hu.1)
    have h_norm_int : вАЦвИЂ u in Y1..Y2, f uвАЦ вЙ§ вИЂ u in Y1..Y2, вАЦf uвАЦ := by
      rw [intervalIntegral.integral_of_le hY12,
          intervalIntegral.integral_of_le hY12]
      exact MeasureTheory.norm_integral_le_integral_norm _
    have h_mono : вИЂ u in Y1..Y2, вАЦf uвАЦ вЙ§ вИЂ u in Y1..Y2, M u :=
      intervalIntegral.integral_mono_on hY12 hf_int_Y1Y2.norm hM_int_Y1Y2
        hbound_Y1Y2
    have h_comp : вАЦвИЂ u in Y1..Y2, f uвАЦ вЙ§ вИЂ u in Y1..Y2, M u :=
      le_trans h_norm_int h_mono
    have h_split_M : (вИЂ u in T..Y2, M u) =
        (вИЂ u in T..Y1, M u) + вИЂ u in Y1..Y2, M u :=
      (intervalIntegral.integral_add_adjacent_intervals
        hM_int_TY1 hM_int_Y1Y2).symm
    have h_M_tail_eq : вИЂ u in Y1..Y2, M u =
        (вИЂ u in T..Y2, M u) - (вИЂ u in T..Y1, M u) := by linarith
    have h_M_close_Y1 := hN_M Y1 hN_M_Y1
    have h_M_close_Y2 := hN_M Y2 hN_M_Y2
    have h_M_diff_lt :
        |(вИЂ u in T..Y2, M u) - (вИЂ u in T..Y1, M u)| < ќµ := by
      calc |(вИЂ u in T..Y2, M u) - (вИЂ u in T..Y1, M u)|
          вЙ§ |(вИЂ u in T..Y2, M u) - LM| + |LM - (вИЂ u in T..Y1, M u)| :=
              abs_sub_le _ _ _
        _ = |(вИЂ u in T..Y2, M u) - LM| + |(вИЂ u in T..Y1, M u) - LM| := by
              rw [abs_sub_comm LM]
        _ < ќµ / 2 + ќµ / 2 := add_lt_add h_M_close_Y2 h_M_close_Y1
        _ = ќµ := by ring
    rw [h_M_tail_eq] at h_comp
    have h_le_abs :
        (вИЂ u in T..Y2, M u) - (вИЂ u in T..Y1, M u)
          вЙ§ |(вИЂ u in T..Y2, M u) - (вИЂ u in T..Y1, M u)| := le_abs_self _
    linarith
  obtain вЯ®L, hLвЯ© := CompleteSpace.complete h_cauchy
  exact вЯ®L, hLвЯ©

-- =====================================================================
-- ¬ІCCXXIX-3. True-kernel norm bound on UHP probes
-- =====================================================================
-- Crude `1/u¬≤` decay bound on the true rational kernel at UHP probes
-- `(upperHalfPoint x y)`. For `u` larger than `2|x|`:
--   вАҐ `|x ¬± u| вЙ• u/2`;
--   вАҐ hence `вАЦz ¬± uвАЦ вЙ• u/2` (via `Complex.abs_re_le_norm`);
--   вАҐ hence `вАЦ1/(z ¬± u)¬≤вАЦ вЙ§ 4/u¬≤`;
--   вАҐ triangle inequality on the difference gives вЙ§ 8/u¬≤.
-- The `1/u¬≤` decay is enough (combined with a log envelope on `S`)
-- to apply ¬ІCCXXIX's `improperComplexIntegralConverges_of_normMajorant`.
--
-- Adds:
--   upperHalfPoint_sub_real_norm_ge_half
--   upperHalfPoint_add_real_norm_ge_half
--   norm_inv_sq_le_four_div_sq_of_norm_ge_half
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
--   norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually

/-- в≠Р **PROVED вАФ `вАЦUHP - uвАЦ вЙ• u/2` when `u вЙ• 2|x|`.** Lower bound on
the denominator of the first true-kernel term. -/
lemma upperHalfPoint_sub_real_norm_ge_half
    (x y u : вДЭ) (hu : 2 * |x| вЙ§ u) :
    u / 2 вЙ§ вАЦupperHalfPoint x y - (u : вДВ)вАЦ := by
  have h_re : (upperHalfPoint x y - (u : вДВ)).re = x - u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| вЙ§ u / 2 := by linarith
  have hu_nn : 0 вЙ§ u := by linarith [abs_nonneg x]
  have h_x_upper : x вЙ§ u / 2 := le_trans (le_abs_self x) h_abs_x
  have h_nonneg : 0 вЙ§ u - x := by linarith
  have h_abs_eq : |x - u| = u - x := by
    rw [abs_sub_comm]
    exact abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 вЙ§ |x - u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x - u| вЙ§ вАЦupperHalfPoint x y - (u : вДВ)вАЦ := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y - (u : вДВ))
    rw [h_re] at this
    exact this
  linarith

/-- в≠Р **PROVED вАФ `вАЦUHP + uвАЦ вЙ• u/2` when `u вЙ• 2|x|`.** Lower bound on
the denominator of the second true-kernel term. -/
lemma upperHalfPoint_add_real_norm_ge_half
    (x y u : вДЭ) (hu : 2 * |x| вЙ§ u) :
    u / 2 вЙ§ вАЦupperHalfPoint x y + (u : вДВ)вАЦ := by
  have h_re : (upperHalfPoint x y + (u : вДВ)).re = x + u := by
    simp [upperHalfPoint]
  have h_abs_x : |x| вЙ§ u / 2 := by linarith
  have hu_nn : 0 вЙ§ u := by linarith [abs_nonneg x]
  have h_neg_x_le : -x вЙ§ |x| := neg_le_abs x
  have h_x_lower : -(u / 2) вЙ§ x := by linarith
  have h_nonneg : 0 вЙ§ x + u := by linarith
  have h_abs_eq : |x + u| = x + u := abs_of_nonneg h_nonneg
  have h_abs_ge : u / 2 вЙ§ |x + u| := by
    rw [h_abs_eq]; linarith
  have h_norm_ge : |x + u| вЙ§ вАЦupperHalfPoint x y + (u : вДВ)вАЦ := by
    have := Complex.abs_re_le_norm (upperHalfPoint x y + (u : вДВ))
    rw [h_re] at this
    exact this
  linarith

/-- в≠Р **PROVED вАФ reciprocal-square norm bound.** If `вАЦwвАЦ вЙ• u/2 > 0`,
then `вАЦ1/w¬≤вАЦ вЙ§ 4/u¬≤`. -/
lemma norm_inv_sq_le_four_div_sq_of_norm_ge_half
    {w : вДВ} {u : вДЭ} (hu : 0 < u) (hw : u / 2 вЙ§ вАЦwвАЦ) :
    вАЦ(1 : вДВ) / w^2вАЦ вЙ§ 4 / u^2 := by
  have hu_half_pos : 0 < u / 2 := by linarith
  have hw_pos : 0 < вАЦwвАЦ := lt_of_lt_of_le hu_half_pos hw
  have h_sq : (u / 2)^2 вЙ§ вАЦwвАЦ^2 :=
    sq_le_sq' (by linarith [norm_nonneg w]) hw
  have hw_sq_pos : 0 < вАЦwвАЦ^2 := by positivity
  have hu_sq_pos : 0 < u^2 := by positivity
  rw [norm_div, norm_one, norm_pow, div_le_div_iffвВА hw_sq_pos hu_sq_pos]
  nlinarith [h_sq]

/-- рЯМЯрЯМЯ **PROVED вАФ true-kernel `8/u¬≤` bound for `u вЙ• 2|x|`.**
Triangle inequality on `1/(z-u)¬≤ - 1/(z+u)¬≤` plus the per-term `4/u¬≤`
bound from `norm_inv_sq_le_four_div_sq_of_norm_ge_half`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    (x y u : вДЭ) (hu_pos : 0 < u) (hu_large : 2 * |x| вЙ§ u) :
    вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y)вАЦ
      вЙ§ 8 / u^2 := by
  unfold pairedCauchyComplexKernelTrue
  have hsub :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y - (u : вДВ)) hu_pos
      (upperHalfPoint_sub_real_norm_ge_half x y u hu_large)
  have hadd :=
    norm_inv_sq_le_four_div_sq_of_norm_ge_half
      (w := upperHalfPoint x y + (u : вДВ)) hu_pos
      (upperHalfPoint_add_real_norm_ge_half x y u hu_large)
  calc
    вАЦ(1 : вДВ) / (upperHalfPoint x y - (u : вДВ))^2
        - (1 : вДВ) / (upperHalfPoint x y + (u : вДВ))^2вАЦ
        вЙ§ вАЦ(1 : вДВ) / (upperHalfPoint x y - (u : вДВ))^2вАЦ
          + вАЦ(1 : вДВ) / (upperHalfPoint x y + (u : вДВ))^2вАЦ := norm_sub_le _ _
    _ вЙ§ 4 / u^2 + 4 / u^2 := add_le_add hsub hadd
    _ = 8 / u^2 := by ring

/-- рЯМЯрЯМЯ **PROVED вАФ eventual `8/u¬≤` bound on the true kernel.** For
each `(x, y)`, the bound holds for all sufficiently large `u` (i.e.
`u > 0` and `u вЙ• 2|x|`). This is the form needed by
`improperComplexIntegralConverges_of_normMajorant`. -/
lemma norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually
    (x y : вДЭ) :
    вИАбґ† u in Filter.atTop,
      вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y)вАЦ
        вЙ§ 8 / u^2 := by
  filter_upwards
    [Filter.eventually_gt_atTop (0 : вДЭ),
     Filter.eventually_ge_atTop (2 * |x|)]
    with u hu_pos hu_large
  exact norm_pairedCauchyComplexKernelTrue_le_eight_div_sq
    x y u hu_pos hu_large

-- =====================================================================
-- ¬ІCCXXIX-4a. True-kernel log majorant and its convergence
-- =====================================================================
-- Defines the real majorant `(8/u¬≤)(C log u + D)` for the true-kernel
-- integrand, computes its explicit primitive `-8(C(log u + 1) + D)/u`,
-- and proves convergence of `вИЂ_T^X majorant вЖТ -primitive(T)`. The proof
-- mirrors ¬ІCCIII's `derivativeSideMajorantConverges` chain.
--
-- Adds:
--   trueKernelLogMajorant                     вАФ `(8/u¬≤)(C log u + D)`
--   trueKernelLogMajorantPrimitive            вАФ explicit primitive
--   hasDerivAt_trueKernelLogMajorantPrimitive вАФ derivative identity
--   trueKernelLogMajorant_continuousOn_Icc
--   trueKernelLogMajorant_intervalIntegrable
--   trueKernelLogMajorant_integral_eq_sub     вАФ FTC
--   log_div_id_atTop_tendsto_zero             вАФ `log x / x вЖТ 0`
--   trueKernelLogMajorantPrimitive_tendsto_zero
--   trueKernelLogMajorantConverges            вАФ improper convergence

/-- **True-kernel log majorant**: `(8/u¬≤) ¬Ј (C log u + D)`. Real
upper bound for `вАЦtrueKernel u z ¬Ј S uвАЦ` when `|S u| вЙ§ C log u + D`
and `u` is large enough that `вАЦtrueKernel u zвАЦ вЙ§ 8/u¬≤`. -/
noncomputable def trueKernelLogMajorant
    (C D : вДЭ) (u : вДЭ) : вДЭ :=
  8 * (C * Real.log u + D) / u^2

/-- **Explicit primitive** of `trueKernelLogMajorant` on `u > 0`:
  `P(u) = -8(C(log u + 1) + D) / u`. -/
noncomputable def trueKernelLogMajorantPrimitive
    (C D : вДЭ) (u : вДЭ) : вДЭ :=
  -8 * (C * (Real.log u + 1) + D) / u

/-- рЯМЯ **PROVED вАФ `P'(u) = M(u)`** for `u > 0`. -/
lemma hasDerivAt_trueKernelLogMajorantPrimitive
    (C D u : вДЭ) (hu : 0 < u) :
    HasDerivAt
      (fun t => trueKernelLogMajorantPrimitive C D t)
      (trueKernelLogMajorant C D u)
      u := by
  unfold trueKernelLogMajorantPrimitive trueKernelLogMajorant
  have hu_ne : u вЙ† 0 := ne_of_gt hu
  have hu_sq_pos : 0 < u^2 := by positivity
  have h_log : HasDerivAt Real.log uвБї¬є u := Real.hasDerivAt_log hu_ne
  have h_g : HasDerivAt (fun t => C * (Real.log t + 1) + D) (C * uвБї¬є) u := by
    have h1 := h_log.add_const (1 : вДЭ)
    have h2 := h1.const_mul C
    exact h2.add_const D
  have h_id : HasDerivAt (fun t : вДЭ => t) (1 : вДЭ) u := hasDerivAt_id u
  have h_div : HasDerivAt
      (fun t : вДЭ => (C * (Real.log t + 1) + D) / t)
      ((C * uвБї¬є * u - (C * (Real.log u + 1) + D) * 1) / u^2) u :=
    h_g.div h_id hu_ne
  have h_neg8 : HasDerivAt
      (fun t : вДЭ => -8 * ((C * (Real.log t + 1) + D) / t))
      (-8 * ((C * uвБї¬є * u - (C * (Real.log u + 1) + D) * 1) / u^2)) u :=
    h_div.const_mul (-8)
  have h_fun_eq :
      (fun t : вДЭ => -8 * ((C * (Real.log t + 1) + D) / t))
      = (fun t : вДЭ => -8 * (C * (Real.log t + 1) + D) / t) := by
    funext t; ring
  rw [h_fun_eq] at h_neg8
  have h_val :
      -8 * ((C * uвБї¬є * u - (C * (Real.log u + 1) + D) * 1) / u^2)
        = 8 * (C * Real.log u + D) / u^2 := by
    field_simp
    ring
  rw [h_val] at h_neg8
  exact h_neg8

/-- в≠Р **PROVED вАФ majorant is continuous on `[T, X]`** for `0 < T вЙ§ X`. -/
lemma trueKernelLogMajorant_continuousOn_Icc
    (C D T X : вДЭ) (hT : 0 < T) (_hTX : T вЙ§ X) :
    ContinuousOn (fun u => trueKernelLogMajorant C D u) (Set.Icc T X) := by
  intro u hu
  have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
  unfold trueKernelLogMajorant
  apply ContinuousAt.continuousWithinAt
  refine ContinuousAt.div ?_ ?_ ?_
  ¬Ј refine continuousAt_const.mul ?_
    refine (continuousAt_const.mul ?_).add continuousAt_const
    exact Real.continuousAt_log (ne_of_gt hu_pos)
  ¬Ј exact continuousAt_id.pow 2
  ¬Ј exact pow_ne_zero 2 (ne_of_gt hu_pos)

/-- в≠Р **PROVED вАФ majorant is `IntervalIntegrable`** on `[T, X]`. -/
lemma trueKernelLogMajorant_intervalIntegrable
    (C D T X : вДЭ) (hT : 0 < T) (hTX : T вЙ§ X) :
    IntervalIntegrable (fun u => trueKernelLogMajorant C D u)
      MeasureTheory.volume T X :=
  ContinuousOn.intervalIntegrable_of_Icc hTX
    (trueKernelLogMajorant_continuousOn_Icc C D T X hT hTX)

/-- рЯМЯ **PROVED вАФ FTC for the majorant**:
  `вИЂ_T^X M(u) du = P(X) вИТ P(T)`. -/
lemma trueKernelLogMajorant_integral_eq_sub
    (C D T X : вДЭ) (hT : 0 < T) (hTX : T вЙ§ X) :
    (вИЂ u in T..X, trueKernelLogMajorant C D u)
      = trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T := by
  apply intervalIntegral.integral_eq_sub_of_hasDerivAt
  ¬Ј intro u hu
    rw [Set.uIcc_of_le hTX] at hu
    have hu_pos : 0 < u := lt_of_lt_of_le hT hu.1
    exact hasDerivAt_trueKernelLogMajorantPrimitive C D u hu_pos
  ¬Ј exact trueKernelLogMajorant_intervalIntegrable C D T X hT hTX

/-- в≠Р **PROVED вАФ `log X / X вЖТ 0`** as `X вЖТ вИЮ`. Via Mathlib's
`Real.tendsto_pow_log_div_mul_add_atTop` specialized to `n = 1, a = 1,
b = 0`. -/
lemma log_div_id_atTop_tendsto_zero :
    Tendsto (fun X : вДЭ => Real.log X / X) Filter.atTop (рЭУЭ 0) := by
  have := Real.tendsto_pow_log_div_mul_add_atTop (1 : вДЭ) (0 : вДЭ) 1
    (by norm_num : (1 : вДЭ) вЙ† 0)
  simpa using this

/-- рЯМЯ **PROVED вАФ `P(X) вЖТ 0`** as `X вЖТ вИЮ`. The primitive splits as
constant multiples of `log X / X` and `1/X`, both vanishing. -/
lemma trueKernelLogMajorantPrimitive_tendsto_zero
    (C D : вДЭ) :
    Tendsto (fun X : вДЭ => trueKernelLogMajorantPrimitive C D X)
      Filter.atTop (рЭУЭ 0) := by
  unfold trueKernelLogMajorantPrimitive
  have h_logterm : Tendsto (fun X : вДЭ => (-8 * C) * (Real.log X / X))
      Filter.atTop (рЭУЭ ((-8 * C) * 0)) :=
    log_div_id_atTop_tendsto_zero.const_mul (-8 * C)
  have h_constterm : Tendsto (fun X : вДЭ => (-8 * (C + D)) * (1 / X))
      Filter.atTop (рЭУЭ ((-8 * (C + D)) * 0)) :=
    (Phase1IBP.const_div_tendsto_zero_atTop (1 : вДЭ)).const_mul (-8 * (C + D))
  have h_sum : Tendsto (fun X : вДЭ =>
      (-8 * C) * (Real.log X / X) + (-8 * (C + D)) * (1 / X))
      Filter.atTop (рЭУЭ ((-8 * C) * 0 + (-8 * (C + D)) * 0)) :=
    h_logterm.add h_constterm
  have h_zero_eq : (-8 * C) * 0 + (-8 * (C + D)) * 0 = 0 := by ring
  rw [h_zero_eq] at h_sum
  refine Filter.Tendsto.congr' ?_ h_sum
  filter_upwards [Filter.eventually_gt_atTop (0 : вДЭ)] with X hX
  have hX_ne : X вЙ† 0 := ne_of_gt hX
  field_simp
  ring

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ `trueKernelLogMajorantConverges`** for any `C, D,
T > 0`. The limit is `-P(T)`. -/
theorem trueKernelLogMajorantConverges
    (C D T : вДЭ) (hT : 0 < T) :
    Tendsto (fun X : вДЭ => вИЂ u in T..X, trueKernelLogMajorant C D u)
      Filter.atTop (рЭУЭ (-trueKernelLogMajorantPrimitive C D T)) := by
  have hprim0 := trueKernelLogMajorantPrimitive_tendsto_zero C D
  have hconst : Tendsto (fun _ : вДЭ => trueKernelLogMajorantPrimitive C D T)
      Filter.atTop (рЭУЭ (trueKernelLogMajorantPrimitive C D T)) :=
    tendsto_const_nhds
  have hsub : Tendsto (fun X : вДЭ =>
      trueKernelLogMajorantPrimitive C D X
        - trueKernelLogMajorantPrimitive C D T) Filter.atTop
      (рЭУЭ (0 - trueKernelLogMajorantPrimitive C D T)) :=
    hprim0.sub hconst
  rw [show (0 - trueKernelLogMajorantPrimitive C D T
            = -trueKernelLogMajorantPrimitive C D T) from by ring] at hsub
  refine Filter.Tendsto.congr' ?_ hsub
  filter_upwards [Filter.eventually_ge_atTop T] with X hTX
  exact (trueKernelLogMajorant_integral_eq_sub C D T X hT hTX).symm

-- =====================================================================
-- ¬ІCCXXIX-4b. True-kernel adaptive complex convergence (`conv` field)
-- =====================================================================
-- Combines ¬ІCCXXIX (Cauchy comparison) + ¬ІCCXXIX-3 (kernel norm bound)
-- + ¬ІCCXXIX-4a (log majorant convergence) + ¬ІCCXXVI Turing log envelope
-- into the `conv` field of `TrueKernelTailData` for the finite-fluctuation
-- `S = finiteFluctuationPrimitive Dzero T0`.
--
-- Adds:
--   trueKernel_integrand_norm_le_logMajorant_eventually
--   trueKernelComplexTail_converges_at
--   trueKernelAdaptiveTail
--   adaptiveComplexConverges_trueKernel_of_turingBound

/-- рЯМЯрЯМЯ **PROVED вАФ true-kernel integrand norm-majorant.** Given an
eventual log envelope on `|S u|`, the complex integrand
`вАЦtrueKernel u (UHP x y) ¬Ј (S u : вДВ)вАЦ` is eventually bounded by
`trueKernelLogMajorant C D u`. -/
lemma trueKernel_integrand_norm_le_logMajorant_eventually
    {S : вДЭ вЖТ вДЭ} {C D x y : вДЭ}
    (hS : вИАбґ† u in Filter.atTop, |S u| вЙ§ C * Real.log u + D) :
    вИАбґ† u in Filter.atTop,
      вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : вДВ)вАЦ
        вЙ§ trueKernelLogMajorant C D u := by
  filter_upwards
    [norm_pairedCauchyComplexKernelTrue_le_eight_div_sq_eventually x y, hS]
    with u hk hSu
  have hS_norm : вАЦ(S u : вДВ)вАЦ = |S u| := by simp
  have hS_bound : вАЦ(S u : вДВ)вАЦ вЙ§ C * Real.log u + D := by
    rw [hS_norm]; exact hSu
  have henv_nonneg : 0 вЙ§ C * Real.log u + D :=
    le_trans (norm_nonneg ((S u : вДВ))) hS_bound
  have h_eight_nn : 0 вЙ§ (8 : вДЭ) / u^2 := by
    have hnn : 0 вЙ§ вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y)вАЦ :=
      norm_nonneg _
    linarith [hnn]
  calc
    вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y) * (S u : вДВ)вАЦ
        = вАЦpairedCauchyComplexKernelTrue u (upperHalfPoint x y)вАЦ
            * вАЦ(S u : вДВ)вАЦ := by rw [norm_mul]
    _ вЙ§ (8 / u^2) * (C * Real.log u + D) :=
          mul_le_mul hk hS_bound (norm_nonneg _) h_eight_nn
    _ = trueKernelLogMajorant C D u := by
          unfold trueKernelLogMajorant
          ring

/-- рЯМЯрЯМЯрЯМЯ **PROVED вАФ pointwise complex convergence at adaptive `(z, T)`.**
For each `(z, T)` in the adaptive band, the complex partial integrals
of `trueKernel ¬Ј finiteFluctuation` over `[T, X]` converge as `X вЖТ вИЮ`.
Routes through `improperComplexIntegralConverges_of_normMajorant` with
the log majorant from ¬ІCCXXIX-4a and the integrability from ¬ІCCXXVIII. -/
theorem trueKernelComplexTail_converges_at
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    {z : вДВ} {T : вДЭ}
    (h10 : 10 вЙ§ T) (h140 : T вЙ§ 140) (hy : 0 < z.im)
    (hregime : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    вИГ L : вДВ,
      Tendsto
        (fun X : вДЭ =>
          complexDensityTailPartial pairedCauchyComplexKernelTrue
            (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
            T X z)
        Filter.atTop (рЭУЭ L) := by
  have hTpos : 0 < T := lt_of_lt_of_le (by norm_num : (0 : вДЭ) < 10) h10
  have hMconv :
      Tendsto (fun X : вДЭ =>
          вИЂ u in T..X,
            trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u)
        Filter.atTop
        (рЭУЭ (-trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)) :=
    trueKernelLogMajorantConverges (slabCD T).1 (slabCD T).2 T hTpos
  have hS_eventual :
      вИАбґ† u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2 := by
    filter_upwards [Filter.eventually_ge_atTop T] with u hTu
    exact hTuring h10 h140 hy hregime hTu
  have hbound_uhp :=
    trueKernel_integrand_norm_le_logMajorant_eventually
      (S := fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      (C := (slabCD T).1) (D := (slabCD T).2)
      (x := z.re) (y := z.im) hS_eventual
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hbound :
      вИАбґ† u in Filter.atTop,
        вАЦpairedCauchyComplexKernelTrue u z
            * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : вДЭ) : вДВ)вАЦ
          вЙ§ trueKernelLogMajorant (slabCD T).1 (slabCD T).2 u := by
    filter_upwards [hbound_uhp] with u hu
    rw [hzUHP] at hu
    exact hu
  apply improperComplexIntegralConverges_of_normMajorant
    (f := fun u =>
      pairedCauchyComplexKernelTrue u z *
        ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : вДЭ) : вДВ))
    (M := trueKernelLogMajorant (slabCD T).1 (slabCD T).2)
    (T := T)
    (LM := -trueKernelLogMajorantPrimitive (slabCD T).1 (slabCD T).2 T)
  ¬Ј intro X hTX
    exact true_int_of_finiteFluctuation
      Dzero T0 hT0_pos hT0_le_10 h10 h140 hy hregime hTX
  ¬Ј intro X hTX
    exact trueKernelLogMajorant_intervalIntegrable
      (slabCD T).1 (slabCD T).2 T X hTpos hTX
  ¬Ј exact hMconv
  ¬Ј exact hbound

/-- **Adaptive tail value for the true kernel.** Uses `Classical.choose`
to extract the limit guaranteed by `trueKernelComplexTail_converges_at`
inside the adaptive band; outside the band, defined as 0. -/
noncomputable def trueKernelAdaptiveTail
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2)
    (T : вДЭ) (z : вДВ) : вДВ :=
  if h : 10 вЙ§ T вИІ T вЙ§ 140 вИІ 0 < z.im вИІ
      2 * (1 + |z.re| + z.im) вЙ§ T then
    Classical.choose
      (trueKernelComplexTail_converges_at
        Dzero T0 hT0_pos hT0_le_10 hTuring
        h.1 h.2.1 h.2.2.1 h.2.2.2)
  else
    0

/-- рЯМЯрЯМЯрЯМЯрЯМЯ **PROVED вАФ true-kernel adaptive complex convergence.**
The full `conv` field of `TrueKernelTailData` for the finite-fluctuation
`S`. Uses `Classical.choose_spec` to identify the tail value with the
guaranteed limit, then transports via `dif_pos` for the adaptive band. -/
noncomputable def adaptiveComplexConverges_trueKernel_of_turingBound
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : вДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 вЙ§ 10)
    (hTuring :
      вИА {z : вДВ} {T u : вДЭ},
        10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
        2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        T вЙ§ u вЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          вЙ§ (slabCD T).1 * Real.log u + (slabCD T).2) :
    AdaptiveComplexDensityTailFamilyConverges
      pairedCauchyComplexKernelTrue
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) where
  tail := trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring
  tendsto := by
    intro T z h10 h140 hy hregime
    have hExists := trueKernelComplexTail_converges_at
      Dzero T0 hT0_pos hT0_le_10 hTuring h10 h140 hy hregime
    have hregion :
        10 вЙ§ T вИІ T вЙ§ 140 вИІ 0 < z.im вИІ 2 * (1 + |z.re| + z.im) вЙ§ T :=
      вЯ®h10, h140, hy, hregimeвЯ©
    have htail_val :
        trueKernelAdaptiveTail Dzero T0 hT0_pos hT0_le_10 hTuring T z
          = Classical.choose hExists := by
      unfold trueKernelAdaptiveTail
      rw [dif_pos hregion]
    rw [htail_val]
    exact Classical.choose_spec hExists

