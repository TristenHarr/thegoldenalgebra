/-! ### CW21: reduce pointwise count constancy to set equality + count extensionality -/

/-- Pure-logic lemma: the set of nontrivial ╬╢-zeros up to height `u` agrees
with the set up to height `T` whenever `T < u тЙд T + ╬╡` and no ╬╢-zero in
the Backlund strip slab `(T, T + ╬╡]` exists.  Uses the nontriviality
conditions `0 < ╧Б.re < 1` to deduce the strip inclusion `-1 тЙд ╧Б.re тЙд 2`
needed by the gap hypothesis. -/
theorem zetaZerosUpToHeightSet_eq_of_strip_gap
    {T u ╬╡ : тДЭ}
    (_hT : (140 : тДЭ) тЙд T)
    (huT : T < u)
    (hu╬╡ : u тЙд T + ╬╡)
    (_h╬╡ : 0 < ╬╡)
    (hgap :
      тИА ╧Б : тДВ,
        riemannZeta ╧Б = 0 тЖТ
        (-1 : тДЭ) тЙд ╧Б.re тЖТ
        ╧Б.re тЙд 2 тЖТ
        T < ╧Б.im тЖТ
        ╧Б.im тЙд T + ╬╡ тЖТ
        False) :
    zetaZerosUpToHeightSet u = zetaZerosUpToHeightSet T := by
  ext ╧Б
  constructor
  ┬╖ intro h╧Бu
    obtain тЯитЯиhzero, hre_pos, hre_lt_oneтЯй, him_pos, him_le_uтЯй := h╧Бu
    by_cases hle : ╧Б.im тЙд T
    ┬╖ exact тЯитЯиhzero, hre_pos, hre_lt_oneтЯй, him_pos, hleтЯй
    ┬╖ push_neg at hle
      have him_le_eps : ╧Б.im тЙд T + ╬╡ := le_trans him_le_u hu╬╡
      have hre_low : (-1 : тДЭ) тЙд ╧Б.re := by linarith
      have hre_high : ╧Б.re тЙд 2 := by linarith
      exact (hgap ╧Б hzero hre_low hre_high hle him_le_eps).elim
  ┬╖ intro h╧БT
    obtain тЯиnontriv, him_pos, him_le_TтЯй := h╧БT
    exact тЯиnontriv, him_pos, le_trans him_le_T (le_of_lt huT)тЯй

/-- Extensionality input for the real-valued weighted zero count: if the
geometric zero set up to two heights is the same, then the counts agree.
Named anchor тАФ proving it requires unfolding the certificate-based
`weightedZeroCountFromCertificate` chain (via `weightedZeroSetOfGlobalMultiplicity`
and `truncatedMultiplicity`). -/
structure ZetaWeightedCountExtensionalityInput : Prop where
  count_eq_of_set_eq :
    тИА T U : тДЭ,
      zetaZerosUpToHeightSet T = zetaZerosUpToHeightSet U тЖТ
        zetaWeightedZeroCountUpToHeightReal T =
          zetaWeightedZeroCountUpToHeightReal U

/-- **CW21 тАФ bridge from count extensionality:** combining the strip-gap
set-equality lemma with the count-extensionality input discharges the
pointwise count-constancy obligation. -/
noncomputable def ZetaStripGapPointwiseCountConstancyInput.of_set_ext
    (Ext : ZetaWeightedCountExtensionalityInput) :
    ZetaStripGapPointwiseCountConstancyInput where
  const_on_gap := by
    intro T u ╬╡ hT huT hu╬╡ h╬╡ hgap
    exact Ext.count_eq_of_set_eq u T
      (zetaZerosUpToHeightSet_eq_of_strip_gap hT huT hu╬╡ h╬╡ hgap)

/-- **CW21 тАФ sharper final theorem.**  Replaces the pointwise count
constancy obligation with the more focused count-extensionality input. -/
theorem
    concreteS_halfLogPlusHalf_of_numericalExtraction_and_countExtensionality
    (E : BacklundNumericalExtractionInput)
    (Ext : ZetaWeightedCountExtensionalityInput)
    {T : тДЭ} (hT : (140 : тДЭ) тЙд T) :
    |concreteS T| тЙд (1 / 2 : тДЭ) * Real.log T + 1 / 2 :=
