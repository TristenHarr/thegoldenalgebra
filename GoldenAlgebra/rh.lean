/-! ### AK1 sub-lemma: log-derivative of `(w - s)^m` -/

/-- Logarithmic derivative of the simple power factor.  This isolates
the `m * (z-s)^(m-1) / (z-s)^m = m / (z-s)` simplification that
underlies the principal-part identity. -/
theorem logDeriv_pow_sub
    {s z : ℂ} {m : ℕ}
    (hm : 0 < m)
    (hz : z ≠ s) :
    logDeriv (fun w : ℂ => (w - s) ^ m) z = (m : ℂ) / (z - s) := by
  have hzs_ne : z - s ≠ 0 := sub_ne_zero.mpr hz
  have h_sub : HasDerivAt (fun w : ℂ => w - s) 1 z :=
    (hasDerivAt_id z).sub_const s
  have h_pow : HasDerivAt (fun w : ℂ => (w - s) ^ m)
                  ((m : ℂ) * (z - s) ^ (m - 1) * 1) z := h_sub.pow m
  rw [logDeriv_apply]
  show deriv (fun w : ℂ => (w - s) ^ m) z / (z - s) ^ m = (m : ℂ) / (z - s)
  rw [h_pow.deriv, mul_one]
  rcases m with _ | m'
  · omega
  · have h_pow_m'_ne : (z - s) ^ m' ≠ 0 := pow_ne_zero m' hzs_ne
    simp only [Nat.succ_sub_one, pow_succ]
    field_simp
    ring

/-! ### AK1 sub-lemma: log-derivative under product factorization -/

/-- If `f` agrees with `(w - s)^m * u w` on a neighborhood of `z`, and `z ≠ s`,
`u z ≠ 0`, `u` is differentiable at `z`, then `logDeriv f z` splits into the
pole term `m / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_factorization
    {f u : ℂ → ℂ} {s z : ℂ} {m : ℕ}
    (hm : 0 < m)
    (hz : z ≠ s)
    (hu : u z ≠ 0)
    (hu_diff : DifferentiableAt ℂ u z)
    (hf : f =ᶠ[𝓝 z] fun w : ℂ => (w - s) ^ m * u w) :
    logDeriv f z = (m : ℂ) / (z - s) + logDeriv u z := by
  have h_pow_diff : DifferentiableAt ℂ (fun w : ℂ => (w - s) ^ m) z := by
    fun_prop
  have h_pow_ne : (z - s) ^ m ≠ 0 := pow_ne_zero m (sub_ne_zero.mpr hz)
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : ℂ => (w - s) ^ m * u w) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_mul z h_pow_ne hu h_pow_diff hu_diff,
      logDeriv_pow_sub hm hz]

/-! ### AK1: continuous principal part from analytic zero factorization -/

/-- A local analytic zero factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = m/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_factorization
    {f : ℂ → ℂ} {s : ℂ} {m : ℕ}
    (hm_pos : 0 < m)
    (H : HasAnalyticZeroFactorization f s m) :
    HasLogDerivPrincipalPartContinuous f s (m : ℤ) := by
  set u : ℂ → ℂ := H.unit with hu_def
  have hu_an : AnalyticAt ℂ u s := H.unit_analytic
  have hu_ne_s : u s ≠ 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : ∀ᶠ z in 𝓝 s, u z ≠ 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : ∀ᶠ z in 𝓝 s, DifferentiableAt ℂ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hfac_eventually_nhds :
      ∀ᶠ z in 𝓝 s, f =ᶠ[𝓝 z] fun w : ℂ => (w - s) ^ m * u w :=
    H.factorization.eventually_nhds
  have hu_ne_punct : ∀ᶠ z in 𝓝[≠] s, u z ≠ 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : ∀ᶠ z in 𝓝[≠] s, DifferentiableAt ℂ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hfac_punct :
      ∀ᶠ z in 𝓝[≠] s, f =ᶠ[𝓝 z] fun w : ℂ => (w - s) ^ m * u w :=
    hfac_eventually_nhds.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : ∀ᶠ z in 𝓝[≠] s, z ≠ s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine ⟨logDeriv u, ?_, ?_⟩
  · show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  · filter_upwards [hfac_punct, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (m : ℂ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_factorization hm_pos hz_ne_z huz hu_diff_z hfz
    have hcast : ((m : ℤ) : ℂ) = (m : ℂ) := by push_cast; rfl
    rw [hcast]
    exact hmain

/-- At a nontrivial zeta zero, `ζ'/ζ` has principal coefficient equal to the
analytic multiplicity, with continuous remainder. -/
theorem zetaLogDeriv_principalPartContinuous_at_nontrivial_zero
    {s : ℂ} (hs : IsNontrivialZetaZero s) :
    HasLogDerivPrincipalPartContinuous
      riemannZeta s
      (zetaGlobalZeroMultiplicity.mult s : ℤ) :=
  hasLogDerivPrincipalPartContinuous_of_factorization
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaAnalyticZeroFactorization hs)

/-! ### AL1: simple-pole factorization interface -/

/-- Local factorization of a function with a simple pole at `s`:
on a punctured neighborhood of `s`, the function equals `unit z / (z - s)`
where `unit` is analytic and nonzero at `s`.

The factorization is stated in the *local* form so that derivative
identities (which need `=ᶠ[𝓝 z]`) compose cleanly without an extra
upgrade lemma. -/
structure HasSimplePoleFactorization (f : ℂ → ℂ) (s : ℂ) where
  unit : ℂ → ℂ
  unit_analytic : AnalyticAt ℂ unit s
  unit_ne_zero : unit s ≠ 0
  factorization_local :
    ∀ᶠ z in 𝓝[≠] s,
      f =ᶠ[𝓝 z] fun w : ℂ => unit w / (w - s)

/-! ### AL2: log-derivative under simple-pole product factorization -/

/-- If `f` agrees with `u w / (w - s)` on a neighborhood of `z`, and
`z ≠ s`, `u z ≠ 0`, `u` is differentiable at `z`, then the logarithmic
derivative splits into the pole term `-1 / (z - s)` plus `logDeriv u z`. -/
theorem logDeriv_eq_of_eventual_simplePoleFactorization
    {f u : ℂ → ℂ} {s z : ℂ}
    (hz : z ≠ s)
    (hu : u z ≠ 0)
    (hu_diff : DifferentiableAt ℂ u z)
    (hf : f =ᶠ[𝓝 z] fun w : ℂ => u w / (w - s)) :
    logDeriv f z = (-1 : ℂ) / (z - s) + logDeriv u z := by
  have hzs_ne : z - s ≠ 0 := sub_ne_zero.mpr hz
  have hsub_diff : DifferentiableAt ℂ (fun w : ℂ => w - s) z := by fun_prop
  have h_logDeriv_eq :
      logDeriv f z = logDeriv (fun w : ℂ => u w / (w - s)) z := by
    rw [logDeriv_apply, logDeriv_apply, hf.deriv_eq, hf.self_of_nhds]
  rw [h_logDeriv_eq, logDeriv_div z hu hzs_ne hu_diff hsub_diff]
  have h_sub_log :
      logDeriv (fun w : ℂ => w - s) z = (1 : ℂ) / (z - s) := by
    have h := logDeriv_pow_sub (m := 1) (s := s) (z := z) (by norm_num) hz
    simpa [pow_one] using h
  rw [h_sub_log]
  ring

/-! ### AL3: continuous principal part from simple-pole factorization -/

/-- A local simple-pole factorization yields the logarithmic-derivative
principal part with continuous remainder:
`logDeriv f = -1/(z-s) + (continuous function)` on a punctured neighborhood. -/
theorem hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization
    {f : ℂ → ℂ} {s : ℂ}
    (H : HasSimplePoleFactorization f s) :
    HasLogDerivPrincipalPartContinuous f s (-1) := by
  set u : ℂ → ℂ := H.unit with hu_def
  have hu_an : AnalyticAt ℂ u s := H.unit_analytic
  have hu_ne_s : u s ≠ 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : ∀ᶠ z in 𝓝 s, u z ≠ 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : ∀ᶠ z in 𝓝 s, DifferentiableAt ℂ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hu_ne_punct : ∀ᶠ z in 𝓝[≠] s, u z ≠ 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : ∀ᶠ z in 𝓝[≠] s, DifferentiableAt ℂ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : ∀ᶠ z in 𝓝[≠] s, z ≠ s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine ⟨logDeriv u, ?_, ?_⟩
  · show ContinuousAt (fun z => deriv u z / u z) s
    exact hu_an.deriv.continuousAt.div hu_cont hu_ne_s
  · filter_upwards
      [H.factorization_local, hu_ne_punct, hu_diff_punct, hz_ne_punct]
      with z hfz huz hu_diff_z hz_ne_z
    have hmain :
        logDeriv f z = (-1 : ℂ) / (z - s) + logDeriv u z :=
      logDeriv_eq_of_eventual_simplePoleFactorization
        hz_ne_z huz hu_diff_z hfz
    have hcast : ((-1 : ℤ) : ℂ) = (-1 : ℂ) := by push_cast; rfl
    rw [hcast]
    exact hmain

/-- Conditional theorem: if `riemannZeta` admits a simple-pole factorization
at `1`, then `ζ'/ζ` has principal-part `-1 / (z - 1)` with continuous
remainder. -/
theorem zetaLogDeriv_principalPartContinuous_at_one
    (H : HasSimplePoleFactorization riemannZeta (1 : ℂ)) :
    HasLogDerivPrincipalPartContinuous riemannZeta (1 : ℂ) (-1) :=
  hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization H

/-! ### AM1: removable extension of `(z-1)·ζ(z)` at the pole -/

/-- The removable extension of `(z - 1) * ζ(z)` at the pole `z = 1`.
Away from `1`, equal to `(z - 1) * ζ(z)`; at `1`, defined to be `1`,
matching `riemannZeta_residue_one`. -/
noncomputable def riemannZetaPoleUnit (z : ℂ) : ℂ :=
  if z = (1 : ℂ) then 1 else (z - 1) * riemannZeta z

@[simp] theorem riemannZetaPoleUnit_one :
    riemannZetaPoleUnit (1 : ℂ) = 1 := by
  unfold riemannZetaPoleUnit; simp

theorem riemannZetaPoleUnit_eq_of_ne_one
    {z : ℂ} (hz : z ≠ (1 : ℂ)) :
    riemannZetaPoleUnit z = (z - 1) * riemannZeta z := by
  unfold riemannZetaPoleUnit; simp [hz]

/-! ### AM2: punctured-neighborhood factorization -/

/-- On the punctured neighborhood of `1`, `riemannZeta z = riemannZetaPoleUnit z / (z - 1)`. -/
theorem riemannZeta_eventuallyEq_poleUnit_div :
    riemannZeta =ᶠ[𝓝[≠] (1 : ℂ)]
      fun z : ℂ => riemannZetaPoleUnit z / (z - 1) := by
  filter_upwards [self_mem_nhdsWithin] with z hz
  have hz_ne : z ≠ (1 : ℂ) := hz
  rw [riemannZetaPoleUnit_eq_of_ne_one hz_ne]
  have hsub : z - 1 ≠ 0 := sub_ne_zero.mpr hz_ne
  field_simp

/-! ### AM3: local-at-each-point factorization -/

/-- The pole-unit factorization is locally available at each point of the
punctured neighborhood of `1`. -/
theorem riemannZeta_eventuallyEq_poleUnit_div_local :
    ∀ᶠ z in 𝓝[≠] (1 : ℂ),
      riemannZeta =ᶠ[𝓝 z]
        fun w : ℂ => riemannZetaPoleUnit w / (w - 1) := by
  filter_upwards [self_mem_nhdsWithin] with z hz
  have hz_ne : z ≠ (1 : ℂ) := hz
  have h_mem : ({(1 : ℂ)}ᶜ : Set ℂ) ∈ 𝓝 z :=
    isOpen_compl_singleton.mem_nhds hz_ne
  filter_upwards [h_mem] with w hw
  have hw_ne : w ≠ (1 : ℂ) := hw
  rw [riemannZetaPoleUnit_eq_of_ne_one hw_ne]
  have hsub : w - 1 ≠ 0 := sub_ne_zero.mpr hw_ne
  field_simp

/-! ### AM4: removable singularity — pole unit is analytic at `1` -/

/-- The pole unit `riemannZetaPoleUnit` is analytic at `1`.

Proof: `(z - 1) * ζ(z)` is bounded near `1` (by `riemannZeta_residue_one`),
analytic away from `1`, and the update at `1` equals `1`
(again by `riemannZeta_residue_one`).  Mathlib's removable singularity
theorem then gives differentiability on a neighborhood of `1`, which
upgrades to analyticity. -/
theorem riemannZetaPoleUnit_analyticAt_one :
    AnalyticAt ℂ riemannZetaPoleUnit (1 : ℂ) := by
  set f : ℂ → ℂ := fun z => (z - 1) * riemannZeta z with hf_def
  have h_tend : Tendsto f (𝓝[≠] (1 : ℂ)) (𝓝 1) := riemannZeta_residue_one
  have h_lim_one : limUnder (𝓝[≠] (1 : ℂ)) f = 1 := h_tend.limUnder_eq
  -- ‖f z‖ < 2 eventually on 𝓝[≠] 1
  have h_norm_tend : Tendsto (fun z => ‖f z‖) (𝓝[≠] (1 : ℂ)) (𝓝 (1 : ℝ)) := by
    have := h_tend.norm
    simpa using this
  have h_bd_event : ∀ᶠ z in 𝓝[≠] (1 : ℂ), ‖f z‖ < 2 :=
    h_norm_tend.eventually (eventually_lt_nhds (by norm_num : (1 : ℝ) < 2))
  -- Extract open V ∋ 1 such that ‖f‖ < 2 on V \ {1}
  rw [eventually_iff_exists_mem] at h_bd_event
  obtain ⟨E, hE_mem, hE⟩ := h_bd_event
  rw [mem_nhdsWithin] at hE_mem
  obtain ⟨V, hV_open, hV_mem_self, hV_sub⟩ := hE_mem
  have hV_nhds : V ∈ 𝓝 (1 : ℂ) := hV_open.mem_nhds hV_mem_self
  have h_bdd : BddAbove (norm ∘ f '' (V \ {1})) := by
    refine ⟨2, ?_⟩
    rintro x ⟨z, ⟨hz_V, hz_ne_one⟩, rfl⟩
    have hz_in_E : z ∈ E := hV_sub ⟨hz_V, hz_ne_one⟩
    exact le_of_lt (hE z hz_in_E)
  -- f is differentiable on V \ {1}
  have h_diff_on : DifferentiableOn ℂ f (V \ {1}) := by
    intro z hz
    obtain ⟨_, hz_ne_one⟩ := hz
    have hz_ne : z ≠ 1 := hz_ne_one
    have h_zeta : DifferentiableAt ℂ riemannZeta z := differentiableAt_riemannZeta hz_ne
    have h_sub : DifferentiableAt ℂ (fun w : ℂ => w - 1) z := by fun_prop
    exact (h_sub.mul h_zeta).differentiableWithinAt
  -- Apply removable singularity
  have h_diff_update :
      DifferentiableOn ℂ (Function.update f 1 (limUnder (𝓝[≠] (1 : ℂ)) f)) V :=
    differentiableOn_update_limUnder_of_bddAbove hV_nhds h_diff_on h_bdd
  -- The updated function equals riemannZetaPoleUnit
  have h_eq : Function.update f 1 (limUnder (𝓝[≠] (1 : ℂ)) f) = riemannZetaPoleUnit := by
    rw [h_lim_one]
    funext z
    by_cases hz : z = 1
    · subst hz; simp [riemannZetaPoleUnit]
    · rw [riemannZetaPoleUnit_eq_of_ne_one hz, Function.update_of_ne hz]
  rw [← h_eq]
  exact h_diff_update.analyticAt hV_nhds

/-! ### AM5: unconditional construction of the simple-pole factorization -/

/-- The simple-pole factorization of `riemannZeta` at `1`. -/
noncomputable def riemannZeta_simplePoleFactorizationAtOne :
    HasSimplePoleFactorization riemannZeta (1 : ℂ) where
  unit := riemannZetaPoleUnit
  unit_analytic := riemannZetaPoleUnit_analyticAt_one
  unit_ne_zero := by simp [riemannZetaPoleUnit_one]
  factorization_local := riemannZeta_eventuallyEq_poleUnit_div_local

/-- Unconditional pole principal part for `riemannZeta` at `z = 1`. -/
theorem zetaLogDeriv_principalPartContinuous_at_one_unconditional :
    HasLogDerivPrincipalPartContinuous riemannZeta (1 : ℂ) (-1) :=
  zetaLogDeriv_principalPartContinuous_at_one
    riemannZeta_simplePoleFactorizationAtOne

/-! ## BX: Analytic-remainder upgrades of the local principal-part theorems -/

/-! ### BX1: `logDeriv u` is analytic at a nonzero analytic point -/

/-- If `u` is analytic at `s` and `u s ≠ 0`, then `logDeriv u` is analytic
at `s`.  Pure `AnalyticAt.div` on `deriv u / u`. -/
theorem analyticAt_logDeriv_of_analyticAt_ne_zero
    {u : ℂ → ℂ} {s : ℂ}
    (hu : AnalyticAt ℂ u s) (hu0 : u s ≠ 0) :
    AnalyticAt ℂ (logDeriv u) s :=
  hu.deriv.div hu hu0

/-! ### BX2: analytic-remainder zero-factorization principal part -/

/-- Analytic version of `hasLogDerivPrincipalPartContinuous_of_factorization`:
the chosen remainder `logDeriv u` is analytic at `s`, not merely continuous. -/
theorem hasLogDerivPrincipalPart_of_factorization
    {f : ℂ → ℂ} {s : ℂ} {m : ℕ}
    (hm_pos : 0 < m) (H : HasAnalyticZeroFactorization f s m) :
    HasLogDerivPrincipalPart f s m := by
  set u : ℂ → ℂ := H.unit with hu_def
  have hu_an : AnalyticAt ℂ u s := H.unit_analytic
  have hu_ne_s : u s ≠ 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : ∀ᶠ z in 𝓝 s, u z ≠ 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : ∀ᶠ z in 𝓝 s, DifferentiableAt ℂ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hfac_eventually_nhds :
      ∀ᶠ z in 𝓝 s, f =ᶠ[𝓝 z] fun w : ℂ => (w - s) ^ m * u w :=
    H.factorization.eventually_nhds
  have hu_ne_punct : ∀ᶠ z in 𝓝[≠] s, u z ≠ 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : ∀ᶠ z in 𝓝[≠] s, DifferentiableAt ℂ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hfac_punct :
      ∀ᶠ z in 𝓝[≠] s, f =ᶠ[𝓝 z] fun w : ℂ => (w - s) ^ m * u w :=
    hfac_eventually_nhds.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : ∀ᶠ z in 𝓝[≠] s, z ≠ s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine ⟨logDeriv u, analyticAt_logDeriv_of_analyticAt_ne_zero hu_an hu_ne_s, ?_⟩
  filter_upwards [hfac_punct, hu_ne_punct, hu_diff_punct, hz_ne_punct]
    with z hfz huz hu_diff_z hz_ne_z
  exact logDeriv_eq_of_eventual_factorization hm_pos hz_ne_z huz hu_diff_z hfz

/-! ### BX3: zeta nontrivial-zero analytic principal part -/

/-- Nat-valued analytic principal part for `ζ'/ζ` at a nontrivial zero. -/
theorem zetaLogDeriv_principalPart_at_nontrivial_zero_nat
    {s : ℂ} (hs : IsNontrivialZetaZero s) :
    ZetaHasLogDerivPrincipalPart s :=
  hasLogDerivPrincipalPart_of_factorization
    (zetaGlobalZeroMultiplicity_pos hs)
    (zetaAnalyticZeroFactorization hs)

/-- Integer-valued analytic principal part for `ζ'/ζ` at a nontrivial zero. -/
theorem zetaLogDeriv_principalPart_at_nontrivial_zero
    {s : ℂ} (hs : IsNontrivialZetaZero s) :
    ZetaHasIntegerLogDerivPrincipalPartAtZero s :=
  (zetaLogDeriv_principalPart_at_nontrivial_zero_nat hs).toInteger

/-! ### BX4: analytic-remainder simple-pole-factorization principal part -/

/-- Analytic version of
`hasLogDerivPrincipalPartContinuous_of_simplePoleFactorization`. -/
theorem hasLogDerivIntegerPrincipalPart_of_simplePoleFactorization
    {f : ℂ → ℂ} {s : ℂ} (H : HasSimplePoleFactorization f s) :
    HasLogDerivIntegerPrincipalPart f s (-1) := by
  set u : ℂ → ℂ := H.unit with hu_def
  have hu_an : AnalyticAt ℂ u s := H.unit_analytic
  have hu_ne_s : u s ≠ 0 := H.unit_ne_zero
  have hu_cont : ContinuousAt u s := hu_an.continuousAt
  have hu_ne_eventually : ∀ᶠ z in 𝓝 s, u z ≠ 0 :=
    hu_cont.eventually_ne hu_ne_s
  have hu_diff_eventually : ∀ᶠ z in 𝓝 s, DifferentiableAt ℂ u z :=
    hu_an.eventually_analyticAt.mono (fun _ h => h.differentiableAt)
  have hu_ne_punct : ∀ᶠ z in 𝓝[≠] s, u z ≠ 0 :=
    hu_ne_eventually.filter_mono nhdsWithin_le_nhds
  have hu_diff_punct : ∀ᶠ z in 𝓝[≠] s, DifferentiableAt ℂ u z :=
    hu_diff_eventually.filter_mono nhdsWithin_le_nhds
  have hz_ne_punct : ∀ᶠ z in 𝓝[≠] s, z ≠ s := by
    filter_upwards [self_mem_nhdsWithin] with z hz using hz
  refine ⟨logDeriv u, analyticAt_logDeriv_of_analyticAt_ne_zero hu_an hu_ne_s, ?_⟩
  filter_upwards
    [H.factorization_local, hu_ne_punct, hu_diff_punct, hz_ne_punct]
    with z hfz huz hu_diff_z hz_ne_z
  have hmain :
      logDeriv f z = (-1 : ℂ) / (z - s) + logDeriv u z :=
    logDeriv_eq_of_eventual_simplePoleFactorization hz_ne_z huz hu_diff_z hfz
  have hcast : ((-1 : ℤ) : ℂ) = (-1 : ℂ) := by push_cast; rfl
  rw [hcast]
  exact hmain

/-! ### BX5: zeta pole analytic principal part (unconditional) -/

/-- Unconditional analytic pole principal part for `ζ'/ζ` at `z = 1`. -/
theorem zetaLogDeriv_principalPart_at_one_unconditional :
    HasLogDerivIntegerPrincipalPart riemannZeta (1 : ℂ) (-1) :=
  hasLogDerivIntegerPrincipalPart_of_simplePoleFactorization
    riemannZeta_simplePoleFactorizationAtOne

/-! ## AN: Rectangle principal-part data (residue-free) -/

namespace ZetaRectangle

/-! ### AN1: counted-singularity predicate -/

/-- Singularities of `ζ'/ζ` that the Backlund/Turing rectangle counts:
either a nontrivial zero of `ζ` strictly inside the rectangle, or the pole
at `s = 1` if it lies strictly inside. -/
def IsCountedZetaSingularityInside (R : ZetaRectangle) (s : ℂ) : Prop :=
  R.IsNontrivialZeroInside s ∨ (R.PoleInside ∧ s = 1)

/-! ### AN1 (continued): rectangle principal-part data -/

/-- Residue-free local principal-part data on a rectangle: a finite list of
singularities, each with an integer coefficient, each carrying a continuous
log-derivative principal-part certificate. -/
structure RectanglePrincipalPartData (R : ZetaRectangle) where
  stronglyAdmissible : R.StronglyAdmissibleForZeta
  singularities : Finset ℂ
  principalCoeff : ℂ → ℤ
  localPrincipalPart :
    ∀ s : ℂ, s ∈ singularities →
      HasLogDerivPrincipalPartContinuous
        riemannZeta s (principalCoeff s)
  singularities_complete :
    ∀ s : ℂ, s ∈ singularities ↔ R.IsCountedZetaSingularityInside s

/-! ### AN2: principal-part integral identity (residue-theorem replacement) -/

/-- The residue-free rectangle argument principle: the normalized contour
integral of `ζ'/ζ` equals the sum of integer principal coefficients of the
counted singularities. -/
structure RectanglePrincipalPartIntegralTheorem (R : ZetaRectangle) where
  ppData : R.RectanglePrincipalPartData
  normalizedIntegral_eq_sum :
    R.normalizedRectangleLogDerivIntegral =
      ((ppData.singularities.sum ppData.principalCoeff : ℤ) : ℂ)

/-! ### AN4: canonical principal coefficient for `ζ'/ζ` -/

/-- Canonical principal coefficient function for `ζ'/ζ`: equal to the
analytic zero multiplicity at nontrivial zeros, `-1` at the pole `s = 1`,
and `0` elsewhere. -/
noncomputable def zetaLogDerivPrincipalCoeff (s : ℂ) : ℤ :=
  zetaLogDerivExpectedResidueIndex s

theorem zetaLogDerivPrincipalCoeff_of_zero
    {s : ℂ} (hs : IsNontrivialZetaZero s) :
    zetaLogDerivPrincipalCoeff s = (zetaGlobalZeroMultiplicity.mult s : ℤ) :=
  zetaLogDerivExpectedResidueIndex_of_zero hs

theorem zetaLogDerivPrincipalCoeff_one :
    zetaLogDerivPrincipalCoeff (1 : ℂ) = -1 :=
  zetaLogDerivExpectedResidueIndex_one

theorem zetaLogDerivPrincipalCoeff_elsewhere
    {s : ℂ} (hs : ¬ IsNontrivialZetaZero s) (hs1 : s ≠ 1) :
    zetaLogDerivPrincipalCoeff s = 0 :=
  zetaLogDerivExpectedResidueIndex_elsewhere hs hs1

/-! ### AN5: counted principal-part data from zero-set + admissibility -/

/-- Bundle the local zero/pole principal parts into rectangle-level data
indexed by the canonical singularity set. -/
noncomputable def countedPrincipalPartData
    {R : ZetaRectangle}
    (hAdm : R.StronglyAdmissibleForZeta)
    (Z : R.ZeroSetInside) :
    R.RectanglePrincipalPartData where
  stronglyAdmissible := hAdm
  singularities := R.canonicalSingularities Z
  principalCoeff := zetaLogDerivPrincipalCoeff
  localPrincipalPart := by
    intro s hs
    unfold canonicalSingularities at hs
    by_cases hpole : R.PoleInside
    · rw [if_pos hpole] at hs
      rw [Finset.mem_insert] at hs
      rcases hs with rfl | hsZ
      · rw [zetaLogDerivPrincipalCoeff_one]
        exact zetaLogDeriv_principalPartContinuous_at_one_unconditional
      · have hsInside : R.IsNontrivialZeroInside s := (Z.complete s).mp hsZ
        have hsNT : IsNontrivialZetaZero s := hsInside.1
        rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
        exact zetaLogDeriv_principalPartContinuous_at_nontrivial_zero hsNT
    · rw [if_neg hpole] at hs
      have hsInside : R.IsNontrivialZeroInside s := (Z.complete s).mp hs
      have hsNT : IsNontrivialZetaZero s := hsInside.1
      rw [zetaLogDerivPrincipalCoeff_of_zero hsNT]
      exact zetaLogDeriv_principalPartContinuous_at_nontrivial_zero hsNT
  singularities_complete := by
    intro s
    unfold IsCountedZetaSingularityInside canonicalSingularities
    by_cases hpole : R.PoleInside
    · rw [if_pos hpole]
      constructor
      · intro hs
        rw [Finset.mem_insert] at hs
        rcases hs with rfl | hsZ
        · exact Or.inr ⟨hpole, rfl⟩
        · exact Or.inl ((Z.complete s).mp hsZ)
      · intro hs
        rcases hs with hsInside | ⟨_, hs1⟩
        · rw [Finset.mem_insert]
          exact Or.inr ((Z.complete s).mpr hsInside)
        · rw [Finset.mem_insert]
          exact Or.inl hs1
    · rw [if_neg hpole]
      constructor
      · intro hs
        exact Or.inl ((Z.complete s).mp hs)
      · intro hs
        rcases hs with hsInside | ⟨hpole', _⟩
        · exact (Z.complete s).mpr hsInside
        · exact absurd hpole' hpole

/-! ## AO: Principal-part contour integral decomposition -/

/-! ### AO1: principal kernel and its rectangle integral -/

/-- The principal kernel `k / (z - a)` at singularity `a` with coefficient `k`. -/
noncomputable def principalKernel (k : ℤ) (a z : ℂ) : ℂ :=
  (k : ℂ) / (z - a)

/-- Integral of the principal kernel `k/(z-a)` around the rectangle's four
edges. -/
noncomputable def principalKernelRectangleIntegral
    (R : ZetaRectangle) (k : ℤ) (a : ℂ) : ℂ :=
  (∫ t in (0 : ℝ)..1,
      principalKernel k a (R.bottomEdge t) * deriv R.bottomEdge t)
  + (∫ t in (0 : ℝ)..1,
      principalKernel k a (R.rightEdge t) * deriv R.rightEdge t)
  + (∫ t in (0 : ℝ)..1,
      principalKernel k a (R.topEdge t) * deriv R.topEdge t)
  + (∫ t in (0 : ℝ)..1,
      principalKernel k a (R.leftEdge t) * deriv R.leftEdge t)

/-- Normalized principal-kernel integral `(1/2πi) ∮ k/(z-a) dz`. -/
noncomputable def normalizedPrincipalKernelRectangleIntegral
    (R : ZetaRectangle) (k : ℤ) (a : ℂ) : ℂ :=
  (twoPiI)⁻¹ * R.principalKernelRectangleIntegral k a

/-! ### AO2: single-kernel Cauchy-index theorem target -/

/-- For a singularity `a` strictly inside the rectangle (and not on the
boundary), the normalized principal-kernel integral equals its coefficient.
This is the residue-free Cauchy-index statement. -/
structure PrincipalKernelIntegralTheorem
    (R : ZetaRectangle) (k : ℤ) (a : ℂ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : ∀ z : ℂ, R.ContainsBoundary z → z ≠ a
  normalized_integral_eq_coeff :
    R.normalizedPrincipalKernelRectangleIntegral k a = (k : ℂ)

/-! ### AO3: vanishing-remainder integral target -/

/-- The normalized contour integral of `ζ'/ζ` minus the sum of normalized
principal-kernel integrals — i.e. the "holomorphic remainder" part of the
residue-theorem decomposition. -/
noncomputable def rectangleRemainderIntegral
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : ℂ :=
  R.normalizedRectangleLogDerivIntegral -
    P.singularities.sum
      (fun s => R.normalizedPrincipalKernelRectangleIntegral
        (P.principalCoeff s) s)

/-- After subtracting all principal kernels, the remaining contour integrand
has zero normalized integral.  This is the residue-free replacement for the
holomorphic-remainder part of the residue theorem. -/
def RectangleRemainderIntegralVanishes
    (R : ZetaRectangle) (P : R.RectanglePrincipalPartData) : Prop :=
  R.rectangleRemainderIntegral P = 0

/-! ### AO4: contour decomposition + assembled integral theorem -/

/-- Contour decomposition: the normalized `ζ'/ζ` integral splits into the
sum of normalized principal-kernel integrals. -/
structure RectanglePrincipalPartContourDecomposition
    (R : ZetaRectangle)
    (P : R.RectanglePrincipalPartData) : Prop where
  integral_decomposition :
    R.normalizedRectangleLogDerivIntegral =
      P.singularities.sum
        (fun s => R.normalizedPrincipalKernelRectangleIntegral
          (P.principalCoeff s) s)

/-- Assemble the contour decomposition + per-kernel Cauchy index into the
full residue-free rectangle argument principle. -/
noncomputable def RectanglePrincipalPartContourDecomposition.toIntegralTheorem
    {R : ZetaRectangle}
    {P : R.RectanglePrincipalPartData}
    (D : R.RectanglePrincipalPartContourDecomposition P)
    (HK :
      ∀ s : ℂ, s ∈ P.singularities →
        R.normalizedPrincipalKernelRectangleIntegral
          (P.principalCoeff s) s =
        (P.principalCoeff s : ℂ)) :
    R.RectanglePrincipalPartIntegralTheorem where
  ppData := P
  normalizedIntegral_eq_sum := by
    rw [D.integral_decomposition]
    push_cast
    exact Finset.sum_congr rfl (fun s hs => HK s hs)

/-! ### AO5: canonical rectangle theorem target -/

/-- Final residue-free rectangle argument principle target: the normalized
contour integral equals the sum of canonical principal coefficients over
the canonical singularity set. -/
def CanonicalRectanglePrincipalPartIntegralTheorem
    (R : ZetaRectangle) (Z : R.ZeroSetInside) : Prop :=
  R.normalizedRectangleLogDerivIntegral =
    (((R.canonicalSingularities Z).sum zetaLogDerivPrincipalCoeff : ℤ) : ℂ)

/-! ## AP: single-kernel Cauchy index targets -/

/-! ### AP1: unnormalized kernel theorem + adapter to normalized -/

/-- Unnormalized Cauchy index for a single principal kernel:
`∮ k / (z - a) dz = 2πi · k` for `a` strictly inside the rectangle. -/
structure PrincipalKernelUnnormalizedIntegralTheorem
    (R : ZetaRectangle) (k : ℤ) (a : ℂ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : ∀ z : ℂ, R.ContainsBoundary z → z ≠ a
  integral_eq :
    R.principalKernelRectangleIntegral k a = twoPiI * (k : ℂ)

/-- The unnormalized Cauchy-index theorem implies the normalized one. -/
noncomputable def PrincipalKernelUnnormalizedIntegralTheorem.toNormalized
    {R : ZetaRectangle} {k : ℤ} {a : ℂ}
    (H : R.PrincipalKernelUnnormalizedIntegralTheorem k a) :
    R.PrincipalKernelIntegralTheorem k a where
  inside := H.inside
  boundary_avoids := H.boundary_avoids
  normalized_integral_eq_coeff := by
    unfold normalizedPrincipalKernelRectangleIntegral
    rw [H.integral_eq]
    field_simp [twoPiI_ne_zero]

/-! ### AP2: unit kernel and its rectangle integral -/

/-- Unit principal kernel `1 / (z - a)`. -/
noncomputable def unitPrincipalKernel (a z : ℂ) : ℂ :=
  1 / (z - a)

/-- Integral of the unit kernel around the rectangle's four edges, defined
as the `k = 1` specialization of `principalKernelRectangleIntegral`. -/
noncomputable def unitPrincipalKernelRectangleIntegral
    (R : ZetaRectangle) (a : ℂ) : ℂ :=
  R.principalKernelRectangleIntegral 1 a

/-! ### AP3: Cauchy index theorem target for the unit kernel -/

/-- Cauchy index for the unit kernel around a rectangle:
`∮ dz / (z - a) = 2πi` for `a` strictly inside the rectangle.

This is the smallest remaining analytic theorem in the residue-free
argument-principle chain; once proved, general-`k` and the full rectangle
theorem follow by linearity and the contour decomposition. -/
structure UnitPrincipalKernelIntegralTheorem
    (R : ZetaRectangle) (a : ℂ) : Prop where
  inside : R.ContainsOpen a
  boundary_avoids : ∀ z : ℂ, R.ContainsBoundary z → z ≠ a
  integral_eq :
    R.unitPrincipalKernelRectangleIntegral a = twoPiI

/-! ### AQ1 (probe results, recorded as comment).

Mathlib survey for the unit-kernel rectangle integral:

* `circleIntegral.integral_sub_inv_of_mem_ball` (circle):
    `∮ z in C(c, R), (z - w)⁻¹ = 2πi` when `w ∈ ball c R`.

* `Complex.circleIntegral_div_sub_of_differentiable_on_off_countable`
  (Cauchy formula, circles):
    `(∮ z in C(c, R), f z / (z - w)) = 2πi · f w` for `w ∈ ball c R`.

* `Complex.integral_boundary_rect_eq_zero_of_continuousOn_of_differentiableOn`
  (Cauchy-Goursat for rectangles): boundary integral of a *holomorphic*
  function on a closed rectangle is `0`.  Does not directly apply here
  because the singularity at `a` is inside the rectangle.

* `Complex.circleIntegral_sub_center_inv_smul_eq_of_differentiable_on_annulus_off_countable`
  (annular Cauchy): equates circle integrals at different radii across an
  annulus.  Circle-to-circle only — not rectangle-to-circle.

* No `windingNumber` definition, no `Path`/contour-based winding-number
  Cauchy formula, and no rectangle-to-circle deformation theorem in Mathlib.

**Conclusion.** No direct Mathlib theorem produces the rectangle unit-kernel
integral.  Two viable routes:

(a) **Deform-to-small-circle.**  Choose `r > 0` so `closedBall a r ⊆ openRect`.
    Apply rectangle Cauchy-Goursat to the holomorphic function `1/(z - a)`
    on the punctured region `closedRect \ ball a r`, giving
    `(rectangle integral) - (∮_{C(a,r)} dz/(z-a)) = 0`.  Then the circle
    integral evaluates to `2πi` by `integral_sub_inv_of_mem_ball`.

(b) **Direct edge computation.**  Compute each of the four edge integrals
    as a complex-logarithm difference and assemble using `arg` bookkeeping.

Route (a) is the classical argument and the more tractable path in Lean.
Both are substantial multi-step proofs.  Deferred. -/

/-! ### AQ4: linearity of the kernel integral in the coefficient -/

/-- The principal-kernel rectangle integral is linear in the integer
coefficient: `∮ k/(z-a) dz = k · ∮ 1/(z-a) dz`. -/
theorem principalKernelRectangleIntegral_eq_int_mul_unit
    (R : ZetaRectangle) (k : ℤ) (a : ℂ) :
    R.principalKernelRectangleIntegral k a =
      (k : ℂ) * R.unitPrincipalKernelRectangleIntegral a := by
  have h_kernel : ∀ z : ℂ,
      principalKernel k a z = (k : ℂ) * principalKernel 1 a z := by
    intro z; unfold principalKernel; ring
  have edge_eq : ∀ edge : ℝ → ℂ,
      (∫ t in (0 : ℝ)..1, principalKernel k a (edge t) * deriv edge t) =
        (k : ℂ) *
          ∫ t in (0 : ℝ)..1, principalKernel 1 a (edge t) * deriv edge t := by
    intro edge
    rw [← intervalIntegral.integral_const_mul]
    refine intervalIntegral.integral_congr (fun t _ => ?_)
    rw [h_kernel]; ring
  unfold principalKernelRectangleIntegral unitPrincipalKernelRectangleIntegral
  rw [edge_eq R.bottomEdge, edge_eq R.rightEdge,
      edge_eq R.topEdge, edge_eq R.leftEdge]
  -- `ring_nf` normalizes the LHS but leaves `R.principalKernelRectangleIntegral 1 a`
  -- folded on the RHS; unfold it once more, then `ring` closes by
  -- distributivity over the four-edge sum.
  unfold principalKernelRectangleIntegral
  ring

/-! ### AQ4 (continued): unit theorem implies general-`k` theorem -/

/-- Given the unit-kernel Cauchy index, the general-`k` unnormalized
Cauchy index follows by linearity. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.toUnnormalized
    {R : ZetaRectangle} {a : ℂ}
    (H : R.UnitPrincipalKernelIntegralTheorem a) (k : ℤ) :
    R.PrincipalKernelUnnormalizedIntegralTheorem k a where
  inside := H.inside
  boundary_avoids := H.boundary_avoids
  integral_eq := by
    rw [principalKernelRectangleIntegral_eq_int_mul_unit, H.integral_eq]
    ring

/-- Given the unit-kernel Cauchy index, the general-`k` normalized
Cauchy index follows. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.toNormalizedAtCoeff
    {R : ZetaRectangle} {a : ℂ}
    (H : R.UnitPrincipalKernelIntegralTheorem a) (k : ℤ) :
    R.PrincipalKernelIntegralTheorem k a :=
  (H.toUnnormalized k).toNormalized

/-! ## AR: Unit-kernel theorem via deformation to a small interior circle -/

/-! ### AR1: small circle inside the rectangle -/

/-- A small closed disk centered at `a` lying strictly inside the open
rectangle.  The radius `r` is positive and the closed ball avoids the
boundary. -/
structure SmallCircleInsideRectangle
    (R : ZetaRectangle) (a : ℂ) where
  r : ℝ
  r_pos : 0 < r
  closedBall_subset_open :
    Metric.closedBall a r ⊆ {z : ℂ | R.ContainsOpen z}

/-- The set of points strictly inside the rectangle is open in `ℂ`. -/
theorem isOpen_containsOpen (R : ZetaRectangle) :
    IsOpen {z : ℂ | R.ContainsOpen z} := by
  have h1 : IsOpen {z : ℂ | R.left < z.re} :=
    isOpen_Ioi.preimage Complex.continuous_re
  have h2 : IsOpen {z : ℂ | z.re < R.right} :=
    isOpen_Iio.preimage Complex.continuous_re
  have h3 : IsOpen {z : ℂ | R.bottom < z.im} :=
    isOpen_Ioi.preimage Complex.continuous_im
  have h4 : IsOpen {z : ℂ | z.im < R.top} :=
    isOpen_Iio.preimage Complex.continuous_im
  exact h1.inter (h2.inter (h3.inter h4))

/-- Every point strictly inside the rectangle admits a small interior
disk. -/
theorem exists_smallCircleInsideRectangle
    {R : ZetaRectangle} {a : ℂ}
    (ha : R.ContainsOpen a) :
    Nonempty (R.SmallCircleInsideRectangle a) := by
  have hopen := isOpen_containsOpen R
  rw [Metric.isOpen_iff] at hopen
  obtain ⟨ε, hε_pos, hε_sub⟩ := hopen a ha
  refine ⟨{ r := ε / 2, r_pos := by linarith, closedBall_subset_open := ?_ }⟩
  intro z hz
  rw [Metric.mem_closedBall] at hz
  apply hε_sub
  rw [Metric.mem_ball]
  linarith

/-! ### AR2: unit-kernel circle integral -/

/-- Integral of the unit kernel `1/(z - a)` around the positively oriented
circle centered at `a` with radius `r`. -/
noncomputable def unitKernelCircleIntegral (a : ℂ) (r : ℝ) : ℂ :=
  ∮ z in C(a, r), (z - a)⁻¹

/-! ### AR3: circle integral evaluates to `2πi` -/

/-- The unit-kernel circle integral around `a` equals `2πi` for any positive
radius.  This is `circleIntegral.integral_sub_inv_of_mem_ball` applied at
the center. -/
theorem unitKernelCircleIntegral_eq_twoPiI
    (a : ℂ) {r : ℝ} (hr : 0 < r) :
    unitKernelCircleIntegral a r = twoPiI := by
  unfold unitKernelCircleIntegral twoPiI
  rw [circleIntegral.integral_sub_inv_of_mem_ball (Metric.mem_ball_self hr)]

/-! ### AR4: punctured-rectangle deformation theorem target -/

/-- Cauchy-Goursat-on-punctured-rectangle: the rectangle boundary integral of
`1/(z - a)` equals the corresponding small-circle integral around `a`.

This is the last hard analytic piece in the unit-kernel chain.  It is left
as a target (Prop) to be inhabited later by an annular Cauchy-Goursat
argument. -/
structure UnitKernelRectangleToCircleDeformation
    (R : ZetaRectangle) (a : ℂ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  rectangle_eq_circle :
    R.unitPrincipalKernelRectangleIntegral a =
      unitKernelCircleIntegral a C.r

/-! ### AR5: deformation + circle theorem ⇒ unit Cauchy index -/

/-- A rectangle-to-circle deformation, combined with the proved circle
integral, gives the unit principal-kernel Cauchy-index theorem. -/
noncomputable def UnitKernelRectangleToCircleDeformation.toUnitPrincipalKernelIntegralTheorem
    {R : ZetaRectangle} {a : ℂ}
    {C : R.SmallCircleInsideRectangle a}
    (D : R.UnitKernelRectangleToCircleDeformation a C) :
    R.UnitPrincipalKernelIntegralTheorem a where
  inside :=
    C.closedBall_subset_open (Metric.mem_closedBall_self C.r_pos.le)
  boundary_avoids := by
    intro z hz heq
    subst heq
    exact hz.2
      (C.closedBall_subset_open (Metric.mem_closedBall_self C.r_pos.le))
  integral_eq := by
    rw [D.rectangle_eq_circle]
    exact unitKernelCircleIntegral_eq_twoPiI a C.r_pos

/-! ## AS: Punctured-rectangle Cauchy-Goursat target -/

/-! ### AS1: punctured rectangle region (closed rectangle minus open ball) -/

/-- Closed rectangle with the open ball `ball a r` removed.  This is the
region on which the unit kernel `1/(z-a)` is holomorphic. -/
def puncturedRectangleRegion
    (R : ZetaRectangle) (a : ℂ) (r : ℝ) : Set ℂ :=
  {z : ℂ | R.ContainsClosed z ∧ z ∉ Metric.ball a r}

/-! ### AS2: analyticity of the unit kernel away from the singularity -/

/-- The unit principal kernel `1/(z - a)` is analytic at any point `z ≠ a`. -/
theorem analyticAt_unitPrincipalKernel_of_ne
    {a z : ℂ} (hz : z ≠ a) :
    AnalyticAt ℂ (fun w : ℂ => unitPrincipalKernel a w) z := by
  unfold unitPrincipalKernel
  have h_id : AnalyticAt ℂ (fun w : ℂ => w) z := analyticAt_id
  have h_const_a : AnalyticAt ℂ (fun _ : ℂ => a) z := analyticAt_const
  have h_den : AnalyticAt ℂ (fun w : ℂ => w - a) z := h_id.sub h_const_a
  have h_num : AnalyticAt ℂ (fun _ : ℂ => (1 : ℂ)) z := analyticAt_const
  exact h_num.div h_den (sub_ne_zero.mpr hz)

/-! ### AS3: Cauchy-Goursat-on-punctured-rectangle target -/

/-- Cauchy-Goursat on the rectangle with a circular hole around `a`:
the outer rectangle boundary integral of the unit kernel equals the inner
small-circle boundary integral. -/
structure PuncturedRectangleCauchyGoursat
    (R : ZetaRectangle) (a : ℂ)
    (C : R.SmallCircleInsideRectangle a) : Prop where
  boundary_integral_eq :
    R.unitPrincipalKernelRectangleIntegral a =
      unitKernelCircleIntegral a C.r

/-- The Cauchy-Goursat-on-punctured-rectangle theorem upgrades to the
deformation interface. -/
noncomputable def PuncturedRectangleCauchyGoursat.toDeformation
    {R : ZetaRectangle} {a : ℂ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitKernelRectangleToCircleDeformation a C where
  rectangle_eq_circle := H.boundary_integral_eq

/-! ### AS4: combined constructor — punctured CG ⇒ unit Cauchy index -/

/-- A punctured-rectangle Cauchy-Goursat inhabitant gives the unit
principal-kernel Cauchy-index theorem directly. -/
noncomputable def UnitPrincipalKernelIntegralTheorem.of_puncturedCauchyGoursat
    {R : ZetaRectangle} {a : ℂ}
    {C : R.SmallCircleInsideRectangle a}
    (H : R.PuncturedRectangleCauchyGoursat a C) :
    R.UnitPrincipalKernelIntegralTheorem a :=
  H.toDeformation.toUnitPrincipalKernelIntegralTheorem

