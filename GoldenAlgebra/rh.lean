/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ AFZ low finite-IBP domination from AFZ source +
AFZ low_eq + first-zero gap.** -/
theorem XiLowResidualFiniteIBPDominationAwayFromZeros_of_AFZ
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (Hstarts : DzeroStartsAfter Dzero 14)
    (Hsrc : XiHadamardLogDerivativeSourceAFZ)
    (HlowEq :
      LowFiniteStieltjesFormulaOnFirstZeroGapAFZ
        Dzero T0 Hsrc.zeroContribution) :
    XiLowResidualFiniteIBPDominationAwayFromZeros
      Dzero T0 honestZeroDensityModelTwoPi := by
  have hT0_le_11 : T0 тЙд 11 := by linarith
  have Hgap : FirstZeroGapIdentityOn Dzero T0 11 14 :=
    FirstZeroGapIdentityOn_of_startsAfter Hstarts hT0_pos hT0_le_11
  refine тЯи?_тЯй
  intro z hz hne
  have hy : 0 < z.im := hz.1
  have hlog := Hsrc.logDeriv_eq_zeroContribution z hy hne
  have hlow := HlowEq.formula z hz hne Hgap
  have h_res_eq :
      (xiResidualError honestZeroDensityModelTwoPi z).im
        = lowFiniteFluctuationContribution Dzero T0 z := by
    unfold xiResidualError
    rw [hlog, honestZeroDensityModelTwoPi_model_eq]
    exact hlow
  have h_int_eq :=
    lowFiniteIntegralIm_eq_derivativeSide Dzero T0 hT0_pos hT0_le_10 hy
  have h_contrib_eq :
      lowFiniteFluctuationContribution Dzero T0 z
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14 := by
    unfold lowFiniteFluctuationContribution
    rw [h_int_eq]
  rw [h_res_eq, h_contrib_eq]
  exact abs_add _ _

