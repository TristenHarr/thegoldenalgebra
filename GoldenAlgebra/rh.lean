-- ┬зCDXXXIX. Algebra: the `+ 1/2` correction
-- =====================================================================

/-- тнР **PROVED тАФ algebra for the ╬╛ correction term**, valid for
`s тЙа 0` and `s тЙа 1`. The identity fails at s = 0 and s = 1 in Lean's
totalized arithmetic (`1/0 = 0`), because the `+ 1/2` correction
kicks in exactly when the `s┬╖(s-1)` factor vanishes. -/
theorem xi_completedZeta_correction_algebra
    {s : тДВ} (hs0 : s тЙа 0) (hs1 : s тЙа 1) :
    (1 / 2 : тДВ) * s * (s - 1)
        * (completedRiemannZetaтВА s - 1 / s - 1 / (1 - s))
      = (1 / 2 : тДВ) * s * (s - 1) * completedRiemannZetaтВА s + 1 / 2 := by
  have h1s : (1 : тДВ) - s тЙа 0 := sub_ne_zero.mpr (Ne.symm hs1)
  field_simp
  ring

