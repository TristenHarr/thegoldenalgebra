-- =====================================================================
-- On `lowCompactRegion`, `x┬▓ + y┬▓ Ôëñ 16` (from `|x| + y Ôëñ 4`), so each
-- normalized cloud term `2/(x┬▓+╬│┬▓+y┬▓) ÔëÑ 2/(╬│┬▓+16)`. Summing over
-- `zeros100ceil` gives the uniform lower bound
--   `cloudLBConst := ╬ú_{╬│ Ôêê zeros100ceil} 2/(╬│┬▓+16) Ôëê 0.0370`.
-- Cloud alone is insufficient (`C Ôëê 0.0473`, gap Ôëê -0.0103). The
-- smooth lower bound (┬ºCCXCIII-B, separate section) supplies the
-- additional Ôëê 0.0125 to close with margin Ôëê 0.0024.

/-- Ô¡É **PROVED ÔÇö `x┬▓ + y┬▓ Ôëñ 16` on the low compact region.** Follows
from `(|x| + y)┬▓ Ôëñ 16` and dropping the non-negative cross term `2|x|y`. -/
lemma lowCompactRegion_sq_re_add_sq_im_le_16
    {z : Ôäé} (hz : lowCompactRegion z) :
    z.re ^ 2 + z.im ^ 2 Ôëñ 16 := by
  have hy : 0 < z.im := hz.1
  have h_sum : 2 * (1 + |z.re| + z.im) Ôëñ 10 := hz.2
  have h_xy : |z.re| + z.im Ôëñ 4 := by linarith
  have h_abs_nn : (0 : ÔäØ) Ôëñ |z.re| := abs_nonneg _
  have h_y_nn : (0 : ÔäØ) Ôëñ z.im := le_of_lt hy
  have h_sq_re : z.re ^ 2 = |z.re| ^ 2 := (sq_abs z.re).symm
  rw [h_sq_re]
  nlinarith [sq_nonneg (|z.re| + z.im), h_abs_nn, h_y_nn, h_xy,
             mul_nonneg h_abs_nn h_y_nn]

/-- Ô¡É **PROVED ÔÇö generic pointwise list sum bound.** -/
lemma list_sum_le_sum_of_pointwise
    {╬▒ : Type*} {L : List ╬▒} {f g : ╬▒ ÔåÆ ÔäØ}
    (h : ÔêÇ a Ôêê L, f a Ôëñ g a) :
    (L.map f).sum Ôëñ (L.map g).sum := by
  induction L with
  | nil => simp
  | cons a rest ih =>
    simp only [List.map_cons, List.sum_cons]
    have h_a : f a Ôëñ g a := h a (by simp)
    have h_rest : ÔêÇ b Ôêê rest, f b Ôëñ g b :=
      fun b hb => h b (List.mem_cons_of_mem a hb)
    have h_rest_le := ih h_rest
    linarith

/-- Ô¡É **PROVED ÔÇö per-zero cloud lower bound.** -/
lemma simpleCloudSumNorm_term_lower
    {x y ╬│ : ÔäØ} (hxy : x ^ 2 + y ^ 2 Ôëñ 16) (hy : 0 < y) :
    (2 : ÔäØ) / (╬│ ^ 2 + 16) Ôëñ 2 / (x ^ 2 + ╬│ ^ 2 + y ^ 2) := by
  have h_xsq_nn : (0 : ÔäØ) Ôëñ x ^ 2 := sq_nonneg x
  have h_ysq_pos : (0 : ÔäØ) < y ^ 2 := by positivity
  have h_gamma_sq_nn : (0 : ÔäØ) Ôëñ ╬│ ^ 2 := sq_nonneg ╬│
  have h_denom_pos : (0 : ÔäØ) < x ^ 2 + ╬│ ^ 2 + y ^ 2 := by linarith
  have h_denom_target_pos : (0 : ÔäØ) < ╬│ ^ 2 + 16 := by positivity
  have h_denom_le : x ^ 2 + ╬│ ^ 2 + y ^ 2 Ôëñ ╬│ ^ 2 + 16 := by linarith
  rw [div_le_div_iffÔéÇ h_denom_target_pos h_denom_pos]
  nlinarith [h_denom_le, h_denom_pos, h_denom_target_pos]

/-- **Cloud lower-bound constant**: `╬ú_{╬│ Ôêê zeros100ceil} 2/(╬│┬▓ + 16) Ôëê 0.0370`. -/
noncomputable def cloudLBConst : ÔäØ :=
  (zeros100ceil.map (fun ╬│ : ÔäØ => 2 / (╬│ ^ 2 + 16))).sum

/-- ­ƒîƒ **PROVED ÔÇö uniform cloud lower bound** on the low compact region:
`cloudLBConst Ôëñ simpleCloudSumNorm zeros100ceil z.re z.im`. -/
theorem simpleCloudSumNorm_zeros100ceil_lower_bound
    {z : Ôäé} (hz : lowCompactRegion z) :
    cloudLBConst Ôëñ simpleCloudSumNorm zeros100ceil z.re z.im := by
  unfold cloudLBConst simpleCloudSumNorm
  have hy : 0 < z.im := hz.1
  have hxy : z.re ^ 2 + z.im ^ 2 Ôëñ 16 :=
