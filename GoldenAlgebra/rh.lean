-- =====================================================================
-- ┬зCCXCIX. Corrected low split + HlowB proof
-- =====================================================================
-- ┬зCCXCVIII split `XiLowResidualFiniteIBPEquality` into:
--   A : residual.im = integral.im                   (xi-side)
--   B : integral.im = boundary + deriv side         (proposed pure-IBP)
--
-- **Critical audit finding (this section).** Piece B as stated is
-- provably FALSE in general. Kernel Im compatibility says
--   `Im (pairedCauchyComplexKernelTrue u (UHP x y)) = pairedCauchyImKernelDeriv x y u`
-- (pointwise, from `pairedCauchyComplexKernelTrue_imCompatible`), so
-- `(complexDensityTailPartial true-kernel S 11 14 z).im` is the
-- derivative-side integral on `[11, 14]` тАФ there is no boundary term
-- from the IBP step alone. The boundary term must live on the
-- xi-side.
--
-- This section keeps ┬зCCXCVIII's structures (they remain logically
-- well-formed, just under-inhabited) and adds the CORRECTED split:
--
--   B' : integral.im = derivative side              -- PROVED here
--   A' : residual.im = boundary + integral.im       -- xi-side w/ boundary
--   composition: A' + B' тЖТ XiLowResidualFiniteIBPEquality
--
-- Adds:
--   lowFiniteIntegralIm_eq_derivativeSide                       тАФ PROVED (B')
--   XiLowResidualImEqBoundaryAddIntegralIm                      тАФ corrected A'
--   XiLowResidualFiniteIBPEquality_of_correctedSplit            тАФ composition
--   XiPullbackAntiHerglotzTarget_..._lowCorrectedSplit          тАФ final front door

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ HlowB (corrected).** On the low compact region,
the Im of the true-kernel partial of the finite fluctuation primitive
over `[11, 14]` equals the derivative-side integral
`lowFirstZeroDerivativeSide`. No boundary term.

Chain:
1. integrability of true-kernel integrand on `[11, 14]` (via
   `finiteFluctuationPrimitive_trueKernel_intervalIntegrable`);
2. integrability of wrap-kernel integrand on `[11, 14]` (via
   `wrapKernel_intervalIntegrable_of_real_derivative_integrable`
   applied to the real integrand from
   `finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic`);
3. kernel Im compat transfers Im of true partial to Im of wrap
   partial (`complexDensityTailPartial_im_eq_of_kernelImCompatible`
   with `pairedCauchyComplexKernelTrue_imCompatible`);
4. wrap partial Im = real derivative-side partial
   (`complexDensityTailPartial_im_eq_derivativeSidePartial`);
5. `lowFirstZeroDerivativeSide_eq_partial` is `rfl`. -/
theorem lowFiniteIntegralIm_eq_derivativeSide
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    {z : тДВ} (hy : 0 < z.im) :
    (complexDensityTailPartial pairedCauchyComplexKernelTrue
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        11 14 z).im
      = lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14 := by
  have hzUHP : upperHalfPoint z.re z.im = z := upperHalfPoint_re_im z
  have hT0_le_11 : T0 тЙд (11 : тДЭ) := by linarith
  have h11_le_14 : (11 : тДЭ) тЙд 14 := by norm_num
  have h_true_int :
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelTrue u (upperHalfPoint z.re z.im)
                    * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : тДЭ) : тДВ))
        MeasureTheory.volume 11 14 := by
    rw [hzUHP]
    exact finiteFluctuationPrimitive_trueKernel_intervalIntegrable
      Dzero T0 11 14 z hT0_pos hT0_le_11 h11_le_14 (ne_of_gt hy)
  have hreal :
      IntervalIntegrable
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
                    * pairedCauchyImKernelDeriv z.re z.im u)
        MeasureTheory.volume 11 14 :=
    finiteFluctuationPrimitive_kernelDeriv_intervalIntegrable_generic
      Dzero T0 11 14 z.re z.im hT0_pos hT0_le_11 h11_le_14 hy
  have h_deriv_int :
      IntervalIntegrable
        (fun u => pairedCauchyComplexKernelDeriv u (upperHalfPoint z.re z.im)
                    * ((Phase1IBP.finiteFluctuationPrimitive Dzero T0 u : тДЭ) : тДВ))
        MeasureTheory.volume 11 14 :=
    wrapKernel_intervalIntegrable_of_real_derivative_integrable
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14 hreal
  have h_im_eq :
      (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im
        =
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im :=
    complexDensityTailPartial_im_eq_of_kernelImCompatible
      pairedCauchyComplexKernelTrue_imCompatible
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14 h_true_int h_deriv_int
  have h_deriv_eq :
      (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im
        =
      Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        z.re z.im 11 14 :=
    complexDensityTailPartial_im_eq_derivativeSidePartial
      (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
      z.re z.im 11 14
  calc (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14 z).im
      = (complexDensityTailPartial pairedCauchyComplexKernelTrue
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im := by rw [hzUHP]
    _ = (complexDensityTailPartial pairedCauchyComplexKernelDeriv
          (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u) 11 14
          (upperHalfPoint z.re z.im)).im := h_im_eq
    _ = Phase1IBP.derivativeSidePartial
        (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
        z.re z.im 11 14 := h_deriv_eq
    _ = lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14 :=
        (lowFirstZeroDerivativeSide_eq_partial Dzero T0 z.re z.im 11 14).symm

/-- ЁЯУж **`XiLowResidualImEqBoundaryAddIntegralIm` (corrected A').** The
xi-side residual decomposition that DOES include the boundary term:
`Im(residual) = boundary + Im(true-kernel partial on [11, 14])` on the
low compact region. This is the actual content of the xi explicit
formula on the bounded interval тАФ the boundary `k(11)┬╖S(T0, 11)` comes
from the residual decomposition itself, not from any IBP rearrangement
of the integral. -/
structure XiLowResidualImEqBoundaryAddIntegralIm
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_im_eq_boundary_add_integral :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (xiResidualError M z).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ bridge from corrected split to master
equality.** Combines A' (xi-side residual = boundary + integral) with
B' (the proved integral = derivative-side identity) to produce
`XiLowResidualFiniteIBPEquality`. -/
theorem XiLowResidualFiniteIBPEquality_of_correctedSplit
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    {M : CloudDensityTailModelDecomposition}
    (HA : XiLowResidualImEqBoundaryAddIntegralIm Dzero T0 M) :
    XiLowResidualFiniteIBPEquality Dzero T0 M := by
  refine тЯи?_тЯй
  intro z hz
