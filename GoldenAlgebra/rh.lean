    XiResidualLowIBPRepresentationAt 11 14 (1 / 2)
      honestZeroDensityModelTwoPi := by
  refine тЯи?_тЯй
  intro z hz
  have hy : 0 < z.im := hz.1
  have hregime10 : 2 * (1 + |z.re| + z.im) тЙд 10 := hz.2
  have hregime11 : 2 * (1 + |z.re| + z.im) тЙд 11 := by linarith
