      2 * (1 + |z.re| + z.im) Ôëñ T ÔåÆ
        errorBound z.im T Ôëñ -(model z).im

/-- Ô¡É **PROVED ÔÇö bundle Ôƒ╣ `FirstZeroBandCertificate`** at `gamma1`
(any `╬│Ôéü ÔëÑ 10`). Dispatches by 4-way case analysis on `T`. -/
noncomputable def firstZeroBandCert_from_inputs
    (model : Ôäé ÔåÆ Ôäé) (errorBound : ÔäØ ÔåÆ ÔäØ ÔåÆ ÔäØ)
    (gamma1 : ÔäØ) (h_10_le_gamma1 : 10 Ôëñ gamma1)
    (I : FirstZeroBandCertInputs model errorBound) :
    FirstZeroBandCertificate where
  Tmin := 2 * Real.pi
  Tmax := 10
  gamma1 := gamma1
  Tmin_ge_two_pi := le_refl _
  Tmin_le_Tmax := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  Tmax_le_gamma1 := h_10_le_gamma1
