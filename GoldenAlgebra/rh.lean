  have h_exp_le : Real.exp (9/25) ≤ 25/16 := by
    have := mul_le_mul_of_nonneg_right h_1625 (le_of_lt h_exp_pos)
    rw [inv_mul_cancel₀ (ne_of_gt h_exp_pos)] at this
    linarith
  have h_10_2pi_ge : (25/16 : ℝ) ≤ 10 / (2 * Real.pi) := by
