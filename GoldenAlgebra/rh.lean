  have h_44_nn : (0 : тДЭ) тЙд (74 / 163 : тДЭ) := by norm_num
  have h_inv_nn : (0 : тДЭ) тЙд 1 / (2 * Real.pi) := by
    have h2pi_pos : (0 : тДЭ) < 2 * Real.pi := by linarith [Real.pi_pos]
    positivity
  calc (259 / 3586 : тДЭ)
      = (7 / 44) * (74 / 163) := by norm_num
    _ тЙд (1 / (2 * Real.pi)) * Real.log (5 / Real.pi) :=
        mul_le_mul h_inv h_log h_44_nn h_inv_nn
