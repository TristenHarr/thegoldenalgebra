      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 T z L тИз
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L
  low_value :
    тИА z : тДВ,
      lowCompactRegion z тЖТ
      (ZC z -
          (cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z)).im
        = lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11
          + (complexDensityTailPartial pairedCauchyComplexKernelTrue
              (fun u => Phase1IBP.finiteFluctuationPrimitive Dzero T0 u)
              11 14 z).im

/-- ЁЯМЯЁЯМЯ **PROVED тАФ `ZeroContributionStieltjesFormula` from
`StieltjesZeroContributionData`.** -/
theorem ZeroContributionStieltjesFormula_of_data
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    (S : StieltjesZeroContributionData Dzero T0) :
    ZeroContributionStieltjesFormula Dzero T0 S.ZC :=
  { tail_formula := тЯиS.tail_valueтЯй
    low_formula := тЯиS.low_valueтЯй }

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PATH B
FINAL FRONT DOOR (Hadamard source + independent Stieltjes tail/low)**.

Path B is now in its most decomposed form: four genuinely
distinguishable analytic inputs, plus the parallel-agent log envelopes
and trivial data-side gap.

```
hTuring + hHighLog                                 (parallel agent тАФ log envelopes)
+ Hsrc  : XiHadamardLogDerivativeSource             (A: Hadamard product log-deriv)
+ Htail : StieltjesTailContributionData ... ZC      (B1: tail Stieltjes split)
+ Hlow  : StieltjesLowContributionData ... ZC       (B2: low finite Stieltjes split)
+ h_Z_ge_15                                          (trivial)
тЯ╣ XiPullbackAntiHerglotzTarget
```

B1 (tail) and B2 (low) can be attacked independently. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesTailLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : тИА i : тДХ, (15 : тДЭ) тЙд Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (Htail : StieltjesTailContributionData Dzero 10 Hsrc.zeroContribution)
    (Hlow : StieltjesLowContributionData Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesFormula
    Dzero h_Z_ge_15 hTuring hHighLog Hsrc
    (ZeroContributionStieltjesFormula_of_tail_low_data Htail Hlow)

-- =====================================================================
-- ┬зCCCX. Regional tail Stieltjes data + bridge bypassing global form
-- =====================================================================
-- `StieltjesTailContributionData` and `XiModelTailExplicitFormula` are
-- region-agnostic тАФ they quantify over ALL `T` with `regime`, including
-- small `T` where convergence may require non-existent log envelopes.
-- The actual consumers only need mid (`T = canonicalAdaptiveT z` with
-- `10 тЙд T тЙд 140`) and high (`T тЙе 140`).
--
-- This section adds the regional Props (`XiMidHighTailExplicitFormula`,
-- `StieltjesMidHighTailContributionData`), bridges them through to the
-- corrected-split front door, and separates equality from convergence
-- so the Stieltjes equality theorem doesn't have to re-prove convergence
-- already covered by `trueKernelComplexTail_converges_at_of_logEnvelope`.

/-- ЁЯУж **`XiMidHighTailExplicitFormula`** тАФ regional analogue of
`XiModelTailExplicitFormula`. Covers mid (at `canonicalAdaptiveT z`)
and high (`T тЙе 140`) only тАФ matches actual use cases. -/
structure XiMidHighTailExplicitFormula
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  mid_formula :
    тИА {z : тДВ},
      0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L тИз
        logDerivativeResponse XiPullback z = M.model z + L
  high_formula :
    тИА {z : тДВ} {T : тДЭ},
      140 тЙд T тЖТ
      0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 T z L тИз
        logDerivativeResponse XiPullback z = M.model z + L

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ bridge from regional formula to
`XiLogDerivativeModelTailDecomposition`.** Direct unpacking of the
mid/high fields. Bypasses the over-strong global
`XiModelTailExplicitFormula`. -/
theorem XiLogDerivativeModelTailDecomposition_of_midHighTailFormula
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    {M : CloudDensityTailModelDecomposition}
    (H : XiMidHighTailExplicitFormula Dzero T0 M) :
    XiLogDerivativeModelTailDecomposition Dzero T0 M := by
  refine тЯи?_, ?_тЯй
  ┬╖ intro z T hT hy hr
    obtain тЯиL, hL, hdтЯй := H.high_formula hT hy hr
    exact тЯиL, hL.tendsto_tail, hdтЯй
  ┬╖ intro z hy hm
    obtain тЯиL, hL, hdтЯй := H.mid_formula hy hm
    exact тЯиL, hL.tendsto_tail, hdтЯй

/-- ЁЯУж **`StieltjesMidHighTailContributionData`** тАФ regional Stieltjes
identification of the zero contribution. Mid uses `canonicalAdaptiveT z`,
high uses any `T тЙе 140`. -/
structure StieltjesMidHighTailContributionData
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  mid_tail :
    тИА {z : тДВ},
      0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L тИз
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L
  high_tail :
    тИА {z : тДВ} {T : тДЭ},
      140 тЙд T тЖТ
      0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 T z L тИз
        ZC z =
          cloudModel zeros100ceil z
            + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
            + L

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `XiMidHighTailExplicitFormula` from Hadamard
source + regional Stieltjes data** (at the honest twoPi model). -/
theorem XiMidHighTailExplicitFormula_of_hadamardSource_and_midHighTailData
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ}
    (Hsrc : XiHadamardLogDerivativeSource)
    (Htail :
      StieltjesMidHighTailContributionData
        Dzero T0 Hsrc.zeroContribution) :
    XiMidHighTailExplicitFormula
      Dzero T0 honestZeroDensityModelTwoPi := by
  refine тЯи?_, ?_тЯй
  ┬╖ intro z hy hm
    obtain тЯиL, hL, hZтЯй := Htail.mid_tail hy hm
    refine тЯиL, hL, ?_тЯй
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]
  ┬╖ intro z T hT hy hr
    obtain тЯиL, hL, hZтЯй := Htail.high_tail hT hy hr
    refine тЯиL, hL, ?_тЯй
    rw [Hsrc.logDeriv_eq_zeroContribution z hy, hZ,
        honestZeroDensityModelTwoPi_model_eq z]

/-- ЁЯУж **`StieltjesMidHighTailEquality`** тАФ Stieltjes equality only,
given a converged `L`. Separates the equality content from the
convergence content (which comes from log envelopes / Turing). -/
structure StieltjesMidHighTailEquality
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (ZC : тДВ тЖТ тДВ) : Prop where
  mid_eq :
    тИА {z : тДВ} {L : тДВ},
      0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L
  high_eq :
    тИА {z : тДВ} {T : тДЭ} {L : тДВ},
      140 тЙд T тЖТ
      0 < z.im тЖТ
      2 * (1 + |z.re| + z.im) тЙд T тЖТ
      XiFluctuationTailValue Dzero T0 T z L тЖТ
      ZC z =
        cloudModel zeros100ceil z
          + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z
          + L

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `StieltjesMidHighTailContributionData` from
convergence + equality.** Convergence supplies `L`; equality provides
the Stieltjes identification.

The convergence hypothesis `Hconv_mid` / `Hconv_high` is exactly what
the existing `trueKernelComplexTail_converges_at_of_logEnvelope` machinery
discharges from `hTuring` / `hHighLog` log envelopes. -/
theorem StieltjesMidHighTailContributionData_of_convergence_and_equality
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : тДЭ} {ZC : тДВ тЖТ тДВ}
    (Hconv_mid :
      тИА {z : тДВ},
        0 < z.im тЖТ
        (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
          2 * (1 + |z.re| + z.im) тЙд T) тЖТ
        тИГ L : тДВ, XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L)
    (Hconv_high :
      тИА {z : тДВ} {T : тДЭ},
        140 тЙд T тЖТ
        0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        тИГ L : тДВ, XiFluctuationTailValue Dzero T0 T z L)
    (Heq : StieltjesMidHighTailEquality Dzero T0 ZC) :
    StieltjesMidHighTailContributionData Dzero T0 ZC := by
  refine тЯи?_, ?_тЯй
  ┬╖ intro z hy hm
    obtain тЯиL, hLтЯй := Hconv_mid hy hm
    exact тЯиL, hL, Heq.mid_eq hy hm hLтЯй
  ┬╖ intro z T hT hy hr
    obtain тЯиL, hLтЯй := Hconv_high hT hy hr
    exact тЯиL, hL, Heq.high_eq hT hy hr hLтЯй

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PATH B
FINAL FRONT DOOR (regional mid/high tail + low)**.

Replaces the over-strong global `StieltjesTailContributionData` with
the regionally-correct `StieltjesMidHighTailContributionData`. The
Stieltjes theorem now matches the actual analytic use cases тАФ mid at
canonical T, high at any T тЙе 140 тАФ without quantifying over irrelevant
small T.

```
hTuring + hHighLog                                      (parallel agent)
+ Hsrc       : XiHadamardLogDerivativeSource             (A)
+ HtailMidHi : StieltjesMidHighTailContributionData ... ZC   (B1 regional)
+ Hlow       : StieltjesLowContributionData ... ZC       (B2)
+ h_Z_ge_15                                              (trivial)
тЯ╣ XiPullbackAntiHerglotzTarget
```

The mid/high Stieltjes target is now matched to actual regimes. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_hadamardAndStieltjesMidHighTailLow
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData)
    (h_Z_ge_15 : тИА i : тДХ, (15 : тДЭ) тЙд Dzero.toFluctuationMeasureData.Z i)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero 10 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hsrc : XiHadamardLogDerivativeSource)
    (HtailMidHi :
      StieltjesMidHighTailContributionData
        Dzero 10 Hsrc.zeroContribution)
    (Hlow :
      StieltjesLowContributionData
        Dzero 10 Hsrc.zeroContribution) :
    XiPullbackAntiHerglotzTarget := by
  have Htail_fmla :
      XiMidHighTailExplicitFormula
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiMidHighTailExplicitFormula_of_hadamardSource_and_midHighTailData
      Hsrc HtailMidHi
  have Htail_decomp :
      XiLogDerivativeModelTailDecomposition
        Dzero 10 honestZeroDensityModelTwoPi :=
    XiLogDerivativeModelTailDecomposition_of_midHighTailFormula Htail_fmla
  have HlowA :
      XiLowResidualImEqBoundaryAddIntegralIm
        Dzero 10 honestZeroDensityModelTwoPi := by
    refine тЯи?_тЯй
    intro z hz
    have hy : 0 < z.im := hz.1
    have h_resid :
        (xiResidualError honestZeroDensityModelTwoPi z).im
          = (Hsrc.zeroContribution z
              - honestZeroDensityModelTwoPi.model z).im := by
      unfold xiResidualError
      rw [Hsrc.logDeriv_eq_zeroContribution z hy]
    rw [h_resid, honestZeroDensityModelTwoPi_model_eq z]
    exact Hlow.low_value z hz
  exact XiPullbackAntiHerglotzTarget_of_twoPiModel_logDerivativeDecomposition_lowCorrectedSplit
    Dzero h_Z_ge_15 hTuring hHighLog Htail_decomp HlowA

-- =====================================================================
-- ┬зCCCXI. B1-conv: tail convergence from log envelopes
-- =====================================================================
-- Discharges the convergence half of `StieltjesMidHighTailContributionData`
-- using existing `trueKernelComplexTail_converges_at_of_logEnvelope`
-- + `hTuring` / `hHighLog`. After this, B1's only remaining content is
-- `StieltjesMidHighTailEquality`.

/-- ЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ mid convergence at canonical T from `hTuring`.**
For every `z` in the adaptive region, `XiFluctuationTailValue` exists at
`canonicalAdaptiveT z`. Convergence is supplied by the log-envelope
machinery applied to the Turing bound at the canonical T. -/
theorem XiFluctuationTailValue_exists_mid_of_turing
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2) :
    тИА {z : тДВ},
      0 < z.im тЖТ
      (тИГ T : тДЭ, 10 тЙд T тИз T тЙд 140 тИз
        2 * (1 + |z.re| + z.im) тЙд T) тЖТ
      тИГ L : тДВ,
        XiFluctuationTailValue Dzero T0 (canonicalAdaptiveT z) z L := by
  intro z hy hmid
  have hc := canonicalAdaptiveT_spec hmid
  have h10 : 10 тЙд canonicalAdaptiveT z := hc.1
  have h140 : canonicalAdaptiveT z тЙд 140 := hc.2.1
  have hregime : 2 * (1 + |z.re| + z.im) тЙд canonicalAdaptiveT z := hc.2.2
  have hT0leT : T0 тЙд canonicalAdaptiveT z := by linarith
  have hTpos : 0 < canonicalAdaptiveT z := by linarith
  have hEnv :
      тИАс╢а u in Filter.atTop,
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD (canonicalAdaptiveT z)).1 * Real.log u
              + (slabCD (canonicalAdaptiveT z)).2 := by
    filter_upwards [Filter.eventually_ge_atTop (canonicalAdaptiveT z)] with u hu
    exact hTuring h10 h140 hy hregime hu
  obtain тЯиL, hLтЯй :=
    trueKernelComplexTail_converges_at_of_logEnvelope
      Dzero T0 hT0_pos hT0leT hTpos hy hEnv
  exact тЯиL, тЯиhLтЯйтЯй

