/-- Standard fixed-side Backlund rectangle.  The finite table only has to
choose the vertical interval; the horizontal sides are fixed at `-1` and
`2`. -/
def backlundFixedSideRectangle
    (bottom top : вДЭ) (hbottom_lt_top : bottom < top) :
    ZetaRectangle where
  left := -1
  right := 2
  bottom := bottom
  top := top
  hleft_lt_right := by norm_num
  hbottom_lt_top := hbottom_lt_top

theorem backlundFixedSideRectangle_left_lt_zero
    {bottom top : вДЭ} {hbottom_lt_top : bottom < top} :
    (backlundFixedSideRectangle bottom top hbottom_lt_top).left < 0 := by
  norm_num [backlundFixedSideRectangle]

theorem backlundFixedSideRectangle_one_lt_right
    {bottom top : вДЭ} {hbottom_lt_top : bottom < top} :
    1 < (backlundFixedSideRectangle bottom top hbottom_lt_top).right := by
  norm_num [backlundFixedSideRectangle]

/-- If a canonical argument index is certified equal to a natural number,
then Lean's nonnegative-index conversion returns that same natural
number. -/
theorem backlund_argumentIndexNat_eq_of_eq_nat
    {R : ZetaRectangle}
    {hleft : R.left < 0}
    {hright : 1 < R.right}
    {hbottom_nonneg : 0 вЙ§ R.bottom}
    {hgood : GoodHeight R.top}
    (F : R.CanonicalZetaArgumentPrincipleFormula
      hleft hright hbottom_nonneg hgood)
    (HN :
      @ZetaRectangle.CanonicalZetaArgumentPrincipleNatFormula
        R hleft hright hbottom_nonneg hgood F)
    {n : вДХ} (h : F.argumentIndex = (n : вД§)) :
    F.argumentIndexNat HN = n := by
  have hcast := F.argumentIndexNat_cast HN
  rw [h] at hcast
  exact Int.ofNat.inj hcast

