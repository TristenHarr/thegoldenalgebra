  · simp only [if_pos h80]
    exact closedFormSErrorBoundCD_le_neg_model_im_of_slabSimple
      M hM_zeros nineSlabSimpleCerts_zeros100ceil.poly_48_80
      h48_le h80 hT_2pi hy hreg
  push_neg at h80
  have h80_le : (80 : ℝ) ≤ T := le_of_lt h80
  rw [if_neg (not_le.mpr h80)]
  exact closedFormSErrorBoundCD_le_neg_model_im_of_slabSimple
    M hM_zeros nineSlabSimpleCerts_zeros100ceil.poly_80_140
    h80_le hT140 hT_2pi hy hreg

/-- **Closed-form error bound discharged on the finite band.**
The IBP/Stieltjes-side hypothesis: there's an `error : ℂ → ℂ` whose
imaginary part is bounded by the slab-specific closed form on all of
`[10, 140]`. -/
def closedFormErrorControlledOnFiniteBand (error : ℂ → ℂ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    10 ≤ T → T ≤ 140 →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im|
        ≤ closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T

/-- 🌟 **PROVED — Finite-band error margin** via `slabCD`. Direct `le_trans`
chaining the IBP-side error bound with the slab-side model-margin
domination — BOTH using the same `(slabCD T).1, (slabCD T).2`. -/
theorem finiteBand_errorMargin_of_slabCD
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : closedFormErrorControlledOnFiniteBand error)
    {z : ℂ} {T : ℝ}
    (hT10 : 10 ≤ T) (hT140 : T ≤ 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(error z).im| ≤ -(M.model z).im :=
  le_trans (herr hT10 hT140 hy hreg)
    (hclosed_on_10_140_zeros100ceil_slabCD M hzeros hT10 hT140 hy hreg)

-- =====================================================================
-- CLXXXV: Concrete `xiCloudDensityModel_zeros100ceil`
-- =====================================================================
-- A trivial-but-valid concrete `CloudDensityTailModelDecomposition`
-- with `zeros = zeros100ceil`. Uses a deliberately massive linear density
-- tail `densityTail z := -i · (100 · z.im)` so the `densityTailRationalLB`
-- obligation reduces to the crude bound `smoothTail ≤ 100·y` on the
-- adaptive region. Plumbing only — the real analytic decomposition and
-- IBP/Stieltjes error bound remain open.

/-- **Trivial massive-margin density tail.** `-i · 100·z.im` so its
`-Im` is `100·z.im`, which trivially dominates any reasonable
`smoothTailRationalLowerBoundAbs` on the admissible region. -/
noncomputable def linearDensityTail100 : ℂ → ℂ :=
  fun z => -Complex.I * ((100 * z.im : ℝ) : ℂ)

/-- ⭐ **PROVED — `-Im(linearDensityTail100 z) = 100·z.im`.** -/
lemma linearDensityTail100_neg_im (z : ℂ) :
    -(linearDensityTail100 z).im = 100 * z.im := by
  unfold linearDensityTail100
  simp [Complex.mul_im, Complex.neg_im, Complex.I_re, Complex.I_im,
        Complex.ofReal_re, Complex.ofReal_im]

/-- ⭐ **PROVED — `(linearDensityTail100 z).im = -100·z.im ≤ 0`** for `0 < z.im`. -/
lemma linearDensityTail100_im_nonpos
    {z : ℂ} (hz : 0 < z.im) :
    (linearDensityTail100 z).im ≤ 0 := by
  have h := linearDensityTail100_neg_im z
  linarith

/-- ⭐ **PROVED — `zeroDensityRho T ≤ T`** for `T ≥ 2π`.
Via `log x ≤ x` applied to `x = T/(2π)`, then `log(T/(2π))/(2π) ≤ T/(4π²) ≤ T`
(since `4π² > 1`). -/
lemma zeroDensityRho_le_T
    {T : ℝ} (hT2pi : 2 * Real.pi ≤ T) :
    zeroDensityRho T ≤ T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_gt_d2 : 3.14 < Real.pi := Real.pi_gt_d2
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_pos : 0 < T / (2 * Real.pi) := by positivity
  have h_log_le : Real.log (T / (2 * Real.pi)) ≤ T / (2 * Real.pi) - 1 :=
    Real.log_le_sub_one_of_pos hT_2pi_pos
  have h_log_le_T_2pi : Real.log (T / (2 * Real.pi)) ≤ T / (2 * Real.pi) := by
    linarith
  have h_inv_pos : (0 : ℝ) < 1 / (2 * Real.pi) := by positivity
  have h_step :
      (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        ≤ (1 / (2 * Real.pi)) * (T / (2 * Real.pi)) :=
    mul_le_mul_of_nonneg_left h_log_le_T_2pi (le_of_lt h_inv_pos)
  -- (1/(2π))·(T/(2π)) = T/(4π²)
  have h_2pi_ne : (2 * Real.pi : ℝ) ≠ 0 := ne_of_gt h_2pi_pos
  have h_eq :
      (1 / (2 * Real.pi)) * (T / (2 * Real.pi))
        = T / ((2 * Real.pi)^2) := by
    rw [sq, mul_comm (2 * Real.pi) (2 * Real.pi)]
    field_simp
  have h_2pi_sq_gt_1 : (1 : ℝ) ≤ (2 * Real.pi)^2 := by
    nlinarith [h_pi_gt_d2]
  have h_T_div_le : T / ((2 * Real.pi)^2) ≤ T := by
    rw [div_le_iff₀ (by positivity : (0:ℝ) < (2 * Real.pi)^2)]
    nlinarith [hT_pos, h_2pi_sq_gt_1]
  linarith [h_step, h_eq, h_T_div_le]

/-- ⭐ **PROVED — Crude smooth-tail kernel bound.**
On the admissible region, each kernel term `y·U/(U²+y²) ≤ y/U`, and
`T-|x|, T+|x| ≥ T/2` gives `y/U ≤ 2y/T`. So the sum is `≤ 4y/T`,
which we round up to `5y/T` for safety margin (any bound suffices). -/
lemma smoothTail_kernel_le_five_y_div_T
    {x y T : ℝ}
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) ≤ T) :
    (y * (T - |x|) / ((T - |x|)^2 + y^2)
      + y * (T + |x|) / ((T + |x|)^2 + y^2))
      ≤ 5 * y / T := by
  have h_absx_nn : 0 ≤ |x| := abs_nonneg _
  have hy_nn : 0 ≤ y := le_of_lt hy
  have hT_ge : T ≥ 2 := by linarith
  have hT_pos : 0 < T := by linarith
  have hTpos2 : 0 < T / 2 := by linarith
  -- |x| ≤ T/2 - 1, y ≤ T/2 - 1, so T - |x| ≥ T/2 + 1 > T/2
  have h_T_minus_x_lo : T / 2 ≤ T - |x| := by linarith
  have h_T_plus_x_lo : T ≤ T + |x| := by linarith
  have h_T_minus_x_pos : 0 < T - |x| := by linarith
  have h_T_plus_x_pos : 0 < T + |x| := by linarith
  -- First term: y·(T-|x|)/((T-|x|)²+y²) ≤ y/(T-|x|)
  have h_term1_bound : y * (T - |x|) / ((T - |x|)^2 + y^2) ≤ y / (T - |x|) := by
    rw [div_le_div_iff₀ (by positivity : 0 < (T - |x|)^2 + y^2) h_T_minus_x_pos]
    nlinarith [sq_nonneg (T - |x|), sq_nonneg y]
  have h_term2_bound : y * (T + |x|) / ((T + |x|)^2 + y^2) ≤ y / (T + |x|) := by
    rw [div_le_div_iff₀ (by positivity : 0 < (T + |x|)^2 + y^2) h_T_plus_x_pos]
    nlinarith [sq_nonneg (T + |x|), sq_nonneg y]
  -- y/(T-|x|) ≤ y/(T/2) = 2y/T
  have h_term1_le_2yT : y / (T - |x|) ≤ 2 * y / T := by
    rw [div_le_div_iff₀ h_T_minus_x_pos hT_pos]
    nlinarith [h_T_minus_x_lo, hy_nn]
  have h_term2_le_yT : y / (T + |x|) ≤ y / T :=
    div_le_div_of_nonneg_left hy_nn hT_pos h_T_plus_x_lo
  -- Combine: total ≤ 2y/T + y/T = 3y/T ≤ 5y/T
  have h_total : y / (T - |x|) + y / (T + |x|) ≤ 3 * y / T := by
    have : 2 * y / T + y / T = 3 * y / T := by ring
    linarith [h_term1_le_2yT, h_term2_le_yT]
  have h3le5 : 3 * y / T ≤ 5 * y / T := by
    apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
    nlinarith
  linarith [h_term1_bound, h_term2_bound, h_total, h3le5]

/-- ⭐ **PROVED — Crude smooth-tail upper bound on the adaptive region.**
`smoothTail ≤ ρ(T)·5y/T ≤ T·5y/T = 5y ≤ 100·y`. -/
lemma smoothTailRationalLowerBoundAbs_le_100y
    {x y T : ℝ}
    (hT2pi : 2 * Real.pi ≤ T)
    (hy : 0 < y)
    (hreg : 2 * (1 + |x| + y) ≤ T) :
    smoothTailRationalLowerBoundAbs x y T ≤ 100 * y := by
  unfold smoothTailRationalLowerBoundAbs
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 ≤ y := le_of_lt hy
  have h_rho_le : zeroDensityRho T ≤ T := zeroDensityRho_le_T hT2pi
  have h_rho_nn : 0 ≤ zeroDensityRho T := by
    unfold zeroDensityRho
    have h_2pi_pos : 0 < 2 * Real.pi := by linarith
    have hT_2pi_ge_one : (1 : ℝ) ≤ T / (2 * Real.pi) := by
      rw [le_div_iff₀ h_2pi_pos]; linarith
    have h_log_nn : 0 ≤ Real.log (T / (2 * Real.pi)) := Real.log_nonneg hT_2pi_ge_one
    positivity
  have h_kernel : (y * (T - |x|) / ((T - |x|)^2 + y^2)
                    + y * (T + |x|) / ((T + |x|)^2 + y^2))
                    ≤ 5 * y / T :=
    smoothTail_kernel_le_five_y_div_T hy hreg
  have h_kernel_nn :
      0 ≤ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h_absx_nn : 0 ≤ |x| := abs_nonneg _
    have hT_ge : T ≥ 2 := by linarith
    have h_T_minus_x_pos : 0 < T - |x| := by linarith
    have h_T_plus_x_pos : 0 < T + |x| := by linarith
    have h1 : 0 ≤ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
      apply div_nonneg
      · exact mul_nonneg hy_nn (le_of_lt h_T_minus_x_pos)
      · positivity
    have h2 : 0 ≤ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
      apply div_nonneg
      · exact mul_nonneg hy_nn (le_of_lt h_T_plus_x_pos)
      · positivity
    linarith
  have h_combine :
      zeroDensityRho T * (y * (T - |x|) / ((T - |x|)^2 + y^2)
        + y * (T + |x|) / ((T + |x|)^2 + y^2))
        ≤ T * (5 * y / T) := by
    apply mul_le_mul h_rho_le h_kernel h_kernel_nn (by linarith)
  have h_T5y : T * (5 * y / T) = 5 * y := by
    field_simp
  have h_5y_le : 5 * y ≤ 100 * y := by linarith
  linarith

/-- ⭐ **PROVED — `linearDensityTail100` discharges the rational LB obligation.** -/
theorem linearDensityTail100_rationalLB :
    ∀ z : ℂ, ∀ T : ℝ, 2 * Real.pi ≤ T → 0 < z.im →
      2 * (1 + |z.re| + z.im) ≤ T →
        smoothTailRationalLowerBoundAbs z.re z.im T
          ≤ -(linearDensityTail100 z).im := by
  intro z T hT2pi hy hreg
  rw [linearDensityTail100_neg_im]
  exact smoothTailRationalLowerBoundAbs_le_100y hT2pi hy hreg

/-- 🎯🎯🎯 **CONCRETE xi-facing cloud-density model over `zeros100ceil`.** 🎯🎯🎯
The first concrete inhabitant of `CloudDensityTailModelDecomposition`
plumbed in this file. Uses `linearDensityTail100` (trivial massive-margin
linear tail) — sufficient for the abstract bridge but NOT for the actual
xi log-derivative decomposition (which is a separate analytic problem). -/
noncomputable def xiCloudDensityModel_zeros100ceil :
    CloudDensityTailModelDecomposition where
  zeros := zeros100ceil
  densityTail := linearDensityTail100
  densityTailRationalLB := linearDensityTail100_rationalLB

/-- ⭐ **PROVED — `xiCloudDensityModel_zeros100ceil.zeros = zeros100ceil`.** -/
theorem xiCloudDensityModel_zeros100ceil_zeros :
    xiCloudDensityModel_zeros100ceil.zeros = zeros100ceil := rfl

/-- 🌟 **PROVED — Model anti-Herglotz** for the concrete model. -/
theorem xiCloudDensityModel_zeros100ceil_modelAnti :
    AntiHerglotzUHP xiCloudDensityModel_zeros100ceil.model := by
  intro z hz
  unfold CloudDensityTailModelDecomposition.model
  show (cloudModel xiCloudDensityModel_zeros100ceil.zeros z
          + xiCloudDensityModel_zeros100ceil.densityTail z).im ≤ 0
  rw [Complex.add_im]
  have hcloud : (cloudModel xiCloudDensityModel_zeros100ceil.zeros z).im ≤ 0 :=
    cloudModel_im_nonpos _ hz
  have htail : (xiCloudDensityModel_zeros100ceil.densityTail z).im ≤ 0 := by
    show (linearDensityTail100 z).im ≤ 0
    exact linearDensityTail100_im_nonpos hz
  linarith

/-- ⭐ **PROVED — Specialized adapter for `[10, 140]` slab region.**
Specialization of `localPackage_of_finiteBandSandwich` where the sandwich is
provided by `hclosed_on_10_140_zeros100ceil` (slab bundle) plus a separately
supplied error bound from the IBP machinery.

Given an IBP-derived error bound `|Im(error z)| ≤ closedFormSErrorBoundCD C D z.im T`
on the `[10, 140]` adaptive region and a model with `zeros = zeros100ceil`,
this constructs the `LocalXiCloudDensityErrorPackage`. -/
noncomputable def localPackage_10_140_of_slabBundle
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (herr_bound : ∀ z : ℂ, ∀ T : ℝ,
        10 ≤ T → T ≤ 140 → 0 < z.im → 2 * (1 + |z.re| + z.im) ≤ T →
        ∀ C D : ℝ,
          closedFormSErrorBoundCD C D z.im T ≤ -(M.model z).im →
          |(error z).im| ≤ closedFormSErrorBoundCD C D z.im T) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_of_finiteBandSandwich
    M.model error
    (fun z => ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧ 2 * (1 + |z.re| + z.im) ≤ T)
    hdecomp
    hmodelAnti
    (by
      intro z hreg hz
      obtain ⟨T, hT10, hT140, hreg_T⟩ := hreg
      obtain ⟨C, D, hclosed⟩ :=
        hclosed_on_10_140_zeros100ceil M hM_zeros hT10 hT140 hz hreg_T
      refine ⟨C, D, T, ?_, hclosed⟩
      exact herr_bound z T hT10 hT140 hz hreg_T C D hclosed)

-- =====================================================================
-- CLXXXV-final: slabCD-based local-package adapter (clean composition)
-- =====================================================================
-- Replaces the verbose `localPackage_10_140_of_slabBundle` hypothesis
-- shape with the cleaner `closedFormErrorControlledOnFiniteBand error`
-- predicate (which uses `slabCD T` so the (C,D) automatically matches).

/-- 🎯 **PROVED — Generic slabCD-based local package adapter.**
Takes an IBP-style hypothesis `closedFormErrorControlledOnFiniteBand error`
(using the deterministic `slabCD` selector) and produces a
`LocalXiCloudDensityErrorPackage` over the `[10, 140]` adaptive region.

Composes:
- `finiteBand_errorMargin_of_slabCD` (which is `le_trans` of
  `herr` + `hclosed_on_10_140_zeros100ceil_slabCD`),
- the generic `LocalXiCloudDensityErrorPackage` constructor. -/
noncomputable def localPackage_10_140_of_slabCD
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (herr : closedFormErrorControlledOnFiniteBand error) :
    LocalXiCloudDensityErrorPackage :=
  { model := M.model
    error := error
    region := fun z =>
      ∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T
    decomp := hdecomp
    modelAnti := hmodelAnti
    errorMargin := by
      intro z hreg hz
      obtain ⟨T, hT10, hT140, hregT⟩ := hreg
      exact finiteBand_errorMargin_of_slabCD
        (M := M) (error := error)
        hM_zeros herr hT10 hT140 hz hregT }

/-- 🎯 **PROVED — Concrete-model specialization** of the slabCD adapter.
Plugs in the concrete `xiCloudDensityModel_zeros100ceil` model and its
already-proven `modelAnti` to give the simplest possible "landing pad"
for the upcoming IBP/Stieltjes + log-derivative decomposition work. -/
noncomputable def localXiPackage_10_140_zeros100ceil
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (herr : closedFormErrorControlledOnFiniteBand error) :
    LocalXiCloudDensityErrorPackage :=
  localPackage_10_140_of_slabCD
    xiCloudDensityModel_zeros100ceil
    xiCloudDensityModel_zeros100ceil_zeros
    xiCloudDensityModel_zeros100ceil_modelAnti
    error hdecomp herr

/-- 🌟 **PROVED — Finite-band regional anti-Herglotz from the two missing
analytic inputs.** Given the log-derivative decomposition and the
IBP-controlled error bound, the regional anti-Herglotz statement is
immediate by inlining `finiteBand_errorMargin_of_slabCD` + the model
anti-Herglotz fact + the decomposition. -/
theorem localXiPackage_10_140_regionAnti
    (error : ℂ → ℂ)
    (hdecomp : ∀ z : ℂ,
        (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
          2 * (1 + |z.re| + z.im) ≤ T) →
        logDerivativeResponse XiPullback z =
          xiCloudDensityModel_zeros100ceil.model z + error z)
    (herr : closedFormErrorControlledOnFiniteBand error) :
    ∀ z : ℂ,
      (∃ T : ℝ, 10 ≤ T ∧ T ≤ 140 ∧
        2 * (1 + |z.re| + z.im) ≤ T) →
      0 < z.im →
      (logDerivativeResponse XiPullback z).im ≤ 0 := by
  intro z hreg hz
  obtain ⟨T, hT10, hT140, hregT⟩ := hreg
  rw [hdecomp z ⟨T, hT10, hT140, hregT⟩, Complex.add_im]
  have h_model_im : (xiCloudDensityModel_zeros100ceil.model z).im ≤ 0 :=
    xiCloudDensityModel_zeros100ceil_modelAnti z hz
  have h_err_margin :
      |(error z).im| ≤ -(xiCloudDensityModel_zeros100ceil.model z).im :=
    finiteBand_errorMargin_of_slabCD
      (M := xiCloudDensityModel_zeros100ceil) (error := error)
      xiCloudDensityModel_zeros100ceil_zeros herr hT10 hT140 hz hregT
  have h_err_le : (error z).im ≤ |(error z).im| := le_abs_self _
  linarith

-- =====================================================================
-- CLXXXVb: Per-window global error control + 3-band dispatcher
-- =====================================================================
-- Following the file's `[2π,10] / [10,140] / [140,∞)` band structure,
-- this section defines `PerWindowGlobalErrorControl` (bundle of low/mid/high
-- hypotheses) and proves the dispatcher `errorMargin_of_globalErrorControl`
-- that picks the right band by case-splitting on `T`. The mid band is
-- the slab cert (already proved); low and high are still hypothesis
-- placeholders for the Phase1IBP / first-zero / large-T analytic work.

/-- **Per-window global error control.** Bundles the three band-specific
error-margin hypotheses needed for global covering:
- `low`: `[2π, 10]` band — first-zero / `N₀` control;
- `mid`: `[10, 140]` band — the slab cert via `closedFormErrorControlledOnFiniteBand`;
- `high`: `[140, ∞)` band — large-T smooth-tail domination. -/
structure PerWindowGlobalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (error : ℂ → ℂ) where
  low : ∀ {z : ℂ} {T : ℝ},
    2 * Real.pi ≤ T → T ≤ 10 →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤ -(M.model z).im
  mid : closedFormErrorControlledOnFiniteBand error
  high : ∀ {z : ℂ} {T : ℝ},
    140 ≤ T →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤ -(M.model z).im

/-- 🎯 **PROVED — Per-window dispatcher.** From the bundled
`PerWindowGlobalErrorControl`, picks the right band by case-splitting
on `T`. Uses `finiteBand_errorMargin_of_slabCD` in the mid band. -/
theorem errorMargin_of_globalErrorControl
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (hzeros : M.zeros = zeros100ceil)
    (H : PerWindowGlobalErrorControl M error)
    {z : ℂ} {T : ℝ}
    (hT2pi : 2 * Real.pi ≤ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(error z).im| ≤ -(M.model z).im := by
  by_cases hT10 : T ≤ 10
  · exact H.low hT2pi hT10 hy hreg
  · push_neg at hT10
    have hT10_le : (10 : ℝ) ≤ T := le_of_lt hT10
    by_cases hT140 : T ≤ 140
    · exact finiteBand_errorMargin_of_slabCD
        (M := M) (error := error)
        hzeros H.mid hT10_le hT140 hy hreg
    · push_neg at hT140
      have hT140_le : (140 : ℝ) ≤ T := le_of_lt hT140
      exact H.high hT140_le hy hreg

/-- 🎯 **PROVED — Per-window local-package constructor.** Given a chosen
region containing only points admissible at some `T`, produces a
`LocalXiCloudDensityErrorPackage`. The dispatched error-margin proof
comes from `errorMargin_of_globalErrorControl`. -/
noncomputable def localPackage_of_globalErrorControl
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    (hmodelAnti : AntiHerglotzUHP M.model)
    (error : ℂ → ℂ)
    (region : ℂ → Prop)
    (hregT : ∀ z : ℂ, region z →
        ∃ T : ℝ, 2 * Real.pi ≤ T ∧ 2 * (1 + |z.re| + z.im) ≤ T)
    (hdecomp : ∀ z : ℂ, region z →
        logDerivativeResponse XiPullback z = M.model z + error z)
    (H : PerWindowGlobalErrorControl M error) :
    LocalXiCloudDensityErrorPackage :=
  { model := M.model
    error := error
    region := region
    decomp := hdecomp
    modelAnti := hmodelAnti
    errorMargin := by
      intro z hreg hz
      obtain ⟨T, hT2pi, hregT_val⟩ := hregT z hreg
      exact errorMargin_of_globalErrorControl
        (M := M) (error := error)
        hM_zeros H hT2pi hz hregT_val }

-- =====================================================================
-- CLXXXVc: High-range `[140, ∞)` margin bridge
-- =====================================================================
-- The high-T analogue of `slabCD`. Uses the existing `proved_numerics_22_15_at_140`
-- + `largeTScalarConditionTwentyTwoFifteenths_implies_domination` chain.
-- Output: a deterministic closed-form bound + `le_trans`-style adapter so
-- the high field of `PerWindowGlobalErrorControl` has a clean landing pad.

/-- **Deterministic high-`T` closed-form bound.** At all `T ≥ 140` we know
the closed form at `(C, D) = (1/2, 49/20)` is dominated by
`smoothTailRationalLowerBoundAbs`, which in turn is bounded by `-Im(densityTail)`. -/
noncomputable def highTClosedFormBound (y T : ℝ) : ℝ :=
  closedFormSErrorBoundCD (1 / 2) (49 / 20) y T

/-- ⭐ **PROVED — High-`T` closed-form bound dominates `-Im(M.model)`** for
`T ≥ 140` and `M.zeros = zeros100ceil`. Chain:

`highTClosedFormBound = closedFormSErrorBoundCD (1/2) (49/20)`
  `≤ smoothTailRationalLowerBoundAbs`  (via `largeTScalar…_implies_domination`
                                          + `proved_numerics_22_15_at_140`)
  `≤ -(densityTail).im`                (via `M.densityTailRationalLB`)
  `≤ -(densityTail).im + -(cloud).im = -(model).im` (cloud anti-Herglotz). -/
theorem highTClosedFormBound_le_neg_model_im
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    {z : ℂ} {T : ℝ}
    (hT140 : 140 ≤ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    highTClosedFormBound z.im T ≤ -(M.model z).im := by
  unfold highTClosedFormBound
  have hscalar : largeTScalarMarginConditionTwentyTwoFifteenths T :=
    largeTScalarMarginConditionTwentyTwoFifteenths_of_ge_140_from_numerics
      proved_numerics_22_15_at_140 hT140
  have h_dom :
      closedFormSErrorBoundCD (1 / 2 : ℝ) (49 / 20 : ℝ) z.im T
        ≤ smoothTailRationalLowerBoundAbs z.re z.im T :=
    largeTScalarConditionTwentyTwoFifteenths_implies_domination hT140 hy hreg hscalar
  have hT_2pi : 2 * Real.pi ≤ T := by
    have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
    linarith
  have h_tail_lb :
      smoothTailRationalLowerBoundAbs z.re z.im T ≤ -(M.densityTail z).im :=
    M.densityTailRationalLB z T hT_2pi hy hreg
  have h_model : M.model z = cloudModel M.zeros z + M.densityTail z := rfl
  have h_model' : M.model z = cloudModel zeros100ceil z + M.densityTail z := by
    rw [h_model, hM_zeros]
  have h_cloud_im_nonpos : (cloudModel zeros100ceil z).im ≤ 0 :=
    cloudModel_im_nonpos _ hy
  have h_model_im :
      -(M.model z).im = -(cloudModel zeros100ceil z).im + -(M.densityTail z).im := by
    rw [h_model', Complex.add_im]; ring
  linarith [h_dom, h_tail_lb, h_cloud_im_nonpos, h_model_im]

/-- **High-`T` closed-form error control.** The IBP/large-T-side
hypothesis: `|Im(error z)| ≤ highTClosedFormBound z.im T` on `[140, ∞)`. -/
def highTErrorControlled (error : ℂ → ℂ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    140 ≤ T →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤ highTClosedFormBound z.im T

/-- 🌟 **PROVED — High-`T` error margin via `le_trans`.** Chains the
IBP-side error control with the model-margin domination, BOTH using
the same `highTClosedFormBound z.im T`. -/
theorem highT_errorMargin_of_highTErrorControlled
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : highTErrorControlled error)
    {z : ℂ} {T : ℝ}
    (hT140 : 140 ≤ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(error z).im| ≤ -(M.model z).im :=
  le_trans (herr hT140 hy hreg)
    (highTClosedFormBound_le_neg_model_im M hzeros hT140 hy hreg)

-- =====================================================================
-- CLXXXVd: Low-range `[2π, 10]` margin bridge
-- =====================================================================
-- The low-T analogue of `slabCD` and `highTClosedFormBound`. Uses the
-- existing `FirstZeroDirectBandCertificate` structure (which models the
-- pre-first-zero region where `N(u) = 0` and `S = -N₀` directly).
-- The certificate's `errorBound : ℂ → ℝ` plays the same role as
-- `closedFormSErrorBoundCD (slabCD T)` in the mid range — a function-valued
-- bound supplied by the first-zero analytic infrastructure.

/-- **Low-`T` error control predicate.** Says `|Im(error z)|` is bounded
by a function-valued `errorBound : ℂ → ℝ` on the `[2π, 10]` adaptive region. -/
def lowTErrorControlled
    (error : ℂ → ℂ)
    (errorBound : ℂ → ℝ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    2 * Real.pi ≤ T →
    T ≤ 10 →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
      |(error z).im| ≤ errorBound z

/-- 🌟 **PROVED — Generic low-T error margin** via `FirstZeroDirectBandCertificate`.
Chains the IBP-side error control (`herr`) with the certificate's
model-margin domination (`F.cert`), BOTH using `F.errorBound z`. -/
theorem lowT_errorMargin_of_firstZeroDirect
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi)
    (hF_B : F.B = 10)
    (hF_model : F.model = M.model)
    (herr : lowTErrorControlled error F.errorBound)
    {z : ℂ} {T : ℝ}
    (hT2pi : 2 * Real.pi ≤ T)
    (hT10 : T ≤ 10)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T) :
    |(error z).im| ≤ -(M.model z).im := by
  have herr_bound : |(error z).im| ≤ F.errorBound z :=
    herr hT2pi hT10 hy hreg
  have hA : F.A ≤ T := by rw [hF_A]; exact hT2pi
  have hB : T ≤ F.B := by rw [hF_B]; exact hT10
  have hcert : F.errorBound z ≤ -(F.model z).im :=
    F.cert z T hA hB hy hreg
  rw [hF_model] at hcert
  exact le_trans herr_bound hcert

-- =====================================================================
-- CLXXXVd-bis: Guarded (away-from-zeros) variants — closes the `a/0=0`
-- gap in Route B's residual route.
-- =====================================================================
-- Background. `logDerivativeResponse f z := deriv f z / f z` totalizes
-- to `0` at zeros of `f` (Lean's `a / 0 = 0`). The §6-bis engine guard
-- (`antiHerglotz_at_zero_is_vacuous`,
-- `antiHerglotz_iff_antiHerglotz_away_from_zeros`) shows the totalization
-- adds no proof obligation to the *sign law itself*. But Route B's
-- residual hypotheses `lowTErrorControlled` / `highTErrorControlled`
-- quantify over every band-`z` including hypothetical UHP zeros of Ξ.
-- At a zero `ρ`, the algebra `error := Λ[Ξ] − M.model` forces
-- `|Im(error ρ)| = −Im(M.model ρ)` exactly, which the certificate's
-- strict slack `errorBound z < −Im(M.model z)` cannot accommodate.
-- Discharging the unguarded hypotheses therefore requires ruling out
-- UHP zeros — i.e. RH — making the conditional theorem effectively
-- RH-equivalent.
--
-- The fix is structural: keep `LocalXiCloudDensityErrorPackage` strong,
-- but weaken Route B's *input* predicates to demand the analytic bound
-- only where `XiPullback z ≠ 0`. The zero case is handled internally
-- by a single algebra lemma.

/-- **Algebra at a zero of `XiPullback`.** If `Λ[Ξ] z = M.model z + error z`
holds and `M.model` is anti-Herglotz on the UHP, then at any UHP zero of
`XiPullback` the totalization `Λ[Ξ] ρ = 0` forces
`|Im(error ρ)| = −Im(M.model ρ)`, hence the margin inequality holds with
equality. This is the structural lemma that lets the analytic
hypotheses skip the zero case without going through the totalization. -/
theorem errorMargin_at_XiPullback_zero_of_decomp
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (hmodelAnti : AntiHerglotzUHP M.model)
    (hdecomp : ∀ z : ℂ,
      logDerivativeResponse XiPullback z = M.model z + error z)
    {z : ℂ}
    (hz : 0 < z.im)
    (hzero : XiPullback z = 0) :
    |(error z).im| ≤ -(M.model z).im := by
  have hΛ0 : logDerivativeResponse XiPullback z = 0 :=
    logDerivativeResponse_eq_zero_at_zero hzero
  have hsum : M.model z + error z = 0 := by
    calc
      M.model z + error z = logDerivativeResponse XiPullback z := by
        rw [hdecomp z]
      _ = 0 := hΛ0
  have him : (error z).im = -(M.model z).im := by
    have h := congrArg Complex.im hsum
    simp [Complex.add_im] at h
    linarith
  have hnonneg : 0 ≤ -(M.model z).im := by
    have hm := hmodelAnti z hz
    linarith
  rw [him]
  exact le_of_eq (abs_of_nonneg hnonneg)

/-- **High-`T` error control, only away from zeros of `XiPullback`.**
The guarded version of `highTErrorControlled`. Discharging this
predicate does *not* require any claim about `|Im(error z)|` at
hypothetical UHP zeros of Ξ — exactly the points where the totalization
`logDerivativeResponse XiPullback z = 0` would force an unprovable
equality with the certificate's strict-slack bound. -/
def highTErrorControlledAwayFromZeros (error : ℂ → ℂ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    140 ≤ T →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
    XiPullback z ≠ 0 →
      |(error z).im| ≤ highTClosedFormBound z.im T

/-- **Low-`T` error control, only away from zeros of `XiPullback`.**
The guarded version of `lowTErrorControlled`. -/
def lowTErrorControlledAwayFromZeros
    (error : ℂ → ℂ)
    (errorBound : ℂ → ℝ) : Prop :=
  ∀ {z : ℂ} {T : ℝ},
    2 * Real.pi ≤ T →
    T ≤ 10 →
    0 < z.im →
    2 * (1 + |z.re| + z.im) ≤ T →
    XiPullback z ≠ 0 →
      |(error z).im| ≤ errorBound z

/-- **Old high-`T` predicate ⇒ guarded one.** The guarded predicate is
strictly weaker; the old predicate trivially discharges it. Provided so
existing inhabitants can be reused as-is. -/
theorem highTErrorControlledAwayFromZeros_of_highTErrorControlled
    {error : ℂ → ℂ} (h : highTErrorControlled error) :
    highTErrorControlledAwayFromZeros error :=
  fun hT hy hreg _ => h hT hy hreg

/-- **Old low-`T` predicate ⇒ guarded one.** -/
theorem lowTErrorControlledAwayFromZeros_of_lowTErrorControlled
    {error : ℂ → ℂ} {errorBound : ℂ → ℝ}
    (h : lowTErrorControlled error errorBound) :
    lowTErrorControlledAwayFromZeros error errorBound :=
  fun hT2pi hT10 hy hreg _ => h hT2pi hT10 hy hreg

/-- 🌟 **PROVED — High-`T` error margin via the guarded predicate.**
Same chain as `highT_errorMargin_of_highTErrorControlled`, but the
analytic hypothesis is only consumed with the explicit `XiPullback z ≠ 0`
guard. -/
theorem highT_errorMargin_of_highTErrorControlledAwayFromZeros
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (hzeros : M.zeros = zeros100ceil)
    (herr : highTErrorControlledAwayFromZeros error)
    {z : ℂ} {T : ℝ}
    (hT140 : 140 ≤ T)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T)
    (hz_ne : XiPullback z ≠ 0) :
    |(error z).im| ≤ -(M.model z).im :=
  le_trans
    (herr hT140 hy hreg hz_ne)
    (highTClosedFormBound_le_neg_model_im M hzeros hT140 hy hreg)

/-- 🌟 **PROVED — Low-`T` error margin via the guarded predicate.** -/
theorem lowT_errorMargin_of_firstZeroDirectAwayFromZeros
    {M : CloudDensityTailModelDecomposition}
    {error : ℂ → ℂ}
    (F : FirstZeroDirectBandCertificate)
    (hF_A : F.A = 2 * Real.pi)
    (hF_B : F.B = 10)
    (hF_model : F.model = M.model)
    (herr : lowTErrorControlledAwayFromZeros error F.errorBound)
    {z : ℂ} {T : ℝ}
    (hT2pi : 2 * Real.pi ≤ T)
    (hT10 : T ≤ 10)
    (hy : 0 < z.im)
    (hreg : 2 * (1 + |z.re| + z.im) ≤ T)
    (hz_ne : XiPullback z ≠ 0) :
    |(error z).im| ≤ -(M.model z).im := by
  have h_err : |(error z).im| ≤ F.errorBound z :=
    herr hT2pi hT10 hy hreg hz_ne
  have hA : F.A ≤ T := by rw [hF_A]; exact hT2pi
  have hB : T ≤ F.B := by rw [hF_B]; exact hT10
  have h_cert : F.errorBound z ≤ -(M.model z).im := by
    have h := F.cert z T hA hB hy hreg
    rw [hF_model] at h
    exact h
  exact le_trans h_err h_cert

/-- 🌟 **PROVED — Regression: zero-branch dispatch is `antiHerglotz_at_zero_is_vacuous`.**
A regression-style smoke test that the totalization at `XiPullback z = 0`
discharges the anti-Herglotz inequality via §6-bis, independent of any
analytic input. -/
theorem routeB_zero_branch_uses_vacuity
    {z : ℂ}
    (_hz : 0 < z.im)
    (hzero : XiPullback z = 0) :
    (logDerivativeResponse XiPullback z).im ≤ 0 := by
  have := antiHerglotz_at_zero_is_vacuous (f := XiPullback) (ρ := z) hzero
  linarith

/-- 🌟 **PROVED — API-shape check.** Exists purely to enforce, at the
type level, that consumers of `lowTErrorControlledAwayFromZeros` must
supply a `XiPullback z ≠ 0` witness at the call site. If this `example`
ever fails to elaborate, the guarded API has regressed and the
`a/0=0` trap is back. -/
example
    {error : ℂ → ℂ} {B : ℂ → ℝ}
    (herr : lowTErrorControlledAwayFromZeros error B)
    {z : ℂ} {T : ℝ}
