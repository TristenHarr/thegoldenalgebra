    вИА {z : вДВ} {T : вДЭ} {J : вДЭ}, 10 вЙ§ T вЖТ T вЙ§ 140 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
      Tendsto
        (fun X : вДЭ => Phase1IBP.derivativeSidePartial S z.re z.im T X)
        Filter.atTop (рЭУЭ J) вЖТ
      |J| вЙ§ -Phase1IBP.derivativeSideMajorantPrimitive
        z.im (slabCD T).1 (slabCD T).2 T

/-- в≠Р **PROVED вАФ adaptive specialization of the Im-Tendsto lemma.**
For each adaptive `(T, z)`, the imaginary part of the complex partial
tends to the imaginary part of the adaptive tail. -/
lemma adaptiveComplexDensityTailFamilyPartial_im_tendsto
    {kernel : вДЭ вЖТ вДВ вЖТ вДВ} {S : вДЭ вЖТ вДЭ}
    (conv : AdaptiveComplexDensityTailFamilyConverges kernel S)
    {T : вДЭ} {z : вДВ}
