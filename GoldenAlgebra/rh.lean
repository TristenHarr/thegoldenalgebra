-- =====================================================================
-- ┬º16. Phase 1 + Phase 2 scaffolding (codifying ┬º15.A)
-- =====================================================================
-- The four sub-targets of the ┬º15.A roadmap, laid down as named Prop
-- structures with bridge theorems into the existing ┬º13/┬º10 pipeline.
-- Style mirrors ┬º13: define the data, expose Prop-field obligations,
-- and compose into the upstream chain
-- (`PerWindowClosedFormIBPData` / `ZeroCountingFluctuationBound` /
-- `LocalAnalyticZeroFactorization` /
-- `EntireLocalPoleDecompositionHypothesis`).

-- ---------------------------------------------------------------------
-- ┬º16.1. Fluctuation measure data (Phase 1.1)
-- ---------------------------------------------------------------------
-- The pair `(N, NÔéÇ)` of the discrete zero-counting function and the
-- smooth model. The signed-measure `dS = dN ÔêÆ dNÔéÇ` is encoded by the
-- difference `S(u) = N(u) ÔêÆ NÔéÇ(u)` at the function level (the existing
-- ┬º13 `ZeroCountingFluctuationBound` already carries `S` in this
-- form). The structure below pins down the concrete construction of
-- `S` from a zero list `Z : Ôäò ÔåÆ ÔäØ` with multiplicities
-- `mult : Ôäò ÔåÆ Ôäò` and a smooth `NÔéÇ : ÔäØ ÔåÆ ÔäØ` (e.g.
-- `smoothZeroCountingN0`). Once Mathlib's
-- `MeasureTheory.SignedMeasure ÔäØ` packaging of
-- `dS = ╬ú_{j<n} (mult j) ÔÇó dirac (Z j) ÔêÆ volume.withDensity ¤ü` lands,
-- this structure is the function-level bridge.

/-- **Discrete zero-counting function** for a list of zero ordinates
`Z : Ôäò ÔåÆ ÔäØ` with multiplicities `mult : Ôäò ÔåÆ Ôäò`, truncated to the
first `n` entries:
`N_{Z, mult, n}(u) = ╬ú_{j < n, Z j Ôëñ u} mult j`. -/
noncomputable def discreteZeroCounting
    (Z : Ôäò ÔåÆ ÔäØ) (mult : Ôäò ÔåÆ Ôäò) (n : Ôäò) (u : ÔäØ) : ÔäØ :=
  (Finset.range n).sum
    (fun j => if Z j Ôëñ u then (mult j : ÔäØ) else 0)

/-- **Concrete fluctuation function** `S = N ÔêÆ NÔéÇ` from a zero list
and the smooth model. -/
noncomputable def concreteFluctuation
    (Z : Ôäò ÔåÆ ÔäØ) (mult : Ôäò ÔåÆ Ôäò) (n : Ôäò) (NÔéÇ : ÔäØ ÔåÆ ÔäØ) (u : ÔäØ) : ÔäØ :=
  discreteZeroCounting Z mult n u - NÔéÇ u

/-- **Fluctuation measure data.** Packages the inputs to the
signed-measure construction `dS = dN ÔêÆ dNÔéÇ` together with the
function-level fluctuation `S : ÔäØ ÔåÆ ÔäØ`. Fields:

* `Z` ÔÇö zero ordinates (e.g. positive imaginary parts of the
  nontrivial zeros of `XiPullback`);
* `mult` ÔÇö algebraic multiplicities;
* `n` ÔÇö number of zeros included in the window;
* `NÔéÇ` ÔÇö smooth model (concretely `smoothZeroCountingN0`);
* `S` ÔÇö the named fluctuation function;
* `S_eq` ÔÇö `S` agrees with the concrete `N ÔêÆ NÔéÇ` construction.

This is the input the ┬º13 `ZeroCountingFluctuationBound.S` field
expects, once the measure-theoretic side of Phase 1.1 lands. -/
structure FluctuationMeasureData where
  Z : Ôäò ÔåÆ ÔäØ
  mult : Ôäò ÔåÆ Ôäò
  n : Ôäò
  NÔéÇ : ÔäØ ÔåÆ ÔäØ
  S : ÔäØ ÔåÆ ÔäØ
  S_eq : ÔêÇ u : ÔäØ, S u = concreteFluctuation Z mult n NÔéÇ u

/-- Ô¡É **PROVED ÔÇö fluctuation measure data unfolds to `N ÔêÆ NÔéÇ`.** -/
theorem FluctuationMeasureData.S_def
    (D : FluctuationMeasureData) (u : ÔäØ) :
    D.S u =
      (Finset.range D.n).sum
        (fun j => if D.Z j Ôëñ u then (D.mult j : ÔäØ) else 0)
      - D.NÔéÇ u := by
  rw [D.S_eq u]; rfl

/-- Ô¡É **PROVED ÔÇö canonical xi-facing instance.** Given any zero list
`Z` with multiplicities `mult`, truncated to `n` entries, the
fluctuation `S = N ÔêÆ smoothZeroCountingN0` (the ┬º13 smooth model) is
a `FluctuationMeasureData`. -/
noncomputable def FluctuationMeasureData.ofXiSmooth
    (Z : Ôäò ÔåÆ ÔäØ) (mult : Ôäò ÔåÆ Ôäò) (n : Ôäò) :
    FluctuationMeasureData where
  Z := Z
  mult := mult
  n := n
  NÔéÇ := smoothZeroCountingN0
  S := fun u => concreteFluctuation Z mult n smoothZeroCountingN0 u
  S_eq := fun _ => rfl

-- ---------------------------------------------------------------------
-- ┬º16.2. Improper Stieltjes integral wrapper (Phase 1.2)
-- ---------------------------------------------------------------------
-- The improper integral `Ôê½_T^Ôê× f(u) dS(u)` is the `atTop` limit of the
-- finite Stieltjes integrals `F(X) = Ôê½_T^X f(u) dS(u)`. At the
-- function level (`S = N ÔêÆ NÔéÇ` as in ┬º16.1), the finite Stieltjes
-- integral splits as
--   `Ôê½_T^X f(u) dS(u)
--      = ╬ú_{j: T Ôëñ Z j Ôëñ X} mult j ┬À f(Z j)  ÔêÆ  Ôê½_T^X f(u) ┬À ¤ü(u) du`.
-- The Prop-level abstraction below names the limit value without
-- committing to that explicit split; the ┬º16.3 IBP bridge uses it.

/-- **Improper Stieltjes integral, function-level convergence.**
`ImproperStieltjesConverges F L` says the partial integral
`F : ÔäØ ÔåÆ ÔäØ` tends to `L` as the upper cutoff `X ÔåÆ Ôê×`. The function
`F` is a parameter so this abstraction is agnostic to whether the
partial integral is encoded via RiemannÔÇôStieltjes sums,
`intervalIntegral` against a signed measure, or any explicit split. -/
def ImproperStieltjesConverges (F : ÔäØ ÔåÆ ÔäØ) (L : ÔäØ) : Prop :=
  Tendsto F (Filter.atTop : Filter ÔäØ) (­ØôØ L)

/-- **Improper Stieltjes integral data.** Bundles a candidate
partial-integral function `F : ÔäØ ÔåÆ ÔäØ`, a basepoint `T`, and a limit
value `L`, with the proof that `F X ÔåÆ L` as `X ÔåÆ Ôê×`. -/
structure ImproperStieltjesIntegralData where
  F : ÔäØ ÔåÆ ÔäØ
  T : ÔäØ
  L : ÔäØ
  converges : ImproperStieltjesConverges F L

/-- **PROVED ÔÇö extract the limit value.** -/
theorem ImproperStieltjesIntegralData.tendsto
    (I : ImproperStieltjesIntegralData) :
    Tendsto I.F (Filter.atTop : Filter ÔäØ) (­ØôØ I.L) := I.converges

/-- **Imaginary-kernel improper Stieltjes integral.** Specialization
to the integrand `pairedCauchyImKernel x y ┬À = Im K_┬À(z)` at a fixed
probe `z = x + i┬Ày` and basepoint `T`. The convergence target `L` is
the value of `Im (Ôê½_T^Ôê× K_u(z) dS(u))`. -/
structure ImaginaryKernelImproperIntegral where
  x : ÔäØ
  y : ÔäØ
  T : ÔäØ
  partialIntegral : ÔäØ ÔåÆ ÔäØ         -- X Ôåª Ôê½_T^X k_z(u) dS(u)
  L : ÔäØ                           -- limiting value Im Ôê½_T^Ôê× K dS
  converges : ImproperStieltjesConverges partialIntegral L

-- ---------------------------------------------------------------------
-- ┬º16.2-A. Function-level Stieltjes split (Phase 1 concretization)
-- ---------------------------------------------------------------------
-- The Mathlib signed measure `╬╝_S = dN ÔêÆ dNÔéÇ` has the awkward feature
-- that `dNÔéÇ = volume.withDensity ¤ü` is infinite on `ÔäØ`, so direct
-- subtraction as a `SignedMeasure ÔäØ` requires either restricting to a
-- bounded interval or going through localized measures. The
-- *function-level* equivalent ÔÇö splitting the Stieltjes integral as
--   `Ôê½_T^X f dS = (╬ú_{j: T Ôëñ Z j Ôëñ X} mult j ┬À f (Z j))
--                 ÔêÆ (Ôê½_T^X f(u) ┬À ¤ü(u) du)`
-- ÔÇö sidesteps that completely. The discrete partial is computable; the
-- smooth partial is a named field so downstream code can supply it via
-- either an explicit `intervalIntegral` or any other encoding.

/-- **Discrete Stieltjes partial integral.** The contribution to
`Ôê½_T^X f dS` from the discrete Dirac part `dN = ╬ú_j mult j ┬À ╬┤_{Z j}`:
  `discreteStieltjesPartial Z mult n f T X
     = ╬ú_{j < n : T Ôëñ Z j Ôëñ X} mult j ┬À f (Z j)`. -/
noncomputable def discreteStieltjesPartial
    (Z : Ôäò ÔåÆ ÔäØ) (mult : Ôäò ÔåÆ Ôäò) (n : Ôäò) (f : ÔäØ ÔåÆ ÔäØ) (T X : ÔäØ) : ÔäØ :=
  (Finset.range n).sum (fun j =>
    if T Ôëñ Z j Ôêº Z j Ôëñ X then (mult j : ÔäØ) * f (Z j) else 0)

/-- **Function-level Stieltjes partial integral split.** Encodes
`Ôê½_T^X f dS = (discrete part against `dN`) ÔêÆ (smooth part against `d¤ü`)`
as named data. The `smoothPart` field stays abstract so it can be
either an explicit `intervalIntegral` or a Prop-level commitment to a
downstream integral computation. -/
structure StieltjesPartialSplit where
  Z : Ôäò ÔåÆ ÔäØ
  mult : Ôäò ÔåÆ Ôäò
  n : Ôäò
  f : ÔäØ ÔåÆ ÔäØ
  T : ÔäØ
  smoothPart : ÔäØ ÔåÆ ÔäØ      -- X Ôåª Ôê½_T^X f(u) ┬À ¤ü(u) du
  total : ÔäØ ÔåÆ ÔäØ           -- X Ôåª Ôê½_T^X f dS
  total_eq :
    ÔêÇ X : ÔäØ,
      total X = discreteStieltjesPartial Z mult n f T X - smoothPart X

/-- Ô¡É **PROVED ÔÇö function-level split projects to the abstract
improper-Stieltjes wrapper.** Given a `StieltjesPartialSplit` together
with a limit value `L` and a convergence proof for the `total` field,
construct the `ImproperStieltjesIntegralData` of ┬º16.2. -/
noncomputable def StieltjesPartialSplit.toImproperStieltjesIntegralData
    (S : StieltjesPartialSplit) (L : ÔäØ)
    (hconv : ImproperStieltjesConverges S.total L) :
    ImproperStieltjesIntegralData where
  F := S.total
  T := S.T
  L := L
  converges := hconv

/-- Ô¡É **PROVED ÔÇö discrete partial is nonneg when `f ÔëÑ 0`.** Used in
positivity arguments: the discrete part of any Stieltjes integral
against a nonnegative integrand is nonnegative. -/
theorem discreteStieltjesPartial_nonneg_of_nonneg_f
    {Z : Ôäò ÔåÆ ÔäØ} {mult : Ôäò ÔåÆ Ôäò} {n : Ôäò} {f : ÔäØ ÔåÆ ÔäØ} {T X : ÔäØ}
    (hf : ÔêÇ u : ÔäØ, 0 Ôëñ f u) :
    0 Ôëñ discreteStieltjesPartial Z mult n f T X := by
  unfold discreteStieltjesPartial
  apply Finset.sum_nonneg
  intro j _
  by_cases h : T Ôëñ Z j Ôêº Z j Ôëñ X
  ┬À rw [if_pos h]
    have : (0 : ÔäØ) Ôëñ (mult j : ÔäØ) := by positivity
    exact mul_nonneg this (hf _)
  ┬À rw [if_neg h]

/-- Ô¡É **PROVED ÔÇö discrete partial telescope at `X = T ÔêÆ 1`** (or any
`X < min Z j`): the partial is `0` when the upper cutoff is below all
zero ordinates. Trivially the empty-window case of the discrete
Stieltjes integral. -/
theorem discreteStieltjesPartial_eq_zero_of_X_lt
    {Z : Ôäò ÔåÆ ÔäØ} {mult : Ôäò ÔåÆ Ôäò} {n : Ôäò} {f : ÔäØ ÔåÆ ÔäØ} {T X : ÔäØ}
    (hX : ÔêÇ j : Ôäò, j < n ÔåÆ X < Z j) :
    discreteStieltjesPartial Z mult n f T X = 0 := by
  unfold discreteStieltjesPartial
  apply Finset.sum_eq_zero
  intro j hj
  have hj_lt : j < n := Finset.mem_range.mp hj
  rw [if_neg]
  intro Ôƒ¿_, hZjÔƒ®
  exact absurd hZj (not_le_of_gt (hX j hj_lt))

-- ---------------------------------------------------------------------
-- ┬º16.3. IBP bound + `hmargin_from_ibp` bridge (Phase 1.3)
-- ---------------------------------------------------------------------
-- Bundles a `PerWindowClosedFormIBPData` together with the
-- identification `(error z).im = improper Stieltjes integral of
-- Im K_u(z) against dS(u) on [T, Ôê×)`. This is the data the existing
-- `PerWindowClosedFormIBPData.toZeroCountingFluctuationBound` needs to
-- have its `hmargin_from_ibp` hypothesis discharged constructively.

/-- **Stieltjes IBP data for a per-window package.** Given a
`PerWindowClosedFormIBPData` `P`, the analytic content required to
discharge `P.toZeroCountingFluctuationBound`'s `hmargin_from_ibp`
hypothesis splits into:

* `modelMargin_eq` ÔÇö for every `z` in `P.region` with `Im z > 0`,
  `P.modelMargin = ÔêÆIm(model z)`. (Already a per-probe fact at `P.z`
  via `P.modelMargin_eq`; here we lift it to the whole region.)
* `tail_bound` ÔÇö for every `z` in `P.region` with `Im z > 0`,
  `|(P.error z).im| Ôëñ P.modelMargin`. This is exactly the IBP-side
  estimate certified by the ┬º13 closed-form S-error bound combined
  with `Im(error z) = Ôê½_T^Ôê× Im K_u(z) dS(u)`.

Together they yield the margin hypothesis required upstream. -/
structure StieltjesIBPDataFor (P : PerWindowClosedFormIBPData) where
  modelMargin_eq :
    ÔêÇ z : Ôäé, P.region z ÔåÆ 0 < z.im ÔåÆ
      P.modelMargin = -(P.model z).im
  tail_bound :
    ÔêÇ z : Ôäé, P.region z ÔåÆ 0 < z.im ÔåÆ
      |(P.error z).im| Ôëñ P.modelMargin

/-- Ô¡É **PROVED ÔÇö Stieltjes IBP data discharges `hmargin_from_ibp`.**
Combine `tail_bound` (IBP-side estimate from ┬º13) and `modelMargin_eq`
(identification of `P.modelMargin` with `ÔêÆIm(model z)`) to get the
margin hypothesis required by
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`. -/
theorem StieltjesIBPDataFor.hmargin
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    ÔêÇ z : Ôäé, P.region z ÔåÆ 0 < z.im ÔåÆ
      |(P.error z).im| Ôëñ -(P.model z).im := by
  intro z hz hzim
  have h1 := D.tail_bound z hz hzim
  rw [D.modelMargin_eq z hz hzim] at h1
  exact h1

/-- Ô¡É **PROVED ÔÇö Stieltjes IBP data + per-window data Ôƒ╣
zero-counting fluctuation bound.** Discharges the `hmargin_from_ibp`
hypothesis of the existing
`PerWindowClosedFormIBPData.toZeroCountingFluctuationBound`
constructively. -/
noncomputable def StieltjesIBPDataFor.toZeroCountingFluctuationBound
    {P : PerWindowClosedFormIBPData}
    (D : StieltjesIBPDataFor P) :
    ZeroCountingFluctuationBound :=
  P.toZeroCountingFluctuationBound D.hmargin

/-- **PROVED ÔÇö `modelMargin_eq` specializes to the per-probe fact at
