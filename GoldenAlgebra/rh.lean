-- ---------------------------------------------------------------------
-- CLXVII: cert_2pi_7_real (vanishing-errorBound)
-- ---------------------------------------------------------------------
-- For [2ѕА, 7] the bound `log(T/(2ѕА))` vanishes at the left endpoint,
-- so a constant-D `closedFormSErrorBoundCD` is incompatible. Instead
-- use an errorBound that vanishes at `T = 2ѕА`:
--   errorBound z T := (T вИТ 2ѕА) ¬Ј y / 1000.
-- Chain: LHS вЙ§ 11(TвИТ2ѕА)y/(15ѕА¬ЈT¬≤) вЙ§ (22/15)¬ЈѕБ(T)¬Јy/T вЙ§ smoothTail вЙ§ вИТIm(model).
-- Key: ѕБ(T) вЙ• (TвИТ2ѕА)/(T¬Ј2ѕА) via `log_ge_one_sub_inv` (from add_one_le_exp).
-- Constants: 15ѕА¬ЈT¬≤ вЙ§ 15¬Ј3.15¬Ј49 = 2315.25 вЙ§ 11000.

/-- в≠Р **PROVED вАФ `cert_2pi_7_real`.** Vanishing-errorBound cert for the
irreducible first-zero sub-band `[2ѕА, 7]`. Closes the 4th and final
first-zero sub-cert. -/
theorem cert_2pi_7_real :
    вИА z : вДВ, вИА T : вДЭ,
      2 * Real.pi вЙ§ T вЖТ T вЙ§ 7 вЖТ 0 < z.im вЖТ
      2 * (1 + |z.re| + z.im) вЙ§ T вЖТ
        (T - 2 * Real.pi) * z.im / 1000
          вЙ§ -((cloudModel [] z + demoDensityTailT T z).im) := by
  intro z T hT2pi hT7 hy hreg
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt : Real.pi < 3.15 := Real.pi_lt_d2
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hT_2pi_nn : 0 вЙ§ T - 2 * Real.pi := by linarith
  have hy_nn : 0 вЙ§ z.im := le_of_lt hy
  have h_cloud_zero : (cloudModel ([] : List вДЭ) z).im = 0 := by
    simp [cloudModel]
  have htail := demoDensityTailT_neg_im T z
  have h_split :
      -((cloudModel ([] : List вДЭ) z + demoDensityTailT T z).im)
        = -(cloudModel ([] : List вДЭ) z).im + -(demoDensityTailT T z).im := by
    rw [Complex.add_im]; ring
  -- log(T/(2ѕА)) вЙ• (T - 2ѕА)/T
  have h_T_2pi_div_pos : 0 < T / (2 * Real.pi) := div_pos hT_pos h_2pi_pos
  have h_log_bound : (T - 2 * Real.pi) / T вЙ§ Real.log (T / (2 * Real.pi)) := by
    have h := Real.add_one_le_exp (-(Real.log (T / (2 * Real.pi))))
    rw [Real.exp_neg, Real.exp_log h_T_2pi_div_pos] at h
    have h_inv : (T / (2 * Real.pi))вБї¬є = (2 * Real.pi) / T := by rw [inv_div]
    rw [h_inv] at h
    have h_simp : (T - 2 * Real.pi) / T = 1 - (2 * Real.pi) / T := by
      field_simp
    rw [h_simp]
    linarith
  -- ѕБ(T) вЙ• (T - 2ѕА)/(T ¬Ј 2ѕА)
  have h_rho_ge :
      (T - 2 * Real.pi) / (T * (2 * Real.pi)) вЙ§ zeroDensityRho T := by
    unfold zeroDensityRho
    have h_step :
        (1 / (2 * Real.pi)) * ((T - 2 * Real.pi) / T)
          вЙ§ (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi)) :=
      mul_le_mul_of_nonneg_left h_log_bound (by positivity)
    have h_eq :
        (T - 2 * Real.pi) / (T * (2 * Real.pi))
          = (1 / (2 * Real.pi)) * ((T - 2 * Real.pi) / T) := by
      have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
      have h_2pi_ne : (2 * Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_2pi_pos
      rw [mul_comm T (2 * Real.pi), вЖР div_div]
      rw [mul_div_assoc' (1 / (2 * Real.pi)) (T - 2 * Real.pi) T]
      rw [one_div_mul_eq_div]
    rw [h_eq]
    exact h_step
  have h_smooth_22_15 := smoothTailRationalLowerBoundAbs_ge_22_15 hT2pi hy hreg
  -- (T-2ѕА)¬Јy/1000 вЙ§ (22/15)¬ЈѕБ(T)¬Јy/T via the ѕБ lower bound + key constant
  have h_smooth_linear :
      (T - 2 * Real.pi) * z.im / 1000
        вЙ§ (22 / 15 : вДЭ) * zeroDensityRho T * z.im / T := by
    have h_chain :
        (22 / 15 : вДЭ) * ((T - 2 * Real.pi) / (T * (2 * Real.pi))) * z.im / T
          вЙ§ (22 / 15) * zeroDensityRho T * z.im / T := by
      apply div_le_div_of_nonneg_right _ (le_of_lt hT_pos)
      apply mul_le_mul_of_nonneg_right _ hy_nn
      apply mul_le_mul_of_nonneg_left h_rho_ge (by norm_num)
    apply le_trans _ h_chain
    -- Goal: (T-2ѕА)¬Јy/1000 вЙ§ (22/15)¬Ј((T-2ѕА)/(T¬Ј2ѕА))¬Јy/T
    --     = 11¬Ј(T-2ѕА)¬Јy/(15ѕА¬ЈT¬≤)
    have hT_sq_le : T^2 вЙ§ 49 := by nlinarith
    have h_15piT_le : 15 * Real.pi * T^2 вЙ§ 11000 := by nlinarith
    have h_prod_nn : 0 вЙ§ (T - 2 * Real.pi) * z.im := mul_nonneg hT_2pi_nn hy_nn
    have h_rhs_eq :
        (22 / 15 : вДЭ) * ((T - 2 * Real.pi) / (T * (2 * Real.pi))) * z.im / T
          = 11 * (T - 2 * Real.pi) * z.im / (15 * Real.pi * T^2) := by
      have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
      have h_pi_ne : Real.pi вЙ† 0 := ne_of_gt h_pi_pos
      field_simp
      ring
    rw [h_rhs_eq]
    rw [div_le_div_iffвВА (by norm_num : (0:вДЭ) < 1000) (by positivity)]
    nlinarith [h_15piT_le, h_prod_nn, hy_nn, hT_2pi_nn]
  have h_smooth_lb :
      (T - 2 * Real.pi) * z.im / 1000
        вЙ§ smoothTailRationalLowerBoundAbs z.re z.im T :=
    le_trans h_smooth_linear h_smooth_22_15
  rw [h_split, htail, h_cloud_zero]
  linarith [h_smooth_lb]

