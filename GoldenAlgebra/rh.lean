/-- Ô¡É **PROVED ÔÇö `slabSimple_19_32_core`.** -/
lemma slabSimple_19_32_core
    {x y T : ÔäØ}
    (hx : 0 Ôëñ x) (hT19 : 19 Ôëñ T) (hT32 : T Ôëñ 32)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) Ôëñ T) :
    closedFormSErrorBoundCD 0 (1 : ÔäØ) y T
      Ôëñ simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hTpos : (0 : ÔäØ) < T := by linarith
  have hT_ne : T Ôëá 0 := ne_of_gt hTpos
  have hy_nn : 0 Ôëñ y := le_of_lt hy
  have hclosed :
      closedFormSErrorBoundCD 0 (1 : ÔäØ) y T = y * (17 / T^2) :=
    closedFormSErrorBoundCD_19_32 hT_ne
  have hscalar :
      (17 : ÔäØ) / T^2 Ôëñ 2 * cloudK_T zeros100ceil T + tailK_19_32 T :=
    scalar_19_32_cert hT19 hT32
  have hscaled :
      y * ((17 : ÔäØ) / T^2) Ôëñ y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T) :=
    mul_le_mul_of_nonneg_left hscalar hy_nn
  have hsplit :
      y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T)
        = 2 * y * cloudK_T zeros100ceil T + y * tailK_19_32 T := by ring
  have hcloud :
      2 * y * cloudK_T zeros100ceil T
        Ôëñ simpleCloudSum zeros100ceil x y :=
    simpleCloudSum_ge_admissible_T_bound zeros100ceil hx hy hreg
  have htail :
      y * tailK_19_32 T
        Ôëñ smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_affine_19_32 hx hT19 hT32 hy hreg
  rw [hclosed]
  calc
    y * ((17 : ÔäØ) / T^2)
        Ôëñ y * (2 * cloudK_T zeros100ceil T + tailK_19_32 T) := hscaled
    _ = 2 * y * cloudK_T zeros100ceil T + y * tailK_19_32 T := hsplit
    _ Ôëñ simpleCloudSum zeros100ceil x y
          + smoothTailRationalLowerBoundAbs x y T :=
        add_le_add hcloud htail

/-- ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ **PROVED ÔÇö `slabSimple_19_32_cert`.** ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ­ƒîƒ
