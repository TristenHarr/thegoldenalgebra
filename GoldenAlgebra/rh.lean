-- =====================================================================
-- CLXXXIV: Bridge adapter вАФ finite-band sandwich вЖТ LocalXiCloudDensityErrorPackage
-- =====================================================================
-- The slab bundle delivers `closedFormSErrorBoundCD C D z.im T вЙ§ -(model z).im`.
-- The companion IBP/Stieltjes machinery delivers `|Im(error z)| вЙ§ closedFormSErrorBoundCD C D z.im T`.
-- Combined, these give the `errorMargin` field of `LocalXiCloudDensityErrorPackage`,
-- which discharges `XiPullbackAntiHerglotzTarget` on the region (and via the
-- existing `XiCloudDensityCoveringFamily` chain, globally).

/-- в≠Р **PROVED вАФ generic `LocalXiCloudDensityErrorPackage` adapter from a
finite-band sandwich.**

Given:
- a model/error decomposition of `ќЫ[XiPullback]` on a region;
- the model is globally anti-Herglotz on the upper half-plane;
- for each region-z with `Im z > 0`, the error's imaginary part is sandwiched
  between a closed-form bound and the model margin (any choice of `C, D, T`
  per-z is fine);

then we get a `LocalXiCloudDensityErrorPackage`, which feeds the existing
`XiCloudDensityCoveringFamily.implies_XiPullbackAntiHerglotzTarget` chain.

This is the **post-bundle adapter**: it bridges from the numerical slab bundle
(which gives the `closedForm вЙ§ -Im(model)` side) and from the IBP/Stieltjes
machinery (which gives the `|Im(error)| вЙ§ closedForm` side) to the existing
anti-Herglotz infrastructure. -/
def localPackage_of_finiteBandSandwich
    (model error : вДВ вЖТ вДВ)
    (region : вДВ вЖТ Prop)
    (hdecomp : вИА z : вДВ, region z вЖТ
        logDerivativeResponse XiPullback z = model z + error z)
    (hmodelAnti : AntiHerglotzUHP model)
    (sandwich : вИА z : вДВ, region z вЖТ 0 < z.im вЖТ
        вИГ C D T : вДЭ,
          |(error z).im| вЙ§ closedFormSErrorBoundCD C D z.im T вИІ
          closedFormSErrorBoundCD C D z.im T вЙ§ -(model z).im) :
    LocalXiCloudDensityErrorPackage where
  model := model
  error := error
  region := region
  decomp := hdecomp
  modelAnti := hmodelAnti
  errorMargin := by
    intro z hreg hz
    obtain вЯ®C, D, T, herr, hclosedвЯ© := sandwich z hreg hz
    exact le_trans herr hclosed

-- =====================================================================
-- CLXXXIVa: Deterministic slab (C, D) selector + closed-form margin lemma
-- =====================================================================
-- Replaces the existential `вИГ C D` in `hclosed_on_10_140_zeros100ceil` with
-- a deterministic `slabCD : вДЭ вЖТ вДЭ √Ч вДЭ` that picks the right (C, D) per T.
-- Essential for composing with the IBP/Stieltjes error bound, which must
-- use the SAME (C, D) as the slab cert.

/-- **Deterministic slab `(C, D)` selector.** Maps `T вИИ [10, 140]` to the
slab-specific `(C, D)` pair from `NineSlabSimplePolyInequalities`. -/
noncomputable def slabCD (T : вДЭ) : вДЭ √Ч вДЭ :=
  if T вЙ§ 12 then (0, 21/100)
  else if T вЙ§ 13 then (0, 31/100)
  else if T вЙ§ 14 then (0, 44/100)
  else if T вЙ§ 19 then (0, 1/2)
  else if T вЙ§ 32 then (0, 1)
  else if T вЙ§ 36 then (1/2, 1/2)
  else if T вЙ§ 48 then (1/2, 1)
  else if T вЙ§ 80 then (1/2, 49/20)
  else (1/2, 49/20)

/-- в≠Р **PROVED вАФ Single-slab chain: slab cert + cloud im + tail LB вЖТ model margin.**

For a `CloudDensityTailModelDecomposition M` with `zeros = zeros100ceil`,
any per-slab `SlabSimplePolyIneq` over `zeros100ceil` discharges
`closedFormSErrorBoundCD C D z.im T вЙ§ -(M.model z).im`. Chains:
`closedForm вЙ§ simpleCloudSum + smoothTail вЙ§ cloudImNegSum + (-Im densityTail) = -Im model`. -/
lemma closedFormSErrorBoundCD_le_neg_model_im_of_slabSimple
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    {Tmin Tmax C D : вДЭ}
    (slab : SlabSimplePolyIneq zeros100ceil Tmin Tmax C D)
    {z : вДВ} {T : вДЭ}
    (hTmin : Tmin вЙ§ T) (hTmax : T вЙ§ Tmax)
    (hT_2pi : 2 * Real.pi вЙ§ T)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    closedFormSErrorBoundCD C D z.im T вЙ§ -(M.model z).im := by
  have hclosed :
      closedFormSErrorBoundCD C D z.im T
        вЙ§ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im T :=
    slab z.re z.im T hTmin hTmax hy hreg
  have h_cloud_bound :
      simpleCloudSum zeros100ceil z.re z.im
        вЙ§ cloudImNegSum zeros100ceil z.re z.im :=
    cloudImNegSum_ge_simpleCloudSum zeros100ceil z.re z.im hy
  have h_cloud_im :
      -(cloudModel zeros100ceil z).im = cloudImNegSum zeros100ceil z.re z.im :=
    cloudModel_neg_im_at zeros100ceil z
  have h_tail_lb :
      smoothTailRationalLowerBoundAbs z.re z.im T вЙ§ -(M.densityTail z).im :=
    M.densityTailRationalLB z T hT_2pi hy hreg
  have h_model : M.model z = cloudModel M.zeros z + M.densityTail z := rfl
  have h_model' : M.model z = cloudModel zeros100ceil z + M.densityTail z := by
    rw [h_model, hM_zeros]
  have h_model_im :
      -(M.model z).im = -(cloudModel zeros100ceil z).im + -(M.densityTail z).im := by
    rw [h_model', Complex.add_im]; ring
  calc closedFormSErrorBoundCD C D z.im T
      вЙ§ simpleCloudSum zeros100ceil z.re z.im
          + smoothTailRationalLowerBoundAbs z.re z.im T := hclosed
    _ вЙ§ cloudImNegSum zeros100ceil z.re z.im + -(M.densityTail z).im := by linarith
    _ = -(cloudModel zeros100ceil z).im + -(M.densityTail z).im := by rw [h_cloud_im]
    _ = -(M.model z).im := h_model_im.symm

/-- рЯОѓрЯОѓрЯОѓ **PROVED вАФ Deterministic `hclosed_on_10_140_zeros100ceil`** using `slabCD`.

Whereas `hclosed_on_10_140_zeros100ceil` returns an existential `вИГ C D`,
this version commits to a specific `(C, D) = slabCD T`. Critical for
composing with the IBP/Stieltjes error bound. -/
theorem hclosed_on_10_140_zeros100ceil_slabCD
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
    {z : вДВ} {T : вДЭ}
    (hT10 : 10 вЙ§ T) (hT140 : T вЙ§ 140)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) вЙ§ T) :
    closedFormSErrorBoundCD (slabCD T).1 (slabCD T).2 z.im T
      вЙ§ -(M.model z).im := by
  have hT_2pi : 2 * Real.pi вЙ§ T := by
    have := Real.pi_lt_d2; linarith
  unfold slabCD
  by_cases h12 : T вЙ§ 12
  ¬Ј simp only [if_pos h12]
    exact closedFormSErrorBoundCD_le_neg_model_im_of_slabSimple
      M hM_zeros nineSlabSimpleCerts_zeros100ceil.poly_10_12
      hT10 h12 hT_2pi hy hreg
  push_neg at h12
  have h12_le : (12 : вДЭ) вЙ§ T := le_of_lt h12
  rw [if_neg (not_le.mpr h12)]
  by_cases h13 : T вЙ§ 13
