      intro s hs
      -- Membership in a literal 9-element list decomposes to 9 disjuncts.
      -- The default `simp` set fully reduces `s тИИ [s1, ..., s9]` to
      -- `s = s1 тИи ... тИи s = s9`.
      simp at hs
      rcases hs with rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl <;>
        rfl
    Tmin_total := 10
    Tmax_total := 140
    Tmin_ge_two_pi := h_2pi_lt_10
    cover := by
      intro T hT10 hT140
      by_cases h1 : T тЙд 12
      ┬╖ exact тЯиs1, List.mem_cons_self .., hT10, h1тЯй
      push_neg at h1
      by_cases h2 : T тЙд 13
      ┬╖ refine тЯиs2, ?_, le_of_lt h1, h2тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons_self ..))
      push_neg at h2
      by_cases h3 : T тЙд 14
      ┬╖ refine тЯиs3, ?_, le_of_lt h2, h3тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons_self ..))))
      push_neg at h3
      by_cases h4 : T тЙд 19
      ┬╖ refine тЯиs4, ?_, le_of_lt h3, h4тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons_self ..))))))
      push_neg at h4
      by_cases h5 : T тЙд 32
      ┬╖ refine тЯиs5, ?_, le_of_lt h4, h5тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons_self ..))))))))
      push_neg at h5
      by_cases h6 : T тЙд 36
      ┬╖ refine тЯиs6, ?_, le_of_lt h5, h6тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons_self ..))))))))))
      push_neg at h6
      by_cases h7 : T тЙд 48
      ┬╖ refine тЯиs7, ?_, le_of_lt h6, h7тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons.mpr
                        (Or.inr (List.mem_cons_self ..))))))))))))
      push_neg at h7
      by_cases h8 : T тЙд 80
      ┬╖ refine тЯиs8, ?_, le_of_lt h7, h8тЯй
        exact List.mem_cons.mpr (Or.inr (List.mem_cons.mpr
                (Or.inr (List.mem_cons.mpr
                  (Or.inr (List.mem_cons.mpr
                    (Or.inr (List.mem_cons.mpr
                      (Or.inr (List.mem_cons.mpr
