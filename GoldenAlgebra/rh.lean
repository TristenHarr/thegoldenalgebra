    rw [show (22 / 15 : ℝ) * (((2/5 : ℝ) + (T - 12) / 10) / (2 * Real.pi)) * (y / T)
          = (22 / 15 : ℝ) * (((2/5 : ℝ) + (T - 12) / 10) / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : ℝ) * zeroDensityRho T * (y / T)
