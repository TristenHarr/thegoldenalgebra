-- =====================================================================
-- ┬зCCLXXVIII. Structural reduction of `LowMarginDominatesExplicitBound`
--             to a single model-side rational/log arithmetic inequality
-- =====================================================================
-- `LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi` is the
-- model-side half of the ┬зCCLXXVII split. It is purely model-side тАФ
-- no `╬Ы[╬Ю]` content тАФ so it should reduce to rational/log arithmetic
-- on the compact low region. This section discharges the structural
-- pieces (cloud anti-Herglotz `-Im` identity, smooth-tail CLV bound
-- via `HonestSmoothTailRationalLB_twoPi` at `T = 10`, and additive
-- `Im` decomposition of the honest model) and exposes the remaining
-- analytic obligation as a single named arithmetic Prop.
--
-- After this section, the entire low-band model obligation is
-- `lowResidualExplicitBound z тЙд simpleCloudSum + smoothTailRationalLowerBoundAbs(...,10)`
-- on `lowCompactRegion z` тАФ a pure inequality in `z.re`, `z.im`, and the
-- 100-element list `zeros100ceil`, with no complex analysis remaining.
--
-- Adds:
--   honestZeroDensityModelTwoPi_model_eq          тАФ definitional decomp
--   honestZeroDensityModelTwoPi_neg_im_eq          тАФ `-Im(model)` splits
--   lowModelMarginEnvelope_eq_cloud_plus_smooth   тАФ envelope form
--   honestZeroDensityModelTwoPi_cloud_simpleLB    тАФ cloud LB via simpleCloudSum
--   honestZeroDensityModelTwoPi_smooth_LB_at_10   тАФ smooth LB at T=10 via CLV
--   LowExplicitArithmeticBound                     тАФ named arithmetic Prop
--   LowMarginDominatesExplicitBound_twoPi_of_arith тАФ `_of_arith` reduction
--   XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit_arith
--                                                  тАФ front door consuming arith

/-- тнР **PROVED тАФ model decomposition at `Tsmooth := 2╧А`.** The honest
model is definitionally the sum of the paired finite cloud on
`zeros100ceil` and the `zeroDensitySmoothTailModel` at `2╧А`. -/
lemma honestZeroDensityModelTwoPi_model_eq (z : тДВ) :
    honestZeroDensityModelTwoPi.model z
      = cloudModel zeros100ceil z
        + zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z := rfl

/-- тнР **PROVED тАФ `-Im` of the honest model splits additively.** -/
lemma honestZeroDensityModelTwoPi_neg_im_eq (z : тДВ) :
    -(honestZeroDensityModelTwoPi.model z).im
      = -(cloudModel zeros100ceil z).im
        + -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  rw [honestZeroDensityModelTwoPi_model_eq, Complex.add_im]
  ring

/-- тнР **PROVED тАФ envelope form of the additive `-Im` split.** -/
lemma lowModelMarginEnvelope_eq_cloud_plus_smooth (z : тДВ) :
    lowModelMarginEnvelope z
      = -(cloudModel zeros100ceil z).im
        + -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  unfold lowModelMarginEnvelope
  exact honestZeroDensityModelTwoPi_neg_im_eq z

/-- тнР **PROVED тАФ cloud part of the model margin is bounded below by
`simpleCloudSum`.** Composes `cloudImNegSum_ge_simpleCloudSum` with the
identity `-Im(cloudModel) = cloudImNegSum`. -/
lemma honestZeroDensityModelTwoPi_cloud_simpleLB
    {z : тДВ} (hy : 0 < z.im) :
    simpleCloudSum zeros100ceil z.re z.im
      тЙд -(cloudModel zeros100ceil z).im := by
  rw [cloudModel_neg_im_at]
  exact cloudImNegSum_ge_simpleCloudSum zeros100ceil z.re z.im hy

/-- тнР **PROVED тАФ smooth part of the model margin at `T = 10`** via
`HonestSmoothTailRationalLB_twoPi`. The choice `T := 10` is forced by
the low compact regime `2(1 + |z.re| + z.im) тЙд 10`. -/
lemma honestZeroDensityModelTwoPi_smooth_LB_at_10
    {z : тДВ} (hz : lowCompactRegion z) :
    smoothTailRationalLowerBoundAbs z.re z.im 10
      тЙд -(zeroDensitySmoothTailModel (2 * Real.pi) le_rfl z).im := by
  have h2pi_le_10 : 2 * Real.pi тЙд 10 := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  exact HonestSmoothTailRationalLB_twoPi z 10 h2pi_le_10 hz.1 hz.2

/-- ЁЯУж **`LowExplicitArithmeticBound`** тАФ the named pure-arithmetic
obligation isolated by the ┬зCCLXXVIII reduction. After all structural
content is discharged, `LowMarginDominatesExplicitBound` reduces to
this single rational/log inequality on the compact low region:
```
lowResidualExplicitBound z
  тЙд simpleCloudSum zeros100ceil z.re z.im
      + smoothTailRationalLowerBoundAbs z.re z.im 10
```
No complex analysis remaining тАФ only the explicit closed-form
expressions in `z.re`, `z.im`, and the 100-element list. -/
def LowExplicitArithmeticBound : Prop :=
  тИА z : тДВ,
    lowCompactRegion z тЖТ
    lowResidualExplicitBound z
      тЙд simpleCloudSum zeros100ceil z.re z.im
        + smoothTailRationalLowerBoundAbs z.re z.im 10

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **PROVED тАФ `LowMarginDominatesExplicitBound` from the
arithmetic Prop.** The structural decomposition (cloud `-Im` identity,
smooth-tail CLV LB at `T=10`, additive `Im` split) discharges all
complex-analytic content; the remaining obligation is the named
`LowExplicitArithmeticBound`. -/
theorem LowMarginDominatesExplicitBound_twoPi_of_arith
    (harith : LowExplicitArithmeticBound) :
    LowMarginDominatesExplicitBound honestZeroDensityModelTwoPi := by
  intro z hz
  have hcloud := honestZeroDensityModelTwoPi_cloud_simpleLB hz.1
  have hsmooth := honestZeroDensityModelTwoPi_smooth_LB_at_10 hz
  have harith_z := harith z hz
  rw [honestZeroDensityModelTwoPi_neg_im_eq]
  linarith

/-- ЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯЁЯМЯ **FINAL
FRONT DOOR (twoPi + tail limits + low explicit split with arithmetic).**

The low-band model obligation is now reduced to a single pure
rational/log arithmetic inequality:

```
hTuring + hHighLog              (parallel agent)
+ Hcanon_tailLimit              (mid residual Tendsto)
+ Hhigh_tailLimit               (high residual Tendsto)
+ Hlow_explicit                 (xi: residual тЙд closed-form first-zero bound)
+ Hlow_arith                    (model-side: pure arithmetic on the box)
тЯ╣ XiPullbackAntiHerglotzTarget
```

The `Hlow_arith` input is `LowExplicitArithmeticBound` тАФ no complex
analysis, no `╬Ы[╬Ю]`, just an inequality in `z.re`, `z.im`, and the
100-element `zeros100ceil` list. -/
theorem XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit_arith
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : тДЭ)
    (hT0_pos : 0 < T0) (hT0_le_10 : T0 тЙд 10)
    (hTuring :
      тИА {z : тДВ} {T u : тДЭ},
        10 тЙд T тЖТ T тЙд 140 тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (slabCD T).1 * Real.log u + (slabCD T).2)
    (hHighLog :
      тИА {z : тДВ} {T u : тДЭ},
        140 тЙд T тЖТ 0 < z.im тЖТ
        2 * (1 + |z.re| + z.im) тЙд T тЖТ
        T тЙд u тЖТ
        |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u|
          тЙд (1 / 2 : тДЭ) * Real.log u + (49 / 20 : тДЭ))
    (Hcanon_tailLimit :
      XiCanonicalResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hhigh_tailLimit :
      XiHighResidualAsTailLimit Dzero T0 honestZeroDensityModelTwoPi)
    (Hlow_explicit :
      XiLowResidualExplicitData honestZeroDensityModelTwoPi)
    (Hlow_arith : LowExplicitArithmeticBound) :
    XiPullbackAntiHerglotzTarget :=
  XiPullbackAntiHerglotzTarget_of_twoPiModel_lowExplicit
    Dzero T0 hT0_pos hT0_le_10 hTuring hHighLog
