noncomputable def localXiPackage_of_trueKernelTailData
    (S : ÔäØ ÔåÆ ÔäØ) (R : RealIBPFamilyData S)
    (M : CloudDensityTailModelDecomposition)
    (hM_zeros : M.zeros = zeros100ceil)
