-- CLX-D + CLX-E: FirstZeroDirectBandCertificate (slot)
-- ---------------------------------------------------------------------
-- Bypasses the `closedFormSErrorBoundCD` envelope (whose `8 + 18` IBP
-- constants inflate any `D` by ~17├Ч, blocking even `D = 0.125` on
-- `[2╧А, 10]`). The `errorBound` field is a function `тДВ тЖТ тДЭ` so the
-- closed-form can target a concrete integral against `-NтВА(u)` rather
-- than the generic `(C┬╖log u + D)`-envelope expression.

/-- **First-zero direct-band model-margin certificate.** A slot for a
sharper error formula on a slab `[A, B] тКЖ [2╧А, ╬│тВБ)`. The crucial
difference from `FiniteSlabModelMarginCertificate` is the
function-valued `errorBound : тДВ тЖТ тДЭ`, which can target a concrete
integral expression against `-NтВА(u)` rather than the generic
`(C┬╖log u + D)`-envelope. -/
structure FirstZeroDirectBandCertificate where
  A : тДЭ
  B : тДЭ
  gamma1 : тДЭ
  A_ge_two_pi : 2 * Real.pi тЙд A
  A_le_B : A тЙд B
  B_lt_gamma1 : B < gamma1
  model : тДВ тЖТ тДВ
  errorBound : тДВ тЖТ тДЭ
  cert :
    тИА z : тДВ, тИА T : тДЭ,
      A тЙд T тЖТ T тЙд B тЖТ
      0 < z.im тЖТ 2 * (1 + |z.re| + z.im) тЙд T тЖТ
        errorBound z тЙд -(model z).im

/-- тнР **PROVED тАФ `FirstZeroDirectBandCertificate тЯ╣ ModelMarginLowerBound`**
for any probe in the certified slab. Same shape as the per-probe
projections on the other certificate structures. -/
noncomputable def FirstZeroDirectBandCertificate.atProbe
    (F : FirstZeroDirectBandCertificate)
    (z : тДВ) (T : тДЭ)
    (hAT : F.A тЙд T) (hTB : T тЙд F.B)
    (hy : 0 < z.im) (hreg : 2 * (1 + |z.re| + z.im) тЙд T) :
    ModelMarginLowerBound where
  model := F.model
  z := z
  T := T
  lowerBound := F.errorBound z
  lowerBound_le := F.cert z T hAT hTB hy hreg

