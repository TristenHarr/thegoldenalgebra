-- ---------------------------------------------------------------------

noncomputable def cloudK64_80_const : тДЭ := 9 / 1000

lemma cloudK64_80_const_le_zeros100ceil_sum :
    cloudK64_80_const тЙд
      (zeros100ceil.map (fun ╬│ : тДЭ => 1 / (((39 : тДЭ)^2) + ╬│^2))).sum := by
  unfold cloudK64_80_const zeros100ceil
  simp only [List.map_cons, List.sum_cons, List.map_nil, List.sum_nil, add_zero]
  norm_num

lemma cloudK_T_zeros100ceil_ge_const_64_80
    {T : тДЭ} (hT64 : 64 тЙд T) (hT80 : T тЙд 80) :
    cloudK64_80_const тЙд cloudK_T zeros100ceil T := by
  have h_static := cloudK64_80_const_le_zeros100ceil_sum
  unfold cloudK_T
  have h_sum_le :
      (zeros100ceil.map (fun ╬│ : тДЭ => 1 / (((39 : тДЭ)^2) + ╬│^2))).sum
        тЙд (zeros100ceil.map (fun ╬│ : тДЭ => 1 / (((T / 2 - 1)^2) + ╬│^2))).sum := by
    apply List.sum_le_sum
    intro a _ha
    apply one_div_Tbox_le_one_div_of_box (B := 39)
    ┬╖ linarith
    ┬╖ linarith
    ┬╖ linarith
  linarith [h_static, h_sum_le]

lemma slabSimple_64_80_core
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hT64 : 64 тЙд T) (hT80 : T тЙд 80)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) (49 / 20 : тДЭ) y T
      тЙд simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hT48 : (48 : тДЭ) тЙд T := by linarith
  have hTpos : (0 : тДЭ) < T := by linarith
  have hT_ge_one : (1 : тДЭ) тЙд T := by linarith
  have hT2_ge : ((64 : тДЭ))^2 тЙд T^2 := by nlinarith
  have hlog_le : Real.log T тЙд 5 := log_T_le_5_of_le_140 hTpos (by linarith)
  have habs :=
    closedFormSErrorBoundCD_subband_le_const (A := (64 : тДЭ)) (L := (5 : тДЭ))
      (le_of_lt hy) hTpos hT_ge_one (by norm_num : (0:тДЭ) < (64:тДЭ)^2)
      hT2_ge (by norm_num : (0:тДЭ) тЙд (5:тДЭ)) hlog_le
  have h_const_eq : ((17/2 : тДЭ) * 5 + 439/10) / (64 : тДЭ)^2 = 27/1280 := by
    norm_num
  rw [h_const_eq] at habs
  have hcloud := cloudK_T_zeros100ceil_ge_const_64_80 hT64 hT80
  have htail :=
    tailK_80_140_ge_seven_fifteen_div hTpos (by norm_num : (0:тДЭ) < 80)
      (by linarith : T тЙд 80)
  -- 7/(15*80) = 7/1200
  have h_tail_eq : (7 / (15 * 80) : тДЭ) = 7/1200 := by norm_num
  rw [h_tail_eq] at htail
  apply slabSimple_48_80_subband_assembly hx hy hreg hT48 hT80
    habs hcloud htail
  -- scalar: 27/1280 тЙд 2*(9/1000) + 7/1200
  show (27/1280 : тДЭ) тЙд 2 * cloudK64_80_const + 7/1200
  unfold cloudK64_80_const
  norm_num

