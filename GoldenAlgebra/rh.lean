noncomputable def largeTScalarMarginConditionTwoThirds (T : вДЭ) : Prop :=
  (17 / 2) * Real.log T + 439 / 10
    вЙ§ (T / (3 * Real.pi)) * Real.log (T / (2 * Real.pi))

/-- в≠Р **PROVED вАФ `c = 2/3` scalar condition вЯє closed-form domination
at `(C, D) = (1/2, 49/20)`** for `T вЙ• 250`.

Chain:
  `(y/T¬≤) ¬Ј ((17/2)¬Јlog T + 439/10)`
    `вЙ§ (y/T¬≤) ¬Ј (T/(3ѕА)) ¬Ј log(T/(2ѕА))`        (scalar condition)
    `= (2/3) ¬Ј ѕБ(T) ¬Ј y / T`                    (algebraic identity)
    `вЙ§ smoothTailRationalLowerBoundAbs x y T`   (CLIV-A). -/
theorem largeTScalarConditionTwoThirds_implies_domination
    {x y T : вДЭ}
    (hT250 : 250 вЙ§ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) вЙ§ T)
    (hscalar : largeTScalarMarginConditionTwoThirds T) :
    closedFormSErrorBoundCD (1 / 2 : вДЭ) (49 / 20 : вДЭ) y T
      вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  have h_2pi_lt_250 : 2 * Real.pi < 250 := by
    have h_pi_lt : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hT2pi : 2 * Real.pi вЙ§ T := le_trans (le_of_lt h_2pi_lt_250) hT250
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT2_pos : 0 < T^2 := by positivity
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  have h_yT2_nn : 0 вЙ§ y / T^2 := div_nonneg hy_nn (le_of_lt hT2_pos)
  have h_step2 :
      (y / T^2) * ((17 / 2) * Real.log T + 439 / 10)
        вЙ§ (y / T^2) * ((T / (3 * Real.pi)) * Real.log (T / (2 * Real.pi))) :=
    mul_le_mul_of_nonneg_left hscalar h_yT2_nn
  have h_step3 :
      (y / T^2) * ((T / (3 * Real.pi)) * Real.log (T / (2 * Real.pi)))
        = (2 / 3) * zeroDensityRho T * y / T := by
    unfold zeroDensityRho
    have hpi_ne : (Real.pi : вДЭ) вЙ† 0 := ne_of_gt h_pi_pos
    field_simp; ring
  rw [h_step3] at h_step2
  have h_geom :
      (2 / 3) * zeroDensityRho T * y / T
        вЙ§ smoothTailRationalLowerBoundAbs x y T :=
