-- ---------------------------------------------------------------------
-- CLV-A: Tighter geometric lower bound вАФ constant 22/15 вЙИ 1.467
-- ---------------------------------------------------------------------
-- Term-by-term analysis on the adaptive A = 2 region.
-- Substitute r = |x|/T, s = y/T. Then r + s вЙ§ 1/2 and
--   smoothTailRationalLowerBoundAbs = ѕБ(T) ¬Ј (y/T) ¬Ј q(r, s),
-- where
--   q(r, s) = (1-r)/((1-r)¬≤ + s¬≤) + (1+r)/((1+r)¬≤ + s¬≤).
-- Term-by-term minimization (each decreasing in s):
--   first term вЙ• a/(a¬≤ + (a-1/2)¬≤) вЙ• 4/5  at a = 1   (a вИИ [1/2, 1]);
--   second term вЙ• b/(b¬≤ + (3/2-b)¬≤) вЙ• 2/3 at b = 3/2 (b вИИ [1, 3/2]).
-- Therefore q вЙ• 4/5 + 2/3 = 22/15.
--
-- Unscaled-variable proof (used below):
--   YвВБ := y(TвИТ|x|)/((TвИТ|x|)¬≤ + y¬≤) вЙ• 4y/(5T)
--     вЯЇ 5T(TвИТ|x|) вЙ• 4((TвИТ|x|)¬≤ + y¬≤)
--     вЯЇ (TвИТ|x|)(T+4|x|) вЙ• 4y¬≤,
--     via (TвИТ|x|)(T+4|x|) вЙ• (TвИТ2|x|)¬≤ вЙ• 4y¬≤
--     (first using |x|(7T вИТ 8|x|) вЙ• 0, second using 2y вЙ§ T вИТ 2|x|).
--   YвВВ := y(T+|x|)/((T+|x|)¬≤ + y¬≤) вЙ• 2y/(3T)
--     вЯЇ 3T(T+|x|) вЙ• 2((T+|x|)¬≤ + y¬≤)
--     вЯЇ (T+|x|)(TвИТ2|x|) вЙ• 2y¬≤,
--     via 2(T+|x|)(TвИТ2|x|) вЙ• (TвИТ2|x|)¬≤ вЙ• 4y¬≤
--     (first using (TвИТ2|x|)(T+4|x|) вЙ• 0).
--   Sum: 4y/(5T) + 2y/(3T) = 22y/(15T).

/-- в≠Р **PROVED вАФ tighter rational tail lower bound, constant 22/15.**

On the canonical adaptive `A = 2` region with `T вЙ• 2ѕА`:
  `smoothTailRationalLowerBoundAbs x y T вЙ• (22/15) ¬Ј ѕБ(T) ¬Ј y / T`.

Drops the scalar threshold from ~236 to ~135. -/
theorem smoothTailRationalLowerBoundAbs_ge_22_15
    {x y T : вДЭ}
    (hT : 2 * Real.pi вЙ§ T)
    (hy : 0 < y)
    (hadapt : 2 * (1 + |x| + y) вЙ§ T) :
    (22 / 15) * zeroDensityRho T * y / T
      вЙ§ smoothTailRationalLowerBoundAbs x y T := by
  unfold smoothTailRationalLowerBoundAbs
  have hѕБ_nn : 0 вЙ§ zeroDensityRho T := zeroDensityRho_nonneg_of_ge_two_pi hT
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have hT_pos : 0 < T := by linarith
  have hT_ne : T вЙ† 0 := ne_of_gt hT_pos
  have hT_nn : 0 вЙ§ T := le_of_lt hT_pos
  have hy_nn : 0 вЙ§ y := le_of_lt hy
  have hx_nn : 0 вЙ§ |x| := abs_nonneg x
  -- Adaptive вЗТ |x| вЙ§ T/2 вИТ 1, y вЙ§ T/2 вИТ 1 вИТ |x|, hence 2y вЙ§ T вИТ 2|x|
  have hx_le : |x| вЙ§ T / 2 - 1 := by linarith
  have hy_le_x : y вЙ§ T / 2 - 1 - |x| := by linarith
  have h_2y_le : 2 * y вЙ§ T - 2 * |x| := by linarith
  have h_Tm2x_pos : 0 < T - 2 * |x| := by linarith
  have h_Tm2x_nn : 0 вЙ§ T - 2 * |x| := le_of_lt h_Tm2x_pos
  -- Standard positivity
  have h_tmx_pos : 0 < T - |x| := by linarith
  have h_tmx_nn : 0 вЙ§ T - |x| := le_of_lt h_tmx_pos
  have h_tpx_pos : 0 < T + |x| := by linarith
  have h_tpx_nn : 0 вЙ§ T + |x| := le_of_lt h_tpx_pos
  -- 7T вЙ• 8|x| (from |x| вЙ§ T/2, so 8|x| вЙ§ 4T вЙ§ 7T)
  have h_7T_ge_8x : 8 * |x| вЙ§ 7 * T := by linarith
  have h_T_p_4x_nn : 0 вЙ§ T + 4 * |x| := by linarith
  have h_denom1_pos : 0 < (T - |x|)^2 + y^2 := by positivity
  have h_denom2_pos : 0 < (T + |x|)^2 + y^2 := by positivity
  -- (2y)¬≤ вЙ§ (T вИТ 2|x|)¬≤ from 2y вЙ§ T вИТ 2|x|, both nonneg
  have h_2y_nn : 0 вЙ§ 2 * y := by linarith
  have h_4y_sq_le : 4 * y^2 вЙ§ (T - 2 * |x|)^2 := by
    have h := pow_le_pow_leftвВА h_2y_nn h_2y_le 2
    have h_2y_eq : (2 * y)^2 = 4 * y^2 := by ring
    linarith [h, h_2y_eq]
  -- ----- Lemma 1: YвВБ вЙ• 4y/(5T) -----
  -- (TвИТ|x|)(T+4|x|) вИТ (TвИТ2|x|)¬≤ = |x|¬Ј(7T вИТ 8|x|) вЙ• 0
  have h_alg1 :
      (T - |x|) * (T + 4 * |x|) - (T - 2 * |x|)^2
        = |x| * (7 * T - 8 * |x|) := by ring
  have h_alg1_diff_nn :
      0 вЙ§ |x| * (7 * T - 8 * |x|) :=
    mul_nonneg hx_nn (by linarith)
  have h_step1a : (T - 2 * |x|)^2 вЙ§ (T - |x|) * (T + 4 * |x|) := by
    linarith [h_alg1, h_alg1_diff_nn]
  have h_step1b : 4 * y^2 вЙ§ (T - |x|) * (T + 4 * |x|) := by
    linarith [h_4y_sq_le, h_step1a]
  -- 5T(T вИТ |x|) вИТ 4((TвИТ|x|)¬≤ + y¬≤) = (TвИТ|x|)(T+4|x|) вИТ 4y¬≤
  have h_alg1_full :
      5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)
        = (T - |x|) * (T + 4 * |x|) - 4 * y^2 := by ring
  have h_alg1_full_nn :
      0 вЙ§ 5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2) := by
    linarith [h_alg1_full, h_step1b]
  have h_5T_pos : 0 < 5 * T := by linarith
  have h_Y1_ge :
      4 * y / (5 * T) вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2) := by
    rw [div_le_div_iffвВА h_5T_pos h_denom1_pos]
    have h_calc :
        y * (T - |x|) * (5 * T) - 4 * y * ((T - |x|)^2 + y^2)
          = y * (5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)) := by ring
    have h_nn :
        0 вЙ§ y * (5 * T * (T - |x|) - 4 * ((T - |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg1_full_nn
    linarith
  -- ----- Lemma 2: YвВВ вЙ• 2y/(3T) -----
  -- 2(T+|x|)(TвИТ2|x|) вИТ (TвИТ2|x|)¬≤ = (TвИТ2|x|)¬Ј(T + 4|x|) вЙ• 0
  have h_alg2 :
      2 * ((T + |x|) * (T - 2 * |x|)) - (T - 2 * |x|)^2
        = (T - 2 * |x|) * (T + 4 * |x|) := by ring
  have h_alg2_diff_nn :
      0 вЙ§ (T - 2 * |x|) * (T + 4 * |x|) :=
    mul_nonneg h_Tm2x_nn h_T_p_4x_nn
  have h_step2a :
      (T - 2 * |x|)^2 вЙ§ 2 * ((T + |x|) * (T - 2 * |x|)) := by
    linarith [h_alg2, h_alg2_diff_nn]
  have h_step2b : 2 * y^2 вЙ§ (T + |x|) * (T - 2 * |x|) := by
    linarith [h_4y_sq_le, h_step2a]
  -- 3T(T+|x|) вИТ 2((T+|x|)¬≤ + y¬≤) = (T+|x|)(TвИТ2|x|) вИТ 2y¬≤
  have h_alg2_full :
      3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2)
        = (T + |x|) * (T - 2 * |x|) - 2 * y^2 := by ring
  have h_alg2_full_nn :
      0 вЙ§ 3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2) := by
    linarith [h_alg2_full, h_step2b]
  have h_3T_pos : 0 < 3 * T := by linarith
  have h_Y2_ge :
      2 * y / (3 * T) вЙ§ y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    rw [div_le_div_iffвВА h_3T_pos h_denom2_pos]
    have h_calc :
        y * (T + |x|) * (3 * T) - 2 * y * ((T + |x|)^2 + y^2)
          = y * (3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2)) := by ring
    have h_nn :
        0 вЙ§ y * (3 * T * (T + |x|) - 2 * ((T + |x|)^2 + y^2)) :=
      mul_nonneg hy_nn h_alg2_full_nn
    linarith
  -- Combine: 4y/(5T) + 2y/(3T) = (12y + 10y)/(15T) = 22y/(15T)
  have h_sum_eq :
      4 * y / (5 * T) + 2 * y / (3 * T) = 22 * y / (15 * T) := by
    field_simp; ring
  have h_sum_ge :
      22 * y / (15 * T)
        вЙ§ y * (T - |x|) / ((T - |x|)^2 + y^2)
            + y * (T + |x|) / ((T + |x|)^2 + y^2) := by
    have h := add_le_add h_Y1_ge h_Y2_ge
    rw [h_sum_eq] at h
    exact h
  -- Multiply by ѕБ(T) вЙ• 0
  have h_mul :
      zeroDensityRho T * (22 * y / (15 * T))
        вЙ§ zeroDensityRho T *
            (y * (T - |x|) / ((T - |x|)^2 + y^2)
              + y * (T + |x|) / ((T + |x|)^2 + y^2)) :=
    mul_le_mul_of_nonneg_left h_sum_ge hѕБ_nn
  -- Reshuffle: (22/15) ¬Ј ѕБ(T) ¬Ј y / T = ѕБ(T) ¬Ј (22y/(15T))
  have h_eq :
      (22 / 15) * zeroDensityRho T * y / T
        = zeroDensityRho T * (22 * y / (15 * T)) := by
    field_simp; ring
  rw [h_eq]
  exact h_mul

