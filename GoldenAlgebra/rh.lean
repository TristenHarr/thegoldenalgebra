      (17/2 : ℝ) * Real.log T + 439/10 ≤ (17/2 : ℝ) * L + 439/10 := by
    nlinarith
  have h_L_coeff_nn : 0 ≤ (17/2 : ℝ) * L + 439/10 := by
    have h1 : 0 ≤ (17/2 : ℝ) * L := mul_nonneg (by norm_num) hL_nn
    linarith
