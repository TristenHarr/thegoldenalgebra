namespace OverflowResidueRH

open Complex Filter Topology

-- =====================================================================
-- ┬з1. Sign laws
-- =====================================================================

/-- **Anti-Herglotz upper-half-plane sign law.** `R : тДВ тЖТ тДВ` is
anti-Herglotz iff `Im R z тЙд 0` for every `z` with `Im z > 0`. The sign law
of any real-rooted residue cloud `╬г m_j / (z тИТ r_j)` with real `r_j` and
positive `m_j`. -/
def AntiHerglotzUHP (R : тДВ тЖТ тДВ) : Prop :=
  тИА z : тДВ, 0 < z.im тЖТ (R z).im тЙд 0

/-- **Positive upper imaginary escape.** Some upper-half-plane point has
strictly positive imaginary response тАФ the witness produced by a nonreal
upper-half-plane pole of the function whose log-derivative is `R`. -/
def PositiveUpperImaginaryEscape (R : тДВ тЖТ тДВ) : Prop :=
  тИГ z : тДВ, 0 < z.im тИз 0 < (R z).im

/-- **The clean iff.** Anti-Herglotz on the upper half-plane is precisely
the absence of positive upper-imaginary escape. -/
theorem antiHerglotz_iff_no_positiveUpperEscape (R : тДВ тЖТ тДВ) :
    AntiHerglotzUHP R тЖФ ┬м PositiveUpperImaginaryEscape R := by
  unfold AntiHerglotzUHP PositiveUpperImaginaryEscape
  constructor
  ┬╖ intro hanti тЯиz, hzim, hRimтЯй
    exact absurd (hanti z hzim) (not_le.mpr hRim)
  ┬╖ intro hno z hzim
    by_contra hpos
    push_neg at hpos
    exact hno тЯиz, hzim, hposтЯй

/-- The logical gate тАФ restating the iff as the contradiction direction. -/
theorem positive_escape_kills_antiHerglotz
    {R : тДВ тЖТ тДВ} (h : PositiveUpperImaginaryEscape R) :
    ┬м AntiHerglotzUHP R :=
  fun hanti => (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti h

-- =====================================================================
-- ┬з2. Real residue clouds
-- =====================================================================

/-- **Atom.** For a real root `r` and any upper-half-plane `z`,
  Im(1 / (z тИТ r)) = тИТ(Im z) / |z тИТ r|┬▓ тЙд 0.
The single nonpositivity fact from which the anti-Herglotz cloud law
follows by summation. -/
theorem complex_real_root_residue_imag_nonpos
    (z : тДВ) (r : тДЭ) (hz : 0 < z.im) :
    ((1 : тДВ) / (z - (r : тДВ))).im тЙд 0 := by
  -- z тЙа r since z has positive imaginary part and r is real.
  have hne : z - (r : тДВ) тЙа 0 := by
    intro h
    rw [sub_eq_zero] at h
    have him : z.im = ((r : тДВ)).im := congr_arg Complex.im h
    rw [Complex.ofReal_im] at him
    linarith
  rw [one_div, Complex.inv_im, Complex.sub_im, Complex.ofReal_im, sub_zero]
  have hns : 0 < Complex.normSq (z - (r : тДВ)) := Complex.normSq_pos.mpr hne
  exact le_of_lt (div_neg_of_neg_of_pos (by linarith) hns)

/-- **Real residue cloud is anti-Herglotz.** For any finite list of real
roots, the cloud `z тЖж ╬г_r 1 / (z тИТ r)` satisfies the anti-Herglotz
upper-half-plane sign law.

This single list theorem subsumes the GA `polynomial_one/two/three_real_roots_logDeriv_antiHerglotz`
toy cases (GA 31563тАУ31589). -/
theorem real_residue_cloud_antiHerglotz_list (rs : List тДЭ) :
    AntiHerglotzUHP
      (fun z : тДВ => (rs.map (fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ)))).sum) := by
  intro z hz
  show ((rs.map (fun r : тДЭ => (1 : тДВ) / (z - (r : тДВ)))).sum).im тЙд 0
  induction rs with
  | nil => simp
  | cons r rs ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have h1 : ((1 : тДВ) / (z - (r : тДВ))).im тЙд 0 :=
      complex_real_root_residue_imag_nonpos z r hz
    linarith

/-- тнР **PROVED тАФ weighted real residue cloud is anti-Herglotz.**
Generalizes `real_residue_cloud_antiHerglotz_list` to `(root, weight)`
pairs with non-negative real weights. Useful for multiplicities (just
repeat the same root) and for finite zero clouds with arbitrary positive
masses.

Mechanism: for real `w тЙе 0` and real root `r`,
  `Im((w : тДВ) ┬╖ (1 / (z тИТ r)))  =  w ┬╖ Im(1 / (z тИТ r))  тЙд  0`
since `w тЙе 0` and `Im(1/(z тИТ r)) тЙд 0` (the `complex_real_root_residue_imag_nonpos`
atom). Sum nonpositive contributions by induction. -/
theorem real_weighted_residue_cloud_antiHerglotz_list
    (atoms : List (тДЭ ├Ч тДЭ))
    (hweights : тИА a тИИ atoms, 0 тЙд a.2) :
    AntiHerglotzUHP
      (fun z : тДВ =>
        (atoms.map fun a : тДЭ ├Ч тДЭ =>
          (a.2 : тДВ) * ((1 : тДВ) / (z - (a.1 : тДВ)))).sum) := by
  intro z hz
  show ((atoms.map fun a : тДЭ ├Ч тДЭ =>
          (a.2 : тДВ) * ((1 : тДВ) / (z - (a.1 : тДВ)))).sum).im тЙд 0
  induction atoms with
  | nil => simp
  | cons a atoms ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have ha_weight : 0 тЙд a.2 := hweights a (List.mem_cons_self ..)
    have hrest : тИА b тИИ atoms, 0 тЙд b.2 :=
      fun b hb => hweights b (List.mem_cons_of_mem _ hb)
    have h_residue : ((1 : тДВ) / (z - (a.1 : тДВ))).im тЙд 0 :=
      complex_real_root_residue_imag_nonpos z a.1 hz
    have h_atom :
        ((a.2 : тДВ) * ((1 : тДВ) / (z - (a.1 : тДВ)))).im тЙд 0 := by
      -- Im((w : тДВ) ┬╖ c) = w ┬╖ c.im (since (w : тДВ).im = 0).
      rw [Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im,
          zero_mul, add_zero]
      exact mul_nonpos_of_nonneg_of_nonpos ha_weight h_residue
    have h_tail := ih hrest
    linarith

-- =====================================================================
-- ┬з3. Pole-witness abstraction
-- =====================================================================

/-- The **overflow field** / logarithmic derivative
  ╬Ы[f](z) := f'(z) / f(z).
A signed residue cloud for any factored object. -/
noncomputable def logDerivativeResponse (f : тДВ тЖТ тДВ) : тДВ тЖТ тДВ :=
  fun z => deriv f z / f z

/-- **Log-derivative pole-witness law.** Every upper-half-plane zero of
`f` produces positive upper-imaginary escape for the response `R`. In
applications `R = logDerivativeResponse f`; the parameterization keeps
the abstraction sharp.

Discharged in concrete cases by local factorization `f(z) = (z тИТ ╧Б)^m ┬╖ g(z)`
with `g(╧Б) тЙа 0`, applied to `╬Ы[f](z) = m / (z тИТ ╧Б) + g'(z)/g(z)`. The
constructive discharge for any such decomposition is
`localLogDerivPoleDecomposition_forces_escape` in ┬з5. -/
structure LogDerivPoleWitnessLaw (f R : тДВ тЖТ тДВ) : Prop where
  upper_zero_forces_escape :
    тИА ╧Б : тДВ, f ╧Б = 0 тЖТ 0 < ╧Б.im тЖТ PositiveUpperImaginaryEscape R

-- =====================================================================
-- ┬з4. Probe arithmetic at an upper pole  (CXXIX)
-- =====================================================================
-- The `m / (тИТ╬╡┬╖I)` blow-up family. A real residue `m` divided by `тИТ╬╡┬╖I`
-- rotates onto the positive imaginary axis with magnitude `m/╬╡`, which
-- diverges as `╬╡ тЖУ 0` and defeats any bounded background.

/-- **PROVED тАФ escape value `m/╬╡` exceeds any bounded `K` once `╬╡ < m/K`.**
This is the analytic clincher: a bounded background cannot kill the
`m/╬╡` divergence near an upper pole. -/
theorem escape_exceeds_bounded_background
    (m K eps : тДЭ) (_hm : m > 0) (hK : K > 0) (h╬╡ : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps > K := by
  rw [gt_iff_lt, lt_div_iffтВА h╬╡]
  have hKne : K тЙа 0 := ne_of_gt hK
  have : K * eps < K * (m / K) := by
    apply mul_lt_mul_of_pos_left hsmall hK
  have hKK : K * (m / K) = m := by
    field_simp
  rw [hKK] at this
  linarith

/-- **PROVED тАФ escape strictly positive: `m/╬╡ тИТ K > 0` once `╬╡ < m/K`.** -/
theorem residual_escape_positive
    (m K eps : тДЭ) (hm : m > 0) (hK : K > 0) (h╬╡ : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps - K > 0 := by
  have h := escape_exceeds_bounded_background m K eps hm hK h╬╡ hsmall
  linarith

/-- **PROVED тАФ probe subtraction: `(a + (bтИТ╬╡)┬╖I) тИТ (a + b┬╖I) = тИТ╬╡┬╖I`.** -/
theorem complex_probe_subtraction (a b eps : тДЭ) :
    ((a : тДВ) + (b - eps) * Complex.I) - ((a : тДВ) + b * Complex.I)
      = -eps * Complex.I := by
  ring

/-- **PROVED тАФ `Im(m / (тИТ╬╡┬╖I)) = m / ╬╡`** for `╬╡ тЙа 0`.
The central probe identity: at the probe just below an upper pole, the
residue contribution `m / (z_╬╡ тИТ ╧Б)` has imaginary part `m/╬╡`. -/
theorem upper_pole_probe_imag (m eps : тДЭ) (h╬╡ : eps тЙа 0) :
    ((m : тДВ) / ((-eps : тДВ) * Complex.I)).im = m / eps := by
  have h╬╡2 : eps^2 тЙа 0 := pow_ne_zero 2 h╬╡
  rw [Complex.div_im]
  rw [Complex.normSq_mul, Complex.normSq_I, mul_one]
  simp only [Complex.mul_re, Complex.mul_im, Complex.I_re, Complex.I_im,
    Complex.ofReal_re, Complex.ofReal_im, Complex.neg_re, Complex.neg_im,
    Complex.normSq_neg, Complex.normSq_ofReal,
    mul_zero, mul_one, zero_mul, sub_zero, add_zero, neg_zero, zero_sub,
    neg_neg]
  field_simp
  ring

/-- **PROVED тАФ `Im(m / (тИТ╬╡┬╖I)) > 0` when `m, ╬╡ > 0`.** -/
theorem upper_pole_probe_imag_positive
    (m eps : тДЭ) (hm : 0 < m) (h╬╡ : 0 < eps) :
    0 < ((m : тДВ) / ((-eps : тДВ) * Complex.I)).im := by
  rw [upper_pole_probe_imag m eps (ne_of_gt h╬╡)]
  exact div_pos hm h╬╡

/-- **PROVED тАФ escape exceeds bounded background (complex form):**
if `m, ╬╡ > 0` and `╬╡ < m/K` and `|Im B| тЙд K` then
`Im(m / (тИТ╬╡┬╖I) + B) > 0`. -/
theorem upper_pole_escape_with_background_complex
    (m eps K : тДЭ) (B : тДВ)
    (hm : 0 < m) (hK : 0 < K) (h╬╡ : 0 < eps)
    (hsmall : eps < m / K)
    (hB : |B.im| тЙд K) :
    0 < (((m : тДВ) / ((-eps : тДВ) * Complex.I)) + B).im := by
  rw [Complex.add_im, upper_pole_probe_imag m eps (ne_of_gt h╬╡)]
  have hescape : m / eps > K :=
    escape_exceeds_bounded_background m K eps hm hK h╬╡ hsmall
  have hB_lb : -K тЙд B.im := neg_le_of_abs_le hB
  linarith

/-- **PROVED тАФ escape via probe formula combined: at `z_╬╡` for upper pole
`╧Б`, the residue + background imaginary part is positive.** -/
theorem polynomial_upper_root_forces_escape_complex
    (a b eps m K : тДЭ) (B : тДВ)
    (_hb : 0 < b) (hm : 0 < m) (hK : 0 < K)
    (h╬╡ : 0 < eps) (_h╬╡_lt_b : eps < b)
    (hsmall : eps < m / K)
    (hB : |B.im| тЙд K) :
    0 < (((m : тДВ) /
      (((a : тДВ) + (b - eps) * Complex.I) - ((a : тДВ) + b * Complex.I))) + B).im := by
  rw [complex_probe_subtraction]
  exact upper_pole_escape_with_background_complex m eps K B hm hK h╬╡ hsmall hB

-- =====================================================================
-- ┬з5. Local pole decomposition engine  (CXXXI Layers 1тАУ2)
-- =====================================================================

/-- **Local-decomposition data for a log-derivative response at an upper
pole.** The pole is at `╧Б` with multiplicity `m`. The response equals
`m/(z тИТ ╧Б) + background z` on the probe segment `╧Б тИТ ╬╡┬╖I` for
`0 < ╬╡ < ╬╡0`. The background's imaginary part is uniformly bounded by `K`
on that segment. -/
structure LocalLogDerivPoleDecomposition (R : тДВ тЖТ тДВ) (╧Б : тДВ) where
  m : тДХ
  hm_pos : 0 < m
  background : тДВ тЖТ тДВ
  ╬╡0 : тДЭ
  h╬╡0 : 0 < ╬╡0
  h╬╡0_lt : ╬╡0 < ╧Б.im
  K : тДЭ
  hK_pos : 0 < K
  decomp_at_probe :
    тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
      R (╧Б - (╬╡ : тДВ) * Complex.I) =
        ((m : тДЭ) : тДВ) / ((╧Б - (╬╡ : тДВ) * Complex.I) - ╧Б) +
        background (╧Б - (╬╡ : тДВ) * Complex.I)
  background_bounded :
    тИА ╬╡ : тДЭ, 0 < ╬╡ тЖТ ╬╡ < ╬╡0 тЖТ
      |(background (╧Б - (╬╡ : тДВ) * Complex.I)).im| тЙд K

/-- **PROVED тАФ THE TRUE ANALYTIC ENGINE.** A local pole decomposition at
an upper pole forces a positive upper-imaginary escape. Pick
`╬╡ := min(╬╡тВА/2, m/(2K))`, apply `upper_pole_escape_with_background_complex`. -/
theorem localLogDerivPoleDecomposition_forces_escape
    {R : тДВ тЖТ тДВ} {╧Б : тДВ}
    (D : LocalLogDerivPoleDecomposition R ╧Б) :
    PositiveUpperImaginaryEscape R := by
  have hm_real_pos : (0 : тДЭ) < (D.m : тДЭ) := by exact_mod_cast D.hm_pos
  have hmK_pos : 0 < (D.m : тДЭ) / D.K := div_pos hm_real_pos D.hK_pos
  let ╬╡ : тДЭ := min (D.╬╡0 / 2) ((D.m : тДЭ) / D.K / 2)
  have h╬╡_pos : 0 < ╬╡ := by
    refine lt_min ?_ ?_
    ┬╖ linarith [D.h╬╡0]
    ┬╖ linarith
  have h╬╡_lt_╬╡0 : ╬╡ < D.╬╡0 := by
    refine lt_of_le_of_lt (min_le_left _ _) ?_
    linarith [D.h╬╡0]
  have h╬╡_lt_mK : ╬╡ < (D.m : тДЭ) / D.K := by
    refine lt_of_le_of_lt (min_le_right _ _) ?_
    linarith
  refine тЯи╧Б - (╬╡ : тДВ) * Complex.I, ?_, ?_тЯй
  ┬╖ -- 0 < (╧Б тИТ ╬╡┬╖I).im = ╧Б.im тИТ ╬╡
    have h_im : (╧Б - (╬╡ : тДВ) * Complex.I).im = ╧Б.im - ╬╡ := by
      simp [Complex.sub_im, Complex.mul_im, Complex.I_im, Complex.I_re,
            Complex.ofReal_re, Complex.ofReal_im]
    rw [h_im]
    linarith [D.h╬╡0_lt]
  ┬╖ -- 0 < Im(R(╧Б тИТ ╬╡┬╖I))
    rw [D.decomp_at_probe ╬╡ h╬╡_pos h╬╡_lt_╬╡0]
    have hsub : (╧Б - (╬╡ : тДВ) * Complex.I) - ╧Б = -(╬╡ : тДВ) * Complex.I := by
      ring
    rw [hsub]
    have hB := D.background_bounded ╬╡ h╬╡_pos h╬╡_lt_╬╡0
    exact upper_pole_escape_with_background_complex
      (D.m : тДЭ) ╬╡ D.K (D.background (╧Б - (╬╡ : тДВ) * Complex.I))
      hm_real_pos D.hK_pos h╬╡_pos h╬╡_lt_mK hB

/-- **PROVED тАФ complex local-pole decomposition for a simple root.**
If `p` factors locally as `p = (X тИТ ╧Б) ┬╖ q` at `z` with `q(z) тЙа 0`
and `z тЙа ╧Б`, then `(p value)' / (p value) = 1/(zтИТ╧Б) + q'/q`.
Stated as an algebraic identity on values. -/
theorem complex_local_pole_decomposition_simple_root
    (z ╧Б q dq : тДВ) (h╧Б : z тЙа ╧Б) (hq : q тЙа 0) :
    (q + (z - ╧Б) * dq) / ((z - ╧Б) * q)
      = 1 / (z - ╧Б) + dq / q := by
  have h╧Б' : z - ╧Б тЙа 0 := sub_ne_zero.mpr h╧Б
  field_simp
  ring

/-- **PROVED тАФ complex local-pole decomposition for multiplicity 2.**
If `p = (X тИТ ╧Б)┬▓ ┬╖ q`, then at `z тЙа ╧Б`, `q(z) тЙа 0`:
`p'(z)/p(z) = 2/(zтИТ╧Б) + q'(z)/q(z)`. -/
theorem complex_local_pole_decomposition_double_root
    (z ╧Б q dq : тДВ) (h╧Б : z тЙа ╧Б) (hq : q тЙа 0) :
    (2 * (z - ╧Б) * q + (z - ╧Б)^2 * dq) / ((z - ╧Б)^2 * q)
      = 2 / (z - ╧Б) + dq / q := by
  have h╧Б' : z - ╧Б тЙа 0 := sub_ne_zero.mpr h╧Б
  have h╧Б'2 : (z - ╧Б)^2 тЙа 0 := pow_ne_zero 2 h╧Б'
  field_simp
  ring

/-- **PROVED тАФ complex local-pole decomposition for multiplicity 3.** -/
theorem complex_local_pole_decomposition_triple_root
    (z ╧Б q dq : тДВ) (h╧Б : z тЙа ╧Б) (hq : q тЙа 0) :
    (3 * (z - ╧Б)^2 * q + (z - ╧Б)^3 * dq) / ((z - ╧Б)^3 * q)
      = 3 / (z - ╧Б) + dq / q := by
  have h╧Б' : z - ╧Б тЙа 0 := sub_ne_zero.mpr h╧Б
  have h╧Б'3 : (z - ╧Б)^3 тЙа 0 := pow_ne_zero 3 h╧Б'
  field_simp
  ring

/-- **PROVED тАФ local-pole decomposition for general multiplicity `m = k+1`
in the form `(p value)' / (p value) = m/(zтИТ╧Б) + q'/q`** when supplied
with the standard derivative expansion `m┬╖(zтИТ╧Б)^(mтИТ1)┬╖q + (zтИТ╧Б)^m┬╖q'`. -/
theorem complex_local_pole_decomposition_general
    (z ╧Б q dq : тДВ) (k : тДХ) (h╧Б : z тЙа ╧Б) (hq : q тЙа 0) :
    (((k + 1 : тДХ) : тДВ) * (z - ╧Б)^k * q + (z - ╧Б)^(k + 1) * dq)
      / ((z - ╧Б)^(k + 1) * q)
      = ((k + 1 : тДХ) : тДВ) / (z - ╧Б) + dq / q := by
  have h╧Б' : z - ╧Б тЙа 0 := sub_ne_zero.mpr h╧Б
  have h╧Б'k : (z - ╧Б)^k тЙа 0 := pow_ne_zero k h╧Б'
  have h╧Б'sk : (z - ╧Б)^(k + 1) тЙа 0 := pow_ne_zero (k + 1) h╧Б'
  rw [pow_succ]
  field_simp
  ring

