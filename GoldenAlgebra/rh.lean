/-! ### CW17: strip-restricted gap + local-finiteness layer -/

/-- Right gap for zeta zero heights inside the Backlund standard strip
`-1 ≤ Re ρ ≤ 2`.  Strip restriction makes the statement honest. -/
structure ZetaZeroHeightRightGapInBacklundStripInput : Prop where
  exists_gap :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      ∃ ε : ℝ, 0 < ε ∧
        ∀ ρ : ℂ,
          riemannZeta ρ = 0 →
          (-1 : ℝ) ≤ ρ.re →
          ρ.re ≤ 2 →
          T < ρ.im →
          ρ.im ≤ T + ε →
          False

/-- Local finiteness of zeta zeros inside a Backlund strip window
`{ρ : -1 ≤ Re ρ ≤ 2, T < Im ρ ≤ T + 1}`. -/
structure ZetaZerosLocallyFiniteInBacklundStripInput : Prop where
  finite_window :
    ∀ T : ℝ, (140 : ℝ) ≤ T →
      {ρ : ℂ |
        riemannZeta ρ = 0 ∧
        (-1 : ℝ) ≤ ρ.re ∧ ρ.re ≤ 2 ∧
        T < ρ.im ∧ ρ.im ≤ T + 1}.Finite

/-- **CW17 — local finiteness ⇒ right gap in the strip.**  Take the
minimum positive distance from `T` to any zero height in the finite
window; halve it (and cap at `1`) to produce an open right gap. -/
noncomputable def
    ZetaZerosLocallyFiniteInBacklundStripInput.toRightGapInStrip
    (F : ZetaZerosLocallyFiniteInBacklundStripInput) :
    ZetaZeroHeightRightGapInBacklundStripInput where
  exists_gap := by
    classical
    intro T hT
    set S : Set ℂ :=
      {ρ : ℂ | riemannZeta ρ = 0 ∧ (-1 : ℝ) ≤ ρ.re ∧ ρ.re ≤ 2 ∧
        T < ρ.im ∧ ρ.im ≤ T + 1} with hS_def
    have hfin : S.Finite := F.finite_window T hT
    by_cases hS_ne : S.Nonempty
    · set gaps : Finset ℝ :=
        hfin.toFinset.image (fun ρ : ℂ => ρ.im - T) with hgaps_def
      have hgaps_ne : gaps.Nonempty := by
        rcases hS_ne with ⟨ρ, hρ⟩
        refine ⟨ρ.im - T, ?_⟩
        exact Finset.mem_image.mpr ⟨ρ, hfin.mem_toFinset.mpr hρ, rfl⟩
      set δ : ℝ := gaps.min' hgaps_ne with hδ_def
      have hδ_pos : 0 < δ := by
        have hmem : δ ∈ gaps := gaps.min'_mem hgaps_ne
        rcases Finset.mem_image.mp hmem with ⟨ρ, hρmem, hρeq⟩
        have hρS : ρ ∈ S := hfin.mem_toFinset.mp hρmem
        have hT_lt : T < ρ.im := hρS.2.2.2.1
        linarith [hρeq]
      refine ⟨min δ 1 / 2, by positivity, ?_⟩
      intro ρ hzero hre1 hre2 him him_upper
      have hε_le_δhalf : min δ 1 / 2 ≤ δ / 2 := by
        have hm : min δ 1 ≤ δ := min_le_left _ _
        linarith
      have hε_le_one : min δ 1 / 2 ≤ 1 := by
        have hm : min δ 1 ≤ 1 := min_le_right _ _
        linarith
      have him_le_one : ρ.im ≤ T + 1 := by linarith
      have hρS : ρ ∈ S := ⟨hzero, hre1, hre2, him, him_le_one⟩
      have hgap_mem : ρ.im - T ∈ gaps :=
        Finset.mem_image.mpr ⟨ρ, hfin.mem_toFinset.mpr hρS, rfl⟩
      have hδ_le : δ ≤ ρ.im - T := gaps.min'_le _ hgap_mem
      linarith
    · refine ⟨1, by norm_num, ?_⟩
      intro ρ hzero hre1 hre2 him him_upper
      exact hS_ne ⟨ρ, hzero, hre1, hre2, him, him_upper⟩

/-- Strip-restricted gap → LC bridge.  Named anchor: turning a strip
gap into the count's right local constancy still requires unfolding the
certificate-based count machinery. -/
structure ZetaStripGapToLocalConstancyInput : Prop where
  bridge :
    ZetaZeroHeightRightGapInBacklundStripInput →
      ZetaWeightedZeroCountRightLocalConstancyInput

