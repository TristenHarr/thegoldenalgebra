--                                                         — final front door

/-- 📦 **`XiLowResidualFiniteIBPDomination`** — the xi explicit-formula
identification: on the compact low region, the canonical residual's `Im`
is dominated by the bounded-IBP boundary + derivative pieces at the
canonical first-zero cutoffs `T = 11`, `γ = 14`. This isolates the
**xi-side analytic content** from the already-proved IBP estimates. -/
structure XiLowResidualFiniteIBPDomination
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (M : CloudDensityTailModelDecomposition) : Prop where
  residual_le_finite_ibp :
    ∀ z : ℂ,
      lowCompactRegion z →
      |(xiResidualError M z).im|
        ≤ |lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11|
          + |lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14|

/-- 📦 **`FirstZeroGapForDzero Dzero T0 γ`** — first-zero-gap identity
for the fluctuation primitive: on `[2π, γ]` the finite fluctuation
primitive coincides with `−smoothZeroCountingN0` (i.e., the discrete
counting part vanishes because all zeros lie strictly above `γ`). -/
structure FirstZeroGapForDzero
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 γ : ℝ) : Prop where
  fluct_eq_neg_N0 :
    ∀ u : ℝ, 2 * Real.pi ≤ u → u ≤ γ →
      Phase1IBP.finiteFluctuationPrimitive Dzero T0 u
        = -smoothZeroCountingN0 u

/-- ⭐ **PROVED — `|S(u)| ≤ 1/2` on `[11, 14]`** from `FirstZeroGapForDzero`
at `γ = 14` and `abs_smoothZeroCountingN0_le_half_on_first_band_14`. -/
theorem finiteFluctuation_abs_le_half_on_11_14
    {Dzero : Phase1IBP.OrderedFluctuationMeasureData} {T0 : ℝ}
    (Hgap : FirstZeroGapForDzero Dzero T0 14)
    {u : ℝ} (hu11 : 11 ≤ u) (hu14 : u ≤ 14) :
    |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| ≤ (1 / 2 : ℝ) := by
  have h_2pi_lt_11 : 2 * Real.pi ≤ 11 := by
    have : Real.pi < 4 := Real.pi_lt_four
    linarith
  have hu_2pi : 2 * Real.pi ≤ u := le_trans h_2pi_lt_11 hu11
  rw [Hgap.fluct_eq_neg_N0 u hu_2pi hu14, abs_neg]
  exact abs_smoothZeroCountingN0_le_half_on_first_band_14 hu_2pi hu14

/-- 🌟🌟🌟 **PROVED — `XiResidualLowIBPRepresentationAt 11 14 (1/2)` from
the minimal new interface.** Mechanical closure consuming:
* `Hdom` — xi residual ≤ |boundary| + |deriv| (xi explicit-formula step);
* `Hgap` — fluct primitive = −N₀ on `[2π, 14]`;
* `Hint` — interval integrability of `|S · k'|` on `[11, 14]` for each
  `z` in the low compact region.

Internally chains the §CCLXXXI `|N₀| ≤ 1/2` bound, the §CCLXXXIV
bounded-IBP estimates, and the closed-form algebraic combination
`slabIBP_sum_le_closedFormFirstZeroErrorBound`. -/
theorem XiResidualLowIBPRepresentationAt_11_14_half_of_finiteIBP
    (Dzero : Phase1IBP.OrderedFluctuationMeasureData) (T0 : ℝ)
    (Hdom : XiLowResidualFiniteIBPDomination Dzero T0 honestZeroDensityModelTwoPi)
    (Hgap : FirstZeroGapForDzero Dzero T0 14)
    (Hint : ∀ z : ℂ, lowCompactRegion z →
      IntervalIntegrable
        (fun u => |lowFirstZeroIBPIntegrand Dzero T0 z.re z.im u|)
        MeasureTheory.volume 11 14) :
    XiResidualLowIBPRepresentationAt 11 14 (1 / 2)
      honestZeroDensityModelTwoPi := by
  refine ⟨?_⟩
  intro z hz
  have hy : 0 < z.im := hz.1
  have hregime10 : 2 * (1 + |z.re| + z.im) ≤ 10 := hz.2
  have hregime11 : 2 * (1 + |z.re| + z.im) ≤ 11 := by linarith
  have hS : ∀ u : ℝ, 11 ≤ u → u ≤ 14 →
      |Phase1IBP.finiteFluctuationPrimitive Dzero T0 u| ≤ (1 / 2 : ℝ) :=
    fun u hu11 hu14 =>
      finiteFluctuation_abs_le_half_on_11_14 Hgap hu11 hu14
  have hS11 : |Phase1IBP.finiteFluctuationPrimitive Dzero T0 11| ≤ (1 / 2 : ℝ) :=
    hS 11 le_rfl (by norm_num)
  have hbdy : |lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11|
              ≤ 8 * z.im * (1 / 2 : ℝ) / (11 : ℝ) ^ 2 :=
    lowFirstZeroBoundaryTerm_abs_le hy.le hregime11 hS11
  have hderiv : |lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14|
              ≤ 9 * z.im * (1 / 2 : ℝ) / (11 : ℝ) ^ 2
                - 9 * z.im * (1 / 2 : ℝ) / (14 : ℝ) ^ 2 :=
    lowFirstZeroDerivativeSide_abs_le_majorant
      Dzero T0 hy hregime11 (by norm_num : (11 : ℝ) ≤ 14)
      (by norm_num : (0 : ℝ) ≤ 1 / 2) hS (Hint z hz)
  have hsum :
      |lowFirstZeroBoundaryTerm Dzero T0 z.re z.im 11|
        + |lowFirstZeroDerivativeSide Dzero T0 z.re z.im 11 14|
          ≤ closedFormFirstZeroErrorBound z.im 11 14 (1 / 2) :=
    lowFirstZeroIBP_sum_le_closedForm hbdy hderiv
  exact le_trans (Hdom.residual_le_finite_ibp z hz) hsum

