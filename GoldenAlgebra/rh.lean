    rw [ÔåÉ h_cast]; exact h.symm
  have h_exp_18_5_pow : (Real.exp (18/5 : ÔäØ))^5 = Real.exp 18 := by
    have h := Real.exp_nat_mul (18/5 : ÔäØ) 5
    have h_eq : ((5 : Ôäò) : ÔäØ) * (18/5 : ÔäØ) = 18 := by norm_num
    rw [h_eq] at h
