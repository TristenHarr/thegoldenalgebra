    (hzeros : M.zeros = zeros100ceil)
    (Tsmooth : ÔäØ) (hTsmooth_ge : 2 * Real.pi Ôëñ Tsmooth)
    (error : Ôäé ÔåÆ Ôäé)
    (hmodel : ÔêÇ z : Ôäé,
        M.model z =
          pairedFiniteCloudFromZeros us z +
            zeroDensitySmoothTailModel Tsmooth hTsmooth_ge z)
    (hxi : ÔêÇ z : Ôäé,
        (Ôêâ T : ÔäØ, 10 Ôëñ T Ôêº T Ôëñ 140 Ôêº 2 * (1 + |z.re| + z.im) Ôëñ T) ÔåÆ
        logDerivativeResponse XiPullback z =
