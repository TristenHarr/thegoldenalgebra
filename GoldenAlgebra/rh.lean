/-- тнР **PROVED тАФ `log T тЙд 4` for `T тЙд 54`.**
Chain: `2.718 < exp 1` (from `exp_one_gt_d9`), `2.718^4 тЙе 54` (norm_num),
so `54 тЙд (exp 1)^4 = exp 4`, hence `log T тЙд log 54 тЙд 4` by monotonicity. -/
theorem log_T_le_4_of_le_54 {T : тДЭ} (hT_pos : 0 < T) (hT : T тЙд 54) :
    Real.log T тЙд 4 := by
  have h_2718_lt_exp_1 : (2.718 : тДЭ) < Real.exp 1 :=
    lt_trans (by norm_num : (2.718 : тДЭ) < 2.7182818283) Real.exp_one_gt_d9
  have h_2718_nn : (0 : тДЭ) тЙд 2.718 := by norm_num
  have h_pow_le : (2.718 : тДЭ)^4 тЙд (Real.exp 1)^4 :=
    pow_le_pow_leftтВА h_2718_nn (le_of_lt h_2718_lt_exp_1) 4
  have h_exp_4_eq : Real.exp 4 = (Real.exp 1)^4 := by
    have := Real.exp_one_pow 4
    have h_cast : ((4 : тДХ) : тДЭ) = (4 : тДЭ) := by norm_num
    rw [тЖР h_cast]; exact this.symm
  have h_54_le_pow : (54 : тДЭ) тЙд (2.718 : тДЭ)^4 := by norm_num
  have h_54_le_exp_4 : (54 : тДЭ) тЙд Real.exp 4 := by
    rw [h_exp_4_eq]; linarith
  have h_T_le : T тЙд Real.exp 4 := le_trans hT h_54_le_exp_4
  have h := Real.log_le_log hT_pos h_T_le
  rwa [Real.log_exp] at h

/-- тнР **PROVED тАФ Endpoint bound: `log(48/(2╧А)) тЙе 2`.**
Chain: `(exp 1)┬▓ тЙд 7.4` (from `exp_one_lt_d9`) and `7.4┬╖(2╧А) тЙд 48` via
`╧А < 3.1416`. Tighter than the [80,140] chain because `8┬╖(2╧А) > 48`. -/
lemma log_48_div_2pi_ge_2 :
    (2 : тДЭ) тЙд Real.log (48 / (2 * Real.pi)) := by
  have h_pi_lt : Real.pi < 3.1416 := Real.pi_lt_d4
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_exp_1_lt : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have h_exp_1_pos : 0 < Real.exp 1 := Real.exp_pos _
  have h_exp_1_sq_lt : (Real.exp 1)^2 < (2.7182818286 : тДЭ)^2 :=
    pow_lt_pow_leftтВА h_exp_1_lt (le_of_lt h_exp_1_pos) (n := 2) (by norm_num)
  have h_27_sq_le : (2.7182818286 : тДЭ)^2 тЙд 7.4 := by norm_num
  have h_exp_1_sq_le : (Real.exp 1)^2 тЙд 7.4 := by linarith
  have h_exp_2_eq : Real.exp 2 = (Real.exp 1)^2 := by
    have := Real.exp_one_pow 2
    have h_cast : ((2 : тДХ) : тДЭ) = (2 : тДЭ) := by norm_num
    rw [тЖР h_cast]; exact this.symm
  have h_exp_2_le : Real.exp 2 тЙд 7.4 := h_exp_2_eq тЦ╕ h_exp_1_sq_le
  have h_74_le : (7.4 : тДЭ) тЙд 48 / (2 * Real.pi) := by
    rw [le_div_iffтВА h_2pi_pos]
    nlinarith
  have h_exp_2_le_ratio : Real.exp 2 тЙд 48 / (2 * Real.pi) :=
    le_trans h_exp_2_le h_74_le
  have h_exp_pos : 0 < Real.exp 2 := Real.exp_pos _
  have h := Real.log_le_log h_exp_pos h_exp_2_le_ratio
  rwa [Real.log_exp] at h

/-- тнР **PROVED тАФ `log(T/(2╧А)) тЙе 2` for `T тЙе 48`** via monotonicity. -/
lemma log_T_over_2pi_ge_2_of_ge_48
    {T : тДЭ} (hT48 : 48 тЙд T) :
    (2 : тДЭ) тЙд Real.log (T / (2 * Real.pi)) := by
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h48_pos : (0 : тДЭ) < 48 / (2 * Real.pi) := by positivity
  have hratio : 48 / (2 * Real.pi) тЙд T / (2 * Real.pi) := by
    apply div_le_div_of_nonneg_right hT48 (le_of_lt h_2pi_pos)
  have hlogmono :
      Real.log (48 / (2 * Real.pi)) тЙд Real.log (T / (2 * Real.pi)) :=
    Real.log_le_log h48_pos hratio
  exact le_trans log_48_div_2pi_ge_2 hlogmono

/-- тнР **PROVED тАФ Constant LB for `zeroDensityRho` on `[48, 80]`.** -/
lemma zeroDensityRho_ge_const_48_80
    {T : тДЭ} (hT48 : 48 тЙд T) (_hT80 : T тЙд 80) :
    ((2 : тДЭ) / (2 * Real.pi)) тЙд zeroDensityRho T := by
  unfold zeroDensityRho
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_log_ge := log_T_over_2pi_ge_2_of_ge_48 hT48
  rw [show (1 / (2 * Real.pi)) * Real.log (T / (2 * Real.pi))
        = Real.log (T / (2 * Real.pi)) / (2 * Real.pi) by ring]
  apply div_le_div_of_nonneg_right h_log_ge (le_of_lt h_2pi_pos)

/-- тнР **PROVED тАФ smooth-tail LB on the full `[48, 80]` range.** Reuses
the `tailK_80_140` def since the form `(22/15)┬╖(2/(2╧А))/T` is identical;
this lemma just establishes the underlying `2/(2╧А) тЙд ╧Б(T)` on `[48, 80]`. -/
lemma smoothTail_ge_const_48_80
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hT48 : 48 тЙд T) (hT80 : T тЙд 80)
    (hy : 0 < y) (hreg : 2 * (1 + x + y) тЙд T) :
    y * tailK_80_140 T тЙд smoothTailRationalLowerBoundAbs x y T := by
  unfold tailK_80_140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_pi_lt_4 : Real.pi < 4 := Real.pi_lt_four
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have hT_pos : 0 < T := by linarith
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hT_2pi : 2 * Real.pi тЙд T := by linarith
  have hreg' : 2 * (1 + |x| + y) тЙд T := by
    rw [abs_of_nonneg hx]; exact hreg
  have hrho : ((2 : тДЭ) / (2 * Real.pi)) тЙд zeroDensityRho T :=
    zeroDensityRho_ge_const_48_80 hT48 hT80
  have h_22_15_nn : (0 : тДЭ) тЙд 22 / 15 := by norm_num
  have h_22_15_rho_le :
      (22 / 15 : тДЭ) * ((2 : тДЭ) / (2 * Real.pi))
      тЙд (22 / 15) * zeroDensityRho T :=
    mul_le_mul_of_nonneg_left hrho h_22_15_nn
  have hy_over_T_nn : (0 : тДЭ) тЙд y / T := div_nonneg hy_nn (le_of_lt hT_pos)
  have h_chain :
      (22 / 15 : тДЭ) * ((2 : тДЭ) / (2 * Real.pi)) * y / T
        тЙд (22 / 15) * zeroDensityRho T * y / T := by
    have := mul_le_mul_of_nonneg_right h_22_15_rho_le hy_over_T_nn
    rw [show (22 / 15 : тДЭ) * ((2 : тДЭ) / (2 * Real.pi)) * (y / T)
          = (22 / 15 : тДЭ) * ((2 : тДЭ) / (2 * Real.pi)) * y / T by ring] at this
    rw [show (22 / 15 : тДЭ) * zeroDensityRho T * (y / T)
          = (22 / 15 : тДЭ) * zeroDensityRho T * y / T by ring] at this
    exact this
  have h_base : (22 / 15 : тДЭ) * zeroDensityRho T * y / T
                тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTailRationalLowerBoundAbs_ge_22_15 hT_2pi hy hreg'
  have h_y_form : y * ((22 / 15 : тДЭ) *
      ((2 : тДЭ) / (2 * Real.pi)) / T)
      = (22 / 15 : тДЭ) * ((2 : тДЭ) / (2 * Real.pi)) * y / T := by ring
  rw [h_y_form]
  exact le_trans h_chain h_base

/-- тнР **PROVED тАФ Generic tail bound `tailK_80_140 T тЙе 7/(15┬╖B)`** for
`T тЙд B`. Reused for each `[48, 80]` subband by setting `B` to the
subband upper endpoint. -/
lemma tailK_80_140_ge_seven_fifteen_div
    {T B : тДЭ} (hT_pos : 0 < T) (hB_pos : 0 < B) (hT_le : T тЙд B) :
    (7 / (15 * B) : тДЭ) тЙд tailK_80_140 T := by
  unfold tailK_80_140
  have h_pi_pos : 0 < Real.pi := Real.pi_pos
  have h_2pi_pos : 0 < 2 * Real.pi := by linarith
  have h_2pi_inv : (7 / 44 : тДЭ) тЙд 1 / (2 * Real.pi) :=
    one_div_two_pi_ge_seven_fortyfour
  have h_inv_T : (1 / B : тДЭ) тЙд 1 / T := one_div_le_one_div_of_le hT_pos hT_le
  have h_form_eq : (22 / 15 : тДЭ) *
      ((2 : тДЭ) / (2 * Real.pi)) / T
      = (22 / 15) * (2 : тДЭ) * (1 / (2 * Real.pi)) * (1/T) := by ring
  rw [h_form_eq]
  have h_22_15_2_nn : (0:тДЭ) тЙд (22 / 15) * (2 : тДЭ) := by positivity
  have h_22_15_2_2pi_nn : (0:тДЭ) тЙд (22 / 15) * (2 : тДЭ) * (1 / (2 * Real.pi)) := by
    positivity
  have h2 : (22 / 15 : тДЭ) * (2 : тДЭ) * (7/44)
          тЙд (22 / 15) * (2 : тДЭ) * (1/(2*Real.pi)) := by
    apply mul_le_mul_of_nonneg_left h_2pi_inv h_22_15_2_nn
  have h3 : (22 / 15 : тДЭ) * (2 : тДЭ) * (1/(2*Real.pi)) * (1/B)
          тЙд (22 / 15) * (2 : тДЭ) * (1/(2*Real.pi)) * (1/T) := by
    apply mul_le_mul_of_nonneg_left h_inv_T h_22_15_2_2pi_nn
  have h_inv_B_nn : (0 : тДЭ) тЙд 1/B := le_of_lt (one_div_pos.mpr hB_pos)
  have h_C_le_A :
      (22 / 15 : тДЭ) * (2 : тДЭ) * (7/44) * (1/B)
        тЙд (22 / 15) * (2 : тДЭ) * (1/(2*Real.pi)) * (1/B) := by
    apply mul_le_mul_of_nonneg_right h2 h_inv_B_nn
  have hB_ne : B тЙа 0 := ne_of_gt hB_pos
  have h_const_eq : (22 / 15 : тДЭ) * (2 : тДЭ) * (7/44) * (1/B) = 7/(15*B) := by
    field_simp
    ring
  linarith [h3, h_C_le_A, h_const_eq]

/-- тнР **PROVED тАФ Generic closed-form upper bound for the
`(C, D) = (1/2, 49/20)` slab.**
Given `T тИИ [A, +тИЮ)` with `Real.log T тЙд L`, bounds
`closedFormSErrorBoundCD (1/2) (49/20) y T` by `y ┬╖ ((17/2┬╖L + 439/10)/A┬▓)`.
Each subband instantiates this with its `A` (lower endpoint) and `L`. -/
lemma closedFormSErrorBoundCD_subband_le_const
    {y T A L : тДЭ}
    (hy : 0 тЙд y) (hT_pos : 0 < T) (hT_ge_one : 1 тЙд T)
    (hA_sq_pos : 0 < A^2) (hT2_ge : A^2 тЙд T^2)
    (hL_nn : 0 тЙд L) (hlog_le : Real.log T тЙд L) :
    closedFormSErrorBoundCD (1 / 2 : тДЭ) (49 / 20 : тДЭ) y T
      тЙд y * (((17/2 : тДЭ) * L + 439/10) / A^2) := by
  have hT_ne : T тЙа 0 := ne_of_gt hT_pos
  have hT2pos : 0 < T^2 := by positivity
  have hlogT_nn : 0 тЙд Real.log T := Real.log_nonneg hT_ge_one
  have hcoeff_le :
      (17/2 : тДЭ) * Real.log T + 439/10 тЙд (17/2 : тДЭ) * L + 439/10 := by
    nlinarith
  have h_L_coeff_nn : 0 тЙд (17/2 : тДЭ) * L + 439/10 := by
    have h1 : 0 тЙд (17/2 : тДЭ) * L := mul_nonneg (by norm_num) hL_nn
    linarith
  rw [closedFormSErrorBoundCD_half_4920_eq hT_ne]
  unfold closedFormSErrorBoundHalf4920
  have hz_nn : 0 тЙд y / T^2 := div_nonneg hy (le_of_lt hT2pos)
  calc (y / T^2) * ((17/2 : тДЭ) * Real.log T + 439/10)
        тЙд (y / T^2) * ((17/2 : тДЭ) * L + 439/10) :=
          mul_le_mul_of_nonneg_left hcoeff_le hz_nn
      _ = y * (((17/2 : тДЭ) * L + 439/10) / T^2) := by ring
      _ тЙд y * (((17/2 : тДЭ) * L + 439/10) / A^2) := by
          apply mul_le_mul_of_nonneg_left _ hy
          exact div_le_div_of_nonneg_left h_L_coeff_nn hA_sq_pos hT2_ge

/-- тнР **PROVED тАФ Generic subband assembly for `[48, 80]`.**
Given closed-form bound by a constant `C`, cloud LB `K тЙд cloudK_T`,
tail LB `╧Д тЙд tailK_80_140 T`, and scalar margin `C тЙд 2 K + ╧Д`,
closes the slab-cert inequality on the `x тЙе 0` branch. -/
lemma slabSimple_48_80_subband_assembly
    {x y T : тДЭ}
    (hx : 0 тЙд x) (hy : 0 < y)
    (hreg : 2 * (1 + x + y) тЙд T)
    (hT48 : 48 тЙд T) (hT80 : T тЙд 80)
    {C K ╧Д : тДЭ}
    (hclosed_le : closedFormSErrorBoundCD (1/2 : тДЭ) (49/20 : тДЭ) y T тЙд y * C)
    (hcloud_const : K тЙд cloudK_T zeros100ceil T)
    (htail_const : ╧Д тЙд tailK_80_140 T)
    (hscalar : C тЙд 2 * K + ╧Д) :
    closedFormSErrorBoundCD (1/2 : тДЭ) (49/20 : тДЭ) y T
      тЙд simpleCloudSum zeros100ceil x y
        + smoothTailRationalLowerBoundAbs x y T := by
  have hy_nn : 0 тЙд y := le_of_lt hy
  have hscaled : y * C тЙд y * (2 * K + ╧Д) :=
    mul_le_mul_of_nonneg_left hscalar hy_nn
  have hcloud : 2 * y * cloudK_T zeros100ceil T
                  тЙд simpleCloudSum zeros100ceil x y :=
    simpleCloudSum_ge_admissible_T_bound zeros100ceil hx hy hreg
  have htail : y * tailK_80_140 T тЙд smoothTailRationalLowerBoundAbs x y T :=
    smoothTail_ge_const_48_80 hx hT48 hT80 hy hreg
  have h_y_const_le_dyn :
      y * (2 * K + ╧Д)
        тЙд 2 * y * cloudK_T zeros100ceil T + y * tailK_80_140 T := by
    nlinarith [hy_nn, hcloud_const, htail_const]
  calc
    closedFormSErrorBoundCD (1/2 : тДЭ) (49/20 : тДЭ) y T
        тЙд y * C := hclosed_le
    _ тЙд y * (2 * K + ╧Д) := hscaled
    _ тЙд 2 * y * cloudK_T zeros100ceil T + y * tailK_80_140 T :=
        h_y_const_le_dyn
    _ тЙд simpleCloudSum zeros100ceil x y
          + smoothTailRationalLowerBoundAbs x y T :=
        add_le_add hcloud htail

