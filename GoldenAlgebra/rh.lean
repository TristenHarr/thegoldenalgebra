  refine ⟨?_⟩
  intro s hs
  obtain ⟨U, hUopen, hsU, hreg⟩ := Hreg.exists_regular_nhds s hs
  exact ⟨U, hUopen, hsU, Hformula.eq_on_regular U hUopen hreg⟩

