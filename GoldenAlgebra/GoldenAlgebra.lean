lower bound). -/
theorem pi_sqrt_two_thirds_gt :
    Real.pi * Real.sqrt (2/3) > 2.54 := by
  have hπ : Real.pi > 3.14 := Real.pi_gt_d2
  have hπ_pos : (0 : ℝ) < Real.pi := Real.pi_pos
  have h23 : Real.sqrt (2/3) > 0.81 := by
    rw [show (0.81 : ℝ) = Real.sqrt (0.6561) from by
      rw [show (0.6561 : ℝ) = (0.81 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 0.81)).symm]
    apply Real.sqrt_lt_sqrt (by norm_num)
    norm_num
  have h23_pos : (0 : ℝ) < Real.sqrt (2/3) := by
    apply Real.sqrt_pos.mpr; norm_num
  nlinarith [hπ, h23, hπ_pos, h23_pos]

