-- === Phase XC: The DELTA FILTER Δ_N(r) = (1/N)·∑_{d|N} c_d(r) ===
-- THE EXACT "cancel all other terms" filter. The delta filter
--   Δ_N(r) = (1/N)·∑_{d|N} c_d(r)
-- equals 1 if N | r and 0 otherwise. Centered at r = k − 4, it
-- preserves k ≡ 4 (mod N), i.e. exactly ζ(5) + tail of ζ(5 + jN) at
-- powers of ρ^{jN}. Equivalently:
--   Δ_N = ∑_{d|N} (φ(d)/N) · ℙ_d
-- where ℙ_d = c_d/φ(d) is the primitive Ramanujan projector. The
-- weights `φ(d)/N` are POSITIVE and SUM TO 1 (since ∑_{d|N} φ(d) = N).
-- This unifies: the FULL ROOT PROJECTOR is exactly the
-- divisor-summed primitive Ramanujan filter — the answer to "all
-- N-th roots split into primitive roots of orders d | N".

/-- **PROVED — `∑_{d|N} φ(d) = N`** (Mathlib's `Nat.sum_totient`).
This is why the primitive decomposition weights `φ(d)/N` SUM TO 1. -/
theorem sum_totient_eq_self (N : ℕ) :
    ∑ d ∈ N.divisors, Nat.totient d = N :=
  Nat.sum_totient N

/-- **PROVED — `∑_{d|12} φ(d) = 12`.** Concrete instance. -/
theorem sum_totient_12 :
    ∑ d ∈ (12 : ℕ).divisors, Nat.totient d = 12 := by decide

/-- **PROVED — `∑_{d|24} φ(d) = 24`.** -/
theorem sum_totient_24 :
    ∑ d ∈ (24 : ℕ).divisors, Nat.totient d = 24 := by decide

/-- **PROVED — `∑_{d|30} φ(d) = 30`.** -/
theorem sum_totient_30 :
    ∑ d ∈ (30 : ℕ).divisors, Nat.totient d = 30 := by decide

/-- **PROVED — `∑_{d|60} φ(d) = 60`.** -/
theorem sum_totient_60 :
    ∑ d ∈ (60 : ℕ).divisors, Nat.totient d = 60 := by decide

/-- **PROVED — primitive decomposition weights sum to 1 for any N > 0.**
`∑_{d|N} (φ(d)/N) = (∑_{d|N} φ(d))/N = N/N = 1`. -/
theorem primitive_weights_sum_one (N : ℕ) (hN : 0 < N) :
    ∑ d ∈ N.divisors, ((Nat.totient d : ℚ) / N) = 1 := by
  rw [← Finset.sum_div]
  rw [show ((∑ d ∈ N.divisors, (Nat.totient d : ℚ)) : ℚ)
       = ((∑ d ∈ N.divisors, Nat.totient d : ℕ) : ℚ) from by push_cast; rfl]
  rw [sum_totient_eq_self N]
  have hN_ne : (N : ℚ) ≠ 0 := by exact_mod_cast Nat.pos_iff_ne_zero.mp hN
  field_simp

/-- **PROVED — primitive weights are positive for each divisor of N
(N > 0).** -/
theorem primitive_weight_positive (N d : ℕ) (hN : 0 < N) (hd : d ∈ N.divisors) :
    (0 : ℚ) < (Nat.totient d : ℚ) / N := by
  have hd_pos : 0 < d := Nat.pos_of_mem_divisors hd
  have hphi_pos : 0 < Nat.totient d := Nat.totient_pos.mpr hd_pos
  have hphi_q : (0 : ℚ) < (Nat.totient d : ℚ) := by exact_mod_cast hphi_pos
  have hN_q : (0 : ℚ) < (N : ℚ) := by exact_mod_cast hN
  positivity

/-- **PROVED — `(1/2)^N` error decay matches the table at the
listed `N` values.** -/
