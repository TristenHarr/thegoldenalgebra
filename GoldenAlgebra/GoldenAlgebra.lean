structure IrrationalityWallDiagnosis where
  errorSplit : AnalyticVsArithmeticError
  zetaThreeWorks : ZetaThreeClearedFormsVanish
  harmonicTail : HarmonicTwoTailIdentity
  tailExpansion : HarmonicTwoTailEulerMaclaurin
  coupledIdentity : ZetaFivePlusZetaTwoZetaThreeIdentity
  residue : ZetaFiveResidueExpansion
  coupling : ZetaFiveZetaTwoZetaThreeCoupling
  weight5 : Weight5PeriodSpace
  linearFormAttack : ZetaFiveLinearFormAttack

/-- **PROVED.** ζ(3)'s cleared linear forms tend to zero, extracted
from the diagnosis. -/
theorem zetaThreeClearedForms_tendsto_zero
