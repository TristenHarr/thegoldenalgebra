-- === Phase XCIII: The "Last Row" of Pascal + Carry Operator + Three Shadows ===
-- The M-th row of Pascal with M = 10^m has THREE SHADOWS:
--   Shadow A (front residue): C(M, k)/M^k → 1/k!, sum → e.
--   Shadow B (center mass):  C(M, M/2) ~ 2^M/√(πM/2), catastrophic.
--   Shadow C (carried front): (1 + 1/M)^M → e (the visible result).
-- Three coordinates:
--   front k, bulk x = k/M, center y = (k − M/2)/√M.
-- Each reveals a different face.
-- The carry operator separates raw / overflow / visible:
--   a_k = C(n,k)       (raw)
--   q_k = ⌊(a_k + q_{k+1})/M⌋  (overflow transport)
--   d_k = (a_k + q_{k+1}) mod M  (visible chamber)
-- Six conjectures (A-F): A,B PROVED structurally; C-F are research
-- statements.

/-- The displayed bin value `d_k(n, M) = (C(n,k) + q_{k+1}) mod M`.
Computed in tandem with the carry field `q_k`. -/
def displayedBin (a_k q_kplus1 M : ℕ) : ℕ :=
  (a_k + q_kplus1) % M

/-- The carry transport at chamber k. -/
def carryAtChamber (a_k q_kplus1 M : ℕ) : ℕ :=
  (a_k + q_kplus1) / M

/-- **PROVED — `displayedBin + M·carryAtChamber = a_k + q_{k+1}`.**
The decomposition is exact: raw + incoming = displayed + outgoing×M. -/
theorem displayedBin_plus_carry_eq
    (a_k q_kplus1 M : ℕ) (_hM : 0 < M) :
    displayedBin a_k q_kplus1 M
      + M * carryAtChamber a_k q_kplus1 M
    = a_k + q_kplus1 := by
  unfold displayedBin carryAtChamber
  exact Nat.mod_add_div (a_k + q_kplus1) M

/-- **PROVED — `displayedBin < M`** (residue is bounded by capacity). -/
theorem displayedBin_lt_M
    (a_k q_kplus1 M : ℕ) (hM : 0 < M) :
    displayedBin a_k q_kplus1 M < M :=
  Nat.mod_lt _ hM

/--
**Computable carry field for a single Pascal row, indexed from the
right boundary.** This is the honest replacement for the previously
all-`Prop` `PascalCarryWave` structure.

`carryFromRight M n j` is the carry that has accumulated after
processing the `j` rightmost Pascal entries of row `n` under chamber
width `M`. Boundary `j = 0`: no carry (matches the convention
`q_{n+1} = 0` from the carry-operator framework). Recurrence: at
step `j + 1` the chamber being processed is `n − j` with raw value
`Nat.choose n (n − j)`, and the outgoing carry is
`carryAtChamber (Nat.choose n (n − j)) (carryFromRight M n j) M`.

Together with `visibleFromRight` and the per-step conservation theorem
below this turns the carry wave into a genuine computable object. -/
def carryFromRight (M n : ℕ) : ℕ → ℕ
  | 0     => 0
  | j + 1 => carryAtChamber (Nat.choose n (n - j)) (carryFromRight M n j) M

/-- **PROVED — boundary value: `carryFromRight M n 0 = 0`** (no carry
coming in past the right boundary of the row). -/
theorem carryFromRight_zero (M n : ℕ) : carryFromRight M n 0 = 0 := rfl

/-- **PROVED — right-to-left recurrence for the carry field.** -/
theorem carryFromRight_succ (M n j : ℕ) :
    carryFromRight M n (j + 1) =
      carryAtChamber (Nat.choose n (n - j)) (carryFromRight M n j) M := rfl

/-- The displayed (visible) digit at the chamber being processed at
step `j + 1`. With `j = 0` this is the value of chamber `n`, etc. -/
def visibleFromRight (M n : ℕ) (j : ℕ) : ℕ :=
  displayedBin (Nat.choose n (n - j)) (carryFromRight M n j) M

/-- **PROVED — per-step conservation:** at step `j + 1`, the raw
coefficient plus the incoming carry equals the visible digit plus
`M ·` outgoing carry. The exact local conservation law that lifts
`displayedBin_plus_carry_eq` along the recurrence. -/
theorem visible_plus_carry_conservation_step
    (M n j : ℕ) (hM : 0 < M) :
    visibleFromRight M n j + M * carryFromRight M n (j + 1)
      = Nat.choose n (n - j) + carryFromRight M n j := by
  unfold visibleFromRight
  rw [carryFromRight_succ]
  exact displayedBin_plus_carry_eq _ _ _ hM

/-- **PROVED — every visible digit is `< M`.** The carry field keeps
each chamber inside its capacity bound. -/
theorem visibleFromRight_lt_M
    (M n j : ℕ) (hM : 0 < M) :
    visibleFromRight M n j < M := by
  unfold visibleFromRight
  exact displayedBin_lt_M _ _ _ hM

/-- **PROVED — `C(n, k) ≤ n^k / k!` upper bound** (via the standard
inequality `Nat.choose_le_pow_self_div_factorial` or by direct
computation). Actually a much simpler PROVED bound: `C(n, k) ≤ n^k`. -/
theorem choose_le_n_pow_k (n k : ℕ) : Nat.choose n k ≤ n^k := by
  induction k with
  | zero => simp
  | succ j ih =>
      by_cases hjn : j < n
      · -- For k ≤ n, we have C(n, k+1) ≤ C(n, k)·n.
        have hch : Nat.choose n (j+1) ≤ n * Nat.choose n j := by
          rcases lt_or_ge (j+1) (n+1) with hjp | hjp
          · -- C(n, j+1) = C(n, j) · (n - j) / (j + 1) ≤ C(n, j) · n
            have hcn : Nat.choose n (j+1) * (j+1) = Nat.choose n j * (n - j) := by
              rw [Nat.choose_succ_right_eq]
            have hle : Nat.choose n j * (n - j) ≤ Nat.choose n j * n :=
              Nat.mul_le_mul_left _ (Nat.sub_le _ _)
            have h1 : Nat.choose n (j+1) * (j+1) ≤ Nat.choose n j * n :=
              hcn ▸ hle
            have h_jp : 1 ≤ j + 1 := by omega
            calc Nat.choose n (j+1)
                ≤ Nat.choose n (j+1) * (j+1) := Nat.le_mul_of_pos_right _ h_jp
              _ ≤ Nat.choose n j * n := h1
              _ = n * Nat.choose n j := Nat.mul_comm _ _
          · -- C(n, j+1) = 0 since j+1 > n
            have : Nat.choose n (j+1) = 0 := Nat.choose_eq_zero_of_lt (by omega)
            rw [this]; exact Nat.zero_le _
        calc Nat.choose n (j+1) ≤ n * Nat.choose n j := hch
          _ ≤ n * n^j := Nat.mul_le_mul_left _ ih
          _ = n^(j+1) := by rw [pow_succ]; ring
      · -- j ≥ n: then C(n, j+1) = 0
        have : Nat.choose n (j+1) = 0 := Nat.choose_eq_zero_of_lt (by omega)
        rw [this]; exact Nat.zero_le _

/--
**Named record — the THREE SHADOWS of the last Pascal row.**
  A: front residue (factorial).
  B: center mass (Gaussian).
  C: carried front value (exponential).
-/
structure ThreeShadowsOfLastRow where
  M : ℕ                                  -- = 10^m
  shadowA_front_residue : Prop           -- C(M, k)/M^k → 1/k!
  shadowB_center_mass : Prop             -- C(M, M/2) ~ 2^M/√(πM/2)
  shadowC_carried_value : Prop           -- (1+1/M)^M → e

/--
**Named record — the three coordinate systems.** Each reveals a
different face of the last row.
-/
structure ThreeCoordinates where
  front_k : ℕ → ℕ                       -- k itself
  bulk_x : ℕ → ℚ                        -- x = k/M
  center_y : ℕ → ℚ                      -- y = (k - M/2)/√M
  front_gives_factorial_residue : Prop
  bulk_gives_distribution_shape : Prop
  center_gives_gaussian : Prop

/--
**Named record — the carry-operator framework** with three layers:
  raw / overflow transport / visible residue.
-/
structure CarryOperatorFramework where
  rawPressure : ℕ → ℕ → ℕ              -- (n, k) ↦ C(n, k)
  carryWave : ℕ → ℕ → ℕ → ℕ            -- (n, k, M) ↦ q_k
  visibleResidue : ℕ → ℕ → ℕ → ℕ       -- (n, k, M) ↦ d_k
  carry_recurrence : Prop               -- q_k = ⌊(a_k + q_{k+1})/M⌋
  visible_residue_eq : Prop             -- d_k = (a_k + q_{k+1}) mod M
  conservation : Prop                   -- a_k + q_{k+1} = d_k + M·q_k

/--
**Named record — the post-rupture carry wave** (anchor subtracted).
`C_m(t) = (1 + 1/M)^{⌊tM⌋ − R_m}` where `R_m` is the first rupture row.
Same e^t limit as the unanchored wave (since R_m/M → 0). The clean
prefix is structurally necessary but numerically vanishing.
-/
structure PostRuptureCarryWave where
  C_wave : ℕ → ℚ → ℚ                   -- (Ω, t) ↦ C_m(t)
  prefix_subtracted : Prop
  same_limit_as_unanchored : Prop      -- C_m(t) → e^t
  e_mass_carried_entirely_by_overflow : Prop

/--
**Named target — Postulate 1 (Theorem A): factorials are front
residues of compressed combinatorial waves.**
`lim_{M→∞} C(tM, k)/M^k = t^k/k!`.
-/
structure Postulate1_FactorialFrontResidue where
  identity : Prop
  is_a_theorem : Prop  -- the limit is a true theorem

/-- **Named target — Theorem B: total residue = e^t.**
`lim_{M→∞} (1 + 1/M)^{tM} = e^t`. -/
structure TheoremB_TotalResidue where
  identity : Prop

/-- **Named target — Conjecture D: scaled carry-field shape.** There
exists a meaningful limiting shape for `q_k(tM, M)` after normalization
and using coordinate `x = k/M`. -/
structure ConjectureD_ScaledCarryShape where
