-- === Phase LXVI: The Unified Trace Machine c_i = Tr(λ·φⁱ) ===
-- The single formula c_i = Tr_{ℚ(√5)/ℚ}(λ·φⁱ) contains Lucas (λ=1),
-- Fibonacci-like (λ=√5=2φ−1), conjugate-twist (λ=1−φ), and minus-φ
-- (λ=−φ) filters as special cases. Fibonacci = COORDINATES of φⁿ in
-- ℤ[φ]; Lucas = TRACES of φⁿ. Two shadows of the same algebraic
-- object. φⁿ = F_{n−1} + Fₙ·φ. Tested across the b-stack:
-- Lucas length-2 vs length-3 at n=3 margin +0.258141;
-- minus-φ length-2 vs length-3 at n=3 margin +0.187850.
-- Previous custom-pair best (+1.353595) remains the leader at small n.

/-- The conjugate `φ' = 1 − φ = (1 − √5)/2`. The Galois conjugate of
`φ` in `ℚ(√5)`. -/
noncomputable def phiConj : ℝ := 1 - phi

/-- **PROVED — `φ + φ' = 1`.** -/
theorem phi_plus_phiConj : phi + phiConj = 1 := by unfold phiConj; ring

/-- **PROVED — `φ · φ' = −1`.** Uses `phi² = phi + 1`. -/
theorem phi_times_phiConj : phi * phiConj = -1 := by
  unfold phiConj
  have h : phi + 1 = phi ^ 2 := phi_add_one_eq_phi_sq
  nlinarith [h]

/-- **PROVED — `φ` and `φ'` are conjugate roots of `x² − x − 1 = 0`.** -/
theorem phiConj_min_poly : phiConj^2 - phiConj - 1 = 0 := by
  have h1 : phi + phiConj = 1 := phi_plus_phiConj
  have h2 : phi * phiConj = -1 := phi_times_phiConj
  have h3 : phi + 1 = phi^2 := phi_add_one_eq_phi_sq
  nlinarith [h1, h2, h3]

/-- **PROVED — the Fibonacci expansion of `φⁿ`.** For all `n : ℕ`,
`φ^(n+1) = F_n + F_{n+1}·φ`. The single recurrence equation gives both
Fibonacci (coordinates) and Lucas (traces). -/
theorem phi_pow_succ_fib_expansion (n : ℕ) :
    phi ^ (n + 1) = (Nat.fib n : ℝ) + (Nat.fib (n + 1) : ℝ) * phi := by
  induction n with
  | zero =>
      simp [Nat.fib_zero, Nat.fib_one, pow_one]
  | succ k ih =>
      have h_phi_sq : phi^2 = phi + 1 := phi_add_one_eq_phi_sq.symm
      have hfib : (Nat.fib (k + 2) : ℝ)
          = (Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ) := by
        exact_mod_cast Nat.fib_add_two
      calc phi ^ (k + 1 + 1)
          = phi ^ (k + 1) * phi := by ring
        _ = ((Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ) * phi) * phi := by
            rw [ih]
        _ = (Nat.fib k : ℝ) * phi + (Nat.fib (k + 1) : ℝ) * phi^2 := by
            ring
        _ = (Nat.fib k : ℝ) * phi + (Nat.fib (k + 1) : ℝ) * (phi + 1) := by
            rw [h_phi_sq]
        _ = (Nat.fib (k + 1) : ℝ)
              + ((Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ)) * phi := by
            ring
        _ = (Nat.fib (k + 1) : ℝ) + (Nat.fib (k + 2) : ℝ) * phi := by
            rw [hfib]

/-- The rational trace `Tr_{ℚ(√5)/ℚ}` of an element `a + b·φ ∈ ℚ[φ]`.
For `α = a + b·φ`, the conjugate is `a + b·φ' = a + b·(1−φ)`, so the
trace is `(a + b·φ) + (a + b·(1−φ)) = 2a + b`. -/
def traceQSqrt5 (a b : ℝ) : ℝ := 2 * a + b

/-- **PROVED — the trace formula.** `(a + b·φ) + (a + b·φ') = 2a + b`. -/
theorem traceQSqrt5_eq (a b : ℝ) :
    (a + b * phi) + (a + b * phiConj) = traceQSqrt5 a b := by
  unfold traceQSqrt5 phiConj; ring

/-- **PROVED — the same Fibonacci expansion for `φ' = 1 − φ`.** The
conjugate also satisfies `x² = x + 1`, so the identical induction
applies. -/
theorem phiConj_pow_succ_fib_expansion (n : ℕ) :
    phiConj ^ (n + 1) = (Nat.fib n : ℝ) + (Nat.fib (n + 1) : ℝ) * phiConj := by
  have hconj_sq : phiConj^2 = phiConj + 1 := by
    have := phiConj_min_poly; linarith
  induction n with
  | zero => simp [Nat.fib_zero, Nat.fib_one, pow_one]
  | succ k ih =>
      have hfib : (Nat.fib (k + 2) : ℝ)
          = (Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ) := by
        exact_mod_cast Nat.fib_add_two
      calc phiConj ^ (k + 1 + 1)
          = phiConj ^ (k + 1) * phiConj := by ring
        _ = ((Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ) * phiConj) * phiConj := by
            rw [ih]
        _ = (Nat.fib k : ℝ) * phiConj + (Nat.fib (k + 1) : ℝ) * phiConj^2 := by
            ring
        _ = (Nat.fib k : ℝ) * phiConj + (Nat.fib (k + 1) : ℝ) * (phiConj + 1) := by
            rw [hconj_sq]
        _ = (Nat.fib (k + 1) : ℝ)
              + ((Nat.fib k : ℝ) + (Nat.fib (k + 1) : ℝ)) * phiConj := by
            ring
        _ = (Nat.fib (k + 1) : ℝ) + (Nat.fib (k + 2) : ℝ) * phiConj := by
            rw [hfib]

/-- **PROVED — Lucas numbers as traces of `φⁿ`.** For all `n`,
`Tr(φ^(n+1)) = 2·F_n + F_{n+1}`. Lucas IS the trace of the Fibonacci
expansion. -/
theorem lucas_eq_trace_phi_pow_succ (n : ℕ) :
    phi^(n+1) + phiConj^(n+1) = traceQSqrt5 (Nat.fib n) (Nat.fib (n+1)) := by
  rw [phi_pow_succ_fib_expansion n, phiConj_pow_succ_fib_expansion n,
      ← traceQSqrt5_eq]

