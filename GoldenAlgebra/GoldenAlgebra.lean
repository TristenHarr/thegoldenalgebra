  [instInner : InnerProductSpace ℂ H]
  /-- Completeness. -/
  [instComplete : CompleteSpace H]
  /-- The self-adjoint operator. -/
  A : H →L[ℂ] H
  /-- Self-adjointness. -/
  selfAdjoint : IsSelfAdjoint A
  /-- The spectrum lies on the real axis. -/
  spectrum_real : ∀ z : ℂ, z ∈ spectrum ℂ A → z.im = 0

attribute [instance] ToyHPBridge.instNorm ToyHPBridge.instInner
  ToyHPBridge.instComplete

/-- **Every operator yields a toy HP bridge.**
The operator-construction engine: from any bounded operator `N` on a
complex Hilbert space, `N + N*` inhabits `ToyHPBridge`. -/
noncomputable def ToyHPBridge.ofOperator
    {H : Type} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (N : H →L[ℂ] H) : ToyHPBridge where
  H := H
  A := selfAdjointization N
  selfAdjoint := selfAdjointization_isSelfAdjoint N
  spectrum_real := selfAdjointization_spectrum_real N

/-- **The toy Hilbert–Pólya bridge is inhabited.**
A concrete witness on `H = ℂ`: the architecture
(self-adjoint operator + real spectrum) is genuinely constructible.

The contrast with `BoundedHPBridge` is the honest statement of where
