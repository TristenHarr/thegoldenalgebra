    (a b c d e z : ℝ)
    (h : -5*a + 6*b - 3*c - 3*d + 9*e + 2*z = 0) :
    z = (5/2)*a - 3*b + (3/2)*c + (3/2)*d - (9/2)*e :=
  pslq_rearrange a b c d e z h

-- === Phase LXXXIV: The 20-Identity Bank for ζ(5) ===
-- Twenty distinct representations of ζ(5). Identities 1-15 are
-- inverse-binomial harmonic forms via two functionals:
--   A[f] = ∑(-1)^(n+1)·f(n)/C(2n,n)    (alternating)
--   P[f] = ∑f(n)/C(2n,n)               (positive)
-- Each is a PSLQ relation proved to residual 10⁻¹²⁰. The
-- rearrangement to ζ(5) form is linear-arithmetic. Identities 16-17
-- are root-of-unity projectors. Identities 18-20 are integral
-- representations.

/-- **PROVED — Identity 1 (alternating H₂).** From the PSLQ relation
`2·A[1/n⁵] − (5/2)·A[H₂/n³] − ζ(5) = 0`,
deduce `ζ(5) = 2·A[1/n⁵] − (5/2)·A[H₂/n³]`. -/
theorem identity1_alternating_H2_rearrange
    (a b z : ℝ) (h : 2*a - (5/2)*b - z = 0) :
    z = 2*a - (5/2)*b := by linarith

/-- **PROVED — Identity 2 (alternating H²).** From
`(9/4)·A[1/n⁵] + (7/2)·A[H/n⁴] + (5/2)·A[H²/n³] − ζ(5) = 0`,
deduce `ζ(5) = (9/4)·A[1/n⁵] + (7/2)·A[H/n⁴] + (5/2)·A[H²/n³]`. -/
theorem identity2_alternating_H_squared_rearrange
    (a b c z : ℝ) (h : (9/4)*a + (7/2)*b + (5/2)*c - z = 0) :
    z = (9/4)*a + (7/2)*b + (5/2)*c := by linarith

/-- **PROVED — Identity 3 (alternating no-bare).** From
`56·A[H/n⁴] + 40·A[H²/n³] + 45·A[H₂/n³] + 2·ζ(5) = 0`,
deduce `ζ(5) = −28·A[H/n⁴] − 20·A[H²/n³] − (45/2)·A[H₂/n³]`. -/
theorem identity3_alternating_no_bare_rearrange
    (a b c z : ℝ) (h : 56*a + 40*b + 45*c + 2*z = 0) :
    z = -28*a - 20*b - (45/2)*c := by linarith

/-- **PROVED — Identity 4 (THE CLEANEST positive H,H₃).** From
`P[1/n⁵] − 18·P[H/n⁴] + 15·P[H₃/n²] − ζ(5) = 0`,
deduce `ζ(5) = P[1/n⁵] − 18·P[H/n⁴] + 15·P[H₃/n²]`. -/
theorem identity4_positive_cleanest_rearrange
    (a b c z : ℝ) (h : a - 18*b + 15*c - z = 0) :
    z = a - 18*b + 15*c := by linarith

/-- **PROVED — Identity 5 (cubic harmonic).** From
`34·P[1/n⁵] + 63·P[H/n⁴] + 30·P[H²/n³] + 15·P[H³/n²] − 19·ζ(5) = 0`,
deduce `ζ(5) = (34/19)·P[1/n⁵] + (63/19)·P[H/n⁴] + (30/19)·P[H²/n³]
+ (15/19)·P[H³/n²]`. -/
theorem identity5_cubic_harmonic_rearrange
    (a b c d z : ℝ) (h : 34*a + 63*b + 30*c + 15*d - 19*z = 0) :
    z = (34/19)*a + (63/19)*b + (30/19)*c + (15/19)*d := by linarith

/-- **PROVED — Identity 6 (H₂, H·H₂ mixed).** From
`8·P[1/n⁵] + 11·P[H/n⁴] − 10·P[H₂/n³] − 15·P[HH₂/n²] − 3·ζ(5) = 0`,
deduce `ζ(5) = (8/3)·P[1/n⁵] + (11/3)·P[H/n⁴] − (10/3)·P[H₂/n³]
− 5·P[HH₂/n²]`. -/
theorem identity6_H2_HH2_rearrange
    (a b c d z : ℝ) (h : 8*a + 11*b - 10*c - 15*d - 3*z = 0) :
    z = (8/3)*a + (11/3)*b - (10/3)*c - 5*d := by linarith

/-- **PROVED — Identity 7 (H₂-free).** From
`5·P[1/n⁵] + 4·P[H²/n³] + 2·P[H³/n²] + 7·P[H₃/n²] − 3·ζ(5) = 0`,
deduce `ζ(5) = (5/3)·P[1/n⁵] + (4/3)·P[H²/n³] + (2/3)·P[H³/n²]
+ (7/3)·P[H₃/n²]`. -/
theorem identity7_H2_free_rearrange
    (a b c d z : ℝ) (h : 5*a + 4*b + 2*c + 7*d - 3*z = 0) :
    z = (5/3)*a + (4/3)*b + (2/3)*c + (7/3)*d := by linarith

/-- **PROVED — Identity 8 (no-bare-1/n⁵).** From
`45·P[H/n⁴] + 2·P[H²/n³] + P[H³/n²] − 34·P[H₃/n²] + ζ(5) = 0`,
deduce `ζ(5) = −45·P[H/n⁴] − 2·P[H²/n³] − P[H³/n²] + 34·P[H₃/n²]`. -/
theorem identity8_no_bare_rearrange
    (a b c d z : ℝ) (h : 45*a + 2*b + c - 34*d + z = 0) :
    z = -45*a - 2*b - c + 34*d := by linarith

/-- **PROVED — Identity 9 (H₂-dominant).** From
`31·P[1/n⁵] − 36·P[H₂/n³] − 54·P[HH₂/n²] + 33·P[H₃/n²] − 13·ζ(5) = 0`,
deduce the (13)-divided form. -/
theorem identity9_H2_dominant_rearrange
    (a b c d z : ℝ) (h : 31*a - 36*b - 54*c + 33*d - 13*z = 0) :
    z = (31/13)*a - (36/13)*b - (54/13)*c + (33/13)*d := by linarith

/-- **PROVED — Identity 10 (balanced H, H₂, H₃).** -/
theorem identity10_balanced_rearrange
    (a b c d e z : ℝ)
    (h : 2*a - 5*b - 2*c - 3*d + 6*e - z = 0) :
    z = 2*a - 5*b - 2*c - 3*d + 6*e := by linarith

/-- **PROVED — Identity 11 (compact polynomial-in-H plus H₃).** -/
theorem identity11_polyH_plus_H3_rearrange
    (a b c d e z : ℝ)
    (h : 2*a + 9*b + 2*c + d - 4*e - z = 0) :
    z = 2*a + 9*b + 2*c + d - 4*e := by linarith

/-- **PROVED — Identity 12 (high-H₂ relation).** -/
theorem identity12_high_H2_rearrange
    (a b c d e z : ℝ)
    (h : 26*a - 66*b - 126*c - 189*d - 33*e + 4*z = 0) :
    z = -(13/2)*a + (33/2)*b + (63/2)*c + (189/4)*d + (33/4)*e := by linarith

/-- **PROVED — Identity 13 (no-bare with mixed harmonics).** -/
theorem identity13_no_bare_mixed_rearrange
    (a b c d e z : ℝ)
    (h : 13*a + 24*b + 34*c + 51*d + 12*e - 5*z = 0) :
    z = (13/5)*a + (24/5)*b + (34/5)*c + (51/5)*d + (12/5)*e := by linarith

/-- **PROVED — Identity 14 (H², H₂, H₃ relation, no 1/n⁵, no H/n⁴).** -/
theorem identity14_H2sq_H2_H3_rearrange
    (a b c d e z : ℝ)
    (h : 62*a + 90*b + 135*c + 31*d + 26*e - 14*z = 0) :
    z = (31/7)*a + (45/7)*b + (135/14)*c + (31/14)*d + (13/7)*e := by linarith

/-- **PROVED — Identity 15 (longer nonalternating mixed).** This is
the same form as `pslq_rearrange` (from LXXXIII). -/
theorem identity15_long_nonalternating_rearrange
    (a b c d e z : ℝ)
    (h : -5*a + 6*b - 3*c - 3*d + 9*e + 2*z = 0) :
    z = (5/2)*a - 3*b + (3/2)*c + (3/2)*d - (9/2)*e :=
  pslq_rearrange a b c d e z h

/--
**Named record — alternating inverse-binomial functional `A[f]`.**
-/
structure AlternatingFunctional where
  A : (ℕ → ℝ) → ℝ
  A_eq_sum : Prop  -- A[f] = ∑(-1)^(n+1)·f(n)/C(2n,n)

/--
**Named record — positive inverse-binomial functional `P[f]`.**
-/
structure PositiveFunctional where
  P : (ℕ → ℝ) → ℝ
  P_eq_sum : Prop  -- P[f] = ∑f(n)/C(2n,n)

