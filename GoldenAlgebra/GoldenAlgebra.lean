-- === Phase LXVIII: Pascal / Cyclotomic / Golden Operator Algebra ===
-- Each filter is a "color lens" on the b-stack: a filter
-- [c₀,c₁,…,c_d] acts as c₀R_{n,b} + c₁R_{n,b+1} + ⋯ + c_d R_{n,b+d}.
-- The structured atoms form a small operator algebra in ℤ[x]:
--   D     = 1 − x                          (Pascal / finite-difference)
--   Φ₅    = 1 + x + x² + x³ + x⁴           (cyclotomic, pentagon avg)
--   J     = 1 − x⁵ = D · Φ₅                (pentagonal jump)
--   G     = 2 − x                          (golden splitter)
-- The factorization J = D·Φ₅ is the Pascal/root-of-unity bridge.
-- Best margin still G = [2,−1] with stack [2,−1,3]: +1.353595.
-- Pascal/cyclotomic products did NOT beat it. After total index 11,
-- margins go negative. The missing object: an ITERATION RULE in the
-- operator algebra (e.g. G_{r+1} = D·Φ₅·G_r, or G_{r+1} = G_r(x⁵), or
-- a companion recurrence in the operator algebra).

/-- **The Pascal / finite-difference operator `D(x) = 1 − x`.** -/
def D_op (x : ℝ) : ℝ := 1 - x

/-- **The fifth-root cyclotomic `Φ₅(x) = 1 + x + x² + x³ + x⁴`.** -/
def Phi5_op (x : ℝ) : ℝ := 1 + x + x^2 + x^3 + x^4

/-- **The pentagonal jump `J(x) = 1 − x⁵`.** -/
def J_op (x : ℝ) : ℝ := 1 - x^5

/-- **The golden splitter `G(x) = 2 − x`.** -/
def G_op (x : ℝ) : ℝ := 2 - x

/-- **PROVED — `D · Φ₅ = J`.** The Pascal/root-of-unity bridge:
local difference × pentagonal average = five-step jump. By `ring`. -/
theorem D_times_Phi5_eq_J (x : ℝ) :
    D_op x * Phi5_op x = J_op x := by
  unfold D_op Phi5_op J_op
  ring

/-- **PROVED — Pascal alternating row `(1−x)² = 1 − 2x + x²`.** -/
theorem one_minus_x_sq (x : ℝ) :
    (1 - x)^2 = 1 - 2*x + x^2 := by ring

/-- **PROVED — Pascal alternating row `(1−x)³ = 1 − 3x + 3x² − x³`.** -/
theorem one_minus_x_cubed (x : ℝ) :
    (1 - x)^3 = 1 - 3*x + 3*x^2 - x^3 := by ring

/-- **PROVED — Pascal alternating row `(1−x)⁴ = 1 − 4x + 6x² − 4x³ + x⁴`.**
The four-step finite-difference operator. -/
theorem one_minus_x_to_four (x : ℝ) :
    (1 - x)^4 = 1 - 4*x + 6*x^2 - 4*x^3 + x^4 := by ring

/-- **PROVED — `Φ₅` is the geometric-series sum at degree 4.** For
`x ≠ 1`, `Φ₅(x) = (x⁵ − 1)/(x − 1)`. -/
theorem Phi5_geom_sum (x : ℝ) (hx : x ≠ 1) :
    Phi5_op x = (x^5 - 1) / (x - 1) := by
  unfold Phi5_op
  have hx_ne : x - 1 ≠ 0 := sub_ne_zero.mpr hx
  field_simp
  ring

/-- **PROVED — `Φ₅(1) = 5`.** -/
theorem Phi5_at_one : Phi5_op 1 = 5 := by unfold Phi5_op; norm_num

/-- **PROVED — `Φ₅` evaluated at a primitive 5th root of unity gives 0.**
Generic statement: if `x⁵ = 1` and `x ≠ 1`, then `Φ₅(x) = 0`. -/
theorem Phi5_at_fifth_root (x : ℝ) (h5 : x^5 = 1) (hx : x ≠ 1) :
    Phi5_op x = 0 := by
  have hbridge : (1 - x) * Phi5_op x = 1 - x^5 := by
    have h := D_times_Phi5_eq_J x
    unfold D_op J_op at h
    exact h
  rw [h5, sub_self] at hbridge
  have hne : (1 - x) ≠ 0 := sub_ne_zero.mpr (Ne.symm hx)
  exact (mul_eq_zero.mp hbridge).resolve_left hne

/-- The filter coefficient lists for each operator atom. -/
def filter_D : List ℤ := [1, -1]
def filter_D2 : List ℤ := [1, -2, 1]
def filter_D3 : List ℤ := [1, -3, 3, -1]
def filter_D4 : List ℤ := [1, -4, 6, -4, 1]
def filter_Phi5 : List ℤ := [1, 1, 1, 1, 1]
def filter_J : List ℤ := [1, 0, 0, 0, 0, -1]
def filter_G : List ℤ := [2, -1]
def filter_G_stack3 : List ℤ := [2, -1, 3]

