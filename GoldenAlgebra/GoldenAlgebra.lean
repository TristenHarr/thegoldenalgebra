-- === Phase CIX: Non-Recursive RS₀ Zero Constructor ===
-- Replace the CIRCULAR exact `R(t) = Z(t) − A(t)` with an EXPLICIT
-- leading Riemann-Siegel correction `E_0(t)`. The constructor:
--   A(t) + E_0(t) = 0  ⟹  ρ ≈ 1/2 + i·t.
-- Errors ~10⁻³ throughout the first 200 zeros — first concrete
-- "overflow math" zero machine.

/-- Fractional part `p(t) = √(t/(2π)) − ⌊√(t/(2π))⌋`. -/
noncomputable def RS_fractional (t : ℝ) : ℝ :=
  Real.sqrt (t / (2 * Real.pi)) - ⌊Real.sqrt (t / (2 * Real.pi))⌋

/-- The first RS correction polynomial. -/
noncomputable def RS_C0 (p : ℝ) : ℝ :=
  Real.cos (2 * Real.pi * (p^2 - p - 1/16)) / Real.cos (2 * Real.pi * p)

/-- The leading RS correction `E_0(t)`. -/
noncomputable def RS_E0 (t : ℝ) (N : ℕ) (p : ℝ) : ℝ :=
  ((-1)^(N - 1) : ℝ) * (t / (2 * Real.pi))^(-(1/4) : ℝ) * RS_C0 p

