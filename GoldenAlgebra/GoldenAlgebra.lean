  ArithmeticMechanizedHeatZetaCore_implies_zeta_critical_line
    Z.toArithmeticMechanizedHeatZetaCore

-- Step 162: Dirichlet-convolution heat deformation.

/--
A heat-trace deformation produced by Dirichlet-convolution weighting —
the most arithmetic mechanism.
-/
structure DirichletConvolutionHeatDeformation where
