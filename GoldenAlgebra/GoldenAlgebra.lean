    (2 : ℝ) / Real.sqrt Real.pi > 1.128
    ∧ (2 : ℝ) / Real.sqrt Real.pi < 1.13 := by
  have h_sqrt_pi_lower : Real.sqrt Real.pi > 1.7715 := by
    rw [show (1.7715 : ℝ) = Real.sqrt 3.13821225 from by
      rw [show (3.13821225 : ℝ) = (1.7715 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 1.7715)).symm]
    apply Real.sqrt_lt_sqrt (by norm_num)
    have hπ : Real.pi > 3.14 := Real.pi_gt_d2
    linarith
  have h_sqrt_pi_upper : Real.sqrt Real.pi < 1.7725 := by
    rw [show (1.7725 : ℝ) = Real.sqrt 3.14175625 from by
      rw [show (3.14175625 : ℝ) = (1.7725 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 1.7725)).symm]
    apply Real.sqrt_lt_sqrt
    · positivity
    · have hπ : Real.pi < 3.1416 := Real.pi_lt_d4
      linarith
  refine ⟨?_, ?_⟩
  · rw [gt_iff_lt, lt_div_iff₀ (by positivity)]
    nlinarith [h_sqrt_pi_upper,
      Real.sqrt_pos.mpr (show (0 : ℝ) < Real.pi from Real.pi_pos)]
  · rw [div_lt_iff₀ (by positivity)]
    nlinarith [h_sqrt_pi_lower]

