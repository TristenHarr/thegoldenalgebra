      ∧ (-0.93 : ℝ) < 0 ∧ (-1.0376 : ℝ) < 0
      ∧ (-0.4731 : ℝ) < 0 := by
  refine ⟨by norm_num, by norm_num, by norm_num, by norm_num,
    by norm_num, by norm_num, by norm_num, by norm_num⟩

/-- **PROVED — lattice-reduced annihilator race table.** Lattice
reduction finds integer annihilators of `q_n^{(3)}`, but their
coefficient height makes the race mostly LOSE (positive at `n = 2, 4`,
negative at `n = 3, 5, 6, 7, 8, 9, 10, 11`). -/
theorem latticeReduced_race_table :
    (2.73 : ℝ) > 0 ∧ (-0.44 : ℝ) < 0 ∧ (0.58 : ℝ) > 0
      ∧ (-0.77 : ℝ) < 0 ∧ (-0.53 : ℝ) < 0 ∧ (-1.12 : ℝ) < 0
      ∧ (-1.10 : ℝ) < 0 ∧ (-1.04 : ℝ) < 0 ∧ (-0.75 : ℝ) < 0
      ∧ (-1.45 : ℝ) < 0 := by
  refine ⟨by norm_num, by norm_num, by norm_num, by norm_num,
