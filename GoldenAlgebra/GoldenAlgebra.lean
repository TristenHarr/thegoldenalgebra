-- =====================================================================
-- === Tier 73 — Critical-Shift Coordinate Lemmas =====================
-- =====================================================================

/-- The real part of a critical-shift point is always `1/2`. -/
theorem criticalShift_re (t : ℝ) : (criticalShift t).re = 1 / 2 := by
  unfold criticalShift
  simp [Complex.add_re, Complex.mul_re]

/-- The imaginary part of a critical-shift point is the ordinate `t`. -/
theorem criticalShift_im (t : ℝ) : (criticalShift t).im = t := by
  unfold criticalShift
  simp [Complex.add_im, Complex.mul_im]

-- =====================================================================
-- === Tier 74 — Exactness from Zero Error ============================
-- =====================================================================

/-- Zero matching error forces an exact critical-shift identity. -/
theorem zero_error_gives_exact_criticalShift
    {ρ : ℂ} {t : ℝ} (h : ‖ρ - criticalShift t‖ = 0) :
    ρ = criticalShift t := by
  rw [← sub_eq_zero]
  exact norm_eq_zero.mp h

-- =====================================================================
-- === Tier 75 — Quantitative Distance to the Critical Line ===========
-- =====================================================================

/-- **Distance to the critical line.**
The best critical-shift approximation of `ρ` (taking `t = ρ.im`) has
squared error exactly `(Re ρ − 1/2)²`:
  `‖ρ − criticalShift ρ.im‖² = (Re ρ − 1/2)²`.
Spectral-matching error *is* the squared distance to the critical line. -/
theorem criticalShift_distance_sq (ρ : ℂ) :
    ‖ρ - criticalShift ρ.im‖ ^ 2 = (ρ.re - 1 / 2) ^ 2 := by
  rw [Complex.norm_def, Real.sq_sqrt (Complex.normSq_nonneg _),
      Complex.normSq_apply]
  have hre : (ρ - criticalShift ρ.im).re = ρ.re - 1 / 2 := by
    rw [Complex.sub_re, criticalShift_re]
  have him : (ρ - criticalShift ρ.im).im = 0 := by
    rw [Complex.sub_im, criticalShift_im]; ring
  rw [hre, him]
  ring

/-- **Exact critical-shift representability ⇔ on the critical line.**
`ρ` is a critical-shift point for *some* ordinate iff `Re ρ = 1/2`. -/
theorem exact_criticalShift_iff_re_eq_half (ρ : ℂ) :
    (∃ t : ℝ, ρ = criticalShift t) ↔ ρ.re = 1 / 2 := by
  constructor
  · rintro ⟨t, ht⟩
    rw [ht, criticalShift_re]
  · intro hre
    refine ⟨ρ.im, ?_⟩
    apply Complex.ext
    · rw [criticalShift_re]; exact hre
    · rw [criticalShift_im]

-- =====================================================================
-- === Tier 76 — Approximate Match Bounds the RH Error ================
-- =====================================================================

/-- **An approximate spectral match bounds the RH error.**
If `ρ` is within `ε` of *some* critical-shift point, then `ρ` is within
`ε` of the critical line:  `|Re ρ − 1/2| ≤ ε`.
The real part is 1-Lipschitz, so matching error controls RH error. -/
theorem criticalLine_distance_bound_of_match
    {ρ : ℂ} {t ε : ℝ} (hε : ‖ρ - criticalShift t‖ ≤ ε) :
    |ρ.re - 1 / 2| ≤ ε := by
  have hre : (ρ - criticalShift t).re = ρ.re - 1 / 2 := by
    rw [Complex.sub_re, criticalShift_re]
  calc |ρ.re - 1 / 2|
      = |(ρ - criticalShift t).re| := by rw [hre]
    _ ≤ ‖ρ - criticalShift t‖ := Complex.abs_re_le_norm _
    _ ≤ ε := hε

-- =====================================================================
-- === Tier 77 — Finite Approximate-RH Theorem ========================
-- =====================================================================

/-- A **finite zeta spectral match**: finitely many poles paired with
spectral ordinates, with the pointwise matching error. -/
structure FiniteZetaSpectralMatch where
  /-- The number of matched poles. -/
  n : ℕ
  /-- The zeta poles. -/
  pole : Fin n → ℂ
  /-- The matched spectral ordinates. -/
  spectral : Fin n → ℝ
  /-- The pointwise matching error. -/
  match_error : Fin n → ℝ
  /-- The error is the distance pole↔critical-shift. -/
  match_error_eq : ∀ i,
    match_error i = ‖pole i - criticalShift (spectral i)‖

/-- A **uniform finite zeta spectral match**: a finite match with a
global error bound `ε`. -/
structure UniformFiniteZetaSpectralMatch extends FiniteZetaSpectralMatch where
  /-- The uniform error bound. -/
  ε : ℝ
  /-- The bound is non-negative. -/
  ε_nonneg : 0 ≤ ε
  /-- Every matching error is within `ε`. -/
  error_le : ∀ i, match_error i ≤ ε

/-- **Finite approximate-RH theorem.**
If a toy spectrum matches finitely many zeta poles within `ε`, then
each of those poles is within `ε` of the critical line:
  `|Re(poleᵢ) − 1/2| ≤ ε`.
No Riemann Hypothesis assumption — a genuine unconditional theorem. -/
theorem UniformFiniteZetaSpectralMatch.rh_error_le
    (M : UniformFiniteZetaSpectralMatch) (i : Fin M.n) :
    |(M.pole i).re - 1 / 2| ≤ M.ε := by
  have h1 : ‖M.pole i - criticalShift (M.spectral i)‖ ≤ M.ε := by
    rw [← M.match_error_eq i]
    exact M.error_le i
  exact criticalLine_distance_bound_of_match h1

/-- A **vanishing zeta spectral match**: a sequence of uniform finite
matches whose error bounds are intended to tend to zero. -/
structure VanishingZetaSpectralMatch where
  /-- The sequence of uniform finite matches. -/
  approx : ℕ → UniformFiniteZetaSpectralMatch
  /-- Intended property: the error bounds tend to zero. -/
  ε_tends_zero : Prop

-- =====================================================================
-- === Tier 79 — Countable Real Spectrum Model ========================
-- =====================================================================

/-- **Countable real spectrum model**: a self-adjoint operator with a
designated countable family of real spectral values. -/
structure CountableRealSpectrumModel where
  /-- The carrier Hilbert space. -/
  H : Type
  /-- Normed group structure. -/
  [instNorm : NormedAddCommGroup H]
  /-- Complex inner product structure. -/
  [instInner : InnerProductSpace ℂ H]
  /-- Completeness. -/
  [instComplete : CompleteSpace H]
  /-- The operator. -/
  A : H →L[ℂ] H
  /-- Self-adjointness. -/
  selfAdjoint : IsSelfAdjoint A
  /-- The designated real spectral values. -/
  spectralValue : ℕ → ℝ
  /-- Each spectral value lies in the spectrum. -/
  spectralValue_mem : ∀ n, (spectralValue n : ℂ) ∈ spectrum ℂ A

attribute [instance] CountableRealSpectrumModel.instNorm
  CountableRealSpectrumModel.instInner CountableRealSpectrumModel.instComplete

-- =====================================================================
-- === Tier 80 — The Bounded-Spectrum Obstruction =====================
-- =====================================================================
-- A bounded operator has bounded spectrum. Zeta zero ordinates are
-- unbounded. So a single bounded operator cannot carry the raw
-- ordinates as spectral values — the architecture must compactify.

/-- **Bounded operators have bounded spectrum.**
Every spectral value of `A : H →L[ℂ] H` satisfies `‖z‖ ≤ ‖A‖·‖1‖`. -/
theorem boundedOperator_spectrum_norm_bound
    {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (A : H →L[ℂ] H) {z : ℂ}
    (hz : z ∈ spectrum ℂ A) :
    ‖z‖ ≤ ‖A‖ * ‖(1 : H →L[ℂ] H)‖ :=
  spectrum.norm_le_norm_mul_of_mem hz

/-- **The bounded-spectrum obstruction.**
No bounded operator can carry an *unbounded* family of real numbers as
spectral values. In particular: a single bounded HP operator cannot
have the raw (unbounded) zeta zero ordinates directly in its spectrum.

This theorem says **"no"** to a false route — it forces the
architecture to compactify the spectral parameter (Tier 81). -/
theorem no_boundedOperator_with_unbounded_spectralValues
    {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (A : H →L[ℂ] H) (t : ℕ → ℝ)
    (ht : ∀ n, (t n : ℂ) ∈ spectrum ℂ A)
    (hunbounded : ∀ B : ℝ, ∃ n, B < |t n|) :
    False := by
  obtain ⟨n, hn⟩ := hunbounded (‖A‖ * ‖(1 : H →L[ℂ] H)‖)
  have hbound := boundedOperator_spectrum_norm_bound A (ht n)
  rw [Complex.norm_real, Real.norm_eq_abs] at hbound
  linarith

