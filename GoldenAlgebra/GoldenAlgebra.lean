/-!
## Tier 98 — Usefulness API

This tier records the **closed-loop usefulness** patterns the Python
experiments demonstrated. Each is captured as a Lean object (definition
+ small lemma) that future development can hang concrete instances on.

* **A. Orbit fitting** — fit `(A, B, C, D)` to observed behaviour.
* **B. Fast far-field approximation** — total desire + low multipoles.
* **C. Unit-lattice as desire detector** — strain monotone in `k_c`.
* **D. Spectral diagnosis** — Hessian eigenvalues scale with `k_c`.
* **E. n-body compression** — reconstruct positions from `r_{ij} = 1/u_{ij}`.
-/

section UsefulnessAPI

-- =========================================================================
-- A. Orbit-fitting interface (compression-polynomial coefficients)
-- =========================================================================

/-- **Compression-polynomial fitting predicate.**
`(A, B, C, D)` fits an observed compression waveform `u : ℝ → ℝ` when
`u'' + u = A + Bu + Cu² + Du³` pointwise. This is exactly
`IsPolynomialCompression4 A B C D u`. -/
def FitsCompressionOrbit (A B C D : ℝ) (u : ℝ → ℝ) : Prop :=
  IsPolynomialCompression4 A B C D u

/-- Newton fit is `(A, 0, 0, 0)`. -/
theorem FitsCompressionOrbit_newton_iff
    {μ h : ℝ} (u : ℝ → ℝ) :
    FitsCompressionOrbit (μ / h ^ 2) 0 0 0 u
      ↔ IsBinetSolution μ h u := by
  unfold FitsCompressionOrbit IsPolynomialCompression4 IsBinetSolution
  constructor
  · intro hu θ; have := hu θ; simpa using this
  · intro hu θ; have := hu θ; simpa using this

-- =========================================================================
-- B. Fast far-field approximation (monopole / quadrupole moments)
-- =========================================================================

/-- A finite point-mass cluster: `n` source points, each with a desire
amplitude (mass) and a 3D position. -/
structure DesirePointCluster (n : ℕ) where
  mass : Fin n → ℝ
  pos  : Fin n → ℝ × ℝ × ℝ

variable {n : ℕ}

/-- **Total desire / monopole** of a finite cluster. -/
noncomputable def DesirePointCluster.totalDesire
    (C : DesirePointCluster n) : ℝ :=
  ∑ i : Fin n, C.mass i

/-- A trivial monotonicity: adding a non-negative-mass source increases
total desire. (Cluster appending is omitted for brevity; recorded as a
non-negativity property of the underlying sum.) -/
theorem DesirePointCluster.totalDesire_nonneg
    (C : DesirePointCluster n) (hC : ∀ i, 0 ≤ C.mass i) :
    0 ≤ C.totalDesire := by
  unfold DesirePointCluster.totalDesire
  exact Finset.sum_nonneg (fun i _ => hC i)

/-- **Center-of-desire** (first moment / "dipole zero" coordinate).
Defined as a vector-valued sum; recorded component-wise. -/
noncomputable def DesirePointCluster.centerOfDesire
    (C : DesirePointCluster n) : ℝ × ℝ × ℝ :=
  let M := C.totalDesire
  ( (∑ i : Fin n, C.mass i * (C.pos i).1) / M
  , (∑ i : Fin n, C.mass i * (C.pos i).2.1) / M
  , (∑ i : Fin n, C.mass i * (C.pos i).2.2) / M )

/-- **Quadrupole-style trace moment** (one scalar — the second-moment
trace; full tensor moments are recorded separately as future work). -/
noncomputable def DesirePointCluster.traceQuadrupole
    (C : DesirePointCluster n) : ℝ :=
  ∑ i : Fin n,
    C.mass i *
      ((C.pos i).1 ^ 2 + (C.pos i).2.1 ^ 2 + (C.pos i).2.2 ^ 2)

-- =========================================================================
-- C. Unit-lattice strain as a desire-density detector (monotonicity)
-- =========================================================================

/-- **Monotonicity statement (qualitative).** A lattice strain measure
`σ : ℝ → ℝ` (parameterised by collapse strength `k_c`) is `desire-monotone`
if it is increasing in `k_c`.

Concrete numerical examples from the Python experiments fit this shape:
edge-RMS error, cell-area defect, and inverse vertex-distance are all
monotone in `k_c`. -/
def IsDesireMonotone (σ : ℝ → ℝ) : Prop :=
  ∀ a b : ℝ, 0 ≤ a → a ≤ b → σ a ≤ σ b

theorem IsDesireMonotone.zero : IsDesireMonotone (fun _ => (0 : ℝ)) := by
  intro _ _ _ _; exact le_refl 0

theorem IsDesireMonotone.id_nonneg :
    IsDesireMonotone (fun k => max 0 k) := by
  intro a b _ hab
  exact max_le_max le_rfl hab

-- =========================================================================
-- D. Spectral diagnosis (eigenvalues increase with collapse strength)
-- =========================================================================

/-- **Spectral diagnosis predicate.** A real-valued eigenvalue
function `λ : ℝ → ℝ` (parameterised by collapse strength `k_c`) is
`spectrally desire-monotone` if it is increasing in `k_c`. The
experimental table shows the first nonzero mode is ≈ √k_c-like (so
strictly monotone). -/
def IsSpectrallyDesireMonotone (lambda : ℝ → ℝ) : Prop :=
  ∀ a b : ℝ, 0 ≤ a → a ≤ b → lambda a ≤ lambda b

theorem IsSpectrallyDesireMonotone.sqrt :
    IsSpectrallyDesireMonotone Real.sqrt := by
  intro a b _ hab
  exact Real.sqrt_le_sqrt hab

-- =========================================================================
-- E. n-body compression reconstruction (closed loop)
-- =========================================================================

/-- **Pair-compression to pair-distance.** `r_{ij} = 1 / u_{ij}` (for
`u_{ij} > 0`). -/
noncomputable def pairDistance (u : ℝ) : ℝ := 1 / u

theorem pairDistance_pos {u : ℝ} (hu : 0 < u) : 0 < pairDistance u := by
  unfold pairDistance
  exact div_pos one_pos hu

/-- Round-trip identity: for `u ≠ 0`, `1 / (1 / u) = u`. The
compression ⇄ distance translation is involutive away from zero. -/
theorem pairDistance_pairDistance {u : ℝ} (_hu : u ≠ 0) :
    pairDistance (pairDistance u) = u := by
  unfold pairDistance
  field_simp

/-- **Closed-loop reconstruction predicate.** Given an ansatz
`A : CompressionChoreographyAnsatz`, reconstruction produces three
pair-distances `r_{12}, r_{23}, r_{31}` as `1 / u` of the phase-shifted
compression. The triangle-inequality constraint must hold pointwise for
the reconstructed shape to be Euclidean-realizable. -/
def IsRealizableChoreographyAt
    (A : CompressionChoreographyAnsatz) (t : ℝ) : Prop :=
  TriangleInequalities (A.side12 t) (A.side23 t) (A.side31 t)

/-- At every `t`, the reconstructed sides are strictly positive. -/
theorem CompressionChoreographyAnsatz.sides_pos
    (A : CompressionChoreographyAnsatz) (t : ℝ) :
    0 < A.side12 t ∧ 0 < A.side23 t ∧ 0 < A.side31 t :=
  ⟨A.side12_pos t, A.side23_pos t, A.side31_pos t⟩

/-- **Newton-residual interface.** A reconstructed orbit `q : ℝ → Fin N → ℂ`
has a "Newton residual" measuring how close it is to a true Newton
solution. We record it as a `Prop`-level interface; the squared L²
residual is the typical concrete realisation. -/
def IsLowNewtonResidual {N : ℕ}
    (_q : ℝ → Fin N → ℂ) (_m : Fin N → ℝ) (_G : ℝ)
    (_ε : ℝ) : Prop :=
  True  -- placeholder for ‖q̈ − grav(q)‖_{L²} ≤ ε.

end UsefulnessAPI

