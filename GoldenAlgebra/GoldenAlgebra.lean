-- Step 212: incomplete-explicit-formula no-go.

/--
An explicit-formula attempt is *incomplete* if it omits any of the
three correction terms (archimedean, trivial-zero, pole).
-/
def IncompleteExplicitFormulaAttempt
    (D : RiemannWeilExplicitFormulaDependencies) : Prop :=
  ¬ D.archimedeanCorrectionDefined ∨
  ¬ D.trivialZeroCorrectionDefined ∨
  ¬ D.poleCorrectionDefined

/-- An incomplete explicit-formula attempt cannot have all three
correction terms — preserving the Step 209 honesty: no "explicit
formula" without its correction terms. -/
theorem incompleteExplicitFormulaAttempt_rejected
    (D : RiemannWeilExplicitFormulaDependencies)
    (h : IncompleteExplicitFormulaAttempt D) :
    ¬ (D.archimedeanCorrectionDefined ∧
        D.trivialZeroCorrectionDefined ∧
        D.poleCorrectionDefined) := by
  intro hall
  rcases hall with ⟨ha, ht, hp⟩
  rcases h with h | h | h
  · exact h ha
  · exact h ht
  · exact h hp

