-- === Phase LXXII: The Moment-Filter Machine ===
-- The abstraction: each node r gives a coefficient vector
--   v_r = (a_r(1), a_r(2), a_r(3), …)
-- indexed by odd-zeta channels ζ(3), ζ(5), ζ(7), …, with
--   a_r(m) = (r^(2m) − 1)/(r+1)^(2m).
-- Using x_r = r/(r+1), y_r = 1/(r+1) (with x_r + y_r = 1):
--   a_r(m) = x_r^(2m) − y_r^(2m).
-- Filters w = (w_i) cancel chosen color channels via determinant
-- cofactor patterns. The cotangent identity
--   S_r = π·cot(π/(r+1))
-- bridges the zeta-summation world to the cotangent/root-of-unity
-- world via Euler: cot θ = i(e^{2iθ}+1)/(e^{2iθ}−1).
-- The stable infinite projector is a coefficient extractor / contour
-- integral approached through operators (substitution, derivative,
-- integral, finite difference, cotangent reflection, root-of-unity
-- projection), NOT through naive deeper linear algebra.

/-- The complementary node parameter `x_r = r/(r+1)`. -/
def xN (r : ℕ) : ℚ := (r : ℚ) / ((r : ℚ) + 1)

/-- The complementary node parameter `y_r = 1/(r+1)`. -/
def yN (r : ℕ) : ℚ := 1 / ((r : ℚ) + 1)

/-- **PROVED — the complement relation `x_r + y_r = 1`.** The
geometric heart of the node parametrization. -/
theorem xN_plus_yN (r : ℕ) : xN r + yN r = 1 := by
  unfold xN yN
  have hpos : (0 : ℚ) < (r : ℚ) + 1 := by
    have : (0 : ℚ) ≤ (r : ℚ) := by exact_mod_cast Nat.zero_le r
    linarith
  have hne : ((r : ℚ) + 1) ≠ 0 := ne_of_gt hpos
  field_simp

/-- **PROVED — coefficient identity.** `a_r(k) = x_r^k − y_r^k`.
The link between the digamma compression coefficient and the
`(x_r, y_r)` parametrization. -/
theorem aN_eq_xN_pow_sub_yN_pow (r k : ℕ) :
    digammaCompressionCoeff r k = xN r ^ k - yN r ^ k := by
  unfold digammaCompressionCoeff xN yN
  have hpos : (0 : ℚ) < (r : ℚ) + 1 := by
    have : (0 : ℚ) ≤ (r : ℚ) := by exact_mod_cast Nat.zero_le r
    linarith
  have hne : ((r : ℚ) + 1) ≠ 0 := ne_of_gt hpos
  rw [div_pow, div_pow, one_pow]
  field_simp

/-- **PROVED — the 2-node cofactor generator.** For the 1×2 matrix
`[a_2(1), a_5(1)]`, the null vector is `[a_5(1), −a_2(1)]`, which
when scaled by 3 gives exactly the filter `[2, −1]`. -/
theorem twoNode_cofactor_eq_filter_2_5 :
    (3 : ℚ) * aN 5 2 = 2 ∧ (3 : ℚ) * aN 2 2 = 1 := by
  unfold digammaCompressionCoeff
  refine ⟨by norm_num, by norm_num⟩

/-- **PROVED — the 2-node null vector kills its row.** -/
theorem twoNode_null_vector_kills :
    aN 5 2 * aN 2 2 - aN 2 2 * aN 5 2 = 0 := by ring

/-- **PROVED — `a_r(0) = 0` for any node.** The zeroth channel is
always zero (boundary condition). -/
theorem aN_zero_channel (r : ℕ) : digammaCompressionCoeff r 0 = 0 := by
  unfold digammaCompressionCoeff
  simp

/-- The color-channel coefficient vector `v_r : m ↦ a_r(2m)`. The
`m = 1` channel is ζ(3), `m = 2` is ζ(5), `m = 3` is ζ(7), etc. -/
def colorVector (r : ℕ) (m : ℕ) : ℚ := digammaCompressionCoeff r (2 * m)

/-- **PROVED — `colorVector r m = x_r^(2m) − y_r^(2m)`.** -/
theorem colorVector_eq_xy_pow (r m : ℕ) :
    colorVector r m = xN r ^ (2 * m) - yN r ^ (2 * m) :=
  aN_eq_xN_pow_sub_yN_pow r (2 * m)

/-- **PROVED — the (2,3,5),[−58,64,−19] filter kills color channels
1 (= ζ(3)) and 3 (= ζ(7)) while leaving channel 2 (= ζ(5)) at
coefficient `1/9`.** Restated in color-channel language. -/
theorem filter_235_color_channels :
    (-58 : ℚ) * colorVector 2 1 + 64 * colorVector 3 1
        - 19 * colorVector 5 1 = 0
    ∧ (-58 : ℚ) * colorVector 2 2 + 64 * colorVector 3 2
        - 19 * colorVector 5 2 = 1/9
    ∧ (-58 : ℚ) * colorVector 2 3 + 64 * colorVector 3 3
        - 19 * colorVector 5 3 = 0 := by
  unfold colorVector
  refine ⟨filter_235_kills_zeta3, filter_235_keeps_zeta5,
          filter_235_kills_zeta7⟩

/--
**Named record — a single color-channel coefficient vector** `v_r`.
-/
structure ColorChannelVector where
  r : ℕ
  v : ℕ → ℚ
  v_eq_colorVector : ∀ m, v m = colorVector r m

/-- The first three color vectors `v_2, v_3, v_5`. -/
def colorVector_v2 : ColorChannelVector :=
  { r := 2, v := colorVector 2, v_eq_colorVector := fun _ => rfl }
def colorVector_v3 : ColorChannelVector :=
  { r := 3, v := colorVector 3, v_eq_colorVector := fun _ => rfl }
