structure ExactTruncationFormula where
  C : ℕ → ℕ
  ternaryDyadicQuotient : ℕ → ℕ
  topLayer : ℕ → ℕ
  quotient_eq_truncation_ratio : Prop
  exact_formula : ∀ n, 56 ≤ n → ternaryDyadicQuotient n = topLayer n
  validatedTo5000 : Prop
  finiteExceptionsBelow56 : Prop

/--
**Named target — the top-layer denominator skeleton.** `Uₙ` has cost
exactly `5/6 ≈ 0.833`, worst observed `≈ 0.851`; total clearing
`Dₙ³·Uₙ` PROVED below the tiny-mode threshold.
