  rw [two_T_eq_phi_sub_one]

/-- The half-angle cascade `45°/2ⁿ` from the Atomic Measurements
construction: 45, 22.5, 11.25, 5.625, 2.8125, 1.40625, … . -/
noncomputable def halfAngleAt (n : ℕ) : ℝ := 45 / (2:ℝ)^n

/-- **PROVED — the half-angle cascade ratio.** Each level is half the
previous. -/
theorem halfAngleAt_succ (n : ℕ) :
    halfAngleAt (n + 1) = halfAngleAt n / 2 := by
  unfold halfAngleAt
  rw [pow_succ]
  ring

