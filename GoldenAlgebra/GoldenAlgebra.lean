-- === Phase XXXV: The Denominator-Clearing Threshold ===
-- The tiny eigenmode `λ₃ ≈ −0.0200151` is not enough unless the
-- denominator clearing is below `Dₙ⁴`. Threshold `−log|λ₃| ≈ 3.911`:
-- `e³|λ₃| < 1` (Dₙ³ wins) but `e⁴|λ₃| > 1` (Dₙ⁴ loses). Zudilin's
-- construction carries `Dₙ⁷`, so even perfect tiny-mode exposure loses.

/-- **PROVED.** `e³ < 21`. -/
theorem exp_three_lt_twentyone : Real.exp 3 < 21 := by
  have he1 : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have he1pos : (0 : ℝ) < Real.exp 1 := Real.exp_pos 1
  have he3 : Real.exp 3 = Real.exp 1 * (Real.exp 1 * Real.exp 1) := by
    rw [show (3 : ℝ) = 1 + (1 + 1) by norm_num,
      Real.exp_add, Real.exp_add]
  have hsq : Real.exp 1 * Real.exp 1 < 7.39 := by
    nlinarith [he1, he1pos]
  rw [he3]
  nlinarith [he1, he1pos, hsq, mul_pos he1pos he1pos]

/-- **PROVED.** `54 < e⁴`. -/
theorem exp_four_gt_fiftyfour : (54 : ℝ) < Real.exp 4 := by
  have he1 : (2.7182818283 : ℝ) < Real.exp 1 := Real.exp_one_gt_d9
  have he1pos : (0 : ℝ) < Real.exp 1 := Real.exp_pos 1
  have he4 : Real.exp 4 =
      Real.exp 1 * Real.exp 1 * (Real.exp 1 * Real.exp 1) := by
    rw [show (4 : ℝ) = (1 + 1) + (1 + 1) by norm_num,
      Real.exp_add, Real.exp_add]
  have hsq : (7.38 : ℝ) < Real.exp 1 * Real.exp 1 := by
    nlinarith [he1, he1pos]
  rw [he4]
  nlinarith [hsq, mul_pos he1pos he1pos]

/--
**PROVED — the denominator-clearing threshold.** For a tiny-mode
magnitude `μ ∈ [0.02, 0.0201]` (Zudilin's `|λ₃| ≈ 0.0200151`):
`e³·μ < 1` (so `Dₙ³` clearing wins) but `1 < e⁴·μ` (so `Dₙ⁴` clearing
already loses). The threshold is `−log|λ₃| ≈ 3.911 ∈ (3,4)`.
-/
theorem clearing_threshold {μ : ℝ}
    (hlo : 0.02 ≤ μ) (hhi : μ ≤ 0.0201) :
    Real.exp 3 * μ < 1 ∧ 1 < Real.exp 4 * μ := by
  refine ⟨?_, ?_⟩
  · nlinarith [exp_three_lt_twentyone, Real.exp_pos 3, hlo, hhi]
  · nlinarith [exp_four_gt_fiftyfour, Real.exp_pos 4, hlo, hhi]

/--
The **tiny-mode clearing threshold**: a tiny-mode magnitude in the
window `[0.02, 0.0201]` together with the PROVED facts that `Dₙ³`
clearing wins and `Dₙ⁴` clearing loses.
-/
structure TinyModeThreshold where
  tinyModeMagnitude : ℝ
  magnitude_lo : 0.02 ≤ tinyModeMagnitude
  magnitude_hi : tinyModeMagnitude ≤ 0.0201
  dn3_wins : Real.exp 3 * tinyModeMagnitude < 1
  dn4_loses : 1 < Real.exp 4 * tinyModeMagnitude

/-- **PROVED.** The tiny-mode threshold is inhabited for any magnitude
in `[0.02, 0.0201]` — the `Dₙ³`-wins / `Dₙ⁴`-loses dichotomy holds. -/
def TinyModeThreshold.of_magnitude {μ : ℝ}
    (hlo : 0.02 ≤ μ) (hhi : μ ≤ 0.0201) : TinyModeThreshold :=
  { tinyModeMagnitude := μ
    magnitude_lo := hlo
    magnitude_hi := hhi
    dn3_wins := (clearing_threshold hlo hhi).1
    dn4_loses := (clearing_threshold hlo hhi).2 }

/-- **Named target — Zudilin's denominator burden.** Zudilin's ζ(5)
construction carries a `Dₙ⁷` clearing burden — so even perfect
tiny-mode exposure (`Dₙ³`-threshold) still loses. -/
