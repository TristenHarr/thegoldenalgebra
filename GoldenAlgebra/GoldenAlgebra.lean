-- =====================================================================
-- === Tier 53 — The Golden Transfer Operator =========================
-- =====================================================================
-- The AR(1) skeleton, read as a signal-processing transfer operator:
-- bounded impulses, filtered through golden memory, produce a bounded
-- response. The arithmetic-forcing analogue of the explicit formula.

/-- **Causal convolution**: the AR(1) transfer operator.
  `(r ⋆ u)(n+1) = r·(r ⋆ u)(n) + u(n)`,  `(r ⋆ u)(0) = 0`.
A discrete one-pole filter with memory coefficient `r`. -/
noncomputable def causalConvolution (r : ℝ) (u : ℕ → ℝ) : ℕ → ℝ
  | 0 => 0
  | n + 1 => r * causalConvolution r u n + u n

/-- The causal convolution recurrence. -/
theorem causalConvolution_succ (r : ℝ) (u : ℕ → ℝ) (n : ℕ) :
    causalConvolution r u (n + 1)
      = r * causalConvolution r u n + u n := rfl

/-- **BIBO stability of the causal convolution.**
For `0 ≤ r < 1` and impulses bounded by `C`, the response is bounded by
`C / (1 − r)`. Bounded input ⇒ bounded output: the contraction is a
provably stable transfer operator. -/
theorem causalConvolution_bound
    {r C : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) (hC : 0 ≤ C)
    {u : ℕ → ℝ} (hu : ∀ n, |u n| ≤ C) :
    ∀ n, |causalConvolution r u n| ≤ C / (1 - r) := by
  have h1r : 0 < 1 - r := by linarith
  intro n
  induction n with
  | zero =>
    simp only [causalConvolution, abs_zero]
    exact div_nonneg hC h1r.le
  | succ n ih =>
    rw [causalConvolution_succ]
    have hstep : |r * causalConvolution r u n + u n|
        ≤ r * |causalConvolution r u n| + |u n| := by
      calc |r * causalConvolution r u n + u n|
          ≤ |r * causalConvolution r u n| + |u n| := abs_add _ _
        _ = r * |causalConvolution r u n| + |u n| := by
            rw [abs_mul, abs_of_nonneg hr0]
    have ha : r * |causalConvolution r u n| ≤ r * (C / (1 - r)) :=
      mul_le_mul_of_nonneg_left ih hr0
    have hkey : r * (C / (1 - r)) + C = C / (1 - r) := by
      field_simp
      ring
    have hb : |u n| ≤ C := hu n
    linarith [hstep, ha, hb, hkey]

-- =====================================================================
-- === Tier 54 — The Golden Transfer Function =========================
-- =====================================================================

/-- **The golden transfer operator**: causal convolution with golden
memory `‖λ‖`. -/
noncomputable def goldenTransfer (impulse : ℕ → ℝ) : ℕ → ℝ :=
  causalConvolution goldenMemory impulse

/-- The golden transfer recurrence. -/
theorem goldenTransfer_recurrence (impulse : ℕ → ℝ) (n : ℕ) :
    goldenTransfer impulse (n + 1)
      = goldenMemory * goldenTransfer impulse n + impulse n :=
  rfl

/-- **Golden transfer stability bound.**
Bounded impulses ⇒ the golden-filtered response is bounded by
`C / (1 − ‖λ‖)`. The golden memory kernel is a provably stable
arithmetic transfer operator. -/
theorem goldenTransfer_stability_bound
    {C : ℝ} (hC : 0 ≤ C) {impulse : ℕ → ℝ}
    (hu : ∀ n, |impulse n| ≤ C) (n : ℕ) :
    |goldenTransfer impulse n| ≤ C / (1 - goldenMemory) := by
  unfold goldenTransfer
  exact causalConvolution_bound goldenMemory_nonneg goldenMemory_lt_one hC hu n

-- =====================================================================
-- === Tier 55 — Prime Impulse Model ==================================
-- =====================================================================

/-- **Prime impulse model**: an arithmetic impulse sequence with a
uniform growth bound. The interface for the prime side of the explicit
formula, without committing to a concrete von Mangoldt encoding. -/
structure PrimeImpulseModel where
  /-- The arithmetic impulse sequence. -/
  impulse : ℕ → ℝ
  /-- A uniform growth bound on the impulses. -/
  growthBound : ∃ C, 0 ≤ C ∧ ∀ n, |impulse n| ≤ C

/-- **Every prime impulse model has a bounded golden response.**
Bridges arithmetic input to spectral stability: a uniformly bounded
prime impulse, filtered through the golden memory kernel, produces a
bounded spectral response. -/
theorem PrimeImpulseModel.golden_response_bounded
    (P : PrimeImpulseModel) :
    ∃ B, ∀ n, |goldenTransfer P.impulse n| ≤ B := by
  obtain ⟨C, hC0, hC⟩ := P.growthBound
  exact ⟨C / (1 - goldenMemory),
    fun n => goldenTransfer_stability_bound hC0 hC n⟩

-- =====================================================================
-- === Tier 56 — Explicit-Formula Innovation Bridge ===================
-- =====================================================================

/-- **Causal innovation signal**: an AR(1) signal with zero initial
condition. The signal-processing form of the explicit formula. -/
structure CausalInnovationSignal where
  /-- The memory coefficient. -/
  r : ℝ
  /-- The impulse (forcing) sequence. -/
  impulse : ℕ → ℝ
  /-- The response sequence. -/
  response : ℕ → ℝ
  /-- Zero initial condition. -/
  init : response 0 = 0
  /-- AR(1) recurrence: response = memory + impulse. -/
  recurrence : ∀ n, response (n + 1) = r * response n + impulse n

/-- A causal innovation signal's response is the causal convolution of
its impulse. -/
theorem CausalInnovationSignal.response_eq_convolution
    (S : CausalInnovationSignal) (n : ℕ) :
    S.response n = causalConvolution S.r S.impulse n := by
  induction n with
  | zero => rw [S.init]; rfl
  | succ n ih => rw [S.recurrence, ih, causalConvolution_succ]

/-- A causal innovation signal with contracting memory and bounded
impulse has a bounded response. -/
theorem CausalInnovationSignal.response_bounded
    (S : CausalInnovationSignal) (hr0 : 0 ≤ S.r) (hr1 : S.r < 1)
    {C : ℝ} (hC : 0 ≤ C) (hu : ∀ n, |S.impulse n| ≤ C) (n : ℕ) :
    |S.response n| ≤ C / (1 - S.r) := by
  rw [S.response_eq_convolution]
  exact causalConvolution_bound hr0 hr1 hC hu n

/-- **Explicit-formula innovation bridge**: a causal innovation signal
whose memory coefficient is the golden `‖λ‖`. -/
structure ExplicitFormulaInnovationBridge where
  /-- The underlying AR(1) signal. -/
  signal : CausalInnovationSignal
  /-- The memory coefficient is golden. -/
  golden : signal.r = goldenMemory

/-- **The explicit-formula response is stable.**
If the prime impulses are uniformly bounded, the golden explicit-formula
response is bounded. -/
theorem ExplicitFormulaInnovationBridge.response_is_stable
    (E : ExplicitFormulaInnovationBridge)
    (hbound : ∃ C, 0 ≤ C ∧ ∀ n, |E.signal.impulse n| ≤ C) :
    ∃ B, ∀ n, |E.signal.response n| ≤ B := by
  obtain ⟨C, hC0, hC⟩ := hbound
  refine ⟨C / (1 - E.signal.r), fun n => ?_⟩
  apply E.signal.response_bounded
  · rw [E.golden]; exact goldenMemory_nonneg
  · rw [E.golden]; exact goldenMemory_lt_one
  · exact hC0
  · exact hC

-- =====================================================================
-- === Tier 57 — Mirror-Compatible Signals ============================
-- =====================================================================

/-- A complex function is **critical-mirror compatible** when reflecting
its argument conjugates its value:
  `F(criticalReflection s) = conj(F s)`. -/
def CriticalMirrorCompatible (F : ℂ → ℂ) : Prop :=
  ∀ s, F (criticalReflection s) = (starRingEnd ℂ) (F s)

/-- **Mirror compatibility forces real values on the critical line.**
If `F` is critical-mirror compatible and `s` is a critical-line point
(`criticalReflection s = s`), then `F s` is real. -/
theorem criticalLine_values_real
    {F : ℂ → ℂ} (hF : CriticalMirrorCompatible F)
    {s : ℂ} (hs : criticalReflection s = s) :
    (F s).im = 0 := by
  have h := hF s
  rw [hs] at h
  have him : (F s).im = -(F s).im := by
    have h2 := congrArg Complex.im h
    rwa [Complex.conj_im] at h2
  linarith

