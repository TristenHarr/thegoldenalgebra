    (1 : ℝ) / Real.exp 1 > 0.367
    ∧ (1 : ℝ) / Real.exp 1 < 0.369 := by
  have he_lo : Real.exp 1 > 2.7182818283 := Real.exp_one_gt_d9
  have he_hi : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  refine ⟨?_, ?_⟩
  · rw [gt_iff_lt, lt_div_iff₀ (by linarith)]; nlinarith
  · rw [div_lt_iff₀ (by linarith)]; nlinarith

/-- **PROVED — `2/√π ∈ (1.128, 1.13)`** (1/Γ(3/2) residue). -/
