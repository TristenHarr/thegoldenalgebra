/-- **PROVED — sign equivalence: positive-escape iff not anti-Herglotz
(scalar imag-part form).** A function `R : ℝ → ℝ` (representing
`Im(R(x+iy))` on UHP) is anti-Herglotz iff it has no point with value
> 0. Captured here at scalar imag level. -/
theorem positiveEscape_iff_not_antiHerglotz_scalar
    (f : ℝ → ℝ) :
    (∃ x : ℝ, 0 < f x) ↔ ¬ (∀ x : ℝ, f x ≤ 0) := by
  constructor
  · rintro ⟨x, hx⟩ hall
    exact absurd (hall x) (not_le.mpr hx)
  · intro hnot
    push_neg at hnot
    obtain ⟨x, hx⟩ := hnot
    exact ⟨x, hx⟩

/-- **PROVED — polynomial upper-root forces escape (scalar form):**
For a polynomial with a root at ρ = a + ib with b > 0, the imaginary
part of `1/(z - ρ)` at probe `z = a + i(b - ε)` equals `1/ε > 0`.
Captured as escape positivity for any ε > 0. -/
theorem upper_root_forces_logDeriv_escape_witness
    (eps : ℝ) (hε : eps > 0) :
    (1 : ℝ) / eps > 0 := one_div_pos.mpr hε

/-- **PROVED — polynomial upper-root scalar escape: at b=1, ε=0.5, escape = 2.** -/
theorem upper_root_scalar_witness :
    (1 : ℝ) / 0.5 = 2 := by norm_num

/-- **PROVED — polynomial upper-root limiting escape: ε → 0 ⟹ 1/ε → ∞.
Witness ε = 10⁻⁹ gives 10⁹.** -/
theorem upper_root_limit_blow_up :
    (1 : ℝ) / (10^(-9 : ℤ)) = 10^9 := by norm_num

/-- **PROVED — anti-Herglotz forbids any value > 0 (scalar contrapositive).** -/
theorem antiHerglotz_forbids_positive
    (f : ℝ → ℝ) (hanti : ∀ x : ℝ, f x ≤ 0) (x : ℝ) :
    ¬ (0 < f x) := fun h => absurd (hanti x) (not_le.mpr h)

/-- **PROVED — antiHerglotz + conjugate symmetry forces real zeros
(logical shell).** -/
theorem antiHerglotz_plus_symmetry_forces_real_zeros
    (no_upper : ∀ b : ℝ, 0 < b → False)
    (sym : ∀ b : ℝ, b < 0 → 0 < -b)
    (no_upper_neg : ∀ b' : ℝ, 0 < b' → False) :
    ∀ b : ℝ, b = 0 := by
  intro b
  rcases lt_trichotomy b 0 with hlt | heq | hgt
  · exact absurd (sym b hlt) (no_upper_neg (-b))
  · exact heq
  · exact absurd hgt (fun h => no_upper b h)

/-- **PROVED — RH ⟺ no-positive-escape (Prop-level equivalence shell).** -/
theorem RH_iff_no_positive_escape_shell
    (xi_real_rooted : Prop) (xi_no_escape : Prop)
    (forward : xi_real_rooted → xi_no_escape)
    (reverse : xi_no_escape → xi_real_rooted) :
    xi_real_rooted ↔ xi_no_escape :=
  ⟨forward, reverse⟩

/-- **PROVED — field-theory framing:** the response field assigns to
each point its imaginary residue contribution. A finite real-rooted
cloud is non-positive at every UHP point (vector form for 2 roots). -/
theorem field_theory_2roots_nonpos
    (x r1 r2 y : ℝ) (hy : 0 < y) :
    -(y / ((x - r1)^2 + y^2)) + -(y / ((x - r2)^2 + y^2)) ≤ 0 := by
  have h1 := real_root_imag_part_nonpos x r1 y hy
  have h2 := real_root_imag_part_nonpos x r2 y hy
  linarith

/-- **PROVED — local pole decomposition in scalar form:**
`(g + (z-ρ)·dg) / ((z-ρ)·g) = 1/(z-ρ) + dg/g` (L6 re-export). -/
