theorem council_C022_momentum_sum :
    ∑' (n : ℕ), (n : ℂ) * lambdaG1 ^ n = lambdaG1 / (1 - lambdaG1) ^ 2 :=
  law_of_harmonic_momentum_sum

/-- Council C023 — Kinetic sum.
`Σ n² · λⁿ = λ(1+λ) / (1−λ)³`. Status: **alias** over
