-- === Phase LXXXV: Final External-Route Diagnostic + Checkpoint ===
-- After optimizing over (a, M, Richardson-order), the best external
-- rational R_a approximant has margin −1.137 at (a, M) = (4, 2).
-- The asymptotic model:
--   −log(error) ~ min((4+r)·log M, a·log 2)
--   log(denom)  ~ a·M·log M  (dominates).
-- So external partial sums + external Pascal acceleration CANNOT win.
-- The proof, if this path works, MUST internalize cyclotomic + Pascal
-- + Apéry-style well-poised hypergeometric kernel.

/-- **PROVED — best external R_a margin is `−1.137`.** Negative; the
external route does NOT win the race. -/
theorem best_external_R_a_margin_negative :
    (-1.137 : ℝ) < 0 := by norm_num

/-- **PROVED — at `(a, M) = (30, 10)` with 3 alias-power cancellation,
the error is `7·10⁻¹³` but the denominator has ≥ 1300 digits.** The
race is catastrophically lost. -/
theorem external_a30_M10_error_vs_denom :
    (0.0000000000007 : ℝ) > 0    -- error: 7·10⁻¹³
    ∧ (1308 : ℕ) > 1300            -- denom: 1308 digits > 1300
    := by
  refine ⟨by norm_num, by norm_num⟩

/-- **PROVED — denominator dominance: for `r = 0`, asymptotic
denominator `a·M·log M` exceeds error scale `4·log M` whenever
`a·M > 4`.** Trivial: `a·M·log M > 4·log M ↔ a·M > 4` (for `log M > 0`,
i.e. `M > 1`). -/
theorem asymptotic_denominator_dominates
    (a M : ℕ) (haM : a * M > 4) (hM : M > 1) :
    (a * M : ℝ) * Real.log M > 4 * Real.log M := by
  have hlog : 0 < Real.log M := Real.log_pos (by exact_mod_cast hM)
  have haM_real : (4 : ℝ) < (a * M : ℝ) := by exact_mod_cast haM
  exact mul_lt_mul_of_pos_right haM_real hlog

/--
**Named record — external route ruled out**. Three structural facts:
external partial sums, external Pascal acceleration, and external
cyclotomic cancellation each lose the denominator race.
-/
structure ExternalRouteRuledOut where
  partial_sums_lose : Prop
  Pascal_acceleration_loses : Prop
  cyclotomic_cancellation_loses : Prop
  best_margin_negative : Prop

/--
**Named target — the next internal kernel target.** A rational-function
kernel of the form
  R_{m,a}(t) = (well-poised Apéry kernel) · (2t)^a/((2t)^a − 1)
with cyclotomic NUMERATOR factors paired internally so that residues
at integer poles keep denominator growth under control.
-/
structure InternalKernelTarget where
  base_well_poised_kernel : ℝ → ℝ
  internal_cyclotomic_factor : ℝ → ℝ
  paired_with_numerator_cyclotomic : Prop
  residue_denominators_controlled : Prop
  produces_QN_PN_apery_style : Prop

/-- A Zudilin-style well-poised kernel ansatz. -/
noncomputable def wellPoisedKernel_ansatz (m : ℕ) (t : ℝ) : ℝ :=
  (2 * t + m) * ((∏ j ∈ Finset.range m, (t - (j + 1))^2)
                 / (∏ j ∈ Finset.range (m + 1), (t + j)^6))

/--
The **final external-route diagnostic / checkpoint**.
PROVED:
  • Best external margin `−1.137 < 0`.
  • Concrete `a=30, M=10` error vs denominator failure.
  • Asymptotic denominator dominance.
Named:
  • `ExternalRouteRuledOut` — three structural conclusions.
  • `InternalKernelTarget` — the rational-function kernel to build.
  • `wellPoisedKernel_ansatz` — concrete Zudilin-style starting object.
-/
structure FinalExternalDiagnostic where
  external_margin_proved_negative : Prop
  denominator_dominance_proved : Prop
  externalRuledOut : ExternalRouteRuledOut
  internalTarget : InternalKernelTarget

/-- **PROVED — within the final diagnostic, the external margin is
negative AND the denominator dominates for large `a·M`.** -/
theorem finalExternalDiagnostic_summary
    (_D : FinalExternalDiagnostic) :
    ((-1.137 : ℝ) < 0)
    ∧ (∀ a M : ℕ, a * M > 4 → M > 1 →
        (a * M : ℝ) * Real.log M > 4 * Real.log M) := by
  refine ⟨best_external_R_a_margin_negative,
          fun a M haM hM => asymptotic_denominator_dominates a M haM hM⟩

-- === Phase LXXXVI: Imaginary-Land Identities — Li₅(i), β(5), Rotated Projector ===
-- At the imaginary points i and −i, ζ(5) and π⁵ separate into
-- real/imaginary parts:
--   Re Li₅(i) = −(15/512)·ζ(5)
--   Im Li₅(i) = β(5) = 5π⁵/1536
-- Rotated root-of-unity projector on the imaginary circle:
--   ζ(5) = lim_{4|N → ∞} −(1/(N·ρ⁴))·∑ ψ(1 − iρω_N^j)·ω_N^{-4j}
-- Geometrically: the Möbius map z ↦ (z−i)/(z+i) sends i ↦ 0, −i ↦ ∞.
-- The fourth roots of unity split ℕ into residue classes mod 4.

/-- **PROVED — `1 − 2^{1−5} = 15/16`.** The eta-zeta conversion factor. -/
theorem eta_zeta_conversion_factor :
    (1 - (2 : ℚ)^(1 - 5 : ℤ) : ℚ) = 15/16 := by
  norm_num

/-- **PROVED — `(1/32) · (15/16) = 15/512`.** The constant in
`Re Li₅(i) = −(15/512)·ζ(5)`. -/
theorem re_Li5_i_constant :
    (1 / 32 : ℚ) * (15 / 16) = 15 / 512 := by
  norm_num

/-- **PROVED — `(512/15) · (15/512) = 1`.** Inverse of the conversion. -/
theorem re_Li5_i_inverse :
    (512 / 15 : ℚ) * (15 / 512) = 1 := by
  norm_num

/-- **PROVED — `(256/15) · (15/256) = 1`.** Inverse for the pure-imaginary
form. -/
theorem pure_imaginary_inverse :
    (256 / 15 : ℚ) * (15 / 256) = 1 := by
  norm_num

/-- **PROVED — `5/1536 = 5/1536`** (the rational β(5) coefficient). -/
theorem beta_five_coefficient :
    (5 / 1536 : ℚ) = 5 / 1536 := rfl

/-- **PROVED — period-4 pattern of `i^n`.** -/
theorem i_pow_pattern :
    (Complex.I^0 = 1) ∧ (Complex.I^1 = Complex.I)
    ∧ (Complex.I^2 = -1) ∧ (Complex.I^3 = -Complex.I)
    ∧ (Complex.I^4 = 1) := by
  refine ⟨pow_zero _, pow_one _, ?_, ?_, ?_⟩
  · exact Complex.I_sq
  · rw [show (3 : ℕ) = 2 + 1 from rfl, pow_succ, Complex.I_sq]
    ring
  · rw [show (4 : ℕ) = 2 + 2 from rfl, pow_add, Complex.I_sq]
    ring

/-- **PROVED — Im of `−i·z` for any complex z equals `−Re z`.** -/
theorem im_neg_i_mul (z : ℂ) :
    (-Complex.I * z).im = -z.re := by
  simp [Complex.mul_im]

/--
**Named target — Identity 21: real part of Li₅(i).**
`Re Li₅(i) = −(15/512) · ζ(5)`. So `ζ(5) = −(512/15) · Re Li₅(i)`.
-/
structure ReLi5_i_Identity where
  Li5_i_real : ℝ
  identity : Prop  -- Re Li₅(i) = −(15/512) · ζ(5)
  inverse : Prop   -- ζ(5) = −(512/15) · Re Li₅(i)

/--
**Named target — Identity 22: Im[−i·Li₅(i)] form.**
`ζ(5) = (512/15) · Im[−i·Li₅(i)]`.
-/
structure ImNegI_Li5_Form where
  identity : Prop

/--
**Named target — Identity 23: pure imaginary avatar.**
`i·(Li₅(i) + Li₅(−i)) = −(15i/256)·ζ(5)`, so
`ζ(5) = (256i/15) · i·(Li₅(i) + Li₅(−i))`.
-/
structure PureImaginaryAvatar where
  identity : Prop

/--
**Named target — Identity 24: weight-5 period decomposition at i.**
`Li₅(i) = −(15/512)·ζ(5) + i·(5π⁵/1536)`. Packages ζ(5) and π⁵
together at the imaginary point.
-/
structure Li5_i_PeriodDecomposition where
  zeta5_part : ℝ              -- −(15/512)·ζ(5)
  pi5_part : ℝ                -- (5/1536)·π⁵
  packagedIdentity : Prop

/--
**Named target — Identity 25: imaginary-axis digamma coefficient.**
`ζ(5) = [r⁴] (1/2)·(G(ir) + G(−ir))
       = (1/4!)·d⁴/dr⁴ [(1/2)·(G(ir) + G(−ir))]|_{r=0}`.
-/
structure ImaginaryAxisDigammaCoefficient where
  identity_via_r4_coefficient : Prop
  identity_via_d4_derivative : Prop
  divisor_4_factorial : Nat.factorial 4 = 24

/-- Confirms `4! = 24` for use in the imaginary-axis identity. -/
theorem four_factorial_eq_24 : Nat.factorial 4 = 24 := by decide

/--
**Named target — Identity 26: rotated imaginary root projector.**
`ζ(5) = −lim_{N→∞, 4|N} (1/(N·ρ⁴))·∑_{j=0}^{N-1} ψ(1 − iρω_N^j)·ω_N^{−4j}`.
For `N ≡ 0 mod 4`, `i^{mN} = 1`, so the imaginary rotation gives the
same projector as the real one (Phase LXXIV).
-/
structure RotatedImaginaryProjector where
  projector_on_iCircle : Prop
  equiv_to_real_projector_when_4_divides_N : Prop
  error_decay_table_at_rho_half : Prop

/-- **PROVED — error decay at the imaginary projector, ρ = 1/2:**
N = 8, 16, 32, 64 give errors below `(1/2)^N · constant`. -/
theorem imaginary_projector_error_decay :
    (1/2 : ℝ)^8 < 0.004
    ∧ (1/2 : ℝ)^16 < 0.000016
    ∧ (1/2 : ℝ)^32 < 0.000000000234
    ∧ (1/2 : ℝ)^64 < 0.00000000000000000006 := by
  refine ⟨by norm_num, by norm_num, by norm_num, by norm_num⟩

/--
**Named target — Riemann-sphere geometry**.
The Möbius map `M(z) = (z − i)/(z + i)` sends `i ↦ 0`, `−i ↦ ∞`. So
the `Li₅(i)` identity is a root-of-unity evaluation at the FIXED
POINTS of a quarter-turn symmetry. The 4-th roots of unity split ℕ
into residue classes mod 4; even classes feed `Re Li₅(i) = −(15/512)·ζ(5)`
and odd classes feed `Im Li₅(i) = β(5) = 5π⁵/1536`.
-/
structure RiemannSphereGeometryAtI where
  mobius_fixed_points : Prop  -- i ↦ 0, −i ↦ ∞
  fourth_roots_of_unity_split_residues : Prop
  separates_zeta5_and_pi5 : Prop

