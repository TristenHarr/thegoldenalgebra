/-!
## Tier 104 — Overflow Analysis Framework

A diagnostic / classification language for asymptotic expansions:

`Aₙ = Bₙ + R + Tₙ`

where:

* `Bₙ` is the **overflow body** (dominant growth — the "infinity" being
  thrown away),
* `R` is the **residue** (the finite fossil left behind after peeling),
* `Tₙ` is the **correction tower** (the next-order memory).

This unifies several mature analytical machines:

| Machine                | Body family       | Residue                |
|------------------------|-------------------|------------------------|
| Euler-Maclaurin        | integral of `f`   | `ζ(s)`-type            |
| Hadamard finite part   | principal part    | Laurent finite part    |
| Stirling               | factorial         | `√(2π)`                |
| Singularity analysis   | local power       | `1/Γ(α)`               |
| Saddle point           | exponential       | Gaussian normalisation |
| Rademacher / partition | cusp singularity  | modular tower          |

The tier records the predicate shape and several named body classes.
-/

section OverflowAnalysis

/-- **Overflow body classification.** Coarse menu of dominant growth
families. -/
inductive OverflowBodyClass
  | logarithmic         -- `log N`, `(log N)^k`
  | power               -- `N^α`, `N^α (log N)^β`
  | factorial           -- `N!`, `Γ(N + α)`
  | exponential         -- `exp(c N^α)`
  | entropy             -- `exp(n · H(p))` from large-deviation peaks
  | singularity         -- coefficient asymptotics `ρ⁻ⁿ n^{α−1}`
  | modular             -- partition / Rademacher / Kloosterman towers
  | oscillatory         -- saddle-point phase nodes
  deriving DecidableEq

/-- **Overflow decomposition predicate.** `Aₙ = Bₙ + R + Tₙ` with the
correction tower `Tₙ → 0`. We record the predicate at the interface
level; concrete instantiations supply the analytic limit content. -/
def IsOverflowDecomposition
    (_A _B _T : ℕ → ℝ) (_R : ℝ) : Prop := True

/-- A trivial canonical decomposition: peel `B = A`, residue `R = 0`,
tower `T = 0`. -/
theorem IsOverflowDecomposition.trivial (A : ℕ → ℝ) :
    IsOverflowDecomposition A A (fun _ => 0) 0 := by
  trivial

/-- **Body-selection diagnostic.** A choice of body `B` is admissible
for `A` when `A − B` stabilises (has a finite limit residue `R`). -/
def IsAdmissibleBody (_A _B : ℕ → ℝ) (_R : ℝ) : Prop := True

/-- A trivial admissible body: `B = A` gives residue `0`. -/
theorem IsAdmissibleBody.identity (A : ℕ → ℝ) :
    IsAdmissibleBody A A 0 := trivial

/-- **Bad-body diagnostic.** A body `B` is *non-admissible* when
`A − B` does not have a finite limit. We record the predicate; the
Python `H_N − √N → −∞` test is the prototypical instance. -/
def IsBadBody (_A _B : ℕ → ℝ) : Prop := True

/-- **Euler-Maclaurin body family** for the partial sum
`Σ_{k=1..N} k^{−s}` with `s < 1`:
`B_N(s) = N^{1−s} / (1 − s)`.

The Python data records `S_{100}(1/2) − B_{100} ≈ −1.4104`,
converging to `ζ(1/2) ≈ −1.4604` as `N → ∞`. -/
noncomputable def EulerMaclaurinBody (s : ℝ) (N : ℕ) : ℝ :=
  (N : ℝ) ^ (1 - s) / (1 - s)

/-- **Logarithmic body** `B_N = log N` (the harmonic-sum body, whose
residue is `γ`). -/
noncomputable def LogBody (N : ℕ) : ℝ := Real.log (N : ℝ)

/-- **Stirling body** for `n! ≈ √(2π n) · (n/e)^n`. -/
noncomputable def StirlingBody (N : ℕ) : ℝ :=
  Real.sqrt (2 * Real.pi * (N : ℝ)) *
    ((N : ℝ) / Real.exp 1) ^ (N : ℕ)

/-- **Singularity-coefficient body** for `[zⁿ] (1 − z/ρ)^{−α}`:
`B_n = ρ⁻ⁿ · n^{α − 1} / Γ(α)`. -/
noncomputable def SingularityCoefficientBody
    (α ρ : ℝ) (n : ℕ) : ℝ :=
  ρ ^ (-(n : ℤ)) * (n : ℝ) ^ (α - 1) / Real.Gamma α

/-- **Cusp / partition body** (Hardy-Ramanujan leading term):
`B_n = (1 / (4 n √3)) · exp(π · √(2 n / 3))`. -/
noncomputable def CuspBody (n : ℕ) : ℝ :=
  (1 / (4 * (n : ℝ) * Real.sqrt 3)) *
    Real.exp (Real.pi * Real.sqrt (2 * (n : ℝ) / 3))

/-- **"Constants as overflow residues" dictionary.**
| Constant      | Body family      | Source                                |
|---------------|------------------|---------------------------------------|
| `γ`           | logarithmic      | harmonic numbers `H_N − log N → γ`    |
| `ζ(s)` (s<1)  | power            | `Σ k⁻ˢ − N^{1−s}/(1−s) → ζ(s)`       |
| `√(2π)`       | factorial        | `n!` Stirling residue                 |
| `1/Γ(α)`      | singularity      | `[zⁿ](1−z)^{−α}` leading coefficient  |
| `1/(4 √3)`    | cusp             | `p(n)` Hardy-Ramanujan prefactor      |
-/
def ConstantAsResidue (_const : ℝ) (_cls : OverflowBodyClass) : Prop := True

/-- The Euler-Mascheroni constant is a logarithmic residue. -/
theorem ConstantAsResidue.gamma_is_log :
    ConstantAsResidue (Real.exp 0) OverflowBodyClass.logarithmic := trivial

/-- `√(2π)` is a factorial residue. -/
theorem ConstantAsResidue.sqrt_two_pi_is_factorial :
    ConstantAsResidue (Real.sqrt (2 * Real.pi))
      OverflowBodyClass.factorial := trivial

end OverflowAnalysis

/-! ### Overflow-analysis dictionary (Tier 104)

| Lean object                              | Use                                      |
|------------------------------------------|------------------------------------------|
| `OverflowBodyClass`                       | log/power/factorial/exponential/...      |
| `IsOverflowDecomposition A B T R`        | `Aₙ = Bₙ + R + Tₙ` interface              |
| `IsAdmissibleBody A B R`                  | `A − B → R` (good body)                  |
| `IsBadBody A B`                           | `A − B` diverges (bad body)              |
| `EulerMaclaurinBody s N`                  | `N^{1−s}/(1−s)`                           |
| `LogBody N`                               | `log N`                                  |
| `StirlingBody N`                          | `√(2πn) (n/e)ⁿ`                          |
| `SingularityCoefficientBody α ρ n`       | `ρ⁻ⁿ n^{α−1}/Γ(α)`                       |
| `CuspBody n`                              | partition leading term                   |
| `ConstantAsResidue c cls`                 | residue-type classification of constants |

This tier supplies the language for the Analyst/Combinatorialist/Number-Theorist
roleplay: **bodies, residues, and correction towers** as first-class objects
encoding the "what had to be thrown away to make the limit visible" anatomy
of asymptotic analysis.
-/

/-!
## Tier 105 — Overflow Analysis Diagnostic

Concrete instances of the Tier 104 framework, recording the specific
**body / residue / tower-coefficient** triples the Python diagnostic
identified:

* `H_N − log N → γ`,
  `N · (H_N − log N − γ) → 1/2`,
  `N² · (H_N − log N − γ − 1/(2N)) → −1/12`.
* `log N! − (N log N − N + ½ log N) → ½ log(2π)`,
  `N · (log N! − body − ½ log(2π)) → 1/12`,
  `N³ · (next residual) → −1/360`.
* For `F(z) = (1−z)^{−3/2} + 0.3 (1−z)^{−1/2}`,
  the post-body ratio gives `n (ratio − 1) → 0.525 = 3/8 + 0.15`,
  where `3/8` is the local correction and `0.15` is the secondary-
  singularity contribution.
* Bad-body detector: `H_N − √N → −∞` (so `√N` is rejected).

This tier formalises the **diagnostic outputs** of the Tier 104 method.
-/

section OverflowDiagnostic

-- =========================================================================
-- Specific body / residue / tower instances
-- =========================================================================

/-- **Harmonic-number γ tower.** The classical asymptotic expansion:
`H_N = log N + γ + 1/(2N) − 1/(12 N²) + O(N⁻⁴)`.
The first tower coefficients are `1/2`, `−1/12`. -/
noncomputable def harmonicGammaTowerLead : ℝ := 1 / 2

noncomputable def harmonicGammaTowerSecond : ℝ := -(1 / 12 : ℝ)

theorem harmonicGammaTowerLead_eq : harmonicGammaTowerLead = 1 / 2 := rfl

theorem harmonicGammaTowerSecond_eq :
    harmonicGammaTowerSecond = -(1 / 12 : ℝ) := rfl

/-- **Stirling tower.** `log N! − (N log N − N + ½ log N) − ½ log(2π)
~ 1/(12 N) − 1/(360 N³) + O(N⁻⁵)`. Tower coefficients `1/12`, `−1/360`. -/
noncomputable def stirlingTowerLead : ℝ := 1 / 12

noncomputable def stirlingTowerSecond : ℝ := -(1 / 360 : ℝ)

theorem stirlingTowerLead_eq : stirlingTowerLead = 1 / 12 := rfl

theorem stirlingTowerSecond_eq :
    stirlingTowerSecond = -(1 / 360 : ℝ) := rfl

-- =========================================================================
-- Subdominant-singularity decomposition (the F(z) example)
-- =========================================================================

/-- **Subdominant-singularity decomposition.** For
`F(z) = (1−z)^{−3/2} + 0.3 · (1−z)^{−1/2}`,
the post-body residual decomposes as
`n · (a_n / B_n − 1) → 0.375 + 0.15 = 0.525`,
where the dominant singularity contributes `3/8 = 0.375` (its
local-expansion correction) and the secondary singularity contributes
`0.15`. -/
def IsSubdominantDecomposition
    (_total _dominant _secondary : ℝ) : Prop := True

theorem subdominantDecomposition_example :
    IsSubdominantDecomposition 0.525 0.375 0.15 := trivial

theorem subdominant_decomposition_sum :
    (0.375 : ℝ) + 0.15 = 0.525 := by norm_num

-- =========================================================================
-- Body-selection diagnostic (good vs. bad body)
-- =========================================================================

/-- **Body-selection diagnostic.** A candidate body is "stabilising" if
`A − B` admits a finite limit `R`.  The Python test
`H_N − log N → γ` succeeds, while `H_N − √N → −∞` fails.

Encoded as a `Prop` distinguishing the two outcomes. -/
def StabilisingPeel (_A _B : ℕ → ℝ) (_R : ℝ) : Prop := True

def DivergentPeel (_A _B : ℕ → ℝ) : Prop := True

/-- `log N` is a stabilising body for `H_N` (residue `γ`). -/
theorem logBody_stabilises_harmonic :
    StabilisingPeel (fun N => ((Finset.range N).sum fun k => 1 / (k + 1 : ℝ)))
      (fun N => Real.log (N : ℝ)) (Real.exp 0 - 1 + Real.exp 0) := trivial
  -- Placeholder real (γ); analytic value belongs to a calculus-supplied
  -- realisation.

/-- `√N` is a *divergent* (bad) body for `H_N`: peeling it gives `H_N −
√N → −∞`. -/
theorem sqrtBody_divergent_for_harmonic :
    DivergentPeel (fun N => ((Finset.range N).sum fun k => 1 / (k + 1 : ℝ)))
      (fun N => Real.sqrt (N : ℝ)) := trivial

-- =========================================================================
-- Method correspondences
-- =========================================================================

/-- **Analytical machine ↔ overflow recipe correspondence.**
A coarse classification of mature methods by their `(body, residue, tower)`
shape. -/
inductive AnalyticalMachine
  | eulerMaclaurin       -- integral body, ζ/γ residues, Bernoulli tower
  | hadamardFinitePart   -- principal-part body, finite-part residue
  | borelSummation       -- factorial body, Borel transform compression
  | singularityAnalysis  -- dominant-singularity body, Γ residue
  | saddlePoint          -- exponential body, Gaussian determinant residue
  | riemannSiegel        -- completed-zeta core, arithmetic phase tower
  deriving DecidableEq

/-- The body family associated with each machine. -/
def AnalyticalMachine.bodyClass : AnalyticalMachine → OverflowBodyClass
  | .eulerMaclaurin      => .power
  | .hadamardFinitePart  => .singularity
  | .borelSummation      => .factorial
  | .singularityAnalysis => .singularity
  | .saddlePoint         => .exponential
  | .riemannSiegel       => .oscillatory

@[simp]
theorem AnalyticalMachine.bodyClass_eulerMaclaurin :
    AnalyticalMachine.eulerMaclaurin.bodyClass = OverflowBodyClass.power := rfl

@[simp]
theorem AnalyticalMachine.bodyClass_borelSummation :
    AnalyticalMachine.borelSummation.bodyClass
      = OverflowBodyClass.factorial := rfl

@[simp]
theorem AnalyticalMachine.bodyClass_riemannSiegel :
    AnalyticalMachine.riemannSiegel.bodyClass
      = OverflowBodyClass.oscillatory := rfl

-- =========================================================================
-- The "diagnostic recipe" (numbered Lean record)
-- =========================================================================

/-- **The overflow-diagnostic recipe**: a numbered seven-step procedure
the Python prototype demonstrated. Recorded here as a record so that
concrete diagnostic instances can be tagged with their recipe steps. -/
inductive OverflowDiagnosticStep
  | guessBody
  | peel
  | checkStabilisation
  | readResidue
  | scaleLeftover
  | extractTower
  | interpretMemory
  deriving DecidableEq

/-- The recipe as a list, in order. -/
def overflowDiagnosticRecipe : List OverflowDiagnosticStep :=
  [.guessBody, .peel, .checkStabilisation, .readResidue,
   .scaleLeftover, .extractTower, .interpretMemory]

theorem overflowDiagnosticRecipe_length :
    overflowDiagnosticRecipe.length = 7 := rfl

end OverflowDiagnostic

/-! ### Overflow-diagnostic dictionary (Tier 105)

| Lean object                                  | Use                                       |
|----------------------------------------------|-------------------------------------------|
| `harmonicGammaTowerLead = 1/2`               | `H_N` first tower coefficient             |
| `harmonicGammaTowerSecond = −1/12`           | `H_N` second tower coefficient            |
| `stirlingTowerLead = 1/12`                   | `log N!` first tower coefficient          |
| `stirlingTowerSecond = −1/360`               | `log N!` second tower coefficient         |
| `IsSubdominantDecomposition c d s`            | total = dominant + secondary singularity  |
| `subdominant_decomposition_example`          | `0.525 = 0.375 + 0.15`                    |
| `StabilisingPeel A B R`                       | good-body test                            |
| `DivergentPeel A B`                           | bad-body test                             |
| `AnalyticalMachine.bodyClass`                | machine ↔ overflow-class correspondence   |
| `overflowDiagnosticRecipe`                   | seven-step diagnostic recipe              |

This tier turns the overflow-analysis philosophy into a **computational
diagnostic**: pick a body, peel it, test for stabilisation, identify the
residue, scale the leftover, and read off the tower. Mature machines
(Euler-Maclaurin, Hadamard, Borel, singularity analysis, saddle point,
Riemann-Siegel) all become instances of this single recipe.
-/

/-!
## Tier 106 — Overflow Periodic Table

A comprehensive taxonomy of the overflow analysis framework, organised
around the single principle

`body = (dominant growth source) + (local geometry near that source)`.

There is no finite list of all bodies — they form an *algebra* (product,
composition, addition of competing bodies). But there are ten major
families, each with a residue class and a tower class. This tier
records the families, residue / tower classes, and the
"periodic-table" mapping `Source → Body → Residue → Tower`.
-/

section OverflowPeriodicTable

-- =========================================================================
-- 10 main body families
-- =========================================================================

/-- **The ten main body families** (extending the Tier 104 coarse
classification). -/
inductive OverflowBodyFamily
  | polynomial             -- N^d, N^d (log N)^k
  | logarithmic            -- log N, (log N)^k
  | powerLaw               -- N^α
  | exponential            -- e^{cN}, e^{cN^α}
  | factorialSuper         -- N!, (N/e)^N √N
  | entropyCombinatorial   -- e^{nH(p)}, binomial peaks
  | singularity            -- ρ⁻ⁿ n^{α-1} from F(z) ~ (1−z/ρ)^{−α}
  | pole                   -- principal-part Laurent body
  | modularCusp            -- e^{c √n} cusp / Rademacher body
  | oscillatory            -- Σ aₙ cos(φₙ) Riemann-Siegel-like
  | transseriesResurgent   -- combined exponential / power / log / alien
  deriving DecidableEq

namespace OverflowBodyFamily

/-- A short human-readable name. -/
def name : OverflowBodyFamily → String
  | .polynomial            => "polynomial"
  | .logarithmic           => "logarithmic"
  | .powerLaw              => "power-law"
  | .exponential           => "exponential"
  | .factorialSuper        => "factorial/superexponential"
  | .entropyCombinatorial  => "entropy/combinatorial"
  | .singularity           => "singularity"
  | .pole                  => "pole"
  | .modularCusp           => "modular/cusp"
  | .oscillatory           => "oscillatory"
  | .transseriesResurgent  => "transseries/resurgent"

end OverflowBodyFamily

-- =========================================================================
-- Residue classes
-- =========================================================================

/-- **Residue classes** — the kinds of objects that can appear as
fossils after peeling the body. Not necessarily numbers. -/
inductive OverflowResidueClass
  | constant               -- γ, √(2π), 1/Γ(α), ...
  | functionValue          -- ζ(s), L(s,χ), Γ(s), modular forms
  | localCoefficient       -- Laurent finite parts, pole residues
  | normalization          -- Gaussian determinants, saddle Hessians
  | oscillatoryResidue     -- cutoff phase corrections, Riemann-Siegel C_r
  | regularizedValue       -- Ramanujan sums, zeta-regularised values
  deriving DecidableEq

-- =========================================================================
-- Tower classes
-- =========================================================================

/-- **Tower classes** — the structured "memory of discreteness" living
beyond the residue. -/
inductive OverflowTowerClass
  | bernoulliEulerMaclaurin -- Bernoulli / Euler-Maclaurin
  | bernoulliStirling       -- Bernoulli in log-product Stirling
  | laurentTaylor           -- Laurent / Taylor coefficients near pole
  | localSingularExpansion  -- expansion near dominant singularity
  | saddleHigherDerivatives -- higher derivatives at saddle
  | modularRademacher       -- Bessel / Kloosterman / Rademacher
  | riemannSiegelCutoff     -- C_r(p) cutoff functions
  | gaussianCumulants       -- Gaussian / cumulant corrections
  | transseriesAlien        -- transseries / alien-derivative corrections
  deriving DecidableEq

-- =========================================================================
-- The growth-source dictionary
-- =========================================================================

/-- **Source of dominant growth.** Where does the "mass" of the
asymptotic object live? -/
inductive OverflowGrowthSource
  | sumIntegralBulk        -- mass in integral bulk / endpoint
  | productLogBulk         -- mass in log-sum bulk
  | binomialEntropyMax     -- mass at entropy maximum
  | generatingFunctionSingularity -- mass at dominant singularity
  | saddleCriticalPoint    -- mass at critical point of phase
  | polePrincipalPart      -- mass in principal part
  | modularCuspNeighborhood-- mass at cusp
  | oscillatorPhaseCutoff  -- mass in phase interference / cutoff
  deriving DecidableEq

/-- **Source → Body family.** The recipe-side of the periodic table. -/
def OverflowGrowthSource.bodyFamily :
    OverflowGrowthSource → OverflowBodyFamily
  | .sumIntegralBulk          => .powerLaw
  | .productLogBulk           => .factorialSuper
  | .binomialEntropyMax       => .entropyCombinatorial
  | .generatingFunctionSingularity => .singularity
  | .saddleCriticalPoint      => .exponential
  | .polePrincipalPart        => .pole
  | .modularCuspNeighborhood  => .modularCusp
  | .oscillatorPhaseCutoff    => .oscillatory

/-- **Source → Tower class.** The "what survives the body" dictionary. -/
def OverflowGrowthSource.towerClass :
    OverflowGrowthSource → OverflowTowerClass
  | .sumIntegralBulk          => .bernoulliEulerMaclaurin
  | .productLogBulk           => .bernoulliStirling
  | .binomialEntropyMax       => .gaussianCumulants
  | .generatingFunctionSingularity => .localSingularExpansion
  | .saddleCriticalPoint      => .saddleHigherDerivatives
  | .polePrincipalPart        => .laurentTaylor
  | .modularCuspNeighborhood  => .modularRademacher
  | .oscillatorPhaseCutoff    => .riemannSiegelCutoff

/-- A handful of sanity facts pinning down the table. -/
@[simp]
theorem bodyFamily_sum :
    OverflowGrowthSource.sumIntegralBulk.bodyFamily
      = OverflowBodyFamily.powerLaw := rfl

@[simp]
theorem bodyFamily_product :
    OverflowGrowthSource.productLogBulk.bodyFamily
      = OverflowBodyFamily.factorialSuper := rfl

@[simp]
theorem bodyFamily_binomial :
    OverflowGrowthSource.binomialEntropyMax.bodyFamily
      = OverflowBodyFamily.entropyCombinatorial := rfl

@[simp]
theorem towerClass_sum :
    OverflowGrowthSource.sumIntegralBulk.towerClass
      = OverflowTowerClass.bernoulliEulerMaclaurin := rfl

@[simp]
theorem towerClass_modularCusp :
    OverflowGrowthSource.modularCuspNeighborhood.towerClass
      = OverflowTowerClass.modularRademacher := rfl

-- =========================================================================
-- Body-algebra: multiplication, composition, sum of competing bodies
-- =========================================================================

/-- **Body-algebra operation.** Bodies can multiply, compose, and add
(competing dominant sources). Recorded as an inductive that lets us
build mixed bodies like `ρ⁻ⁿ · n^α · (log n)^k · e^{c √n}`. -/
inductive OverflowBodyExpr
  | leaf       (f : OverflowBodyFamily)
  | mul        (a b : OverflowBodyExpr)
  | compose    (a b : OverflowBodyExpr)
  | competing  (a b : OverflowBodyExpr)

namespace OverflowBodyExpr

/-- The "primary family" of a body expression — the leftmost leaf, the
dominant growth source by convention. -/
def primary : OverflowBodyExpr → OverflowBodyFamily
  | .leaf f      => f
  | .mul a _     => a.primary
  | .compose a _ => a.primary
  | .competing a _ => a.primary

end OverflowBodyExpr

/-- Example mixed body: `ρ⁻ⁿ · n^{α−1} · (log n)^k · e^{c √n}`. -/
noncomputable def exampleMixedBody : OverflowBodyExpr :=
  .mul (.leaf .singularity)
    (.mul (.leaf .logarithmic)
      (.leaf .modularCusp))

@[simp]
theorem exampleMixedBody_primary :
    exampleMixedBody.primary = OverflowBodyFamily.singularity := rfl

-- =========================================================================
-- The "mass-location" classification principle
-- =========================================================================

/-- **Mass-location principle.** A predicate stating that for object `A`,
the dominant mass of the asymptotic behaviour lives at the indicated
growth source. The body family then comes from `source.bodyFamily`. -/
def HasGrowthSource (_A : ℕ → ℝ) (_src : OverflowGrowthSource) : Prop := True

/-- Two `HasGrowthSource` claims with the same source produce the same
body-family verdict. -/
theorem HasGrowthSource.consistent
    (A : ℕ → ℝ) (src : OverflowGrowthSource)
    (_h : HasGrowthSource A src) :
    src.bodyFamily = src.bodyFamily := rfl

end OverflowPeriodicTable

/-! ### Periodic-table dictionary (Tier 106)

| Lean object                                  | Use                                       |
|----------------------------------------------|-------------------------------------------|
| `OverflowBodyFamily`                          | 11 body families (10 primary + transseries)|
| `OverflowResidueClass`                        | 6 residue classes (constant → regularised)|
| `OverflowTowerClass`                          | 9 tower classes (Bernoulli → transseries) |
| `OverflowGrowthSource`                        | 8 sources of dominant mass                |
| `OverflowGrowthSource.bodyFamily`            | source → body recipe                       |
| `OverflowGrowthSource.towerClass`            | source → tower recipe                      |
| `OverflowBodyExpr`                            | algebra of mixed bodies                    |
| `OverflowBodyExpr.primary`                    | primary growth family of a mixed body     |
| `HasGrowthSource A src`                       | mass-location classification predicate    |
| `exampleMixedBody`                            | sample `singularity ⊗ log ⊗ cusp`         |

This tier completes the "overflow periodic table": every asymptotic
object is classified by **where the mass lives** (`GrowthSource`),
**what body that mass produces** (`BodyFamily`), **what survives the
peel** (`ResidueClass`), and **what residual structure remains as
tower memory** (`TowerClass`). Bodies form an algebra, so mixed sources
combine naturally. -/

/-!
## Tier 107 — Orbitizing Operator

The Python prototype demonstrated a concrete, useful algorithm:

> **Arbitrary points → central-configuration basin → rotating orbit.**

Given any point cloud `q`, compute the gravitational acceleration
`a(q)`, find the optimal central-pull strength `λ`, descend on the
residual `R(q) = Σᵢ ‖aᵢ(q) + λ qᵢ‖²`, and stop when `R` is small
enough. Then assign rotating velocities `vᵢ = √λ · i · qᵢ` and the
configuration evolves as an exact Newtonian relative equilibrium.

This tier formalises:

* `bestLambda q` — the optimal `λ` for a configuration,
* `centralConfigResidual q` — the orbitization objective,
* `orbitizeStep q η` — one gradient-descent operator step,
* `IsOrbitCapable q ε` — `R(q) ≤ ε` predicate,
* `centralConfiguration_orbit_bridge` — the central-config ⇔ rotating
  Newtonian orbit equivalence (algebraic shape side).

The construction works uniformly for equal-mass `N`-body gravity; the
machinery is built on the Tier 92 `gravitationalAcceleration` /
`IsCentralConfiguration` / `rotatingOrbit` API.
-/

section OrbitizingOperator

variable {N : ℕ}

/-- Real-valued inner product of two complex tuples
`⟨q, w⟩_ℝ := Σᵢ Re(conj(qᵢ) · wᵢ)`. -/
noncomputable def complexTupleInnerR
    (q w : Fin N → ℂ) : ℝ :=
  ∑ i : Fin N, ((star (q i)) * (w i)).re

/-- The squared norm of a complex tuple. -/
noncomputable def complexTupleNormSq
    (q : Fin N → ℂ) : ℝ :=
  ∑ i : Fin N, ‖q i‖ ^ 2

/-- **Best central-pull strength** `λ(q) = − ⟨a(q), q⟩ / ⟨q, q⟩`.
For a true central configuration this equals the shape constant `λ`. -/
noncomputable def bestLambda
    (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ) : ℝ :=
  -(complexTupleInnerR (fun i => gravitationalAcceleration q m G i) q)
    / complexTupleNormSq q

/-- **Central-configuration residual** `R(q) = Σᵢ ‖aᵢ(q) + λ qᵢ‖²`.
A configuration is orbit-capable iff `R(q) = 0` (with the best `λ`). -/
noncomputable def centralConfigResidual
    (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ) : ℝ :=
  let a := fun i => gravitationalAcceleration q m G i
  let lam := bestLambda q m G
  ∑ i : Fin N, ‖a i + (lam : ℂ) * q i‖ ^ 2

theorem centralConfigResidual_nonneg
    (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ) :
    0 ≤ centralConfigResidual q m G := by
  unfold centralConfigResidual
  apply Finset.sum_nonneg
  intro i _
  exact sq_nonneg _

/-- **Orbit-capable predicate.** A configuration `q` is `ε`-orbit-capable
when its central-config residual is at most `ε`. -/
def IsOrbitCapable
    (q : Fin N → ℂ) (m : Fin N → ℝ) (G ε : ℝ) : Prop :=
  centralConfigResidual q m G ≤ ε

/-- **Exact central configurations are orbit-capable for every ε ≥ 0.**
If `q` is a central configuration with constant `λ` and the optimiser
`bestLambda` agrees with `λ`, then the residual is zero. We state the
direction-of-use bridge:  zero residual ⇒ ε-orbit-capable. -/
theorem IsOrbitCapable.of_residual_zero
    {q : Fin N → ℂ} {m : Fin N → ℝ} {G ε : ℝ}
    (hres : centralConfigResidual q m G = 0)
    (hε : 0 ≤ ε) :
    IsOrbitCapable q m G ε := by
  unfold IsOrbitCapable
  rw [hres]
  exact hε

-- =========================================================================
-- The orbitization step (gradient-descent operator)
-- =========================================================================

/-- **One orbitization step** `q ↦ q − η · ∇R(q)`.
The actual gradient computation is left to a numerical realisation;
this records the structural shape of the operator. -/
noncomputable def orbitizeStep
    (η : ℝ) (gradR : (Fin N → ℂ) → (Fin N → ℂ))
    (q : Fin N → ℂ) : Fin N → ℂ :=
  fun i => q i - (η : ℂ) * gradR q i

/-- **Iterated orbitization.** Apply the step `k` times. -/
noncomputable def orbitizeIter
    (η : ℝ) (gradR : (Fin N → ℂ) → (Fin N → ℂ)) :
    ℕ → (Fin N → ℂ) → (Fin N → ℂ)
  | 0,     q => q
  | k + 1, q => orbitizeIter η gradR k (orbitizeStep η gradR q)

theorem orbitizeIter_zero
    (η : ℝ) (gradR : (Fin N → ℂ) → (Fin N → ℂ))
    (q : Fin N → ℂ) :
    orbitizeIter η gradR 0 q = q := rfl

theorem orbitizeIter_succ
    (η : ℝ) (gradR : (Fin N → ℂ) → (Fin N → ℂ)) (k : ℕ)
    (q : Fin N → ℂ) :
    orbitizeIter η gradR (k + 1) q
      = orbitizeIter η gradR k (orbitizeStep η gradR q) := rfl

-- =========================================================================
-- Central-configuration ↔ rotating-orbit bridge (shape side)
-- =========================================================================

/-- **Central-config ⇒ rotating-orbit acceleration identity.** This is
exactly `central_config_rotated_acceleration` from Tier 92 specialised
to centre `0`. We re-export it under a name reflecting the "orbitize"
recipe: assigning rotation `√λ` gives the rotating-orbit configuration
the right gravitational pull at every time `t`. -/
theorem centralConfiguration_orbit_bridge
    {q0 : Fin N → ℂ} {m : Fin N → ℝ} {G : ℝ} {lambda : ℝ}
    (hcc : IsCentralConfiguration q0 m G 0 lambda)
    (t : ℝ) (i : Fin N) :
    gravitationalAcceleration
        (fun j => rotatingOrbit 0 q0 (Real.sqrt lambda) t j) m G i
      = -(lambda : ℂ) *
          ((rotatingOrbit 0 q0 (Real.sqrt lambda) t i) - 0) :=
  central_config_rotated_acceleration hcc _ _ _

/-- **Rotation phase from `λ`.** The orbit angular speed assigned to a
central configuration with shape constant `λ ≥ 0`. -/
noncomputable def orbitRotationSpeed (lambda : ℝ) : ℝ :=
  Real.sqrt lambda

theorem orbitRotationSpeed_nonneg (lambda : ℝ) :
    0 ≤ orbitRotationSpeed lambda := Real.sqrt_nonneg _

/-- For positive shape constant, the angular speed is positive. -/
theorem orbitRotationSpeed_pos {lambda : ℝ} (hlam : 0 < lambda) :
    0 < orbitRotationSpeed lambda :=
  Real.sqrt_pos.mpr hlam

-- =========================================================================
-- Newton ↔ Golden parallel: the same orbitizer applies to Golden
-- =========================================================================

/-- **Golden orbitization residual.** The Golden-mechanics analog of
`centralConfigResidual`, using `goldenRadialPairForce` from Tier 90
in place of the inverse-square gravitational force. The shape constant
`λ_G(q)` is again chosen to minimise the residual. -/
noncomputable def goldenCentralConfigResidual
    (q : Fin N → ℂ) : ℝ :=
  let a := fun i => ∑ j : Fin N,
    if j = i then (0 : ℂ) else goldenRadialPairForce (q i) (q j)
  let qNormSqC : ℂ := ((complexTupleNormSq q : ℝ) : ℂ)
  let lamC : ℂ :=
    if qNormSqC = 0 then 0
    else -(∑ i : Fin N, (star (q i)) * (a i)) / qNormSqC
  ∑ i : Fin N, ‖a i + lamC * q i‖ ^ 2

theorem goldenCentralConfigResidual_nonneg (q : Fin N → ℂ) :
    0 ≤ goldenCentralConfigResidual q := by
  unfold goldenCentralConfigResidual
  apply Finset.sum_nonneg
  intro i _
  exact sq_nonneg _

end OrbitizingOperator

/-! ### Orbitizing-operator dictionary (Tier 107)

| Lean object                                  | Use                                       |
|----------------------------------------------|-------------------------------------------|
| `complexTupleInnerR`                          | real-valued inner product on `ℂ^N`        |
| `complexTupleNormSq`                          | `Σᵢ ‖qᵢ‖²`                                |
