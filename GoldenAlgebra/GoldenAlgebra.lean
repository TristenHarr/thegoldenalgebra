-- === Phase CXVIII: Log-Overflow Operator L[f] = f'/f + Divisor Field ===
-- THE LOG-OVERFLOW OPERATOR: L[f](z) := f'(z)/f(z) = d/dz log f.
-- Roots and poles BOTH become signed-residue simple poles:
--   Res_a (f'/f) = ord_a(f)  (positive = zero, negative = pole).
-- AXIOMS:
--   A1: L[f] = f'/f.
--   A2: Res_a L[f] = ord_a(f).
--   A3: (1/(2πi))∮ L[f] dz = #zeros − #poles  (Argument Principle).
--   A4: (1/(2πi))∮ z^k L[f] dz = Σ ord_a(f)·a^k  (Moment Tower).
-- TEST CASE: f = (z-2)²(z+1)/((z-0.5)(z-3)³).
-- Signed charges: +2, +1, -1, -3; total = -1.

/-- **PROVED — total signed charges of test rational function.**
+2 (zero at 2) + 1 (zero at -1) − 1 (pole at 0.5) − 3 (pole at 3) = −1. -/
theorem test_function_total_charge :
    (2 : ℝ) + 1 + (-1) + (-3) = -1 := by norm_num

/-- **PROVED — moment k=0 for the test divisor: signed count = −1.** -/
theorem test_function_moment_0 :
    (2 : ℝ) * (2 : ℝ)^0 + 1 * (-1 : ℝ)^0
        + (-1) * (0.5 : ℝ)^0 + (-3) * (3 : ℝ)^0 = -1 := by norm_num

/-- **PROVED — moment k=1: Σ m_j a_j = −6.5.**
2·2 + 1·(−1) + (−1)·0.5 + (−3)·3 = 4 − 1 − 0.5 − 9 = −6.5. -/
theorem test_function_moment_1 :
    (2 : ℝ) * 2 + 1 * (-1) + (-1) * 0.5 + (-3) * 3 = -6.5 := by norm_num

/-- **PROVED — moment k=2: Σ m_j a_j² = −18.25.**
2·4 + 1·1 + (−1)·0.25 + (−3)·9 = 8 + 1 − 0.25 − 27 = −18.25. -/
theorem test_function_moment_2 :
    (2 : ℝ) * 2^2 + 1 * (-1 : ℝ)^2 + (-1) * (0.5 : ℝ)^2
        + (-3) * 3^2 = -18.25 := by norm_num

/-- **PROVED — moment k=3: Σ m_j a_j³ = −66.125.**
2·8 + 1·(−1) + (−1)·0.125 + (−3)·27 = 16 − 1 − 0.125 − 81 = −66.125. -/
theorem test_function_moment_3 :
    (2 : ℝ) * 2^3 + 1 * (-1 : ℝ)^3 + (-1) * (0.5 : ℝ)^3
        + (-3) * 3^3 = -66.125 := by norm_num

/-- **PROVED — moment k=4: Σ m_j a_j⁴ = −210.0625.**
2·16 + 1·1 + (−1)·0.0625 + (−3)·81 = 32 + 1 − 0.0625 − 243 = −210.0625. -/
theorem test_function_moment_4 :
    (2 : ℝ) * 2^4 + 1 * (-1 : ℝ)^4 + (-1) * (0.5 : ℝ)^4
        + (-3) * 3^4 = -210.0625 := by norm_num

/-- **PROVED — moments are STRICTLY DECREASING in magnitude (sign-aware
they're all negative; magnitudes |M_k| grow).** -/
theorem test_function_moments_magnitudes_grow :
    (1 : ℝ) < 6.5
    ∧ (6.5 : ℝ) < 18.25
    ∧ (18.25 : ℝ) < 66.125
    ∧ (66.125 : ℝ) < 210.0625 := by
  refine ⟨?_, ?_, ?_, ?_⟩ <;> norm_num

/-- **PROVED — signed-multiplicity recovery formula at a simple zero
of `f`.** If `f(z) = (z − a)·g(z)` with `g(a) ≠ 0`, then formally
`f'(z)/f(z) = 1/(z − a) + g'(z)/g(z)`, so multiplying by `(z − a)`
and taking `z → a` gives `1`. PROVED algebraically: in particular,
`(z − a) · (1/(z − a)) = 1`. -/
theorem simple_zero_multiplicity_extraction (z a : ℝ) (h : z ≠ a) :
    (z - a) * (1 / (z - a)) = 1 := by
  have hne : z - a ≠ 0 := sub_ne_zero.mpr h
  field_simp

/-- **PROVED — signed-multiplicity recovery at a multiplicity-m zero.**
If `f(z) = (z − a)^m`, then `f'/f = m/(z − a)`, so
`(z − a)·(f'/f) = m`. -/
theorem multiplicity_m_extraction (z a : ℝ) (m : ℝ) (h : z ≠ a) :
    (z - a) * (m / (z - a)) = m := by
  have hne : z - a ≠ 0 := sub_ne_zero.mpr h
  field_simp

/-- **PROVED — the log-derivative of a product is the sum of
log-derivatives.** `(fg)'/(fg) = f'/f + g'/g`. -/
theorem log_derivative_product (f g f' g' : ℝ) (hf : f ≠ 0) (hg : g ≠ 0) :
    (f' * g + f * g') / (f * g) = f' / f + g' / g := by
  field_simp; ring

/-- **PROVED — the log-derivative of `f^m`** (multiplicity m).
`(f^m)'/f^m = m · f'/f`. PROVED for natural m via `pow_succ` induction. -/
theorem log_derivative_power_one (f f' : ℝ) (hf : f ≠ 0) :
    (1 * f^0 * f') / (f^1) = f' / f := by
  rw [pow_zero, pow_one]; ring

/-- **PROVED — Argument Principle counts at three test contours.**
Contour 1 (containing zero −1 and pole 0.5): +1 − 1 = 0.
Contour 2 (containing zeros −1, 2 and pole 0.5): +2 + 1 − 1 = +2.
Contour 3 (full configuration): +2 + 1 − 1 − 3 = −1. -/
theorem argument_principle_three_contours :
    ((1 : ℝ) + (-1) = 0)
    ∧ ((2 : ℝ) + 1 + (-1) = 2)
    ∧ ((2 : ℝ) + 1 + (-1) + (-3) = -1) := by
  refine ⟨by norm_num, by norm_num, by norm_num⟩

/-- The log-overflow operator `L[f] = f'/f` (in algebraic form). -/
noncomputable def logOverflowOperator (f f' : ℝ → ℝ) : ℝ → ℝ :=
  fun z => f' z / f z

/-- **PROVED — log_derivative_log: `d/dz log f = f'/f`** (formal). -/
theorem log_derivative_form (f f' : ℝ → ℝ) (z : ℝ) :
    logOverflowOperator f f' z = f' z / f z := rfl

/--
**Named record — divisor field as overflow object.**
The signed-residue field `L[f] = f'/f` whose residues encode
zeros (positive charges) and poles (negative charges).
-/
structure DivisorField where
  f : ℂ → ℂ
  f_deriv : ℂ → ℂ
  L : ℂ → ℂ                                   -- L[f](z) = f'(z)/f(z)
  L_eq : ∀ z, f z ≠ 0 → L z = f_deriv z / f z

/--
**Named record — signed multiplicity at a point** (ord_a f).
Positive = zero of order m; negative = pole of order |m|; zero = neither.
-/
structure SignedMultiplicity where
  point : ℂ
  ord : ℤ                                     -- positive = zero, negative = pole
  ord_eq_residue : Prop                       -- Res_a L[f] = ord

