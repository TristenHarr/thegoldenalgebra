    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  WeilPositivityPackage_implies_zeta_critical_line P.positivityPackage

-- Step 221: extract the single RH-hard theorem.

/--
The single remaining RH-hard theorem: the classical Weil positivity
inequality has been established.
-/
def FinalWeilPositivityTheorem : Prop :=
  Nonempty ClassicalWeilPositivityCriterion

/-- The final Weil-positivity theorem genuinely *is* the quantified
inequality `∀ f admissible, 0 ≤ Q(f)`. -/
theorem FinalWeilPositivityTheorem.extract
    (h : FinalWeilPositivityTheorem) :
    ∃ W : ClassicalWeilPositivityCriterion,
      ∀ f : RiemannWeilTestFunction,
        W.admissible f → 0 ≤ W.weilForm.quadraticForm f := by
  rcases h with ⟨W⟩
  exact ⟨W, W.positivity⟩

-- Step 222: one-shot theorem from explicit formula + Weil positivity.

/--
**Final one-shot theorem.** Supplying a formalized Riemann–Weil
explicit formula package and a Weil positivity package that uses it
proves the critical-line statement for all nontrivial zeta zeros.
