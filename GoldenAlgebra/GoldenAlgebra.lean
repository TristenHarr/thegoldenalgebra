  limiting_shape : Prop

/-- **Named target — Conjecture E: pole-overflow analogy.** Analytic
poles correspond to continuum limits of discrete overflow/carry waves. -/
structure ConjectureE_PoleAsOverflow where
  pole_eq_overflow_boundary : Prop
