/--
**Named record — Pascal as INFORMATION** (log_2 C(n,k) bits to
identify a k-choice out of n). The rupture is where entropy exceeds
storage capacity:
  log_2 C(n, n/2) ≥ log_2 M ⟺ n·H_2(1/2) − (small tax) ≥ log_2 M.
-/
structure PascalAsInformation where
  bits_to_identify_choice : ℕ → ℕ → ℝ      -- (n, k) ↦ log_2 C(n, k)
  binary_entropy : ℝ → ℝ                    -- H_2(p)
  stirling_tax : ℕ → ℝ                      -- − (1/2) log_2(2πn p(1-p))
  rupture_is_entropy_overflow : Prop

