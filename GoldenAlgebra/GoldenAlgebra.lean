-- === Phase LXXX: The EXACT Collapse R₂ = 32 log 2 − 16 − 4ζ(3) ===
-- The half-integer kernel admits a clean partial-fraction
-- decomposition:
--   4/(n³(2n−1)(2n+1)) = 16/(2n+1) + 16/(2n−1) − 16/n − 4/n³.
-- Summing gives the EXACT collapse
--   R₂ = ∑ζ(5+2j)/4^j = 32·log 2 − 16 − 4ζ(3).
-- So the cyclotomic design compresses the entire odd-zeta ladder
-- starting at ζ(5) into elementary constants and ζ(3). It does NOT
-- isolate ζ(5) directly — but it gives a CLEAN BRIDGE between the
-- root-of-unity projector and the ζ(3) shadow. The family R_a for
-- a ∈ {1,2,3,4,6} introduces different cyclotomic factor geometries.
-- The hybrid filter: combine R₂ with the (2,3,5),[−58,64,−19] node
-- filter that kills ζ(3).

/-- **PROVED — the partial-fraction decomposition of the half-integer
kernel.** `4/(n³·(2n−1)·(2n+1)) = 16/(2n+1) + 16/(2n−1) − 16/n − 4/n³`.
Verified by clearing denominators: the numerator collapses to `4`. -/
theorem half_integer_kernel_partial_fraction (n : ℚ)
    (hn : n ≠ 0) (h1 : 2*n - 1 ≠ 0) (h2 : 2*n + 1 ≠ 0) :
    (4 : ℚ) / (n^3 * (2*n - 1) * (2*n + 1))
    = 16 / (2*n + 1) + 16 / (2*n - 1) - 16 / n - 4 / n^3 := by
  have hn3 : n^3 ≠ 0 := pow_ne_zero _ hn
  field_simp
  ring

/-- **PROVED — at `n = 1` the PF decomposition gives `4/3 = 16/3 +
16/1 − 16 − 4`.** Concrete check. -/
theorem half_integer_kernel_partial_fraction_n1 :
    (16/3 : ℚ) + 16 - 16 - 4 = 4/3 := by norm_num

/-- **PROVED — the a=1 family kernel.** `1/(n⁵·(1 − 1/(2n))) =
2/(n⁴·(2n − 1))`. -/
theorem family_kernel_a1 (n : ℚ) (hn : n ≠ 0) (h1 : 2*n - 1 ≠ 0) :
    1 / (n^5 * (1 - 1/(2*n))) = 2 / (n^4 * (2*n - 1)) := by
  have hn4 : n^4 ≠ 0 := pow_ne_zero _ hn
  field_simp
  ring

/-- **PROVED — the a=2 family kernel matches the half-integer kernel.**
(Same as `universal_residual_half_integer_kernel`.) Routed through
the half-integer form for clarity. -/
theorem family_kernel_a2 (n : ℚ) (hn : n ≠ 0)
    (h1 : 2*n - 1 ≠ 0) (h2 : 2*n + 1 ≠ 0) :
    1 / (n^5 * (1 - 1/(2*n)^2)) = 4 / (n^3 * (2*n - 1) * (2*n + 1)) := by
  have heq : (1 : ℚ) / (2*n)^2 = 1/(4*n^2) := by
    rw [show ((2*n)^2 : ℚ) = 4*n^2 from by ring]
  rw [heq]
  exact universal_residual_half_integer_kernel n hn h1 h2

/-- **PROVED — the a=3 family kernel factors via `8n³ − 1 =
(2n − 1)·(4n² + 2n + 1)`** (sum of cubes; `4n² + 2n + 1 = Φ₃(2n)`). -/
theorem family_kernel_a3_factor (n : ℚ) :
    8*n^3 - 1 = (2*n - 1) * (4*n^2 + 2*n + 1) := by ring

/-- **PROVED — Φ₃(2n) = 4n² + 2n + 1.** Identity linking the a=3
family to the 3rd cyclotomic polynomial. -/
theorem Phi3_at_2n (n : ℚ) :
    Phi3_poly (2 * n) = 4*n^2 + 2*n + 1 := by
  unfold Phi3_poly; ring

/-- **PROVED — the a=4 family kernel factors as
`16n⁴ − 1 = (2n−1)(2n+1)(4n² + 1) = (2n−1)(2n+1)·Φ₄(2n)`.** -/
theorem family_kernel_a4_factor (n : ℚ) :
    16*n^4 - 1 = (2*n - 1) * (2*n + 1) * (4*n^2 + 1) := by ring

/-- **PROVED — Φ₄(2n) = 4n² + 1.** Identity linking the a=4 family
to the 4th cyclotomic polynomial. -/
theorem Phi4_at_2n (n : ℚ) : Phi4_poly (2 * n) = 4*n^2 + 1 := by
  unfold Phi4_poly; ring

/-- **PROVED — the a=6 family kernel factors as
`(2n)⁶ − 1 = (2n−1)(2n+1)·Φ₃(2n)·Φ₆(2n)`** where
`Φ₃(2n) = 4n²+2n+1` and `Φ₆(2n) = 4n²−2n+1`. -/
theorem family_kernel_a6_factor (n : ℚ) :
    (2*n)^6 - 1
    = (2*n - 1) * (2*n + 1) * (4*n^2 + 2*n + 1) * (4*n^2 - 2*n + 1) := by
  ring

/-- **PROVED — Φ₆(2n) = 4n² − 2n + 1.** Identity linking the a=6
family to the 6th cyclotomic polynomial. -/
theorem Phi6_at_2n (n : ℚ) : Phi6_poly (2 * n) = 4*n^2 - 2*n + 1 := by
  unfold Phi6_poly; ring

