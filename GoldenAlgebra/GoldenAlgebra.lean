/-- The real local Euler factor `(1 − p^(−s))⁻¹` (real `s`, no branch
cuts — the honest finite-skeleton setting). -/
noncomputable def localEulerFactorReal (p : ℕ) (s : ℝ) : ℝ :=
  (1 - (p : ℝ) ^ (-s))⁻¹

/--
**Step XXIV.1 — finite Euler-product logarithm (PROVED).** The log of a
finite product of local Euler factors is the sum of `−log(1 − p^(−s))`.
The honest finite skeleton of `log ζ = −Σ_p log(1 − p^(−s))`.
-/
theorem finiteEulerProduct_log (S : Finset ℕ) (s : ℝ)
    (h : ∀ p ∈ S, (1 - (p : ℝ) ^ (-s)) ≠ 0) :
    Real.log (∏ p ∈ S, localEulerFactorReal p s)
      = ∑ p ∈ S, - Real.log (1 - (p : ℝ) ^ (-s)) := by
  unfold localEulerFactorReal
  rw [Real.log_prod S _ (fun p hp => inv_ne_zero (h p hp))]
  simp only [Real.log_inv]

/--
**Step XXIV.2 — bounded-power Euler factor as a finite geometric sum
(PROVED).** `Σ_{k<K} (p^(−s))^k = ((p^(−s))^K − 1)/(p^(−s) − 1)` —
the bounded-power local factor before passing to the limit.
-/
theorem finiteEulerFactor_geom_sum (p : ℕ) (s : ℝ) (K : ℕ)
    (hp : (p : ℝ) ^ (-s) ≠ 1) :
    ∑ k ∈ Finset.range K, ((p : ℝ) ^ (-s)) ^ k
      = (((p : ℝ) ^ (-s)) ^ K - 1) / ((p : ℝ) ^ (-s) - 1) :=
  geom_sum_eq hp K

/--
**Step XXIV.3 — the Mercator log series (PROVED).** For `|x| < 1`,
`−log(1 − x) = Σ_{n≥0} x^(n+1)/(n+1)` — i.e. `Σ_{k≥1} x^k/k`. The
per-factor prime-power expansion.
-/
theorem neg_log_one_sub_eq_tsum (x : ℝ) (hx : |x| < 1) :
    - Real.log (1 - x) = ∑' n : ℕ, x ^ (n + 1) / (n + 1) :=
  (Real.hasSum_pow_div_log_of_abs_lt_one hx).tsum_eq.symm

/--
**Step XXIV.4 — finite Euler-product log as a prime-power sum (PROVED).**
`log(∏_{p∈S} (1−p^(−s))⁻¹) = Σ_{p∈S} Σ_{k≥1} p^(−ks)/k`.

This is the finite-primes version of the prime-zeta log identity
`log ζ(s) = Σ_p Σ_{k≥1} p^(−ks)/k`. Only the extension of `S` to ALL
primes (a convergence theorem) and the rearrangement-by-`j` remain —
those are the named target `PrimeZetaLogIdentity` below.
-/
theorem finiteEulerProduct_log_eq_primePowerSum
    (S : Finset ℕ) (s : ℝ)
    (h : ∀ p ∈ S, |(p : ℝ) ^ (-s)| < 1) :
    Real.log (∏ p ∈ S, localEulerFactorReal p s)
      = ∑ p ∈ S, ∑' n : ℕ, ((p : ℝ) ^ (-s)) ^ (n + 1) / (n + 1) := by
  have hne : ∀ p ∈ S, (1 - (p : ℝ) ^ (-s)) ≠ 0 := by
    intro p hp heq
    have hx1 : (p : ℝ) ^ (-s) = 1 := by
      have hz := sub_eq_zero.mp heq
      linarith [hz]
    have hx := h p hp
    rw [hx1] at hx
    norm_num at hx
  rw [finiteEulerProduct_log S s hne]
  apply Finset.sum_congr rfl
  intro p hp
  exact neg_log_one_sub_eq_tsum _ (h p hp)

/--
**Named target — the prime-zeta logarithm identity.** The infinite
identity `log ζ(s) = Σ_{j≥1} P(j·s)/j` for `Re(s) > 1`, with `P` the
prime zeta function. The finite skeleton above is PROVED; what remains
is the extension to all primes (convergence) and the rearrangement by
`j`. Carried as a genuine equation field — not `sorry`.
-/
structure PrimeZetaLogIdentity where
  domainCondition : ℂ → Prop
  identity :
    ∀ s : ℂ, domainCondition s →
      Complex.log (riemannZeta s)
        = ∑' j : ℕ+, primeZetaFunction ((j : ℂ) * s) / (j : ℂ)

/--
The finite-to-infinite Euler-log bridge: the PROVED finite-primes
skeleton plus the two remaining analytic obligations (extension to all
primes, rearrangement by `j`) that would yield `PrimeZetaLogIdentity`.
-/
structure FiniteToInfiniteEulerLogBridge where
  extendsToAllPrimes : Prop
  rearrangesByJ : Prop
  yieldsPrimeZetaLog : PrimeZetaLogIdentity

-- === Phase XXV: Finite → Infinite Euler Log Bridge ===
-- A concrete Mathlib convergence problem (not RH scaffolding). The
-- infinite prime-power log sum, its summability, and the equality
-- `Σ_p −log(1−p^(−s)) = Σ_p Σ_{k≥1} p^(−ks)/k`.

/-- The real prime zeta function `P(s) = Σ_p p^(−s)` (sum over primes,
real `s`). -/
noncomputable def realPrimeZeta (s : ℝ) : ℝ :=
  ∑' p : {p : ℕ // Nat.Prime p}, (p.1 : ℝ) ^ (-s)

/-- The infinite Euler-product logarithm `Σ_p −log(1−p^(−s))`. -/
noncomputable def infiniteEulerProductLog (s : ℝ) : ℝ :=
  ∑' p : {p : ℕ // Nat.Prime p}, - Real.log (1 - (p.1 : ℝ) ^ (-s))

/-- The infinite prime-power Euler log sum
`Σ_p Σ_{n≥0} (p^(−s))^(n+1)/(n+1)` = `Σ_p Σ_{k≥1} p^(−ks)/k`. -/
noncomputable def primePowerEulerLogSum (s : ℝ) : ℝ :=
  ∑' p : {p : ℕ // Nat.Prime p},
    ∑' n : ℕ, ((p.1 : ℝ) ^ (-s)) ^ (n + 1) / (n + 1)

/-- The finite-prime Euler log sum, primes up to `N`. -/
noncomputable def finitePrimeEulerLogSum (N : ℕ) (s : ℝ) : ℝ :=
  ∑ p ∈ (Finset.range (N + 1)).filter Nat.Prime,
    - Real.log (1 - (p : ℝ) ^ (-s))

/-- **PROVED.** For a prime `p` and `s > 0`, `|p^(−s)| < 1` — the
condition needed for the Mercator series. -/
theorem prime_rpow_neg_abs_lt_one
    (p : {p : ℕ // Nat.Prime p}) {s : ℝ} (hs : 0 < s) :
    |(p.1 : ℝ) ^ (-s)| < 1 := by
  have hp1 : (1 : ℝ) < (p.1 : ℝ) := by
    have h2 : (2 : ℕ) ≤ p.1 := p.2.two_le
    have hc : (2 : ℝ) ≤ (p.1 : ℝ) := by exact_mod_cast h2
    linarith
  have hpos : (0 : ℝ) < (p.1 : ℝ) ^ (-s) :=
    Real.rpow_pos_of_pos (by linarith) _
  have hlt : (p.1 : ℝ) ^ (-s) < 1 :=
    Real.rpow_lt_one_of_one_lt_of_neg hp1 (by linarith)
  rw [abs_of_pos hpos]
  exact hlt

/--
**Step XXV.1 — infinite Euler-product log = prime-power sum (PROVED).**
`Σ_p −log(1−p^(−s)) = Σ_p Σ_{k≥1} p^(−ks)/k`. This is the user's "best
first theorem": it needs only the Mercator series termwise (`tsum_congr`),
no summability. The infinite version of the proved finite skeleton.
-/
theorem infiniteEulerProduct_log_eq_primePowerSum
    {s : ℝ} (hs : 0 < s) :
    infiniteEulerProductLog s = primePowerEulerLogSum s := by
  unfold infiniteEulerProductLog primePowerEulerLogSum
  exact tsum_congr fun p =>
    neg_log_one_sub_eq_tsum _ (prime_rpow_neg_abs_lt_one p hs)

/-- **PROVED.** For each prime `p` and `s > 0`, the inner prime-power
series converges. -/
theorem primePowerEulerLog_inner_summable
    (p : {p : ℕ // Nat.Prime p}) {s : ℝ} (hs : 0 < s) :
    Summable (fun n : ℕ =>
      ((p.1 : ℝ) ^ (-s)) ^ (n + 1) / (n + 1)) :=
  (Real.hasSum_pow_div_log_of_abs_lt_one
    (prime_rpow_neg_abs_lt_one p hs)).summable

/--
**Step XXV.2 — prime zeta converges for `s > 1` (PROVED).** The real
prime zeta sum `Σ_p p^(−s)` is summable for `s > 1` — by comparison
with `Σ_n n^(−s)` (an injective restriction). No prime number theorem
needed.
-/
theorem realPrimeZeta_summable {s : ℝ} (hs : 1 < s) :
    Summable (fun p : {p : ℕ // Nat.Prime p} => (p.1 : ℝ) ^ (-s)) := by
  have hN : Summable (fun n : ℕ => (n : ℝ) ^ (-s)) :=
    Real.summable_nat_rpow.mpr (by linarith)
  exact hN.comp_injective Subtype.val_injective

/--
**Named target — outer Euler-log summability.** `Σ_p −log(1−p^(−s))`
is summable for `s > 1`. Provable by domination: `−log(1−x) ≤ 2x` for
`x ≤ 1/2`, and `Σ_p p^(−s)` is summable (`realPrimeZeta_summable`).
Carried as a genuine `Summable` field — a bounded convergence
obligation, not `sorry`.
-/
structure PrimePowerEulerLogSummable (s : ℝ) where
  oneLtS : 1 < s
  outerSummable :
    Summable (fun p : {p : ℕ // Nat.Prime p} =>
      - Real.log (1 - (p.1 : ℝ) ^ (-s)))

/--
**Named target — finite → infinite convergence.** The finite-prime
Euler log sums converge to the infinite one. Follows from
`PrimePowerEulerLogSummable` by Finset exhaustion of a summable family.
-/
structure FinitePrimeEulerLogConvergence (s : ℝ) where
  oneLtS : 1 < s
  tendsto :
    Filter.Tendsto (fun N => finitePrimeEulerLogSum N s)
      Filter.atTop (nhds (infiniteEulerProductLog s))

/--
**Named target — the real zeta Euler-product logarithm.**
`log ζ(s) = Σ_p −log(1−p^(−s))` for `s > 1`. Needs Mathlib's zeta
Euler product plus the log of an infinite product. Stated with
`Complex.log` for type-correctness (`riemannZeta` is `ℂ`-valued).
-/
structure RealZetaEulerProductLogTheorem where
  identity :
    ∀ s : ℝ, 1 < s →
      Complex.log (riemannZeta (s : ℂ))
        = ((infiniteEulerProductLog s : ℝ) : ℂ)

/--
**Named target — the real prime-zeta log identity.**
`log ζ(s) = Σ_{k≥1} P(k·s)/k` for `s > 1`, with `P` the real prime
zeta. The rearrangement-by-`k` of the prime-power double sum.
-/
structure RealPrimeZetaLogIdentity where
  identity :
    ∀ s : ℝ, 1 < s →
      Complex.log (riemannZeta (s : ℂ))
        = ((∑' k : ℕ, realPrimeZeta (s * (k + 1)) / (k + 1) : ℝ) : ℂ)

/--
The finite → infinite Euler-log program: the PROVED equality skeleton
(`infiniteEulerProduct_log_eq_primePowerSum`) plus the three remaining
named obligations — outer summability, finite-exhaustion convergence,
and the zeta Euler-product log.
-/
structure EulerLogConvergenceProgram (s : ℝ) where
  summability : PrimePowerEulerLogSummable s
  convergence : FinitePrimeEulerLogConvergence s
  zetaEulerLog : RealZetaEulerProductLogTheorem
  primeZetaLog : RealPrimeZetaLogIdentity

-- === Phase XXVI: Euler-Log Summability (the convergence half) ===
-- The outer summability `Σ_p −log(1−p^(−s))` is now PROVED, by
-- logarithmic domination plus the proved prime-zeta convergence.

/--
**Step XXVI.1 — logarithmic domination (PROVED).** For `0 ≤ x ≤ 1/2`,
`−log(1−x) ≤ 2x`. Proof: `log y ≤ y−1` at `y = (1−x)⁻¹`, then the
quadratic bound `x(1−2x) ≥ 0`.
-/
theorem neg_log_one_sub_le_two_mul {x : ℝ} (hx0 : 0 ≤ x)
    (hxhalf : x ≤ 1 / 2) : - Real.log (1 - x) ≤ 2 * x := by
  have h1x : (0 : ℝ) < 1 - x := by linarith
  have hstep : Real.log ((1 - x)⁻¹) ≤ (1 - x)⁻¹ - 1 :=
    Real.log_le_sub_one_of_pos (inv_pos.mpr h1x)
  rw [Real.log_inv] at hstep
  have hinv_mul : (1 - x)⁻¹ * (1 - x) = 1 := inv_mul_cancel₀ h1x.ne'
  nlinarith [hstep, hinv_mul, hx0, hxhalf, h1x]

/--
**Step XXVI.2 — prime power bound (PROVED).** For a prime `p` and
`s > 1`, `p^(−s) ≤ 1/2`. Proof: `p^s ≥ 2^s ≥ 2`, then reciprocate.
-/
theorem prime_rpow_neg_le_half {s : ℝ} (hs : 1 < s)
    {p : ℕ} (hp : Nat.Prime p) : ((p : ℝ) ^ (-s)) ≤ 1 / 2 := by
  have hp2 : (2 : ℝ) ≤ (p : ℝ) := by exact_mod_cast hp.two_le
  have hppos : (0 : ℝ) < (p : ℝ) := by linarith
  have hs0 : (0 : ℝ) ≤ s := by linarith
  rw [Real.rpow_neg hppos.le, inv_eq_one_div]
  have hA : (2 : ℝ) ^ s ≤ (p : ℝ) ^ s :=
    Real.rpow_le_rpow (by norm_num) hp2 hs0
  have hB : (2 : ℝ) ≤ (2 : ℝ) ^ s := by
    calc (2 : ℝ) = (2 : ℝ) ^ (1 : ℝ) := (Real.rpow_one 2).symm
    _ ≤ (2 : ℝ) ^ s := Real.rpow_le_rpow_of_exponent_le (by norm_num) hs.le
  exact one_div_le_one_div_of_le (by norm_num) (le_trans hB hA)

/--
**Step XXVI.3 — outer Euler-log summability (PROVED).** `Σ_p −log(1−p^(−s))`
is summable for `s > 1`: dominated by `2·Σ_p p^(−s)`, which converges
by `realPrimeZeta_summable`. This is the convergence half of the
prime-zeta log identity.
-/
theorem primePowerEulerLog_outer_summable {s : ℝ} (hs : 1 < s) :
    Summable (fun p : {p : ℕ // Nat.Prime p} =>
      - Real.log (1 - (p.1 : ℝ) ^ (-s))) := by
  have hg : Summable (fun p : {p : ℕ // Nat.Prime p} =>
      2 * (p.1 : ℝ) ^ (-s)) := (realPrimeZeta_summable hs).mul_left 2
  refine Summable.of_nonneg_of_le ?_ ?_ hg
  · intro p
    have hpp : (0 : ℝ) < (p.1 : ℝ) := by
      have h2 : (2 : ℝ) ≤ (p.1 : ℝ) := by exact_mod_cast p.2.two_le
      linarith
    have hxpos : (0 : ℝ) < (p.1 : ℝ) ^ (-s) :=
      Real.rpow_pos_of_pos hpp _
    have hxhalf : (p.1 : ℝ) ^ (-s) ≤ 1 / 2 :=
      prime_rpow_neg_le_half hs p.2
    have hlog : Real.log (1 - (p.1 : ℝ) ^ (-s)) ≤ 0 :=
      Real.log_nonpos (by linarith) (by linarith)
    linarith
  · intro p
    have hpp : (0 : ℝ) < (p.1 : ℝ) := by
      have h2 : (2 : ℝ) ≤ (p.1 : ℝ) := by exact_mod_cast p.2.two_le
      linarith
    have hxpos : (0 : ℝ) < (p.1 : ℝ) ^ (-s) :=
      Real.rpow_pos_of_pos hpp _
    exact neg_log_one_sub_le_two_mul hxpos.le (prime_rpow_neg_le_half hs p.2)

/-- The outer Euler-log summability target is now inhabited for every
`s > 1` — the `PrimePowerEulerLogSummable` obligation is DISCHARGED. -/
def PrimePowerEulerLogSummable.of_one_lt {s : ℝ} (hs : 1 < s) :
    PrimePowerEulerLogSummable s :=
  { oneLtS := hs
    outerSummable := primePowerEulerLog_outer_summable hs }

/-- **PROVED.** Partial sums of a summable real series over `range N`
converge to the total sum. -/
theorem tendsto_finset_range_sum_of_summable {a : ℕ → ℝ}
    (ha : Summable a) :
    Filter.Tendsto (fun N => ∑ n ∈ Finset.range N, a n)
      Filter.atTop (nhds (∑' n, a n)) :=
  ha.hasSum.tendsto_sum_nat

-- === Phase XXVII: Bernoulli/Euler Mirror — Even/Odd Zeta Values ===
-- Bernoulli numbers control ζ(2k); Euler numbers control β(2k+1); the
-- odd zeta values ζ(2k+1) are tied to ζ'(−2k), the SLOPES at zeta's
-- trivial zeros. Definitions + named targets; the trivial zeros are
-- PROVED from Mathlib. (Kept import-free: Mathlib's HurwitzZetaValues
-- /Bernoulli imports perturb downstream simp behaviour, so the even-
-- zeta Bernoulli sequence is carried as a structure field. Mathlib's
-- `riemannZeta_two`, `riemannZeta_four`, `riemannZeta_two_mul_nat`
-- prove the even-zeta values directly if those modules are imported.)

/-- The *Dirichlet beta function* `β(s) = Σ_{n≥0} (−1)ⁿ/(2n+1)ˢ` — the
zeta-like cousin whose odd values use Euler numbers. -/
noncomputable def dirichletBeta (s : ℂ) : ℂ :=
  ∑' n : ℕ, (-1 : ℂ) ^ n / (2 * (n : ℂ) + 1) ^ s

/--
**Named target — even zeta values via Bernoulli numbers.**
`ζ(2k) = |B_{2k}|·(2π)^{2k} / (2·(2k)!)` for `k ≥ 1`, over a supplied
Bernoulli sequence `bernoulliNumber`. Mathlib proves the equivalent
`(−1)^{k+1}·2^{2k−1}·π^{2k}·B_{2k}/(2k)!` form as
`riemannZeta_two_mul_nat`.
-/
structure EvenZetaBernoulliFormula where
  bernoulliNumber : ℕ → ℚ
  identity :
    ∀ k : ℕ, 0 < k →
      riemannZeta (2 * (k : ℂ)) =
        ((|bernoulliNumber (2 * k)| : ℚ) : ℂ)
          * (2 * (Real.pi : ℂ)) ^ (2 * k)
          / (2 * (Nat.factorial (2 * k) : ℂ))

/--
**Named target — the trivial zeros of zeta.** `ζ(−2(k+1)) = 0`: the
negative even integers, the mirror of `B_{2k+1} = 0`.
-/
structure TrivialZetaZeros where
  zeros : ∀ k : ℕ, riemannZeta (-2 * ((k : ℂ) + 1)) = 0

/-- **PROVED (Mathlib).** The trivial zeros target is inhabited:
`ζ(−2(k+1)) = 0` for every `k`, via `riemannZeta_neg_two_mul_nat_add_one`.
The `TrivialZetaZeros` obligation is DISCHARGED. -/
def trivial_zeta_zeros : TrivialZetaZeros :=
  ⟨fun k => riemannZeta_neg_two_mul_nat_add_one k⟩

/--
**Named target — the odd-zeta slope relation.** The odd zeta values
hide in the SLOPES at the trivial zeros:
`ζ(2k+1) = (−1)^k · 2^{2k+1}·π^{2k} / (2k)! · ζ'(−2k)`.
This is the genuinely mysterious mirror object: `ζ(−2k) = 0` but
`ζ'(−2k)` carries `ζ(2k+1)`.
-/
structure OddZetaSlopeRelation where
  identity :
    ∀ k : ℕ, 0 < k →
      riemannZeta (2 * (k : ℂ) + 1) =
        (-1 : ℂ) ^ k * 2 ^ (2 * k + 1) * (Real.pi : ℂ) ^ (2 * k)
          / (Nat.factorial (2 * k) : ℂ)
          * deriv riemannZeta (-2 * (k : ℂ))

/--
**Named target — odd Dirichlet-beta values via Euler numbers.**
`β(2k+1) = |E_{2k}|·π^{2k+1} / (4^{k+1}·(2k)!)`. The Euler-number
sequence `eulerNumber` is carried as a field (Mathlib has no Euler
numbers). This is the cleanest "opposite Bernoulli" pattern.
-/
structure OddBetaEulerFormula where
  eulerNumber : ℕ → ℤ
  identity :
    ∀ k : ℕ,
      dirichletBeta (2 * (k : ℂ) + 1) =
        ((|eulerNumber (2 * k)| : ℤ) : ℂ)
          * (Real.pi : ℂ) ^ (2 * k + 1)
          / (4 ^ (k + 1) * (Nat.factorial (2 * k) : ℂ))

/--
The **Bernoulli/Euler mirror**: even zeta ← Bernoulli, the trivial
zeros mirror the vanishing odd Bernoulli numbers, odd zeta ← slopes at
those zeros, odd beta ← Euler numbers.
-/
structure BernoulliEulerMirror where
  evenZeta : EvenZetaBernoulliFormula
  trivialZeros : TrivialZetaZeros
  oddZetaSlopes : OddZetaSlopeRelation
  oddBeta : OddBetaEulerFormula

/-- The odd zeta values, extracted from the mirror's slope relation:
each `ζ(2k+1)` is determined by `ζ'(−2k)`. -/
theorem oddZeta_from_mirror (M : BernoulliEulerMirror)
    {k : ℕ} (hk : 0 < k) :
    riemannZeta (2 * (k : ℂ) + 1) =
      (-1 : ℂ) ^ k * 2 ^ (2 * k + 1) * (Real.pi : ℂ) ^ (2 * k)
        / (Nat.factorial (2 * k) : ℂ)
        * deriv riemannZeta (-2 * (k : ℂ)) :=
  M.oddZetaSlopes.identity k hk

-- === Phase XXVIII: Odd-Zeta Modular Architecture ===
-- The hidden architecture of the ODD zeta values: each is a Bernoulli
-- π^odd term minus a Lambert/modular correction, evaluated at the
-- self-dual point q = e^{−2π} (τ = i). Two families split by parity
-- mod 4. Definitions + named targets; the ζ(3) triple-integral
-- assembly is PROVED.

/-- The Lambert correction `L_p = Σ_{n≥1} 1/(n^p·(e^{2πn}−1))`. -/
noncomputable def lambertL (p : ℕ) : ℝ :=
  ∑' n : ℕ,
    1 / (((n : ℝ) + 1) ^ p
      * (Real.exp (2 * Real.pi * ((n : ℝ) + 1)) - 1))

/-- The derivative correction `M_r = Σ_{n≥1} e^{2πn}/(n^r·(e^{2πn}−1)²)`,
the extra term differentiating the modular mirror produces. -/
noncomputable def lambertM (r : ℕ) : ℝ :=
  ∑' n : ℕ,
    Real.exp (2 * Real.pi * ((n : ℝ) + 1))
      / (((n : ℝ) + 1) ^ r
        * (Real.exp (2 * Real.pi * ((n : ℝ) + 1)) - 1) ^ 2)

/-- The trilogarithm `Li₃(z) = Σ_{j≥1} z^j/j³`. -/
noncomputable def trilogarithm (z : ℝ) : ℝ :=
  ∑' j : ℕ, z ^ (j + 1) / ((j : ℝ) + 1) ^ 3

/-- The divisor power sum `σ_k(N) = Σ_{d∣N} d^k`. -/
def sigmaPow (k N : ℕ) : ℕ :=
  ∑ d ∈ Nat.divisors N, d ^ k

/-- The negative divisor sum `σ_{−3}(N) = Σ_{d∣N} d^{−3}`. -/
noncomputable def sigmaNegThree (N : ℕ) : ℝ :=
  ∑ d ∈ Nat.divisors N, 1 / (d : ℝ) ^ 3

/-- The modular wave `G(t) = Σ_{N≥1} σ₃(N)·e^{−Nt} = (E₄(e^{−t})−1)/240`. -/
noncomputable def eisensteinG (t : ℝ) : ℝ :=
  ∑' N : ℕ,
    (sigmaPow 3 (N + 1) : ℝ) * Real.exp (-((N : ℝ) + 1) * t)

/-- The Eisenstein series `E₄` in `q = e^{−t}`: `E₄ = 1 + 240·G`. -/
noncomputable def eisensteinE4 (t : ℝ) : ℝ := 1 + 240 * eisensteinG t

/--
**Named target — the ζ(3) modular correction identity.**
`ζ(3) = 7π³/180 − 2·L₃`: the modular mirror almost turns `ζ(3)` into a
pure `π³` term, leaving the correction `2L₃`.
-/
structure ZetaThreeModularFormula where
  identity :
    (riemannZeta 3).re = 7 * Real.pi ^ 3 / 180 - 2 * lambertL 3

/--
**Named target — the ζ(3) trilogarithm face.**
`ζ(3) = 7π³/180 − 2·Σ_{k≥1} Li₃(e^{−2πk})`.
-/
structure ZetaThreeTrilogFormula where
  identity :
    (riemannZeta 3).re =
      7 * Real.pi ^ 3 / 180
        - 2 * ∑' k : ℕ,
            trilogarithm (Real.exp (-2 * Real.pi * ((k : ℝ) + 1)))

/--
**Named target — the ζ(3) divisor-combinatorics face.**
`ζ(3) = 7π³/180 − 2·Σ_{N≥1} σ_{−3}(N)·e^{−2πN}`.
-/
structure ZetaThreeDivisorFormula where
  identity :
    (riemannZeta 3).re =
      7 * Real.pi ^ 3 / 180
        - 2 * ∑' N : ℕ,
            sigmaNegThree (N + 1)
              * Real.exp (-2 * Real.pi * ((N : ℝ) + 1))

/-- **Named target — the cubed-derivative identity.** `D³L₃ = (E₄−1)/240`
where `D = q·d/dq`: the third derivative of the divisor-sum wave is the
Eisenstein series. A `Prop` placeholder for the operator identity. -/
structure CubedDerivativeIdentity where
  D3_L3_eq_eisenstein : Prop

/--
**Named target — L₃ as a triple integral of E₄.**
`L₃ = (1/480)·∫_{2π}^∞ (u−2π)²·(E₄(e^{−u})−1) du`: solving `D³L₃ = G`
by integrating three times from `∞` down to the self-dual point `2π`.
-/
structure L3TripleIntegralFormula where
  identity :
    lambertL 3 =
      (1 / 480 : ℝ) *
        ∫ u in Set.Ioi (2 * Real.pi),
          (u - 2 * Real.pi) ^ 2 * (eisensteinE4 u - 1)

/--
**Named target — ζ(3) as a triple-integrated modular wave.**
`ζ(3) = 7π³/180 − (1/240)·∫_{2π}^∞ (u−2π)²·(E₄(e^{−u})−1) du`.
-/
structure ZetaThreeTripleIntegralFormula where
  identity :
    (riemannZeta 3).re =
      7 * Real.pi ^ 3 / 180 -
        (1 / 240 : ℝ) *
          ∫ u in Set.Ioi (2 * Real.pi),
            (u - 2 * Real.pi) ^ 2 * (eisensteinE4 u - 1)

/--
**Named target — Ramanujan odd-zeta Family A** (`p = 4a−1`: 3, 7, 11,
…). `ζ(4a−1) = A_a·π^{4a−1} − 2·L_{4a−1}`. The mirror equation does NOT
cancel at the self-dual point, so `ζ` is directly exposed. `coeffA` is
the Bernoulli-derived rational coefficient.
-/
structure RamanujanOddZetaFamilyA where
  coeffA : ℕ → ℝ
  identity :
    ∀ a : ℕ, 0 < a →
      (riemannZeta ((4 * a - 1 : ℕ) : ℂ)).re =
        coeffA a * Real.pi ^ (4 * a - 1)
          - 2 * lambertL (4 * a - 1)

/--
**Named target — Ramanujan odd-zeta Family B** (`p = 4a+1`: 5, 9, 13,
…). `ζ(4a+1) = A_a·π^{4a+1} − 2·L_{4a+1} − (2/a)·π·M_{4a}`. The mirror
equation CANCELS at the self-dual point, so it must be differentiated —
which produces the extra `M_{4a}` term.
-/
structure RamanujanOddZetaFamilyB where
  coeffA : ℕ → ℝ
  identity :
    ∀ a : ℕ, 0 < a →
      (riemannZeta ((4 * a + 1 : ℕ) : ℂ)).re =
        coeffA a * Real.pi ^ (4 * a + 1)
          - 2 * lambertL (4 * a + 1)
          - (2 / (a : ℝ)) * Real.pi * lambertM (4 * a)

/--
The **odd-zeta modular architecture**: both Ramanujan families, the
ζ(3) modular/trilogarithm faces, the cubed-derivative identity, and the
triple-integral form — the full hidden architecture of the odd zetas.
-/
structure OddZetaModularArchitecture where
  familyA : RamanujanOddZetaFamilyA
  familyB : RamanujanOddZetaFamilyB
  zetaThree : ZetaThreeModularFormula
  zetaThreeTrilog : ZetaThreeTrilogFormula
  cubedDerivative : CubedDerivativeIdentity
  tripleIntegral : L3TripleIntegralFormula

/--
**Step XXVIII — the ζ(3) triple-integral formula from its parts
(PROVED).** The modular correction identity `ζ(3) = 7π³/180 − 2L₃` plus
the triple-integral form of `L₃` give the exact ζ(3) integral formula —
pure algebra (`2·(1/480) = 1/240`).
-/
theorem zetaThree_tripleIntegral_of_parts
    (hM : ZetaThreeModularFormula) (hL : L3TripleIntegralFormula) :
    ZetaThreeTripleIntegralFormula := by
  refine ⟨?_⟩
  rw [hM.identity, hL.identity]
  ring

/-- The odd-zeta modular architecture yields the exact ζ(3)
triple-integral formula. -/
theorem zetaThree_tripleIntegral_of_architecture
    (A : OddZetaModularArchitecture) :
    ZetaThreeTripleIntegralFormula :=
  zetaThree_tripleIntegral_of_parts A.zetaThree A.tripleIntegral

/-- **PROVED.** The two ζ(3) faces agree: modular-correction form and
triple-integral form both equal `ζ(3)`, so the Lambert correction `L₃`
and the triple integral coincide (`2L₃ = (1/240)·∫…`). -/
theorem L3_eq_of_modular_and_tripleIntegral
    (hM : ZetaThreeModularFormula)
    (hT : ZetaThreeTripleIntegralFormula) :
    2 * lambertL 3 =
      (1 / 240 : ℝ) *
        ∫ u in Set.Ioi (2 * Real.pi),
          (u - 2 * Real.pi) ^ 2 * (eisensteinE4 u - 1) := by
  have h := hM.identity.symm.trans hT.identity
  linarith [h]

-- === Phase XXIX: Apéry / Irrationality Architecture ===
-- Apéry proved ζ(3) irrational via insanely fast rational
-- approximants from a hypergeometric recurrence. The modular
-- correction L₃ is what makes ζ(3) a period; Apéry attacks the
-- period arithmetically. Ball–Rivoal/Zudilin generalize via linear
-- forms in many odd zetas. (Import-free: `IsIrrational` is defined
-- locally to avoid perturbing downstream simp behaviour.)

/-- A real number is *irrational* — not the image of any rational.
(Local definition, equivalent to Mathlib's `Irrational`, kept here to
avoid an import that perturbs downstream tactic behaviour.) -/
def IsIrrational (x : ℝ) : Prop := ¬ ∃ q : ℚ, (q : ℝ) = x

/-- The Apéry numbers `A_n = Σ_{k=0}^n C(n,k)²·C(n+k,k)²`. -/
def aperyNumber (n : ℕ) : ℕ :=
  ∑ k ∈ Finset.range (n + 1),
    Nat.choose n k ^ 2 * Nat.choose (n + k) k ^ 2

/-- **PROVED.** `A₀ = 1` — the Apéry-number initial value. -/
theorem aperyNumber_zero : aperyNumber 0 = 1 := by decide

/-- **PROVED.** `A₁ = 5` — the Apéry-number initial value. -/
theorem aperyNumber_one : aperyNumber 1 = 5 := by decide

/--
**Named target — the Apéry recurrence and convergence.** Two sequences
`A`, `B` obeying `(n+1)³u_{n+1} = (34n³+51n²+27n+5)u_n − n³u_{n−1}`,
with `A₀=1, A₁=5, B₀=0, B₁=6`, and `B_n/A_n → ζ(3)` — the irrationality
engine's input.
-/
structure AperyRecurrence where
  A : ℕ → ℝ
  B : ℕ → ℝ
  A_zero : A 0 = 1
  A_one : A 1 = 5
  B_zero : B 0 = 0
  B_one : B 1 = 6
  recurrenceA :
    ∀ n : ℕ, 0 < n →
      ((n : ℝ) + 1) ^ 3 * A (n + 1) =
        (34 * (n : ℝ) ^ 3 + 51 * (n : ℝ) ^ 2 + 27 * (n : ℝ) + 5) * A n
          - (n : ℝ) ^ 3 * A (n - 1)
  recurrenceB :
    ∀ n : ℕ, 0 < n →
      ((n : ℝ) + 1) ^ 3 * B (n + 1) =
        (34 * (n : ℝ) ^ 3 + 51 * (n : ℝ) ^ 2 + 27 * (n : ℝ) + 5) * B n
          - (n : ℝ) ^ 3 * B (n - 1)
  convergence :
    Filter.Tendsto (fun n => B n / A n) Filter.atTop
      (nhds ((riemannZeta 3).re))

/-- **Named target — Apéry's theorem: `ζ(3)` is irrational.** -/
structure IrrationalZetaThree where
  irrational : IsIrrational ((riemannZeta 3).re)

/--
**Named target — the Apéry binomial series.**
`ζ(3) = (5/2)·Σ_{n≥1} (−1)^{n−1}/(n³·C(2n,n))` — the geometrically
convergent combinatorial face.
-/
structure AperyBinomialSeries where
  identity :
    (riemannZeta 3).re =
      (5 / 2 : ℝ) * ∑' n : ℕ,
        (-1 : ℝ) ^ n
          / (((n : ℝ) + 1) ^ 3
            * (Nat.choose (2 * (n + 1)) (n + 1) : ℝ))

/--
**Named target — the irrationality engine.** A real `x` with rational
approximants `pₙ/qₙ` (`qₙ > 0`, `x ≠ pₙ/qₙ`) for which
`qₙ·|x − pₙ/qₙ| → 0` cannot be rational: a rational `a/b` admits no
such sequence (since `|a/b − p/q| ≥ 1/(bq)`).
-/
structure IrrationalityEngine (x : ℝ) where
  num : ℕ → ℤ
  den : ℕ → ℤ
  den_pos : ∀ n, 0 < den n
  not_equal : ∀ n, x ≠ (num n : ℝ) / (den n : ℝ)
  fast :
    Filter.Tendsto
      (fun n => (den n : ℝ) * |x - (num n : ℝ) / (den n : ℝ)|)
      Filter.atTop (nhds 0)
  yields_irrational : IsIrrational x

/-- **Named target — Zudilin's theorem.** At least one of
`ζ(5), ζ(7), ζ(9), ζ(11)` is irrational. -/
structure ZudilinOddZetaResult where
  oneIrrational :
    IsIrrational ((riemannZeta 5).re)
      ∨ IsIrrational ((riemannZeta 7).re)
      ∨ IsIrrational ((riemannZeta 9).re)
      ∨ IsIrrational ((riemannZeta 11).re)

/-- **Named target — Ball–Rivoal: infinitely many odd zeta values are
irrational.** -/
structure BallRivoalResult where
  infinitelyMany :
    ∀ N : ℕ, ∃ k : ℕ, N < k ∧
      IsIrrational ((riemannZeta (2 * k + 1)).re)

/--
**Named target — an integer linear form in odd zeta values**
`A₀ + A₁ζ(3) + A₂ζ(5) + … + A_mζ(2m+1)` — the Ball–Rivoal/Zudilin
attack object: small such forms force irrationality among the values.
-/
structure OddZetaLinearForm (m : ℕ) where
  coeff : ℕ → ℤ
  value : ℝ
  value_eq :
    value = (coeff 0 : ℝ)
      + ∑ j ∈ Finset.range m,
          (coeff (j + 1) : ℝ) * (riemannZeta (2 * (j + 1) + 1)).re

/--
The **Apéry / irrationality architecture**: the recurrence, Apéry's
theorem, the binomial series, and the group irrationality results
(Zudilin, Ball–Rivoal). Odd zetas are modular periods; Apéry attacks
the `k = 1` period arithmetically.
-/
structure AperyIrrationalityArchitecture where
  recurrence : AperyRecurrence
  aperyTheorem : IrrationalZetaThree
  binomialSeries : AperyBinomialSeries
  zudilin : ZudilinOddZetaResult
  ballRivoal : BallRivoalResult

/-- **PROVED.** `ζ(3)` is irrational, extracted from the architecture
(Apéry's theorem). -/
theorem zetaThree_irrational_of_architecture
    (A : AperyIrrationalityArchitecture) :
    IsIrrational ((riemannZeta 3).re) :=
  A.aperyTheorem.irrational

/-- **PROVED.** At least one of `ζ(5), ζ(7), ζ(9), ζ(11)` is
irrational, extracted from the architecture (Zudilin). -/
theorem someOddZeta_irrational_of_architecture
    (A : AperyIrrationalityArchitecture) :
    IsIrrational ((riemannZeta 5).re)
      ∨ IsIrrational ((riemannZeta 7).re)
      ∨ IsIrrational ((riemannZeta 9).re)
      ∨ IsIrrational ((riemannZeta 11).re) :=
  A.zudilin.oneIrrational

-- === Phase XXX: The Apéry Harmonic-Binomial Tower ===
-- Every odd zeta value has a rapidly-convergent central-binomial /
-- harmonic-sum identity. ζ(3) needs no harmonic correction; ζ(5) needs
-- H^(2); ζ(7) needs H^(2),H^(4),(H^(2))²; the tower climbs by
-- weight-preserving harmonic-binomial expansions.

/-- The generalized harmonic number `H_{n-1}^{(r)} = Σ_{k=1}^{n-1} 1/k^r`. -/
noncomputable def genHarmonic (r n : ℕ) : ℝ :=
  ∑ k ∈ Finset.Ico 1 n, 1 / (k : ℝ) ^ r

/-- The real central binomial coefficient `C(2n,n)`. -/
noncomputable def centralBinomReal (n : ℕ) : ℝ :=
  (Nat.choose (2 * n) n : ℝ)

/-- **PROVED.** `H_0^{(r)} = 0` — the empty harmonic sum. -/
theorem genHarmonic_one (r : ℕ) : genHarmonic r 1 = 0 := by
  simp [genHarmonic]

/-- **PROVED.** `H_1^{(r)} = 1`. -/
theorem genHarmonic_two (r : ℕ) : genHarmonic r 2 = 1 := by
  unfold genHarmonic
  rw [show Finset.Ico 1 2 = ({1} : Finset ℕ) from by decide,
    Finset.sum_singleton]
  norm_num

/--
**Named target — the ζ(5) Apéry-binomial identity.**
`ζ(5) = 2·Σ (−1)^{n−1}/(n⁵C(2n,n)) − (5/2)·Σ (−1)^{n−1}H_{n−1}^{(2)}/(n³C(2n,n))`.
The first harmonic correction `H^(2)` appears.
-/
structure ZetaFiveBinomialIdentity where
  identity :
    (riemannZeta 5).re =
      2 * ∑' n : ℕ,
          (-1 : ℝ) ^ n
            / (((n : ℝ) + 1) ^ 5 * centralBinomReal (n + 1))
        - (5 / 2 : ℝ) * ∑' n : ℕ,
          (-1 : ℝ) ^ n * genHarmonic 2 (n + 1)
            / (((n : ℝ) + 1) ^ 3 * centralBinomReal (n + 1))

/--
**Named target — the ζ(7) Apéry-binomial identity.**
`ζ(7) = Σ (−1)^{n−1}/C(2n,n)·[2/n⁷ − 2H²/n⁵ − (5/4)H⁴/n³ + (5/4)(H²)²/n³]`.
-/
structure ZetaSevenBinomialIdentity where
  identity :
    (riemannZeta 7).re =
      ∑' n : ℕ,
        (-1 : ℝ) ^ n / centralBinomReal (n + 1)
          * (2 / ((n : ℝ) + 1) ^ 7
             - 2 * genHarmonic 2 (n + 1) / ((n : ℝ) + 1) ^ 5
             - (5 / 4) * genHarmonic 4 (n + 1) / ((n : ℝ) + 1) ^ 3
             + (5 / 4) * (genHarmonic 2 (n + 1)) ^ 2
                 / ((n : ℝ) + 1) ^ 3)

/--
**Named target — the ζ(9) Apéry-binomial identity.**
`ζ(9) = Σ (−1)^{n−1}/C(2n,n)·[2/n⁹ − 2H²/n⁷ − H⁴/n⁵ + (H²)²/n⁵
  − (5/6)H⁶/n³ + (5/4)H²H⁴/n³ − (5/12)(H²)³/n³]`.
-/
structure ZetaNineBinomialIdentity where
  identity :
    (riemannZeta 9).re =
      ∑' n : ℕ,
        (-1 : ℝ) ^ n / centralBinomReal (n + 1)
          * (2 / ((n : ℝ) + 1) ^ 9
             - 2 * genHarmonic 2 (n + 1) / ((n : ℝ) + 1) ^ 7
             - genHarmonic 4 (n + 1) / ((n : ℝ) + 1) ^ 5
             + (genHarmonic 2 (n + 1)) ^ 2 / ((n : ℝ) + 1) ^ 5
             - (5 / 6) * genHarmonic 6 (n + 1) / ((n : ℝ) + 1) ^ 3
             + (5 / 4) * genHarmonic 2 (n + 1) * genHarmonic 4 (n + 1)
                 / ((n : ℝ) + 1) ^ 3
             - (5 / 12) * (genHarmonic 2 (n + 1)) ^ 3
                 / ((n : ℝ) + 1) ^ 3)

/--
**Named target — the sparse ζ(11) Apéry-binomial identity.** PSLQ
found a surprisingly sparse form involving only `H^(4)` and `H^(8)`:
`ζ(11) = Σ (−1)^{n−1}/C(2n,n)·[(5/2)/n¹¹ + (25/2)H⁴/n⁷
  − (75/4)H⁸/n³ + (125/4)(H⁴)²/n³]`.
-/
structure ZetaElevenBinomialIdentity where
  identity :
    (riemannZeta 11).re =
      ∑' n : ℕ,
        (-1 : ℝ) ^ n / centralBinomReal (n + 1)
          * ((5 / 2) / ((n : ℝ) + 1) ^ 11
             + (25 / 2) * genHarmonic 4 (n + 1) / ((n : ℝ) + 1) ^ 7
             - (75 / 4) * genHarmonic 8 (n + 1) / ((n : ℝ) + 1) ^ 3
             + (125 / 4) * (genHarmonic 4 (n + 1)) ^ 2
                 / ((n : ℝ) + 1) ^ 3)

/--
**Named target — the general Apéry harmonic-binomial tower.**
`ζ(2m+3) = Σ (−1)^{n−1}/C(2n,n)·P_m(1/n, H^(2), H^(4), …)` where `P_m`
is a weight-`(2m+3)`-preserving rational polynomial in the even
generalized harmonic numbers. `bracketValue m` is the binomial-harmonic
sum value for odd weight `2m+3`.
-/
structure AperyHarmonicTower where
  bracketValue : ℕ → ℝ
  weightPreserving : Prop
  recursiveCoefficientLaw : Prop
  towerIdentity :
    ∀ m : ℕ, (riemannZeta (2 * (m : ℂ) + 3)).re = bracketValue m

/--
The **odd-zeta Apéry tower**: the central-binomial / harmonic-sum
identities for `ζ(3), ζ(5), ζ(7), ζ(9), ζ(11)` and the general tower —
the combinatorial face where irrationality proofs live.
-/
structure OddZetaAperyTower where
  zetaThree : AperyBinomialSeries
  zetaFive : ZetaFiveBinomialIdentity
  zetaSeven : ZetaSevenBinomialIdentity
  zetaNine : ZetaNineBinomialIdentity
  zetaEleven : ZetaElevenBinomialIdentity
  tower : AperyHarmonicTower

/-- **PROVED.** Each odd zeta value `ζ(2m+3)` equals its
binomial-harmonic bracket value, extracted from the Apéry tower. -/
theorem oddZeta_eq_bracket_of_tower
    (T : OddZetaAperyTower) (m : ℕ) :
    (riemannZeta (2 * (m : ℂ) + 3)).re = T.tower.bracketValue m :=
  T.tower.towerIdentity m

-- === Phase XXXI: The Master Generating Function ===
-- The Koecher–Leshchiner / Almkvist–Granville generating function: a
-- SINGLE product produces the whole Apéry-binomial tower. The finite
-- product ∏(1−z²/m²) expands into the even harmonic numbers — which is
-- exactly why the harmonic towers of Phase XXX appeared.

/-- The finite Apéry product `∏_{m=1}^{n-1} (1 − z²/m²)`. -/
noncomputable def aperyProduct (z : ℝ) (n : ℕ) : ℝ :=
  ∏ m ∈ Finset.Ico 1 n, (1 - z ^ 2 / (m : ℝ) ^ 2)

/-- **PROVED.** The empty Apéry product `∏_{m=1}^{0} = 1`. -/
theorem aperyProduct_one (z : ℝ) : aperyProduct z 1 = 1 := by
  simp [aperyProduct]

/-- **PROVED.** `∏_{m=1}^{1} (1 − z²/m²) = 1 − z²`. -/
theorem aperyProduct_two (z : ℝ) : aperyProduct z 2 = 1 - z ^ 2 := by
  unfold aperyProduct
  rw [show Finset.Ico 1 2 = ({1} : Finset ℕ) from by decide,
    Finset.prod_singleton]
  norm_num

/-- The Apéry generating-function summand at term `n`:
`(−1)^{n−1}/(n³C(2n,n))·(5n²−z²)/(n²−z²)·∏(1−z²/m²)`. -/
noncomputable def aperyGenTerm (z : ℝ) (n : ℕ) : ℝ :=
  (-1 : ℝ) ^ n
    / (((n : ℝ) + 1) ^ 3 * centralBinomReal (n + 1))
    * ((5 * ((n : ℝ) + 1) ^ 2 - z ^ 2)
        / (((n : ℝ) + 1) ^ 2 - z ^ 2))
    * aperyProduct z (n + 1)

/--
The **Apéry / Koecher–Leshchiner generating function**
`(1/2)·Σ_{n≥1} (−1)^{n−1}/(n³C(2n,n))·(5n²−z²)/(n²−z²)·∏_{m=1}^{n−1}(1−z²/m²)`.
The single product that generates the whole odd-zeta tower.
-/
noncomputable def aperyGeneratingFunction (z : ℝ) : ℝ :=
  (1 / 2 : ℝ) * ∑' n : ℕ, aperyGenTerm z n

/--
**Named target — the master generating-function identity.**
`Σ_{k≥0} ζ(2k+3)·z^{2k} = aperyGeneratingFunction z` for `|z| < 1`.
The left side's coefficient of `z^{2k}` is `ζ(2k+3)`.
-/
structure OddZetaGeneratingFunction where
  identity :
    ∀ z : ℝ, |z| < 1 →
      ∑' k : ℕ, (riemannZeta (2 * (k : ℂ) + 3)).re * z ^ (2 * k)
        = aperyGeneratingFunction z

/--
**Named target — the bracket-polynomial extraction.** For each `k`,
`ζ(2k+3) = Σ_n (−1)^{n−1}/C(2n,n)·P_k(n)`, where `bracketPoly k n` is
the coefficient of `z^{2k}` in the master kernel — a weight-preserving
rational polynomial in `1/n` and the even harmonic numbers.
-/
structure AperyBracketExtraction where
  bracketPoly : ℕ → ℕ → ℝ
  identity :
    ∀ k : ℕ,
      (riemannZeta (2 * (k : ℂ) + 3)).re =
        ∑' n : ℕ,
          (-1 : ℝ) ^ n / centralBinomReal (n + 1)
            * bracketPoly k n

/--
The **Koecher–Leshchiner master**: the generating-function identity,
the bracket extraction, and the explicit Apéry tower of Phase XXX —
the complete hidden combinatorial machine behind the odd zeta values.
-/
structure KoecherLeshchinerMaster where
  generatingFunction : OddZetaGeneratingFunction
  bracketExtraction : AperyBracketExtraction
  aperyTower : OddZetaAperyTower

/-- **PROVED.** Each odd zeta value is the central-binomial bracket
sum, extracted from the master generating function. -/
theorem oddZeta_eq_bracketSum_of_master
    (M : KoecherLeshchinerMaster) (k : ℕ) :
    (riemannZeta (2 * (k : ℂ) + 3)).re =
      ∑' n : ℕ,
        (-1 : ℝ) ^ n / centralBinomReal (n + 1)
          * M.bracketExtraction.bracketPoly k n :=
  M.bracketExtraction.identity k

/-- **PROVED.** The master generating-function identity holds for every
admissible `z`, extracted from the master. -/
theorem generatingFunction_identity_of_master
    (M : KoecherLeshchinerMaster) {z : ℝ} (hz : |z| < 1) :
    ∑' k : ℕ, (riemannZeta (2 * (k : ℂ) + 3)).re * z ^ (2 * k)
      = aperyGeneratingFunction z :=
  M.generatingFunction.identity z hz

-- === Phase XXXII: Analytic vs Arithmetic Error — the Irrationality Wall ===
-- Irrationality needs the ANALYTIC error to beat the ARITHMETIC
-- denominator clearing. For ζ(3) it does: `e³·(√2−1)⁴ < 1` (PROVED).
-- For ζ(5) the harmonic burden overwhelms it, and ζ(5) couples to
-- ζ(2)ζ(3) — peeling `ζ(2) − H_{n-1}^{(2)}` exposes the residue.

/-- **PROVED.** `(√2−1)⁴ = 17 − 12√2`. -/
theorem sqrt_two_sub_one_pow_four :
    (Real.sqrt 2 - 1) ^ 4 = 17 - 12 * Real.sqrt 2 := by
  have hs2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num)
  linear_combination
    (Real.sqrt 2 ^ 2 - 4 * Real.sqrt 2 + 8) * hs2

/-- The **Apéry cleared rate** `e³·(√2−1)⁴`: it governs whether ζ(3)'s
denominator-cleared linear forms still vanish. -/
noncomputable def aperyClearedRate : ℝ :=
  Real.exp 3 * (Real.sqrt 2 - 1) ^ 4

/--
**PROVED — why ζ(3) works.** `e³·(√2−1)⁴ < 1`. The analytic error decay
`(√2−1)^{4n}` beats the denominator-clearing growth `Lₙ³ ∼ e^{3n}`, so
the cleared Apéry linear forms `Lₙ³·(Aₙζ(3) − Bₙ)` still tend to zero —
this is the engine of Apéry's irrationality proof.
-/
theorem aperyClearedRate_lt_one : aperyClearedRate < 1 := by
  unfold aperyClearedRate
  have hs2 : Real.sqrt 2 ^ 2 = 2 := Real.sq_sqrt (by norm_num)
  have hsnn : (0 : ℝ) ≤ Real.sqrt 2 := Real.sqrt_nonneg 2
  have hslo : (1.41421356 : ℝ) < Real.sqrt 2 := by nlinarith [hs2, hsnn]
  have hshi : Real.sqrt 2 < (1.41421357 : ℝ) := by nlinarith [hs2, hsnn]
  have hpow : (Real.sqrt 2 - 1) ^ 4 = 17 - 12 * Real.sqrt 2 :=
    sqrt_two_sub_one_pow_four
  have he1 : Real.exp 1 < 2.7182818286 := Real.exp_one_lt_d9
  have he1pos : (0 : ℝ) < Real.exp 1 := Real.exp_pos 1
  have he3 : Real.exp 3 = Real.exp 1 * (Real.exp 1 * Real.exp 1) := by
    rw [show (3 : ℝ) = 1 + (1 + 1) by norm_num,
      Real.exp_add, Real.exp_add]
  have hsq : Real.exp 1 * Real.exp 1 < 7.39 := by
    nlinarith [he1, he1pos]
  have hexp3 : Real.exp 3 < 21 := by
    rw [he3]
    nlinarith [he1, he1pos, hsq, mul_pos he1pos he1pos]
  have hexp3pos : (0 : ℝ) < Real.exp 3 := Real.exp_pos 3
  rw [hpow]
  have hbpos : (0 : ℝ) < 17 - 12 * Real.sqrt 2 := by nlinarith [hshi]
  have hbhi : 17 - 12 * Real.sqrt 2 < 0.0295 := by nlinarith [hslo]
  nlinarith [hexp3, hexp3pos, hbpos, hbhi]

/-- The two errors in an irrationality attack: analytic (convergence
speed) and arithmetic (denominator growth). Irrationality requires the
*cleared* error — denominator times analytic error — to vanish. -/
structure AnalyticVsArithmeticError where
  analyticError : ℕ → ℝ
  arithmeticDenominator : ℕ → ℝ
  clearedError : ℕ → ℝ
  cleared_eq :
    ∀ n, clearedError n = arithmeticDenominator n * analyticError n
  irrationalityNeedsClearedToZero : Prop

/-- **Named target — ζ(3)'s cleared forms vanish.** The cleared Apéry
linear forms `Lₙ³·(Aₙζ(3) − Bₙ)` tend to `0`, at the rate governed by
`aperyClearedRate < 1`. -/
structure ZetaThreeClearedFormsVanish where
  linearForm : ℕ → ℝ
  tendsToZero :
    Filter.Tendsto linearForm Filter.atTop (nhds 0)
  rateGovernedByAperyConstant : Prop

/-- The harmonic-two tail `Σ_{k≥n} 1/k²`. -/
noncomputable def harmonicTwoTail (n : ℕ) : ℝ :=
  ∑' k : ℕ, 1 / ((k : ℝ) + n) ^ 2

/-- A central-binomial power sum `Σ_{n≥1} (−1)^{n−1}/(C(2n,n)·n^r)` —
the simpler objects the peeled ζ(5) residue reduces to. -/
noncomputable def centralBinomPowerSum (r : ℕ) : ℝ :=
  ∑' n : ℕ,
    (-1 : ℝ) ^ n
      / (centralBinomReal (n + 1) * ((n : ℝ) + 1) ^ r)

/-- **Named target — the harmonic-tail identity.**
`ζ(2) − H_{n-1}^{(2)} = Σ_{k≥n} 1/k²` — the residue after the leading
`ζ(2)ζ(3)` cancellation. -/
structure HarmonicTwoTailIdentity where
  identity :
    ∀ n : ℕ, 0 < n →
      (riemannZeta 2).re - genHarmonic 2 n = harmonicTwoTail n

/--
**Named target — the Euler–Maclaurin expansion of the harmonic tail.**
`ζ(2) − H_{n-1}^{(2)} = 1/n + 1/(2n²) + 1/(6n³) − 1/(30n⁵) + 1/(42n⁷) − …`
— the Bernoulli expansion peeling the ζ(5) tail open term by term.
-/
structure HarmonicTwoTailEulerMaclaurin where
  bernoulliCoefficient : ℕ → ℝ
  leadingTerms : ℕ → ℕ → ℝ
  asymptoticExpansion : Prop
  remainderBound : Prop

/--
**Named target — the exact ζ(5) ↔ ζ(2)ζ(3) coupled identity.**
`ζ(5) + ζ(2)·ζ(3) = Σ (−1)^{n−1}/C(2n,n)·[2/n⁵ + (5/(2n³))(ζ(2) − H_{n-1}^{(2)})]`.
The leading `−ζ(2)ζ(3)` leakage is cancelled; the residue has a far
smaller tail.
-/
structure ZetaFivePlusZetaTwoZetaThreeIdentity where
  identity :
    (riemannZeta 5).re + (riemannZeta 2).re * (riemannZeta 3).re =
      ∑' n : ℕ,
        (-1 : ℝ) ^ n / centralBinomReal (n + 1)
          * (2 / ((n : ℝ) + 1) ^ 5
             + (5 / (2 * ((n : ℝ) + 1) ^ 3))
               * ((riemannZeta 2).re - genHarmonic 2 (n + 1)))

/--
**Named target — the peeled ζ(5) residue expansion.** After the
`ζ(2)ζ(3)` cancellation the new leading tail is `5/(2n⁴)`, with the
fully predictable continuation `+ 13/(4n⁵) + 5/(12n⁶) − 1/(12n⁸) + …`.
-/
structure ZetaFiveResidueExpansion where
  residueCoefficient : ℕ → ℝ
  leadingTailIsFiveOverTwoNFour : Prop
  centralBinomReducible : Prop

/--
**Named target — the ζ(5) ↔ ζ(2)ζ(3) coupling.** The ratio of the ζ(5)
Apéry bracket to the ζ(3) bracket tends to `−ζ(2)`; so ζ(5) is NOT
isolated — it couples to `ζ(2)ζ(3)` at weight 5.
-/
structure ZetaFiveZetaTwoZetaThreeCoupling where
  bracketRatio : ℕ → ℝ
  ratio_tendsto :
    Filter.Tendsto bracketRatio Filter.atTop
      (nhds (-(riemannZeta 2).re))
  leadingTailCancels : Prop

/--
**Named target — the weight-5 period space.** Weight 5 is spanned by
`1, ζ(3), ζ(5), ζ(2)ζ(3)` — ζ(5) lives in a larger period space than
ζ(3) (which has no lower product, since ζ(1) diverges).
-/
structure Weight5PeriodSpace where
  basis : Fin 4 → ℝ
  basis_eq :
    basis 0 = 1 ∧ basis 1 = (riemannZeta 3).re
      ∧ basis 2 = (riemannZeta 5).re
      ∧ basis 3 = (riemannZeta 2).re * (riemannZeta 3).re

/--
**Named target — the ζ(5) linear-form attack.** Integer forms
`Uₙ·ζ(5) + Vₙ·ζ(3) + Wₙ` that tend to `0` — the Ball–Rivoal/Zudilin
route: ζ(5) needs simultaneous period control, not a 1-D Apéry trick.
-/
structure ZetaFiveLinearFormAttack where
  U : ℕ → ℤ
  V : ℕ → ℤ
  W : ℕ → ℤ
  form : ℕ → ℝ
  form_eq :
    ∀ n, form n =
      (U n : ℝ) * (riemannZeta 5).re
        + (V n : ℝ) * (riemannZeta 3).re + (W n : ℝ)
  formTendsToZero :
    Filter.Tendsto form Filter.atTop (nhds 0)

/--
The **irrationality-wall diagnosis**: the analytic/arithmetic error
split, why ζ(3) works (`aperyClearedRate < 1`), the ζ(5) harmonic
obstruction, its coupling to ζ(2)ζ(3), the peeled residue, and the
linear-form battlefield.
