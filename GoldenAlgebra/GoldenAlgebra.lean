  builtFromExplicitFormula : Prop

-- Step 219: the classical Weil positivity criterion, honest form.

/--
**`ClassicalWeilPositivityCriterion`** — the classical Weil positivity
criterion in fully honest form. The `positivity` field is NOT a `Prop`
placeholder: it is the genuine quantified inequality
`∀ f admissible, 0 ≤ Q(f)`. Constructing an inhabitant of this
structure means the RH-hard checkbox has actually been proved.
-/
structure ClassicalWeilPositivityCriterion where
  weilForm : ConcreteWeilQuadraticForm
  admissible : RiemannWeilTestFunction → Prop
  positivity :
    ∀ f : RiemannWeilTestFunction,
      admissible f → 0 ≤ weilForm.quadraticForm f

/--
The classical Weil-positivity target: the proposition that the Weil
positivity criterion has been established. This is **the** RH-hard
checkbox, in its honest fully-quantified form.
-/
def ClassicalWeilPositivityTarget : Prop :=
  Nonempty ClassicalWeilPositivityCriterion

/--
Extracts the genuine positivity inequality from a classical Weil
positivity criterion — confirming the `positivity` field really is the
quantified statement `∀ f admissible, 0 ≤ Q(f)`.
-/
theorem ClassicalWeilPositivityCriterion.positivity_holds
    (W : ClassicalWeilPositivityCriterion)
    (f : RiemannWeilTestFunction) (hf : W.admissible f) :
    0 ≤ W.weilForm.quadraticForm f :=
  W.positivity f hf

-- === Final One-Shot RH Theorem Interface (Steps 220-224) ===
-- The clean honest endpoint: supply the two missing inputs (a
