-- =========================================================================
-- Twisted rings: per-ring phase offsets
-- =========================================================================

/-- **Twisted ring vertex.** `q_{k,n} = r_k · exp(i (2π n / P + θ_k))`,
where `θ_k` is the per-ring phase offset. The Tier 109 `ringPoint`
is recovered at `θ_k = 0`. -/
noncomputable def twistedRingPoint
    {K P : ℕ} (r θ : Fin K → ℝ) (k : Fin K) (n : Fin P) : ℂ :=
  ((r k : ℝ) : ℂ) *
    Complex.exp ((2 * Real.pi * (n : ℝ) / (P : ℝ) + θ k : ℝ) * I)

theorem twistedRingPoint_zero_phase
    {K P : ℕ} (r : Fin K → ℝ) (k : Fin K) (n : Fin P) :
    twistedRingPoint r (fun _ => (0 : ℝ)) k n = ringPoint r k n := by
  unfold twistedRingPoint ringPoint
  congr 2
  push_cast
  ring

/-- **Twisted-ring configuration.** Bundle the radii, masses, and phase
offsets of a twisted-ring central-configuration candidate. -/
structure TwistedRingConfig (K : ℕ) where
  r : Fin K → ℝ
  μ : Fin K → ℝ
  θ : Fin K → ℝ
  r_pos : ∀ k, 0 < r k
  μ_pos : ∀ k, 0 < μ k

namespace TwistedRingConfig

variable {K : ℕ} (T : TwistedRingConfig K)

/-- The full `K · P`-body twisted-ring configuration. -/
noncomputable def configuration
    {P : ℕ} (hP : 0 < P) : Fin (K * P) → ℂ :=
  fun i =>
    let kval := i.val / P
    let nval := i.val % P
    have hi : i.val < K * P := i.isLt
    have hk : kval < K := by
      have h1 : kval * P ≤ i.val := Nat.div_mul_le_self i.val P
      by_contra h_neg
      push_neg at h_neg
      have h2 : K * P ≤ kval * P := Nat.mul_le_mul_right P h_neg
      omega
    have hn : nval < P := Nat.mod_lt i.val hP
    twistedRingPoint (P := P) T.r T.θ ⟨kval, hk⟩ ⟨nval, hn⟩

end TwistedRingConfig

