The de Branges route says: find the **missing companion** `B` such
that

  `E = Ξ − i·B`

is a Hermite–Biehler entire function. Then `E` generates a de Branges
space, and the Hilbert–Pólya operator appears as **multiplication by
the variable** in that space.

This is the first genuine *operator-construction branch* (as opposed
to a sieve branch): a positive analytic mechanism producing the
operator, not just gates excluding fakes.

The parity is the crux: `Ξ` even and `B` odd means `E` carries *both*
halves of the functional equation. The flagship identity

  `E(−z) = Ξ(z) + i·B(z)`

(`CompanionFunction.reflection_formula`) is the baby form of the de
Branges conjugation symmetry.

Components:
* `HermiteBiehlerFunction` — the de Branges positivity gate.
* `CompanionFunction` — the missing odd half `B`, with `E = Ξ − iB`.
* `DeBrangesCompanionGate` — companion + Hermite–Biehler.
* `DeBrangesSpaceModel` / `DeBrangesOperatorModel` — the space and the
  self-adjoint multiplication operator.
* `DeBrangesFeeder` — wires the de Branges route into the Diamond.
* `evenPartC` / `oddPartC` + `CompanionFunction.reflection_formula` —
  the companion parity algebra.
-/

-- --- Tier 36.1 — Hermite–Biehler positivity gate --------------------

/-- **Hermite–Biehler function.** `E` satisfies the upper-half-plane
dominance `|E#(z)| < |E(z)|` (`Im z > 0`) needed to generate a de
Branges space. Kept abstract as the de Branges positivity gate. -/
structure HermiteBiehlerFunction (E : ℂ → ℂ) where
  /-- Upper-half-plane dominance of `E` over its reflection `E#`. -/
  upperHalfPlaneDominance : Prop
  /-- No degeneracy on the real axis. -/
  noRealDegeneracy : Prop

-- --- Tier 36.2 — Companion function ---------------------------------

/-- **Companion function.** The missing odd half `B` of `Ξ`, forming
the Hermite–Biehler entire function `E = Ξ − i·B`. The parity
constraint — `Ξ` mirror-even, `B` odd — makes `E` carry both halves
of the functional equation. -/
structure CompanionFunction (Xi B E : ℂ → ℂ) where
  /-- `E = Ξ − i·B`. -/
  companionIdentity : ∀ z : ℂ, E z = Xi z - Complex.I * B z
  /-- `Ξ` is mirror-even. -/
  xiMirrorEven : MirrorEvenFunction Xi
  /-- `B` is odd. -/
  companionMirrorOdd : OddFunctionC B

-- --- Tier 36.3 — de Branges companion gate --------------------------

/-- **de Branges companion gate.** `Ξ` admits a companion `B` such
that `E = Ξ − i·B` is Hermite–Biehler. -/
structure DeBrangesCompanionGate (Xi : ℂ → ℂ) where
  /-- The companion (odd) half. -/
  B : ℂ → ℂ
  /-- The Hermite–Biehler function `E`. -/
  E : ℂ → ℂ
  /-- `E = Ξ − iB` with the parity constraints. -/
  companion : CompanionFunction Xi B E
  /-- `E` is Hermite–Biehler. -/
  hermiteBiehler : HermiteBiehlerFunction E

/-- Passing the de Branges companion gate carries the mirror
functional equation for `Ξ`. -/
theorem DeBrangesCompanionGate.mirrorEven
    {Xi : ℂ → ℂ} (G : DeBrangesCompanionGate Xi) :
    MirrorEvenFunction Xi :=
  G.companion.xiMirrorEven

/-- The companion of a de Branges gate is odd. -/
theorem DeBrangesCompanionGate.companionOdd
    {Xi : ℂ → ℂ} (G : DeBrangesCompanionGate Xi) :
    OddFunctionC G.B :=
  G.companion.companionMirrorOdd

/-- **No-go**: a non-mirror-even target cannot pass the de Branges
companion gate. -/
theorem no_DeBrangesCompanionGate_of_not_mirrorEven
    {Xi : ℂ → ℂ} (hNot : ¬ MirrorEvenFunction Xi) :
    DeBrangesCompanionGate Xi → False :=
  fun G => hNot G.mirrorEven

-- --- Tier 36.4 — de Branges space and operator model ----------------

/-- **de Branges space model** generated by a Hermite–Biehler
function `E`. -/
structure DeBrangesSpaceModel (E : ℂ → ℂ) where
  /-- The underlying space. -/
  space : Type
  /-- It carries a Hilbert structure. -/
  hilbertStructure : Prop
  /-- Its reproducing kernel is positive. -/
  reproducingKernelPositive : Prop
  /-- Multiplication by the variable is symmetric. -/
  multiplicationSymmetric : Prop

/-- **de Branges operator model.** The self-adjoint multiplication
operator arising from the de Branges space of `E = Ξ − iB`: the
concrete Hilbert–Pólya mechanism. -/
structure DeBrangesOperatorModel (Xi : ℂ → ℂ) where
  /-- The companion gate. -/
  gate : DeBrangesCompanionGate Xi
  /-- The de Branges space of `E`. -/
  spaceModel : DeBrangesSpaceModel gate.E
  /-- The self-adjoint extension of multiplication. -/
  selfAdjointExtension : Prop
  /-- Its spectrum matches the zeros of `Ξ`. -/
  spectralZerosMatchXi : Prop

/-- **Hermite–Biehler obstruction** for a function `E`. -/
def HermiteBiehlerObstruction (E : ℂ → ℂ) : Prop :=
  HermiteBiehlerFunction E → False

/-- **No-go**: if *every* companion `B` makes `E = Ξ − iB` fail
Hermite–Biehler, then no de Branges operator model exists for `Ξ`.
The strongest de Branges falsification pattern. -/
theorem no_DeBrangesOperatorModel_of_HB_obstruction
    {Xi : ℂ → ℂ}
    (hObs : ∀ B E : ℂ → ℂ,
      CompanionFunction Xi B E → HermiteBiehlerObstruction E) :
    DeBrangesOperatorModel Xi → False :=
  fun M => hObs M.gate.B M.gate.E M.gate.companion M.gate.hermiteBiehler

-- --- Tier 36.5 — Companion parity algebra ---------------------------

/-- The **even part** of a complex function: `(F z + F(−z))/2`. -/
noncomputable def evenPartC (F : ℂ → ℂ) : ℂ → ℂ :=
  fun z => (F z + F (-z)) / 2

/-- The **odd part** of a complex function: `(F z − F(−z))/2`. -/
noncomputable def oddPartC (F : ℂ → ℂ) : ℂ → ℂ :=
  fun z => (F z - F (-z)) / 2

/-- The even part is mirror-even. -/
theorem evenPartC_mirrorEven (F : ℂ → ℂ) :
    MirrorEvenFunction (evenPartC F) := by
  intro z
  unfold evenPartC
  rw [neg_neg]
  ring

/-- The odd part is odd. -/
theorem oddPartC_odd (F : ℂ → ℂ) :
    OddFunctionC (oddPartC F) := by
  intro z
  unfold oddPartC
  rw [neg_neg]
  ring

/-- The **mirror reflection** of `E`: `z ↦ E(−z)`. -/
def sharpMirror (E : ℂ → ℂ) : ℂ → ℂ :=
  fun z => E (-z)

/-- **Flagship — the companion reflection formula.**

`E(−z) = Ξ(z) + i·B(z)`. The mirror reflection of the Hermite–Biehler
function recovers the *conjugate* half of the de Branges pair. This is
the baby form of the de Branges conjugation symmetry: `E#` differs
from `E` exactly by flipping the sign of the companion term. -/
theorem CompanionFunction.reflection_formula
    {Xi B E : ℂ → ℂ} (C : CompanionFunction Xi B E) :
    ∀ z : ℂ, E (-z) = Xi z + Complex.I * B z := by
  intro z
  rw [C.companionIdentity (-z), C.xiMirrorEven z, C.companionMirrorOdd z]
  ring

-- --- Tier 36.6 — de Branges feeder into the Diamond -----------------

/-- **de Branges feeder.** A de Branges operator model together with
the real-rooted polynomial approximation it produces — wiring the de
Branges route into the Tier-21 dispatcher. -/
structure DeBrangesFeeder (Xi : ℂ → ℂ) where
  /-- The de Branges operator model (the construction). -/
  operatorModel : DeBrangesOperatorModel Xi
  /-- The real-rooted polynomial approximation it yields. -/
  realRootedApproximation : RealRootedPolynomialApproximation Xi

/-- A de Branges feeder upgrades to a Hermitian determinant
approximation (via the Tier-21 bridge). -/
noncomputable def DeBrangesFeeder.toHermitianApproximation
    {Xi : ℂ → ℂ} (F : DeBrangesFeeder Xi) :
    HermitianDeterminantApproximation Xi :=
  F.realRootedApproximation.toHermitianApproximation

/-- **de Branges Diamond limit.** A de Branges feeder yields the
Diamond real-zero conclusion, conditional only on the abstract Hurwitz
transfer principle. The de Branges construction branch reaches the
same endpoint as the Golden Hankel and Jacobi feeders. -/
theorem deBranges_diamond_limit
    {Xi : ℂ → ℂ}
    (F : DeBrangesFeeder Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyRealZeros Xi :=
  realRooted_diamond_limit F.realRootedApproximation hHurwitz

-- --- Tier 36.7 — de Branges survivor integration --------------------

/-- **de Branges extreme survivor.** An extreme survivor whose operator
is constructed by the de Branges companion mechanism. -/
structure DeBrangesExtremeSurvivor
    (Xi : ℂ → ℂ) (Eigen : ℝ → Prop)
    (D Response : ℂ → ℂ) (Dreal : ℝ → ℂ)
    (Lambda : ℕ → ℝ) (Count : ℝ → ℝ) (TestFunction : Type) where
  /-- The underlying extreme survivor stack. -/
  extreme : ExtremeHPSurvivorStack Xi Eigen D Response Dreal Lambda Count TestFunction
  /-- The de Branges operator model. -/
  deBranges : DeBrangesOperatorModel Xi

/-- A de Branges extreme survivor carries the mirror functional
equation, sourced from its companion gate. -/
theorem DeBrangesExtremeSurvivor.mirrorEven_from_companion
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {D Response : ℂ → ℂ} {Dreal : ℝ → ℂ}
    {Lambda : ℕ → ℝ} {Count : ℝ → ℝ} {TestFunction : Type}
    (S : DeBrangesExtremeSurvivor Xi Eigen D Response Dreal Lambda Count TestFunction) :
    MirrorEvenFunction Xi :=
  S.deBranges.gate.mirrorEven

