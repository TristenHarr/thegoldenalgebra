-- === Phase LXIX: Digamma / Cotangent Node-Filter Machine ===
-- The digamma "Alternating Power Compression Series":
--   S_n = ∑_{k≥1} (n^k − 1)/(n+1)^k · ζ(k+1)
--       = ψ(n/(n+1)) − ψ(1/(n+1))                          (digamma identity)
--       = π·cot(π/(n+1))                                    (digamma reflection)
-- The coefficient of ζ(k+1) is a_n(k) = (n^k − 1)/(n+1)^k.
-- For odd zetas, a_n(2m) = (n^{2m} − 1)/(n+1)^{2m}.
-- The (2,3,5) NODE FILTER with weights [-58, 64, -19] kills ζ(3) and
-- ζ(7), leaves ζ(5) with coefficient 1/9 — all four facts PROVED below
-- as pure rational arithmetic by `norm_num`. A new filter direction
-- complementing the b-stack filters: filter on NODE PARAMETERS.

/-- The odd-zeta coefficient `a_n(k) = (n^k − 1)/(n+1)^k`, as a
rational. For odd zetas use even `k = 2m`. -/
def digammaCompressionCoeff (n k : ℕ) : ℚ :=
  ((n : ℚ)^k - 1) / ((n + 1 : ℚ)^k)

/-- Shorthand. -/
local notation "aN" => digammaCompressionCoeff

/-- **PROVED — the (2,3,5) filter kills ζ(3).** With weights
`[-58, 64, -19]` at nodes `n = 2, 3, 5`, the combined coefficient of
ζ(3) (i.e. `k = 2`) is exactly zero. -/
theorem filter_235_kills_zeta3 :
    (-58 : ℚ) * aN 2 2 + 64 * aN 3 2 - 19 * aN 5 2 = 0 := by
  unfold digammaCompressionCoeff
  norm_num

/-- **PROVED — the (2,3,5) filter leaves ζ(5) with coefficient `1/9`.** -/
theorem filter_235_keeps_zeta5 :
    (-58 : ℚ) * aN 2 4 + 64 * aN 3 4 - 19 * aN 5 4 = 1/9 := by
  unfold digammaCompressionCoeff
  norm_num

/-- **PROVED — the (2,3,5) filter kills ζ(7).** -/
theorem filter_235_kills_zeta7 :
    (-58 : ℚ) * aN 2 6 + 64 * aN 3 6 - 19 * aN 5 6 = 0 := by
  unfold digammaCompressionCoeff
  norm_num

/-- **PROVED — the (2,3,5) filter ζ(9) tail coefficient is
`−6223/23328`.** Verified by rational arithmetic. -/
theorem filter_235_zeta9_tail :
    (-58 : ℚ) * aN 2 8 + 64 * aN 3 8 - 19 * aN 5 8 = -6223/23328 := by
  unfold digammaCompressionCoeff
  norm_num

/-- **PROVED — the (2,3,5) filter ζ(11) tail coefficient is
`−6307675/13436928`.** Verified by rational arithmetic. -/
theorem filter_235_zeta11_tail :
    (-58 : ℚ) * aN 2 10 + 64 * aN 3 10 - 19 * aN 5 10
      = -6307675/13436928 := by
  unfold digammaCompressionCoeff
  norm_num

