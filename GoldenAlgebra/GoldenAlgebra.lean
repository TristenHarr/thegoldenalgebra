/-!
## Tier 37 — Phase / Companion / Canonical System Gate

Tier 36 made the companion `B` *exist* (`E = Ξ − iB` Hermite–Biehler).
Tier 37 makes it **non-arbitrary**: the companion must generate the
right phase, counting law, response parity, prime trace, and — the
likely true operator source — a **canonical system**.

de Branges spaces are canonically produced by canonical systems
(positive-semidefinite Hamiltonian `H(x)`). The self-adjoint operator
is the canonical-system transfer/Dirac operator; its de Branges space
is exactly the Tier-36 space. Tier 37 wires this in and adds the phase
→ counting and companion → response → prime-trace bridges.

Components:
* `DeBrangesPhaseLaw` / `PhaseCountingLaw` / `PhaseDeBrangesSurvivor` —
  the phase controls the spectral counting function.
* `CompanionResponseLaw` — the companion generates the determinant
  response; with obstruction `no_CompanionResponseLaw_of_response_not_odd`.
* `ArithmeticDeBrangesSurvivor` — the de Branges branch must hear
  primes; with the flagship prime-trace-parity obstruction.
* `CanonicalHamiltonian` / `CanonicalSystemModel` /
  `CanonicalSystemHPModel` — the canonical-system operator source,
  with `no_CanonicalSystemHPModel_of_obstruction`.
* `CanonicalScatteringSurvivor` — canonical system + scattering /
  log-phase-space geometry.
-/

-- --- Tier 37.1 — Phase law and phase-counting -----------------------

/-- **de Branges phase law.** For a Hermite–Biehler `E`, the real-line
phase function controls the spectral counting. -/
structure DeBrangesPhaseLaw (E : ℂ → ℂ) (phase : ℝ → ℝ) where
  /-- `phase` represents `E` on the real axis. -/
  phaseRepresentsE : Prop
  /-- The phase is monotone. -/
  monotonePhase : Prop
  /-- The phase derivative is positive (spectral density). -/
  phaseDerivativePositive : Prop

/-- **Phase-counting law.** The spectral counting function is the de
Branges phase, and is Riemann–von Mangoldt compatible. -/
structure PhaseCountingLaw (phase Count : ℝ → ℝ) where
  /-- `Count` is read off from `phase`. -/
  countByPhase : Prop
  /-- The phase counting is Riemann–von Mangoldt compatible. -/
  rvmCompatible : Prop

/-- **Phase de Branges survivor.** A de Branges companion gate whose
phase explains the counting law. -/
structure PhaseDeBrangesSurvivor
    (Xi : ℂ → ℂ) (Eigen : ℝ → Prop) (Count : ℝ → ℝ) where
  /-- The companion gate. -/
  gate : DeBrangesCompanionGate Xi
  /-- The de Branges phase. -/
  phase : ℝ → ℝ
  /-- The phase law for `E`. -/
  phaseLaw : DeBrangesPhaseLaw gate.E phase
  /-- The phase-counting law. -/
  phaseCounting : PhaseCountingLaw phase Count
  /-- The Riemann–von Mangoldt counting law. -/
  rvm : RiemannVonMangoldtCounting Eigen Count

/-- A phase de Branges survivor carries the mirror functional
equation. -/
theorem PhaseDeBrangesSurvivor.mirrorEven
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {Count : ℝ → ℝ}
    (S : PhaseDeBrangesSurvivor Xi Eigen Count) :
    MirrorEvenFunction Xi :=
  S.gate.mirrorEven

-- --- Tier 37.2 — Companion response law -----------------------------

/-- **Companion response law.** Links the de Branges companion to the
determinant response function `R = −D'/D`, expected to match the prime
trace and to inherit the odd parity forced by mirror-evenness. -/
structure CompanionResponseLaw (Xi B E Response : ℂ → ℂ) where
  /-- The underlying companion. -/
  companion : CompanionFunction Xi B E
  /-- The response is generated by the companion. -/
  responseFromCompanion : Prop
  /-- The response is odd. -/
  responseParity : OddFunctionC Response

/-- The response of a companion response law is odd. -/
theorem CompanionResponseLaw.parity
    {Xi B E Response : ℂ → ℂ} (L : CompanionResponseLaw Xi B E Response) :
    OddFunctionC Response :=
  L.responseParity

/-- **No-go**: a non-odd response admits no companion response law. -/
theorem no_CompanionResponseLaw_of_response_not_odd
    {Xi B E Response : ℂ → ℂ}
    (hObs : ResponseParityObstruction Response) :
    CompanionResponseLaw Xi B E Response → False :=
  fun L => hObs L.responseParity

-- --- Tier 37.3 — Arithmetic de Branges survivor ---------------------

/-- **Arithmetic de Branges survivor.** A de Branges model whose
companion-generated response satisfies the prime trace law — the de
Branges branch made to *hear the primes*. -/
structure ArithmeticDeBrangesSurvivor
    (Xi Response : ℂ → ℂ) (Lambda : ℕ → ℝ) where
  /-- The companion gate. -/
  gate : DeBrangesCompanionGate Xi
  /-- The companion response law. -/
  responseLaw : CompanionResponseLaw Xi gate.B gate.E Response
  /-- The prime trace law. -/
  primeTrace : PrimeTraceLaw Response Lambda
  /-- The parity-compatible prime trace. -/
  parityPrimeTrace : ParityCompatiblePrimeTrace Response Lambda

/-- The response of an arithmetic de Branges survivor is odd. -/
theorem ArithmeticDeBrangesSurvivor.responseOdd
    {Xi Response : ℂ → ℂ} {Lambda : ℕ → ℝ}
    (S : ArithmeticDeBrangesSurvivor Xi Response Lambda) :
    OddFunctionC Response :=
  S.responseLaw.parity

/-- **Flagship no-go**: a wrong-parity response admits no arithmetic
de Branges survivor — the de Branges branch is forced to carry the
correct prime-trace parity. -/
theorem no_ArithmeticDeBrangesSurvivor_of_prime_trace_parity_obstruction
    {Xi Response : ℂ → ℂ} {Lambda : ℕ → ℝ}
    (hObs : PrimeTraceParityObstruction Response) :
    ArithmeticDeBrangesSurvivor Xi Response Lambda → False :=
  fun S => hObs S.responseOdd

-- --- Tier 37.4 — Canonical system gate ------------------------------

/-- **Canonical Hamiltonian.** The positive-semidefinite, trace-
normalized `2×2` matrix-valued function `H(x)` of a canonical system. -/
structure CanonicalHamiltonian where
  /-- The carrier of the Hamiltonian data. -/
  carrier : Type
  /-- `H(x)` is positive semidefinite. -/
  positiveSemidefinite : Prop
  /-- `H` is trace-normalized. -/
  traceNormalization : Prop

/-- **Canonical system model.** A canonical system whose Hamiltonian
produces a Hermite–Biehler function `E` (hence a de Branges space). -/
structure CanonicalSystemModel (E : ℂ → ℂ) where
  /-- The canonical Hamiltonian. -/
  H : CanonicalHamiltonian
  /-- The canonical system produces `E`. -/
  producesE : Prop
  /-- The associated spectral measure exists. -/
  spectralMeasureExists : Prop

/-- **Canonical-system HP model.** A de Branges operator model whose
Hermite–Biehler function arises from a canonical system — the likely
true operator source. -/
structure CanonicalSystemHPModel (Xi : ℂ → ℂ) where
  /-- The companion gate. -/
  gate : DeBrangesCompanionGate Xi
  /-- The canonical system producing `E`. -/
  canonical : CanonicalSystemModel gate.E
  /-- The de Branges operator model. -/
  operatorModel : DeBrangesOperatorModel Xi

/-- **Canonical-system obstruction** for a function `E`. -/
def CanonicalSystemObstruction (E : ℂ → ℂ) : Prop :=
  CanonicalSystemModel E → False

/-- **No-go**: if every companion gate's `E` admits no canonical
system, then no canonical-system HP model exists for `Ξ`. -/
theorem no_CanonicalSystemHPModel_of_obstruction
    {Xi : ℂ → ℂ}
    (hObs : ∀ G : DeBrangesCompanionGate Xi, CanonicalSystemObstruction G.E) :
    CanonicalSystemHPModel Xi → False :=
  fun M => hObs M.gate M.canonical

-- --- Tier 37.5 — Canonical scattering survivor ----------------------

/-- **Canonical scattering survivor.** A canonical-system HP model that
also explains the scattering / log-phase-space geometry demanded by the
survivor classification — the convergence point of the de Branges,
arithmetic, and scattering branches. -/
structure CanonicalScatteringSurvivor
    (Xi Response : ℂ → ℂ) (Lambda : ℕ → ℝ)
    (Count : ℝ → ℝ) (Phase : ℝ → ℝ) where
  /-- The canonical-system HP model. -/
  canonicalHP : CanonicalSystemHPModel Xi
  /-- The arithmetic de Branges survivor. -/
  arithmeticDB : ArithmeticDeBrangesSurvivor Xi Response Lambda
  /-- The logarithmic phase-space law. -/
  logPhaseSpace : LogPhaseSpaceLaw Count
  /-- The scattering / trace structure. -/
  scattering : ScatteringTraceHPModel Xi Response Phase Lambda

/-- A canonical scattering survivor carries the mirror functional
equation, sourced from its canonical-system companion gate. -/
theorem CanonicalScatteringSurvivor.mirrorEven
    {Xi Response : ℂ → ℂ} {Lambda : ℕ → ℝ} {Count : ℝ → ℝ} {Phase : ℝ → ℝ}
    (S : CanonicalScatteringSurvivor Xi Response Lambda Count Phase) :
