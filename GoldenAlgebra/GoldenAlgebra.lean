structure FifteenInverseBinomialIdentities where
  A_functional : AlternatingFunctional
  P_functional : PositiveFunctional
  alternating_identities : List (List ℚ)   -- identities 1, 2, 3
  positive_identities : List (List ℚ)      -- identities 4-15
  all_verified_residual_1e_neg_120 : Prop

