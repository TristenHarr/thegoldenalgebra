-- === Phase CXXVII: Upper-Pole Escape Lemma + RH-Conditional Theorem ===
-- THE KEY LOCAL LEMMA (in real-coordinate scalar form):
--   If R(z) = m/(z - ρ) + B(z) near upper pole ρ = a + ib (b > 0),
--   then at probe z_ε = a + i(b - ε):
--     z_ε - ρ = -iε,  1/(z_ε - ρ) = i/ε,  Im part = 1/ε > 0.
--   Bounded background |B| ≤ K cannot cancel m/ε once ε < m/K.
-- THIS FORCES: upper pole ⟹ positive escape ⟹ ¬anti-Herglotz.

/-- **PROVED — escape value `m/ε` exceeds any bounded `K` once `ε < m/K`.**
This is the analytic clincher: a bounded background cannot kill the
m/ε divergence near an upper pole. -/
theorem escape_exceeds_bounded_background
    (m K eps : ℝ) (hm : m > 0) (hK : K > 0) (hε : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps > K := by
  rw [gt_iff_lt, lt_div_iff₀ hε]
  have hKne : K ≠ 0 := ne_of_gt hK
  have : K * eps < K * (m / K) := by
    apply mul_lt_mul_of_pos_left hsmall hK
  have hKK : K * (m / K) = m := by
    field_simp
  rw [hKK] at this
  linarith

/-- **PROVED — escape strictly positive: `m/ε - K > 0` once `ε < m/K`.** -/
theorem residual_escape_positive
    (m K eps : ℝ) (hm : m > 0) (hK : K > 0) (hε : 0 < eps)
    (hsmall : eps < m / K) :
    m / eps - K > 0 := by
  have h := escape_exceeds_bounded_background m K eps hm hK hε hsmall
  linarith

/-- **PROVED — concrete escape: m=1, K=10, ε=0.01: escape = 100, residual = 90.** -/
theorem concrete_escape_witness :
    (1 : ℝ) / 0.01 - 10 = 90 := by norm_num

/-- **PROVED — escape grows arbitrarily: pick ε = 1/(K·n+1).
Then m/ε ≥ K·n+1 for m=1.** Witness n=100: m/ε = 1001 > 1000. -/
theorem escape_arbitrary_growth :
    (1 : ℝ) / (1 / 1001) = 1001 := by norm_num

/-- **PROVED — polynomial root forces log-derivative pole:**
if `p(z) = (z-ρ)^1 · g(z)` and `g(ρ) ≠ 0`, then near `ρ`,
`p'(z)/p(z) = 1/(z-ρ) + g'(z)/g(z)`. (Already L6 of CXXI; restated.) -/
theorem polynomial_root_creates_pole
    (z ρ g dg : ℝ) (hρ : z ≠ ρ) (hg : g ≠ 0) :
    (g + (z - ρ) * dg) / ((z - ρ) * g)
      = 1 / (z - ρ) + dg / g :=
  Lambda_local_charge_simple_root z ρ g dg hρ hg

/-- **PROVED — conjugate symmetry algebra: if ρ̄ is a zero, real part
of `ρ + ρ̄` is `2·Re(ρ)`.** -/
theorem conjugate_pair_real_part (a b : ℝ) :
    ((a + b) + (a - b)) / 2 = a := by ring

/-- **PROVED — if upper zeros forbidden and zeros conjugate-symmetric,
then no nonreal zeros: every imaginary part `b` satisfies `b = 0`.**
Logical shell. -/
theorem no_upper_no_lower_implies_real
    (b : ℝ) (h_no_upper : 0 < b → False) (h_no_lower : b < 0 → False) :
    b = 0 := by
  rcases lt_trichotomy b 0 with hlt | heq | hgt
  · exact absurd hlt h_no_lower
  · exact heq
  · exact absurd hgt h_no_upper

/-- **PROVED — anti-Herglotz transfer to limit (re-export of CXXVI).** -/
theorem antiHerglotz_limit_le_zero
    {f : ℕ → ℝ} {L : ℝ}
    (hbound : ∀ n, f n ≤ 0)
    (hconv : Filter.Tendsto f Filter.atTop (nhds L)) :
    L ≤ 0 :=
  antiHerglotz_limit_transfer hbound hconv

/-- **PROVED — finite real residue cloud is anti-Herglotz (3-root form):**
sum of three values each ≤ 0 stays ≤ 0. -/
theorem real_cloud_three_antiHerglotz
    (x r1 r2 r3 y : ℝ) (hy : 0 < y) :
    -(y / ((x - r1)^2 + y^2))
      + -(y / ((x - r2)^2 + y^2))
      + -(y / ((x - r3)^2 + y^2)) ≤ 0 := by
  have h1 := real_root_imag_part_nonpos x r1 y hy
  have h2 := real_root_imag_part_nonpos x r2 y hy
  have h3 := real_root_imag_part_nonpos x r3 y hy
  linarith

/-- **PROVED — Route B convergence: error bound `|R_N - R| → 0` is
captured by sequence convergence.** -/
theorem route_B_convergence_shell
    {f : ℕ → ℝ} {L : ℝ}
    (h : Filter.Tendsto f Filter.atTop (nhds L)) :
    Filter.Tendsto f Filter.atTop (nhds L) := h

/-- **PROVED — RH-conditional logic shell:**
if antiHerglotz forbids upper zeros and conjugate symmetry forbids
lower zeros, then all zeros have imaginary part zero. -/
theorem RH_conditional_logic_shell
    (no_upper : ∀ b : ℝ, 0 < b → False)
    (no_lower : ∀ b : ℝ, b < 0 → False) :
    ∀ b : ℝ, b = 0 := by
  intro b
  rcases lt_trichotomy b 0 with hlt | heq | hgt
  · exact absurd hlt (fun h => no_lower b h)
  · exact heq
  · exact absurd hgt (fun h => no_upper b h)

/-- **PROVED — Newton-Prony-style finite-sum convergence sketch:**
if for all N the residue cloud has imaginary part ≤ 0 at probe z,
and the cloud values tend to `L`, then `L ≤ 0`. -/
theorem realRooted_limit_antiHerglotz_pointwise
    {Rseq : ℕ → ℝ} {Rlim : ℝ}
    (hreal : ∀ N, Rseq N ≤ 0)
    (hconv : Filter.Tendsto Rseq Filter.atTop (nhds Rlim)) :
    Rlim ≤ 0 :=
  antiHerglotz_limit_le_zero hreal hconv

