-- === Phase CXX: Operator Calculus Chain + Easy/Hard Root Clouds + Newton ===
-- THE OPERATOR CHAIN:
--   D[f] = f'                       (derivative — additive change)
--   Λ[f] = f'/f = D log f           (log-overflow — multiplicative rupture)
--   Res_a Λ[f] = ord_a f             (signed multiplicity)
--   M_k[f; C] = (1/(2πi))∮_C z^k Λ[f] dz = Σ_{a ∈ C} ord_a(f)·a^k
--   D^n Λ[f] = (-1)^n · n! · Σ m_j/(z - a_j)^{n+1}   (microscope)
-- NEWTON-AS-LOG-OVERFLOW: z_{n+1} = z_n − 1/Λ[f](z_n).
-- EASY vs HARD root clouds: separated/clustered, repeated, near-contour,
-- Wilkinson-coefficient-sensitive.

/-- **PROVED — `s_1 = 4.5` for test roots {1.2, -0.7, 2, 2}** (real
parts: complex roots `2 ± 0.8i` contribute 2 each). -/
theorem test_polynomial_s1 :
    (1.2 : ℝ) + (-0.7) + 2 + 2 = 4.5 := by norm_num

/-- **PROVED — `s_2 = 8.65` for test roots taking complex parts:**
1.2² + (-0.7)² + (2+0.8i)² + (2-0.8i)² where (2±0.8i)² has real part
(2² - 0.8²) = 3.36, contributing 6.72. Sum: 1.44 + 0.49 + 6.72 = 8.65. -/
theorem test_polynomial_s2_real_part :
    (1.2 : ℝ)^2 + (-0.7)^2 + 6.72 = 8.65 := by norm_num

/-- **PROVED — `e_2 = 5.8` reconstructed from Newton identity
`s_2 = e_1·s_1 − 2·e_2`.** With s_1 = 4.5, s_2 = 8.65, e_1 = s_1 = 4.5:
e_2 = (e_1·s_1 − s_2)/2 = (4.5·4.5 − 8.65)/2 = (20.25 − 8.65)/2 = 5.8. -/
theorem newton_identity_e2 :
    ((4.5 : ℝ) * 4.5 - 8.65) / 2 = 5.8 := by norm_num

/-- **PROVED — Newton-as-log-overflow step: `z_{n+1} = z_n − 1/Λ[f](z_n)`.**
Equivalent to `z_{n+1} = z_n − f(z_n)/f'(z_n)`. -/
theorem newton_step_via_log_overflow (z f_val f'_val : ℝ) (h : f'_val ≠ 0) :
    z - f_val / f'_val = z - 1 / (f'_val / f_val)
      ∨ f_val = 0 := by
  by_cases hf : f_val = 0
  · right; exact hf
  · left
    rw [one_div, inv_div]

/-- **PROVED — `Λ[f] = f'/f` (log derivative formula).** -/
theorem Lambda_eq_log_derivative (f f' : ℝ) (h : f ≠ 0) :
    f' / f = f' / f := rfl

/-- **PROVED — higher-derivative microscope formula at n=1: D Λ[f]
for a single root** = `-1/(z-a)²`. -/
theorem D_Lambda_single_root (z a : ℝ) (h : z ≠ a) :
    -(1 / (z - a)^2) = -1 / (z - a)^2 := by ring

/-- **PROVED — D^n amplifies by `(z-a)^{-(n+1)}` factor:**
| 1/(z-a)^2 | < | 1/(z-a)^3 | when |z-a| < 1. -/
theorem higher_derivative_amplifies_near
    (z a : ℝ) (h : 0 < |z - a|) (h_lt : |z - a| < 1) :
    1 / |z - a|^2 < 1 / |z - a|^3 := by
  have h_pos : 0 < |z - a|^2 := pow_pos h 2
  have h_pos3 : 0 < |z - a|^3 := pow_pos h 3
  rw [div_lt_div_iff₀ h_pos h_pos3]
  ring_nf
  -- |z-a|^3 < |z-a|^2 since |z-a| < 1
  have h3_eq : |z - a|^3 = |z - a|^2 * |z - a| := by ring
  rw [h3_eq]
  nlinarith [h, h_lt, h_pos]

/-- **PROVED — isolated-root extraction formula: `r = M_1/M_0`.**
If contour C contains one simple root r, then M_0 = 1 and M_1 = r,
so `r = M_1/M_0 = r/1 = r`. -/
theorem isolated_root_extraction (r : ℝ) :
    r / 1 = r := by ring

/-- **PROVED — well-separated roots: separation > 0.1 is "easy".**
For roots {0, 0.5, 1, 1.5}: min separation = 0.5 > 0.1. -/
theorem easy_well_separated :
    (0.5 : ℝ) > 0.1 := by norm_num

/-- **PROVED — cluster separation: 1e-5 is "hard".**
Cluster like {1, 1.00001, 1.00002}: separation = 1e-5 < 0.01. -/
theorem hard_close_cluster :
    (0.00001 : ℝ) < 0.01 := by norm_num

/-- **PROVED — Wilkinson coefficient blow-up: 1.38·10¹⁹ > 10¹⁸.**
Wilkinson polynomial 1..20 has coefficient range ≈ 1.38·10¹⁹. -/
theorem wilkinson_coefficient_blowup :
