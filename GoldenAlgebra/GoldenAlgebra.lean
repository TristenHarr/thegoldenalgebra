-- Step 123: heat trace / spectral flow.

/--
Heat-trace law for the positive squared operator `A = H²`:
`Tr(exp(−tA))`, with convergence, spectral expansion, small-time
asymptotics, and theta compatibility. The geometric-flow form of the
spectral data.
-/
structure HeatTraceSieveLaw (Eigen : ℝ → Prop) where
  heatTrace : ℝ → ℂ
  positiveTimeConvergence : Prop
  spectralExpansion : Prop
  smallTimeAsymptotic : Prop
  thetaCompatibility : Prop

