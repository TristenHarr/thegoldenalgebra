/-!
## Tier 109 — Multi-Ring Central Configurations (`N = K · P`)

The orbitizer scales by **symmetry reduction**: instead of solving for
`2 N` raw coordinates, place all bodies on `K` concentric regular
`P`-gons (rings). Tangential forces cancel by ring symmetry; only `K`
radial balance equations remain.

For ring `k` of radius `r_k` and per-body mass `μ_k`, the radial
acceleration on a body in ring `k` is

`A_k = Σ_ℓ C_{kℓ}(r) · μ_ℓ`,

and the central-configuration condition `A_k = −λ r_k` gives the
linear `K × K` system

`Σ_ℓ C_{kℓ}(r) · μ_ℓ + λ r_k = 0,    k = 1,…,K`.

If this admits a positive null vector `μ > 0`, the full `N = K · P`
configuration rotates rigidly at angular speed `ω = √λ`.

This tier formalises:

* `ringPoint K P r k n` — the explicit ring/vertex parameterisation,
* `MultiRingBalance K P r μ λ` — the balance-equation predicate,
* `multiRingConfig K P r` — the full configuration as a `Fin (K·P) → ℂ`,
* the `N = 100` candidate the prototype produced (`K = 5`, `P = 20`),
  with the five ring radii and ring masses,
* `IsHugeRingSearchTarget K P` for the `N = 1000`, Golden-rings,
  phase-offset, etc. follow-on research targets.

The flagship theorem
`multiRingBalance_gives_centralConfiguration` reduces a `K · P`-body
central configuration to the `K`-equation linear system; we record it
as a sorry-marked target. -/

section MultiRingCentralConfig

-- =========================================================================
-- Ring point + radial coefficient
-- =========================================================================

/-- The vertex `n` of ring `k` in a `K`-ring `P`-gon configuration:
`r_k · exp(2π i n / P)`. -/
noncomputable def ringPoint
    {K P : ℕ} (r : Fin K → ℝ) (k : Fin K) (n : Fin P) : ℂ :=
  ((r k : ℝ) : ℂ) *
    Complex.exp ((2 * Real.pi * (n : ℝ) / (P : ℝ) : ℝ) * I)

/-- A simple sanity fact: the radial magnitude of a ring vertex is `|r_k|`. -/
theorem ringPoint_norm
    {K P : ℕ} (r : Fin K → ℝ) (k : Fin K) (n : Fin P) :
    ‖ringPoint r k n‖ = |r k| := by
  unfold ringPoint
  rw [norm_mul, norm_exp_ofReal_mul_I, mul_one, Complex.norm_real,
      Real.norm_eq_abs]

/-- **Radial coefficient** `C_{k ℓ}(r)` — the projection of the
combined gravitational acceleration from all bodies on ring `ℓ` onto
the radial direction of ring `k`, per unit mass at each source vertex.

We record the structural shape (sum over the `P − 1` source vertices,
omitting the self-vertex when `k = ℓ`). -/
noncomputable def ringCoeff
    {K P : ℕ} [NeZero P] (r : Fin K → ℝ) (k l : Fin K) : ℝ :=
  let zk : ℂ := ringPoint (P := P) r k 0
  ∑ n : Fin P,
    if k = l ∧ n.val = 0 then 0
    else
      let zln : ℂ := ringPoint (P := P) r l n
      let d   : ℂ := zln - zk
      ((d / ((‖d‖ ^ 3 : ℝ) : ℂ))).re

-- =========================================================================
-- Multi-ring balance equation
-- =========================================================================

/-- **Multi-ring balance predicate.** The `K` radial balance equations
`Σ_ℓ C_{kℓ}(r) μ_ℓ + λ r_k = 0` for every ring `k`. -/
def MultiRingBalance
    {K P : ℕ} [NeZero P] (r μ : Fin K → ℝ) (lam : ℝ) : Prop :=
  ∀ k : Fin K,
    (∑ l : Fin K, (ringCoeff (P := P) r k l) * μ l) + lam * r k = 0

-- =========================================================================
-- Full N = K · P configuration
-- =========================================================================

/-- The full `K · P`-body configuration produced by the `K` rings.
Body index `i ∈ Fin (K · P)` maps to ring `i.val / P` and vertex
`i.val % P`. -/
noncomputable def multiRingConfig
    {K P : ℕ} (hP : 0 < P) (r : Fin K → ℝ) :
    Fin (K * P) → ℂ :=
  fun i =>
    let kval := i.val / P
    let nval := i.val % P
    have hi : i.val < K * P := i.isLt
    have hk : kval < K := by
      have h1 : kval * P ≤ i.val := Nat.div_mul_le_self i.val P
      by_contra h_neg
      push_neg at h_neg
      have h2 : K * P ≤ kval * P := Nat.mul_le_mul_right P h_neg
      omega
    have hn : nval < P := Nat.mod_lt i.val hP
    ringPoint (K := K) (P := P) r ⟨kval, hk⟩ ⟨nval, hn⟩

/-- The mass assignment: body `i` inherits the per-body mass `μ_{k}`
of its ring. -/
noncomputable def multiRingMass
    {K P : ℕ} (_hP : 0 < P) (μ : Fin K → ℝ) :
    Fin (K * P) → ℝ :=
  fun i =>
    let kval := i.val / P
    have hi : i.val < K * P := i.isLt
    have hk : kval < K := by
      have h1 : kval * P ≤ i.val := Nat.div_mul_le_self i.val P
      by_contra h_neg
      push_neg at h_neg
      have h2 : K * P ≤ kval * P := Nat.mul_le_mul_right P h_neg
      omega
    μ ⟨kval, hk⟩

-- =========================================================================
-- Flagship target theorem
-- =========================================================================

/-- **Flagship multi-ring → central-configuration theorem (target).**
If the `K` ring balance equations hold for positive ring masses and
positive ring radii, then the expanded `K · P`-body configuration is a
Newtonian central configuration with the same `λ`.

Proof outline:
1. By ring symmetry, all tangential force components cancel.
2. The remaining radial component is exactly `Σ_ℓ C_{kℓ}(r) μ_ℓ`.
3. Setting that equal to `−λ r_k` is the balance equation.
4. The full vector `a_i = −λ q_i` then follows from the polar split. -/
theorem multiRingBalance_gives_centralConfiguration
    {K P : ℕ} [NeZero P] (hP : 0 < P) (r μ : Fin K → ℝ) (lam : ℝ)
    (_hbalance : MultiRingBalance (P := P) r μ lam)
    (_hμ : ∀ k, 0 < μ k) (_hr : ∀ k, 0 < r k) :
    IsCentralConfiguration
      (multiRingConfig hP r)
      (multiRingMass hP μ)
      1 0 lam := by
  -- Reduces, by ring symmetry, to the K balance equations.
  sorry

-- =========================================================================
-- The N = 100 numerical candidate (K = 5, P = 20)
-- =========================================================================

/-- **`N = 100` multi-ring candidate.** Five concentric 20-gons with the
ring radii and per-body masses the Python prototype refined:

| Ring | radius     | mass per body |
|------|------------|---------------|
| 1    | 0.42059175 | 0.15243781    |
| 2    | 0.78747792 | 0.29846646    |
| 3    | 1.02415195 | 0.07419385    |
| 4    | 1.36320029 | 0.74182791    |
| 5    | 2.44201994 | 3.73307398    |

* `λ ≈ 4.681059835555`
* `ω = √λ ≈ 2.163575706`
* `T = 2π / ω ≈ 2.904074625`
* full 100-body central-config residual ≈ `3.77 · 10⁻¹⁵` -/
noncomputable def ringRadii_N100 : Fin 5 → ℝ :=
  ![0.420591752, 0.787477923, 1.024151945, 1.363200286, 2.442019942]

noncomputable def ringMasses_N100 : Fin 5 → ℝ :=
  ![0.152437811, 0.298466462, 0.074193848, 0.741827905, 3.733073975]

noncomputable def lambda_N100 : ℝ := 4.681059835555

noncomputable def omega_N100 : ℝ := Real.sqrt lambda_N100

noncomputable def period_N100 : ℝ := 2 * Real.pi / omega_N100

/-- Numerical full-system residual the Python prototype achieved. -/
noncomputable def residual_N100 : ℝ := 3.77e-15

theorem lambda_N100_pos : 0 < lambda_N100 := by
  unfold lambda_N100; norm_num

theorem omega_N100_pos : 0 < omega_N100 := by
  unfold omega_N100; exact Real.sqrt_pos.mpr lambda_N100_pos

theorem period_N100_pos : 0 < period_N100 := by
  unfold period_N100
  have h2π : (0 : ℝ) < 2 * Real.pi := by
    have := Real.pi_pos; linarith
  exact div_pos h2π omega_N100_pos

theorem residual_N100_pos : 0 < residual_N100 := by
  unfold residual_N100; norm_num

theorem ringRadii_N100_pos (k : Fin 5) : 0 < ringRadii_N100 k := by
  fin_cases k <;> simp [ringRadii_N100] <;> norm_num

theorem ringMasses_N100_pos (k : Fin 5) : 0 < ringMasses_N100 k := by
  fin_cases k <;> simp [ringMasses_N100] <;> norm_num

/-- The recipe count: `N = K · P = 5 · 20 = 100`. -/
theorem N100_count : (5 : ℕ) * 20 = 100 := by norm_num

-- =========================================================================
-- Future research targets: huge rings, Golden rings, phase offsets
-- =========================================================================

/-- **Huge-ring search target** (`N = 1000` from `K = 10`, `P = 100`,
etc.). Recorded as an interface; the construction is identical to the
`N = 100` case, just with larger `K, P`. -/
def IsHugeRingSearchTarget (_K _P : ℕ) : Prop := True

/-- **Golden-ring search target.** Replace the Newtonian
`(q_j − q_i) / |q_j − q_i|³` summand by the Golden radial pair force
`(T − H² / r²) (q_j − q_i)` and solve the analogous ring-balance
equations. The likely outcome (per the Tier 90 polygon-equilibrium
theme) is a *finite* equilibrium without rotation in the simplest
case, and a one-parameter family in the general multi-ring case. -/
def IsGoldenRingSearchTarget (_K _P : ℕ) : Prop := True

/-- **Phase-offset multi-ring search target.** Allow each ring to carry
a per-ring phase shift `φ_k`, breaking the strict "all rings aligned"
symmetry; this opens the door to genuinely new configurations. -/
def IsPhaseOffsetRingSearchTarget (_K _P : ℕ) (_φ : ℕ → ℝ) : Prop := True

/-- **Variable-`P` (per-ring vertex count) search target.** Allow
each ring its own `P_k`; the symmetry reduction still applies provided
all `P_k`s yield zero tangential force at the rate-matched angular
velocity. -/
def IsVariablePRingSearchTarget (_K : ℕ) (_P : ℕ → ℕ) : Prop := True

end MultiRingCentralConfig

