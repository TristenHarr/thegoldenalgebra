-- Step 166: the prime-heat deformation mechanism cover.

/-- World class: Euler-local heat mechanism. -/
def EulerLocalHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty EulerLocalHeatDeformation

/-- World class: Dirichlet-convolution heat mechanism. -/
def DirichletConvolutionHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty DirichletConvolutionHeatDeformation

/-- World class: scattering-phase heat mechanism. -/
def ScatteringPhaseHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty ScatteringPhaseHeatDeformation

/-- World class: transfer-operator heat mechanism. -/
def TransferOperatorHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty TransferOperatorHeatDeformation

/-- World class: adelic orbit-counting heat mechanism. -/
def AdelicOrbitHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty AdelicOrbitHeatDeformation

/-- The five-mechanism cover for prime-heat deformations. -/
def PrimeHeatMechanismCover : List (OperatorCandidateWorld → Prop) :=
  [EulerLocalHeatWorld,
   DirichletConvolutionHeatWorld,
   ScatteringPhaseHeatWorld,
   TransferOperatorHeatWorld,
   AdelicOrbitHeatWorld]

/-- A search space is prime-heat-mechanism-covered if every candidate
arises through one of the five mechanisms. -/
def PrimeHeatMechanismCoveredSearchSpace
    (Search : OperatorCandidateWorld → Prop) : Prop :=
  CoversByList OperatorCandidateWorld Search PrimeHeatMechanismCover

-- Step 167: mechanism agreement.

/-- Two heat-deformation mechanisms *agree* if they produce the same
deformed heat trace. -/
def HeatMechanismsAgree
    (D₁ D₂ : PrimeHeatTraceDeformation) : Prop :=
  D₁.deformedHeatTrace = D₂.deformedHeatTrace

/--
*Euler ↔ Dirichlet* heat-mechanism agreement: the Euler-local and
Dirichlet-convolution routes produce the same prime-deformed heat trace.
-/
structure EulerDirichletHeatAgreement where
  eulerLocal : EulerLocalHeatDeformation
  dirichlet : DirichletConvolutionHeatDeformation
  samePrimeHeatTrace :
    HeatMechanismsAgree
      eulerLocal.producesPrimeHeatTraceDeformation
      dirichlet.producesPrimeHeatTraceDeformation

/--
**Full mechanism agreement**: all five prime-heat deformation routes
produce the same deformed heat trace. The hidden operator should sit at
this five-way intersection.
-/
structure FullPrimeHeatMechanismAgreement where
  eulerLocal : EulerLocalHeatDeformation
  dirichlet : DirichletConvolutionHeatDeformation
  scattering : ScatteringPhaseHeatDeformation
  transfer : TransferOperatorHeatDeformation
  adelic : AdelicOrbitHeatDeformation
  euler_dirichlet :
    HeatMechanismsAgree
      eulerLocal.producesPrimeHeatTraceDeformation
      dirichlet.producesPrimeHeatTraceDeformation
  euler_scattering :
    HeatMechanismsAgree
      eulerLocal.producesPrimeHeatTraceDeformation
      scattering.producesPrimeHeatTraceDeformation
  euler_transfer :
    HeatMechanismsAgree
      eulerLocal.producesPrimeHeatTraceDeformation
      transfer.producesPrimeHeatTraceDeformation
  euler_adelic :
    HeatMechanismsAgree
      eulerLocal.producesPrimeHeatTraceDeformation
      adelic.producesPrimeHeatTraceDeformation

/-- Full mechanism agreement is transitive across the routes: any two
of the five produce the same deformed heat trace. -/
theorem FullPrimeHeatMechanismAgreement.dirichlet_scattering
    (A : FullPrimeHeatMechanismAgreement) :
    HeatMechanismsAgree
      A.dirichlet.producesPrimeHeatTraceDeformation
      A.scattering.producesPrimeHeatTraceDeformation := by
  unfold HeatMechanismsAgree at *
  rw [← A.euler_dirichlet, A.euler_scattering]

-- === Mechanism Reductions / Universal Mechanism (Steps 168-172) ===
-- Are the five mechanisms genuinely distinct, or five shadows of one?
-- This wave defines reductions between them and the universal
-- mechanism they should all realize.

-- Step 168: mechanism reduction maps.

/--
A *heat-mechanism reduction*: one mechanism translates into another
while preserving the produced prime-deformed heat trace.
-/
structure HeatMechanismReduction (M₁ M₂ : Type) where
  reduce : M₁ → M₂
  preservesPrimeHeatTrace : Prop

/--
Euler-local reduces to Dirichlet-convolution: the product over
prime-local factors expands into arithmetic convolution weights.
-/
structure EulerToDirichletHeatReduction where
  reduce :
    EulerLocalHeatDeformation → DirichletConvolutionHeatDeformation
  preservesDeformedTrace :
    ∀ E : EulerLocalHeatDeformation,
      HeatMechanismsAgree
        E.producesPrimeHeatTraceDeformation
        (reduce E).producesPrimeHeatTraceDeformation
  eulerProductExpandsToDirichletSeries : Prop

/--
Transfer-operator periodic orbits reduce to Euler-local prime factors:
primitive periodic orbits are identified with primes.
-/
structure TransferToEulerHeatReduction where
  reduce :
    TransferOperatorHeatDeformation → EulerLocalHeatDeformation
  preservesDeformedTrace :
    ∀ T : TransferOperatorHeatDeformation,
      HeatMechanismsAgree
        T.producesPrimeHeatTraceDeformation
        (reduce T).producesPrimeHeatTraceDeformation
  primitiveOrbitsArePrimes : Prop

/--
Adelic orbit-counting reduces to Euler-local prime factors: local
orbits at `p` recover the `p`-Euler factor.
-/
structure AdelicToEulerHeatReduction where
  reduce :
    AdelicOrbitHeatDeformation → EulerLocalHeatDeformation
  preservesDeformedTrace :
    ∀ A : AdelicOrbitHeatDeformation,
      HeatMechanismsAgree
        A.producesPrimeHeatTraceDeformation
        (reduce A).producesPrimeHeatTraceDeformation
  localAdelicOrbitsRecoverEulerFactors : Prop

-- Step 169: scattering phase as the determinant log-derivative.

/--
A scattering phase is *determinant-compatible* if its derivative equals
the negative logarithmic derivative of the zeta determinant.
-/
structure ScatteringPhaseDeterminantCompatibility
    (S : ScatteringPhaseHeatDeformation) where
  phaseDerivativeEqualsNegLogDerivative : Prop
  scatteringDeterminantEqualsZeta : Prop
  phaseTraceEqualsVonMangoldt : Prop

/--
The scattering mechanism reduces to the determinant triangle: every
scattering phase deformation is determinant-compatible.
-/
structure ScatteringToTriangleReduction where
  reduce :
    ScatteringPhaseHeatDeformation → ZetaDeterminantTriangle
  compatibility :
    ∀ S : ScatteringPhaseHeatDeformation,
      ScatteringPhaseDeterminantCompatibility S

-- Step 170: the universal prime-heat mechanism.

/--
**`UniversalPrimeHeatMechanism`** — the common object behind all five
mechanism families: Euler-local, Dirichlet-convolution, scattering,
transfer-operator, and adelic. The candidate "true deformation
mechanism," with all five realizations producing the same deformed
heat trace.
-/
structure UniversalPrimeHeatMechanism where
  deformation : PrimeHeatTraceDeformation
  eulerLocalRealization : EulerLocalHeatDeformation
  dirichletRealization : DirichletConvolutionHeatDeformation
  scatteringRealization : ScatteringPhaseHeatDeformation
  transferRealization : TransferOperatorHeatDeformation
  adelicRealization : AdelicOrbitHeatDeformation
  allAgree : FullPrimeHeatMechanismAgreement

/-- A core whose prime deformation is the universal mechanism. -/
structure UniversalPrimeHeatZetaCore
    extends ArithmeticMechanizedHeatZetaCore where
  universalPrimeHeat : UniversalPrimeHeatMechanism

/-- Bridge: universal prime-heat zeta core ⟹ critical-line. -/
theorem UniversalPrimeHeatZetaCore_implies_zeta_critical_line
    (Z : UniversalPrimeHeatZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ArithmeticMechanizedHeatZetaCore_implies_zeta_critical_line
    Z.toArithmeticMechanizedHeatZetaCore

-- Step 171: the universal mechanism construction problem.

/--
**The universal prime-heat construction problem.** The five serious
prime-deformation mechanisms are not separate — they are realizations
of one common prime heat trace deformation.
-/
def UniversalPrimeHeatConstructionProblem : Prop :=
  Nonempty UniversalPrimeHeatZetaCore

/-- Solving the universal prime-heat construction problem implies the
critical-line statement. -/
theorem UniversalPrimeHeatConstructionProblem_implies_zeta_critical_line
    (h : UniversalPrimeHeatConstructionProblem) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ := by
  rcases h with ⟨Z⟩
  exact UniversalPrimeHeatZetaCore_implies_zeta_critical_line Z

-- Step 172: isolated-mechanism no-go.

/-- Cold: an Euler-local heat world that does not sit inside the
universal mechanism — a one-faced mechanism. -/
def IsolatedEulerHeatWorld (W : OperatorCandidateWorld) : Prop :=
  EulerLocalHeatWorld W ∧ ¬ Nonempty UniversalPrimeHeatMechanism

/-- Constraint: a world inside the universal prime-heat mechanism. -/
def UniversalPrimeHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty UniversalPrimeHeatMechanism

/-- Isolated (one-faced) Euler-local heat worlds are rejected: a
mechanism that cannot sit in the universal intersection is less
credible than one that does. -/
theorem isolatedEulerHeatWorld_rejected :
    ClassRejectedBy OperatorCandidateWorld
      IsolatedEulerHeatWorld UniversalPrimeHeatWorld := by
  intro W hW hU
  exact hW.2 hU.2

-- === Arithmetic Hilbert Space Anatomy (Steps 173-179) ===
-- The universal mechanism is not allowed to be a black-box equality
-- machine. It must act on a Hilbert space with an inner product. This
-- wave builds the operator's internal anatomy: state space →
-- prime-local factorization → log-scale generator → prime oscillators
-- → global interference → positive square operator.

-- Step 173: the arithmetic Hilbert space core.

/--
**`ArithmeticHilbertSpaceCore`** — the proposed state space on which the
hidden operator acts. Forces the universal prime-heat mechanism to be a
genuine Hilbert-space representation, not just five equal traces.
-/
structure ArithmeticHilbertSpaceCore where
