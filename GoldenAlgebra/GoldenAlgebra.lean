/-- **Definition — anti-Herglotz on the upper half-plane (complex).** -/
def AntiHerglotzUHP (R : ℂ → ℂ) : Prop :=
  ∀ z : ℂ, 0 < z.im → (R z).im ≤ 0

/-- **Definition — positive upper-half-plane imaginary escape.** -/
def PositiveUpperImaginaryEscape (R : ℂ → ℂ) : Prop :=
  ∃ z : ℂ, 0 < z.im ∧ 0 < (R z).im

/-- **PROVED — equivalence: anti-Herglotz ⟺ no positive upper escape.** -/
theorem antiHerglotz_iff_no_positiveUpperEscape (R : ℂ → ℂ) :
    AntiHerglotzUHP R ↔ ¬ PositiveUpperImaginaryEscape R := by
  constructor
  · rintro h ⟨z, hz, hRz⟩
    exact absurd (h z hz) (not_le.mpr hRz)
  · intro h z hz
    by_contra hcontra
    push_neg at hcontra
    exact h ⟨z, hz, hcontra⟩

/-- **PROVED — list-version of real-residue anti-Herglotz.** Replaces the
1/2/3-root concrete cases with one general theorem by induction. -/
theorem real_residue_cloud_antiHerglotz_list (rs : List ℝ) :
    AntiHerglotzUHP
      (fun z : ℂ => (rs.map (fun r : ℝ => (1 : ℂ) / (z - (r : ℂ)))).sum) := by
  intro z hz
  induction rs with
  | nil => simp
  | cons r rs ih =>
    simp only [List.map_cons, List.sum_cons, Complex.add_im]
    have hne : z ≠ (r : ℂ) := by
      intro h
      rw [h] at hz
      simp at hz
    have h_atom : ((1 : ℂ) / (z - (r : ℂ))).im ≤ 0 :=
      complex_real_root_residue_imag_nonpos z r hz hne
    linarith

/-- **Abstract pole-witness law for the log-derivative response of `f`.**
This is the analytic interface: an upper zero of `f` forces a positive
escape in the response field `R`. Polynomial / xi instantiations live
in later phases. -/
structure LogDerivPoleWitnessLaw (f R : ℂ → ℂ) : Prop where
  upper_zero_forces_escape :
    ∀ ρ : ℂ, f ρ = 0 → 0 < ρ.im → PositiveUpperImaginaryEscape R

/-- **PROVED — anti-Herglotz + pole-witness ⟹ no upper zeros.** -/
theorem antiHerglotz_forbids_upper_zeros
    {f R : ℂ → ℂ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R) :
    ∀ ρ : ℂ, 0 < ρ.im → f ρ ≠ 0 := by
  intro ρ hupper hzero
  have hesc := hpole.upper_zero_forces_escape ρ hzero hupper
  exact (antiHerglotz_iff_no_positiveUpperEscape R).mp hanti hesc

/-- **PROVED — `(star ρ).im = -ρ.im` (complex conjugation flips imag).** -/
theorem complex_star_im (ρ : ℂ) : (star ρ).im = -ρ.im := by
  show (starRingEnd ℂ ρ).im = -ρ.im
  exact Complex.conj_im ρ

/-- **PROVED — full engine: anti-Herglotz + pole-witness + conjugation
symmetry ⟹ all zeros real. (General complex form.)** -/
theorem antiHerglotz_plus_symmetry_forces_real_zeros_complex
    {f R : ℂ → ℂ}
    (hpole : LogDerivPoleWitnessLaw f R)
    (hanti : AntiHerglotzUHP R)
    (hsym : ∀ z : ℂ, f (star z) = star (f z)) :
    ∀ ρ : ℂ, f ρ = 0 → ρ.im = 0 := by
  intro ρ hρzero
  rcases lt_trichotomy ρ.im 0 with hneg | hzero | hpos
  · -- lower zero ⇒ conjugate is upper zero ⇒ contradiction
    have hconj_zero : f (star ρ) = 0 := by
      rw [hsym ρ, hρzero]
      simp
    have hupper_conj : 0 < (star ρ).im := by
      rw [complex_star_im]
      linarith
    exact absurd hconj_zero
      (antiHerglotz_forbids_upper_zeros hpole hanti (star ρ) hupper_conj)
  · exact hzero
  · -- upper zero directly contradicts the engine
    exact absurd hρzero
      (antiHerglotz_forbids_upper_zeros hpole hanti ρ hpos)

