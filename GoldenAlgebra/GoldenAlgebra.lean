  unfold piSquaredOverThree
  have hπ : (3 : ℝ) < Real.pi := Real.pi_gt_three
  nlinarith [hπ, Real.pi_pos]

/-- The completed weight-5 combination `ζ(5) + (π²/3)·ζ(3)` — the
natural object emerging from the symmetric kernel, with the asymptotic
coupling baked in. -/
