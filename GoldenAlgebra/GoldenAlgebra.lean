/-- Council C077 — Functional Equation Integration.

There is a witness `Ξ` satisfying `Ξ(s) = Ξ(1 − s)` whose zero set inside
the open critical strip is exactly the nontrivial zeta zeros.

**Discharged** — this was previously `axiom
council_C077_functional_equation_axiom`; it is now a proven theorem.
The witness is `Ξ(s) := ζ(s) · ζ(1−s)`. Symmetry is `mul_comm` after
`1 − (1 − s) = s`. The zero-set equivalence on the open strip
`0 < Re ρ < 1` uses Mathlib's `riemannZeta_one_sub` together with
non-vanishing of the factor `2 · (2π)^(−ρ) · Γ(ρ) · cos(πρ/2)` there:
`two_ne_zero`, `Complex.cpow_eq_zero_iff` (base `2π ≠ 0`),
`Complex.Gamma_ne_zero_of_re_pos`, and `Complex.cos_ne_zero_iff` (no odd
integer lies in `(0,1)`).

Scope note: `Ξ` is *not* claimed to be entire — `ζ(s)·ζ(1−s)` has poles
at `s = 0, 1`. The statement asks only for the strip zero-set identity
plus the symmetry `Ξ(s) = Ξ(1−s)`, and that is exactly — and only —
what is proven here. Status: **proven** (no axiom). -/
theorem council_C077_functional_equation :
    ∃ Ξ : ℂ → ℂ, (∀ ρ : ℂ, CriticalStrip ρ → (Ξ ρ = 0 ↔ NontrivialZetaZero ρ)) ∧
                  (∀ s : ℂ, Ξ s = Ξ (1 - s)) := by
  refine ⟨fun s => riemannZeta s * riemannZeta (1 - s), ?_, ?_⟩
  · intro ρ hρ
    obtain ⟨hρ0, hρ1⟩ := hρ
    have hsn : ∀ n : ℕ, ρ ≠ -(n : ℂ) := by
      intro n hn
      have hre : ρ.re = -(n : ℝ) := by rw [hn]; simp
      rw [hre] at hρ0
      have : (0 : ℝ) ≤ (n : ℝ) := Nat.cast_nonneg n
      linarith
    have hs1 : ρ ≠ 1 := by
      intro h
      have hre : ρ.re = 1 := by rw [h]; simp
      rw [hre] at hρ1
      exact lt_irrefl 1 hρ1
    have hfe := riemannZeta_one_sub hsn hs1
    have hC : (2 : ℂ) * (2 * (Real.pi : ℂ)) ^ (-ρ) * Complex.Gamma ρ
        * Complex.cos ((Real.pi : ℂ) * ρ / 2) ≠ 0 := by
      refine mul_ne_zero (mul_ne_zero (mul_ne_zero ?_ ?_) ?_) ?_
      · exact two_ne_zero
      · intro hcpow
        rw [Complex.cpow_eq_zero_iff] at hcpow
        exact (mul_ne_zero two_ne_zero
          (Complex.ofReal_ne_zero.mpr Real.pi_ne_zero)) hcpow.1
      · exact Complex.Gamma_ne_zero_of_re_pos hρ0
      · rw [Complex.cos_ne_zero_iff]
        intro k hk
        have hπ : (Real.pi : ℂ) ≠ 0 :=
          Complex.ofReal_ne_zero.mpr Real.pi_ne_zero
        have hρeq : ρ = 2 * (k : ℂ) + 1 := by
          have hk2 : (Real.pi : ℂ) * ρ
              = (Real.pi : ℂ) * (2 * (k : ℂ) + 1) := by
            linear_combination 2 * hk
          exact mul_left_cancel₀ hπ hk2
        have hρeq' : ρ = ((2 * k + 1 : ℤ) : ℂ) := by
          rw [hρeq]; push_cast; ring
        have hre : ρ.re = ((2 * k + 1 : ℤ) : ℝ) := by
          rw [hρeq']; exact Complex.intCast_re _
        rw [hre] at hρ0 hρ1
        have h0 : (0 : ℤ) < 2 * k + 1 := by exact_mod_cast hρ0
        have h1 : (2 * k + 1 : ℤ) < 1 := by exact_mod_cast hρ1
        omega
    show riemannZeta ρ * riemannZeta (1 - ρ) = 0 ↔ NontrivialZetaZero ρ
    rw [NontrivialZetaZero_iff_zeta_zero_in_criticalStrip]
    constructor
    · intro hΞ
      rw [mul_eq_zero] at hΞ
      refine ⟨?_, hρ0, hρ1⟩
      rcases hΞ with hz | hz
      · exact hz
      · rw [hfe, mul_eq_zero] at hz
        exact hz.resolve_left hC
    · rintro ⟨hz, -⟩
      rw [mul_eq_zero]
      exact Or.inl hz
  · intro s
    show riemannZeta s * riemannZeta (1 - s)
       = riemannZeta (1 - s) * riemannZeta (1 - (1 - s))
    rw [sub_sub_cancel]
    ring

/-- Compatibility alias: `council_C077_functional_equation` was formerly
the axiom `council_C077_functional_equation_axiom`. The name is retained
so existing references keep resolving; it is now a theorem, not an
axiom. -/
theorem council_C077_functional_equation_axiom :
    ∃ Ξ : ℂ → ℂ, (∀ ρ : ℂ, CriticalStrip ρ → (Ξ ρ = 0 ↔ NontrivialZetaZero ρ)) ∧
                  (∀ s : ℂ, Ξ s = Ξ (1 - s)) :=
  council_C077_functional_equation

/-- Council C078 — Critical Symmetry.
The zero set of the (completed-xi) determinant is symmetric under
`s ↦ 1 − s`. Now **unconditional**: it consumes `council_C077_…`, which
was discharged from an axiom to a proven theorem.
Status: **proof** (no axiom — see C077). -/
theorem council_C078_critical_symmetry :
    ∃ Ξ : ℂ → ℂ, ∀ s : ℂ, Ξ s = 0 ↔ Ξ (1 - s) = 0 := by
  obtain ⟨Ξ, _, hfe⟩ := council_C077_functional_equation
  refine ⟨Ξ, fun s => ?_⟩
  constructor
  · intro hΞs
    rw [← hfe]; exact hΞs
  · intro hΞ1s
    rw [hfe]; exact hΞ1s

