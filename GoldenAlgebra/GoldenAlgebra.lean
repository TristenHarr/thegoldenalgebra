-- Step 116: Euler-Hadamard local-global compatibility.

/--
Euler-Hadamard compatibility: the prime-local Euler product and the
spectral Hadamard product are the same determinant, with the
log-derivative yielding the explicit formula.
-/
structure EulerHadamardCompatibilityLaw
    (detZ : ℂ → ℂ) (Eigen : ℝ → Prop) where
  eulerProductSide : EulerProductReconstruction
  hadamardSide : HadamardProductSieveLaw detZ Eigen
