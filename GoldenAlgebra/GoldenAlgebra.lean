/-!
## Tier 90 — Golden Mechanics Layer

This section turns the algebraic Golden operator into a mechanics model.
It records the formalization of the radial / swirl decomposition discovered
experimentally, together with the textbook physics problems that decomposition
makes solvable.

There are two related systems:

* The **conservative radial system**
  `Fᵢⱼ = (T − H² / |zⱼ − zᵢ|²) (zⱼ − zᵢ)`.
* The **full complex propulsion system**
  `Fᵢⱼ = λ_eff(|zⱼ − zᵢ|) (zⱼ − zᵢ) = Fᵢⱼʳᵃᵈ + i · Jeff(|zⱼ − zᵢ|) (zⱼ − zᵢ)`.

The radial system is Hamiltonian/conservative; the full system equals
radial mechanics plus a tangential swirl-propulsion term.

### Status

* P1 / P2 / P3 / P4 / P6 results below are unconditionally proved.
* The flagship n-body theorems
  (`golden_regular_polygon_equilibrium`,
   `golden1D_equilibrium_iff_stieltjes`)
  are stated; their proofs reduce to finite-sum algebra plus the classical
  root-of-unity sums and the Stieltjes/Hermite electrostatic identity. They
  are recorded as `sorry`-marked targets with proof outlines in their
  docstrings.
* The conjectured polygon stability threshold `N_crit = 7` is recorded
  only as documentation, not as a Lean theorem.
-/

section GoldenMechanics

-- =========================================================================
-- Tier P1 — Free Golden dynamics and minimum-thrust station keeping
-- =========================================================================

/--
Discrete free Golden evolution.

The free Golden dynamics is the iteration `z_{n+1} = lambdaG1 · z_n`,
whose closed form is `z_n = lambdaG1^n · z_0`.
-/
noncomputable def goldenFreeOrbit (z0 : ℂ) (n : ℕ) : ℂ :=
  lambdaG1 ^ n * z0

@[simp] theorem goldenFreeOrbit_zero (z0 : ℂ) :
    goldenFreeOrbit z0 0 = z0 := by
  simp [goldenFreeOrbit]

theorem goldenFreeOrbit_succ (z0 : ℂ) (n : ℕ) :
    goldenFreeOrbit z0 (n + 1) = lambdaG1 * goldenFreeOrbit z0 n := by
  simp [goldenFreeOrbit, pow_succ]; ring

/-- Golden free energy, modeled as squared complex norm `‖z‖²`. -/
noncomputable def goldenEnergy1 (z : ℂ) : ℝ := ‖z‖ ^ 2

/-- The free Golden orbit dissipates energy geometrically:
`E_n = ‖λ_G‖^(2n) E_0`. -/
theorem goldenFreeOrbit_energy_exact (z0 : ℂ) (n : ℕ) :
    goldenEnergy1 (goldenFreeOrbit z0 n)
      = ‖lambdaG1‖ ^ (2 * n) * goldenEnergy1 z0 := by
  unfold goldenEnergy1 goldenFreeOrbit
  rw [norm_mul, norm_pow, mul_pow, ← pow_mul]
  congr 1
  congr 1
  omega

/-- One-step energy contraction: `E_{n+1} = ‖λ_G‖² · E_n`. -/
theorem goldenFreeOrbit_energy_contracts (z0 : ℂ) (n : ℕ) :
    goldenEnergy1 (goldenFreeOrbit z0 (n + 1))
      = ‖lambdaG1‖ ^ 2 * goldenEnergy1 (goldenFreeOrbit z0 n) := by
  rw [goldenFreeOrbit_succ]
  unfold goldenEnergy1
  rw [norm_mul, mul_pow]

/-- One controlled Golden step `z_{n+1} = λ_G · z_n + u_n`. -/
noncomputable def goldenControlledStep (z u : ℂ) : ℂ :=
  lambdaG1 * z + u

/-- The exact thrust required to convert the Golden contraction into a
unitary rotation by angle `θ`:
`u_n = (e^{iθ} − λ_G) · z_n`. -/
noncomputable def circularizingControl (theta : ℝ) (z : ℂ) : ℂ :=
  (Complex.exp ((theta : ℂ) * I) - lambdaG1) * z

/-- With the circularizing control, one Golden step becomes a pure rotation. -/
theorem goldenControlledStep_circularizes (theta : ℝ) (z : ℂ) :
    goldenControlledStep z (circularizingControl theta z)
      = Complex.exp ((theta : ℂ) * I) * z := by
  unfold goldenControlledStep circularizingControl
  ring

/-- The circularized step preserves the orbit radius:
`‖z_{n+1}‖ = ‖z_n‖`. -/
theorem goldenControlledStep_preserves_norm (theta : ℝ) (z : ℂ) :
    ‖goldenControlledStep z (circularizingControl theta z)‖ = ‖z‖ := by
  rw [goldenControlledStep_circularizes]
  simp [norm_mul, norm_exp_ofReal_mul_I]

/-- Minimum-thrust lower bound: every circularizing control has magnitude
at least `(1 − ‖λ_G‖) · ‖z‖`. The bound is attained when `θ = arg(λ_G)`. -/
theorem circularizingControl_norm_lower_bound (theta : ℝ) (z : ℂ) :
    (1 - ‖lambdaG1‖) * ‖z‖ ≤ ‖circularizingControl theta z‖ := by
  unfold circularizingControl
  rw [norm_mul]
  have hexp : ‖Complex.exp ((theta : ℂ) * I)‖ = 1 := by
    simp [norm_exp_ofReal_mul_I]
  have hkey :
      |‖Complex.exp ((theta : ℂ) * I)‖ - ‖lambdaG1‖|
        ≤ ‖Complex.exp ((theta : ℂ) * I) - lambdaG1‖ :=
    abs_norm_sub_norm_le _ _
  have h1 :
      1 - ‖lambdaG1‖ ≤ ‖Complex.exp ((theta : ℂ) * I) - lambdaG1‖ := by
    have h := hkey
    rw [hexp] at h
    exact (le_abs_self _).trans h
  exact mul_le_mul_of_nonneg_right h1 (norm_nonneg _)

-- =========================================================================
-- Tier P2 — Conservative radial mechanics
-- =========================================================================

/-- Radial Golden pair coefficient `T − H² / r²`.
Equal to the already-defined `Teff r`; recorded under a physics-flavored
name for use inside the n-body force law. -/
noncomputable def goldenRadialCoeff (r : ℝ) : ℝ := T - H ^ 2 / r ^ 2

@[simp] theorem goldenRadialCoeff_eq_Teff (r : ℝ) :
    goldenRadialCoeff r = Teff r := rfl

/-- Conservative radial Golden pair force on `zᵢ` produced by `zⱼ`:
`Fᵢⱼ = (T − H²/|zⱼ − zᵢ|²) (zⱼ − zᵢ)`. -/
noncomputable def goldenRadialPairForce (zi zj : ℂ) : ℂ :=
  ((goldenRadialCoeff ‖zj - zi‖ : ℝ) : ℂ) * (zj - zi)

/-- Pair antisymmetry: `Fᵢⱼ = −Fⱼᵢ`. This is the Newton-third-law identity
underwriting conservation of total linear momentum. -/
theorem goldenRadialPairForce_antisymm (zi zj : ℂ) :
    goldenRadialPairForce zi zj = - goldenRadialPairForce zj zi := by
  unfold goldenRadialPairForce
  have hnorm : ‖zi - zj‖ = ‖zj - zi‖ := by
    simpa using norm_neg (zj - zi)
  rw [hnorm]
  ring

/-- The Golden radial pair potential
`U(r) = ½ T r² − H² log r`.
Physically meaningful for `r > 0`. The force law `F = −∇U` reduces to
`(T − H²/r²) · r̂ · r` in the radial direction. -/
noncomputable def goldenPairPotential (r : ℝ) : ℝ :=
  (1 / 2 : ℝ) * T * r ^ 2 - H ^ 2 * Real.log r

/-- One-dimensional derivative of the radial pair potential:
`U'(r) = T r − H² / r` for `r ≠ 0`. -/
theorem hasDerivAt_goldenPairPotential {r : ℝ} (hr : r ≠ 0) :
    HasDerivAt goldenPairPotential (T * r - H ^ 2 / r) r := by
  have h_pow : HasDerivAt (fun x : ℝ => x ^ 2) (2 * r) r := by
    simpa using hasDerivAt_pow 2 r
  have h1 : HasDerivAt (fun x : ℝ => (1 / 2 : ℝ) * T * x ^ 2) (T * r) r := by
    have := h_pow.const_mul ((1 / 2 : ℝ) * T)
    convert this using 1
    ring
  have h_log : HasDerivAt Real.log r⁻¹ r := Real.hasDerivAt_log hr
  have h2 : HasDerivAt (fun x : ℝ => H ^ 2 * Real.log x) (H ^ 2 / r) r := by
    have := h_log.const_mul (H ^ 2)
    convert this using 1
  exact h1.sub h2

-- =========================================================================
-- Tier P3 — Two-body exact results
-- =========================================================================

/-- The unique radial separation at which the Golden pair force vanishes:
`r_T = H / √T`. -/
noncomputable def goldenEquilibriumRadius : ℝ := H / Real.sqrt T

theorem goldenEquilibriumRadius_pos : 0 < goldenEquilibriumRadius := by
  unfold goldenEquilibriumRadius
  exact div_pos H_pos (Real.sqrt_pos.mpr T_pos)

/-- The radial Golden coefficient vanishes at `r = r_T = H/√T`:
`T − H² / r_T² = 0`. -/
theorem goldenRadialCoeff_eq_zero_at_equilibrium :
    goldenRadialCoeff goldenEquilibriumRadius = 0 := by
  unfold goldenRadialCoeff goldenEquilibriumRadius
  have hT : (0 : ℝ) < T := T_pos
  have hT_ne : T ≠ 0 := ne_of_gt hT
  have hsqT_pos : 0 < Real.sqrt T := Real.sqrt_pos.mpr hT
  have _hsqT_ne : Real.sqrt T ≠ 0 := ne_of_gt hsqT_pos
  have _hH_ne : H ≠ 0 := ne_of_gt H_pos
  have hsqT_sq : (Real.sqrt T) ^ 2 = T := Real.sq_sqrt hT.le
  have hsq : (H / Real.sqrt T) ^ 2 = H ^ 2 / T := by
    rw [div_pow, hsqT_sq]
  rw [hsq]
  have hH_sq_ne : H ^ 2 ≠ 0 := pow_ne_zero 2 (ne_of_gt H_pos)
  field_simp [hH_sq_ne, hT_ne]

/-- Squared circular orbit frequency `Ω²(r) = 2(T − H²/r²)` for two
equal-mass bodies. -/
noncomputable def goldenTwoBodyOmegaSq (r : ℝ) : ℝ :=
  2 * goldenRadialCoeff r

/-- Circular orbit frequency `Ω(r) = √(2 (T − H²/r²))`. -/
noncomputable def goldenTwoBodyOmega (r : ℝ) : ℝ :=
  Real.sqrt (goldenTwoBodyOmegaSq r)

/-- Squared orbital frequency is positive exactly when the separation
exceeds the equilibrium radius `r_T = H/√T`. -/
theorem goldenTwoBodyOmegaSq_pos_of_gt_equilibrium
    {r : ℝ} (hr_pos : 0 < r) (hr : goldenEquilibriumRadius < r) :
    0 < goldenTwoBodyOmegaSq r := by
  unfold goldenTwoBodyOmegaSq goldenRadialCoeff
  have hT : (0 : ℝ) < T := T_pos
  have hsqT_pos : 0 < Real.sqrt T := Real.sqrt_pos.mpr hT
  have hsqT_sq : (Real.sqrt T) ^ 2 = T := Real.sq_sqrt hT.le
  have hHlt : H < r * Real.sqrt T := by
    have := (div_lt_iff₀ hsqT_pos).mp
      (by simpa [goldenEquilibriumRadius] using hr)
    exact this
  have hH_nn : 0 ≤ H := H_pos.le
  have hH_sq_lt : H ^ 2 < (r * Real.sqrt T) ^ 2 := by
    have := mul_self_lt_mul_self hH_nn hHlt
    simpa [pow_two] using this
  have hRHS_sq : (r * Real.sqrt T) ^ 2 = r ^ 2 * T := by
    rw [mul_pow, hsqT_sq]
  rw [hRHS_sq] at hH_sq_lt
  have hr_sq_pos : 0 < r ^ 2 := by positivity
  have hdiv : H ^ 2 / r ^ 2 < T := by
    rw [div_lt_iff₀ hr_sq_pos]
    linarith
  linarith

-- =========================================================================
-- Tier P4 — N-body conservation: pairwise antisymmetry ⇒ Σᵢ Fᵢ = 0
-- =========================================================================

/-- The radial Golden total force on body `i`:
`F_i = Σ_{j ≠ i} F_{ij}^{rad}`. -/
noncomputable def goldenRadialTotalForce
    (N : ℕ) (z : Fin N → ℂ) (i : Fin N) : ℂ :=
  ∑ j : Fin N, if j = i then 0 else goldenRadialPairForce (z i) (z j)

/-- General lemma: a pair-antisymmetric family `F i j = − F j i` on a
finite index type sums to zero in characteristic 0.

This is the structural fact powering Newton's third law: internal forces
cancel in pairs. -/
lemma sum_pairwise_antisymm_zero
    {α : Type*} [Fintype α] [DecidableEq α]
    (F : α → α → ℂ)
    (hanti : ∀ i j, F i j = - F j i) :
    (∑ i : α, ∑ j : α, F i j) = 0 := by
  -- Show S = -S by replacing F i j with -F j i and swapping the sums.
  have hswap_neg :
      (∑ i : α, ∑ j : α, F i j)
        = - ∑ i : α, ∑ j : α, F i j := by
    calc (∑ i : α, ∑ j : α, F i j)
        = ∑ i : α, ∑ j : α, -F j i := by
          refine Finset.sum_congr rfl fun i _ => ?_
          refine Finset.sum_congr rfl fun j _ => ?_
          exact hanti i j
      _ = -∑ i : α, ∑ j : α, F j i := by
          simp only [Finset.sum_neg_distrib]
      _ = -∑ j : α, ∑ i : α, F j i := by
          rw [Finset.sum_comm]
      _ = -∑ i : α, ∑ j : α, F i j := rfl
  -- S = -S in ℂ implies S = 0 since 2 ≠ 0.
  linear_combination (1 / 2 : ℂ) * hswap_neg

/-- Total internal Golden radial force on an n-body system vanishes:
`Σᵢ Fᵢ = 0`. This is the conservation of total linear momentum. -/
theorem goldenRadialTotalForce_sum_zero
    (N : ℕ) (z : Fin N → ℂ) :
    (∑ i : Fin N, goldenRadialTotalForce N z i) = 0 := by
  unfold goldenRadialTotalForce
  set F : Fin N → Fin N → ℂ :=
    fun i j => if j = i then 0 else goldenRadialPairForce (z i) (z j)
    with hFdef
  have hanti : ∀ i j : Fin N, F i j = - F j i := by
    intro i j
    by_cases hij : j = i
    · -- diagonal case: both `F i j` and `F j i` are zero by definition
      have h1 : F i j = 0 := by simp [hFdef, hij]
      have h2 : F j i = 0 := by
        have hii : (i : Fin N) = j := hij.symm
        simp [hFdef, hii]
      rw [h1, h2, neg_zero]
    · have hji : ¬ (i = j) := fun h => hij h.symm
      have hpair : goldenRadialPairForce (z i) (z j)
              = - goldenRadialPairForce (z j) (z i) :=
        goldenRadialPairForce_antisymm (z i) (z j)
      simp [hFdef, hij, hji, hpair]
  have := sum_pairwise_antisymm_zero (α := Fin N) F hanti
  -- The hypothesis matches the goal up to definitional unfolding of `F`.
  exact this

-- =========================================================================
-- Tier P5 — Exact equilibria (flagship statements)
-- =========================================================================

/-- Regular polygon radius for the radial Golden n-body equilibrium:
`R_N = H · √((N − 1) / (2 T N))`. -/
noncomputable def goldenPolygonRadius (N : ℕ) : ℝ :=
  H * Real.sqrt (((N : ℝ) - 1) / (2 * T * (N : ℝ)))

/-- The `k`-th vertex of the regular Golden `N`-gon, with the canonical
radius `R_N`. -/
noncomputable def goldenPolygonPoint (N : ℕ) (k : Fin N) : ℂ :=
  ((goldenPolygonRadius N : ℝ) : ℂ) *
    Complex.exp ((2 * Real.pi * (k : ℝ) / (N : ℝ) : ℝ) * I)

/-- **Flagship n-body theorem (target).** For every `N ≥ 2`, the regular
polygon of radius `R_N` is a Golden radial equilibrium.

Proof outline (to be formalised):
1. Centre identity: `Σ_{j ≠ i} (zⱼ − zᵢ) = − N · zᵢ`, because
   `Σ_k e^{2πik/N} = 0`.
2. Inverse-square identity: for the regular polygon,
   `Σ_{j ≠ i} (zⱼ − zᵢ) / |zⱼ − zᵢ|² = − (N − 1) / (2 R²) · zᵢ`.
   Uses `|zⱼ − zᵢ|² = 2 R² (1 − cos((j − i) · 2π/N))` together with
   the classical pair-summation identity for `1 / (1 − cos)`.
3. Substituting these two identities into `goldenRadialTotalForce`
   reduces the equilibrium condition to
   `T · N = H² · (N − 1) / (2 R²)`, i.e. `R² = H² (N − 1) / (2 T N) = R_N²`.
-/
theorem golden_regular_polygon_equilibrium
    {N : ℕ} (_hN : 2 ≤ N) :
    ∀ i : Fin N,
      goldenRadialTotalForce N (goldenPolygonPoint N) i = 0 := by
  -- Reduces to the two finite-sum identities outlined above.
  sorry

/-- One-dimensional radial Golden pair force on `xᵢ` from `xⱼ`. -/
noncomputable def golden1DPairForce (xi xj : ℝ) : ℝ :=
  (T - H ^ 2 / (xj - xi) ^ 2) * (xj - xi)

/-- Total 1D radial Golden force on `xᵢ`. -/
noncomputable def golden1DTotalForce
    (N : ℕ) (x : Fin N → ℝ) (i : Fin N) : ℝ :=
  ∑ j : Fin N, if j = i then 0 else golden1DPairForce (x i) (x j)

/-- **Flagship n-body theorem (target).** Under centre-of-mass zero and
pairwise-distinct positions, the 1D Golden equilibrium equation is
equivalent to the Stieltjes/Hermite electrostatic identity

`Σ_{j ≠ i} 1 / (xᵢ − xⱼ) = (T N / H²) xᵢ`.

Proof outline: split `(T − H² / (xⱼ − xᵢ)²)(xⱼ − xᵢ)` into
`T (xⱼ − xᵢ) − H² / (xⱼ − xᵢ)` and use `Σ_j xⱼ = 0` for the linear part. -/
theorem golden1D_equilibrium_iff_stieltjes
    {N : ℕ} (_hN : 1 ≤ N)
    (x : Fin N → ℝ)
    (hcenter : (∑ i : Fin N, x i) = 0)
    (hsep : ∀ i j : Fin N, i ≠ j → x i ≠ x j) :
    (∀ i, golden1DTotalForce N x i = 0)
      ↔
    (∀ i,
      (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x i - x j))
        = (T * (N : ℝ) / H ^ 2) * x i) := by
  have hH_sq_pos : (0 : ℝ) < H ^ 2 := pow_pos H_pos 2
  have hH_sq_ne : (H : ℝ) ^ 2 ≠ 0 := ne_of_gt hH_sq_pos
  -- Per-term split:
  --   if j = i then 0 else (T - H²/(xj-xi)²)(xj - xi)
  --     = T*(xj - xi) - H² * (if j = i then 0 else 1/(xj - xi))
  -- The linear part `T*(xj - xi)` already agrees with `0` at `j = i`
  -- since `x i - x i = 0`.
  have pair_split : ∀ i j : Fin N,
      (if j = i then (0 : ℝ) else golden1DPairForce (x i) (x j))
        = T * (x j - x i)
          - H ^ 2 * (if j = i then (0 : ℝ) else 1 / (x j - x i)) := by
    intro i j
    by_cases hij : j = i
    · rw [hij]; simp
    · have hxne : x j ≠ x i := hsep j i hij
      have hsub_ne : x j - x i ≠ 0 := sub_ne_zero.mpr hxne
      simp only [hij, if_false]
      unfold golden1DPairForce
      field_simp
      ring
  -- Sum of linear part uses Σ x = 0.
  have h_linear : ∀ i, (∑ j : Fin N, (x j - x i)) = -((N : ℝ) * x i) := by
    intro i
    rw [Finset.sum_sub_distrib, hcenter, Finset.sum_const, Finset.card_univ,
        Fintype.card_fin, nsmul_eq_mul]
    ring
  -- Sign-flip identity for the Stieltjes sum: `1/(xj-xi) = -1/(xi-xj)`.
  have h_flip : ∀ i,
      (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x j - x i))
        = -(∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x i - x j)) := by
    intro i
    rw [← Finset.sum_neg_distrib]
    apply Finset.sum_congr rfl
    intro j _
    by_cases hij : j = i
    · rw [hij]; simp
    · simp only [hij, if_false]
      rw [show x j - x i = -(x i - x j) from (neg_sub _ _).symm, div_neg]
  -- Closed form: `F_total(i) = -T·N·x_i + H² · Stieltjes(i)`.
  have h_total : ∀ i,
      golden1DTotalForce N x i
        = -T * (N : ℝ) * x i
          + H ^ 2 * (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x i - x j)) := by
    intro i
    unfold golden1DTotalForce
    rw [show (∑ j : Fin N, if j = i then (0 : ℝ)
                              else golden1DPairForce (x i) (x j))
          = ∑ j : Fin N, (T * (x j - x i)
            - H ^ 2 * (if j = i then (0 : ℝ) else 1 / (x j - x i))) from
        Finset.sum_congr rfl (fun j _ => pair_split i j)]
    rw [Finset.sum_sub_distrib, ← Finset.mul_sum, ← Finset.mul_sum,
        h_linear i, h_flip i]
    ring
  -- Now the equivalence is pure linear algebra.
  refine ⟨fun h i => ?_, fun h i => ?_⟩
  · have heq := h i
    rw [h_total i] at heq
    have h1 : H ^ 2 * (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x i - x j))
                = T * (N : ℝ) * x i := by linarith
    have h2 : (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (x i - x j))
                = T * (N : ℝ) * x i / H ^ 2 :=
      (eq_div_iff hH_sq_ne).mpr (by linarith)
    rw [h2]; ring
  · have heq := h i
    rw [h_total i, heq]
    field_simp

/-- **Stieltjes configuration.** A finite tuple of real positions satisfying
the Hermite electrostatic identity.

Physically, the roots `y₁ < ⋯ < y_N` of the physicists' Hermite polynomial
`H_N` form such a configuration. This structure lets us decouple the
Golden-mechanics result from the Mathlib status of Hermite polynomials:
once Hermite roots are formalised, they instantiate this structure. -/
structure HermiteStieltjesConfig (N : ℕ) where
  y : Fin N → ℝ
  separated : ∀ i j : Fin N, i ≠ j → y i ≠ y j
  stieltjes :
    ∀ i,
      (∑ j : Fin N, if j = i then (0 : ℝ) else 1 / (y i - y j)) = y i
  center_zero : (∑ i : Fin N, y i) = 0

/-- Golden Hermite scale `H / √(T N)`. -/
noncomputable def goldenHermiteScale (N : ℕ) : ℝ :=
  H / Real.sqrt (T * (N : ℝ))

/-- Scaled Hermite configuration: `xᵢ = (H / √(T N)) · yᵢ`. -/
noncomputable def goldenHermiteConfig
    {N : ℕ} (Y : HermiteStieltjesConfig N) : Fin N → ℝ :=
  fun i => goldenHermiteScale N * Y.y i

/-! **Open conjecture (documentation only).**

*Regular-polygon stability threshold.* Numerical experiments (see
`golden_phi_stress_test.py`, `golden_resonance_fit.py`) show that the
