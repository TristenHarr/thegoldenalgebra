/-- **PROVED — `1/Γ(1/2) = 1/√π`** (Gamma half identity). Constant. -/
theorem one_over_gamma_half :
    (1 : ℝ) / Real.sqrt Real.pi > 0.564
    ∧ (1 : ℝ) / Real.sqrt Real.pi < 0.565 := by
  -- √π ≈ 1.7724539, so 1/√π ≈ 0.564189...
  have h_sqrt_pi_lower : Real.sqrt Real.pi > 1.77 := by
    rw [show (1.77 : ℝ) = Real.sqrt 3.1329 from by
      rw [show (3.1329 : ℝ) = (1.77 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 1.77)).symm]
    apply Real.sqrt_lt_sqrt (by norm_num)
    have hπ : Real.pi > 3.14 := Real.pi_gt_d2
    linarith
  have h_sqrt_pi_upper : Real.sqrt Real.pi < 1.7725 := by
    rw [show (1.7725 : ℝ) = Real.sqrt 3.14175625 from by
      rw [show (3.14175625 : ℝ) = (1.7725 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 1.7725)).symm]
    apply Real.sqrt_lt_sqrt
    · positivity
    · have hπ : Real.pi < 3.1416 := Real.pi_lt_d4
      linarith
  refine ⟨?_, ?_⟩
  · rw [gt_iff_lt, lt_div_iff₀ (by positivity)]
    nlinarith [h_sqrt_pi_upper, Real.sqrt_pos.mpr (show (0 : ℝ) < Real.pi from Real.pi_pos)]
  · rw [div_lt_iff₀ (by positivity)]
    nlinarith [h_sqrt_pi_lower]

