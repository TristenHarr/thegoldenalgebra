-- --- Tier 9.1 — Golden Affine Fixed-Point Uniqueness ----------------

/-- The Golden affine map `x ↦ λ·x + b` has a **unique** complex fixed
point at `x = b / (1 − λ)`. Contraction-principle import: `‖λ‖ < 1`
forces `1 − λ ≠ 0`, giving an explicit, unique solution. -/
theorem goldenAffine_fixed_unique (b : ℂ) :
    ∃! x : ℂ, x = lambdaG1 * x + b := by
  have hne : (1 : ℂ) - lambdaG1 ≠ 0 := one_sub_lambdaG1_ne_zero
  refine ⟨b / (1 - lambdaG1), ?_, ?_⟩
  · field_simp; ring
  · intro y hy
    rw [eq_div_iff hne]
    linear_combination hy

/-- Closed-form witness: `b/(1-λ)` is a fixed point. -/
theorem goldenAffine_fixed_value (b : ℂ) :
    b / (1 - lambdaG1) = lambdaG1 * (b / (1 - lambdaG1)) + b := by
  have hne : (1 : ℂ) - lambdaG1 ≠ 0 := one_sub_lambdaG1_ne_zero
  field_simp; ring

-- --- Tier 9.2 — Golden Affine Iterate Convergence -------------------

/-- The Golden affine iteration `xₙ₊₁ = λ·xₙ + b`, from any seed `x₀`,
converges to the fixed point `b / (1 − λ)`.
Proof: closed form `xₙ = x* + λⁿ·(x₀ − x*)` where `x* = b/(1−λ)`. -/
theorem goldenAffine_iterate_converges (x₀ b : ℂ) :
    Tendsto
      (fun n : ℕ => (fun x : ℂ => lambdaG1 * x + b)^[n] x₀)
      Filter.atTop
      (𝓝 (b / (1 - lambdaG1))) := by
  have hne : (1 : ℂ) - lambdaG1 ≠ 0 := one_sub_lambdaG1_ne_zero
  set x_star : ℂ := b / (1 - lambdaG1) with hxstar_def
  have h_fixed : lambdaG1 * x_star + b = x_star := by
    rw [hxstar_def]; field_simp; ring
  have hclosed : ∀ n : ℕ,
      (fun x : ℂ => lambdaG1 * x + b)^[n] x₀
        = x_star + lambdaG1 ^ n * (x₀ - x_star) := by
    intro n
    induction n with
    | zero => simp
    | succ n ih =>
      rw [Function.iterate_succ_apply', ih]
      -- Goal: λ * (x* + λ^n * (x₀ - x*)) + b = x* + λ^(n+1) * (x₀ - x*)
      have hpow : lambdaG1 ^ (n + 1) = lambdaG1 * lambdaG1 ^ n := by
        rw [pow_succ, mul_comm]
      rw [hpow]
      linear_combination h_fixed
  have hpow_tendsto : Tendsto (fun n : ℕ => lambdaG1 ^ n) Filter.atTop (𝓝 0) :=
    tendsto_pow_atTop_nhds_zero_of_norm_lt_one norm_lambdaG1_lt_one
  have h_tendsto :
      Tendsto (fun n : ℕ => x_star + lambdaG1 ^ n * (x₀ - x_star))
        Filter.atTop (𝓝 (x_star + 0 * (x₀ - x_star))) :=
    tendsto_const_nhds.add (hpow_tendsto.mul_const _)
  have h_simp : x_star + 0 * (x₀ - x_star) = x_star := by ring
  rw [h_simp] at h_tendsto
  refine (Filter.tendsto_congr ?_).mpr h_tendsto
  intro n
  exact hclosed n

-- --- Tier 9.3 — Golden Probability Weights -------------------------

/-- The **Golden geometric weights**:
  `goldenWeight n = (1 − ‖λ‖) · ‖λ‖ⁿ`.
A geometric probability distribution on `ℕ` with parameter `‖λ‖`. -/
noncomputable def goldenWeight (n : ℕ) : ℝ :=
  (1 - ‖lambdaG1‖) * ‖lambdaG1‖ ^ n

/-- Each Golden weight is non-negative. -/
theorem goldenWeight_nonneg (n : ℕ) : 0 ≤ goldenWeight n := by
  unfold goldenWeight
  have : (0 : ℝ) ≤ 1 - ‖lambdaG1‖ := by linarith [norm_lambdaG1_lt_one]
  positivity

/-- **The Golden weights sum to 1**: `Σₙ goldenWeight n = 1`.
A direct consequence of `Σ rⁿ = 1/(1−r)` for `0 ≤ r < 1` at `r = ‖λ‖`. -/
theorem goldenWeight_tsum_eq_one :
    ∑' n : ℕ, goldenWeight n = 1 := by
  unfold goldenWeight
  rw [tsum_mul_left]
  rw [tsum_geometric_of_lt_one (norm_nonneg _) norm_lambdaG1_lt_one]
  have h1_ne : (1 : ℝ) - ‖lambdaG1‖ ≠ 0 := by
    have := norm_lambdaG1_lt_one; linarith
  field_simp

-- --- Tier 9.4 — Generic SpectralContractionPair --------------------

/-- **Generic spectral contraction pair.**
The abstract structure underlying every Golden trace/zeta/theta
construction: a complex multiplier with norm `< 1`. Any theorem in
Tiers 4–7 that doesn't depend on the specific value of `lambdaG1` can
be lifted to this generic setting. -/
structure SpectralContractionPair where
  /-- The complex spectral parameter. -/
  lam : ℂ
  /-- The contraction hypothesis. -/
  hlam : ‖lam‖ < 1

/-- The Golden multiplier `lambdaG1` is an instance of
`SpectralContractionPair`. -/
noncomputable def goldenSpectralPair : SpectralContractionPair :=
  ⟨lambdaG1, norm_lambdaG1_lt_one⟩

/-- For any spectral contraction pair, `1 − λ ≠ 0`. -/
theorem SpectralContractionPair.one_sub_lam_ne_zero
    (S : SpectralContractionPair) : (1 : ℂ) - S.lam ≠ 0 := by
  intro h
  have hlam_eq : S.lam = 1 := by linear_combination -h
  have hnorm : ‖S.lam‖ = 1 := by rw [hlam_eq]; simp
  linarith [S.hlam]

/-- For any spectral contraction pair, the affine map `x ↦ λ·x + b`
has a unique complex fixed point. -/
theorem SpectralContractionPair.affine_fixed_unique
    (S : SpectralContractionPair) (b : ℂ) :
    ∃! x : ℂ, x = S.lam * x + b := by
  have hne := S.one_sub_lam_ne_zero
  refine ⟨b / (1 - S.lam), ?_, ?_⟩
  · field_simp; ring
  · intro y hy
    rw [eq_div_iff hne]
    linear_combination hy

/-- For any spectral contraction pair, the affine iteration converges
to the unique fixed point. -/
theorem SpectralContractionPair.affine_iterate_converges
    (S : SpectralContractionPair) (x₀ b : ℂ) :
    Tendsto
      (fun n : ℕ => (fun x : ℂ => S.lam * x + b)^[n] x₀)
      Filter.atTop
      (𝓝 (b / (1 - S.lam))) := by
  have hne := S.one_sub_lam_ne_zero
  set x_star : ℂ := b / (1 - S.lam) with hxstar_def
  have h_fixed : S.lam * x_star + b = x_star := by
    rw [hxstar_def]; field_simp; ring
  have hclosed : ∀ n : ℕ,
      (fun x : ℂ => S.lam * x + b)^[n] x₀
        = x_star + S.lam ^ n * (x₀ - x_star) := by
    intro n
    induction n with
    | zero => simp
    | succ n ih =>
      rw [Function.iterate_succ_apply', ih]
      have hpow : S.lam ^ (n + 1) = S.lam * S.lam ^ n := by
        rw [pow_succ, mul_comm]
      rw [hpow]
      linear_combination h_fixed
  have hpow_tendsto : Tendsto (fun n : ℕ => S.lam ^ n) Filter.atTop (𝓝 0) :=
    tendsto_pow_atTop_nhds_zero_of_norm_lt_one S.hlam
  have h_tendsto :
      Tendsto (fun n : ℕ => x_star + S.lam ^ n * (x₀ - x_star))
        Filter.atTop (𝓝 (x_star + 0 * (x₀ - x_star))) :=
    tendsto_const_nhds.add (hpow_tendsto.mul_const _)
  have h_simp : x_star + 0 * (x₀ - x_star) = x_star := by ring
  rw [h_simp] at h_tendsto
  refine (Filter.tendsto_congr ?_).mpr h_tendsto
  intro n
  exact hclosed n

/-- The Golden affine theorems are *instantiations* of the generic
spectral-contraction theorem at `goldenSpectralPair`. -/
theorem goldenAffine_fixed_unique_via_generic (b : ℂ) :
    ∃! x : ℂ, x = lambdaG1 * x + b :=
  goldenSpectralPair.affine_fixed_unique b

-- =====================================================================
-- === Tier 10 — Generic Spectral Contraction Theory ===================
-- =====================================================================
-- Abstract the Golden zeta/theta pipeline to any spectral contraction
-- pair `S` with `‖S.lam‖ < 1`. Golden becomes one instance.

/-- **Generic complex trace** for a spectral contraction pair:
  `traceC(n) = λⁿ + (λ̄)ⁿ`. -/
noncomputable def SpectralContractionPair.traceC
    (S : SpectralContractionPair) (n : ℕ) : ℂ :=
  S.lam ^ n + (star S.lam) ^ n

/-- For any contraction pair, `‖star λ‖ = ‖λ‖`. -/
theorem SpectralContractionPair.norm_star_lam
    (S : SpectralContractionPair) : ‖star S.lam‖ = ‖S.lam‖ :=
  norm_star S.lam

/-- **Generic dynamical zeta**: `ζ_S(z) = 1 / ((1 − λz)(1 − λ̄z))`. -/
noncomputable def SpectralContractionPair.dynamicalZeta
    (S : SpectralContractionPair) (z : ℂ) : ℂ :=
  1 / ((1 - S.lam * z) * (1 - (star S.lam) * z))

/-- **Generic trace generating function (split form).**
For any `S` and `‖S.lam · z‖ < 1`:
  `Σₙ traceC(n) · zⁿ  =  1/(1 − λz)  +  1/(1 − λ̄z)`. -/
theorem SpectralContractionPair.trace_generating_function_split
    (S : SpectralContractionPair) (z : ℂ) (hz : ‖S.lam * z‖ < 1) :
    HasSum (fun n : ℕ => S.traceC n * z ^ n)
      (1 / (1 - S.lam * z) + 1 / (1 - (star S.lam) * z)) := by
  have hstar_z : ‖(star S.lam) * z‖ < 1 := by
    rw [norm_mul, S.norm_star_lam, ← norm_mul]; exact hz
  have hne1 : (1 : ℂ) - S.lam * z ≠ 0 :=
    one_sub_mul_ne_zero_of_norm_lt_one hz
  have hne2 : (1 : ℂ) - (star S.lam) * z ≠ 0 :=
    one_sub_mul_ne_zero_of_norm_lt_one hstar_z
  have hlam : HasSum (fun n : ℕ => (S.lam * z) ^ n)
      (1 / (1 - S.lam * z)) := by
    have h := hasSum_geometric_of_norm_lt_one hz
    convert h using 1; field_simp
  have hstar : HasSum (fun n : ℕ => ((star S.lam) * z) ^ n)
      (1 / (1 - (star S.lam) * z)) := by
    have h := hasSum_geometric_of_norm_lt_one hstar_z
    convert h using 1; field_simp
  have hsum := hlam.add hstar
  refine hsum.congr_fun ?_
  intro n
  show S.traceC n * z ^ n = (S.lam * z) ^ n + ((star S.lam) * z) ^ n
  rw [SpectralContractionPair.traceC, mul_pow, mul_pow]
  ring

/-- **Generic trace gen ↔ dynamical zeta bridge.**
`Σₙ traceC(n) · zⁿ = (2 − (λ + λ̄) · z) · ζ_S(z)`. -/
theorem SpectralContractionPair.trace_generating_function_via_zeta
    (S : SpectralContractionPair) (z : ℂ) (hz : ‖S.lam * z‖ < 1) :
    HasSum (fun n : ℕ => S.traceC n * z ^ n)
      ((2 - (S.lam + star S.lam) * z) * S.dynamicalZeta z) := by
  have hsplit := S.trace_generating_function_split z hz
  have hstar_z : ‖(star S.lam) * z‖ < 1 := by
    rw [norm_mul, S.norm_star_lam, ← norm_mul]; exact hz
  have hne1 : (1 : ℂ) - S.lam * z ≠ 0 :=
    one_sub_mul_ne_zero_of_norm_lt_one hz
  have hne2 : (1 : ℂ) - (star S.lam) * z ≠ 0 :=
    one_sub_mul_ne_zero_of_norm_lt_one hstar_z
  have hcomb : 1 / (1 - S.lam * z) + 1 / (1 - (star S.lam) * z)
      = (2 - (S.lam + star S.lam) * z) * S.dynamicalZeta z := by
    unfold SpectralContractionPair.dynamicalZeta
    rw [div_add_div _ _ hne1 hne2, mul_one_div]
    congr 1
    ring
  rw [← hcomb]
  exact hsplit

/-- **Generic log-zeta trace expansion** (HasSum form).
For any `S` and `‖S.lam · z‖ < 1`:
  `Σₙ traceC(n) · zⁿ / n  =  −log(1 − λz) − log(1 − λ̄z)`. -/
theorem SpectralContractionPair.log_zeta_trace_expansion
    (S : SpectralContractionPair) (z : ℂ) (hz : ‖S.lam * z‖ < 1) :
    HasSum (fun n : ℕ => S.traceC n * z ^ n / (n : ℂ))
      (-Complex.log (1 - S.lam * z)
        - Complex.log (1 - (star S.lam) * z)) := by
  have hstar_z : ‖(star S.lam) * z‖ < 1 := by
    rw [norm_mul, S.norm_star_lam, ← norm_mul]; exact hz
  have h1 : HasSum (fun n : ℕ => (S.lam * z) ^ n / (n : ℂ))
      (-Complex.log (1 - S.lam * z)) :=
    Complex.hasSum_taylorSeries_neg_log hz
  have h2 : HasSum (fun n : ℕ => ((star S.lam) * z) ^ n / (n : ℂ))
      (-Complex.log (1 - (star S.lam) * z)) :=
    Complex.hasSum_taylorSeries_neg_log hstar_z
  have hsum := h1.add h2
  refine hsum.congr_fun ?_
  intro n
  show S.traceC n * z ^ n / (n : ℂ)
      = (S.lam * z) ^ n / (n : ℂ) + ((star S.lam) * z) ^ n / (n : ℂ)
  rw [SpectralContractionPair.traceC, mul_pow, mul_pow]
  ring

-- --- Golden re-exports as instances of the generic theory -----------

/-- The Golden trace `goldenTraceC` equals the generic
`SpectralContractionPair.traceC` at `goldenSpectralPair`. -/
theorem goldenTraceC_eq_spectralPair_traceC (n : ℕ) :
    goldenTraceC n = goldenSpectralPair.traceC n := by
  rw [goldenTraceC_eq_lambda_plus_conj]
  rfl

/-- The Golden dynamical zeta equals the generic
`SpectralContractionPair.dynamicalZeta` at `goldenSpectralPair`. -/
theorem goldenDynamicalZeta_eq_spectralPair_dynamicalZeta (z : ℂ) :
    goldenDynamicalZeta z = goldenSpectralPair.dynamicalZeta z := by
  rw [goldenDynamicalZeta_spectral_form]
  rfl

/-- The Golden trace generating function via the generic split form. -/
theorem golden_trace_generating_function_via_generic
    (z : ℂ) (hz : ‖lambdaG1 * z‖ < 1) :
    HasSum (fun n : ℕ => goldenTraceC n * z ^ n)
      (1 / (1 - lambdaG1 * z) + 1 / (1 - star lambdaG1 * z)) := by
  have h := goldenSpectralPair.trace_generating_function_split z hz
  convert h using 1
  funext n
  rw [goldenTraceC_eq_spectralPair_traceC]

/-- The Golden log-zeta trace expansion via the generic theorem. -/
theorem golden_log_zeta_trace_expansion_via_generic
    (z : ℂ) (hz : ‖lambdaG1 * z‖ < 1) :
    HasSum (fun n : ℕ => goldenTraceC n * z ^ n / (n : ℂ))
      (-Complex.log (1 - lambdaG1 * z)
        - Complex.log (1 - star lambdaG1 * z)) := by
  have h := goldenSpectralPair.log_zeta_trace_expansion z hz
  convert h using 1
  funext n
  rw [goldenTraceC_eq_spectralPair_traceC]

-- =====================================================================
-- === Tier 11 — Generic Theta–Dirichlet–Mellin Pipeline ===============
-- =====================================================================
-- Lift the Tier 6–7 analytic pipeline to `SpectralContractionPair`.

/-- **The fundamental geometric bound**:
  `‖traceC(n)‖ ≤ 2 · ‖λ‖ⁿ`. -/
theorem SpectralContractionPair.traceC_norm_le
    (S : SpectralContractionPair) (n : ℕ) :
    ‖S.traceC n‖ ≤ 2 * ‖S.lam‖ ^ n := by
  unfold SpectralContractionPair.traceC
  calc ‖S.lam ^ n + (star S.lam) ^ n‖
      ≤ ‖S.lam ^ n‖ + ‖(star S.lam) ^ n‖ := norm_add_le _ _
    _ = ‖S.lam‖ ^ n + ‖S.lam‖ ^ n := by
        rw [norm_pow, norm_pow, S.norm_star_lam]
    _ = 2 * ‖S.lam‖ ^ n := by ring

/-- **Generic renormalized positive theta kernel**:
  `Θ_S⁺(t) = Σ_{n ≥ 1} traceC(n) · exp(-n · t)`. -/
noncomputable def SpectralContractionPair.thetaPositive
    (S : SpectralContractionPair) (t : ℝ) : ℂ :=
  ∑' n : ℕ, S.traceC (n + 1) * Complex.exp (-((n + 1 : ℝ) * t : ℂ))

/-- Summability of the generic positive theta kernel for `t ≥ 0`. -/
theorem SpectralContractionPair.thetaPositive_summable
    (S : SpectralContractionPair) (t : ℝ) (ht : 0 ≤ t) :
    Summable
      (fun n : ℕ => S.traceC (n + 1) * Complex.exp (-((n + 1 : ℝ) * t : ℂ))) := by
  have hgeom : Summable (fun n : ℕ => 2 * ‖S.lam‖ ^ (n + 1)) := by
    have hshift : Summable (fun n : ℕ => ‖S.lam‖ ^ (n + 1)) := by
      have h := (summable_nat_add_iff
        (f := fun n : ℕ => ‖S.lam‖ ^ n) 1).mpr
        (summable_geometric_of_lt_one (norm_nonneg _) S.hlam)
      simpa using h
    exact hshift.mul_left 2
  apply Summable.of_norm_bounded hgeom
  intro n
  rw [norm_mul]
  have h1 : ‖S.traceC (n + 1)‖ ≤ 2 * ‖S.lam‖ ^ (n + 1) :=
    S.traceC_norm_le (n + 1)
  have h2 : ‖Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖ ≤ 1 := by
    rw [Complex.norm_exp]
    apply Real.exp_le_one_iff.mpr
    simp only [Complex.neg_re, Complex.mul_re, Complex.ofReal_re,
      Complex.ofReal_im, Complex.mul_im, zero_mul, mul_zero, sub_zero,
      add_zero, neg_neg, neg_nonpos]
    have hnt_nonneg : 0 ≤ ((n + 1 : ℕ) : ℝ) * t := mul_nonneg (by positivity) ht
    push_cast at hnt_nonneg ⊢
    linarith
  calc ‖S.traceC (n + 1)‖ * ‖Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖
      ≤ (2 * ‖S.lam‖ ^ (n + 1)) * 1 := by
        apply mul_le_mul h1 h2 (norm_nonneg _) (by positivity)
    _ = 2 * ‖S.lam‖ ^ (n + 1) := by ring

/-- **Generic Dirichlet trace series**:
  `D_S(s) := Σ_{n ≥ 1} traceC(n) / nˢ`. -/
noncomputable def SpectralContractionPair.traceDirichlet
    (S : SpectralContractionPair) (s : ℂ) : ℂ :=
  ∑' n : ℕ, S.traceC (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s

/-- **The generic gem**: the Dirichlet trace series converges absolutely
for *every* complex `s`. Same structure as the Golden gem with
`‖S.lam‖ < 1` and `‖traceC(n)‖ ≤ 2 ‖S.lam‖ⁿ` driving the bound. -/
theorem SpectralContractionPair.traceDirichlet_summable
    (S : SpectralContractionPair) (s : ℂ) :
    Summable
      (fun n : ℕ => S.traceC (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s) := by
  set k : ℕ := ⌈max (0 : ℝ) (-s.re)⌉₊ with hk_def
  have hlam_norm : ‖(‖S.lam‖ : ℝ)‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg (norm_nonneg _)]
    exact S.hlam
  have hpow : Summable (fun n : ℕ => (n : ℝ) ^ k * ‖S.lam‖ ^ n) :=
    summable_pow_mul_geometric_of_norm_lt_one k hlam_norm
  have hshift :
      Summable (fun n : ℕ => ((n + 1 : ℕ) : ℝ) ^ k * ‖S.lam‖ ^ (n + 1)) :=
    (summable_nat_add_iff
      (f := fun n : ℕ => (n : ℝ) ^ k * ‖S.lam‖ ^ n) 1).mpr hpow
  have hbound :
      Summable (fun n : ℕ => 2 * (((n + 1 : ℕ) : ℝ) ^ k * ‖S.lam‖ ^ (n + 1))) :=
    hshift.mul_left 2
  apply Summable.of_norm_bounded hbound
  intro n
  have hpos : (0 : ℝ) < ((n + 1 : ℕ) : ℝ) := by exact_mod_cast Nat.succ_pos n
  have hone_le : (1 : ℝ) ≤ ((n + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_le_succ (Nat.zero_le _)
  have hcast : (((n + 1 : ℕ) : ℝ) : ℂ) = ((n + 1 : ℕ) : ℂ) := by push_cast; rfl
  have hden_norm : ‖((n + 1 : ℕ) : ℂ) ^ s‖ = ((n + 1 : ℕ) : ℝ) ^ s.re := by
    rw [← hcast]; exact norm_cpow_eq_rpow_re_of_pos hpos s
  have hnum : ‖S.traceC (n + 1)‖ ≤ 2 * ‖S.lam‖ ^ (n + 1) :=
    S.traceC_norm_le (n + 1)
  have hk_ge : -s.re ≤ (k : ℝ) := by
    have h1 : max (0 : ℝ) (-s.re) ≤ (k : ℝ) := by
      rw [hk_def]; exact_mod_cast Nat.le_ceil _
    linarith [le_max_right (0 : ℝ) (-s.re)]
  have hpow_ge_one :
      ((n + 1 : ℕ) : ℝ) ^ k * ((n + 1 : ℕ) : ℝ) ^ s.re ≥ 1 := by
    rw [show ((n + 1 : ℕ) : ℝ) ^ k = ((n + 1 : ℕ) : ℝ) ^ (k : ℝ) from
        (Real.rpow_natCast _ k).symm]
    rw [← Real.rpow_add hpos]
    exact Real.one_le_rpow hone_le (by linarith)
  rw [norm_div, hden_norm]
  have hden_pos : 0 < ((n + 1 : ℕ) : ℝ) ^ s.re := Real.rpow_pos_of_pos hpos _
  rw [div_le_iff₀ hden_pos]
  calc ‖S.traceC (n + 1)‖
      ≤ 2 * ‖S.lam‖ ^ (n + 1) := hnum
    _ = 2 * ‖S.lam‖ ^ (n + 1) * 1 := by ring
    _ ≤ 2 * ‖S.lam‖ ^ (n + 1)
            * (((n + 1 : ℕ) : ℝ) ^ k * ((n + 1 : ℕ) : ℝ) ^ s.re) :=
          mul_le_mul_of_nonneg_left hpow_ge_one (by positivity)
    _ = 2 * (((n + 1 : ℕ) : ℝ) ^ k * ‖S.lam‖ ^ (n + 1))
            * ((n + 1 : ℕ) : ℝ) ^ s.re := by ring

-- --- Tier 11.4 — Generic Mellin Bridge ------------------------------

/-- Generic per-term Mellin kernel: `∫ tˢ⁻¹ · exp(−(n+1)t) dt = Γ(s) / (n+1)ˢ`.
Lifts `golden_mellin_kernel_term`. Takes a `SpectralContractionPair`
argument purely for dot-notation accessibility on `S`. -/
theorem SpectralContractionPair.mellin_kernel_term
    (_S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) (n : ℕ) :
    ∫ t in Set.Ioi (0 : ℝ),
        ((t : ℂ) ^ (s - 1)) * Complex.exp (-((n + 1 : ℝ) * t))
      = Complex.Gamma s / ((n + 1 : ℕ) : ℂ) ^ s :=
  golden_mellin_kernel_term s hs n

/-- Generic weighted Mellin term: `∫ traceC(n+1) · tˢ⁻¹ · exp(-(n+1)t) dt
= traceC(n+1) · Γ(s) / (n+1)ˢ`. -/
theorem SpectralContractionPair.mellin_kernel_term_weighted
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) (n : ℕ) :
    ∫ t in Set.Ioi (0 : ℝ),
      S.traceC (n + 1) * ((t : ℂ) ^ (s - 1)) * Complex.exp (-((n + 1 : ℝ) * t))
      = S.traceC (n + 1) * (Complex.Gamma s / ((n + 1 : ℕ) : ℂ) ^ s) := by
  have hkernel := S.mellin_kernel_term s hs n
  rw [show (fun t : ℝ =>
        S.traceC (n + 1) * ((t : ℂ) ^ (s - 1))
          * Complex.exp (-((n + 1 : ℝ) * t)))
      = (fun t : ℝ =>
          S.traceC (n + 1) * (((t : ℂ) ^ (s - 1))
            * Complex.exp (-((n + 1 : ℝ) * t))))
      from by funext t; ring]
  rw [MeasureTheory.integral_const_mul, hkernel]

/-- Generic integrand continuity on `Ioi 0`. -/
theorem SpectralContractionPair.mellin_integrand_continuousOn
    (S : SpectralContractionPair) (s : ℂ) (n : ℕ) :
    ContinuousOn
      (fun t : ℝ =>
        S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      (Set.Ioi (0 : ℝ)) := by
  refine ContinuousOn.mul (ContinuousOn.mul continuousOn_const ?_) ?_
  · intro t ht
    refine ContinuousAt.continuousWithinAt ?_
    exact (continuousAt_cpow_const (ofReal_mem_slitPlane.mpr ht)).comp
      Complex.continuous_ofReal.continuousAt
  · refine Continuous.continuousOn ?_
    exact Complex.continuous_exp.comp
      (continuous_neg.comp (continuous_const.mul Complex.continuous_ofReal))

/-- Generic AE strong measurability. -/
theorem SpectralContractionPair.mellin_integrand_aestronglyMeasurable
    (S : SpectralContractionPair) (s : ℂ) (n : ℕ) :
    AEStronglyMeasurable
      (fun t : ℝ =>
        S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      (volume.restrict (Set.Ioi (0 : ℝ))) :=
  (S.mellin_integrand_continuousOn s n).aestronglyMeasurable measurableSet_Ioi

/-- Generic per-term Mellin integrability for `Re(s) > 0`. -/
theorem SpectralContractionPair.mellin_integrand_integrable
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) (n : ℕ) :
    IntegrableOn
      (fun t : ℝ =>
        S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      (Set.Ioi (0 : ℝ)) := by
  have hΓ_real : IntegrableOn
      (fun t : ℝ => Real.exp (-t) * t ^ (s.re - 1))
      (Set.Ioi (0 : ℝ)) :=
    Real.GammaIntegral_convergent hs
  have hbound : IntegrableOn
      (fun t : ℝ => ‖S.traceC (n + 1)‖ * (Real.exp (-t) * t ^ (s.re - 1)))
      (Set.Ioi (0 : ℝ)) :=
    hΓ_real.const_mul _
  refine Integrable.mono' hbound ?_ ?_
  · exact S.mellin_integrand_aestronglyMeasurable s n
  · apply (ae_restrict_iff' measurableSet_Ioi).mpr
    apply Filter.Eventually.of_forall
    intro t ht
    have hpos : (0 : ℝ) < t := ht
    rw [norm_mul, norm_mul]
    rw [show ‖((t : ℂ) ^ (s - 1))‖ = t ^ (s.re - 1) from by
      rw [Complex.norm_cpow_eq_rpow_re_of_pos hpos]
      simp [Complex.sub_re]]
    rw [Complex.norm_exp]
    rw [show (-((n + 1 : ℝ) * t : ℂ)).re = -((n + 1 : ℝ) * t) from by simp]
    have h_exp_le : Real.exp (-((n + 1 : ℝ) * t)) ≤ Real.exp (-t) := by
      apply Real.exp_le_exp.mpr
      have hnt : (n : ℝ) * t ≥ 0 := mul_nonneg (Nat.cast_nonneg _) hpos.le
      have hexpand : (n + 1 : ℝ) * t = n * t + t := by ring
      linarith
    calc ‖S.traceC (n + 1)‖ * t ^ (s.re - 1) * Real.exp (-((n + 1 : ℝ) * t))
        ≤ ‖S.traceC (n + 1)‖ * t ^ (s.re - 1) * Real.exp (-t) := by
          apply mul_le_mul_of_nonneg_left h_exp_le
          positivity
      _ = ‖S.traceC (n + 1)‖ * (Real.exp (-t) * t ^ (s.re - 1)) := by ring

/-- Generic L¹-norm bound per term. -/
theorem SpectralContractionPair.mellin_integrand_L1_le
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) (n : ℕ) :
    ∫ t in Set.Ioi (0 : ℝ),
        ‖S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖
      ≤ ‖S.traceC (n + 1)‖ * Real.Gamma s.re := by
  have hΓ_val : ∫ t in Set.Ioi (0 : ℝ), Real.exp (-t) * t ^ (s.re - 1)
      = Real.Gamma s.re := by
    rw [Real.Gamma_eq_integral hs]
  have hΓ_real_int : IntegrableOn
      (fun t : ℝ => Real.exp (-t) * t ^ (s.re - 1))
      (Set.Ioi (0 : ℝ)) :=
    Real.GammaIntegral_convergent hs
  calc ∫ t in Set.Ioi (0 : ℝ),
          ‖S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
            * Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖
      ≤ ∫ t in Set.Ioi (0 : ℝ),
          ‖S.traceC (n + 1)‖ * (Real.exp (-t) * t ^ (s.re - 1)) := by
        apply MeasureTheory.setIntegral_mono_on
        · exact (S.mellin_integrand_integrable s hs n).norm
        · exact hΓ_real_int.const_mul _
        · exact measurableSet_Ioi
        · intro t ht
          have hpos : (0 : ℝ) < t := ht
          rw [norm_mul, norm_mul]
          rw [show ‖((t : ℂ) ^ (s - 1))‖ = t ^ (s.re - 1) from by
            rw [Complex.norm_cpow_eq_rpow_re_of_pos hpos]
            simp [Complex.sub_re]]
          rw [Complex.norm_exp]
          rw [show (-((n + 1 : ℝ) * t : ℂ)).re = -((n + 1 : ℝ) * t) from by simp]
          have h_exp_le : Real.exp (-((n + 1 : ℝ) * t)) ≤ Real.exp (-t) := by
            apply Real.exp_le_exp.mpr
            have hnt : (n : ℝ) * t ≥ 0 := mul_nonneg (Nat.cast_nonneg _) hpos.le
            have hexpand : (n + 1 : ℝ) * t = n * t + t := by ring
            linarith
          calc ‖S.traceC (n + 1)‖ * t ^ (s.re - 1) * Real.exp (-((n + 1 : ℝ) * t))
              ≤ ‖S.traceC (n + 1)‖ * t ^ (s.re - 1) * Real.exp (-t) := by
                apply mul_le_mul_of_nonneg_left h_exp_le
                positivity
            _ = ‖S.traceC (n + 1)‖ * (Real.exp (-t) * t ^ (s.re - 1)) := by ring
    _ = ‖S.traceC (n + 1)‖ * ∫ t in Set.Ioi (0 : ℝ),
            (Real.exp (-t) * t ^ (s.re - 1)) := by
        rw [MeasureTheory.integral_const_mul]
    _ = ‖S.traceC (n + 1)‖ * Real.Gamma s.re := by rw [hΓ_val]

/-- Generic L¹-norm summability. -/
theorem SpectralContractionPair.mellin_integrand_L1_summable
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) :
    Summable (fun n : ℕ =>
      ∫ t in Set.Ioi (0 : ℝ),
        ‖S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖) := by
  have hgeom : Summable (fun n : ℕ => 2 * ‖S.lam‖ ^ (n + 1) * Real.Gamma s.re) := by
    have hshift : Summable (fun n : ℕ => ‖S.lam‖ ^ (n + 1)) := by
      have h := (summable_nat_add_iff
        (f := fun n : ℕ => ‖S.lam‖ ^ n) 1).mpr
        (summable_geometric_of_lt_one (norm_nonneg _) S.hlam)
      simpa using h
    have := (hshift.mul_left 2).mul_right (Real.Gamma s.re)
    simpa [mul_comm, mul_assoc, mul_left_comm] using this
  refine Summable.of_nonneg_of_le ?_ ?_ hgeom
  · intro n; positivity
  · intro n
    have hbound := S.mellin_integrand_L1_le s hs n
    have hTr : ‖S.traceC (n + 1)‖ ≤ 2 * ‖S.lam‖ ^ (n + 1) := S.traceC_norm_le (n + 1)
    have hΓ_nonneg : 0 ≤ Real.Gamma s.re := (Real.Gamma_pos_of_pos hs).le
    calc (∫ t in Set.Ioi (0 : ℝ),
            ‖S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
              * Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖)
        ≤ ‖S.traceC (n + 1)‖ * Real.Gamma s.re := hbound
      _ ≤ 2 * ‖S.lam‖ ^ (n + 1) * Real.Gamma s.re :=
          mul_le_mul_of_nonneg_right hTr hΓ_nonneg

/-- Generic ENNReal adapter. -/
theorem SpectralContractionPair.mellin_integrand_lintegral_norm_ne_top
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) :
    (∑' n : ℕ, ∫⁻ t in Set.Ioi (0 : ℝ),
      enorm (S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
        * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))) ≠ ⊤ := by
  have hperterm : ∀ n : ℕ,
      ∫⁻ t in Set.Ioi (0 : ℝ),
        enorm (S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      = ENNReal.ofReal
          (∫ t in Set.Ioi (0 : ℝ),
            ‖S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
              * Complex.exp (-((n + 1 : ℝ) * t : ℂ))‖) := by
    intro n
    rw [← MeasureTheory.ofReal_integral_norm_eq_lintegral_enorm
      (S.mellin_integrand_integrable s hs n)]
  simp_rw [hperterm]
  rw [← ENNReal.ofReal_tsum_of_nonneg ?_ (S.mellin_integrand_L1_summable s hs)]
  · exact ENNReal.ofReal_ne_top
  · intro n; positivity

/-- Generic Mellin integrand pointwise sum: `Θ_S⁺(t) · tˢ⁻¹ = Σ ...`. -/
theorem SpectralContractionPair.thetaPositive_mellin_integrand_hasSum
    (S : SpectralContractionPair) (s : ℂ) (t : ℝ) (ht : 0 ≤ t) :
    HasSum
      (fun n : ℕ =>
        S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
          * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      (S.thetaPositive t * (t : ℂ) ^ (s - 1)) := by
  have hsum := (S.thetaPositive_summable t ht).hasSum
  have hmul := hsum.mul_right ((t : ℂ) ^ (s - 1))
  refine hmul.congr_fun ?_
  intro n
  ring

/-- Generic integral/sum interchange. -/
theorem SpectralContractionPair.thetaPositive_mellin_integral_tsum
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) :
    ∫ t in Set.Ioi (0 : ℝ),
        (∑' n : ℕ,
          S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
            * Complex.exp (-((n + 1 : ℝ) * t : ℂ)))
      = ∑' n : ℕ, ∫ t in Set.Ioi (0 : ℝ),
          S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
            * Complex.exp (-((n + 1 : ℝ) * t : ℂ)) := by
  apply MeasureTheory.integral_tsum
  · intro n
    exact S.mellin_integrand_aestronglyMeasurable s n
  · exact S.mellin_integrand_lintegral_norm_ne_top s hs

/-- **Tier 11.4 — The Generic Mellin Bridge.**
For any `SpectralContractionPair S` and `Re(s) > 0`:
  `∫₀^∞ Θ_S⁺(t) · tˢ⁻¹ dt  =  Γ(s) · D_S(s)`.
The Tier-7 Mellin-bridge flagship lifted to the generic abstraction. -/
theorem SpectralContractionPair.thetaPositive_mellin_bridge
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) :
    ∫ t in Set.Ioi (0 : ℝ),
        S.thetaPositive t * (t : ℂ) ^ (s - 1)
      = Complex.Gamma s * S.traceDirichlet s := by
  -- Replace the integrand with the termwise sum, then swap.
  have h_integrand : ∀ t ∈ Set.Ioi (0 : ℝ),
      S.thetaPositive t * (t : ℂ) ^ (s - 1)
        = ∑' n : ℕ,
            S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
              * Complex.exp (-((n + 1 : ℝ) * t : ℂ)) := by
    intro t ht
    exact (S.thetaPositive_mellin_integrand_hasSum s t (le_of_lt ht)).tsum_eq.symm
  rw [MeasureTheory.setIntegral_congr_fun measurableSet_Ioi h_integrand]
  rw [S.thetaPositive_mellin_integral_tsum s hs]
  have h_term : ∀ n : ℕ,
      ∫ t in Set.Ioi (0 : ℝ),
          S.traceC (n + 1) * (t : ℂ) ^ (s - 1)
            * Complex.exp (-((n + 1 : ℝ) * t : ℂ))
        = S.traceC (n + 1) * (Complex.Gamma s / ((n + 1 : ℕ) : ℂ) ^ s) :=
    fun n => S.mellin_kernel_term_weighted s hs n
  simp_rw [h_term]
  rw [show (fun n : ℕ =>
        S.traceC (n + 1) * (Complex.Gamma s / ((n + 1 : ℕ) : ℂ) ^ s))
      = (fun n : ℕ =>
        Complex.Gamma s * (S.traceC (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s))
      from by funext n; ring]
  rw [tsum_mul_left]
  rfl

-- =====================================================================
-- === Tier 12 — Spectral Theory Engine (self-adjoint ⇒ real spectrum)
-- =====================================================================
-- Import the central Hilbert–Pólya engine in its purest form:
-- a self-adjoint operator on a complex Hilbert space has real spectrum.
-- This is the operator-theoretic content behind the bounded HP bridge —
-- every spectrum element coerced from `BoundedHPBridge.A` is forced to
-- have imaginary part zero by `IsSelfAdjoint.im_eq_zero_of_mem_spectrum`
-- (available because `H →L[ℂ] H` is a C⋆-algebra).

/-- **Self-adjoint spectrum is real**: for every bounded HP bridge `B`,
every complex element of `spectrum ℂ B.A` has imaginary part zero.

This is the operator-theoretic engine of the Hilbert–Pólya program: a
self-adjoint operator has spectrum on the real axis. Combined with
`BoundedHPBridge.poleToCompactSpectrum`, every zeta-zero pole transfers to a
real spectral parameter *by theorem*, not by assumption — precisely the
property that closed the free-`Eigen` loophole in earlier work. -/
theorem BoundedHPBridge.spectrum_im_eq_zero (B : BoundedHPBridge) :
    ∀ z : ℂ, z ∈ spectrum ℂ B.A → z.im = 0 :=
  fun _ hz => B.selfAdjoint.im_eq_zero_of_mem_spectrum hz

/-- Equivalent set-theoretic form: `spectrum ℂ B.A ⊆ {z | z.im = 0}`. -/
theorem BoundedHPBridge.spectrum_subset_real (B : BoundedHPBridge) :
    spectrum ℂ B.A ⊆ {z : ℂ | z.im = 0} :=
  fun z hz => B.spectrum_im_eq_zero z hz

/-- For any spectrum element of `B.A`, its real and complex coercions
agree: `z = (z.re : ℂ)`. The form Mathlib uses to state spectrum
reality for self-adjoint operators. -/
theorem BoundedHPBridge.spectrum_eq_re (B : BoundedHPBridge) :
    ∀ z : ℂ, z ∈ spectrum ℂ B.A → z = (z.re : ℂ) :=
  fun _ hz => B.selfAdjoint.mem_spectrum_eq_re hz

/-- **Pole-to-real-spectral-parameter (theorem, not assumption).**
For any pole of `xiLikeReciprocalResponse` in the critical strip, there
exists a *real* spectral parameter `t` of `B.A` with `ρ = criticalShift t`.

The previous `BoundedHPBridge.poleToCompactSpectrum` already gives a `t : ℝ`,
but the *reality* of the spectral parameter was taken as a structural
choice. After Tier 12, the reality is genuinely *forced* by
`B.spectrum_im_eq_zero`: any complex spectral parameter would have to
sit on the real axis anyway, so the `t : ℝ` is not a smuggled hypothesis. -/
theorem BoundedHPBridge.pole_implies_real_spectral_parameter
    (B : BoundedHPBridge) (ρ : ℂ) (hstrip : CriticalStrip ρ)
    (hpole : IsPole xiLikeReciprocalResponse ρ) :
    ∃ t : ℝ, (cayleyOrdinate t : ℂ) ∈ spectrum ℂ B.A ∧
      ((cayleyOrdinate t : ℂ).im = 0) ∧ ρ = criticalShift t := by
  obtain ⟨t, htmem, hrho⟩ := B.poleToCompactSpectrum ρ hstrip hpole
  refine ⟨t, htmem, ?_, hrho⟩
  simp

