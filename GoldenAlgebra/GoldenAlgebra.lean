-- =====================================================================
-- === Tier 43 — Abstract Innovation Geometry =========================
-- =====================================================================
-- Package the AR(1) skeleton (Tiers 37–39) into a reusable structure:
-- a memory coefficient `r`, unit-energy states, and innovations of
-- constant energy `1 − r²`. The conservation law `r² + (1−r²) = 1` is
-- the canonical information split.

/-- **Abstract innovation geometry.**
The portable AR(1) skeleton: a memory coefficient `r ∈ [0,1)`,
unit-energy states, and innovations of constant energy `1 − r²`. -/
structure InnovationGeometry where
  /-- Memory / persistence coefficient. -/
  r : ℝ
  /-- Memory is non-negative. -/
  r_nonneg : 0 ≤ r
  /-- Memory is a strict contraction. -/
  r_lt_one : r < 1
  /-- Self-energy of each state. -/
  stateEnergy : ℕ → ℝ
  /-- Self-energy of each innovation. -/
  innovationEnergy : ℕ → ℝ
  /-- Every state is a unit vector. -/
  state_unit : ∀ n, stateEnergy n = 1
  /-- Every innovation carries the constant energy `1 − r²`. -/
  innovation_law : ∀ n, innovationEnergy n = 1 - r ^ 2

-- =====================================================================
-- === Tier 44 — Conservation of Information ==========================
-- =====================================================================

/-- **Conservation of information** (abstract):
  `r² · ‖state‖² + ‖innovation‖² = 1`.
Memory energy plus innovation energy equals the unit state energy. -/
theorem InnovationGeometry.conservation_of_information
    (G : InnovationGeometry) (n : ℕ) :
    G.r ^ 2 * G.stateEnergy n + G.innovationEnergy n = 1 := by
  rw [G.state_unit, G.innovation_law]
  ring

/-- **State-energy recurrence** (abstract):
  `‖state(n+1)‖² = r²·‖state n‖² + ‖innovation n‖²`.
The next state's energy splits into a remembered part and a fresh
orthogonal innovation. -/
theorem InnovationGeometry.state_energy_recurrence
    (G : InnovationGeometry) (n : ℕ) :
    G.stateEnergy (n + 1)
      = G.r ^ 2 * G.stateEnergy n + G.innovationEnergy n := by
  rw [G.state_unit, G.state_unit, G.innovation_law]
  ring

/-- Each innovation energy is non-negative. -/
theorem InnovationGeometry.innovationEnergy_nonneg
    (G : InnovationGeometry) (n : ℕ) :
    0 ≤ G.innovationEnergy n := by
  rw [G.innovation_law]
  nlinarith [G.r_nonneg, G.r_lt_one, sq_nonneg G.r]

/-- The innovation geometry attached to a spectral contraction pair:
memory `‖λ‖`, unit states, innovation energy `1 − ‖λ‖²`. -/
noncomputable def SpectralContractionPair.innovationGeometry
    (S : SpectralContractionPair) : InnovationGeometry where
  r := ‖S.lam‖
  r_nonneg := norm_nonneg _
  r_lt_one := S.hlam
  stateEnergy := fun _ => 1
  innovationEnergy := fun _ => 1 - ‖S.lam‖ ^ 2
  state_unit := fun _ => rfl
  innovation_law := fun _ => rfl

/-- Each Toeplitz kernel section is a unit vector in the RKHS. -/
theorem SpectralContractionPair.section_normSq_one
    (S : SpectralContractionPair) (N : ℕ) (i : Fin N) :
    (S.toeplitzFinitePositiveKernel N).normSq
        ((S.toeplitzFinitePositiveKernel N).sectionClass i) = 1 := by
  rw [(S.toeplitzFinitePositiveKernel N).normSq_section]
  exact toeplitzKernel_diag_one ‖S.lam‖ _

/-- **Conservation of information (concrete, Toeplitz RKHS).**
  `‖λ‖² + ‖ε_i‖² = 1`.
The memory share `‖λ‖²` plus the innovation share `1 − ‖λ‖²` of every
new RKHS direction sum to one. The canonical information split. -/
theorem SpectralContractionPair.conservation_of_information
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    ‖S.lam‖ ^ 2
        + (S.toeplitzFinitePositiveKernel (n + 1)).normSq
            (S.innovationClass i)
      = 1 := by
  rw [S.innovation_normSq i]
  ring

/-- **State-energy decomposition (concrete, Toeplitz RKHS).**
  `‖K_{i+1}‖² = ‖λ‖²·‖K_i‖² + ‖ε_i‖²`. -/
theorem SpectralContractionPair.state_energy_decomposition
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    (S.toeplitzFinitePositiveKernel (n + 1)).normSq
        ((S.toeplitzFinitePositiveKernel (n + 1)).sectionClass i.succ)
      = ‖S.lam‖ ^ 2
          * (S.toeplitzFinitePositiveKernel (n + 1)).normSq
              ((S.toeplitzFinitePositiveKernel (n + 1)).sectionClass i.castSucc)
        + (S.toeplitzFinitePositiveKernel (n + 1)).normSq
            (S.innovationClass i) := by
  rw [S.section_normSq_one (n + 1) i.succ,
      S.section_normSq_one (n + 1) i.castSucc,
      S.innovation_normSq i]
  ring

-- =====================================================================
-- === Tier 45 — Innovation Volume / Determinant ======================
-- =====================================================================
-- The squared volume of the n-point innovation cloud, recursively,
-- avoiding `Matrix.det` machinery. Closed form `(1 − r²)ⁿ`.

/-- Recursive squared volume of the `n`-point innovation cloud:
each new orthogonal innovation multiplies the volume by `1 − r²`. -/
noncomputable def innovationVolumeSq (r : ℝ) : ℕ → ℝ
  | 0 => 1
  | n + 1 => innovationVolumeSq r n * (1 - r ^ 2)

/-- **Closed form for the innovation volume**: `Vol²ₙ = (1 − r²)ⁿ`. -/
theorem innovationVolumeSq_closed_form (r : ℝ) (n : ℕ) :
    innovationVolumeSq r n = (1 - r ^ 2) ^ n := by
  induction n with
  | zero => rfl
  | succ n ih =>
    rw [innovationVolumeSq, ih]
    exact (pow_succ _ _).symm

/-- The innovation volume is non-negative for `0 ≤ r ≤ 1`. -/
theorem innovationVolumeSq_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) (n : ℕ) :
    0 ≤ innovationVolumeSq r n := by
  rw [innovationVolumeSq_closed_form]
  have : 0 ≤ 1 - r ^ 2 := by nlinarith [hr0, hr1, sq_nonneg r]
  positivity

/-- **Log-volume is linear in `n`** with slope `log(1 − r²)`:
  `log Vol²ₙ = n · log(1 − r²) = − n · (innovation entropy rate)`.
Contraction strength becomes literal geometric volume decay. -/
theorem innovationVolumeSq_log (r : ℝ) (n : ℕ) :
    Real.log (innovationVolumeSq r n)
      = - ((n : ℝ) * toeplitzInnovationEntropyRate r) := by
  rw [innovationVolumeSq_closed_form, Real.log_pow]
  unfold toeplitzInnovationEntropyRate
  ring

