-- === Tier 66 — The Spectral Fitting Ladder ==========================
-- =====================================================================
-- Approach rung 5 indirectly: progressively stronger approximate
-- spectral fits, from finite error data up to an exact match.

/-- An **approximate spectral fit**: model values against target
values, with the pointwise error. -/
structure ApproxSpectralFit where
  /-- The target spectral data. -/
  target : ℕ → ℝ
  /-- The model spectral data. -/
  model : ℕ → ℝ
  /-- The pointwise error. -/
  error : ℕ → ℝ
  /-- The error is the absolute model–target gap. -/
  error_eq : ∀ n, error n = |model n - target n|

/-- A **uniform spectral fit**: an approximate fit with a global error
bound. -/
structure UniformSpectralFit extends ApproxSpectralFit where
  /-- The uniform error bound. -/
  bound : ℝ
  /-- Every error is within the bound. -/
  error_le : ∀ n, error n ≤ bound

/-- A uniform spectral fit has a non-negative bound. -/
theorem UniformSpectralFit.bound_nonneg (F : UniformSpectralFit) :
    0 ≤ F.bound := by
  have h0 := F.error_le 0
  have he := F.error_eq 0
  rw [he] at h0
  exact le_trans (abs_nonneg _) h0

