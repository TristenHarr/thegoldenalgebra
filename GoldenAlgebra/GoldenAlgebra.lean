-- === Phase CXI: Full Residue Oscillator Tower — E_1, E_2, …  ===
-- The "third oscillator" is NOT another arithmetic O_3. It is the
-- NEXT RESIDUE LAYER:
--   E_1(t) = (-1)^{N-1} · (t/(2π))^{-3/4} · C_1(p).
-- General form:
--   E_r(t) = (-1)^{N-1} · (t/(2π))^{-1/4 − r/2} · C_r(p).
-- Two oscillator families:
--   (1) Arithmetic log oscillators O_m: A(t) = ∑ 2cos(θ − t·log m)/√m.
--   (2) Cutoff residue oscillators E_r: residue layers at the cutoff.
-- EXACT decomposition:  Z(t) = ∑_m O_m(t) + ∑_r E_r(t).
-- Zero condition: ∑ O_m + ∑ E_r = 0.

/-- The general residue-layer exponent `−1/4 − r/2` for E_r. -/
def residueLayerExponent (r : ℕ) : ℚ := -1/4 - (r : ℚ)/2

/-- **PROVED — exponent at r = 0 is `−1/4`.** -/
theorem residue_exponent_r0 :
    residueLayerExponent 0 = -1/4 := by
  unfold residueLayerExponent; norm_num

/-- **PROVED — exponent at r = 1 is `−3/4`.** -/
theorem residue_exponent_r1 :
    residueLayerExponent 1 = -3/4 := by
  unfold residueLayerExponent; norm_num

/-- **PROVED — exponent at r = 2 is `−5/4`.** -/
theorem residue_exponent_r2 :
    residueLayerExponent 2 = -5/4 := by
  unfold residueLayerExponent; norm_num

/-- **PROVED — exponent at r = 3 is `−7/4`.** -/
theorem residue_exponent_r3 :
    residueLayerExponent 3 = -7/4 := by
  unfold residueLayerExponent; norm_num

/-- **PROVED — exponents decrease (become MORE negative) with r.** -/
theorem residue_exponent_decreases :
    residueLayerExponent 0 > residueLayerExponent 1
    ∧ residueLayerExponent 1 > residueLayerExponent 2
    ∧ residueLayerExponent 2 > residueLayerExponent 3 := by
  refine ⟨?_, ?_, ?_⟩
  all_goals (rw [residueLayerExponent, residueLayerExponent]; norm_num)

/-- The next residue layer `E_1(t) = (-1)^{N-1} · (t/(2π))^{-3/4} · C_1(p)`. -/
noncomputable def RS_E1 (t : ℝ) (N : ℕ) (C1_p : ℝ) : ℝ :=
  ((-1)^(N - 1) : ℝ) * (t / (2 * Real.pi))^(-(3/4) : ℝ) * C1_p

/-- The general residue layer `E_r(t)`. -/
noncomputable def RS_E_r (t : ℝ) (N r : ℕ) (C_r_p : ℝ) : ℝ :=
  ((-1)^(N - 1) : ℝ) * (t / (2 * Real.pi))^((residueLayerExponent r : ℝ)) * C_r_p

