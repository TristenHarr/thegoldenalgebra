      lhs; arg 1; arg 2; arg 2
      rw [zero_add]
    rw [←pow_two, ←pow_two]
    rw [T_sq_add_J_sq]
    rw [Real.sqrt_div]
    case hx =>
      rw [le_sub_iff_add_le, zero_add]
