/-! # Tier 87 — Guth–Maynard Large-Value Spectral Dictionary

A *formal interface* between Guth–Maynard-style large-value control of
Dirichlet polynomials and the Golden Hankel/Jacobi/Weyl spectral
machinery of Tiers 6, 17, and 25.  The honest claim is **not** "Golden
algebra proves RH"; it is

> Golden/Hankel/Jacobi spectral machinery becomes a formal test bench
> for Guth–Maynard-style large-value estimates.

Guth–Maynard ("New large value estimates for Dirichlet polynomials",
*Annals of Math.* **203** (2026)) study when a Dirichlet polynomial

  `D(t) = Σ_{n ≤ N} aₙ · n^{it}`

is unusually large, improve the large-value estimates, and derive the
zero-density bound `N(σ,T) ≤ T^{(30/13)(1-σ)+o(1)}` and primes in
short intervals of length `x^{17/30+o(1)}`.

This tier lands the genuine, unconditional core of the bridge and names
the open analytic input honestly:

* **Genuine (Tier ★).**  The Dirichlet monomial `n^{it}`, its
  phase–energy identity `n^{it} = exp(i·t·log n)` — the exact point
  where a Dirichlet polynomial becomes a finite-time Fourier transform
  of the prime-Fock log-Hamiltonian spectrum (`log n = E(n)`) — its
  unit norm, the Dirichlet polynomial model with a *real* `eval`, the
  trivial `ℓ¹` large-value bound `‖D(t)‖ ≤ Σ‖aₙ‖`, the resulting
  emptiness of high large-value sets, the Golden Dirichlet polynomial
  built from `goldenTraceC`, its geometric large-value bound, and the
  Guth–Maynard / benchmark zero-density constants with the proved
  strict improvement `30/13 < 12/5`.

* **Scaffold (Tier ⊕).**  `LargeValueEstimate`, `ZeroDensityConsequence`,
  `GuthMaynardBridge`, the Golden shadow/hybrid objects, and the Weyl
  large-value dictionary.  Their bridge obligations are explicit `Prop`
  fields: the Guth–Maynard estimate itself is the open analytic input,
  not something proved here.

The capstone `golden_large_value_control_implies_zero_density` is an
*honest projection*: trivial as a proof, valuable because its
hypotheses force a precise specification of the four missing bridges. -/

-- --- Tier 87.1 — The Dirichlet monomial and the phase–energy identity ---

/-- The **Dirichlet monomial** `n^{it}`, as a genuine complex power.
This is the elementary building block of a Dirichlet polynomial. -/
noncomputable def dirichletMonomial (n : ℕ) (t : ℝ) : ℂ :=
  (n : ℂ) ^ (Complex.I * (t : ℂ))

/-- **Phase–energy identity** (Tier ★).  For `n ≥ 1`,

  `n^{it} = exp(i · t · log n)`.

This is the exact bridge to the prime-Fock log-Hamiltonian layer: with
the log-scale energy `E(n) = log n`, the Dirichlet monomial is the
phase evolution `exp(i·t·E(n))` of the `n`-mode.  A Dirichlet
polynomial is therefore a finite-time Fourier transform of the
log-Hamiltonian spectrum. -/
theorem dirichletMonomial_eq_exp {n : ℕ} (hn : 1 ≤ n) (t : ℝ) :
    dirichletMonomial n t
      = Complex.exp (Complex.I * (t : ℂ) * (Real.log n : ℂ)) := by
  have hn0 : ((n : ℕ) : ℂ) ≠ 0 := by
    have hne : n ≠ 0 := by omega
    exact_mod_cast hne
  have hnpos : (0 : ℝ) ≤ (n : ℝ) := by positivity
  have hcast : ((n : ℕ) : ℂ) = (((n : ℕ) : ℝ) : ℂ) := by push_cast; ring
  unfold dirichletMonomial
  rw [Complex.cpow_def_of_ne_zero hn0]
  congr 1
  rw [hcast, ← Complex.ofReal_log hnpos]
  ring

/-- **The Dirichlet monomial has unit norm** (Tier ★).  For `n ≥ 1` and
real `t`, `‖n^{it}‖ = 1`: a Dirichlet polynomial is large only through
*phase alignment* of its terms, never through term magnitude. -/
theorem dirichletMonomial_norm {n : ℕ} (hn : 1 ≤ n) (t : ℝ) :
    ‖dirichletMonomial n t‖ = 1 := by
  have hpos : (0 : ℝ) < (n : ℝ) := by
    have hp : 0 < n := by omega
    exact_mod_cast hp
  have hcast : ((n : ℕ) : ℂ) = (((n : ℕ) : ℝ) : ℂ) := by push_cast; ring
  unfold dirichletMonomial
  rw [hcast, Complex.norm_cpow_eq_rpow_re_of_pos hpos]
  have hre : (Complex.I * (t : ℂ)).re = 0 := by simp [Complex.mul_re]
  rw [hre, Real.rpow_zero]

-- --- Tier 87.2 — The Dirichlet polynomial model -----------------------

/-- A **Dirichlet polynomial model**: a finite Dirichlet polynomial
`D(t) = Σ_{n=1}^{length} coeff(n-1) · n^{it}`, with `coeff` indexed
from `0`.  Unlike the placeholder sketch, `eval` below is a *genuine*
function, not a `Prop` field. -/
structure DirichletPolynomialModel where
  /-- The coefficient sequence `aₙ` (the `n`-th coefficient is
  `coeff n`, attached to the monomial `(n+1)^{it}`). -/
  coeff : ℕ → ℂ
  /-- The number of terms. -/
  length : ℕ

/-- The genuine evaluation `D(t) = Σ_{n<length} coeff n · (n+1)^{it}`. -/
noncomputable def DirichletPolynomialModel.eval
    (D : DirichletPolynomialModel) (t : ℝ) : ℂ :=
  ∑ n ∈ Finset.range D.length, D.coeff n * dirichletMonomial (n + 1) t

/-- The `ℓ¹` norm of the coefficient sequence, `Σ‖aₙ‖`. -/
noncomputable def DirichletPolynomialModel.coeffL1
    (D : DirichletPolynomialModel) : ℝ :=
  ∑ n ∈ Finset.range D.length, ‖D.coeff n‖

/-- **Trivial large-value bound** (Tier ★).  Because every monomial has
unit norm (`dirichletMonomial_norm`), the triangle inequality gives the
baseline estimate `‖D(t)‖ ≤ Σ‖aₙ‖` that Guth–Maynard set out to
improve. -/
theorem DirichletPolynomialModel.norm_eval_le
    (D : DirichletPolynomialModel) (t : ℝ) :
    ‖D.eval t‖ ≤ D.coeffL1 := by
  unfold DirichletPolynomialModel.eval DirichletPolynomialModel.coeffL1
  refine le_trans (norm_sum_le _ _) (Finset.sum_le_sum ?_)
  intro n _
  have he : ‖D.coeff n * dirichletMonomial (n + 1) t‖ = ‖D.coeff n‖ := by
    rw [norm_mul, dirichletMonomial_norm (by omega) t, mul_one]
  exact le_of_eq he

/-- The **large-value set** at threshold `V`: the genuine super-level
set `{t : V ≤ ‖D(t)‖}`.  Guth–Maynard estimates bound the measure of
this set; here it is the actual set, not a `Prop` placeholder. -/
def DirichletPolynomialModel.largeValueSet
    (D : DirichletPolynomialModel) (V : ℝ) : Set ℝ :=
  {t : ℝ | V ≤ ‖D.eval t‖}

/-- **Trivial large-value estimate** (Tier ★).  Above the `ℓ¹` ceiling
the large-value set is empty: a Dirichlet polynomial can never exceed
`Σ‖aₙ‖`.  This is the unconditional baseline; the Guth–Maynard estimate
is the strictly sharper, open analytic statement. -/
theorem DirichletPolynomialModel.largeValueSet_eq_empty_of_coeffL1_lt
    (D : DirichletPolynomialModel) {V : ℝ} (hV : D.coeffL1 < V) :
    D.largeValueSet V = ∅ := by
  rw [Set.eq_empty_iff_forall_notMem]
  intro t ht
  simp only [DirichletPolynomialModel.largeValueSet, Set.mem_setOf_eq] at ht
  have h1 : ‖D.eval t‖ ≤ D.coeffL1 := D.norm_eval_le t
  linarith

-- --- Tier 87.3 — The Golden Dirichlet-polynomial shadow ---------------

/-- The **Golden Dirichlet polynomial** of length `N`: the Dirichlet
polynomial whose coefficients are the Golden trace data,
`D_G(t) = Σ_{n=1}^{N} Tr(Gⁿ) · n^{it}`.  This is the Dirichlet-polynomial
face of the Golden trace series `goldenTraceDirichlet` of Tier 6. -/
noncomputable def goldenDirichletPoly (N : ℕ) : DirichletPolynomialModel where
  coeff := fun n => goldenTraceC (n + 1)
  length := N

/-- **The Golden Dirichlet polynomial is geometrically large-value
controlled** (Tier ★).  Because the Golden trace is contraction-damped
(`‖Tr Gⁿ‖ ≤ 2‖λ‖ⁿ`, `‖λ‖ < 1`), its Dirichlet polynomial obeys a
geometric large-value bound *unconditionally* — the Golden side never
needs the hard Guth–Maynard estimate. -/
theorem norm_eval_goldenDirichletPoly_le (N : ℕ) (t : ℝ) :
    ‖(goldenDirichletPoly N).eval t‖
      ≤ ∑ n ∈ Finset.range N, 2 * ‖lambdaG1‖ ^ (n + 1) := by
  have hle : ‖(goldenDirichletPoly N).eval t‖
      ≤ ∑ n ∈ Finset.range N, ‖goldenTraceC (n + 1)‖ :=
    (goldenDirichletPoly N).norm_eval_le t
  refine le_trans hle (Finset.sum_le_sum ?_)
  intro n _
  rw [goldenTraceC_eq_lambda_plus_conj]
  calc ‖lambdaG1 ^ (n + 1) + (star lambdaG1) ^ (n + 1)‖
      ≤ ‖lambdaG1 ^ (n + 1)‖ + ‖(star lambdaG1) ^ (n + 1)‖ := norm_add_le _ _
    _ = ‖lambdaG1‖ ^ (n + 1) + ‖lambdaG1‖ ^ (n + 1) := by
        rw [norm_pow, norm_pow, norm_star]
    _ = 2 * ‖lambdaG1‖ ^ (n + 1) := by ring

/-- A **Golden Dirichlet-polynomial shadow**: a Dirichlet polynomial
that genuinely arises from the Golden trace data, together with the
compatibility links into the squared-trace moment and Hankel layers of
Tier 17.  The provenance field `comesFromGoldenTrace` is a genuine
equality; the two moment-compatibility links are the open bridges. -/
structure GoldenDirichletPolynomialShadow where
  /-- The underlying Dirichlet polynomial. -/
  D : DirichletPolynomialModel
  /-- Provenance: `D` is the Golden Dirichlet polynomial of its length. -/
  comesFromGoldenTrace : D = goldenDirichletPoly D.length
  /-- Bridge: the coefficients feed the squared-trace moments
  `m_k(q) = Σ n^k (Tr Gⁿ)² qⁿ` of Tier 17. -/
  squaredTraceMomentCompatible : Prop
  /-- Bridge: the moment sequence assembles into the Golden Hankel
  matrix `H_N(q)` of Tier 17. -/
  hankelMomentCompatible : Prop

-- --- Tier 87.4 — Guth–Maynard exponents and the bridge ----------------

/-- The **Guth–Maynard zero-density constant** `30/13 ≈ 2.3077`: the new
large-value estimates yield `N(σ,T) ≤ T^{(30/13)(1-σ)+o(1)}`. -/
noncomputable def gmDensityConstant : ℝ := 30 / 13

/-- The **benchmark zero-density constant** `12/5 = 2.4`, the previous
best constant exponent in this range. -/
noncomputable def benchmarkDensityConstant : ℝ := 12 / 5

/-- **Guth–Maynard strictly improves the zero-density constant**
(Tier ★): `30/13 < 12/5`. -/
theorem gmDensityConstant_lt_benchmark :
    gmDensityConstant < benchmarkDensityConstant := by
  unfold gmDensityConstant benchmarkDensityConstant
  norm_num

/-- The **Guth–Maynard zero-density exponent** `(30/13)(1-σ)`. -/
noncomputable def gmZeroDensityExponent (σ : ℝ) : ℝ :=
  gmDensityConstant * (1 - σ)

/-- On the edge `σ = 1` the zero-density exponent vanishes (Tier ★). -/
theorem gmZeroDensityExponent_at_one : gmZeroDensityExponent 1 = 0 := by
  unfold gmZeroDensityExponent gmDensityConstant
  norm_num

/-- The Guth–Maynard zero-density exponent is strictly below the
benchmark exponent for every `σ < 1` (Tier ★). -/
theorem gmZeroDensityExponent_lt_benchmark {σ : ℝ} (hσ : σ < 1) :
    gmZeroDensityExponent σ < benchmarkDensityConstant * (1 - σ) := by
  have hpos : (0 : ℝ) < 1 - σ := by linarith
  unfold gmZeroDensityExponent
  have hc : gmDensityConstant < benchmarkDensityConstant :=
    gmDensityConstant_lt_benchmark
  exact mul_lt_mul_of_pos_right hc hpos

/-- The **Guth–Maynard short-interval exponent** `17/30 ≈ 0.5667`:
primes occur in intervals of length `x^{17/30+o(1)}`. -/
noncomputable def gmPrimeIntervalExponent : ℝ := 17 / 30

/-- The classical (Huxley-type) short-interval exponent `7/12 ≈ 0.5833`. -/
noncomputable def classicalPrimeIntervalExponent : ℝ := 7 / 12

/-- **Guth–Maynard shortens the prime interval** (Tier ★):
`17/30 < 7/12`. -/
theorem gmPrimeIntervalExponent_lt_classical :
    gmPrimeIntervalExponent < classicalPrimeIntervalExponent := by
  unfold gmPrimeIntervalExponent classicalPrimeIntervalExponent
  norm_num

/-- A **large-value estimate** in the Guth–Maynard sense (scaffold,
Tier ⊕).  It records a threshold exponent `σ` (the large value is
`T^σ`) and a measure-bound exponent; the bound itself — the actual
Guth–Maynard analytic theorem — is the open input, carried as a `Prop`
field. -/
structure LargeValueEstimate (D : DirichletPolynomialModel) where
  /-- The large-value threshold exponent `σ`: the polynomial is "large"
  when `‖D(t)‖ ≥ T^σ`. -/
  thresholdExponent : ℝ
  /-- The exponent bounding the measure of the large-value set. -/
  measureBoundExponent : ℝ
  /-- **Open bridge.** The Guth–Maynard large-value estimate:
  `meas (D.largeValueSet (T^thresholdExponent)) ≤ T^{measureBoundExponent+o(1)}`. -/
  bound : Prop

/-- A **zero-density consequence** (scaffold, Tier ⊕): the bound
`N(σ,T) ≤ T^{(30/13)(1-σ)+o(1)}` Guth–Maynard derive from large-value
control. -/
structure ZeroDensityConsequence where
  /-- The abscissa `σ ∈ (1/2, 1)`. -/
  sigma : ℝ
  /-- The height `T`. -/
  T : ℝ
  /-- The zero-count `N(σ,T)`. -/
  zeroCount : ℝ
  /-- **Open bridge.** `zeroCount ≤ T^{gmZeroDensityExponent sigma + o(1)}`. -/
  densityBound : Prop

/-- The **Guth–Maynard bridge** (scaffold, Tier ⊕): a Dirichlet
polynomial, a large-value estimate for it, the resulting zero-density
consequence, and the `Prop` link `largeValues_control_zeros` asserting
the implication that is the heart of the Guth–Maynard method. -/
structure GuthMaynardBridge where
  /-- The Dirichlet polynomial under study. -/
  dirichletPoly : DirichletPolynomialModel
  /-- A large-value estimate for it. -/
  largeValueEstimate : LargeValueEstimate dirichletPoly
  /-- The zero-density consequence. -/
  zeroDensityConsequence : ZeroDensityConsequence
  /-- **Open bridge.** Large-value control of `dirichletPoly` constrains
  the zero count `zeroDensityConsequence`. -/
  largeValues_control_zeros : Prop

-- --- Tier 87.5 — The Golden / Guth–Maynard hybrid and capstone --------

/-- The **Golden / Guth–Maynard hybrid** (scaffold, Tier ⊕): a Golden
Dirichlet-polynomial shadow joined to a Guth–Maynard bridge built on
the *same* polynomial (`poly_eq` is a genuine equality), plus the two
open transfer bridges into the Golden Hankel and Jacobi/Weyl layers. -/
structure GoldenGuthMaynardHybrid where
  /-- The Golden Dirichlet-polynomial shadow. -/
  shadow : GoldenDirichletPolynomialShadow
  /-- The Guth–Maynard analytic bridge. -/
  gm : GuthMaynardBridge
  /-- The bridge studies exactly the shadow's polynomial. -/
  poly_eq : gm.dirichletPoly = shadow.D
  /-- **Open bridge.** Large-value control transfers to the squared-trace
  Hankel energy `m_k(q)` of Tier 17. -/
  transfersToHankelEnergy : Prop
  /-- **Open bridge.** The transferred control constrains the Jacobi /
  Weyl `m`-function response of Tier 25. -/
  constrainsJacobiWeylResponse : Prop

/-- **Tier 87 capstone** — *Golden large-value control yields a
zero-density consequence.*

An honest projection: the conclusion is exactly the
`ZeroDensityConsequence` already carried by the hybrid's Guth–Maynard
bridge.  The proof is one line; the *value* is that stating it forces
the four bridge obligations to be named precisely —

  1. Golden trace data produces the Dirichlet polynomial
     (`shadow.comesFromGoldenTrace`, **proved** as an equality);
  2. a Guth–Maynard large-value estimate applies to it
     (`gm.largeValueEstimate`, open);
  3. large-value control transfers to the Hankel energy
     (`transfersToHankelEnergy`, open);
  4. that control constrains the Jacobi/Weyl response
     (`constrainsJacobiWeylResponse`, open).

This is deliberately weaker — and far more defensible — than any claim
that the Golden machine *proves* a zero-density improvement.

Note this is a `def`, not a `theorem`: its conclusion `ZeroDensityConsequence`
is data (a structure), not a proposition. -/
noncomputable def golden_large_value_control_implies_zero_density
    (H : GoldenGuthMaynardHybrid)
    (_hTransfer : H.transfersToHankelEnergy)
    (_hResponse : H.constrainsJacobiWeylResponse) :
    ZeroDensityConsequence :=
  H.gm.zeroDensityConsequence

-- --- Tier 87.6 — The Weyl large-value dictionary (four faces) ---------

/-- A **large-value moment shadow** (scaffold, Tier ⊕): the Hankel-layer
face of the dictionary, recording that large values of a Dirichlet
polynomial are controlled by squared-trace moment growth, which is in
turn controlled by Hankel positivity (Tier 17). -/
structure LargeValueMomentShadow where
  /-- The Dirichlet polynomial has large values on a controlled set. -/
  dirichletLargeValues : Prop
  /-- **Open bridge.** Moment growth `m_k(q)` controls those large values. -/
  momentGrowthControlsLargeValues : Prop
  /-- **Open bridge.** Hankel positivity controls the moment growth. -/
  hankelPositivityControlsMomentGrowth : Prop

/-- The **Weyl large-value dictionary** (scaffold, Tier ⊕): for a Jacobi
spine `J` from moment data and its Weyl `m`-function `W` (Tier 25), a
Dirichlet polynomial whose response function *is* the Weyl `m`-function
(`response_eq_weylM` is a genuine equality).  Large values of the
Dirichlet polynomial are reinterpreted as resonances of the spectral
response, and additive energy of the large-value set as spectral
clustering. -/
structure WeylLargeValueDictionary
    {M : PositiveDiscreteMomentMeasure}
    (J : JacobiSpineFromMoments M)
    (W : WeylMFunctionFromJacobiSpine J) where
  /-- The Dirichlet polynomial side. -/
  dirichletPoly : DirichletPolynomialModel
  /-- The spectral response function. -/
  responseFunction : ℂ → ℂ
  /-- The response function is the Jacobi spine's Weyl `m`-function. -/
  response_eq_weylM : responseFunction = W.m
  /-- **Open bridge.** Large values of `dirichletPoly` are resonances
  (poles/spikes) of `responseFunction`. -/
  largeValues_as_resonances : Prop
  /-- **Open bridge.** Additive energy of the large-value set is spectral
  clustering of the Weyl response. -/
  additiveEnergy_as_spectralClustering : Prop

/-- **The large-value spectral dictionary** — the one-object statement
of the cross-field vision: Dirichlet-polynomial resonance, prime-Fock
log-energy, Hankel moment growth, and the Jacobi/Weyl spectral response
are four faces of the same object.

Face 2, `logEnergyPhase`, is a *genuine* obligation: every instance must
exhibit the phase–energy identity, and the canonical witness is the
proved theorem `dirichletMonomial_eq_exp`. -/
structure LargeValueSpectralDictionary where
  /-- **Face 1 — Dirichlet-polynomial resonance.** -/
  shadow : GoldenDirichletPolynomialShadow
  /-- **Face 2 — prime-Fock log-energy.** The Dirichlet monomial is the
  phase evolution of the log-Hamiltonian `n`-mode: `n^{it} = exp(i·t·log n)`.
  Canonically discharged by `dirichletMonomial_eq_exp`. -/
  logEnergyPhase :
    ∀ n : ℕ, 1 ≤ n → ∀ t : ℝ,
      dirichletMonomial n t
        = Complex.exp (Complex.I * (t : ℂ) * (Real.log n : ℂ))
  /-- **Face 3 — Hankel moment growth.** -/
  momentShadow : LargeValueMomentShadow
  /-- **Face 4 — Jacobi/Weyl spectral response**, together with the
  Guth–Maynard bridge to zero-density. -/
  gm : GuthMaynardBridge

/-- The Face-2 obligation of the dictionary is always dischargeable: the
phase–energy identity is the proved theorem `dirichletMonomial_eq_exp`.
Hence the dictionary's prime-Fock log-energy face is **unconditional**. -/
theorem largeValueSpectralDictionary_logEnergyPhase :
    ∀ n : ℕ, 1 ≤ n → ∀ t : ℝ,
      dirichletMonomial n t
        = Complex.exp (Complex.I * (t : ℂ) * (Real.log n : ℂ)) :=
  fun _ hn t => dirichletMonomial_eq_exp hn t

/-- The large-value spectral dictionary projects onto its zero-density
consequence — the four-faces analogue of the Tier 87 capstone.  A `def`
(not a `theorem`): the conclusion is data, not a proposition. -/
noncomputable def largeValueSpectralDictionary_zero_density
    (L : LargeValueSpectralDictionary) : ZeroDensityConsequence :=
  L.gm.zeroDensityConsequence

