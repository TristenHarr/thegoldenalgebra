/-- **PROVED — half-angle cascade tends to zero.** As n → ∞, the
half-angle goes to zero (geometric ratio 1/2). The "atomic-scale
refinement" of the document. -/
theorem halfAngleAt_tendsto_zero :
    Filter.Tendsto halfAngleAt Filter.atTop (nhds 0) := by
  unfold halfAngleAt
  have h := tendsto_pow_atTop_nhds_zero_of_lt_one
    (show (0 : ℝ) ≤ 1/2 by norm_num)
    (show (1 : ℝ) / 2 < 1 by norm_num)
  have heq : (fun n => (45 : ℝ) / (2 : ℝ)^n) = fun n => 45 * (1/2)^n := by
    funext n; field_simp
  rw [heq]
  have : (0 : ℝ) = 45 * 0 := by ring
  rw [this]
  exact h.const_mul 45

/--
**Named record — generic quadratic root system.** `α, β` are conjugate
roots of `x² − T·x + N = 0`. Their trace `Sₙ = αⁿ + βⁿ` and
coordinate `Uₙ = (αⁿ − βⁿ)/(α − β)` satisfy the same recurrence
`Xₙ₊₂ = T·Xₙ₊₁ − N·Xₙ`. The golden case is `T = 1, N = −1`.
-/
structure QuadraticRootSystem where
  α : ℝ
  β : ℝ
  T : ℝ
  N : ℝ
  α_root : α^2 = T * α - N
  β_root : β^2 = T * β - N

/-- The golden quadratic root system: `α = φ, β = φ', T = 1, N = −1`. -/
noncomputable def goldenRootSystem : QuadraticRootSystem :=
  { α := phi, β := phiConj, T := 1, N := -1
    α_root := phi_companion
    β_root := phiConj_companion }

/-- **PROVED — trace of any quadratic root system satisfies its
recurrence.** -/
theorem QuadraticRootSystem.trace_rec (Q : QuadraticRootSystem) (n : ℕ) :
    Q.α^(n+2) + Q.β^(n+2)
      = Q.T * (Q.α^(n+1) + Q.β^(n+1)) - Q.N * (Q.α^n + Q.β^n) :=
  companion_sum_recurrence Q.α Q.β Q.T Q.N Q.α_root Q.β_root n

