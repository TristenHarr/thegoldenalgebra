/-- The formal power series `G(z) = ∑_{k≥1} ζ(k+1)·z^k` whose
`z^4` coefficient is ζ(5). The infinite projector is a `[z^4]`
extractor. -/
noncomputable def zetaGenFun (z : ℂ) (N : ℕ) : ℂ :=
  ∑ k ∈ Finset.range N, riemannZeta (k + 2) * z ^ (k + 1)

/-- **PROVED — `G_N(z) − G_N(w)` at the digamma sample-pair
`(x_r, y_r)` is exactly the partial sum `∑_{k=1}^{N} (x_r^k − y_r^k)
· ζ(k+1)`.** The sampling identity making the digamma series equal a
G-difference. -/
theorem zetaGenFun_difference (z w : ℂ) (N : ℕ) :
    zetaGenFun z N - zetaGenFun w N
      = ∑ k ∈ Finset.range N,
          riemannZeta (k + 2) * (z ^ (k + 1) - w ^ (k + 1)) := by
  unfold zetaGenFun
  rw [← Finset.sum_sub_distrib]
  congr 1
  funext k
  ring

