-- === Tier 70 — Transfer Stability Under Perturbation ================
-- =====================================================================

/-- The causal convolution is linear in the impulse (subtraction form). -/
theorem causalConvolution_sub (r : ℝ) (u v : ℕ → ℝ) (n : ℕ) :
    causalConvolution r (fun k => u k - v k) n
      = causalConvolution r u n - causalConvolution r v n := by
  induction n with
  | zero => simp [causalConvolution]
  | succ n ih =>
    rw [causalConvolution_succ, causalConvolution_succ, causalConvolution_succ, ih]
    ring

/-- **Golden transfer is Lipschitz under impulse perturbation.**
If two impulse streams differ by at most `C`, their golden responses
differ by at most `C / (1 − ‖λ‖)`. Small arithmetic error ⇒ controlled
spectral-response error. -/
theorem goldenTransfer_error_bound
    {C : ℝ} (hC : 0 ≤ C) {u v : ℕ → ℝ}
    (h : ∀ n, |u n - v n| ≤ C) (n : ℕ) :
    |goldenTransfer u n - goldenTransfer v n|
      ≤ C / (1 - goldenMemory) := by
  unfold goldenTransfer
  rw [← causalConvolution_sub]
  exact causalConvolution_bound goldenMemory_nonneg goldenMemory_lt_one hC h n

