-- =========================================================================
-- Tier 111 — The Log-Overflow Operator: `Λ[f] := f'/f`
-- =========================================================================
/-! ### Tier 111 — Log-Overflow Operator Calculus (`Λ[f] := f'/f`)

This tier formalizes the **log-overflow operator**

  `Λ[f](z) := f'(z) / f(z) = logDeriv f z`

as a **signed charge field** over the roots and poles of `f`. A zero of
order `m` contributes a simple-pole term `m / (z − r)`; a pole of order
`m` contributes `−m / (z − r)`. Critical points of `f` (roots of `f'`
away from the roots of `f`) live exactly at the **equilibrium points**
of this charge field. The chain of ideas formalized here is

  `f  ⟶  f'/f  ⟶  signed divisor field  ⟶  contour moments
        ⟶  root/pole reconstruction`.

This is *classical* complex analysis (logarithmic derivative + argument
principle + Newton identities + Gauss–Lucas) — the contribution is the
**operator-calculus packaging** plus the concrete formal chain to the
algebraic-charge-field theorems.

* **Tier ★** (this tier, unconditional, on top of Mathlib's
  `Mathlib.Analysis.Calculus.LogDeriv` API):
    `logDeriv_linear_root`             — `Λ[w↦w−r](z) = 1/(z−r)`
    `logDeriv_linear_root_pow`         — `Λ[w↦(w−r)^n](z) = n/(z−r)`
    `logDeriv_factored_polynomial`     — `Λ[∏(w−rᵢ)]    = Σ 1/(z−rᵢ)`
    `logDeriv_factored_polynomial_with_multiplicity`
                                       — `Λ[∏(w−rᵢ)^mᵢ] = Σ mᵢ/(z−rᵢ)`
    `logDeriv_rational_factorization`  — `(zeros) − (poles)` charge balance
    `critical_points_eq_charge_equilibria`
                                       — `p'(z) = 0` ⇒ `Σ 1/(z−rᵢ) = 0`

* **Tier ⊕** (conditional missing-piece structures):
    `MultiplicityResidueLaw`           — `residue(Λ[f], r) = multiplicity`
    `ArgumentPrincipleWitness`         — `∮ Λ[f] dz = 2πi (Z − P)`
    `MomentTowerWitness`               — `∮ z^k Λ[f] dz = 2πi · power sum`
    `OverflowOperatorCalculus`         — capstone bundle

The Mathlib (v4.21) gap is the same shape as Tier 16's
`HurwitzZeroTransferPrinciple`: a fully proved argument principle /
residue-of-meromorphic infrastructure is not yet upstream. The
algebraic-charge half of the chain (factorization, critical points,
rational zero/pole balance) is proved unconditionally; the
analytic-contour half is staged as named missing pieces. -/

namespace OverflowOperator

/-- **Log-overflow operator** `Λ[f](z) := f'(z) / f(z)`. Alias for
Mathlib's `logDeriv` that makes the operator-calculus terminology
explicit at the call site. -/
noncomputable def Lambda (f : ℂ → ℂ) : ℂ → ℂ := logDeriv f

@[simp] lemma Lambda_def (f : ℂ → ℂ) (z : ℂ) :
    Lambda f z = deriv f z / f z := rfl

@[simp] lemma Lambda_eq_logDeriv (f : ℂ → ℂ) :
    Lambda f = logDeriv f := rfl

/-- **Signed charge field.** Each indexed root `r i` contributes a
charge `m i / (z − r i)`. Negative `m i` encodes a pole, positive
encodes a zero. This is the operator-calculus shadow of `f'/f` for a
factored rational function. -/
noncomputable def chargeField
    {ι : Type*} (s : Finset ι) (r : ι → ℂ) (m : ι → ℤ) (z : ℂ) : ℂ :=
  ∑ i ∈ s, (m i : ℂ) / (z - r i)

/-- The charge field is additive in the multiplicity assignment. -/
lemma chargeField_add {ι : Type*} (s : Finset ι) (r : ι → ℂ)
    (m₁ m₂ : ι → ℤ) (z : ℂ) :
    chargeField s r (fun i => m₁ i + m₂ i) z =
      chargeField s r m₁ z + chargeField s r m₂ z := by
  unfold chargeField
  rw [← Finset.sum_add_distrib]
  apply Finset.sum_congr rfl
  intro i _
  push_cast
  ring

/-- **Λ of a linear factor.** `Λ[w ↦ w − r](z) = 1/(z − r)`. -/
@[simp] lemma logDeriv_linear_root (r z : ℂ) :
    logDeriv (fun w : ℂ => w - r) z = 1 / (z - r) := by
  unfold logDeriv
  simp

/-- **Λ of a multiplicity-`n` linear factor.**
`Λ[w ↦ (w − r)^n](z) = n / (z − r)`. -/
lemma logDeriv_linear_root_pow (r z : ℂ) (n : ℕ) :
    logDeriv (fun w : ℂ => (w - r) ^ n) z = (n : ℂ) / (z - r) := by
  have hd : DifferentiableAt ℂ (fun w : ℂ => w - r) z :=
    (differentiableAt_id).sub_const _
  have h := logDeriv_fun_pow hd n
  -- `h : logDeriv (fun w => (w - r) ^ n) z = n * logDeriv (fun w => w - r) z`
  rw [h, logDeriv_linear_root]
  ring

/-- **Factorization theorem (simple roots).** For
`p(z) := ∏ i ∈ s, (z − r i)`, away from the roots,
`Λ[p](z) = ∑ i ∈ s, 1 / (z − r i)`.

This is the operator-calculus statement that the logarithmic derivative
of a product factors into a sum of unit charges at the roots. -/
lemma logDeriv_factored_polynomial
    {ι : Type*} (s : Finset ι) (r : ι → ℂ) (z : ℂ)
    (hne : ∀ i ∈ s, z ≠ r i) :
    logDeriv (fun w : ℂ => ∏ i ∈ s, (w - r i)) z =
      ∑ i ∈ s, 1 / (z - r i) := by
  have hf_ne : ∀ i ∈ s, ((fun w : ℂ => w - r i) z) ≠ 0 := by
    intro i hi
    simpa using sub_ne_zero.mpr (hne i hi)
  have hf_diff : ∀ i ∈ s, DifferentiableAt ℂ (fun w : ℂ => w - r i) z :=
    fun i _ => (differentiableAt_id).sub_const _
  have hp :=
    logDeriv_prod s (fun i => fun w : ℂ => w - r i) z hf_ne hf_diff
  rw [hp]
  exact Finset.sum_congr rfl (fun i _ => logDeriv_linear_root _ _)

/-- **Factorization theorem with multiplicity.** For
`p(z) := ∏ i ∈ s, (z − r i)^(m i)`, away from the roots,
`Λ[p](z) = ∑ i ∈ s, m i / (z − r i)`.

A root of multiplicity `m` therefore appears as a charge of strength
`m`, exactly as the local-residue statement predicts. -/
lemma logDeriv_factored_polynomial_with_multiplicity
    {ι : Type*} (s : Finset ι) (r : ι → ℂ) (m : ι → ℕ) (z : ℂ)
    (hne : ∀ i ∈ s, z ≠ r i) :
    logDeriv (fun w : ℂ => ∏ i ∈ s, (w - r i) ^ (m i)) z =
      ∑ i ∈ s, (m i : ℂ) / (z - r i) := by
  have hf_ne : ∀ i ∈ s,
      ((fun w : ℂ => (w - r i) ^ (m i)) z) ≠ 0 := by
    intro i hi
    have h1 : z - r i ≠ 0 := sub_ne_zero.mpr (hne i hi)
    simpa using pow_ne_zero (m i) h1
  have hf_diff : ∀ i ∈ s,
      DifferentiableAt ℂ (fun w : ℂ => (w - r i) ^ (m i)) z := by
    intro i _
    have hd : DifferentiableAt ℂ (fun w : ℂ => w - r i) z :=
      (differentiableAt_id).sub_const _
    exact hd.pow (m i)
  have hp :=
    logDeriv_prod s (fun i => fun w : ℂ => (w - r i) ^ (m i)) z hf_ne hf_diff
  rw [hp]
  exact Finset.sum_congr rfl (fun i _ => logDeriv_linear_root_pow _ _ _)

/-- **Rational-function factorization (signed divisor field).** Zeros
contribute positive unit charges, poles contribute negative ones:

  `Λ[ ∏(w − rZ i) / ∏(w − rP j) ](z) = Σ 1/(z − rZ i) − Σ 1/(z − rP j)`.

This is the most exportable face of the operator calculus — the entire
divisor data of a rational function is read off `Λ`. -/
lemma logDeriv_rational_factorization
    {ιZ ιP : Type*} (sZ : Finset ιZ) (sP : Finset ιP)
    (rZ : ιZ → ℂ) (rP : ιP → ℂ) (z : ℂ)
    (hZne : ∀ i ∈ sZ, z ≠ rZ i) (hPne : ∀ j ∈ sP, z ≠ rP j) :
    logDeriv
        (fun w : ℂ =>
          (∏ i ∈ sZ, (w - rZ i)) / (∏ j ∈ sP, (w - rP j))) z =
      (∑ i ∈ sZ, 1 / (z - rZ i)) - (∑ j ∈ sP, 1 / (z - rP j)) := by
  have hN_ne : (∏ i ∈ sZ, (z - rZ i)) ≠ 0 :=
    Finset.prod_ne_zero_iff.mpr fun i hi => sub_ne_zero.mpr (hZne i hi)
  have hD_ne : (∏ j ∈ sP, (z - rP j)) ≠ 0 :=
    Finset.prod_ne_zero_iff.mpr fun j hj => sub_ne_zero.mpr (hPne j hj)
  have hN_eval :
      ((fun w : ℂ => ∏ i ∈ sZ, (w - rZ i)) z) ≠ 0 := by simpa using hN_ne
  have hD_eval :
      ((fun w : ℂ => ∏ j ∈ sP, (w - rP j)) z) ≠ 0 := by simpa using hD_ne
  have hN_diff : DifferentiableAt ℂ
      (fun w : ℂ => ∏ i ∈ sZ, (w - rZ i)) z :=
    DifferentiableAt.finset_prod
      (fun i _ => (differentiableAt_id).sub_const _)
  have hD_diff : DifferentiableAt ℂ
      (fun w : ℂ => ∏ j ∈ sP, (w - rP j)) z :=
    DifferentiableAt.finset_prod
      (fun j _ => (differentiableAt_id).sub_const _)
  rw [logDeriv_div z hN_eval hD_eval hN_diff hD_diff,
      logDeriv_factored_polynomial sZ rZ z hZne,
      logDeriv_factored_polynomial sP rP z hPne]

/-- **Critical points are charge equilibria.** If `p(z) := ∏(z − rᵢ)`
has no root at `z` and `p'(z) = 0`, then the unit charges at the roots
balance at `z`:

  `∑ i ∈ s, 1 / (z − r i) = 0`.

This is the operator-calculus form of the electrostatic explanation
behind Gauss–Lucas: away from the roots, derivative roots of a
polynomial coincide with equilibria of the unit-charge field placed at
those roots. -/
theorem critical_points_eq_charge_equilibria
    {ι : Type*} (s : Finset ι) (r : ι → ℂ) (z : ℂ)
    (hne : ∀ i ∈ s, z ≠ r i)
    (hp' : deriv (fun w : ℂ => ∏ i ∈ s, (w - r i)) z = 0) :
    (∑ i ∈ s, 1 / (z - r i) : ℂ) = 0 := by
  have hlog :
      logDeriv (fun w : ℂ => ∏ i ∈ s, (w - r i)) z = 0 := by
    unfold logDeriv
    simp [hp']
  rw [← logDeriv_factored_polynomial s r z hne]
  exact hlog

-- ----------------------------------------------------------------------
-- Tier ⊕ — Conditional missing-piece structures
-- ----------------------------------------------------------------------

/-- **Multiplicity-as-residue law.** Packaged as a missing-piece
structure: Mathlib v4.21 lacks the meromorphic-residue API needed to
state this directly. The classical content is

  `residue (logDeriv f) r = multiplicity of `f` at `r``,

with zeros contributing positive integers and poles contributing
negative integers. Concrete realizers (e.g. for `f(z) = (z − r)^m g(z)`
with `g(r) ≠ 0`, this tier's
`logDeriv_factored_polynomial_with_multiplicity` is the algebraic-charge
shadow) await the residue layer upstream. -/
structure MultiplicityResidueLaw (f : ℂ → ℂ) (z₀ : ℂ) (m : ℤ) where
  /-- `f` has a zero or pole of order `m` at `z₀` (signed). -/
  hasOrder : Prop
  /-- The residue of `logDeriv f` at `z₀` equals `m`. -/
  residue_logDeriv_eq_multiplicity : Prop

/-- **Argument principle witness.** A positively-oriented contour `γ`
encloses zeros and poles of a meromorphic `f` such that

  `(1 / (2π i)) ∮_γ logDeriv f = (# zeros) − (# poles)`

inside `γ` (counted with multiplicity). The contour is realised as the
circle `|z − c| = R`. Packaged as a missing-piece structure pending the
Mathlib argument-principle layer. -/
structure ArgumentPrincipleWitness (f : ℂ → ℂ) (c : ℂ) (R : ℝ) where
  /-- The circle `|z − c| = R` is positively oriented. -/
  contourIsPositive : Prop
  /-- `f` is meromorphic inside the contour, with no zeros/poles on it. -/
  meromorphicInside : Prop
  /-- Net zero/pole count balances the contour integral of `logDeriv f`. -/
  countsNetZerosMinusPoles : Prop

/-- **Moment-tower witness.** For each `k ≥ 0`, the weighted contour
moments

  `(1 / (2π i)) ∮_γ z^k · logDeriv f(z) dz`

recover the `k`-th power sum of the zeros (minus poles) enclosed by `γ`.
Combined with Newton's identities, these moments reconstruct the local
polynomial factor of `f`. Packaged as a missing-piece structure
extending the argument principle. -/
structure MomentTowerWitness (f : ℂ → ℂ) (c : ℂ) (R : ℝ) where
  /-- Argument principle holds on this contour. -/
  argument : ArgumentPrincipleWitness f c R
  /-- The `k`-th moment equals the `k`-th power sum of enclosed roots/poles. -/
  weightedMomentEqualsPowerSum : ℕ → Prop
  /-- Newton's identities reconstruct the local polynomial factor. -/
  newtonReconstruction : Prop

/-- **Overflow operator calculus.** Capstone bundle: the algebraic-charge
chain (provided by this tier's Tier ★ lemmas) together with the analytic
contour-moment chain (this structure's payload). Realizing the latter
discharges the analytic side of the `f → f'/f → divisor field →
moments → reconstruction` pipeline. -/
structure OverflowOperatorCalculus (f : ℂ → ℂ) (c : ℂ) (R : ℝ) where
  argument : ArgumentPrincipleWitness f c R
  moments  : MomentTowerWitness f c R

/-- **Argument-principle transfer principle** (`Prop`-style). Mirrors
the shape of Tier 16's `HurwitzZeroTransferPrinciple`: a single named
hypothesis that, when proved upstream, discharges the analytic half of
the operator calculus for *every* `(f, c, R)`. -/
def ArgumentPrinciplePrinciple : Prop :=
  ∀ (f : ℂ → ℂ) (c : ℂ) (R : ℝ), Nonempty (ArgumentPrincipleWitness f c R)

/-- **Moment-tower transfer principle** (`Prop`-style). The
moment-tower analogue of `ArgumentPrinciplePrinciple`. Realising this
in Mathlib upgrades the algebraic-charge layer of Tier 111 to the full
operator-calculus pipeline. -/
def MomentTowerPrinciple : Prop :=
  ∀ (f : ℂ → ℂ) (c : ℂ) (R : ℝ), Nonempty (MomentTowerWitness f c R)

/-- **Transfer-chain capstone.** If both transfer principles hold,
every `(f, c, R)` admits the full operator-calculus bundle. -/
theorem overflowOperatorCalculus_of_principles
    (hA : ArgumentPrinciplePrinciple) (hM : MomentTowerPrinciple)
    (f : ℂ → ℂ) (c : ℂ) (R : ℝ) :
    Nonempty (OverflowOperatorCalculus f c R) :=
  ⟨{ argument := (hA f c R).some
   , moments  := (hM f c R).some }⟩

end OverflowOperator

/-! ### Log-overflow operator dictionary (Tier 111)

| Lean object                                              | Use                                                            |
|----------------------------------------------------------|----------------------------------------------------------------|
| `OverflowOperator.Lambda f`                              | `Λ[f] := f'/f` (alias of Mathlib's `logDeriv`)                 |
| `OverflowOperator.chargeField s r m`                     | signed divisor field `Σ mᵢ/(z − rᵢ)`                            |
| `OverflowOperator.logDeriv_linear_root`                  | `Λ[w ↦ w − r](z) = 1/(z − r)`                                  |
| `OverflowOperator.logDeriv_linear_root_pow`              | `Λ[w ↦ (w − r)^n](z) = n/(z − r)`                              |
| `OverflowOperator.logDeriv_factored_polynomial`          | `Λ[∏(w − rᵢ)](z) = Σ 1/(z − rᵢ)`                                |
| `OverflowOperator.logDeriv_factored_polynomial_with_multiplicity` | `Λ[∏(w − rᵢ)^mᵢ](z) = Σ mᵢ/(z − rᵢ)`                 |
