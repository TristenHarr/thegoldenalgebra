-- === Tier 34 — Spectral Mechanics of Extreme Survivors ===============
-- =====================================================================
/-!
## Tier 34 — Spectral Mechanics of Survivors

Given a survivor operator (one passing the Diamond + chiral + extreme
arithmetic sieves), what must its *internal spectral mechanics* look
like? Tier 34 records the **secondary laws** — consequences that any
such operator satisfies automatically — and the obstructions that kill
operator classes failing them.

Components:
* `ChiralMultiplicity` — multiplicities pair under `t ↦ −t`.
* `SimpleSpectrum` / `SimpleExtremeHPSurvivorStack` — simple-spectrum
  refinement of the survivor stack.
* `NoCentralZero` / `no_zero_eigen_of_noCentralZero` — `Ξ(0) ≠ 0`
  forbids a zero eigenvalue (odd chiral sectors excluded).
* `CentralSpectralGap` — the central gate near the origin.
* `OddFunctionC` / `ParityCompatibleTriangle` — even determinant ⇒
  odd response (log-derivative parity).
* `ChiralTraceCancellation` — paired spectra annihilate odd test
  functions.
* `InterlacingFeeder` / `ChristoffelDarbouxLaw` — orthogonal-polynomial
  fingerprints of operator-natural feeders.
* `FiniteSectionSpectralApproximation` — no spectral pollution +
  completeness for finite-to-infinite passage.
* `FredholmDeterminantLaw` — Fredholm/zeta-regularized determinant
  compatibility for genuine infinite operators.
-/

-- --- Tier 34.1 — Multiplicity pairing -------------------------------

/-- **Chiral multiplicity.** Eigenvalue multiplicities match under
`t ↦ −t`: `m(t) = m(−t)`. -/
def ChiralMultiplicity (mult : ℝ → ℕ) : Prop :=
  ∀ t : ℝ, mult t = mult (-t)

/-- The eigenvalue predicate induced by a multiplicity function:
`t` is an eigenvalue iff its multiplicity is nonzero. -/
def EigenOfMultiplicity (mult : ℝ → ℕ) : ℝ → Prop :=
  fun t => mult t ≠ 0

/-- **Chiral multiplicity ⇒ chiral paired spectrum.** Upgrades
eigenvalue *existence* pairing to full *multiplicity-packet* pairing. -/
theorem chiralMultiplicity_to_pairedSpectrum
    {mult : ℝ → ℕ} (h : ChiralMultiplicity mult) :
    ChiralPairedSpectrum (EigenOfMultiplicity mult) := by
  intro t
  show (mult t ≠ 0) ↔ (mult (-t) ≠ 0)
  rw [h t]

-- --- Tier 34.2 — Simple spectrum gate -------------------------------

/-- **Simple spectrum.** Every eigenvalue has multiplicity at most one. -/
def SimpleSpectrum (mult : ℝ → ℕ) : Prop :=
  ∀ t : ℝ, mult t ≤ 1

/-- **Simple extreme HP survivor stack.** An `ExtremeHPSurvivorStack`
refined with a chiral, simple multiplicity function. -/
structure SimpleExtremeHPSurvivorStack
    (Xi : ℂ → ℂ) (Eigen : ℝ → Prop)
    (D Response : ℂ → ℂ) (Dreal : ℝ → ℂ)
    (Lambda : ℕ → ℝ) (Count : ℝ → ℝ) (TestFunction : Type) where
  /-- The underlying extreme survivor stack. -/
  base : ExtremeHPSurvivorStack Xi Eigen D Response Dreal Lambda Count TestFunction
  /-- The eigenvalue multiplicity function. -/
  mult : ℝ → ℕ
  /-- `Eigen` agrees with positive multiplicity. -/
  eigen_iff_mult_pos : ∀ t : ℝ, Eigen t ↔ mult t ≠ 0
  /-- Multiplicities pair under `t ↦ −t`. -/
  chiralMultiplicity : ChiralMultiplicity mult
  /-- The spectrum is simple. -/
  simple : SimpleSpectrum mult

/-- A simple survivor stack supplies the chiral paired spectrum
directly from its multiplicity data. -/
theorem SimpleExtremeHPSurvivorStack.pairedSpectrum_from_mult
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {D Response : ℂ → ℂ}
    {Dreal : ℝ → ℂ} {Lambda : ℕ → ℝ} {Count : ℝ → ℝ} {TestFunction : Type}
    (S : SimpleExtremeHPSurvivorStack
      Xi Eigen D Response Dreal Lambda Count TestFunction) :
    ChiralPairedSpectrum Eigen := by
  intro t
  constructor
  · intro ht
    have hm : S.mult t ≠ 0 := (S.eigen_iff_mult_pos t).mp ht
    have hmneg : S.mult (-t) ≠ 0 := by
      rw [← S.chiralMultiplicity t]; exact hm
    exact (S.eigen_iff_mult_pos (-t)).mpr hmneg
  · intro hneg
    have hmneg : S.mult (-t) ≠ 0 := (S.eigen_iff_mult_pos (-t)).mp hneg
    have hm : S.mult t ≠ 0 := by
      rw [S.chiralMultiplicity t]; exact hmneg
    exact (S.eigen_iff_mult_pos t).mpr hm

-- --- Tier 34.3 — Central zero / gate --------------------------------

/-- **No central zero.** The determinant shadow does not vanish at the
origin: `D 0 ≠ 0`. -/
def NoCentralZero (D : ℝ → ℂ) : Prop :=
  D 0 ≠ 0

/-- **No-go — `Ξ(0) ≠ 0` forbids a zero eigenvalue.**

If determinant zeros are exactly eigenvalues and the determinant has
no central zero, then `0` is not an eigenvalue. (So an odd chiral
finite sector — which forces a zero mode — cannot survive naively.) -/
theorem no_zero_eigen_of_noCentralZero
    {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (hZE : DeterminantZerosAreEigen Eigen D) (h0 : NoCentralZero D) :
    ¬ Eigen 0 := by
  intro hE
  exact h0 ((hZE 0).mpr hE)

/-- A chiral survivor with nonzero central determinant has no zero
mode. -/
theorem ChiralSurvivorStack.no_zero_mode_of_noCentralZero
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralSurvivorStack Xi Eigen D) (h0 : NoCentralZero D) :
    ¬ Eigen 0 :=
  no_zero_eigen_of_noCentralZero S.zerosAreEigen h0

/-- **Central spectral gap.** No eigenvalue lies in the open interval
`(−gap, gap)`. -/
def CentralSpectralGap (Eigen : ℝ → Prop) (gap : ℝ) : Prop :=
  0 < gap ∧ ∀ t : ℝ, Eigen t → gap ≤ |t|

/-- A central-gap HP model: the spectrum has an explicit central gap. -/
structure CentralGapHPModel (Eigen : ℝ → Prop) where
  /-- The gap width. -/
  gap : ℝ
  /-- The central-gap law. -/
  centralGap : CentralSpectralGap Eigen gap

/-- **Central-gap obstruction.** -/
def CentralGapObstruction (Eigen : ℝ → Prop) : Prop :=
  ¬ ∃ gap : ℝ, CentralSpectralGap Eigen gap

/-- **No-go**: a central-gap obstruction kills the central-gap class. -/
theorem no_CentralGapHPModel_of_obstruction
    {Eigen : ℝ → Prop} (hObs : CentralGapObstruction Eigen) :
    CentralGapHPModel Eigen → False :=
  fun M => hObs ⟨M.gap, M.centralGap⟩

-- --- Tier 34.4 — Resolvent / response parity ------------------------

/-- **Odd function** on `ℂ`: `F(−z) = −F(z)`. -/
def OddFunctionC (F : ℂ → ℂ) : Prop :=
  ∀ z : ℂ, F (-z) = -F z

/-- **Parity-compatible determinant triangle.** An even determinant
forces an odd response (`R = −D'/D`): the log-derivative of an even
function is odd. Records the parity chain
`functional equation → determinant evenness → response oddness`. -/
structure ParityCompatibleTriangle (D Response : ℂ → ℂ) where
  /-- The determinant is mirror-even. -/
  determinantEven : MirrorEvenFunction D
  /-- The response is odd. -/
  responseOdd : OddFunctionC Response
  /-- The underlying determinant triangle. -/
  triangle : DeterminantTriangleLaw D Response

/-- **Response-parity obstruction**: the response is not odd. -/
def ResponseParityObstruction (Response : ℂ → ℂ) : Prop :=
  ¬ OddFunctionC Response

/-- **No-go**: a non-odd response admits no parity-compatible triangle —
so a prime-trace response with the wrong parity dies. -/
theorem no_evenDet_triangle_of_response_not_odd
    {D Response : ℂ → ℂ}
    (_hEven : MirrorEvenFunction D)
    (hObs : ResponseParityObstruction Response) :
    ParityCompatibleTriangle D Response → False :=
  fun T => hObs T.responseOdd

-- --- Tier 34.5 — Chiral trace cancellation --------------------------

/-- **Chiral trace cancellation.** A trace functional annihilates odd
test functions — the spectral-side consequence of a `±`-paired
spectrum. -/
structure ChiralTraceCancellation (Trace : (ℝ → ℂ) → ℂ) where
  /-- Odd test functions are annihilated. -/
  cancelsOdd :
    ∀ f : ℝ → ℂ, (∀ t : ℝ, f (-t) = -f t) → Trace f = 0

/-- A chiral-trace HP model: a paired spectrum together with a trace
functional that cancels odd test functions. -/
structure ChiralTraceHPModel
    (Eigen : ℝ → Prop) (Trace : (ℝ → ℂ) → ℂ) where
  /-- The paired spectrum. -/
  pairedSpectrum : ChiralPairedSpectrum Eigen
  /-- The trace cancellation law. -/
  traceCancellation : ChiralTraceCancellation Trace

-- --- Tier 34.6 — Interlacing / Christoffel–Darboux ------------------

/-- **Interlacing feeder.** Consecutive finite-section characteristic
polynomials (as real functions) interlace — the operator-natural
fingerprint distinguishing Jacobi feeders from arbitrary real-rooted
approximants. -/
structure InterlacingFeeder (P : ℕ → ℝ → ℝ) where
  /-- Consecutive sections interlace. -/
  interlacesConsecutive : Prop

/-- An interlacing Jacobi feeder: a Jacobi feeder whose finite-section
characteristic polynomials interlace. -/
structure InterlacingJacobiFeeder (Xi : ℂ → ℂ) where
  /-- The underlying Jacobi feeder. -/
  feeder : JacobiFeeder Xi
  /-- The finite-section characteristic polynomials (as functions). -/
  characteristicPolys : ℕ → ℝ → ℝ
  /-- The interlacing law. -/
  interlacing : InterlacingFeeder characteristicPolys

/-- **Christoffel–Darboux law.** The reproducing kernel
`Kₙ(x,y) = Σ_{k≤n} pₖ(x)pₖ(y)` of an orthogonal-polynomial system: a
positive kernel controlling zero spacing. -/
structure ChristoffelDarbouxLaw
    (K : ℕ → ℝ → ℝ → ℝ) (P : ℕ → ℝ → ℝ) where
  /-- The kernel reproduces polynomial evaluation. -/
  reproducingKernel : Prop
  /-- Diagonal positivity `Kₙ(x,x) ≥ 0`. -/
  positivity : ∀ n : ℕ, ∀ x : ℝ, 0 ≤ K n x x
  /-- The Christoffel–Darboux summation identity. -/
  cdIdentity : Prop

/-- A Christoffel–Darboux Jacobi HP model. -/
structure CDJacobiHPModel (Xi : ℂ → ℂ) where
  /-- The underlying Jacobi feeder. -/
  feeder : JacobiFeeder Xi
  /-- The finite-section characteristic polynomials. -/
  characteristicPolys : ℕ → ℝ → ℝ
  /-- The Christoffel–Darboux kernel. -/
  kernel : ℕ → ℝ → ℝ → ℝ
  /-- The CD law. -/
  cdLaw : ChristoffelDarbouxLaw kernel characteristicPolys

-- --- Tier 34.7 — Finite-section spectral approximation --------------

/-- **Finite-section spectral approximation.** Records the per-section
eigenvalue predicates and the convergence / no-pollution /
completeness properties needed for finite-to-infinite passage. -/
structure FiniteSectionSpectralApproximation (EigenLimit : ℝ → Prop) where
  /-- Eigenvalue predicate of the `N`-th finite section. -/
  EigenN : ℕ → ℝ → Prop
  /-- The finite spectra converge to `EigenLimit`. -/
  spectralConvergence : Prop
  /-- No spurious finite eigenvalues survive away from the true
  spectrum. -/
  noSpectralPollution : Prop
  /-- Every true spectral point is approximated. -/
  completeness : Prop

/-- **Spectral-pollution obstruction**: no pollution-free finite-section
approximation exists. -/
def SpectralPollutionObstruction (EigenLimit : ℝ → Prop) : Prop :=
  ¬ ∃ A : FiniteSectionSpectralApproximation EigenLimit, A.noSpectralPollution

-- --- Tier 34.8 — Regularized determinant compatibility --------------

/-- **Regularized determinant law.** An infinite operator carries a
regularized (Fredholm / zeta / scattering) determinant compatible with
finite sections and with the determinant triangle. -/
structure FredholmDeterminantLaw (Operator : Type) (D : ℂ → ℂ) where
  /-- The regularized determinant of the operator. -/
  regularizedDet : Operator → ℂ → ℂ
  /-- It equals the determinant shadow `D`. -/
  determinantIdentity : Prop
  /-- It is the limit of finite-section determinants. -/
  finiteSectionCompatibility : Prop
  /-- Its logarithmic derivative matches the response. -/
  logDerivativeCompatibility : Prop

/-- A regularized-determinant HP model. -/
structure RegularizedHPModel
    (Xi : ℂ → ℂ) (Operator : Type) (D Response : ℂ → ℂ) where
  /-- The regularized determinant law. -/
  regDetLaw : FredholmDeterminantLaw Operator D
  /-- The determinant triangle. -/
  triangle : DeterminantTriangleLaw D Response
  /-- `D` matches the target `Xi`. -/
  xiMatch : Prop

/-! ## Tier 34 Status Summary

Tier 34 lands the **spectral mechanics of survivors** — the secondary
laws any survivor operator satisfies automatically, plus the
obstructions for classes failing them.

Multiplicity & simplicity:
