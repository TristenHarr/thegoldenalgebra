    (Z : CorrectedDistributionalPrimeFockCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  DistributionalExplicitFormulaPrimeFockCore_implies_zeta_critical_line
    Z.toDistributionalExplicitFormulaPrimeFockCore

-- Step 202: missing-correction no-go.

/-- An explicit-formula construction that omits the correction terms. -/
def MissingExplicitFormulaCorrections : Prop :=
  ¬ Nonempty ExplicitFormulaCorrectionTerms

/-- An explicit-formula construction that includes the correction
terms. -/
def HasExplicitFormulaCorrections : Prop :=
  Nonempty ExplicitFormulaCorrectionTerms

/-- Missing-correction explicit formulas are rejected: a naive identity
that drops the gamma / trivial-zero / pole terms cannot be the true
explicit formula. -/
theorem missingCorrections_rejected
    (h : MissingExplicitFormulaCorrections) :
    ¬ HasExplicitFormulaCorrections :=
  h

-- Step 203: the corrected distributional construction problem.

/--
**The corrected distributional explicit-formula construction problem.**
Construct the distributional equality between the zero side and the
prime side, including all correction terms, compatible with
Fourier–Mellin / Plancherel. The honest non-naive dual-transform target.
-/
def CorrectedDistributionalExplicitFormulaConstructionProblem : Prop :=
  Nonempty CorrectedDistributionalPrimeFockCore

/-- Solving the corrected distributional explicit-formula construction
problem implies the critical-line statement. -/
theorem CorrectedDistributionalExplicitFormulaConstructionProblem_implies_zeta_critical_line
    (h : CorrectedDistributionalExplicitFormulaConstructionProblem) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ := by
  rcases h with ⟨Z⟩
  exact CorrectedDistributionalPrimeFockCore_implies_zeta_critical_line Z

-- === Weil Positivity / GNS Reconstruction (Steps 204-208) ===
-- The major turn: from operator-GUESSING to positivity RECONSTRUCTION.
-- RH has a famous equivalent — the Weil positivity criterion: a
-- quadratic form from the explicit formula is positive iff RH holds.
-- Positivity → Hilbert space (GNS) → self-adjoint operator → real
-- spectrum. This is the "drive backward through the mirror" route.

-- Step 204: the Weil positivity form.

/--
A *Weil positivity form*: the quadratic form built from the corrected
distributional explicit formula. Its positive-semidefiniteness is the
Weil-criterion shadow of RH.
-/
structure WeilPositivityForm where
  testSpace : ExplicitFormulaTestFunctionSpace
  quadraticForm : testSpace.TestFunction → ℝ
  builtFromCorrectedExplicitFormula : Prop
  positiveSemidefinite : Prop
  fourierMellinPositiveCompatibility : Prop

/-- A corrected-distributional core carrying the Weil positivity form. -/
structure WeilPositiveDistributionalCore
    extends CorrectedDistributionalPrimeFockCore where
  weilPositivity : WeilPositivityForm

/-- Bridge: Weil-positive distributional core ⟹ critical-line. -/
theorem WeilPositiveDistributionalCore_implies_zeta_critical_line
    (Z : WeilPositiveDistributionalCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  CorrectedDistributionalPrimeFockCore_implies_zeta_critical_line
    Z.toCorrectedDistributionalPrimeFockCore

-- Step 205: positivity ⟹ real spectrum.

/--
*Positivity-to-real-spectrum law*: a positive explicit-formula form
constructs a pre-Hilbert space, a self-adjoint representation after
quotient, real spectral support, and the mirror RH statement.
-/
structure PositivityImpliesRealSpectrumLaw
    (W : WeilPositivityForm) where
  constructsPreHilbertSpace : Prop
  quotientByNullSpace : Prop
  selfAdjointRepresentation : Prop
  realSpectralSupport : Prop
  yieldsMirrorRH : Prop

/-- A Weil-positive core carrying the positivity-to-spectrum law. -/
structure WeilPositiveSpectralCore
    extends WeilPositiveDistributionalCore where
  positivityToSpectrum :
    PositivityImpliesRealSpectrumLaw weilPositivity

/-- Bridge: Weil-positive spectral core ⟹ critical-line. -/
theorem WeilPositiveSpectralCore_implies_zeta_critical_line
    (Z : WeilPositiveSpectralCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  WeilPositiveDistributionalCore_implies_zeta_critical_line
    Z.toWeilPositiveDistributionalCore

-- Step 206: GNS reconstruction from positivity.

/--
*GNS-style reconstruction* from the Weil positivity form: a positive
quadratic form yields a Hilbert space (quotient by null vectors, then
complete) carrying a representation — the spectral operator emerges
from positivity, not from a guess.
-/
structure GNSWeilReconstruction where
  positivityForm : WeilPositivityForm
  preHilbertSpace : Type
  nullSpaceQuotientLaw : Prop
  completionLaw : Prop
  representationLaw : Prop
  spectralOperatorProduced : Prop

/-- A Weil-positive spectral core carrying the GNS reconstruction. -/
structure GNSWeilZetaCore
    extends WeilPositiveSpectralCore where
  gnsReconstruction : GNSWeilReconstruction

/-- Bridge: GNS-Weil zeta core ⟹ critical-line. -/
theorem GNSWeilZetaCore_implies_zeta_critical_line
    (Z : GNSWeilZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  WeilPositiveSpectralCore_implies_zeta_critical_line
    Z.toWeilPositiveSpectralCore

-- Step 207: nonpositive explicit formula no-go.

/-- A Weil form that is not positive-semidefinite. -/
def NonPositiveExplicitFormulaWorld (W : WeilPositivityForm) : Prop :=
  ¬ W.positiveSemidefinite

/-- A Weil form that is positive-semidefinite. -/
def PositiveExplicitFormulaWorld (W : WeilPositivityForm) : Prop :=
  W.positiveSemidefinite

/-- Nonpositive explicit-formula forms are rejected: positivity is the
Weil-criterion shadow of RH, and a nonpositive form contradicts it. -/
theorem nonpositiveExplicitFormula_rejected
    {W : WeilPositivityForm}
    (hnon : NonPositiveExplicitFormulaWorld W) :
    ¬ PositiveExplicitFormulaWorld W :=
  hnon

-- Step 208: the Weil-positive construction problem.

/--
**The Weil-positive explicit-formula construction problem.** Construct
the corrected explicit formula with a positive Weil form, then use
GNS / de Branges-style reconstruction to obtain the Hilbert–Pólya
operator. The positivity backdoor to RH.
-/
def WeilPositiveExplicitFormulaConstructionProblem : Prop :=
  Nonempty GNSWeilZetaCore

/-- Solving the Weil-positive explicit-formula construction problem
implies the critical-line statement. -/
theorem WeilPositiveExplicitFormulaConstructionProblem_implies_zeta_critical_line
    (h : WeilPositiveExplicitFormulaConstructionProblem) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ := by
  rcases h with ⟨Z⟩
  exact GNSWeilZetaCore_implies_zeta_critical_line Z

-- === Classical Riemann-Weil Explicit Formula (Step 209) ===
-- HONEST STATUS NOTE. Everything above encodes the *shape* of the
-- explicit formula as typed obligations. The classical Riemann-Weil
-- explicit formula is a genuine, already-known theorem of analytic
-- number theory — but it is NOT yet proved inside this file: proving
-- it would require defining the test-function space, the Fourier/
-- Mellin transform, the sums over zeros and prime powers, their
-- convergence/regularization, and the distributional identity.
--
-- This step names that classical theorem as an explicit object, so the
-- framework can say: "port/prove THIS, and the distributional
-- transform layer is supplied." It is distinct from the Hilbert-Pólya
-- research problem — the explicit formula is known mathematics; only
-- its Lean formalization is open.

/--
**`ClassicalRiemannWeilExplicitFormula`** — the classical explicit
formula as a named object: a test-function space, the zero-side
distribution, the prime-side distribution, the correction terms, and
the distributional identity binding them.

Supplying an inhabitant of this structure means the Riemann-Weil
explicit formula has been formalized; it is a *Mathlib-portable
analytic theorem*, not a research-level obstruction.
-/
structure ClassicalRiemannWeilExplicitFormula where
  testFunctionSpace : ExplicitFormulaTestFunctionSpace
  zeroDistribution : DistributionalSpectralTrace
  primeDistribution : ArithmeticDistributionalTrace
  correctionTerms : ExplicitFormulaCorrectionTerms
  formula :
    ExplicitFormulaDistributionIdentity zeroDistribution primeDistribution

/--
A classical Riemann-Weil explicit formula supplies the corrected
distributional identity used by the framework's distributional layer
(Step 201). This is the conversion that makes "port the explicit
formula" feed directly into the construction tower.
-/
def ClassicalRiemannWeilExplicitFormula.toCorrectedExplicitFormulaDistributionIdentity
    (F : ClassicalRiemannWeilExplicitFormula) :
    CorrectedExplicitFormulaDistributionIdentity
      F.zeroDistribution F.primeDistribution where
  correctionTerms := F.correctionTerms
  distributionEqualityWithCorrections := F.formula.distributionEquality
  fourierMellinCompatibility := F.formula.fourierMellinCompatibility

/--
The Riemann-Weil explicit formula formalization target: the proposition
that the classical explicit formula has been formalized in Lean.

This is the **one named analytic theorem** (as opposed to the
Hilbert-Pólya research problem) whose Mathlib porting would discharge
the entire distributional-transform layer.
-/
def RiemannWeilExplicitFormulaFormalizationTarget : Prop :=
  Nonempty ClassicalRiemannWeilExplicitFormula

