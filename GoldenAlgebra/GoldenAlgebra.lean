    ∧ (1/2 : ℝ)^25 < 0.00000003 -- N=25: 2.98·10⁻⁸
    ∧ (1/2 : ℝ)^30 < 0.00000001 -- N=30: 9.31·10⁻¹⁰
    ∧ (1/2 : ℝ)^60 < 0.000000000000000001 := by  -- N=60: 8.67·10⁻¹⁹
  refine ⟨by norm_num, by norm_num, by norm_num, by norm_num,
          by norm_num, by norm_num⟩

