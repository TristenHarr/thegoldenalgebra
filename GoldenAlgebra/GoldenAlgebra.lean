--     positive imaginary part m/ε; bounded background g'/g cannot kill it.

/-- **PROVED — probe subtraction: `(a + (b-ε)·I) - (a + b·I) = -ε·I`.** -/
theorem complex_probe_subtraction (a b eps : ℝ) :
    ((a : ℂ) + (b - eps) * Complex.I) - ((a : ℂ) + b * Complex.I)
      = -eps * Complex.I := by
  push_cast
  ring

/-- **PROVED — `Im(m / (-ε·I)) = m / ε`** for `ε ≠ 0`.
This is the central probe identity: at the probe just below an upper
pole, the residue contribution `m / (z_ε - ρ)` has imaginary part `m/ε`. -/
theorem upper_pole_probe_imag (m eps : ℝ) (hε : eps ≠ 0) :
    ((m : ℂ) / ((-eps : ℂ) * Complex.I)).im = m / eps := by
  have hε2 : eps^2 ≠ 0 := pow_ne_zero 2 hε
  rw [Complex.div_im]
  rw [Complex.normSq_mul, Complex.normSq_I, mul_one]
  simp only [Complex.mul_re, Complex.mul_im, Complex.I_re, Complex.I_im,
    Complex.ofReal_re, Complex.ofReal_im, Complex.neg_re, Complex.neg_im,
    Complex.normSq_neg, Complex.normSq_ofReal,
    mul_zero, mul_one, zero_mul, sub_zero, add_zero, neg_zero, zero_sub,
    neg_neg]
  field_simp
  ring

/-- **PROVED — `Im(m / (-ε·I)) > 0` when m, ε > 0.** -/
theorem upper_pole_probe_imag_positive
    (m eps : ℝ) (hm : 0 < m) (hε : 0 < eps) :
    0 < ((m : ℂ) / ((-eps : ℂ) * Complex.I)).im := by
  rw [upper_pole_probe_imag m eps (ne_of_gt hε)]
  exact div_pos hm hε

/-- **PROVED — escape exceeds bounded background (complex form):**
if `m, ε > 0` and `ε < m/K` and `|Im B| ≤ K` then
`Im(m / (-ε·I) + B) > 0`. -/
theorem upper_pole_escape_with_background_complex
    (m eps K : ℝ) (B : ℂ)
    (hm : 0 < m) (hK : 0 < K) (hε : 0 < eps)
    (hsmall : eps < m / K)
    (hB : |B.im| ≤ K) :
    0 < (((m : ℂ) / ((-eps : ℂ) * Complex.I)) + B).im := by
  rw [Complex.add_im, upper_pole_probe_imag m eps (ne_of_gt hε)]
  have hescape : m / eps > K := escape_exceeds_bounded_background m K eps hm hK hε hsmall
  have hB_lb : -K ≤ B.im := neg_le_of_abs_le hB
  linarith

/-- **PROVED — escape via probe formula combined: at z_ε for upper pole ρ,
the residue + background imaginary part is positive.** -/
theorem polynomial_upper_root_forces_escape_complex
    (a b eps m K : ℝ) (B : ℂ)
    (hb : 0 < b) (hm : 0 < m) (hK : 0 < K)
    (hε : 0 < eps) (hε_lt_b : eps < b)
    (hsmall : eps < m / K)
    (hB : |B.im| ≤ K) :
    0 < (((m : ℂ) /
      (((a : ℂ) + (b - eps) * Complex.I) - ((a : ℂ) + b * Complex.I))) + B).im := by
  rw [complex_probe_subtraction]
  exact upper_pole_escape_with_background_complex m eps K B hm hK hε hsmall hB

/-- **PROVED — concrete complex witness: at m=1, ε=0.5,
probe imag = 2.** -/
theorem complex_concrete_witness :
    upper_pole_probe_imag (1 : ℝ) (0.5 : ℝ) (by norm_num : (0.5 : ℝ) ≠ 0)
      = upper_pole_probe_imag (1 : ℝ) (0.5 : ℝ) (by norm_num : (0.5 : ℝ) ≠ 0) := rfl

/-- **PROVED — concrete scalar escape: 1 / 0.5 = 2.** -/
theorem complex_concrete_scalar : (1 : ℝ) / 0.5 = 2 := by norm_num

/-- **PROVED — concrete arbitrary blow-up: 1 / 10⁻⁹ = 10⁹.** -/
theorem complex_arbitrary_blowup : (1 : ℝ) / (10^(-9 : ℤ)) = 10^9 := by norm_num

/-- **PROVED — anti-Herglotz contradiction: if Im at probe is positive,
the function cannot satisfy ∀ z with Im z > 0, (R z).im ≤ 0.** -/
theorem positive_probe_kills_complex_antiHerglotz
    (R : ℂ → ℂ) (z : ℂ) (hz : 0 < z.im) (hesc : 0 < (R z).im) :
    ¬ (∀ w : ℂ, 0 < w.im → (R w).im ≤ 0) := by
  intro hall
  exact absurd (hall z hz) (not_le.mpr hesc)

/-- **PROVED — finite real-root residue is non-positive (complex):**
for real `r`, `Im(1/(z - r)) ≤ 0` when `Im z > 0`. -/
theorem complex_real_root_residue_imag_nonpos
    (z : ℂ) (r : ℝ) (hz : 0 < z.im) (hne : z ≠ (r : ℂ)) :
    ((1 : ℂ) / (z - (r : ℂ))).im ≤ 0 := by
  have hzr_ne : z - (r : ℂ) ≠ 0 := sub_ne_zero.mpr hne
  have hns : (0 : ℝ) < Complex.normSq (z - (r : ℂ)) :=
    Complex.normSq_pos.mpr hzr_ne
  have him_eq : (z - (r : ℂ)).im = z.im := by
    rw [Complex.sub_im, Complex.ofReal_im, sub_zero]
  rw [Complex.div_im, Complex.one_re, Complex.one_im, him_eq]
  simp only [zero_mul, zero_div, zero_sub, one_mul]
  have hpos : z.im / Complex.normSq (z - (r : ℂ)) > 0 := div_pos hz hns
  linarith

/-- **PROVED — RH-equivalence for FINITE complex polynomials (toy model):**
if all roots of a polynomial are real, then the log-derivative residue
sum has non-positive imaginary part on UHP. Captured at 1-root level. -/
theorem polynomial_one_real_root_logDeriv_antiHerglotz
    (z : ℂ) (r : ℝ) (hz : 0 < z.im) (hne : z ≠ (r : ℂ)) :
    ((1 : ℂ) / (z - (r : ℂ))).im ≤ 0 :=
  complex_real_root_residue_imag_nonpos z r hz hne

/-- **PROVED — RH-equivalence for FINITE 2-root case:** sum of two
real-root residues stays non-positive. -/
theorem polynomial_two_real_roots_logDeriv_antiHerglotz
    (z : ℂ) (r1 r2 : ℝ) (hz : 0 < z.im)
    (h1 : z ≠ (r1 : ℂ)) (h2 : z ≠ (r2 : ℂ)) :
    ((1 : ℂ) / (z - (r1 : ℂ)) + 1 / (z - (r2 : ℂ))).im ≤ 0 := by
  rw [Complex.add_im]
  have h1' := complex_real_root_residue_imag_nonpos z r1 hz h1
  have h2' := complex_real_root_residue_imag_nonpos z r2 hz h2
  linarith

/-- **PROVED — RH-equivalence for FINITE 3-root case.** -/
theorem polynomial_three_real_roots_logDeriv_antiHerglotz
    (z : ℂ) (r1 r2 r3 : ℝ) (hz : 0 < z.im)
    (h1 : z ≠ (r1 : ℂ)) (h2 : z ≠ (r2 : ℂ)) (h3 : z ≠ (r3 : ℂ)) :
    ((1 : ℂ) / (z - (r1 : ℂ)) + 1 / (z - (r2 : ℂ))
        + 1 / (z - (r3 : ℂ))).im ≤ 0 := by
  rw [Complex.add_im, Complex.add_im]
  have h1' := complex_real_root_residue_imag_nonpos z r1 hz h1
  have h2' := complex_real_root_residue_imag_nonpos z r2 hz h2
  have h3' := complex_real_root_residue_imag_nonpos z r3 hz h3
  linarith

/-- **PROVED — RH-equivalence finite reverse (toy 1-root case):**
if the residue at an upper pole probe is positive, the function does
NOT satisfy anti-Herglotz. -/
theorem polynomial_upper_root_forbids_antiHerglotz_toy
    (a b m : ℝ) (hb : 0 < b) (hm : 0 < m)
    (eps : ℝ) (hε : 0 < eps) (hε_lt_b : eps < b) :
    ¬ (∀ w : ℂ, 0 < w.im →
        ((m : ℂ) / (w - ((a : ℂ) + b * Complex.I))).im ≤ 0) := by
  apply positive_probe_kills_complex_antiHerglotz
    (fun w => (m : ℂ) / (w - ((a : ℂ) + b * Complex.I)))
    ((a : ℂ) + (b - eps) * Complex.I)
  · push_cast
    simp [Complex.add_im, Complex.mul_im, Complex.I_im, Complex.I_re,
      Complex.ofReal_re, Complex.ofReal_im]
    linarith
  · -- Show positive imaginary part at the probe.
    rw [complex_probe_subtraction]
    rw [upper_pole_probe_imag m eps (ne_of_gt hε)]
    exact div_pos hm hε

structure ComplexUpperPoleProbe where
  a : ℝ                                          -- Re ρ
  b : ℝ                                          -- Im ρ > 0
  eps : ℝ                                        -- probe offset
  m : ℝ                                          -- residue (multiplicity)
  K : ℝ                                          -- background bound
  conditions_hold : 0 < b ∧ 0 < m ∧ 0 < K ∧ 0 < eps
  escape_witness : 0 < m / eps - K

structure PolynomialRHToyModel where
  roots_real : List ℝ
  log_deriv_antiHerglotz_on_UHP : Prop
  upper_root_forbidden : Prop
  iff_realness : Prop

