-- === Tier 15 — Entire Dirichlet Extension via contractionPolylog =====
-- =====================================================================
/-!
## Tier 15 — Entire Dirichlet Extension

Tier 14's Theorem A.4 proves the Dirichlet trace series `D_S(s)` is
summable for every `s ∈ ℂ`. Tier 15 promotes this to a much stronger
statement: `D_S` is **entire** in `s`.

The route is through a finite-disk polylog abstraction. For `‖z‖ < 1`
the series `Σ z^(n+1) / (n+1)^s` converges for every `s ∈ ℂ`, defining
a *contraction polylog*:

  `contractionPolylog z s := Σ_{n≥0} z^(n+1) / (n+1)^s`.

Each `D_S(s)` then splits as `contractionPolylog λ s + contractionPolylog λ̄ s`
(since `τₙ = λⁿ + λ̄ⁿ`), so the entireness of `D_S` reduces to the
entireness of `s ↦ contractionPolylog z s` for `‖z‖ < 1`.

The latter is proved by:
1. Dominated normwise bound on `Metric.ball s₀ 1` ⇒ summable.
2. Each per-term function `s ↦ z^(n+1) / (n+1)^s` is differentiable on
   the ball (the denominator `(n+1)^s` is everywhere nonzero).
3. `Mathlib.Analysis.Complex.LocallyUniformLimit.
   differentiableOn_tsum_of_summable_norm` gives differentiability of
   the sum on the ball, then `DifferentiableOn.analyticAt` from
   `Mathlib.Analysis.Complex.CauchyIntegral` lifts to analyticity at
   `s₀`.

Flagship theorems:
* `contractionPolylog_summable` — convergence for any `‖z‖ < 1`, any `s`.
* `SpectralContractionPair.traceDirichlet_eq_contractionPolylog_add` —
  the spectral split.
* `contractionPolylog_analyticAt` — entire in `s` for fixed `‖z‖ < 1`.
* `SpectralContractionPair.traceDirichlet_analyticAt` — `D_S` is entire.
* `goldenTraceDirichlet_analyticAt` — Golden corollary: `D_G` is entire.
-/

/-- **Contraction Polylogarithm.**

For complex `z` with `‖z‖ < 1`, the series
`Σ_{n≥0} z^(n+1) / (n+1)^s` converges absolutely for every `s ∈ ℂ`.
We define `contractionPolylog z s` as its sum. This is a finite-disk
analogue of the classical polylogarithm `Liₛ(z)`. -/
noncomputable def contractionPolylog (z s : ℂ) : ℂ :=
  ∑' n : ℕ, z ^ (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s

/-- **Contraction Polylog summability.**

For any `‖z‖ < 1` and any `s ∈ ℂ`, the contraction polylog series is
summable. Same structure as `SpectralContractionPair.traceDirichlet_summable`
with `‖z^(n+1)‖ = ‖z‖^(n+1)` (no factor of 2) as the source of decay. -/
theorem contractionPolylog_summable
    {z : ℂ} (hz : ‖z‖ < 1) (s : ℂ) :
    Summable (fun n : ℕ => z ^ (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s) := by
  set k : ℕ := ⌈max (0 : ℝ) (-s.re)⌉₊ with hk_def
  have hz_norm : ‖(‖z‖ : ℝ)‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg (norm_nonneg _)]
    exact hz
  have hpow : Summable (fun n : ℕ => (n : ℝ) ^ k * ‖z‖ ^ n) :=
    summable_pow_mul_geometric_of_norm_lt_one k hz_norm
  have hshift :
      Summable (fun n : ℕ => ((n + 1 : ℕ) : ℝ) ^ k * ‖z‖ ^ (n + 1)) :=
    (summable_nat_add_iff
      (f := fun n : ℕ => (n : ℝ) ^ k * ‖z‖ ^ n) 1).mpr hpow
  apply Summable.of_norm_bounded hshift
  intro n
  have hpos : (0 : ℝ) < ((n + 1 : ℕ) : ℝ) := by exact_mod_cast Nat.succ_pos n
  have hone_le : (1 : ℝ) ≤ ((n + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_le_succ (Nat.zero_le _)
  have hcast : (((n + 1 : ℕ) : ℝ) : ℂ) = ((n + 1 : ℕ) : ℂ) := by push_cast; rfl
  have hden_norm : ‖((n + 1 : ℕ) : ℂ) ^ s‖ = ((n + 1 : ℕ) : ℝ) ^ s.re := by
    rw [← hcast]; exact norm_cpow_eq_rpow_re_of_pos hpos s
  have hnum : ‖z ^ (n + 1)‖ = ‖z‖ ^ (n + 1) := by rw [norm_pow]
  have hk_ge : -s.re ≤ (k : ℝ) := by
    have h1 : max (0 : ℝ) (-s.re) ≤ (k : ℝ) := by
      rw [hk_def]; exact_mod_cast Nat.le_ceil _
    linarith [le_max_right (0 : ℝ) (-s.re)]
  have hpow_ge_one :
      ((n + 1 : ℕ) : ℝ) ^ k * ((n + 1 : ℕ) : ℝ) ^ s.re ≥ 1 := by
    rw [show ((n + 1 : ℕ) : ℝ) ^ k = ((n + 1 : ℕ) : ℝ) ^ (k : ℝ) from
        (Real.rpow_natCast _ k).symm]
    rw [← Real.rpow_add hpos]
    exact Real.one_le_rpow hone_le (by linarith)
  rw [norm_div, hden_norm, hnum]
  have hden_pos : 0 < ((n + 1 : ℕ) : ℝ) ^ s.re := Real.rpow_pos_of_pos hpos _
  rw [div_le_iff₀ hden_pos]
  calc ‖z‖ ^ (n + 1)
      = ‖z‖ ^ (n + 1) * 1 := by ring
    _ ≤ ‖z‖ ^ (n + 1)
            * (((n + 1 : ℕ) : ℝ) ^ k * ((n + 1 : ℕ) : ℝ) ^ s.re) :=
          mul_le_mul_of_nonneg_left hpow_ge_one (by positivity)
    _ = ((n + 1 : ℕ) : ℝ) ^ k * ‖z‖ ^ (n + 1)
            * ((n + 1 : ℕ) : ℝ) ^ s.re := by ring

/-- **Spectral split for `traceDirichlet`.**

For any `SpectralContractionPair S` and any `s ∈ ℂ`:
`D_S(s) = contractionPolylog λ s + contractionPolylog λ̄ s`.

This follows from the additive split `τₙ = λⁿ + λ̄ⁿ` term by term. -/
theorem SpectralContractionPair.traceDirichlet_eq_contractionPolylog_add
    (S : SpectralContractionPair) (s : ℂ) :
    S.traceDirichlet s
      = contractionPolylog S.lam s + contractionPolylog (star S.lam) s := by
  unfold SpectralContractionPair.traceDirichlet contractionPolylog
  have hstar : ‖star S.lam‖ < 1 := by rw [S.norm_star_lam]; exact S.hlam
  have h1 := contractionPolylog_summable S.hlam s
  have h2 := contractionPolylog_summable hstar s
  rw [← Summable.tsum_add h1 h2]
  congr 1
  funext n
  unfold SpectralContractionPair.traceC
  rw [add_div]

/-- **Per-term differentiability of contraction polylog.**

For `n ∈ ℕ`, the function `s ↦ z^(n+1) / (n+1)^s` is differentiable
on all of `ℂ` (the denominator `(n+1)^s` is everywhere nonzero, since
the base `(n+1 : ℂ)` is a nonzero positive integer). -/
theorem contractionPolylog_term_differentiable (z : ℂ) (n : ℕ) :
    Differentiable ℂ (fun s : ℂ => z ^ (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s) := by
  have hne : ((n + 1 : ℕ) : ℂ) ≠ 0 := by
    exact_mod_cast Nat.succ_ne_zero n
  have hcpow : Differentiable ℂ
      (fun s : ℂ => ((n + 1 : ℕ) : ℂ) ^ s) :=
    differentiable_id.const_cpow (Or.inl hne)
  refine (differentiable_const _).div hcpow (fun s => ?_)
  have h := Complex.natCast_add_one_cpow_ne_zero n s
  have hcast : ((n + 1 : ℕ) : ℂ) = ((n : ℂ) + 1) := by push_cast; rfl
  rw [hcast]
  exact h

/-- **Per-term L¹-bound on `Metric.ball s₀ 1`.**

For `s ∈ Metric.ball s₀ 1` and `n ∈ ℕ`:
`‖z^(n+1) / (n+1)^s‖ ≤ ‖z‖^(n+1) · (n+1)^k`
where `k := ⌈max 0 (1 − Re(s₀))⌉₊`. -/
theorem contractionPolylog_term_norm_le_on_ball
    {z : ℂ} (s₀ s : ℂ) (hs : s ∈ Metric.ball s₀ 1) (n : ℕ) :
    ‖z ^ (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s‖
      ≤ ‖z‖ ^ (n + 1) * ((n + 1 : ℕ) : ℝ) ^ (⌈max (0 : ℝ) (1 - s₀.re)⌉₊ : ℝ) := by
  set k : ℕ := ⌈max (0 : ℝ) (1 - s₀.re)⌉₊ with hk_def
  have hpos : (0 : ℝ) < ((n + 1 : ℕ) : ℝ) := by exact_mod_cast Nat.succ_pos n
  have hone_le : (1 : ℝ) ≤ ((n + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.succ_le_succ (Nat.zero_le _)
  have hcast : (((n + 1 : ℕ) : ℝ) : ℂ) = ((n + 1 : ℕ) : ℂ) := by push_cast; rfl
  have hden_norm : ‖((n + 1 : ℕ) : ℂ) ^ s‖ = ((n + 1 : ℕ) : ℝ) ^ s.re := by
    rw [← hcast]; exact norm_cpow_eq_rpow_re_of_pos hpos s
  have hnum : ‖z ^ (n + 1)‖ = ‖z‖ ^ (n + 1) := by rw [norm_pow]
  -- On the ball: |Re(s) − Re(s₀)| ≤ ‖s − s₀‖ < 1, so Re(s) > Re(s₀) − 1.
  have hball : ‖s - s₀‖ < 1 := by
    rwa [Metric.mem_ball, dist_eq_norm] at hs
  have hRe_gt : s₀.re - 1 < s.re := by
    have hsub : |(s - s₀).re| ≤ ‖s - s₀‖ := Complex.abs_re_le_norm _
    have : (s - s₀).re = s.re - s₀.re := by simp
    rw [this] at hsub
    have : |s.re - s₀.re| < 1 := lt_of_le_of_lt hsub hball
    have := abs_lt.mp this
    linarith [this.1]
  have hk_ge : (1 : ℝ) - s₀.re ≤ (k : ℝ) := by
    have h1 : max (0 : ℝ) (1 - s₀.re) ≤ (k : ℝ) := by
      rw [hk_def]; exact_mod_cast Nat.le_ceil _
    linarith [le_max_right (0 : ℝ) (1 - s₀.re)]
  -- Goal becomes: ‖z‖^(n+1) / (n+1)^Re(s) ≤ ‖z‖^(n+1) · (n+1)^k.
  rw [norm_div, hden_norm, hnum]
  have hden_pos : 0 < ((n + 1 : ℕ) : ℝ) ^ s.re := Real.rpow_pos_of_pos hpos _
  rw [div_le_iff₀ hden_pos]
  -- It suffices to show (n+1)^Re(s) · (n+1)^k ≥ 1.
  -- Equivalent: (n+1)^(Re(s) + k) ≥ 1. Since (n+1) ≥ 1 and Re(s) + k ≥ Re(s) + (1 - Re(s₀)) > 0
  -- (because Re(s) > Re(s₀) - 1).
  have hsum_nonneg : 0 ≤ s.re + (k : ℝ) := by linarith
  have hrpow_ge_one :
      (1 : ℝ) ≤ ((n + 1 : ℕ) : ℝ) ^ (s.re + (k : ℝ)) :=
    Real.one_le_rpow hone_le hsum_nonneg
  calc ‖z‖ ^ (n + 1)
      = ‖z‖ ^ (n + 1) * 1 := by ring
    _ ≤ ‖z‖ ^ (n + 1) * ((n + 1 : ℕ) : ℝ) ^ (s.re + (k : ℝ)) :=
          mul_le_mul_of_nonneg_left hrpow_ge_one (by positivity)
    _ = ‖z‖ ^ (n + 1)
            * (((n + 1 : ℕ) : ℝ) ^ s.re * ((n + 1 : ℕ) : ℝ) ^ (k : ℝ)) := by
          rw [Real.rpow_add hpos]
    _ = ‖z‖ ^ (n + 1) * ((n + 1 : ℕ) : ℝ) ^ (k : ℝ)
            * ((n + 1 : ℕ) : ℝ) ^ s.re := by ring

/-- **Summability of the dominator** on `Metric.ball s₀ 1`. -/
theorem contractionPolylog_dominator_summable
    {z : ℂ} (hz : ‖z‖ < 1) (s₀ : ℂ) :
    Summable (fun n : ℕ =>
      ‖z‖ ^ (n + 1)
        * ((n + 1 : ℕ) : ℝ) ^ (⌈max (0 : ℝ) (1 - s₀.re)⌉₊ : ℝ)) := by
  set k : ℕ := ⌈max (0 : ℝ) (1 - s₀.re)⌉₊
  have hz_norm : ‖(‖z‖ : ℝ)‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg (norm_nonneg _)]
    exact hz
  have hpow : Summable (fun n : ℕ => (n : ℝ) ^ k * ‖z‖ ^ n) :=
    summable_pow_mul_geometric_of_norm_lt_one k hz_norm
  have hshift :
      Summable (fun n : ℕ => ((n + 1 : ℕ) : ℝ) ^ k * ‖z‖ ^ (n + 1)) :=
    (summable_nat_add_iff
      (f := fun n : ℕ => (n : ℝ) ^ k * ‖z‖ ^ n) 1).mpr hpow
  refine hshift.congr ?_
  intro n
  rw [Real.rpow_natCast]
  ring

/-- **Contraction Polylog is entire in `s` (for `‖z‖ < 1`).**

For any `z ∈ ℂ` with `‖z‖ < 1` and any `s₀ ∈ ℂ`,
`s ↦ contractionPolylog z s` is analytic at `s₀`.

Proof: locally-uniform convergence of differentiable functions on the
open ball `B(s₀, 1)`. Each per-term function is entire; the per-term
norms are dominated by a summable function on the ball; Mathlib's
`differentiableOn_tsum_of_summable_norm` gives `DifferentiableOn` of
the tsum on the ball, and `DifferentiableOn.analyticAt` gives
`AnalyticAt` at `s₀`. -/
theorem contractionPolylog_analyticAt
    {z : ℂ} (hz : ‖z‖ < 1) (s₀ : ℂ) :
    AnalyticAt ℂ (fun s : ℂ => contractionPolylog z s) s₀ := by
  set U : Set ℂ := Metric.ball s₀ 1
  have hU : IsOpen U := Metric.isOpen_ball
  have hs₀ : s₀ ∈ U := Metric.mem_ball_self one_pos
  have hdiff_on : DifferentiableOn ℂ
      (fun s : ℂ => contractionPolylog z s) U := by
    unfold contractionPolylog
    refine differentiableOn_tsum_of_summable_norm
      (u := fun n : ℕ =>
        ‖z‖ ^ (n + 1)
          * ((n + 1 : ℕ) : ℝ) ^ (⌈max (0 : ℝ) (1 - s₀.re)⌉₊ : ℝ))
      (contractionPolylog_dominator_summable hz s₀) ?_ hU ?_
    · intro n
      exact (contractionPolylog_term_differentiable z n).differentiableOn
    · intro n s hs
      exact contractionPolylog_term_norm_le_on_ball s₀ s hs n
  exact hdiff_on.analyticAt (hU.mem_nhds hs₀)

/-- **Generic Dirichlet trace series is entire.**

For any `SpectralContractionPair S` and any `s₀ ∈ ℂ`,
`s ↦ S.traceDirichlet s` is analytic at `s₀`. This is the flagship
"Generic Entire Dirichlet" theorem: the trace Dirichlet series of a
spectral contraction system is entire, in stark contrast to the
classical Riemann zeta which has a pole at `s = 1`. -/
theorem SpectralContractionPair.traceDirichlet_analyticAt
    (S : SpectralContractionPair) (s₀ : ℂ) :
    AnalyticAt ℂ (fun s : ℂ => S.traceDirichlet s) s₀ := by
  have hstar : ‖star S.lam‖ < 1 := by rw [S.norm_star_lam]; exact S.hlam
  have hsplit : (fun s : ℂ => S.traceDirichlet s)
              = (fun s : ℂ =>
                  contractionPolylog S.lam s
                    + contractionPolylog (star S.lam) s) := by
    funext s
    exact S.traceDirichlet_eq_contractionPolylog_add s
  rw [hsplit]
  exact (contractionPolylog_analyticAt S.hlam s₀).add
         (contractionPolylog_analyticAt hstar s₀)

/-- **Golden Dirichlet trace series is entire.**

The Golden specialization of `SpectralContractionPair.traceDirichlet_analyticAt`.
`D_G(s)` is analytic at every `s₀ ∈ ℂ` — i.e., `D_G` is entire. -/
theorem goldenTraceDirichlet_analyticAt (s₀ : ℂ) :
    AnalyticAt ℂ (fun s : ℂ => goldenTraceDirichlet s) s₀ := by
  have h := goldenSpectralPair.traceDirichlet_analyticAt s₀
  have hcongr : (fun s : ℂ => goldenTraceDirichlet s)
              = (fun s : ℂ => goldenSpectralPair.traceDirichlet s) := by
    funext s
    unfold goldenTraceDirichlet SpectralContractionPair.traceDirichlet
    congr 1
    funext n
    rw [goldenTraceC_eq_spectralPair_traceC]
  rw [hcongr]
  exact h

/-- **Generic entireness on all of `ℂ`** (AnalyticOnNhd form). -/
theorem SpectralContractionPair.traceDirichlet_analyticOnNhd
    (S : SpectralContractionPair) :
    AnalyticOnNhd ℂ (fun s : ℂ => S.traceDirichlet s) Set.univ :=
  fun s₀ _ => S.traceDirichlet_analyticAt s₀

/-- **Golden entireness on all of `ℂ`** (AnalyticOnNhd form). -/
theorem goldenTraceDirichlet_analyticOnNhd :
    AnalyticOnNhd ℂ (fun s : ℂ => goldenTraceDirichlet s) Set.univ :=
  fun s₀ _ => goldenTraceDirichlet_analyticAt s₀

/-! ## Tier 15 Status Summary

Tier 15 lands the **Entire Dirichlet Extension** theorem family.

* **`contractionPolylog`** (def) — finite-disk polylogarithm
  `Σ z^(n+1) / (n+1)^s` for `‖z‖ < 1`.
* **`contractionPolylog_summable`** — converges for every `s ∈ ℂ`.
* **`contractionPolylog_analyticAt`** — entire in `s` for `‖z‖ < 1`.
* **`SpectralContractionPair.traceDirichlet_eq_contractionPolylog_add`**
  — spectral split `D_S = contractionPolylog λ + contractionPolylog λ̄`.
* **`SpectralContractionPair.traceDirichlet_analyticAt`** — **`D_S` is
  entire** (flagship, generic).
* **`goldenTraceDirichlet_analyticAt`** — **`D_G` is entire** (Golden
  corollary).
* **`SpectralContractionPair.traceDirichlet_analyticOnNhd`** and
  **`goldenTraceDirichlet_analyticOnNhd`** — `AnalyticOnNhd ℂ _ univ`
  forms.

The entireness of `D_S` (and `D_G`) is the *sharpest possible*
analytic statement about the trace Dirichlet series of a spectral
contraction system: no poles anywhere in the complex plane. This is
the strongest available contrast with the classical Riemann zeta. -/

-- =====================================================================
-- === Tier 14 — Information-Theory Engine: Golden Entropy =============
-- =====================================================================
-- Closed form for the entropy of the geometric distribution `pₙ = (1−r)·rⁿ`:
--   `H(p) = −log(1 − r) − (r / (1 − r)) · log r`.
-- Imports the central information-theoretic invariant of the Golden
-- contraction parameter.

/-- The **geometric distribution weights**: `pₙ = (1 − r) · rⁿ`. -/
noncomputable def geometricWeight (r : ℝ) (n : ℕ) : ℝ :=
  (1 - r) * r ^ n

/-- Each geometric weight is positive when `0 < r < 1`. -/
theorem geometricWeight_pos
    {r : ℝ} (hr0 : 0 < r) (hr1 : r < 1) (n : ℕ) :
    0 < geometricWeight r n := by
  unfold geometricWeight
  have h_pos : 0 < 1 - r := by linarith
  exact mul_pos h_pos (pow_pos hr0 n)

/-- Each geometric weight is non-negative when `0 ≤ r < 1`. -/
theorem geometricWeight_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) (n : ℕ) :
    0 ≤ geometricWeight r n := by
  unfold geometricWeight
  have h_nonneg : 0 ≤ 1 - r := by linarith
  exact mul_nonneg h_nonneg (pow_nonneg hr0 n)

/-- The geometric distribution sums to 1: `Σ (1 − r) · rⁿ = 1`. -/
theorem geometricWeight_tsum_eq_one
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) :
    (∑' n : ℕ, geometricWeight r n) = 1 := by
  unfold geometricWeight
  rw [tsum_mul_left]
  rw [tsum_geometric_of_lt_one hr0 hr1]
  have h_ne : (1 : ℝ) - r ≠ 0 := by linarith
  field_simp

/-- Mean of the geometric distribution: `Σ n · pₙ = r / (1 − r)`. -/
theorem geometricWeight_mean
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) :
    (∑' n : ℕ, (n : ℝ) * geometricWeight r n) = r / (1 - r) := by
  unfold geometricWeight
  exact nat_geometric_mean_tsum hr0 hr1

/-- **Log decomposition** of the geometric weights.
For `0 < r < 1`: `log((1 − r) · rⁿ) = log(1 − r) + n · log r`. -/
theorem log_geometricWeight
    {r : ℝ} (hr0 : 0 < r) (hr1 : r < 1) (n : ℕ) :
    Real.log (geometricWeight r n) = Real.log (1 - r) + n * Real.log r := by
  unfold geometricWeight
  have h_one_sub_pos : 0 < 1 - r := by linarith
  rw [Real.log_mul h_one_sub_pos.ne' (pow_pos hr0 n).ne', Real.log_pow]

/-- The geometric entropy series: `H(p) = Σ −pₙ · log pₙ`. -/
noncomputable def geometricEntropySeries (r : ℝ) : ℝ :=
  ∑' n : ℕ, - geometricWeight r n * Real.log (geometricWeight r n)

/-- The closed-form geometric entropy. -/
noncomputable def geometricEntropyClosedForm (r : ℝ) : ℝ :=
  - Real.log (1 - r) - (r / (1 - r)) * Real.log r

/-- **Closed form of the geometric entropy.**
For `0 < r < 1`:
  `H(p) = −log(1 − r) − (r / (1 − r)) · log r`.
Proof uses the log decomposition plus the two HasSums
`Σ pₙ = 1` and `Σ n · pₙ = r/(1 − r)` to split the entropy. -/
theorem geometric_entropy_closed_form
    {r : ℝ} (hr0 : 0 < r) (hr1 : r < 1) :
    geometricEntropySeries r = geometricEntropyClosedForm r := by
  unfold geometricEntropySeries geometricEntropyClosedForm
  have h0 : 0 ≤ r := le_of_lt hr0
  have h_one_sub_ne : (1 : ℝ) - r ≠ 0 := by linarith
  -- HasSum (n => (1−r) rⁿ) 1
  have h_unit : HasSum (fun n : ℕ => (1 - r) * r ^ n) 1 := by
    have hgeom := hasSum_geometric_of_lt_one h0 hr1
    have hmul := hgeom.mul_left (1 - r)
    rw [show (1 - r) * (1 - r)⁻¹ = 1 from by field_simp] at hmul
    exact hmul
  -- HasSum (n => n · (1−r) rⁿ) (r/(1−r))
  have h_mean : HasSum
      (fun n : ℕ => (n : ℝ) * ((1 - r) * r ^ n)) (r / (1 - r)) :=
    nat_geometric_mean_hasSum h0 hr1
  -- Two scaled HasSums.
  have h1 : HasSum (fun n : ℕ => Real.log (1 - r) * ((1 - r) * r ^ n))
      (Real.log (1 - r) * 1) :=
    h_unit.mul_left (Real.log (1 - r))
  have h2 : HasSum
      (fun n : ℕ => Real.log r * ((n : ℝ) * ((1 - r) * r ^ n)))
      (Real.log r * (r / (1 - r))) :=
    h_mean.mul_left (Real.log r)
  have h_sum := h1.add h2
  -- Align summand with the entropy summand via log_geometricWeight.
  have h_align : ∀ n : ℕ,
      - geometricWeight r n * Real.log (geometricWeight r n)
        = - (Real.log (1 - r) * ((1 - r) * r ^ n)
            + Real.log r * ((n : ℝ) * ((1 - r) * r ^ n))) := by
    intro n
    rw [log_geometricWeight hr0 hr1]
    unfold geometricWeight
    ring
  have h_entropy : HasSum
      (fun n : ℕ => - geometricWeight r n * Real.log (geometricWeight r n))
      (- (Real.log (1 - r) * 1 + Real.log r * (r / (1 - r)))) := by
    refine (h_sum.neg).congr_fun ?_
    intro n
    rw [h_align]
  rw [h_entropy.tsum_eq]
  ring

/-- **Golden entropy closed form.**
The entropy of the Golden geometric distribution `goldenWeight n` equals
  `−log(1 − ‖λ‖) − (‖λ‖ / (1 − ‖λ‖)) · log ‖λ‖`.
Direct specialization of `geometric_entropy_closed_form` at `r = ‖λ‖`. -/
theorem goldenWeight_entropy_closed_form :
    (∑' n : ℕ, - goldenWeight n * Real.log (goldenWeight n))
      = - Real.log (1 - ‖lambdaG1‖)
          - (‖lambdaG1‖ / (1 - ‖lambdaG1‖)) * Real.log ‖lambdaG1‖ := by
  have hpos : 0 < ‖lambdaG1‖ := norm_pos_iff.mpr lambdaG1_ne_zero
  have h := geometric_entropy_closed_form hpos norm_lambdaG1_lt_one
  unfold geometricEntropySeries geometricEntropyClosedForm at h
  exact h

-- =====================================================================
-- === Tier 15 — Generic Spectral Entropy ==============================
-- =====================================================================
-- Attach the Tier 14 entropy theorem to every `SpectralContractionPair`
-- by setting `r = ‖S.lam‖`. Every contraction pair now carries a
-- canonical probability distribution and information invariant.

/-- **The generic spectral weights**:
  `weight S n = (1 − ‖S.lam‖) · ‖S.lam‖ⁿ`. -/
noncomputable def SpectralContractionPair.weight
    (S : SpectralContractionPair) (n : ℕ) : ℝ :=
  (1 - ‖S.lam‖) * ‖S.lam‖ ^ n

/-- Each spectral weight is non-negative. -/
theorem SpectralContractionPair.weight_nonneg
    (S : SpectralContractionPair) (n : ℕ) :
    0 ≤ S.weight n := by
  unfold SpectralContractionPair.weight
  have h1 : (0 : ℝ) ≤ 1 - ‖S.lam‖ := by linarith [S.hlam]
  positivity

/-- The spectral weights sum to 1. -/
theorem SpectralContractionPair.weight_tsum_eq_one
    (S : SpectralContractionPair) :
    ∑' n : ℕ, S.weight n = 1 := by
  unfold SpectralContractionPair.weight
  exact geometricWeight_tsum_eq_one (norm_nonneg _) S.hlam

/-- Mean of the spectral distribution: `Σ n · weight n = ‖λ‖ / (1 − ‖λ‖)`. -/
theorem SpectralContractionPair.weight_mean
    (S : SpectralContractionPair) :
    ∑' n : ℕ, (n : ℝ) * S.weight n = ‖S.lam‖ / (1 - ‖S.lam‖) := by
  unfold SpectralContractionPair.weight
  exact geometricWeight_mean (norm_nonneg _) S.hlam

/-- **Generic spectral entropy closed form.**
For any spectral contraction pair `S` with `S.lam ≠ 0`:
  `H(S) = −log(1 − ‖λ‖) − (‖λ‖ / (1 − ‖λ‖)) · log ‖λ‖`. -/
theorem SpectralContractionPair.entropy_closed_form
    (S : SpectralContractionPair) (hS0 : S.lam ≠ 0) :
    (∑' n : ℕ, - S.weight n * Real.log (S.weight n))
      = - Real.log (1 - ‖S.lam‖)
          - (‖S.lam‖ / (1 - ‖S.lam‖)) * Real.log ‖S.lam‖ := by
  have hpos : 0 < ‖S.lam‖ := norm_pos_iff.mpr hS0
  have h := geometric_entropy_closed_form hpos S.hlam
  unfold geometricEntropySeries geometricEntropyClosedForm at h
  exact h

-- =====================================================================
-- === Tier 16 — Toeplitz Kernel: RKHS Construction Stage 1 ===========
-- =====================================================================
-- `K(m, n) = r^|m−n|` is the canonical PSD covariance kernel for a
-- contraction parameter `r`. Land algebraic structure + foundational
-- 2-point positivity.

/-- **The Toeplitz kernel** `K(m, n) = r^|m − n|`. -/
noncomputable def toeplitzKernel (r : ℝ) (m n : ℕ) : ℝ :=
  r ^ Int.natAbs ((m : ℤ) - (n : ℤ))

/-- The Toeplitz kernel is symmetric: `K(m, n) = K(n, m)`. -/
theorem toeplitzKernel_symm (r : ℝ) (m n : ℕ) :
    toeplitzKernel r m n = toeplitzKernel r n m := by
  unfold toeplitzKernel
  congr 1
  rw [show ((m : ℤ) - (n : ℤ)) = -((n : ℤ) - (m : ℤ)) from by ring]
  exact Int.natAbs_neg _

/-- The Toeplitz diagonal: `K(n, n) = 1`. -/
theorem toeplitzKernel_diag (r : ℝ) (n : ℕ) :
    toeplitzKernel r n n = 1 := by
  unfold toeplitzKernel
  simp

/-- The Toeplitz kernel is non-negative for `0 ≤ r`. -/
theorem toeplitzKernel_nonneg {r : ℝ} (hr : 0 ≤ r) (m n : ℕ) :
    0 ≤ toeplitzKernel r m n := by
  unfold toeplitzKernel
  exact pow_nonneg hr _

/-- **Two-point positive semi-definiteness.**
For `0 ≤ r ≤ 1`:
  `0 ≤ a² + 2·r·a·b + b²`.

The Gram matrix `[[1, r], [r, 1]]` is PSD. Proof via the identity
`a² + 2r·a·b + b² = (1−r)(a² + b²) + r(a+b)²` — the first true RKHS
kernel positivity result for the Toeplitz family. -/
theorem toeplitzKernel_two_point_psd
    {r a b : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) :
    0 ≤ a ^ 2 + 2 * r * a * b + b ^ 2 := by
  have h_identity : a ^ 2 + 2 * r * a * b + b ^ 2
      = (1 - r) * (a ^ 2 + b ^ 2) + r * (a + b) ^ 2 := by ring
  rw [h_identity]
  have h1 : (0 : ℝ) ≤ 1 - r := by linarith
  have ha : 0 ≤ (1 - r) * (a ^ 2 + b ^ 2) :=
    mul_nonneg h1 (by positivity)
  have hb : 0 ≤ r * (a + b) ^ 2 := mul_nonneg hr0 (sq_nonneg _)
  linarith

/-- **The spectral Toeplitz kernel**: a canonical covariance kernel
attached to each spectral contraction pair `S`, with `r = ‖S.lam‖`. -/
noncomputable def SpectralContractionPair.toeplitzKernel
    (S : SpectralContractionPair) (m n : ℕ) : ℝ :=
  ‖S.lam‖ ^ Int.natAbs ((m : ℤ) - (n : ℤ))

/-- The spectral Toeplitz kernel is symmetric. -/
theorem SpectralContractionPair.toeplitzKernel_symm
    (S : SpectralContractionPair) (m n : ℕ) :
    S.toeplitzKernel m n = S.toeplitzKernel n m :=
  GoldenAlgebra.toeplitzKernel_symm ‖S.lam‖ m n

/-- The spectral Toeplitz diagonal is 1. -/
theorem SpectralContractionPair.toeplitzKernel_diag
    (S : SpectralContractionPair) (n : ℕ) :
    S.toeplitzKernel n n = 1 :=
  GoldenAlgebra.toeplitzKernel_diag ‖S.lam‖ n

/-- The spectral Toeplitz kernel is non-negative. -/
theorem SpectralContractionPair.toeplitzKernel_nonneg
    (S : SpectralContractionPair) (m n : ℕ) :
    0 ≤ S.toeplitzKernel m n :=
  GoldenAlgebra.toeplitzKernel_nonneg (norm_nonneg _) m n

/-- Two-point PSD for the spectral Toeplitz kernel. -/
theorem SpectralContractionPair.toeplitzKernel_two_point_psd
    (S : SpectralContractionPair) (a b : ℝ) :
    0 ≤ a ^ 2 + 2 * ‖S.lam‖ * a * b + b ^ 2 :=
  GoldenAlgebra.toeplitzKernel_two_point_psd (norm_nonneg _) (le_of_lt S.hlam)

-- =====================================================================
-- === Tier 17 — Three-point Toeplitz PSD =============================
-- =====================================================================
-- Extend the Tier 16 two-point PSD to the 3×3 Toeplitz Gram matrix
--   `[[1, r, r²], [r, 1, r], [r², r, 1]]`.
-- Cholesky decomposition:
--   `(1−r²)(a²+c²) + (b + r(a+c))² = a²+b²+c² + 2rab + 2rbc + 2r²ac`.

/-- **Three-point Toeplitz PSD.**
For `0 ≤ r ≤ 1` and any reals `a, b, c`:
  `0 ≤ a² + b² + c² + 2·r·a·b + 2·r·b·c + 2·r²·a·c`.

Equivalent to the 3×3 Toeplitz Gram matrix being positive
semi-definite. Proof via the Cholesky decomposition
`(1−r²)(a²+c²) + (b+r(a+c))²` — the first finite-(>2) RKHS positivity
result for the Toeplitz family. -/
theorem toeplitzKernel_three_point_psd
    {r a b c : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2
          + 2 * r * a * b + 2 * r * b * c + 2 * r ^ 2 * a * c := by
  have h_identity : a ^ 2 + b ^ 2 + c ^ 2
        + 2 * r * a * b + 2 * r * b * c + 2 * r ^ 2 * a * c
      = (1 - r ^ 2) * (a ^ 2 + c ^ 2) + (b + r * (a + c)) ^ 2 := by ring
  rw [h_identity]
  have h_one_sub_sq : 0 ≤ 1 - r ^ 2 := by
    nlinarith [sq_nonneg (1 - r), hr0, hr1]
  have ha : 0 ≤ (1 - r ^ 2) * (a ^ 2 + c ^ 2) :=
    mul_nonneg h_one_sub_sq (by positivity)
  have hb : 0 ≤ (b + r * (a + c)) ^ 2 := sq_nonneg _
  linarith

/-- Three-point PSD specialized at a spectral contraction pair. -/
theorem SpectralContractionPair.toeplitzKernel_three_point_psd
    (S : SpectralContractionPair) (a b c : ℝ) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2
          + 2 * ‖S.lam‖ * a * b + 2 * ‖S.lam‖ * b * c
          + 2 * ‖S.lam‖ ^ 2 * a * c :=
  GoldenAlgebra.toeplitzKernel_three_point_psd (norm_nonneg _)
    (le_of_lt S.hlam)

-- =====================================================================
-- === Tier 18 — Poisson Kernel: Harmonic Analysis Bridge =============
-- =====================================================================
-- Import the Poisson kernel and its positivity. Connects the
-- Toeplitz/contraction denominator `1 − 2r cos θ + r²` to harmonic
-- analysis on the unit disk.

/-- **The Poisson kernel** for the unit disk:
  `P_r(θ) = (1 − r²) / (1 − 2r·cos θ + r²)`. -/
noncomputable def poissonKernel (r θ : ℝ) : ℝ :=
  (1 - r ^ 2) / (1 - 2 * r * Real.cos θ + r ^ 2)

/-- **Positivity of the Poisson denominator.**
For `0 ≤ r < 1`:
  `0 < 1 − 2r·cos θ + r²`.
The real form of `|1 − r·e^{iθ}|² > 0`. -/
theorem poissonKernel_denom_pos
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) (θ : ℝ) :
    0 < 1 - 2 * r * Real.cos θ + r ^ 2 := by
  have h_cos_le : Real.cos θ ≤ 1 := Real.cos_le_one θ
  have h_one_sub_r_sq : 0 < (1 - r) ^ 2 :=
    pow_pos (by linarith : 0 < 1 - r) 2
  nlinarith [h_one_sub_r_sq, h_cos_le, hr0, sq_nonneg r]

/-- **Non-negativity of the Poisson kernel** for `0 ≤ r < 1`. -/
theorem poissonKernel_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) (θ : ℝ) :
    0 ≤ poissonKernel r θ := by
  unfold poissonKernel
  have h_denom_pos : 0 < 1 - 2 * r * Real.cos θ + r ^ 2 :=
    poissonKernel_denom_pos hr0 hr1 θ
  have h_num : 0 ≤ 1 - r ^ 2 := by nlinarith [hr0, hr1, sq_nonneg r]
  exact div_nonneg h_num h_denom_pos.le

/-- **The spectral Poisson kernel**: attach the Poisson kernel to each
spectral contraction pair `S`, with `r = ‖S.lam‖`. -/
noncomputable def SpectralContractionPair.poissonKernel
    (S : SpectralContractionPair) (θ : ℝ) : ℝ :=
  GoldenAlgebra.poissonKernel ‖S.lam‖ θ

/-- The spectral Poisson kernel is non-negative. -/
theorem SpectralContractionPair.poissonKernel_nonneg
    (S : SpectralContractionPair) (θ : ℝ) :
    0 ≤ S.poissonKernel θ :=
  GoldenAlgebra.poissonKernel_nonneg (norm_nonneg _) S.hlam θ

-- =====================================================================
-- === Tier 16 — Diamond Zero-Rigidity Transfer ========================
-- =====================================================================
/-!
## Tier 16 — Diamond Zero-Rigidity Transfer

The Diamond push: build a finite-to-infinite zero-rigidity scaffold
where RH-type real-zero conclusions follow from
**spectral positivity + determinant convergence**.

Discipline: this tier does **not** claim to prove RH. It identifies the
exact missing object — a *Hermitian determinant approximation* to a
xi-like entire function with locally uniform convergence — and proves
that the existence of such an approximation, together with the abstract
Hurwitz zero-transfer principle, implies the real-zero conclusion.

The structure of the Diamond chain:

  `Hermitian matrices A_N  →  charDet(A_N) entire with real zeros only
   →  charDet(A_N) → Xi locally uniformly  (Hypothesis)
   →  by Hurwitz: zeros of Xi all real
   →  via critical-line ↔ real pullback, RH-type conclusion.`

Components:
* `CriticalLine`, `HasOnlyCriticalLineZeros`, `HasOnlyRealZeros`,
  `criticalPullback` — coordinate framework.
* `criticalLineZeros_iff_realZeros_pullback` — exact equivalence.
* `HurwitzZeroTransferPrinciple` — abstract Hurwitz statement
  (conditional bridge; Mathlib v4.20.1 lacks Hurwitz/Rouché directly).
* `charDet` — characteristic determinant `z ↦ det(zI − A)`.
* `charDet_isHermitian_hasOnlyRealZeros` — **unconditional**: Hermitian
  matrix has real-zeroed charDet.
* `HermitianDeterminantApproximation` — the missing-object structure.
* `diamond_HP_limit_principle` — the Diamond flagship: HP approximation +
  Hurwitz ⇒ real zeros.
* `RiemannXiModel`, `diamond_RH_from_Xi_HP_approximation` — capstone
  reduction of RH-type statements to constructing an HP approximation.
-/

-- --- Tier 16.1 — Coordinate framework -----------------------------------

/-- **The critical line** `Re(s) = 1/2` as a closed subset of `ℂ`. -/
noncomputable def CriticalLine : Set ℂ := {s : ℂ | s.re = (1 / 2 : ℝ)}

/-- The critical line is closed in `ℂ`. -/
theorem CriticalLine_isClosed : IsClosed CriticalLine := by
  unfold CriticalLine
  exact isClosed_eq Complex.continuous_re continuous_const

/-- **Critical-line pullback** of an entire function via the change of
variables `s ↦ 1/2 + i·t`. Sends critical-line zeros of `F` to real
zeros of `criticalPullback F`. -/
noncomputable def criticalPullback (F : ℂ → ℂ) : ℂ → ℂ :=
  fun t : ℂ => F ((1 / 2 : ℂ) + Complex.I * t)

/-- **`F` has only critical-line zeros**: every zero `s` of `F`
satisfies `Re(s) = 1/2`. -/
def HasOnlyCriticalLineZeros (F : ℂ → ℂ) : Prop :=
  ∀ s : ℂ, F s = 0 → s ∈ CriticalLine

/-- **`f` has only real zeros**: every zero `z` of `f` satisfies
`Im(z) = 0`. -/
def HasOnlyRealZeros (f : ℂ → ℂ) : Prop :=
  ∀ z : ℂ, f z = 0 → z.im = 0

/-- **Pullback equivalence** between critical-line zeros and real zeros.

For any `F : ℂ → ℂ`, `F` has only critical-line zeros iff
`criticalPullback F` has only real zeros. -/
theorem criticalLineZeros_iff_realZeros_pullback (F : ℂ → ℂ) :
    HasOnlyCriticalLineZeros F ↔ HasOnlyRealZeros (criticalPullback F) := by
  constructor
  · intro h t ht
    -- ht : F ((1/2 : ℂ) + I * t) = 0 ⇒ Re((1/2 : ℂ) + I * t) = 1/2 ⇒ t.im = 0.
    have hs : F ((1 / 2 : ℂ) + Complex.I * t) = 0 := ht
    have := h _ hs
    -- this : Re ((1/2 : ℂ) + I * t) = 1/2
    have hre : ((1 / 2 : ℂ) + Complex.I * t).re = (1 / 2 : ℝ) := this
    have hreI : (Complex.I * t).re = -t.im := by
      simp [Complex.mul_re]
    have h12 : ((1 / 2 : ℂ)).re = (1 / 2 : ℝ) := by simp
    have : (1 / 2 : ℝ) + -t.im = (1 / 2 : ℝ) := by
      have := hre
      rw [Complex.add_re, h12, hreI] at this
      exact this
    linarith
  · intro h s hs
    -- For any s : ℂ, write s = 1/2 + I * t with t := -I * (s - 1/2).
    -- Then F s = F ((1/2) + I * t) = (criticalPullback F) t.
    set t : ℂ := -Complex.I * (s - 1 / 2) with ht_def
    have hs_eq : (1 / 2 : ℂ) + Complex.I * t = s := by
      rw [ht_def]
      have hI2 : Complex.I ^ 2 = -1 := Complex.I_sq
      have : Complex.I * (-Complex.I * (s - 1 / 2)) = s - 1 / 2 := by
        have : Complex.I * (-Complex.I * (s - 1 / 2))
            = -(Complex.I ^ 2) * (s - 1 / 2) := by ring
        rw [this, hI2]; ring
      rw [this]; ring
    have hf : criticalPullback F t = 0 := by
      unfold criticalPullback
      rw [hs_eq]; exact hs
    have htim : t.im = 0 := h t hf
    -- Then Re(s) = Re(1/2 + I*t) = 1/2 + (-t.im) = 1/2.
    have : s.re = (1 / 2 : ℝ) := by
      rw [← hs_eq, Complex.add_re]
      have h12 : ((1 / 2 : ℂ)).re = (1 / 2 : ℝ) := by simp
      have hreI : (Complex.I * t).re = -t.im := by simp [Complex.mul_re]
      rw [h12, hreI, htim]; ring
    exact this

-- --- Tier 16.2 — Hurwitz zero-transfer principle --------------------

/-- **Abstract Hurwitz zero-transfer principle.**

If `F_N : ℂ → ℂ` are entire with all zeros in a closed set `L`, and
`F_N → f` locally uniformly with `f ≢ 0`, then every zero of `f`
also lies in `L`.

This is the abstract complex-analysis statement underlying Hurwitz's
theorem. Mathlib v4.20.1 does not provide it directly: the building
blocks (Rouché's theorem, argument principle for analytic functions
under uniform convergence) are not yet ported to a form that gives
zero-transfer in this generality.

We expose this principle as a `Prop`-conditional hypothesis. Each
Diamond flagship takes `HurwitzZeroTransferPrinciple` as an explicit
hypothesis, isolating the missing Mathlib component. -/
def HurwitzZeroTransferPrinciple : Prop :=
  ∀ {F : ℕ → ℂ → ℂ} {f : ℂ → ℂ} {L : Set ℂ},
    IsClosed L →
    (∀ N, AnalyticOnNhd ℂ (F N) Set.univ) →
    AnalyticOnNhd ℂ f Set.univ →
    TendstoLocallyUniformly F f Filter.atTop →
    (∀ N z, F N z = 0 → z ∈ L) →
    f ≠ 0 →
    ∀ z : ℂ, f z = 0 → z ∈ L

-- --- Tier 16.3 — Characteristic determinant `charDet` ---------------

/-- **Characteristic determinant** of a matrix: `charDet A z := det(zI − A)`.
Zeros of `charDet A` are precisely the eigenvalues of `A`. -/
noncomputable def charDet {n : Type*} [Fintype n] [DecidableEq n]
    (A : Matrix n n ℂ) (z : ℂ) : ℂ :=
  (z • (1 : Matrix n n ℂ) - A).det

/-- **Hermitian matrices have real eigenvalues.**

For a Hermitian matrix `A` over `ℂ`, `charDet A` has only real zeros:
if `(z • 1 - A).det = 0`, then `z = (eigenvalues i : ℂ)` for some `i`,
which is real (`.im = 0`).

The proof uses Mathlib's `Matrix.IsHermitian.spectral_theorem`:
`A = U · diag(λ₁,...,λₙ) · U*` with `λᵢ ∈ ℝ` and `U` unitary, hence
`det(zI − A) = det(zI − D) = ∏ᵢ(z − λᵢ)`. This is **unconditional**;
no Hurwitz needed for the finite case. -/
theorem charDet_isHermitian_hasOnlyRealZeros
    {n : Type*} [Fintype n] [DecidableEq n]
    {A : Matrix n n ℂ} (hA : A.IsHermitian) :
    HasOnlyRealZeros (charDet A) := by
  intro z hz
  unfold charDet at hz
  set U : Matrix n n ℂ := (hA.eigenvectorUnitary : Matrix n n ℂ) with hU_def
  set D : Matrix n n ℂ := diagonal (RCLike.ofReal ∘ hA.eigenvalues) with hD_def
  have hUstar : U * star U = 1 :=
    (Matrix.mem_unitaryGroup_iff).mp (hA.eigenvectorUnitary).2
  have hstarU : star U * U = 1 :=
    (Matrix.mem_unitaryGroup_iff').mp (hA.eigenvectorUnitary).2
  have hspec : A = U * D * star U := hA.spectral_theorem
  -- Substitute the spectral decomposition.
  have hsub : z • (1 : Matrix n n ℂ) - A = U * (z • (1 : Matrix n n ℂ) - D) * star U := by
    rw [hspec, Matrix.mul_sub, Matrix.sub_mul]
    congr 1
    · -- U * (z • 1) * star U = z • (U * star U) = z • 1
      rw [Matrix.mul_smul, Matrix.smul_mul]
      rw [Matrix.mul_one, hUstar]
  rw [hsub] at hz
  -- det(U * (z•1 - D) * star U) = det U * det(z•1 - D) * det(star U)
  -- and det U * det(star U) = det(U * star U) = det 1 = 1.
  have hdet_mul : (U * (z • (1 : Matrix n n ℂ) - D) * star U).det
      = (z • (1 : Matrix n n ℂ) - D).det := by
    rw [Matrix.det_mul, Matrix.det_mul]
    have hone : U.det * (star U).det = 1 := by
      rw [← Matrix.det_mul, hUstar, Matrix.det_one]
    ring_nf
    rw [show U.det * (z • (1 : Matrix n n ℂ) - D).det * (star U).det
        = (z • (1 : Matrix n n ℂ) - D).det * (U.det * (star U).det) from by ring]
    rw [hone, mul_one]
  rw [hdet_mul] at hz
  -- z • 1 - D = diagonal (fun i => z - ofReal (eigenvalues i))
  have hdiag : z • (1 : Matrix n n ℂ) - D
      = diagonal (fun i : n => z - (hA.eigenvalues i : ℂ)) := by
    rw [hD_def]
    ext i j
    by_cases h : i = j
    · subst h
      simp [Matrix.smul_apply, Matrix.one_apply_eq, Matrix.sub_apply,
        Matrix.diagonal_apply_eq]
    · simp [Matrix.smul_apply, Matrix.one_apply_ne h, Matrix.sub_apply,
        Matrix.diagonal_apply_ne _ h]
  rw [hdiag, Matrix.det_diagonal] at hz
  -- Some factor (z - eigenvalues i) is zero ⇒ z = (eigenvalues i : ℂ), real.
  rw [Finset.prod_eq_zero_iff] at hz
  obtain ⟨i, _, hi⟩ := hz
  have hz_eq : z = (hA.eigenvalues i : ℂ) := by linear_combination hi
  rw [hz_eq]
  simp

-- --- Tier 16.4 — Hermitian Determinant Approximation ----------------

/-- **Hermitian Determinant Approximation** of a function `Xi : ℂ → ℂ`.

A sequence of finite-dimensional Hermitian matrices whose characteristic
determinants converge locally uniformly to `Xi`. This is the missing
object in the Diamond reduction of RH: producing such an approximation
for the completed Riemann zeta `Ξ` would close the Hilbert–Pólya gap. -/
structure HermitianDeterminantApproximation (Xi : ℂ → ℂ) where
  /-- Dimension of the `N`-th approximant. -/
  dim : ℕ → ℕ
  /-- The `N`-th Hermitian matrix. -/
  matrix : ∀ N : ℕ, Matrix (Fin (dim N)) (Fin (dim N)) ℂ
  /-- Each matrix is Hermitian. -/
  isHermitian : ∀ N : ℕ, (matrix N).IsHermitian
  /-- The characteristic determinants converge locally uniformly to `Xi`. -/
  approx : TendstoLocallyUniformly
    (fun N : ℕ => fun z : ℂ => charDet (matrix N) z) Xi Filter.atTop
  /-- `Xi` is not identically zero (otherwise the conclusion is vacuous). -/
  nonzero : Xi ≠ 0
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- Each `charDet` approximant is entire. -/
  approx_entire : ∀ N : ℕ, AnalyticOnNhd ℂ (fun z : ℂ => charDet (matrix N) z) Set.univ

-- --- Tier 16.5 — Diamond HP Limit Principle -------------------------

/-- **Diamond Hilbert–Pólya Limit Principle.**

If `Xi` admits a Hermitian determinant approximation and the abstract
Hurwitz zero-transfer principle holds, then `Xi` has only real zeros.

This is the **Diamond flagship**: it reduces the RH-type real-zero
conclusion to the existence of a Hermitian determinant approximation
to `Xi`. The Hurwitz principle is an explicit hypothesis (Mathlib gap)
and the existence of the approximation is an explicit open object.

The flagship demonstrates that *spectral positivity + determinant
convergence ⇒ critical-line zeros*. -/
theorem diamond_HP_limit_principle
    {Xi : ℂ → ℂ}
    (h : HermitianDeterminantApproximation Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyRealZeros Xi := by
  -- L := the real axis (closed in ℂ).
  set L : Set ℂ := {z : ℂ | z.im = 0} with hL_def
  have hL_closed : IsClosed L :=
    isClosed_eq Complex.continuous_im continuous_const
  -- Each approximant has zeros in L (by Hermitian charDet ⇒ real zeros).
  have happrox_zeros : ∀ N : ℕ, ∀ z : ℂ, charDet (h.matrix N) z = 0 → z ∈ L := by
    intro N z hz
    exact charDet_isHermitian_hasOnlyRealZeros (h.isHermitian N) z hz
  -- Apply the Hurwitz transfer principle.
  intro z hz
  exact hHurwitz hL_closed h.approx_entire h.entire h.approx
    happrox_zeros h.nonzero z hz

-- --- Tier 16.6 — Riemann Xi Model and Conditional Capstone ----------

/-- **Riemann Xi Model**: an abstract placeholder for the completed
Riemann zeta function `Ξ(t) = ξ(1/2 + it)`.

The properties capture the essential symmetries:
* `entire` — `Ξ` is entire on `ℂ`.
* `even` — `Ξ(−t) = Ξ(t)` (the functional equation collapsed via the
  critical-line coordinate).
* `realOnReal` — `Ξ(t) ∈ ℝ` for `t ∈ ℝ`.

These are facts about the *real* completed zeta function; we abstract
them as a structure so the Diamond reduction is purely formal. -/
structure RiemannXiModel where
  /-- The Xi function. -/
  Xi : ℂ → ℂ
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- `Xi` is even: `Xi(-t) = Xi(t)`. -/
  even : ∀ t : ℂ, Xi (-t) = Xi t
  /-- `Xi` is real on the real axis. -/
  realOnReal : ∀ t : ℝ, (Xi t).im = 0

/-- **The Riemann Hypothesis for an abstract Xi model.**

`Xi` has only real zeros. (Equivalently, the underlying ξ has only
critical-line zeros via the `criticalPullback` equivalence.) -/
def RHForXiModel (M : RiemannXiModel) : Prop :=
  HasOnlyRealZeros M.Xi

/-- **Diamond reduction of RH to HP approximation.**

If a `RiemannXiModel` admits a Hermitian determinant approximation and
the abstract Hurwitz zero-transfer principle holds, then RH holds for
that model.

This is the **Diamond capstone**: it identifies the two missing
objects (an HP approximation to `Ξ`, and the Hurwitz transfer principle)
that together would discharge the real-zero / critical-line conclusion.
Neither object is conjectural in the file: each is a clean, explicit
mathematical target. -/
theorem diamond_RH_from_Xi_HP_approximation
    (M : RiemannXiModel)
    (H : HermitianDeterminantApproximation M.Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    RHForXiModel M :=
  diamond_HP_limit_principle H hHurwitz

/-- **Critical-line corollary** of the Diamond capstone.

If `Xi := criticalPullback ξ` admits an HP approximation and Hurwitz
holds, then `ξ` has only critical-line zeros. This is the *critical
line* formulation of RH-type conclusions. -/
theorem diamond_critical_line_from_Xi_HP_approximation
    (xi : ℂ → ℂ)
    (M : RiemannXiModel)
    (hPullback : M.Xi = criticalPullback xi)
    (H : HermitianDeterminantApproximation M.Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyCriticalLineZeros xi := by
  have hreal : HasOnlyRealZeros M.Xi :=
    diamond_HP_limit_principle H hHurwitz
  rw [hPullback] at hreal
  exact (criticalLineZeros_iff_realZeros_pullback xi).mpr hreal

