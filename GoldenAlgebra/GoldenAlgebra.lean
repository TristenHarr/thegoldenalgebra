    extends HadamardTraceCoherentZetaSource where
  eulerTraceCompatibility : EulerLogDerivativeCompatibility

/-- Bridge: Euler-trace coherent source ⟹ critical-line. -/
theorem EulerTraceCoherentZetaSource_implies_zeta_critical_line
    (S : EulerTraceCoherentZetaSource) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  HadamardTraceCoherentZetaSource_implies_zeta_critical_line
    S.toHadamardTraceCoherentZetaSource

-- Step 130: explicit formula as equality of two log-derivatives.

/--
The *explicit formula* as the equality of:
1. the log-derivative of the Hadamard product over zeros (spectral side);
2. the log-derivative of the Euler product over primes (arithmetic side).
-/
structure ExplicitFormulaDerivativeEquality (Eigen : ℝ → Prop) where
  spectralDerivativeSide : Prop
  arithmeticDerivativeSide : Prop
  equalityOfSides : Prop
  testFunctionRegularization : Prop

/-- A source carrying the explicit-formula derivative equality. -/
structure ExplicitFormulaCoherentZetaSource
    extends EulerTraceCoherentZetaSource where
  explicitDerivativeEquality :
    ExplicitFormulaDerivativeEquality Eigen

/-- Bridge: explicit-formula coherent source ⟹ critical-line. -/
theorem ExplicitFormulaCoherentZetaSource_implies_zeta_critical_line
    (S : ExplicitFormulaCoherentZetaSource) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  EulerTraceCoherentZetaSource_implies_zeta_critical_line
    S.toEulerTraceCoherentZetaSource

-- Step 131: prime-deformed cotangent kernel.

/--
A *prime-deformed cotangent kernel*: a trace kernel whose pole expansion
is spectral (cotangent-like) but whose arithmetic expansion is von
Mangoldt. The framework's deepest current intuition in one object.
-/
structure PrimeDeformedCotangentKernel (Eigen : ℝ → Prop) where
  kernel : ℂ → ℂ
  cotangentLikePoleExpansion : CotangentTraceKernelLaw Eigen kernel
  vonMangoldtArithmeticExpansion : kernel = mirrorVonMangoldtResponse
  explicitFormulaCompatibility : Prop

/-- A source whose trace kernel is a prime-deformed cotangent. -/
structure PrimeCotangentZetaSource
    extends ExplicitFormulaCoherentZetaSource where
  primeCotangent : PrimeDeformedCotangentKernel Eigen

/-- Bridge: prime-cotangent zeta source ⟹ critical-line. -/
theorem PrimeCotangentZetaSource_implies_zeta_critical_line
    (S : PrimeCotangentZetaSource) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ExplicitFormulaCoherentZetaSource_implies_zeta_critical_line
    S.toExplicitFormulaCoherentZetaSource

-- Step 132: trace-kernel defect sieve.

/-- A kernel has the wrong counting if no Riemann-von Mangoldt witness
exists. -/
def KernelHasWrongCounting (Eigen : ℝ → Prop) : Prop :=
  ¬ Nonempty (SpectrumRiemannVonMangoldtCountingLaw Eigen)

/-- A kernel is not prime-deformed if no prime-deformed cotangent kernel
exists for the spectrum. -/
def KernelNotPrimeDeformed (Eigen : ℝ → Prop) : Prop :=
  ¬ Nonempty (PrimeDeformedCotangentKernel Eigen)

/-- Rejection: no prime-deformed kernel ⟹ no prime-cotangent source. -/
theorem no_primeCotangentSource_of_not_primeDeformed
    {Eigen : ℝ → Prop} (h : KernelNotPrimeDeformed Eigen) :
    ¬ ∃ S : PrimeCotangentZetaSource, S.Eigen = Eigen := by
  intro hS
  rcases hS with ⟨S, hSE⟩
  exact h ⟨hSE ▸ S.primeCotangent⟩

-- === Necessity Edges + Coverage Completeness (Steps 133-137) ===
-- Moving from "carries many invariants" to "invariants FORCE each
-- other" (necessity edges), and to the meta-theorem: every surviving
-- candidate must lie in the ultra-refined hot cover.

-- Step 133: necessity edges — invariants force one another.

/-- A *necessity edge*: law `A` forces law `B`. Stronger than merely
storing both as fields. -/
structure NecessityEdge (A B : Prop) where
  force : A → B

/-- Hadamard product law forces residue/multiplicity behavior. -/
def HadamardForcesResidues (detZ : ℂ → ℂ) (Eigen : ℝ → Prop) : Prop :=
  Nonempty (HadamardProductSieveLaw detZ Eigen) →
    ∃ traceZ : ℂ → ℂ, Nonempty (LogDerivativeResidueLaw Eigen traceZ)

/-- Euler product law forces the von Mangoldt log-derivative side. -/
def EulerForcesVonMangoldtTrace : Prop :=
  ∀ _E : EulerProductReconstruction,
    Nonempty VonMangoldtTraceReconstruction

/-- Theta/Poisson/Mellin law forces the completed functional equation. -/
def ThetaPoissonForcesFunctionalEquation : Prop :=
  ∀ _T : ThetaPoissonMellinLaw, Nonempty CompletedZetaDeterminant

/--
A source whose invariants are connected by necessity edges: the
invariants force one another, they are not independent decorations.
-/
structure NecessityGraphZetaSource
    extends PrimeCotangentZetaSource where
  hadamardForcesResidues :
    HadamardForcesResidues mirrorXiLikeDeterminant Eigen
  eulerForcesVonMangoldt : EulerForcesVonMangoldtTrace
  thetaPoissonForcesFunctionalEquation :
    ThetaPoissonForcesFunctionalEquation

/-- Bridge: necessity-graph zeta source ⟹ critical-line. -/
theorem NecessityGraphZetaSource_implies_zeta_critical_line
    (S : NecessityGraphZetaSource) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  PrimeCotangentZetaSource_implies_zeta_critical_line
    S.toPrimeCotangentZetaSource

-- Step 134: candidate-world coverage completeness.

/-- A family of classes is *complete* for a search space if it covers
it. -/
def CompleteCandidateCover
    (Search : OperatorCandidateWorld → Prop)
    (Classes : List (OperatorCandidateWorld → Prop)) : Prop :=
  CoversByList OperatorCandidateWorld Search Classes

/-- A search space is *cold-or-ultrahot complete* if every candidate is
covered by a cold class or an ultra-refined hot class. -/
def ColdOrUltraHotComplete
    (Search : OperatorCandidateWorld → Prop) : Prop :=
  CoversByList OperatorCandidateWorld Search
    (ColdWorldCover ++ UltraRefinedHotWorldCover)

/-- The conclusion target: every surviving candidate lies in the
ultra-refined hot cover. -/
def SurvivorLiesInUltraHotCover
    (Search Constraint : OperatorCandidateWorld → Prop) : Prop :=
  ∀ W : OperatorCandidateWorld,
    Search W → Constraint W →
      ∃ C ∈ UltraRefinedHotWorldCover, C W

-- Step 135: trace-kernel defect classes.

/-- Cold: world with no log-derivative residue law. -/
def WrongResidueTraceWorld (W : OperatorCandidateWorld) : Prop :=
  ¬ Nonempty (LogDerivativeResidueLaw W.Eigen W.response)

/-- Constraint: world with a residue law. -/
def ResidueCompatibleWorld (W : OperatorCandidateWorld) : Prop :=
  Nonempty (LogDerivativeResidueLaw W.Eigen W.response)

/-- Cold: world with no argument-principle counting law. -/
def WrongArgumentCountingWorld (W : OperatorCandidateWorld) : Prop :=
  ¬ Nonempty (ArgumentPrincipleCountingLaw W.determinant W.Eigen)

/-- Constraint: world with an argument-principle counting law. -/
def ArgumentCompatibleWorld (W : OperatorCandidateWorld) : Prop :=
  Nonempty (ArgumentPrincipleCountingLaw W.determinant W.Eigen)

/-- Cold: world with no Hadamard-product reconstruction. -/
def WrongHadamardWorld (W : OperatorCandidateWorld) : Prop :=
  ¬ Nonempty (HadamardProductSieveLaw W.determinant W.Eigen)

/-- Constraint: world with a Hadamard-product reconstruction. -/
def HadamardCompatibleWorld (W : OperatorCandidateWorld) : Prop :=
  Nonempty (HadamardProductSieveLaw W.determinant W.Eigen)

-- Step 136: class-level rejections for the defect classes.

/-- Wrong-residue worlds are rejected by residue compatibility. -/
theorem wrongResidueTrace_rejected :
    ClassRejectedBy OperatorCandidateWorld
      WrongResidueTraceWorld ResidueCompatibleWorld := by
  intro W hwrong hgood
  exact hwrong hgood

/-- Wrong-argument-counting worlds are rejected by argument
compatibility. -/
theorem wrongArgumentCounting_rejected :
    ClassRejectedBy OperatorCandidateWorld
      WrongArgumentCountingWorld ArgumentCompatibleWorld := by
  intro W hwrong hgood
  exact hwrong hgood

/-- Wrong-Hadamard worlds are rejected by Hadamard compatibility. -/
theorem wrongHadamard_rejected :
    ClassRejectedBy OperatorCandidateWorld
      WrongHadamardWorld HadamardCompatibleWorld := by
  intro W hwrong hgood
  exact hwrong hgood

-- Step 137: the survivor-in-ultra-hot-cover classification theorem.

/--
**Step 137 — the "must-fit" classification theorem.**

If a search space is covered by the cold classes plus the ultra-refined
hot classes, and every cold class is rejected by the constraint, then
every surviving candidate (in the search space and satisfying the
constraint) must lie in one of the ultra-refined hot worlds.

This is the formal version of "hotter/colder becomes a theorem": any
serious survivor is forced into the ultra-refined hot cover.
-/
theorem survivorLiesInUltraHotCover
    {Search Constraint : OperatorCandidateWorld → Prop}
    (hcover : ColdOrUltraHotComplete Search)
    (hcold : AllClassesRejectedBy OperatorCandidateWorld
              ColdWorldCover Constraint) :
    SurvivorLiesInUltraHotCover Search Constraint := by
  intro W hSearch hConstraint
  rcases hcover W hSearch with ⟨C, hCmem, hCW⟩
  rcases List.mem_append.mp hCmem with hCold | hUltra
  · exact absurd hConstraint (hcold C hCold W hCW)
  · exact ⟨C, hUltra, hCW⟩

-- === Construction Programs Toward the Zeta Operator (Steps 138-140) ===
-- Three concrete research routes. Each program structure carries a
-- `producedSource` field — the actual constructive obligation — so the
-- RH bridge follows immediately, and the difficulty is honestly
-- isolated in *producing* the source.

/--
**Arithmetic-first program.** Build the zeta operator from Dirichlet
convolution, Möbius inversion, and the von Mangoldt trace; the produced
object is a `PrimeCotangentZetaSource`.
-/
structure DirichletHilbertConstructionProgram where
  hilbertSpace : Prop
  dirichletConvolutionRepresentation : Prop
  hilbertStarStructure : Prop
  mobiusInverseOperator : Prop
  vonMangoldtTraceOperator : Prop
  regularizedDeterminantEqualsZeta : Prop
  producedSource : PrimeCotangentZetaSource

/--
**Geometry-first program.** Build the zeta operator from a positive
square operator whose heat trace, after Mellin transform and
theta/Poisson symmetry, reconstructs completed zeta; the produced
object is a `GeometricAnalyticZetaOperatorSource`.
-/
structure MellinThetaHeatConstructionProgram where
  positiveSelfAdjointSquareOperator : Prop
  heatTrace : Prop
  thetaPoissonSymmetry : Prop
  mellinTransformEqualsCompletedZeta : Prop
  producedSource : GeometricAnalyticZetaOperatorSource

/--
**Real-zero-first program.** Use de Branges / Hermite-Biehler /
canonical-system structure to force real zeros of the mirror
determinant; the produced object is a proof of `MirrorRHStatement`.
-/
structure DeBrangesConstructionProgram where
  hermiteBiehlerFunction : Prop
  deBrangesSpace : Prop
  mirrorXiInDeBrangesStructure : Prop
  mirrorRH : MirrorRHStatement

/-- Bridge: a completed arithmetic-first program implies the
critical-line statement. -/
theorem DirichletHilbertConstructionProgram_implies_zeta_critical_line
    (P : DirichletHilbertConstructionProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  PrimeCotangentZetaSource_implies_zeta_critical_line P.producedSource

/-- Bridge: a completed geometry-first program implies the
critical-line statement. -/
theorem MellinThetaHeatConstructionProgram_implies_zeta_critical_line
    (P : MellinThetaHeatConstructionProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  GeometricAnalyticZetaOperatorSource_implies_zeta_critical_line
    P.producedSource

/-- Bridge: a completed real-zero-first program implies the
critical-line statement. -/
theorem DeBrangesConstructionProgram_implies_zeta_critical_line
    (P : DeBrangesConstructionProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  MirrorRH_implies_zeta_critical_line P.mirrorRH

-- Step 139: program no-go targets and consequences.

/-- No arithmetic-first construction program exists. -/
def NoDirichletHilbertConstruction : Prop :=
  ¬ Nonempty DirichletHilbertConstructionProgram

/-- No geometry-first construction program exists. -/
def NoMellinThetaHeatConstruction : Prop :=
  ¬ Nonempty MellinThetaHeatConstructionProgram

/-- No real-zero-first construction program exists. -/
def NoDeBrangesConstruction : Prop :=
  ¬ Nonempty DeBrangesConstructionProgram

/-- If no prime-cotangent source exists, the arithmetic-first program
cannot be completed. -/
theorem no_dirichletHilbertProgram_of_no_primeCotangentSource
    (h : ¬ Nonempty PrimeCotangentZetaSource) :
    NoDirichletHilbertConstruction := by
  intro hP
  exact h ⟨hP.some.producedSource⟩

/-- If no geometric-analytic source exists, the geometry-first program
cannot be completed. -/
theorem no_mellinThetaHeatProgram_of_no_geometricAnalyticSource
    (h : ¬ Nonempty GeometricAnalyticZetaOperatorSource) :
    NoMellinThetaHeatConstruction := by
  intro hP
  exact h ⟨hP.some.producedSource⟩

/-- If the mirror-coordinate RH statement fails, the real-zero-first
program cannot be completed. -/
theorem no_deBrangesProgram_of_no_mirrorRH
    (h : ¬ MirrorRHStatement) :
    NoDeBrangesConstruction := by
  intro hP
  exact h hP.some.mirrorRH

-- Step 140: program comparison / intersection.

/-- Two produced spectra are *eigen-compatible* if they coincide. -/
def ProgramsEigenCompatible (S₁ S₂ : ℝ → Prop) : Prop :=
  S₁ = S₂

/--
The arithmetic-first and geometry-first programs *agree* if their
produced sources have the same candidate eigenvalue predicate. The real
zeta operator should sit at this intersection.
-/
structure GoldProgramAgreement
    (D : DirichletHilbertConstructionProgram)
    (M : MellinThetaHeatConstructionProgram) where
  eigenAgreement :
    ProgramsEigenCompatible
      D.producedSource.Eigen M.producedSource.Eigen

/-- Program agreement is symmetric in the produced spectra. -/
theorem GoldProgramAgreement.eigen_symm
    {D : DirichletHilbertConstructionProgram}
    {M : MellinThetaHeatConstructionProgram}
    (A : GoldProgramAgreement D M) :
    ProgramsEigenCompatible
      M.producedSource.Eigen D.producedSource.Eigen :=
  A.eigenAgreement.symm

-- === The Common Core Zeta Operator (Steps 141-147) ===
-- The three construction programs should not each carry a black-box
-- `producedSource`. They should all factor through ONE common object —
-- the intersection of arithmetic, geometric, and entire-function
-- routes.

-- Step 141: the abstract core.

/--
**`ZetaOperatorCore`** — the common object sought by all construction
programs. The non-circular object at the intersection of
Dirichlet-Hilbert arithmetic, Mellin-theta-heat geometry, and de
Branges / real-zero theory. Exposes the shared operator faces.
-/
structure ZetaOperatorCore where
  Eigen : ℝ → Prop
  arithmeticFace : Prop
  geometricFace : Prop
  entireFunctionFace : Prop
  determinantFace : Prop
  traceFace : Prop
  selfAdjointFace : Prop
  localGlobalFace : Prop
  producesPrimeCotangentSource : PrimeCotangentZetaSource

/-- Bridge: a constructed core zeta operator implies the critical-line
statement. -/
theorem ZetaOperatorCore_implies_zeta_critical_line
    (Z : ZetaOperatorCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  PrimeCotangentZetaSource_implies_zeta_critical_line
    Z.producesPrimeCotangentSource

-- Step 142: core versions of the three programs.

/-- Arithmetic-first program factoring through the common core. -/
structure DirichletHilbertCoreProgram
    extends DirichletHilbertConstructionProgram where
  core : ZetaOperatorCore
  core_Eigen_agrees : core.Eigen = producedSource.Eigen

/-- Geometry-first program factoring through the common core. -/
structure MellinThetaHeatCoreProgram
    extends MellinThetaHeatConstructionProgram where
  core : ZetaOperatorCore
  core_Eigen_agrees : core.Eigen = producedSource.Eigen

/-- Real-zero-first program factoring through the common core. -/
structure DeBrangesCoreProgram
    extends DeBrangesConstructionProgram where
  core : ZetaOperatorCore

/-- Bridge: arithmetic-first core program ⟹ critical-line. -/
theorem DirichletHilbertCoreProgram_implies_zeta_critical_line
    (P : DirichletHilbertCoreProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ZetaOperatorCore_implies_zeta_critical_line P.core

/-- Bridge: geometry-first core program ⟹ critical-line. -/
theorem MellinThetaHeatCoreProgram_implies_zeta_critical_line
    (P : MellinThetaHeatCoreProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ZetaOperatorCore_implies_zeta_critical_line P.core

/-- Bridge: real-zero-first core program ⟹ critical-line. -/
theorem DeBrangesCoreProgram_implies_zeta_critical_line
    (P : DeBrangesCoreProgram) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ZetaOperatorCore_implies_zeta_critical_line P.core

-- Step 143: three-way core agreement.

/--
The three gold programs *agree* when they factor through the same core
zeta operator. The real operator sits at this triple intersection.
-/
structure ThreeWayGoldAgreement where
  dirichletProgram : DirichletHilbertCoreProgram
  mellinProgram : MellinThetaHeatCoreProgram
  deBrangesProgram : DeBrangesCoreProgram
  sameCore_DM : dirichletProgram.core = mellinProgram.core
  sameCore_DBr : dirichletProgram.core = deBrangesProgram.core

/-- **Three-way agreement ⟹ critical-line.** RH follows if the
arithmetic, geometric, and real-zero constructions meet at one core. -/
theorem ThreeWayGoldAgreement_implies_zeta_critical_line
    (G : ThreeWayGoldAgreement) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ZetaOperatorCore_implies_zeta_critical_line G.dirichletProgram.core

-- Step 144: structured arithmetic core.

/--
Structured arithmetic face: Dirichlet convolution reconstruction, von
Mangoldt trace, and Euler↔log-derivative compatibility.
-/
structure ZetaArithmeticCore where
  dirichletReconstruction : DirichletConvolutionReconstruction
  vonMangoldtTrace : VonMangoldtTraceReconstruction
  eulerTraceCompatibility : EulerLogDerivativeCompatibility

-- Step 145: structured geometric core.

/--
Structured geometric face: heat trace, Mellin/Fourier integral
transform, and theta/Poisson symmetry.
-/
structure ZetaGeometricCore (Eigen : ℝ → Prop) where
  heatTraceLaw : HeatTraceSieveLaw Eigen
  integralTransform : IntegralTransformReconstructionLaw
  thetaPoisson : ThetaPoissonMellinLaw

-- Step 146: structured entire-function core.

/--
Structured entire-function face: de Branges sieve law, Hadamard
product, and mirror functional equation on the mirror determinant.
-/
structure ZetaEntireCore (Eigen : ℝ → Prop) where
  deBrangesLaw : DeBrangesSieveLaw mirrorXiLikeDeterminant
  hadamardProduct :
    HadamardProductSieveLaw mirrorXiLikeDeterminant Eigen
  mirrorFunctionalEquation : MirrorFunctionalEquationSieveLaw

-- Step 147: the structured core, replacing the Prop faces.

/--
**`StructuredZetaOperatorCore`** — `ZetaOperatorCore` with the three
abstract `Prop` faces replaced by structured data (`ZetaArithmeticCore`,
`ZetaGeometricCore`, `ZetaEntireCore`). The remaining faces stay `Prop`
pending further refinement. This is the constructible-object form of
the target.
-/
structure StructuredZetaOperatorCore where
  Eigen : ℝ → Prop
  arithmeticCore : ZetaArithmeticCore
  geometricCore : ZetaGeometricCore Eigen
  entireCore : ZetaEntireCore Eigen
  determinantFace : Prop
  traceFace : Prop
  selfAdjointFace : Prop
  localGlobalFace : Prop
  producesPrimeCotangentSource : PrimeCotangentZetaSource

/-- Bridge: a structured core zeta operator implies the critical-line
statement. -/
theorem StructuredZetaOperatorCore_implies_zeta_critical_line
    (Z : StructuredZetaOperatorCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  PrimeCotangentZetaSource_implies_zeta_critical_line
    Z.producesPrimeCotangentSource

/--
A structured core forgets down to an abstract `ZetaOperatorCore` (the
structured faces witness the abstract `Prop` faces via `Nonempty`).
-/
def StructuredZetaOperatorCore.toZetaOperatorCore
    (Z : StructuredZetaOperatorCore) : ZetaOperatorCore where
  Eigen := Z.Eigen
  arithmeticFace := Nonempty ZetaArithmeticCore
  geometricFace := Nonempty (ZetaGeometricCore Z.Eigen)
  entireFunctionFace := Nonempty (ZetaEntireCore Z.Eigen)
  determinantFace := Z.determinantFace
  traceFace := Z.traceFace
  selfAdjointFace := Z.selfAdjointFace
  localGlobalFace := Z.localGlobalFace
  producesPrimeCotangentSource := Z.producesPrimeCotangentSource

-- === Canonical Theta/Mellin Geometric Core (Steps 148-151) ===
-- Replace the geometric face with the classical Riemann route:
--   theta function → Poisson symmetry → Mellin transform
--     → completed zeta → functional equation.
-- Then force the arithmetic and entire-function faces to produce the
-- SAME completed determinant.

-- Step 148: the theta kernel and its Mellin reconstruction.

/--
A *theta kernel* for reconstructing completed zeta — the geometric
heat-trace face of the zeta operator.
-/
structure ThetaKernelCore where
  theta : ℝ → ℂ
  positiveTimeDomain : Prop
  poissonSymmetry : Prop
  decayAtInfinity : Prop
  smallTimeTransformLaw : Prop

/--
The Mellin-transform reconstruction of completed zeta from a theta
kernel — the classical Riemann route: theta/Poisson symmetry plus
Mellin transform yields completed zeta and its functional equation.
-/
structure ThetaMellinZetaReconstruction where
  kernel : ThetaKernelCore
  mellinIntegral : ℂ → ℂ
  mellinEqualsCompletedZeta : Prop
  functionalEquationFromPoisson : Prop
  archimedeanGammaFactorProduced : Prop

/--
A geometric core whose heat-trace / transform faces are produced by a
theta kernel via Mellin reconstruction.
-/
structure CanonicalThetaMellinGeometricCore (Eigen : ℝ → Prop)
    extends ZetaGeometricCore Eigen where
  thetaMellin : ThetaMellinZetaReconstruction

/--
A structured zeta core whose geometric face is explicitly theta/Mellin.
-/
structure ThetaMellinStructuredZetaOperatorCore
    extends StructuredZetaOperatorCore where
  canonicalThetaGeometry : CanonicalThetaMellinGeometricCore Eigen

/-- Bridge: theta/Mellin structured core ⟹ critical-line. -/
theorem ThetaMellinStructuredZetaOperatorCore_implies_zeta_critical_line
    (Z : ThetaMellinStructuredZetaOperatorCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  StructuredZetaOperatorCore_implies_zeta_critical_line
    Z.toStructuredZetaOperatorCore

-- Step 149: arithmetic face must match the geometric (theta) face.

/--
The arithmetic and geometric faces reconstruct the *same* completed
determinant: Euler product side = theta/Mellin side, with matching
gamma / archimedean factors.
-/
structure ArithmeticGeometryCompatibility
    (Eigen : ℝ → Prop)
    (A : ZetaArithmeticCore)
    (G : CanonicalThetaMellinGeometricCore Eigen) where
  sameCompletedZeta : Prop
  eulerProductMatchesMellinTransform : Prop
  gammaFactorMatchesArchimedeanCompletion : Prop

/-- A theta/Mellin structured core whose arithmetic and geometric faces
agree. -/
structure ArithmeticGeometricThetaCore
    extends ThetaMellinStructuredZetaOperatorCore where
  arithmeticGeometryCompatibility :
    ArithmeticGeometryCompatibility Eigen
      arithmeticCore canonicalThetaGeometry

/-- Bridge: arithmetic-geometric theta core ⟹ critical-line. -/
theorem ArithmeticGeometricThetaCore_implies_zeta_critical_line
    (Z : ArithmeticGeometricThetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ThetaMellinStructuredZetaOperatorCore_implies_zeta_critical_line
    Z.toThetaMellinStructuredZetaOperatorCore

-- Step 150: entire/de Branges face must match the geometric face.

/--
The theta/Mellin determinant and the de Branges / Hadamard determinant
are the same completed determinant.
-/
structure GeometryEntireCompatibility
    (Eigen : ℝ → Prop)
    (G : CanonicalThetaMellinGeometricCore Eigen)
    (E : ZetaEntireCore Eigen) where
  mellinDetEqualsHadamardDet : Prop
  thetaFunctionalEquationEqualsMirrorEvenness : Prop
  deBrangesFunctionIsCompletedDeterminant : Prop

-- Step 151: the fully compatible theta core.

/--
**`FullyCompatibleThetaCore`** — a structured zeta core where the
arithmetic (Euler), geometric (theta/Mellin), and entire-function
(de Branges/Hadamard) faces all reconstruct ONE completed determinant.
The credible next research target.
-/
structure FullyCompatibleThetaCore
    extends ArithmeticGeometricThetaCore where
  geometryEntireCompatibility :
    GeometryEntireCompatibility Eigen
      canonicalThetaGeometry entireCore

/-- Bridge: fully-compatible theta core ⟹ critical-line. -/
theorem FullyCompatibleThetaCore_implies_zeta_critical_line
    (Z : FullyCompatibleThetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  ArithmeticGeometricThetaCore_implies_zeta_critical_line
    Z.toArithmeticGeometricThetaCore

-- === Explicit Operator Construction (Steps 152-156) ===
-- The real frontier: the theta kernel becomes the heat trace of an
-- explicit positive operator `A`. Then `A = H²`, `H` self-adjoint, the
-- mirror determinant factors as `det(z² − A)`, and the zeros are real
-- because `H` is self-adjoint. The operator stops being a silhouette.

-- Step 152: heat-trace realization of the theta kernel.

/--
A positive operator candidate whose heat trace realizes the theta
kernel: `theta(t) = Tr(exp(−t A))` for positive self-adjoint `A`. The
first genuinely operator-facing realization of the geometric side.
-/
structure HeatTraceThetaRealization where
  Operator : Type
  positiveSelfAdjointSquareLaw : Prop
  heatSemigroup : ℝ → Type
  heatTrace : ℝ → ℂ
  heatTrace_eq_theta : Prop
  heatTraceRegularity : Prop

/-- A fully-compatible theta core whose theta kernel is realized as a
heat trace. -/
structure HeatRealizedThetaCore
    extends FullyCompatibleThetaCore where
  heatRealization : HeatTraceThetaRealization

/-- Bridge: heat-realized theta core ⟹ critical-line. -/
theorem HeatRealizedThetaCore_implies_zeta_critical_line
    (Z : HeatRealizedThetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  FullyCompatibleThetaCore_implies_zeta_critical_line
    Z.toFullyCompatibleThetaCore

-- Step 153: spectral zeta of the positive square operator.

/--
Spectral-zeta reconstruction from a heat trace: the operator-theoretic
Mellin transform `Γ(s) ζ_A(s) = ∫₀^∞ t^{s−1} Tr(e^{−tA}) dt`. The
completed zeta becomes the *spectral zeta* of a positive operator.
-/
structure SpectralZetaFromHeatTrace where
  heatRealization : HeatTraceThetaRealization
  spectralZeta : ℂ → ℂ
  mellinHeatTraceFormula : Prop
  spectralZetaEqualsCompletedZeta : Prop
  determinantFromSpectralZeta : Prop

/-- A heat-realized theta core with a spectral-zeta reconstruction. -/
structure SpectralZetaHeatCore
    extends HeatRealizedThetaCore where
  spectralZetaFromHeat : SpectralZetaFromHeatTrace

/-- Bridge: spectral-zeta heat core ⟹ critical-line. -/
theorem SpectralZetaHeatCore_implies_zeta_critical_line
    (Z : SpectralZetaHeatCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  HeatRealizedThetaCore_implies_zeta_critical_line
    Z.toHeatRealizedThetaCore

-- Step 154: the spectral square root — the Hilbert-Pólya operator.

/--
A *spectral square-root* realization: `A = H²` with `H` self-adjoint.
The paired spectrum of `H` explains mirror parity; the determinant
factors as `det(z² − A)`; the zeros are real because `H` is
self-adjoint.
-/
structure SpectralSquareRootRealization where
  heatRealization : HeatTraceThetaRealization
  H : Type
  selfAdjointH : Prop
  squareLaw : Prop
  spectrumAgreement : Prop
  determinantSquareLaw : Prop

/-- A spectral-zeta heat core with an explicit self-adjoint square
root. -/
structure SquareRootHeatZetaCore
    extends SpectralZetaHeatCore where
  squareRoot : SpectralSquareRootRealization

/-- Bridge: square-root heat zeta core ⟹ critical-line. -/
theorem SquareRootHeatZetaCore_implies_zeta_critical_line
    (Z : SquareRootHeatZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  SpectralZetaHeatCore_implies_zeta_critical_line
    Z.toSpectralZetaHeatCore

-- Step 155: the explicit operator construction problem.

/--
**The explicit zeta-operator construction problem.** Construct the
positive square operator, its heat trace realizing the theta kernel,
its spectral zeta equal to completed zeta, and the self-adjoint square
root. This is the first target that is genuinely a *construction*, not
a specification.
-/
def ExplicitZetaOperatorConstructionProblem : Prop :=
  Nonempty SquareRootHeatZetaCore

/-- **Main theorem of the explicit-construction layer.** Solving the
explicit zeta-operator construction problem implies the critical-line
statement. -/
theorem ExplicitZetaOperatorConstructionProblem_implies_zeta_critical_line
    (h : ExplicitZetaOperatorConstructionProblem) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ := by
  rcases h with ⟨Z⟩
  exact SquareRootHeatZetaCore_implies_zeta_critical_line Z

-- Step 156: plain lattice heat-trace no-go.

/--
A *plain lattice heat world*: heat trace is the classical theta/lattice
heat trace with ordinary lattice (power-law) spectral counting.
Riemann's theta gives the functional equation, but the ordinary lattice
heat operator is NOT the Hilbert–Pólya operator.
-/
def PlainLatticeHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty (SpectrumPowerLawCounting W.Eigen)

/-- Plain lattice heat worlds are rejected by the counting sieve: the
operator must be a *prime-deformed* heat operator, not the ordinary
lattice Laplacian. -/
theorem plainLatticeHeatWorld_rejected_by_counting
    (hno : PowerLawCountingNoGoTarget) :
    ClassRejectedBy OperatorCandidateWorld
      PlainLatticeHeatWorld
      (fun W => Nonempty (CountingSpectralSieveLaws W.Eigen)) := by
  intro W hW hcount
  exact no_countingSieve_of_powerLaw_noGo hno hW.2 hcount

-- === Prime-Deformed Heat Operator (Steps 157-160) ===
-- The plain lattice heat operator is cold (Step 156). The corrected
-- replacement must still give theta/Mellin geometry, but its trace must
-- carry von Mangoldt prime-power deformation and Riemann-von Mangoldt
-- density. This is where the operator must "hear primes."

-- Step 157: the prime-deformed heat operator.

/--
A *prime-deformed heat operator* — the corrected replacement for the
plain lattice Laplacian. Still produces theta/Mellin/completed-zeta
geometry, but its trace also carries von Mangoldt deformation and
Riemann-von Mangoldt density.
-/
structure PrimeDeformedHeatOperator where
  Operator : Type
  positiveSelfAdjointSquareLaw : Prop
  heatSemigroup : ℝ → Type
  heatTrace : ℝ → ℂ
  thetaHeatTraceLaw : Prop
  vonMangoldtTraceDeformation : Prop
  riemannVonMangoldtDensityLaw : Prop
  determinantEqualsMirrorXi : Prop

/-- A square-root heat zeta core whose heat operator is prime-deformed. -/
structure PrimeDeformedHeatZetaCore
    extends SquareRootHeatZetaCore where
  primeDeformedHeatOperator : PrimeDeformedHeatOperator

/-- Bridge: prime-deformed heat zeta core ⟹ critical-line. -/
theorem PrimeDeformedHeatZetaCore_implies_zeta_critical_line
    (Z : PrimeDeformedHeatZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  SquareRootHeatZetaCore_implies_zeta_critical_line
    Z.toSquareRootHeatZetaCore

/--
The *prime-deformed* explicit zeta-operator construction problem — the
sharpened version of `ExplicitZetaOperatorConstructionProblem`.
-/
def PrimeDeformedExplicitZetaOperatorConstructionProblem : Prop :=
  Nonempty PrimeDeformedHeatZetaCore

/-- Solving the prime-deformed explicit construction problem implies the
critical-line statement. -/
theorem PrimeDeformedExplicitZetaOperatorConstructionProblem_implies_zeta_critical_line
    (h : PrimeDeformedExplicitZetaOperatorConstructionProblem) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ := by
  rcases h with ⟨Z⟩
  exact PrimeDeformedHeatZetaCore_implies_zeta_critical_line Z

-- Step 158: non-prime-deformed heat world no-go.

/-- Cold: a heat world with no prime/von-Mangoldt deformation. -/
def NonPrimeDeformedHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ ¬ Nonempty PrimeDeformedHeatOperator

/-- Hot: a heat world with a prime-deformed heat operator. -/
def PrimeDeformedHeatWorld (W : OperatorCandidateWorld) : Prop :=
  W.sourceLaw ∧ Nonempty PrimeDeformedHeatOperator

/-- Non-prime-deformed heat worlds are rejected: theta geometry alone is
insufficient — the heat operator must hear primes. -/
theorem nonPrimeDeformedHeatWorld_rejected :
    ClassRejectedBy OperatorCandidateWorld
      NonPrimeDeformedHeatWorld PrimeDeformedHeatWorld := by
  intro W hW hPrime
  exact hW.2 hPrime.2

-- Step 159: the prime deformation mechanism.

/--
A *prime heat-trace deformation* mechanism: the heat trace is deformed
by prime-power weights (morally von Mangoldt), and the deformed trace's
log-derivative gives the von Mangoldt response.
-/
structure PrimeHeatTraceDeformation where
  baseHeatTrace : ℝ → ℂ
  deformedHeatTrace : ℝ → ℂ
  primePowerWeights : ℕ → ℂ
  supportedOnPrimePowers : SupportedOnPrimePowers primePowerWeights
  deformationLaw : Prop
  deformationGivesVonMangoldt : Prop

/-- A prime-deformed heat operator with an explicit deformation
mechanism. -/
structure MechanizedPrimeDeformedHeatOperator
    extends PrimeDeformedHeatOperator where
  deformation : PrimeHeatTraceDeformation

/-- A prime-deformed heat zeta core with a mechanized deformation. -/
structure MechanizedPrimeDeformedHeatZetaCore
    extends PrimeDeformedHeatZetaCore where
  mechanizedPrimeDeformation : MechanizedPrimeDeformedHeatOperator

/-- Bridge: mechanized prime-deformed heat zeta core ⟹ critical-line. -/
theorem MechanizedPrimeDeformedHeatZetaCore_implies_zeta_critical_line
    (Z : MechanizedPrimeDeformedHeatZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  PrimeDeformedHeatZetaCore_implies_zeta_critical_line
    Z.toPrimeDeformedHeatZetaCore

-- Step 160: arithmetic compatibility of the heat deformation.

/--
The prime heat deformation is compatible with the Möbius and von
Mangoldt arithmetic faces, the Euler product, and the explicit formula.
-/
structure ArithmeticHeatDeformationCompatibility
    (D : PrimeHeatTraceDeformation) where
  mobiusCompatibility : Prop
  vonMangoldtCompatibility : Prop
  eulerProductCompatibility : Prop
  explicitFormulaCompatibility : Prop

/-- A mechanized core whose heat deformation is arithmetically
compatible. -/
structure ArithmeticMechanizedHeatZetaCore
    extends MechanizedPrimeDeformedHeatZetaCore where
  arithmeticHeatCompatibility :
    ArithmeticHeatDeformationCompatibility
      mechanizedPrimeDeformation.deformation

/-- Bridge: arithmetic-mechanized heat zeta core ⟹ critical-line. -/
theorem ArithmeticMechanizedHeatZetaCore_implies_zeta_critical_line
    (Z : ArithmeticMechanizedHeatZetaCore) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  MechanizedPrimeDeformedHeatZetaCore_implies_zeta_critical_line
    Z.toMechanizedPrimeDeformedHeatZetaCore

-- === Prime-Heat Deformation Mechanisms (Steps 161-167) ===
-- The "prime deformation" mystery is split into five concrete,
-- testable mechanism families. Each is a candidate answer to:
-- "what operation deforms the theta heat trace by prime powers?"

-- Step 161: Euler-local heat deformation.

/--
A *local prime heat factor*: the heat-trace analogue of an Euler
factor — each prime contributes a local deformation.
-/
structure PrimeLocalHeatFactor where
  prime : ℕ
  isPrime : Nat.Prime prime
  localHeatFactor : ℝ → ℂ
  primePowerExpansionLaw : Prop
  vonMangoldtLocalLaw : Prop

/--
An *Euler-local heat deformation*: assembles prime-local heat factors
into a global prime-deformed heat trace; the log-derivative of the
Euler heat product yields von Mangoldt.
-/
structure EulerLocalHeatDeformation where
  localFactor : ∀ p : ℕ, Nat.Prime p → PrimeLocalHeatFactor
  globalDeformedHeatTrace : ℝ → ℂ
  eulerHeatProductLaw : Prop
  producesPrimeHeatTraceDeformation : PrimeHeatTraceDeformation
  logDerivativeGivesVonMangoldt : Prop

/-- A core whose prime deformation is Euler-local. -/
structure EulerLocalHeatZetaCore
    extends ArithmeticMechanizedHeatZetaCore where
  eulerLocalHeatDeformation : EulerLocalHeatDeformation

/-- Bridge: Euler-local heat zeta core ⟹ critical-line. -/
