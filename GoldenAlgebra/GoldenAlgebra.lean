  have h3 : Real.sqrt 3 > 1.73 := by
    rw [show (1.73 : ℝ) = Real.sqrt 2.9929 from by
      rw [show (2.9929 : ℝ) = (1.73 : ℝ)^2 from by norm_num]
      exact (Real.sqrt_sq (by norm_num : (0:ℝ) ≤ 1.73)).symm]
    apply Real.sqrt_lt_sqrt (by norm_num)
    norm_num
  have hpos : (0 : ℝ) < 4 * Real.sqrt 3 := by positivity
  rw [div_lt_iff₀ hpos]
  nlinarith [h3]

