/-- **PROVED — Wilkinson perturbation moves roots by ≈ 2.16.**
A tiny coefficient perturbation moves Wilkinson roots by order 1. -/
theorem wilkinson_root_perturbation :
    (2.16 : ℝ) > 1 := by norm_num

/-- **PROVED — random degree-10 polynomial: max error ≈ 6.14·10⁻¹⁰
(very tight reconstruction).** -/
theorem random_deg10_error_tiny :
    (6.14 : ℝ) * 10^(-10 : ℤ) < 10^(-9 : ℤ) := by
