-- =====================================================================
-- === Tier 37 — Toeplitz Markov / AR(1) Causal Geometry ==============
-- =====================================================================
-- The Toeplitz RKHS hides an exact Markov / AR(1) structure:
--   K(i,k) = K(i,j)·K(j,k)   for i ≤ j ≤ k   (memory factors through j)
--   ε_i = K_{i+1} − r·K_i    is orthogonal to the entire past
--   ‖ε_i‖² = 1 − r²          (constant innovation energy)
-- Every new point carries exactly one new perpendicular degree of
-- freedom with constant energy `1 − r²`.

/-- **Markov multiplicativity of the Toeplitz kernel.**
For `i ≤ j ≤ k`:  `K(i,k) = K(i,j) · K(j,k)`.
Correlation from `i` to `k` factors through any intermediate `j` — the
Toeplitz kernel is a one-dimensional memory kernel. -/
theorem toeplitzKernel_markov_mul
    {r : ℝ} {i j k : ℕ} (hij : i ≤ j) (hjk : j ≤ k) :
    toeplitzKernel r i k
      = toeplitzKernel r i j * toeplitzKernel r j k := by
  unfold toeplitzKernel
  rw [← pow_add]
  congr 1
  omega

/-- **Innovation orthogonal to the past (pure-kernel form).**
For `k ≤ i`:  `K(i+1,k) − r·K(i,k) = 0`.
The innovation `ε_i = K_{i+1} − r·K_i` is orthogonal to every kernel
section `K_k` with `k ≤ i`. -/
theorem toeplitzInnovation_orthogonal_past
    {r : ℝ} {i k : ℕ} (hk : k ≤ i) :
    toeplitzKernel r (i + 1) k - r * toeplitzKernel r i k = 0 := by
  have h1 : toeplitzKernel r (i + 1) k = r ^ (i + 1 - k) := by
    unfold toeplitzKernel; congr 1; omega
  have h2 : toeplitzKernel r i k = r ^ (i - k) := by
    unfold toeplitzKernel; congr 1; omega
  rw [h1, h2, show i + 1 - k = (i - k) + 1 from by omega, pow_succ]
  ring

/-- The off-diagonal step value: `K(i+1, i) = r`. -/
theorem toeplitzKernel_succ_self (r : ℝ) (i : ℕ) :
    toeplitzKernel r (i + 1) i = r := by
  unfold toeplitzKernel
  rw [show Int.natAbs ((↑(i + 1) : ℤ) - (↑i : ℤ)) = 1 from by omega, pow_one]

/-- **Constant innovation energy (pure-kernel form).**
  `‖ε_i‖² = K(i+1,i+1) − 2r·K(i+1,i) + r²·K(i,i) = 1 − r²`.
Every new innovation enters with the same orthogonal energy `1 − r²`. -/
theorem toeplitzInnovation_energy (r : ℝ) (i : ℕ) :
    toeplitzKernel r (i + 1) (i + 1)
        - 2 * r * toeplitzKernel r (i + 1) i
        + r ^ 2 * toeplitzKernel r i i
      = 1 - r ^ 2 := by
  rw [toeplitzKernel_diag_one, toeplitzKernel_diag_one,
      toeplitzKernel_succ_self]
  ring

/-- **Pairwise orthogonality of innovations (pure-kernel form).**
For `j + 1 ≤ i`, the innovation `ε_i` is orthogonal to `ε_j`:
  `⟪ε_i, ε_j⟫ = 0`.
Distinct innovations are mutually perpendicular — the finite RKHS
Cholesky basis. -/
theorem toeplitzInnovation_pairwise_orthogonal
    {r : ℝ} {i j : ℕ} (hji : j + 1 ≤ i) :
    (toeplitzKernel r (i + 1) (j + 1) - r * toeplitzKernel r i (j + 1))
        - r * (toeplitzKernel r (i + 1) j - r * toeplitzKernel r i j)
      = 0 := by
  have h1 : toeplitzKernel r (i + 1) (j + 1)
      - r * toeplitzKernel r i (j + 1) = 0 :=
    toeplitzInnovation_orthogonal_past hji
  have h2 : toeplitzKernel r (i + 1) j - r * toeplitzKernel r i j = 0 :=
    toeplitzInnovation_orthogonal_past (by omega)
  rw [h1, h2]
  ring

/-- **The innovation entropy rate**: `−log(1 − r²)`.
The per-step log-volume decay of the Toeplitz RKHS point cloud. -/
noncomputable def toeplitzInnovationEntropyRate (r : ℝ) : ℝ :=
  - Real.log (1 - r ^ 2)

/-- The innovation entropy rate is non-negative for `0 ≤ r < 1`. -/
theorem toeplitzInnovationEntropyRate_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r < 1) :
    0 ≤ toeplitzInnovationEntropyRate r := by
  unfold toeplitzInnovationEntropyRate
  have h1 : 0 < 1 - r ^ 2 := by nlinarith [hr0, hr1, sq_nonneg r]
  have h2 : 1 - r ^ 2 ≤ 1 := by nlinarith [hr0, sq_nonneg r]
  have := Real.log_nonpos (le_of_lt h1) h2
  linarith

-- =====================================================================
-- === Tier 38–39 — RKHS-level Innovation: Causal Orthogonal Geometry =
-- =====================================================================
-- The innovation `ε_i = K_{i+1} − ‖λ‖·K_i` as an actual RKHS quotient
-- element. Orthogonal to the entire past, with constant energy `1−‖λ‖²`.

/-- **The innovation vector** `ε_i = K_{i+1} − ‖λ‖·K_i`, as a raw
kernel vector in the `(n+1)`-dimensional spectral Toeplitz RKHS.
`i.castSucc` embeds `i`, `i.succ` embeds `i+1`. -/
noncomputable def SpectralContractionPair.innovationVec
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    FiniteKernelVec (S.toeplitzFinitePositiveKernel (n + 1)) :=
  (S.toeplitzFinitePositiveKernel (n + 1)).kernelSection i.succ
    - fun x => ‖S.lam‖
        * (S.toeplitzFinitePositiveKernel (n + 1)).kernelSection i.castSucc x

/-- The innovation as an RKHS quotient class. -/
noncomputable def SpectralContractionPair.innovationClass
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    (S.toeplitzFinitePositiveKernel (n + 1)).RKHSQuotient :=
  Quotient.mk _ (S.innovationVec i)

/-- **The innovation is orthogonal to the entire past** (raw form).
For `k ≤ i`:  `⟪ε_i, K_k⟫ = 0`.
The future is the past plus one perpendicular spark. -/
theorem SpectralContractionPair.innovationVec_orthogonal_past
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) (k : Fin (n + 1))
    (hk : (k : ℕ) ≤ (i : ℕ)) :
    (S.toeplitzFinitePositiveKernel (n + 1)).innerRaw
        (S.innovationVec i)
        ((S.toeplitzFinitePositiveKernel (n + 1)).kernelSection k) = 0 := by
  unfold SpectralContractionPair.innovationVec
  rw [(S.toeplitzFinitePositiveKernel (n + 1)).innerRaw_sub_left,
      (S.toeplitzFinitePositiveKernel (n + 1)).innerRaw_smul_left,
      (S.toeplitzFinitePositiveKernel (n + 1)).innerRaw_kernelSection,
      (S.toeplitzFinitePositiveKernel (n + 1)).innerRaw_kernelSection]
  have hKs : (S.toeplitzFinitePositiveKernel (n + 1)).K i.succ k
      = GoldenAlgebra.toeplitzKernel ‖S.lam‖ ((i : ℕ) + 1) (k : ℕ) := by
    show GoldenAlgebra.toeplitzKernel ‖S.lam‖ ((i.succ : Fin (n+1)) : ℕ) (k : ℕ)
        = GoldenAlgebra.toeplitzKernel ‖S.lam‖ ((i : ℕ) + 1) (k : ℕ)
    rw [Fin.val_succ]
  have hKc : (S.toeplitzFinitePositiveKernel (n + 1)).K i.castSucc k
      = GoldenAlgebra.toeplitzKernel ‖S.lam‖ (i : ℕ) (k : ℕ) := by
    show GoldenAlgebra.toeplitzKernel ‖S.lam‖ ((i.castSucc : Fin (n+1)) : ℕ) (k : ℕ)
        = GoldenAlgebra.toeplitzKernel ‖S.lam‖ (i : ℕ) (k : ℕ)
    rw [Fin.coe_castSucc]
  rw [hKs, hKc]
  exact toeplitzInnovation_orthogonal_past hk

/-- **The innovation is orthogonal to the past** (RKHS-class form).
`⟪ε_i, K_k⟫ = 0` in the quotient inner product. -/
theorem SpectralContractionPair.innovation_orthogonal_past
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) (k : Fin (n + 1))
    (hk : (k : ℕ) ≤ (i : ℕ)) :
    (S.toeplitzFinitePositiveKernel (n + 1)).inner
        (S.innovationClass i)
        ((S.toeplitzFinitePositiveKernel (n + 1)).sectionClass k) = 0 := by
  unfold SpectralContractionPair.innovationClass
    FinitePositiveKernel.sectionClass
  rw [(S.toeplitzFinitePositiveKernel (n + 1)).inner_mk]
  exact S.innovationVec_orthogonal_past i k hk

/-- **Constant innovation energy** (raw form): `‖ε_i‖² = 1 − ‖λ‖²`.
Every new innovation enters the RKHS with the same orthogonal energy. -/
theorem SpectralContractionPair.innovationVec_normSq
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    (S.toeplitzFinitePositiveKernel (n + 1)).innerRaw
        (S.innovationVec i) (S.innovationVec i)
      = 1 - ‖S.lam‖ ^ 2 := by
  unfold SpectralContractionPair.innovationVec
  set P := S.toeplitzFinitePositiveKernel (n + 1) with hP
  set A := P.kernelSection i.succ with hA
  set B := fun x => ‖S.lam‖ * P.kernelSection i.castSucc x with hB
  -- Diagonal/off-diagonal kernel values.
  have hAA : P.innerRaw A A = 1 := by
    rw [hA, P.innerRaw_kernelSection]
    exact toeplitzKernel_diag_one ‖S.lam‖ _
  have hcc : P.innerRaw (P.kernelSection i.castSucc) (P.kernelSection i.castSucc) = 1 := by
    rw [P.innerRaw_kernelSection]
    exact toeplitzKernel_diag_one ‖S.lam‖ _
  have hcs : P.innerRaw (P.kernelSection i.castSucc) A = ‖S.lam‖ := by
    rw [hA, P.innerRaw_kernelSection]
    show GoldenAlgebra.toeplitzKernel ‖S.lam‖ ((i.castSucc : Fin (n+1)) : ℕ)
        ((i.succ : Fin (n+1)) : ℕ) = ‖S.lam‖
    rw [Fin.coe_castSucc, Fin.val_succ, GoldenAlgebra.toeplitzKernel_symm]
    exact toeplitzKernel_succ_self ‖S.lam‖ (i : ℕ)
  -- The four inner products.
  have hBA : P.innerRaw B A = ‖S.lam‖ * ‖S.lam‖ := by
    rw [hB, P.innerRaw_smul_left, hcs]
  have hAB : P.innerRaw A B = ‖S.lam‖ * ‖S.lam‖ := by
    rw [P.innerRaw_symm A B]; exact hBA
  have hBB : P.innerRaw B B = ‖S.lam‖ * (‖S.lam‖ * 1) := by
    rw [hB]
    rw [P.innerRaw_smul_left ‖S.lam‖ (P.kernelSection i.castSucc)]
    rw [P.innerRaw_symm (P.kernelSection i.castSucc)]
    rw [P.innerRaw_smul_left ‖S.lam‖ (P.kernelSection i.castSucc)]
    rw [hcc]
  rw [P.innerRaw_sub_left, P.innerRaw_sub_right, P.innerRaw_sub_right,
      hAA, hAB, hBA, hBB]
  ring

/-- **Constant innovation energy** (RKHS-class form):
  `‖ε_i‖² = 1 − ‖λ‖²`. -/
theorem SpectralContractionPair.innovation_normSq
    (S : SpectralContractionPair) {n : ℕ} (i : Fin n) :
    (S.toeplitzFinitePositiveKernel (n + 1)).normSq (S.innovationClass i)
      = 1 - ‖S.lam‖ ^ 2 := by
  unfold FinitePositiveKernel.normSq SpectralContractionPair.innovationClass
  rw [(S.toeplitzFinitePositiveKernel (n + 1)).inner_mk]
  exact S.innovationVec_normSq i

/-! ## Tier 37–39 Summary — The Hidden AR(1) Skeleton

The spectral Toeplitz RKHS is revealed as an **exact Markov / AR(1)
geometry**:

* `toeplitzKernel_markov_mul` — `K(i,k) = K(i,j)·K(j,k)`: correlation
   factors through any intermediate index. The kernel is a
   one-dimensional memory kernel.
* `SpectralContractionPair.innovation_orthogonal_past` — the
   innovation `ε_i = K_{i+1} − ‖λ‖·K_i` is orthogonal to the entire
   past `{K_k : k ≤ i}`.
* `SpectralContractionPair.innovation_normSq` — every innovation
   carries the *same* orthogonal energy `1 − ‖λ‖²`.
* `toeplitzInnovation_pairwise_orthogonal` — distinct innovations are
   mutually perpendicular.

Causal reading: **the future is the past plus one perpendicular spark**
of constant energy `1 − ‖λ‖²`. The contraction parameter `‖λ‖` is the
geometric memory/correlation length of the cloud, and
`toeplitzInnovationEntropyRate ‖λ‖ = −log(1 − ‖λ‖²)` is its per-step
log-volume decay. -/

