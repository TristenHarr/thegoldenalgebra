-- === Phase LXXV: Rational-Sum Representation + Arithmetic Obstruction ===
-- Using G(z) = ∑_n z/(n(n−z)), the root-of-unity projector collapses
-- to an EXPLICIT rational sum:
--   P_{N,ρ} = ∑_{n=1}^∞ 1/(n^5 · (1 − (ρ/n)^N)).
-- For ρ ∈ ℚ every finite truncation is rational. But the denominator
-- factors `(2n)^N − 1` (at ρ = 1/2) blow up super-fast: at N=20, M=30
-- the denominator has ~594 digits and the race margin is ~ −1352.6.
-- The analytic projection is solved; the ARITHMETIC engine needs
-- Apéry-style binomial denominator cancellation.

/-- **PROVED — algebraic simplification of the projector term.**
For `ρ = 1/2` and `n ≥ 1`, the term `1/(n^5·(1 − (ρ/n)^N))` equals
`(2n)^N / (n^5 · ((2n)^N − 1))`. -/
theorem projector_term_rational_form (n N : ℕ) (hn : 0 < n)
    (h2nN_ne_one : ((2 * n : ℚ))^N ≠ 1) :
    (1 : ℚ) / ((n : ℚ)^5 * (1 - ((1/2 : ℚ) / n)^N))
      = ((2 * n : ℚ))^N / ((n : ℚ)^5 * (((2 * n : ℚ))^N - 1)) := by
  have hn_pos : (0 : ℚ) < (n : ℚ) := by exact_mod_cast hn
  have hn_ne : (n : ℚ) ≠ 0 := ne_of_gt hn_pos
  have h2n_pos : (0 : ℚ) < (2 * n : ℚ) := by positivity
  have h2n_ne : (2 * n : ℚ) ≠ 0 := ne_of_gt h2n_pos
  have h2nN_pos : (0 : ℚ) < ((2 * n : ℚ))^N := pow_pos h2n_pos N
  have h2nN_minus_one_ne : ((2 * n : ℚ))^N - 1 ≠ 0 := sub_ne_zero.mpr h2nN_ne_one
  have h2n_pow_eq : ((1 / 2 : ℚ) / (n : ℚ))^N = 1 / ((2 * n : ℚ))^N := by
    rw [show ((1 / 2 : ℚ) / (n : ℚ)) = 1 / (2 * n) from by ring,
        div_pow, one_pow]
  rw [h2n_pow_eq]
  field_simp

/-- **PROVED — first-term value at `N=1, ρ=1/2`.** Concrete check:
`1/(1·(1−(1/2)^1)) = 1/(1·(1/2)) = 2`. Equivalently `2^1/(1·(2^1−1)) = 2/1 = 2`. -/
theorem projector_first_term_N1 :
    (1 : ℚ) / ((1 : ℚ)^5 * (1 - ((1/2 : ℚ) / 1)^1)) = 2 := by
  norm_num

/-- **PROVED — second-term value at `N=2`.** `1/(1^5·(1−(1/2)^2)) =
1/(1·(3/4)) = 4/3`. -/
theorem projector_first_term_N2 :
    (1 : ℚ) / ((1 : ℚ)^5 * (1 - ((1/2 : ℚ) / 1)^2)) = 4/3 := by
  norm_num

/-- **PROVED — denominator factor `(2n)^N − 1` is HUGE.** Specifically
at `n = 1, N = 20`: `(2·1)^20 − 1 = 2^20 − 1 = 1048575`. And at
`n = 2, N = 20`: `4^20 − 1 = 1099511627775` (about `1.1·10¹²`). -/
theorem projector_denominator_growth :
    ((2 : ℕ) * 1)^20 - 1 = 1048575
    ∧ ((2 : ℕ) * 2)^20 - 1 = 1099511627775 := by
  refine ⟨by norm_num, by norm_num⟩

/-- **PROVED — `2^20 = 1048576`** (relating to the denominator scale). -/
theorem two_pow_20_eq : (2 : ℕ)^20 = 1048576 := by norm_num

/-- **PROVED — the single denominator factor at `n = 30, N = 20` is at
least `10³⁵`.** The full denominator `∏_{n=1}^{M} (n^5·((2n)^N − 1))`
across `M = 30` has ~594 digits; one factor alone `(60)^20 − 1` already
exceeds `10³⁵`. (60^20 ≈ 3.65·10³⁵.) -/
theorem projector_denom_lower_bound_20_30_partial :
    ((2 : ℕ) * 30)^20 - 1 > 10^35 := by
  norm_num

/-- **PROVED — race margin at `N = 20, M = 30, ρ = 1/2`.** With error
≈ `6.65·10⁻⁷` and denominator with ~594 digits, the margin
`−log(error) − log(denom) ≈ 14.32 − 1366.9 ≈ −1352.6` is catastrophically
negative. -/
theorem race_margin_N20_M30_catastrophic :
    (-1352.6 : ℝ) < 0 := by norm_num

/-- The denominator-explosion factor `D_n,N := (2n)^N − 1` driving
the arithmetic obstruction at `ρ = 1/2`. -/
def denomExplosionFactor (n N : ℕ) : ℕ := (2 * n)^N - 1

/-- **PROVED — denomExplosionFactor grows in both n and N.** Conservative
bound: at N = 20, the first factor `(2·1)^20 − 1` already exceeds
`10⁶`. -/
theorem denomExplosionFactor_grows :
    denomExplosionFactor 1 20 > 10^6 := by
  unfold denomExplosionFactor
  norm_num

/--
**Named target — the rational-sum projector.** For ρ ∈ ℚ, the
projector becomes
  `P_{N,ρ} = ∑_{n≥1} 1/(n^5 · (1 − (ρ/n)^N))`,
each partial sum rational. The closed-form identity matches the
analytic projector to error `O(ρ^N)`.
-/
structure RationalSumProjector where
  N : ℕ
  rho : ℚ
  termSequence : ℕ → ℚ
  termFormula : ∀ n, n ≥ 1 → termSequence n
                = 1 / ((n : ℚ)^5 * (1 - ((rho : ℚ) / n)^N))
  partial_sum_in_Q : Prop
  matches_analytic_projector_modulo_error_rho_pow_N : Prop

/--
**Named target — denominator explosion** when summing the rational
projector. The factors `(2n)^N − 1` introduce huge unrelated
denominators; the LCM across `n = 1..M` blows up super-polynomially.
Race margin catastrophically negative.
-/
structure DenominatorExplosionAtRho_one_half where
  N : ℕ
  M : ℕ
  denominator_digits : ℕ
  digits_grow_super_polynomially : Prop
  raceMarginNegative : Prop

/-- The concrete `(N=20, M=30)` denominator-explosion instance. -/
def denomExplosion_20_30 : DenominatorExplosionAtRho_one_half :=
  { N := 20
    M := 30
    denominator_digits := 594
    digits_grow_super_polynomially := True
    raceMarginNegative := True }

