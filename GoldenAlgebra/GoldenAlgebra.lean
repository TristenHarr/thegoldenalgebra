-- === Phase CXV: Six Operator Rules + Body-Difference Normalization ===
-- The SIX operator rules of Overflow Analysis:
--   R1: Body source rule — dominant source ⟹ overflow body.
--   R2: Peeling rule — O_B[A] = A − B (additive) or A/B (mult.).
--   R3: Residue rule — lim O_B[A] = R is the residue.
--   R4: Tower rule — extract recursively by scaling.
--   R5: Normalization rule — two bodies differ by a finite constant.
--   R6: Geometry-residue rule — local geometry gives the exact residue.

/-- **PROVED — Body-Difference Normalization rule (R5).** If two
bodies B_1 and B_2 both work for the same A (peeled limits R_1, R_2
respectively), then their difference tends to R_2 − R_1. -/
theorem body_difference_normalization
    {ι : Type*} (A B1 B2 : ι → ℝ) (R1 R2 : ℝ) (l : Filter ι)
    (hAB1 : Filter.Tendsto (fun i => A i - B1 i) l (nhds R1))
    (hAB2 : Filter.Tendsto (fun i => A i - B2 i) l (nhds R2)) :
    Filter.Tendsto (fun i => B1 i - B2 i) l (nhds (R2 - R1)) := by
  -- B1 − B2 = (A − B2) − (A − B1)
  have heq : (fun i => B1 i - B2 i) = fun i => (A i - B2 i) - (A i - B1 i) := by
    funext i; ring
  rw [heq]
  exact hAB2.sub hAB1

/-- **PROVED — body-difference constant matches the residue shift.** -/
theorem body_difference_residue_shift
    {ι : Type*} (A B1 B2 : ι → ℝ) (R1 R2 : ℝ) (l : Filter ι)
    (hAB1 : Filter.Tendsto (fun i => A i - B1 i) l (nhds R1))
    (hAB2 : Filter.Tendsto (fun i => A i - B2 i) l (nhds R2)) :
    Filter.Tendsto (fun i => B1 i - B2 i) l (nhds (R2 - R1)) :=
  body_difference_normalization A B1 B2 R1 R2 l hAB1 hAB2

