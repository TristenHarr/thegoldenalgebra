-- === Node-Collapse No-Go: the Golden Hankel test, as a theorem ===
-- The numerical experiment (golden_hankel_xi_test.py) showed the
-- Golden Hankel quadrature nodes COLLAPSE toward 0 as N grows
-- (8.18 → 2.80 → 0.71 → 0.23 → 0.06) rather than stabilizing at the
-- zeta ordinates. This formalizes WHY that refutes Xi-convergence: a
-- first node tending to 0 cannot converge to Ξ's first zero, which is
-- positive (≈ 14.13).

/-- A *node-collapse obstruction*: the family's first quadrature node
tends to `0`, while Ξ's first positive zero is strictly positive. -/
structure NodeCollapseObstruction where
  firstNode : ℕ → ℝ
  firstNode_tendsto_zero :
    Filter.Tendsto firstNode Filter.atTop (nhds 0)
  xiFirstZeroValue : ℝ
  xiFirstZero_pos : 0 < xiFirstZeroValue

/--
**Node-collapse no-go (PROVED).** If a candidate family's first node
collapses to `0`, that node does NOT converge to Ξ's (positive) first
zero. The Golden Hankel family exhibits exactly this collapse, so it is
rejected as a Ξ-approximant — the failed numerical experiment turned
into a theorem.
-/
theorem nodeCollapse_not_tendsto_xiFirstZero
    (O : NodeCollapseObstruction) :
    ¬ Filter.Tendsto O.firstNode Filter.atTop
        (nhds O.xiFirstZeroValue) := by
  intro h
  have heq : (0 : ℝ) = O.xiFirstZeroValue :=
    tendsto_nhds_unique O.firstNode_tendsto_zero h
  exact absurd heq.symm (ne_of_gt O.xiFirstZero_pos)

/--
A node-collapsing family cannot be a Xi-convergent approximant family
*with first node tracking the first quadrature node*: the collapse
contradicts convergence to the positive first Ξ zero.
-/
