i.e. positions whose entropy exceeds bin capacity per row.
-/
structure EntropyContourRupture where
  n : ℕ
  M : ℕ
  capacityPerRow : ℝ                       -- log_2 M / n
  overflow_zone : Set ℝ                    -- { x : H_2(x) > capacityPerRow }
