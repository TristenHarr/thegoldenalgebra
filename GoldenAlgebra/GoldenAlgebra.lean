-- === Phase XXXVI: The Dₙ² Obstruction Layer ===
-- The leftover ζ(5) denominator obstruction is EXACTLY a divisor of
-- Dₙ². The ζ(3)-side is at Dₙ³; the ζ(5)-side is stuck at Dₙ⁵. And a
-- cheap integer linear combination p + a·p̃ + b·q CANNOT remove it —
-- that "failed trick" is now a PROVED theorem.

/-- A real number is *integer-valued* — equal to some integer. -/
def IsIntegerValued (x : ℝ) : Prop := ∃ k : ℤ, (k : ℝ) = x

/-- **PROVED.** The sum of two integer-valued reals is integer-valued. -/
theorem isInt_add {x y : ℝ}
    (hx : IsIntegerValued x) (hy : IsIntegerValued y) :
    IsIntegerValued (x + y) := by
  obtain ⟨j, hj⟩ := hx
  obtain ⟨k, hk⟩ := hy
  exact ⟨j + k, by push_cast; rw [hj, hk]⟩

/-- **PROVED.** An integer multiple of an integer-valued real is
integer-valued. -/
theorem isInt_intMul (a : ℤ) {y : ℝ} (hy : IsIntegerValued y) :
    IsIntegerValued ((a : ℝ) * y) := by
  obtain ⟨k, hk⟩ := hy
  exact ⟨a * k, by push_cast; rw [hk]⟩

/-- **PROVED.** Adding an integer-valued real does not change
integrality: `IsIntegerValued (x + y) ↔ IsIntegerValued x` when `y` is
integer-valued. -/
theorem isInt_add_iff {x y : ℝ} (hy : IsIntegerValued y) :
    IsIntegerValued (x + y) ↔ IsIntegerValued x := by
  constructor
  · intro hxy
    have hkey : IsIntegerValued ((x + y) + ((-1 : ℤ) : ℝ) * y) :=
      isInt_add hxy (isInt_intMul (-1) hy)
    have heq : (x + y) + ((-1 : ℤ) : ℝ) * y = x := by
      push_cast; ring
    rwa [heq] at hkey
  · intro hx
    exact isInt_add hx hy

/--
**PROVED — the failed delinking trick.** Replacing `p` by
`p + a·p̃ + b·q` (`a, b ∈ ℤ`) cannot change whether `p` is
integer-valued, when `p̃` and `q` are integer-valued. So a cheap
integer linear combination of the ζ(3)/rational coordinates cannot
remove the residual ζ(5) denominator burden — the obstruction is
intrinsic to the ζ(5) coordinate.
-/
theorem failed_delinking_trick {p ptilde q : ℝ} (a b : ℤ)
    (hpt : IsIntegerValued ptilde) (hq : IsIntegerValued q) :
    IsIntegerValued (p + (a : ℝ) * ptilde + (b : ℝ) * q)
      ↔ IsIntegerValued p := by
  have hcombo : IsIntegerValued ((a : ℝ) * ptilde + (b : ℝ) * q) :=
    isInt_add (isInt_intMul a hpt) (isInt_intMul b hq)
  rw [add_assoc]
  exact isInt_add_iff hcombo

/--
The **ζ(5) denominator structure**. The cleared sequences: `4Dₙ³qₙ` and
`4Dₙ³p̃ₙ` are integer-valued (ζ(3)-side at the Apéry Dₙ³ level), and
`4Dₙ⁵pₙ` is integer-valued — but `4Dₙ³pₙ` need not be: its denominator
divides `Dₙ²`. That residual `Dₙ²` is the obstruction.
-/
structure ZetaFiveDenominatorStructure where
  clearedQ : ℕ → ℝ
  clearedPtilde : ℕ → ℝ
  clearedP3 : ℕ → ℝ
  clearedP5 : ℕ → ℝ
  q_integral : ∀ n, IsIntegerValued (clearedQ n)
  ptilde_integral : ∀ n, IsIntegerValued (clearedPtilde n)
  p5_integral : ∀ n, IsIntegerValued (clearedP5 n)
  p3_denominator_divides_Dsquared : Prop

/--
**PROVED — the failed trick, applied to ζ(5).** Adding any integer
combination of `4Dₙ³p̃ₙ` and `4Dₙ³qₙ` to `4Dₙ³pₙ` leaves its
integrality unchanged. The `Dₙ²` burden cannot be cleared cheaply.
-/
theorem zetaFive_integer_combination_useless
    (S : ZetaFiveDenominatorStructure) (n : ℕ) (a b : ℤ) :
    IsIntegerValued
        (S.clearedP3 n + (a : ℝ) * S.clearedPtilde n
          + (b : ℝ) * S.clearedQ n)
      ↔ IsIntegerValued (S.clearedP3 n) :=
  failed_delinking_trick a b (S.ptilde_integral n) (S.q_integral n)

/-- **Named target — the square-prime obstruction.** The leftover
denominator `Rₙ = den(4Dₙ³pₙ)` is square-like — factors `17², 19²,
31², 37², 41², …` — a residual weight-2 harmonic `H^(2)` layer. -/
structure SquarePrimeObstruction where
  leftoverDenominator : ℕ → ℕ
  divides_Dsquared : Prop
  squareLikePrimeStructure : Prop
  matchesHarmonicTwoLayer : Prop

/--
**Named target — the ζ(5) internal projection.** A projection acting
*inside* the hypergeometric construction (root-of-unity / parity
filter, golden conjugation, or a new hypergeometric seed) producing a
modified `pₙ⋆` with `4Dₙ³pₙ⋆ ∈ ℤ` — the exact `Dₙ⁵ → Dₙ³` compression —
while still approximating ζ(5) with tiny-mode decay.
-/
structure ZetaFiveInternalProjection where
  projectedP : ℕ → ℝ
  projected_clearedAtDcubed :
    ∀ n, IsIntegerValued (projectedP n)
  stillApproximatesZetaFive : Prop
  errorInTinyMode : Prop

/--
The **ζ(5) denominator diagnosis**: the `Dₙ²` obstruction layer, the
proved uselessness of cheap integer combinations, the square-prime
structure, and the internal-projection target. The `Dₙ⁵ → Dₙ³`
compression is the exact remaining wall.
