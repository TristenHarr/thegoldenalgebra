/--
**Named record — single arithmetic log oscillator** `O_m(t) =
2·cos(θ(t) − t·log m)/√m`.
-/
structure ArithmeticLogOscillator where
  m : ℕ
  m_ge_one : 1 ≤ m
  amplitude : ℝ                                -- 2/√m
  amplitude_eq : amplitude = 2 / Real.sqrt m
  frequency : ℝ                                -- log m (from t·log m phase)

/--
**Named record — single cutoff residue oscillator** `E_r(t) =
(-1)^{N-1}·(t/(2π))^{-1/4-r/2}·C_r(p)`.
-/
structure CutoffResidueOscillator where
