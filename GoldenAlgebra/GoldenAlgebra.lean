is circulant, so the eigenmodes are Fourier modes
`δzₖ = e^{2π i m k / N}`. The conjectural threshold `N_crit = 7` is an
inequality on the closed-form eigenvalue in mode `m`.

This is **not** formalised as a Lean theorem; it is recorded as an open
target for future Hessian-spectrum work. -/

-- =========================================================================
-- Tier P6 — Full swirl / propulsion force
-- =========================================================================

/-- Full complex Golden pair force: radial part plus tangential swirl. -/
noncomputable def goldenFullPairForce (zi zj : ℂ) : ℂ :=
  lambda_eff ‖zj - zi‖ * (zj - zi)

/-- Pure swirl part of the Golden pair force:
`F_swirl = (Jeff(r) · i) (zⱼ − zᵢ)`. -/
noncomputable def goldenSwirlPairForce (zi zj : ℂ) : ℂ :=
  (((Jeff ‖zj - zi‖ : ℝ) : ℂ) * I) * (zj - zi)

/-- Decomposition: full force = radial + swirl. -/
theorem goldenFullPairForce_decompose (zi zj : ℂ) :
    goldenFullPairForce zi zj
      = goldenRadialPairForce zi zj + goldenSwirlPairForce zi zj := by
  unfold goldenFullPairForce goldenRadialPairForce goldenSwirlPairForce
         lambda_eff goldenRadialCoeff Teff Jeff
  push_cast
  ring

/-- The full complex force is pair-antisymmetric, so total linear momentum
is still conserved even though angular momentum generally is not. -/
theorem goldenFullPairForce_antisymm (zi zj : ℂ) :
    goldenFullPairForce zi zj = - goldenFullPairForce zj zi := by
  unfold goldenFullPairForce lambda_eff Teff Jeff
  have hnorm : ‖zi - zj‖ = ‖zj - zi‖ := by
    simpa using norm_neg (zj - zi)
  rw [hnorm]
  push_cast
  ring

/-- Pair antisymmetry of the swirl part alone. -/
theorem goldenSwirlPairForce_antisymm (zi zj : ℂ) :
    goldenSwirlPairForce zi zj = - goldenSwirlPairForce zj zi := by
  unfold goldenSwirlPairForce Jeff
  have hnorm : ‖zi - zj‖ = ‖zj - zi‖ := by
    simpa using norm_neg (zj - zi)
  rw [hnorm]
  push_cast
  ring

/-- 2D scalar torque of force `F` applied at position `z`:
`τ(z, F) = Im(z̄ · F)`. -/
noncomputable def torqueC (z F : ℂ) : ℝ := (star z * F).im

/-- Torque produced by the pure swirl pair force on the relative vector `r`:
`τ(r, F_swirl(r)) = Jeff(‖r‖) · ‖r‖²`.

So the swirl injects angular momentum at every pair-distance for which
`Jeff(r) ≠ 0`. -/
theorem torque_of_swirl_pair (r : ℂ) :
    torqueC r ((((Jeff ‖r‖ : ℝ) : ℂ) * I) * r)
      = Jeff ‖r‖ * ‖r‖ ^ 2 := by
  unfold torqueC
  have hrr : star r * r = ((Complex.normSq r : ℝ) : ℂ) := by
    rw [mul_comm]; exact_mod_cast Complex.mul_conj r
  have hnsq : (Complex.normSq r : ℝ) = ‖r‖ ^ 2 :=
    Complex.normSq_eq_norm_sq r
  have hstep :
      star r * ((((Jeff ‖r‖ : ℝ) : ℂ) * I) * r)
        = ((Jeff ‖r‖ : ℝ) : ℂ) * I * ((‖r‖ ^ 2 : ℝ) : ℂ) := by
    have hcomm :
        star r * ((((Jeff ‖r‖ : ℝ) : ℂ) * I) * r)
          = (((Jeff ‖r‖ : ℝ) : ℂ) * I) * (star r * r) := by ring
    rw [hcomm, hrr, hnsq]
  rw [hstep]
  simp only [Complex.mul_im, Complex.mul_re, Complex.ofReal_re, Complex.ofReal_im,
             Complex.I_re, Complex.I_im, mul_zero, zero_mul, mul_one, one_mul,
             sub_zero, zero_sub, add_zero, zero_add, neg_zero]

/-- The radius at which the Golden swirl vanishes: `r_J = H / √J`. -/
noncomputable def goldenSwirlZeroRadius : ℝ := H / Real.sqrt J

theorem goldenSwirlZeroRadius_pos : 0 < goldenSwirlZeroRadius := by
  unfold goldenSwirlZeroRadius
  exact div_pos H_pos (Real.sqrt_pos.mpr J_pos)

/-- `Jeff` vanishes at the swirl-zero radius `r_J = H / √J`. -/
theorem Jeff_eq_zero_at_swirlZero :
    Jeff goldenSwirlZeroRadius = 0 := by
  unfold Jeff goldenSwirlZeroRadius
  have hJ : (0 : ℝ) < J := J_pos
  have hsqJ_pos : 0 < Real.sqrt J := Real.sqrt_pos.mpr hJ
  have hsqJ_ne : Real.sqrt J ≠ 0 := ne_of_gt hsqJ_pos
  have hH_ne : H ≠ 0 := ne_of_gt H_pos
  have hsqJ_sq : (Real.sqrt J) ^ 2 = J := Real.sq_sqrt hJ.le
  have hsq : (H / Real.sqrt J) ^ 2 = H ^ 2 / J := by
    rw [div_pow, hsqJ_sq]
  rw [hsq]
  have hJ_ne : J ≠ 0 := ne_of_gt hJ
  have hH_sq_ne : H ^ 2 ≠ 0 := pow_ne_zero 2 hH_ne
  field_simp [hH_sq_ne, hJ_ne]

/-- At the swirl-zero radius, the swirl pair force itself vanishes
(regardless of the relative orientation). -/
theorem goldenSwirlPairForce_eq_zero_at_swirlZero
    (zi zj : ℂ) (h : ‖zj - zi‖ = goldenSwirlZeroRadius) :
    goldenSwirlPairForce zi zj = 0 := by
  unfold goldenSwirlPairForce
  rw [h, Jeff_eq_zero_at_swirlZero]
  push_cast
  ring

-- =========================================================================
-- Tier P7 — Closed-form minimum thrust at θ = arg(λ_G)
-- =========================================================================

/-- **Closed-form minimum thrust.** At `θ = arg(λ_G)`, the circularizing
control achieves the lower bound exactly:
`‖u_n‖ = (1 − ‖λ_G‖) · ‖z‖`.

Combined with `circularizingControl_norm_lower_bound`, this proves that
`(1 − ‖λ_G‖) · ‖z‖` is the **infimum (and minimum) of the thrust
magnitude over all `θ`**, attained at the Golden phase angle. -/
theorem circularizingControl_norm_eq_at_arg (z : ℂ) :
    ‖circularizingControl (Complex.arg lambdaG1) z‖
      = (1 - ‖lambdaG1‖) * ‖z‖ := by
  unfold circularizingControl
  rw [norm_mul]
  congr 1
  set a : ℝ := Complex.arg lambdaG1
  have h_polar :
      (‖lambdaG1‖ : ℂ) * Complex.exp ((a : ℂ) * I) = lambdaG1 :=
    Complex.norm_mul_exp_arg_mul_I lambdaG1
  have h_diff :
      Complex.exp ((a : ℂ) * I) - lambdaG1
        = ((1 - ‖lambdaG1‖ : ℝ) : ℂ) * Complex.exp ((a : ℂ) * I) := by
    push_cast
    linear_combination h_polar
  rw [h_diff, norm_mul, norm_exp_ofReal_mul_I, mul_one,
      Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos (by linarith [norm_lambdaG1_lt_one] : (0 : ℝ) < 1 - ‖lambdaG1‖)]

/-- Squared form of the closed-form minimum thrust energy:
`‖u_n‖² = (1 − ‖λ_G‖)² · ‖z‖²` at `θ = arg(λ_G)`. -/
theorem circularizingControl_normSq_at_arg (z : ℂ) :
    ‖circularizingControl (Complex.arg lambdaG1) z‖ ^ 2
      = (1 - ‖lambdaG1‖) ^ 2 * ‖z‖ ^ 2 := by
  rw [circularizingControl_norm_eq_at_arg, mul_pow]

-- =========================================================================
-- Tier P8 — Quiet shell: ‖λ_eff(2H)‖² = (9 − 4√5)/8
-- =========================================================================

/-- Operator-quiet-shell radius `r_min = 2H`: where `‖λ_eff(r)‖` attains
its minimum value over `r > 0`. Numerically `r_min ≈ 0.118034`. -/
noncomputable def goldenQuietShellRadius : ℝ := 2 * H

theorem goldenQuietShellRadius_pos : 0 < goldenQuietShellRadius := by
  unfold goldenQuietShellRadius
  linarith [H_pos]

/-- Norm-squared formula for the effective Golden operator:
`‖λ_eff(r)‖² = T_eff(r)² + J_eff(r)²`. -/
theorem lambda_eff_normSq (r : ℝ) :
    ‖lambda_eff r‖ ^ 2 = (Teff r) ^ 2 + (Jeff r) ^ 2 := by
  unfold lambda_eff
  rw [Complex.norm_def, Real.sq_sqrt (Complex.normSq_nonneg _)]
  simp [Complex.normSq_apply, Complex.add_re, Complex.add_im,
        Complex.mul_re, Complex.mul_im, Complex.ofReal_re, Complex.ofReal_im,
        Complex.I_re, Complex.I_im]
  ring

/-- **Closed form at the operator minimum:**
`‖λ_eff(2H)‖² = (9 − 4√5)/8`. Numerically `‖λ_eff(2H)‖ ≈ 0.083463`.

This is the deepest "quiet" in the Golden response field — the radius
where the operator has minimal effect, sitting between the radial-null
radius `r_T = H/√T ≈ 0.106` and the swirl-null radius `r_J = H/√J ≈ 0.135`. -/
theorem lambda_eff_normSq_at_quiet_shell :
    ‖lambda_eff goldenQuietShellRadius‖ ^ 2 = (9 - 4 * Real.sqrt 5) / 8 := by
  unfold goldenQuietShellRadius
  rw [lambda_eff_normSq]
  have hH_ne : H ≠ 0 := ne_of_gt H_pos
  have hH_sq_ne : H ^ 2 ≠ 0 := pow_ne_zero 2 hH_ne
  have h2H_sq : (2 * H) ^ 2 = 4 * H ^ 2 := by ring
  have hTeff : Teff (2 * H) = T - 1 / 4 := by
    unfold Teff
    rw [h2H_sq]
    field_simp
    ring
  have hJeff : Jeff (2 * H) = J - 1 / 4 := by
    unfold Jeff
    rw [h2H_sq]
    field_simp
    ring
  rw [hTeff, hJeff]
  have h_sum_sq := T_sq_add_J_sq
  have h_sum := T_add_J_eq_one_half
  linear_combination h_sum_sq - h_sum / 2

-- =========================================================================
-- Tier P9 — N-body phase-space structure and conservation theorems
-- =========================================================================

/-- A single body's instantaneous state in the 2D plane (≅ ℂ): mass,
position, and velocity. The position and velocity are complex numbers
representing 2D vectors. -/
structure BodyState where
  mass     : ℝ
  position : ℂ
  velocity : ℂ

/-- An `N`-body system is a finite indexed family of body states. -/
abbrev NBodyState (N : ℕ) := Fin N → BodyState

namespace NBodyState

variable {N : ℕ}

/-- Total mass `M := Σ m_i`. -/
def totalMass (S : NBodyState N) : ℝ :=
  ∑ i : Fin N, (S i).mass

/-- Total linear momentum `P := Σ m_i · v_i`. -/
noncomputable def totalMomentum (S : NBodyState N) : ℂ :=
  ∑ i : Fin N, ((S i).mass : ℂ) * (S i).velocity

/-- Unnormalized center-of-mass vector `Ξ := Σ m_i · q_i`. -/
noncomputable def momentMass (S : NBodyState N) : ℂ :=
  ∑ i : Fin N, ((S i).mass : ℂ) * (S i).position

/-- Total kinetic energy `T_kin := ½ · Σ m_i · ‖v_i‖²`. -/
noncomputable def kineticEnergy (S : NBodyState N) : ℝ :=
  ∑ i : Fin N, (1 / 2 : ℝ) * (S i).mass * ‖(S i).velocity‖ ^ 2

/-- Scalar (2D) angular momentum about the origin
`L := Σ m_i · (x_i v_i^y − y_i v_i^x)`. -/
def angularMomentum (S : NBodyState N) : ℝ :=
  ∑ i : Fin N,
    (S i).mass *
      ((S i).position.re * (S i).velocity.im
        - (S i).position.im * (S i).velocity.re)

end NBodyState

-- ---------- Discrete center-of-mass and momentum conservation ----------

/-- **Center-of-mass conservation under free motion.** For free
linear advection `q_i ↦ q_i + t · v_i`, the unnormalized
center-of-mass `Σ m_i · q_i` is invariant provided the total
momentum `Σ m_i · v_i = 0`. This is the discrete content of the
classical identity `Ξ̈ = 0` for an isolated free system. -/
theorem freeMotion_centerOfMass_invariant {N : ℕ}
    (m : Fin N → ℝ) (q v : Fin N → ℂ)
    (h_p : ∑ i, (m i : ℂ) * v i = 0)
    (t : ℝ) :
    ∑ i, (m i : ℂ) * (q i + (t : ℂ) * v i) = ∑ i, (m i : ℂ) * q i := by
  have h_split : ∀ i, (m i : ℂ) * (q i + (t : ℂ) * v i)
      = (m i : ℂ) * q i + (t : ℂ) * ((m i : ℂ) * v i) := by
    intro i; ring
  simp_rw [h_split]
  rw [Finset.sum_add_distrib, ← Finset.mul_sum, h_p, mul_zero, add_zero]

/-- **N-body origin stability under free motion.** If both the center of
mass and the total momentum vanish initially, the center of mass remains
at the origin under free motion. This is the discrete-time content of
the "Ξ(0) = 0, Ξ̇(0) = 0 ⇒ Ξ(t) = 0" theorem in Newtonian mechanics. -/
theorem freeMotion_origin_stable {N : ℕ}
    (m : Fin N → ℝ) (q v : Fin N → ℂ)
    (h_xi : ∑ i, (m i : ℂ) * q i = 0)
    (h_p : ∑ i, (m i : ℂ) * v i = 0)
    (t : ℝ) :
    ∑ i, (m i : ℂ) * (q i + (t : ℂ) * v i) = 0 := by
  rw [freeMotion_centerOfMass_invariant m q v h_p, h_xi]

/-- One Euler step of momentum under net forces `f : Fin N → ℂ`:
`p_i ↦ p_i + dt · f_i`. -/
def momentumStep {N : ℕ} (p : Fin N → ℂ) (f : Fin N → ℂ) (dt : ℝ) :
    Fin N → ℂ :=
  fun i => p i + (dt : ℂ) * f i

/-- **Conservation of total momentum under one Euler step.** Under any
pair-antisymmetric internal force law, the total momentum is invariant
under an Euler integration step. This is the discrete content of the
classical theorem `dP/dt = Σᵢ Fᵢ^{ext}` — when external forces vanish
and internal forces are Newtonian, total momentum is constant. -/
theorem total_momentum_invariant_one_step {N : ℕ}
    (p : Fin N → ℂ) (F : Fin N → Fin N → ℂ)
    (hF : ∀ i j, F i j = - F j i) (dt : ℝ) :
    ∑ i, momentumStep p (fun i => ∑ j, F i j) dt i = ∑ i, p i := by
  unfold momentumStep
  rw [Finset.sum_add_distrib, ← Finset.mul_sum,
      sum_pairwise_antisymm_zero F hF, mul_zero, add_zero]

/-- **Discrete momentum conservation for the Golden N-body interaction.**
Combining the Newton third-law `goldenRadialPairForce_antisymm` with the
Euler-step machinery: the total Golden radial momentum is invariant
under one explicit-Euler step. -/
theorem goldenRadial_total_momentum_invariant_one_step {N : ℕ}
    (p : Fin N → ℂ) (z : Fin N → ℂ) (dt : ℝ) :
    ∑ i, momentumStep p
        (fun i => ∑ j, if j = i then 0
                         else goldenRadialPairForce (z i) (z j)) dt i
      = ∑ i, p i := by
  apply total_momentum_invariant_one_step
  intro i j
  by_cases hij : j = i
  · subst hij
    simp
  · have hji : ¬ (i = j) := fun h => hij h.symm
    have hrad : goldenRadialPairForce (z i) (z j)
                  = - goldenRadialPairForce (z j) (z i) :=
      goldenRadialPairForce_antisymm (z i) (z j)
    simp [hij, hji, hrad]

end GoldenMechanics

/-!
## Tier 91 — Binet Translation Layer

A small "compression-coordinate" toolkit for central inverse-square
motion. The key move is the substitution

`u(θ) = 1 / r(θ)`.

In Newton's coordinate `r`, the inverse-square equation
`r̈ = − μ r / r³` is nonlinear. In the compression coordinate `u`, it
becomes the **Binet equation**

`u'' + u = μ / h²`,

a forced linear harmonic oscillator. Its closed-form solution

`u(θ) = (μ / h²) · (1 + e · cos θ)`

inverts back to the classical conic-section orbit

`r(θ) = (h² / μ) / (1 + e · cos θ)`.

This section formalises the compression-coordinate side of that
translation — the part that is pure ODE algebra, independent of the
Newton derivation itself. It is the prototype for the project's
"move into the right frustration coordinate, solve there, move back"
pipeline:

```
  Newton-ODE  ──→  compression u  ──→  solve u'' + u = const  ──→  r = 1/u
```

The weak-field general-relativistic correction
`u'' + u = μ/h² + (3μ/c²) u²` is recorded as a `Prop`-level definition
together with its Newtonian limit (`c → ∞`).
-/

section BinetTranslation

/-- The Binet/compression coordinate. -/
noncomputable def binetCompression (r : ℝ) : ℝ := 1 / r

/-- The Newton conic-section compression solution
`u(θ) = (μ / h²) · (1 + e · cos θ)`.

`e` is the orbital eccentricity (a free constant; `e = 0` is a circular
orbit; `0 < e < 1` is an ellipse). -/
noncomputable def binetConicSolution (μ h e : ℝ) (θ : ℝ) : ℝ :=
  (μ / h ^ 2) * (1 + e * Real.cos θ)

/-- The orbit reconstructed from the conic compression by `r = 1 / u`:
`r(θ) = (h² / μ) / (1 + e · cos θ)`. -/
noncomputable def conicOrbit (μ h e : ℝ) (θ : ℝ) : ℝ :=
  1 / binetConicSolution μ h e θ

/-- A function `u : ℝ → ℝ` solves the Newtonian Binet equation
`u'' + u = μ / h²`. -/
def IsBinetSolution (μ h : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ = μ / h ^ 2

/-- A function `u : ℝ → ℝ` solves the weak-field relativistic Binet
equation `u'' + u = μ / h² + (3 μ / c²) u²`. The Newtonian limit is
`c → ∞`. -/
def IsRelativisticBinet (μ h c : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ
        = μ / h ^ 2 + (3 * μ / c ^ 2) * (u θ) ^ 2

-- --- First derivative of the conic compression solution ---------------

/-- First derivative of `u(θ) = (μ/h²)(1 + e cos θ)`:
`u'(θ) = − (μ/h²) · e · sin θ`. -/
theorem hasDerivAt_binetConicSolution (μ h e θ : ℝ) :
    HasDerivAt (binetConicSolution μ h e)
      (-(μ / h ^ 2) * e * Real.sin θ) θ := by
  unfold binetConicSolution
  have hcos : HasDerivAt Real.cos (-Real.sin θ) θ := Real.hasDerivAt_cos θ
  have hcose : HasDerivAt (fun θ => e * Real.cos θ) (e * -Real.sin θ) θ :=
    hcos.const_mul e
  have hsum : HasDerivAt (fun θ => 1 + e * Real.cos θ) (e * -Real.sin θ) θ :=
    hcose.const_add 1
  have hfinal := hsum.const_mul (μ / h ^ 2)
  convert hfinal using 1
  ring

/-- Pointwise value of the first derivative as a `deriv`. -/
theorem deriv_binetConicSolution (μ h e θ : ℝ) :
    deriv (binetConicSolution μ h e) θ
      = -(μ / h ^ 2) * e * Real.sin θ :=
  (hasDerivAt_binetConicSolution μ h e θ).deriv

-- --- Second derivative of the conic compression solution --------------

/-- Second derivative of the conic compression solution. As a function of
`θ`, `u'(θ) = − (μ/h²) · e · sin θ`, and its derivative is
`u''(θ) = − (μ/h²) · e · cos θ`. -/
theorem hasDerivAt_deriv_binetConicSolution (μ h e θ : ℝ) :
    HasDerivAt (fun θ => -(μ / h ^ 2) * e * Real.sin θ)
      (-(μ / h ^ 2) * e * Real.cos θ) θ := by
  have hsin : HasDerivAt Real.sin (Real.cos θ) θ := Real.hasDerivAt_sin θ
  have := hsin.const_mul (-(μ / h ^ 2) * e)
  convert this using 1

/-- The second derivative of `binetConicSolution` equals
`u''(θ) = − (μ/h²) · e · cos θ`. -/
theorem deriv_deriv_binetConicSolution (μ h e θ : ℝ) :
    deriv (deriv (binetConicSolution μ h e)) θ
      = -(μ / h ^ 2) * e * Real.cos θ := by
  have hpt : deriv (binetConicSolution μ h e)
              = fun θ => -(μ / h ^ 2) * e * Real.sin θ := by
    funext θ
    exact deriv_binetConicSolution μ h e θ
  rw [hpt]
  exact (hasDerivAt_deriv_binetConicSolution μ h e θ).deriv

-- --- The Binet equation holds for the conic solution -----------------

/-- **The conic compression is a Newtonian Binet solution.**
`u(θ) = (μ/h²)(1 + e cos θ)` satisfies `u'' + u = μ/h²` for every `θ`. -/
theorem binetConicSolution_isBinetSolution (μ h e : ℝ) :
    IsBinetSolution μ h (binetConicSolution μ h e) := by
  intro θ
  rw [deriv_deriv_binetConicSolution]
  unfold binetConicSolution
  ring

/-- The pure algebraic content of the Binet equation for the conic:
`−(μ/h²) e cos θ + (μ/h²)(1 + e cos θ) = μ/h²`. -/
theorem binet_equation_for_conic_algebra (μ h e θ : ℝ) :
    -(μ / h ^ 2) * e * Real.cos θ + binetConicSolution μ h e θ
      = μ / h ^ 2 := by
  unfold binetConicSolution
  ring

-- --- Recovery: `r = 1/u` gives the conic-section orbit ----------------

/-- **Recovery formula.** Under `r = 1/u`, the conic compression
`u(θ) = (μ/h²)(1 + e cos θ)` becomes the classical conic-section orbit
`r(θ) = (h²/μ) / (1 + e cos θ)`. -/
theorem conicOrbit_eq_semilatus_form
    {μ h e θ : ℝ} (hμ : μ ≠ 0) (hh : h ≠ 0)
    (_hden : 1 + e * Real.cos θ ≠ 0) :
    conicOrbit μ h e θ = (h ^ 2 / μ) / (1 + e * Real.cos θ) := by
  unfold conicOrbit binetConicSolution
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  field_simp

/-- Closed form for the circular orbit (`e = 0`): `r(θ) = h² / μ`. -/
theorem conicOrbit_circular
    {μ h : ℝ} (hμ : μ ≠ 0) (hh : h ≠ 0) (θ : ℝ) :
    conicOrbit μ h 0 θ = h ^ 2 / μ := by
  unfold conicOrbit binetConicSolution
  have _hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  field_simp

-- --- Newton ⇄ relativity bridge ---------------------------------------

/-- **Symbolic Newton limit.** When the relativistic correction
coefficient `3 μ / c²` is zero, the relativistic Binet equation literally
is the Newtonian Binet equation. This is the formal `c → ∞` limit. -/
theorem IsRelativisticBinet.eq_newton_when_no_correction
    {μ h c : ℝ} {u : ℝ → ℝ}
    (hcoef : 3 * μ / c ^ 2 = 0) :
    IsRelativisticBinet μ h c u ↔ IsBinetSolution μ h u := by
  unfold IsRelativisticBinet IsBinetSolution
  constructor
  · intro hrel θ
    have hθ := hrel θ
    rw [hcoef, zero_mul, add_zero] at hθ
    exact hθ
  · intro hbin θ
    rw [hcoef, zero_mul, add_zero]
    exact hbin θ

-- --- Bridge to the Golden mechanics layer -----------------------------

/-- The Golden circular-orbit "compression radius" produced by the
specialisation `(μ, h) = (T, H)`: `r_circ = H² / T`. This connects the
Binet translation layer to the radial mechanics layer's
`goldenEquilibriumRadius = H / √T`: both express the same content that
"the natural Golden separation is fixed by `H` and `T`," but at different
operator orders. -/
noncomputable def goldenBinetCircularRadius : ℝ := H ^ 2 / T

theorem goldenBinetCircularRadius_pos : 0 < goldenBinetCircularRadius := by
  unfold goldenBinetCircularRadius
  exact div_pos (pow_pos H_pos 2) T_pos

/-- Closed form: with the Golden-specialised parameters `(μ, h) = (T, H)`,
the `e = 0` conic orbit has constant radius `H² / T`. -/
theorem conicOrbit_circular_at_golden (θ : ℝ) :
    conicOrbit T H 0 θ = goldenBinetCircularRadius := by
  unfold goldenBinetCircularRadius
  exact conicOrbit_circular (ne_of_gt T_pos) (ne_of_gt H_pos) θ

/-- **Golden Binet solution.** The conic compression specialised to
the Golden constants `(μ, h, e) = (T, H, e)` solves the Newtonian Binet
equation with constant `T / H²`. This is the formal counterpart of
"move Newton-with-Golden-constants into compression space and solve it
there." -/
theorem golden_binetConicSolution_isBinetSolution (e : ℝ) :
    IsBinetSolution T H (binetConicSolution T H e) :=
  binetConicSolution_isBinetSolution T H e

-- =========================================================================
-- Tier 91b — The "10-test gauntlet": central-force translation theorems
-- =========================================================================

/-! ### Generic central-force interface and the master Binet form

For a central force `F : ℝ → ℝ` (with `F r` being the *radial component*
of the force at distance `r`), the Binet form of the orbit equation is

`u'' + u = − F(1/u) / (h² · u²)`,

where `u = 1/r` is the compression coordinate and `h` is angular momentum
per unit mass. This is the master translation rule. Each known central-force
problem is a corollary obtained by substituting a specific `F`. -/

/-- A function `u : ℝ → ℝ` satisfies the general central-force Binet
equation for force `F`. -/
def SatisfiesBinet (F : ℝ → ℝ) (h : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ = - F (1 / u θ) / (h ^ 2 * (u θ) ^ 2)

/-- Newtonian inverse-square radial force `F(r) = − μ / r²`. -/
noncomputable def NewtonForce (μ r : ℝ) : ℝ := - μ / r ^ 2

/-- **Newton's gravity in compression coordinates is a forced linear
oscillator.** The master Binet form `u'' + u = − F(1/u)/(h² u²)`
specialises, for the Newton force `F(r) = − μ/r²`, to the constant-forced
oscillator `u'' + u = μ / h²`.

This is the algebraic content of "moving Newton into compression space
makes the equation linear." -/
theorem satisfiesBinet_newton_iff
    (μ h : ℝ) (u : ℝ → ℝ) (hh : h ≠ 0) (hu : ∀ θ, u θ ≠ 0) :
    SatisfiesBinet (NewtonForce μ) h u ↔ IsBinetSolution μ h u := by
  unfold SatisfiesBinet IsBinetSolution NewtonForce
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  -- For any θ with u θ ≠ 0: -(-(μ) / (1/u θ)^2) / (h^2 * u θ^2) = μ / h^2.
  have hrewrite : ∀ θ,
      -(-(μ) / (1 / u θ) ^ 2) / (h ^ 2 * u θ ^ 2) = μ / h ^ 2 := by
    intro θ
    have huθ : u θ ≠ 0 := hu θ
    have hu2 : (u θ) ^ 2 ≠ 0 := pow_ne_zero 2 huθ
    field_simp
    ring
  constructor
  · intro hsat θ
    have hθ := hsat θ
    rw [hrewrite θ] at hθ
    exact hθ
  · intro hbin θ
    rw [hrewrite θ]
    exact hbin θ

/-! ### Test 1 (already proved): Newton ellipse / Test 6 / Test 7 / Test 10

The unifying Lean object is the **polynomial compression family**. -/

/-- **Polynomial compression family.** A compact umbrella covering Newton,
weak-field GR, inverse-cube corrections, and photon bending all at once:

`u'' + u = A + B · u + C · u²`.

The traditional physics dictionary is:

| Setting               | A          | B          | C            |
|-----------------------|------------|------------|--------------|
| Newton                | `μ/h²`     | `0`        | `0`          |
| inverse-cube ⟨α⟩      | `μ/h²`     | `α/h²`     | `0`          |
| Weak-field GR         | `μ/h²`     | `0`        | `3μ/c²`      |
| Photon (Schwarzschild)| `0`        | `0`        | `3M`         |
-/
def IsPolynomialCompression (A B C : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ = A + B * (u θ) + C * (u θ) ^ 2

/-- **Newton is the `B = C = 0` member** of the polynomial-compression
family. -/
theorem isPolynomialCompression_newton_iff
    {μ h : ℝ} {u : ℝ → ℝ} :
    IsPolynomialCompression (μ / h ^ 2) 0 0 u ↔ IsBinetSolution μ h u := by
  unfold IsPolynomialCompression IsBinetSolution
  constructor
  · intro hu θ; have := hu θ; simpa using this
  · intro hu θ; have := hu θ; simpa using this

/-- The **weak-field GR Binet equation** in polynomial form: take
`A = μ/h²`, `B = 0`, `C = 3μ/c²`. -/
theorem isPolynomialCompression_gr_iff_relativistic
    {μ h c : ℝ} {u : ℝ → ℝ} :
    IsPolynomialCompression (μ / h ^ 2) 0 (3 * μ / c ^ 2) u
      ↔ IsRelativisticBinet μ h c u := by
  unfold IsPolynomialCompression IsRelativisticBinet
  constructor
  · intro hu θ; have := hu θ; simpa using this
  · intro hu θ; have := hu θ; simpa using this

/-! ### Test 7 — Inverse-cube correction (exactly solvable)

Force: `F(r) = − μ/r² − α/r³`.
In compression space: `u'' + (1 − α/h²) u = μ/h²`.
Solution: `u(θ) = C · (1 + e · cos(κ θ))` with `κ² = 1 − α/h²`.
Precession per orbit: `Δθ = 2π/κ − 2π`. -/

/-- The inverse-cube-corrected Binet equation
`u'' + (1 − α/h²) u = μ/h²`, in the form `u'' + κ² u = const`. -/
def IsInverseCubeBinet (μ h α : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + (1 - α / h ^ 2) * (u θ) = μ / h ^ 2

/-- The exactly-solvable inverse-cube compression solution:
`u(θ) = C · (1 + e · cos(κ θ))` with `κ² = 1 − α/h²`. The constant `C` is
the equilibrium compression `(μ/h²) / κ²`, equivalently `μ/(h² − α)`. -/
noncomputable def inverseCubeBinetSolution
    (μ h α e : ℝ) (θ : ℝ) : ℝ :=
  let κ := Real.sqrt (1 - α / h ^ 2)
  (μ / (h ^ 2 - α)) * (1 + e * Real.cos (κ * θ))

/-! ### Test 10 — Schwarzschild photon Binet equation

`u'' + u = 3 M u²` for a photon (no mass term `μ/h²`). -/

/-- Schwarzschild photon Binet equation: `u'' + u = 3 M u²`. -/
def IsPhotonBinet (M : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ = 3 * M * (u θ) ^ 2

/-- The photon Binet equation is the `A = 0, B = 0, C = 3M` member of the
polynomial-compression family. -/
theorem isPolynomialCompression_photon_iff_photonBinet
    {M : ℝ} {u : ℝ → ℝ} :
    IsPolynomialCompression 0 0 (3 * M) u ↔ IsPhotonBinet M u := by
  unfold IsPolynomialCompression IsPhotonBinet
  constructor
  · intro hu θ; have := hu θ; simpa using this
  · intro hu θ; have := hu θ; simpa using this

/-! ### Test 8 — Central harmonic oscillator

Force: `F(r) = − ω² r`. In compression space: `u'' + u = ω²/(h² u³)`. -/

/-- Central harmonic radial force `F(r) = − ω² r`. -/
noncomputable def HarmonicCentralForce (ω r : ℝ) : ℝ := - ω ^ 2 * r

/-- The Binet form of the central harmonic oscillator. -/
def IsHarmonicCentralBinet (ω h : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ = ω ^ 2 / (h ^ 2 * (u θ) ^ 3)

/-- **Central harmonic ↔ master Binet equivalence.** The harmonic Binet
equation is exactly the master form `u'' + u = − F(1/u)/(h² u²)`
specialised to `F = −ω² r`. -/
theorem satisfiesBinet_harmonic_iff
    (ω h : ℝ) (u : ℝ → ℝ) (hh : h ≠ 0) (hu : ∀ θ, u θ ≠ 0) :
    SatisfiesBinet (HarmonicCentralForce ω) h u ↔ IsHarmonicCentralBinet ω h u := by
  unfold SatisfiesBinet HarmonicCentralForce IsHarmonicCentralBinet
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  -- For any θ with u θ ≠ 0:  -(-(ω²) · (1/u))/(h² u²) = ω² / (h² u³).
  have hrewrite : ∀ θ,
      -(-(ω ^ 2) * (1 / u θ)) / (h ^ 2 * u θ ^ 2)
        = ω ^ 2 / (h ^ 2 * u θ ^ 3) := by
    intro θ
    have huθ : u θ ≠ 0 := hu θ
    have h_simp : -(-(ω ^ 2) * (1 / u θ)) = ω ^ 2 * (1 / u θ) := by ring
    rw [h_simp, mul_one_div, div_div]
    congr 1
    ring
  constructor
  · intro hsat θ
    have hθ := hsat θ
    rw [hrewrite θ] at hθ
    exact hθ
  · intro hbin θ
    rw [hrewrite θ]
    exact hbin θ

/-! ### Test 2 — Hyperbolic scattering asymptote

For `e > 1`, the conic compression `u(θ) = (μ/h²)(1 + e cos θ)` vanishes
at asymptotic angles satisfying `cos θ∞ = − 1/e`. -/

/-- **Hyperbolic asymptote.** For `μ ≠ 0` and `h ≠ 0`, the compression
`u(θ) = (μ/h²)(1 + e cos θ)` vanishes exactly when `1 + e cos θ = 0`,
i.e. `cos θ = −1/e` (for `e ≠ 0`). This is the algebraic content of
"the hyperbolic orbit goes to infinity along the asymptote." -/
theorem binetConicSolution_eq_zero_iff
    {μ h e θ : ℝ} (hμ : μ ≠ 0) (hh : h ≠ 0) :
    binetConicSolution μ h e θ = 0 ↔ 1 + e * Real.cos θ = 0 := by
  unfold binetConicSolution
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  have hμh : μ / h ^ 2 ≠ 0 := div_ne_zero hμ hh2
  constructor
  · intro h0
    exact (mul_eq_zero.mp h0).resolve_left hμh
  · intro h0
    rw [h0, mul_zero]

/-- **Asymptote angle formula.** Whenever `e ≠ 0` and `cos θ_inf = − 1/e`,
the compression at `θ_inf` is zero. -/
theorem binetConicSolution_zero_of_cos_eq_neg_inv
    {μ h e θ_inf : ℝ} (he : e ≠ 0) (hcos : Real.cos θ_inf = -1 / e) :
    binetConicSolution μ h e θ_inf = 0 := by
  unfold binetConicSolution
  rw [hcos]
  field_simp

/-! ### Test 9 — Uniform-density sphere gravity (flux/enclosed-mass form)

Inside a uniform sphere of radius `R` and total mass `M`:
`g(r) = G M r / R³`. Outside: `g(r) = G M / r²`.

Translation: define enclosed mass `M_enc(r) = M · (r/R)³` (inside) or `M`
(outside). Then in both cases `g(r) = G M_enc(r) / r²`. -/

/-- Enclosed mass of a uniform-density sphere with total mass `M` and
radius `R`, evaluated at distance `r`. -/
noncomputable def uniformSphereEnclosedMass (M R r : ℝ) : ℝ :=
  if r ≤ R then M * r ^ 3 / R ^ 3 else M

/-- The Newtonian gravitational field magnitude produced by the enclosed
mass at distance `r`: `g(r) = G · M_enc(r) / r²`. -/
noncomputable def uniformSphereField (G M R r : ℝ) : ℝ :=
  G * uniformSphereEnclosedMass M R r / r ^ 2

/-- **Inside the sphere.** For `0 < r ≤ R`:
`g(r) = G M r / R³`. -/
theorem uniformSphereField_inside
    {G M R r : ℝ} (hR_pos : 0 < R) (hr_pos : 0 < r) (hr_le : r ≤ R) :
    uniformSphereField G M R r = G * M * r / R ^ 3 := by
  unfold uniformSphereField uniformSphereEnclosedMass
  rw [if_pos hr_le]
  have hr2_ne : r ^ 2 ≠ 0 := pow_ne_zero 2 (ne_of_gt hr_pos)
  have hR3_ne : R ^ 3 ≠ 0 := pow_ne_zero 3 (ne_of_gt hR_pos)
  field_simp
  ring

/-- **Outside the sphere.** For `r > R`:
`g(r) = G M / r²`, the standard inverse-square law. -/
theorem uniformSphereField_outside
    {G M R r : ℝ} (hr_gt : R < r) :
    uniformSphereField G M R r = G * M / r ^ 2 := by
  unfold uniformSphereField uniformSphereEnclosedMass
  rw [if_neg (not_le.mpr hr_gt)]

/-- **Sphere boundary continuity.** The inside and outside formulas agree
at `r = R`. -/
theorem uniformSphereField_continuous_at_boundary
    {G M R : ℝ} (hR_pos : 0 < R) :
    G * M * R / R ^ 3 = G * M / R ^ 2 := by
  have hR_ne : R ≠ 0 := ne_of_gt hR_pos
  field_simp
  ring

/-! ### Test 5 — Vis-viva relation (algebraic identity in compression space)

For a Keplerian conic orbit with semi-major axis `a` and eccentricity `e`,
the speed at radius `r` satisfies `v² = μ (2/r − 1/a)`.

In compression coordinates the speed splits as
`v² = v_r² + v_θ² = (μ/h)² e² sin²θ + (h/r)²`. The vis-viva identity is
then a pure trig/algebra consequence of `cos² + sin² = 1` plus
`p = h²/μ = a(1 − e²)`.

We record the algebraic identity at the conic level; the kinematic
labelling is conventional. -/

/-- **Vis-viva trigonometric core.** Using `sin² + cos² = 1`,
`e² sin²θ + (1 + e cos θ)² = 1 + 2 e cos θ + e²`.
This is the trigonometric identity that converts compression-space
`v_r² + v_θ²` into the vis-viva form. -/
theorem vis_viva_trig_core (e θ : ℝ) :
    e ^ 2 * (Real.sin θ) ^ 2 + (1 + e * Real.cos θ) ^ 2
      = 1 + 2 * e * Real.cos θ + e ^ 2 := by
  have hsincos : (Real.sin θ) ^ 2 + (Real.cos θ) ^ 2 = 1 :=
    Real.sin_sq_add_cos_sq θ
  nlinarith [hsincos]

/-- **Vis-viva orbital-parameter identity.** When `h² / μ = a (1 − e²)`
(the orbit-parameter / semi-latus-rectum relation), the two sides of the
vis-viva equation agree after using the trigonometric core.

Concretely: with the conic substitution `r := (h²/μ) / (1 + e cos θ)`,
the speed-squared `(μ²/h²)(1 + 2 e cos θ + e²)` equals
`μ (2/r − 1/a)`. -/
theorem vis_viva_relation_speed_form
    {μ h e a θ : ℝ}
    (_hμ : μ ≠ 0) (hh : h ≠ 0) (ha : a ≠ 0)
    (_hden : 1 + e * Real.cos θ ≠ 0)
    (hp : h ^ 2 = a * (1 - e ^ 2) * μ) :
    (μ ^ 2 / h ^ 2) * (1 + 2 * e * Real.cos θ + e ^ 2)
      = μ * (2 * (1 + e * Real.cos θ) * μ / h ^ 2 - 1 / a) := by
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  -- Use `hp` to rewrite `1 / a` as `μ * (1 - e²) / h²`.
  have h_one_div_a : 1 / a = μ * (1 - e ^ 2) / h ^ 2 := by
    rw [eq_div_iff hh2]
    field_simp
    linarith [hp]
  rw [h_one_div_a]
  field_simp
  ring

/-! ### Tests 3 and 4 — Parabolic time-of-flight, Kepler's third law

These require integral calculus over the conic orbit and a known
trigonometric integral
`∫₀^{2π} dθ / (1 + e cos θ)² = 2π / (1 − e²)^{3/2}`.

They are recorded here as future targets, not Lean theorems. -/

/-- The areal-rate kinematic identity `dt/dθ = r² / h` is the
constant-of-motion form of angular momentum. Recorded as a `Prop`-level
interface; the substantive integration theorems
(Barker's equation, Kepler's third law) depend on calculus infrastructure
beyond the scope of this section. -/
def IsAreallyKeplerian (h : ℝ) (r : ℝ → ℝ) (t : ℝ → ℝ) : Prop :=
  ∀ θ, deriv t θ = (r θ) ^ 2 / h

end BinetTranslation

/-!
## Tier 92 — N-body Shape / Compression Space

This tier extends the Binet translation from single-particle central
motion to the n-body setting. The translation moves Newtonian gravity

`q̈ᵢ = G · Σⱼ≠ᵢ mⱼ (qⱼ − qᵢ) / |qⱼ − qᵢ|³`

into **pair-compression** coordinates `u_{ij} = 1 / |qᵢ − qⱼ|`, where
gravity is built from terms of the form `u_{ij}³ · (qⱼ − qᵢ)`.

The headline structural facts:

* **Pair-compression form.** Gravity is `G · Σⱼ≠ᵢ mⱼ · u_{ij}³ · (qⱼ − qᵢ)`.
* **Central configurations.** Shape solutions in which every body's
  acceleration points exactly at a common centre `C`,
  `q̈ᵢ = −λ (qᵢ − C)`. These give exact rotating n-body orbits.
* **Rotation/translation equivariance** of the gravitational force.
* **L₄/L₅ linear stability** in the restricted three-body problem
  reduces to the algebraic inequality `μ(1 − μ) < 1/27`.
* **Distance / triangle realizability** as constraint predicates,
  underwriting the "shape space" interpretation.
* **Compression choreography ansatz** for the equal-mass figure-eight:
  one scalar waveform `u : ℝ → ℝ` plus the two phase-shifted copies
  `u(t − T/3)`, `u(t + T/3)`.

This is the n-body analogue of `BinetTranslation`: "move into pair-compression
space, do shape algebra there, map back to Newton orbits."
-/

section NBodyCompression

-- =========================================================================
-- Polynomial compression force law (extends `IsPolynomialCompression`
-- with a cubic term, and proves the explicit physical-space force form)
-- =========================================================================

/-- **Polynomial compression law** (degree-3 extension of
`IsPolynomialCompression`).

`u'' + u = A + B u + C u² + D u³`. -/
def IsPolynomialCompression4 (A B C D : ℝ) (u : ℝ → ℝ) : Prop :=
  ∀ θ, deriv (deriv u) θ + u θ
        = A + B * (u θ) + C * (u θ) ^ 2 + D * (u θ) ^ 3

/-- **Inverse-power physical-space force** corresponding to the
degree-3 polynomial compression law:

`F(r) = − h² · (A/r² + B/r³ + C/r⁴ + D/r⁵)`. -/
noncomputable def inversePowerForce
    (A B C D h r : ℝ) : ℝ :=
  - h ^ 2 * (A / r ^ 2 + B / r ^ 3 + C / r ^ 4 + D / r ^ 5)

/-- **Compression ↔ physical-space dictionary** (key calculation).
For `r := 1 / u θ` with `u θ ≠ 0`, the right-hand side of the master
Binet form `−F(1/u) / (h² u²)` for the inverse-power force equals
`A + B u + C u² + D u³`.

This is the algebraic content of "polynomial compression in `u`
↔ inverse-power force in `r`." -/
theorem master_binet_inversePower_iff_polynomial
    (A B C D h : ℝ) (u : ℝ → ℝ) (hh : h ≠ 0) (hu : ∀ θ, u θ ≠ 0) :
    SatisfiesBinet (inversePowerForce A B C D h) h u
      ↔ IsPolynomialCompression4 A B C D u := by
  unfold SatisfiesBinet inversePowerForce IsPolynomialCompression4
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  have hrewrite : ∀ θ,
      -(-h ^ 2 *
          (A / (1 / u θ) ^ 2 + B / (1 / u θ) ^ 3
            + C / (1 / u θ) ^ 4 + D / (1 / u θ) ^ 5))
        / (h ^ 2 * u θ ^ 2)
      = A + B * (u θ) + C * (u θ) ^ 2 + D * (u θ) ^ 3 := by
    intro θ
    have huθ : u θ ≠ 0 := hu θ
    have hu2 : (u θ) ^ 2 ≠ 0 := pow_ne_zero 2 huθ
    field_simp
    ring
  constructor
  · intro hsat θ
    have hθ := hsat θ
    rw [hrewrite θ] at hθ
    exact hθ
  · intro hpoly θ
    rw [hrewrite θ]
    exact hpoly θ

/-! ### Newton, GR, inverse-cube, photon as polynomial-compression cases -/

/-- **Newton specialisation.** `A = μ/h², B = C = D = 0` gives the
inverse-square Newton force `F(r) = − μ / r²` and the linear Binet equation
`u'' + u = μ/h²`. -/
theorem inversePowerForce_newton
    (μ h r : ℝ) (hh : h ≠ 0) (hr : r ≠ 0) :
    inversePowerForce (μ / h ^ 2) 0 0 0 h r = -μ / r ^ 2 := by
  unfold inversePowerForce
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  have hr2 : r ^ 2 ≠ 0 := pow_ne_zero 2 hr
  field_simp
  ring

/-- **Inverse-cube correction.** `A = μ/h², B = α/h², C = D = 0` gives the
inverse-cube-corrected force `F(r) = − μ/r² − α/r³`. -/
theorem inversePowerForce_inverseCube
    (μ α h r : ℝ) (hh : h ≠ 0) (hr : r ≠ 0) :
    inversePowerForce (μ / h ^ 2) (α / h ^ 2) 0 0 h r
      = -μ / r ^ 2 - α / r ^ 3 := by
  unfold inversePowerForce
  have hr2 : r ^ 2 ≠ 0 := pow_ne_zero 2 hr
  have hr3 : r ^ 3 ≠ 0 := pow_ne_zero 3 hr
  field_simp
  ring

/-- **Weak-field GR correction.** `A = μ/h², B = 0, C = 3μ/c², D = 0`
gives the GR-corrected force `F(r) = − μ/r² − 3μ h² / (c² r⁴)`. -/
theorem inversePowerForce_grWeakField
    (μ c h r : ℝ) (hh : h ≠ 0) (hr : r ≠ 0) :
    inversePowerForce (μ / h ^ 2) 0 (3 * μ / c ^ 2) 0 h r
      = -μ / r ^ 2 - 3 * μ * h ^ 2 / (c ^ 2 * r ^ 4) := by
  unfold inversePowerForce
  have hr2 : r ^ 2 ≠ 0 := pow_ne_zero 2 hr
  have hr4 : r ^ 4 ≠ 0 := pow_ne_zero 4 hr
  field_simp
  ring

/-- **Photon (Schwarzschild light-bending) correspondence.**
`A = 0, B = 0, C = 3M, D = 0` gives `F(r) = − 3 M h² / r⁴`. -/
theorem inversePowerForce_photon
    (M h r : ℝ) (hr : r ≠ 0) :
    inversePowerForce 0 0 (3 * M) 0 h r
      = -3 * M * h ^ 2 / r ^ 4 := by
  unfold inversePowerForce
  have hr4 : r ^ 4 ≠ 0 := pow_ne_zero 4 hr
  field_simp
  ring

-- =========================================================================
-- N-body gravitational acceleration in pair-compression form
-- =========================================================================

/-- **Newtonian gravitational acceleration** of body `i` in an N-body
system. Bodies are points in `ℂ ≅ ℝ²`; `m` are the masses; `G` is the
gravitational constant. -/
noncomputable def gravitationalAcceleration
    {N : ℕ} (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ) (i : Fin N) : ℂ :=
  (G : ℂ) * ∑ j : Fin N, if j = i then 0
    else ((m j : ℂ) * (q j - q i)) / ((‖q j - q i‖ ^ 3 : ℝ) : ℂ)

/-- **Pair-compression coordinate** `u_{ij} = 1 / |qᵢ − qⱼ|`. -/
noncomputable def pairCompression
    {N : ℕ} (q : Fin N → ℂ) (i j : Fin N) : ℝ :=
  1 / ‖q i - q j‖

/-- Pair compression is symmetric under index swap: `u_{ij} = u_{ji}`. -/
theorem pairCompression_symm
    {N : ℕ} (q : Fin N → ℂ) (i j : Fin N) :
    pairCompression q i j = pairCompression q j i := by
  unfold pairCompression
  rw [norm_sub_rev]

/-- **Translation invariance** of the gravitational acceleration:
shifting all bodies by a common vector leaves the acceleration unchanged. -/
theorem gravitationalAcceleration_translation_invariant
    {N : ℕ} (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ)
    (c : ℂ) (i : Fin N) :
    gravitationalAcceleration (fun j => q j + c) m G i
      = gravitationalAcceleration q m G i := by
  unfold gravitationalAcceleration
  congr 1
  refine Finset.sum_congr rfl (fun j _ => ?_)
  split_ifs with hij
  · rfl
  · have hdiff : (q j + c) - (q i + c) = q j - q i := by ring
    rw [hdiff]

/-- **Rotation equivariance** of the gravitational acceleration:
rotating all bodies by a complex phase `e^{iφ}` rotates each acceleration
by the same phase. -/
theorem gravitationalAcceleration_rotation_equivariant
    {N : ℕ} (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ)
    (φ : ℝ) (i : Fin N) :
    gravitationalAcceleration
        (fun j => Complex.exp ((φ : ℂ) * I) * q j) m G i
      = Complex.exp ((φ : ℂ) * I) *
          gravitationalAcceleration q m G i := by
  unfold gravitationalAcceleration
  set α : ℂ := Complex.exp ((φ : ℂ) * I) with hα
  -- Show each summand of the rotated sum equals α times the original summand.
  have hterm : ∀ j : Fin N,
      (if j = i then (0 : ℂ)
       else ((m j : ℂ) * (α * q j - α * q i))
              / ((‖α * q j - α * q i‖ ^ 3 : ℝ) : ℂ))
        = α * (if j = i then (0 : ℂ)
               else ((m j : ℂ) * (q j - q i))
                      / ((‖q j - q i‖ ^ 3 : ℝ) : ℂ)) := by
    intro j
    split_ifs with hij
    · ring
    · have hdiff : α * q j - α * q i = α * (q j - q i) := by ring
      rw [hdiff]
      have hnorm : ‖α * (q j - q i)‖ = ‖q j - q i‖ := by
        rw [hα, norm_mul, norm_exp_ofReal_mul_I, one_mul]
      rw [hnorm]
      ring
  -- Rewrite the LHS sum term-by-term.
  rw [Finset.sum_congr rfl (fun j _ => hterm j)]
  -- Now both sides have shape (G : ℂ) * Σ_j (α * term_j); algebra closes.
  rw [← Finset.mul_sum]
  ring

-- =========================================================================
-- Central configurations
-- =========================================================================

/-- **Central configuration.** A configuration `(q, m)` is a central
configuration with centre `C` and shape constant `λ` if the gravitational
acceleration of every body points toward `C` with strength proportional
to displacement:

`accel_i = − λ (qᵢ − C)`.

When this holds, the N-body system admits an exact uniformly-rotating
orbit `qᵢ(t) = C + e^{iωt} (qᵢ(0) − C)` with `ω² = λ`. -/
def IsCentralConfiguration
    {N : ℕ} (q : Fin N → ℂ) (m : Fin N → ℝ) (G : ℝ)
    (center : ℂ) (lambda : ℝ) : Prop :=
  ∀ i, gravitationalAcceleration q m G i
        = -(lambda : ℂ) * (q i - center)

/-- **Rotating orbit** generated by a configuration: each body moves on a
circle of radius `|qᵢ − C|` about `C` with angular frequency `ω`. -/
noncomputable def rotatingOrbit
    {N : ℕ} (center : ℂ) (q0 : Fin N → ℂ) (ω t : ℝ) (i : Fin N) : ℂ :=
  center + Complex.exp ((ω * t : ℝ) * I) * (q0 i - center)

@[simp]
theorem rotatingOrbit_zero
    {N : ℕ} (center : ℂ) (q0 : Fin N → ℂ) (ω : ℝ) (i : Fin N) :
    rotatingOrbit center q0 ω 0 i = q0 i := by
  unfold rotatingOrbit
  simp

/-- The rotating orbit preserves each body's distance to the centre. -/
theorem rotatingOrbit_norm_preserved
    {N : ℕ} (center : ℂ) (q0 : Fin N → ℂ) (ω t : ℝ) (i : Fin N) :
    ‖rotatingOrbit center q0 ω t i - center‖ = ‖q0 i - center‖ := by
  unfold rotatingOrbit
  rw [add_sub_cancel_left, norm_mul, norm_exp_ofReal_mul_I, one_mul]

/-- **Central-config rotating-orbit identity.** If `q0` is a central
configuration with constant `λ`, then at every time `t` the rotated
configuration satisfies

`gravitationalAcceleration (rotating(t)) = −λ · (rotating(t) i − C)`.

Together with `ω² = λ`, this matches the second time-derivative
`d²/dt² rotating(t) = −ω² · (rotating(t) i − C)`, certifying the
rotating orbit as a Newton solution. The second-derivative side is
recorded as a separate ODE theorem; this lemma is the structural
shape-side fact. -/
theorem central_config_rotated_acceleration
    {N : ℕ} {q0 : Fin N → ℂ} {m : Fin N → ℝ} {G : ℝ}
    {center : ℂ} {lambda : ℝ}
    (hcc : IsCentralConfiguration q0 m G center lambda)
    (ω t : ℝ) (i : Fin N) :
    gravitationalAcceleration
        (fun j => rotatingOrbit center q0 ω t j) m G i
      = -(lambda : ℂ) *
          ((rotatingOrbit center q0 ω t i) - center) := by
  unfold rotatingOrbit
  set α : ℂ := Complex.exp ((ω * t : ℝ) * I) with hα
  -- Step 1: translation invariance — shift the (center + ...) form to (... + center).
  have hfun1 :
      (fun j => center + α * (q0 j - center))
        = (fun j => α * (q0 j - center) + center) := by
    funext j; ring
  rw [hfun1]
  rw [gravitationalAcceleration_translation_invariant
        (fun j => α * (q0 j - center)) m G center i]
  -- Step 2: rotation equivariance — factor α out.
  rw [gravitationalAcceleration_rotation_equivariant
        (fun j => q0 j - center) m G (ω * t) i]
  -- Step 3: translation invariance again — re-absorb the centre.
  have hfun2 :
      (fun j => q0 j - center) = (fun j => q0 j + (-center)) := by
    funext j; ring
  rw [hfun2]
  rw [gravitationalAcceleration_translation_invariant q0 m G (-center) i]
  -- Step 4: apply the central-configuration hypothesis.
  rw [hcc i]
  -- Goal: α * (-(lambda : ℂ) * (q0 i - center))
  --       = -(lambda : ℂ) * ((center + α * (q0 i - center)) - center)
  ring

-- =========================================================================
-- Restricted three-body L₄/L₅ stability characterisation
-- =========================================================================

/-- **L₄/L₅ linear stability characterisation** (Routh's criterion,
algebraic form). For the restricted three-body problem with mass ratio
`μ ∈ (0, 1)`, the triangular Lagrange points are linearly stable iff

`μ (1 − μ) < 1/27`,

equivalently `μ < μ_crit = (1 − √(69)/9) / 2 ≈ 0.0385208965`.

We record the algebraic predicate; the spectral derivation (which
turns the rotating-frame linearisation into a quartic characteristic
polynomial) is the standard reference computation. -/
def L4L5_LinearlyStable (μ : ℝ) : Prop :=
  μ * (1 - μ) < 1 / 27

/-- The critical mass ratio `μ_crit = (1 − √(69)/9) / 2`. -/
noncomputable def lagrangeL4L5CriticalMu : ℝ :=
  (1 - Real.sqrt 69 / 9) / 2

theorem lagrangeL4L5CriticalMu_pos :
    0 < lagrangeL4L5CriticalMu := by
  unfold lagrangeL4L5CriticalMu
  -- 1 - sqrt 69 / 9 > 0 iff sqrt 69 < 9 iff 69 < 81
  have h69 : Real.sqrt 69 < 9 := by
    have hsq : (Real.sqrt 69) ^ 2 < (9 : ℝ) ^ 2 := by
      rw [Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 69)]
      norm_num
    nlinarith [Real.sqrt_nonneg (69 : ℝ)]
  linarith

-- =========================================================================
-- Distance-realizability and triangle inequalities
-- =========================================================================

/-- A symmetric distance "matrix" `d : Fin N → Fin N → ℝ` is
**Euclidean-realizable in the plane** if there exist 2D points
(here, complex numbers) reproducing all pairwise distances. -/
def IsDistanceRealizable
    {N : ℕ} (d : Fin N → Fin N → ℝ) : Prop :=
  ∃ q : Fin N → ℂ, ∀ i j, ‖q i - q j‖ = d i j

/-- **Triangle inequalities.** Necessary condition for three positive
distances `a, b, c` to come from three points in any metric space. -/
def TriangleInequalities (a b c : ℝ) : Prop :=
  a + b ≥ c ∧ b + c ≥ a ∧ c + a ≥ b

/-- For an actual triple of points, the side lengths automatically satisfy
the triangle inequalities. -/
theorem triangleInequalities_of_points (z1 z2 z3 : ℂ) :
    TriangleInequalities ‖z1 - z2‖ ‖z2 - z3‖ ‖z3 - z1‖ := by
  unfold TriangleInequalities
  refine ⟨?_, ?_, ?_⟩
  · -- ‖z3 - z1‖ ≤ ‖z1 - z2‖ + ‖z2 - z3‖
    rw [show ‖z3 - z1‖ = ‖z1 - z3‖ from norm_sub_rev z3 z1]
    have heq : z1 - z3 = (z1 - z2) + (z2 - z3) := by ring
    rw [heq]
    exact norm_add_le _ _
  · -- ‖z1 - z2‖ ≤ ‖z2 - z3‖ + ‖z3 - z1‖
    rw [show ‖z1 - z2‖ = ‖z2 - z1‖ from norm_sub_rev z1 z2]
    have heq : z2 - z1 = (z2 - z3) + (z3 - z1) := by ring
    rw [heq]
    exact norm_add_le _ _
  · -- ‖z2 - z3‖ ≤ ‖z3 - z1‖ + ‖z1 - z2‖
    rw [show ‖z2 - z3‖ = ‖z3 - z2‖ from norm_sub_rev z2 z3]
    have heq : z3 - z2 = (z3 - z1) + (z1 - z2) := by ring
    rw [heq]
    exact norm_add_le _ _

-- =========================================================================
-- Compression choreography ansatz (figure-eight target structure)
-- =========================================================================

/-- **Compression choreography ansatz.** A single scalar compression
waveform `u : ℝ → ℝ` of period `T`, plus the two phase-shifted copies
`u(t − T/3)` and `u(t + T/3)` representing the other two pair distances.

This is the structural ansatz the user-side Python experiments suggest
for the equal-mass three-body figure-eight orbit: one scalar function
plus the discrete `ℤ/3` symmetry of the choreography. -/
structure CompressionChoreographyAnsatz where
  T : ℝ
  T_pos : 0 < T
  u : ℝ → ℝ
  u_pos : ∀ t, 0 < u t
  u_periodic : Function.Periodic u T

namespace CompressionChoreographyAnsatz

variable (A : CompressionChoreographyAnsatz)

/-- Pair distance `r_{12}(t) = 1 / u(t)`. -/
noncomputable def side12 (t : ℝ) : ℝ := 1 / A.u t

/-- Pair distance `r_{23}(t) = 1 / u(t − T/3)`. -/
noncomputable def side23 (t : ℝ) : ℝ := 1 / A.u (t - A.T / 3)

/-- Pair distance `r_{31}(t) = 1 / u(t + T/3)`. -/
noncomputable def side31 (t : ℝ) : ℝ := 1 / A.u (t + A.T / 3)

/-- Choreography sides are positive for every `t`. -/
theorem side12_pos (t : ℝ) : 0 < A.side12 t := by
  unfold side12; exact div_pos one_pos (A.u_pos t)

theorem side23_pos (t : ℝ) : 0 < A.side23 t := by
  unfold side23; exact div_pos one_pos (A.u_pos _)

theorem side31_pos (t : ℝ) : 0 < A.side31 t := by
  unfold side31; exact div_pos one_pos (A.u_pos _)

/-- The choreography sides are periodic with the same period `T`. -/
theorem side12_periodic : Function.Periodic A.side12 A.T := by
  intro t
  unfold side12
  rw [A.u_periodic t]

theorem side23_periodic : Function.Periodic A.side23 A.T := by
  intro t
  unfold side23
  have : t + A.T - A.T / 3 = (t - A.T / 3) + A.T := by ring
  rw [this, A.u_periodic]

theorem side31_periodic : Function.Periodic A.side31 A.T := by
  intro t
  unfold side31
  have : t + A.T + A.T / 3 = (t + A.T / 3) + A.T := by ring
  rw [this, A.u_periodic]

end CompressionChoreographyAnsatz

-- =========================================================================
-- Bridge: Golden ⇄ Newton shape parallel
-- =========================================================================

/-- **Golden ↔ Newton shape parallel** (interface). Both systems possess
"shape equilibria" — special configurations whose dynamics reduce to
algebra:

* **Newton:** central configurations `q̈ᵢ = −λ(qᵢ − C)` give rotating
  orbits with `ω² = λ`. Existence is structural; the regular `N`-gon
  achieves `λ_N = (1/4) Σ_{k=1}^{N-1} csc(πk/N)`.
* **Golden:** the radial Golden n-body system has finite static
  equilibrium polygons of radius `R_N = H · √((N−1)/(2TN))` — no rotation
  needed.

So Newtonian gravity needs rotation to balance collapse, while the Golden
radial system has a built-in preferred radius. The "frustration"
interpretation: Newton balances collapse with angular motion; Golden
balances collapse with unit/log-repulsion pressure. -/
def IsGoldenNewtonShapeParallel (_N : ℕ) (R_golden : ℝ) (lambda_newton : ℝ) :
    Prop :=
  R_golden > 0 ∧ lambda_newton > 0

/-- The Newtonian regular-`N`-gon shape constant
`λ_N = (1/4) · Σ_{k=1}^{N-1} csc(π k / N)`. -/
noncomputable def newtonRegularPolygonLambda (N : ℕ) : ℝ :=
  (1 / 4 : ℝ) *
    ∑ k ∈ Finset.Ico 1 N, 1 / Real.sin (Real.pi * (k : ℝ) / (N : ℝ))

end NBodyCompression

/-!
## Tier 93 — Unified Operator Grammar

Across the previous tiers a pattern has emerged: many parts of physics
become structurally simpler in **transformed (compression / swirl /
spectral) space**. This tier records the corresponding *operator
grammar* — the menu of building blocks the user-side 10-test gauntlet
turned up.

| Physics              | Operator / transformed form                           |
|----------------------|-------------------------------------------------------|
| Gravity / Coulomb    | compression `u = 1/r` — inverse-square ⇔ linear Binet |
| Magnetism            | swirl: multiplication by `i ω` — pure rotation       |
| Electromagnetism     | Lorentz: `E + i B v` — push + swirl                  |
| Heat / diffusion     | spectral decay: `exp(−α k² t)` per Fourier mode      |
| Quantum (box / QHO)  | eigenvalue ladder                                     |
| Quantum (hydrogen)   | inverse-square spectrum: `Eₙ = − 1/(2n²)`             |
| Strong (Yukawa)      | screened compression: `exp(−r/a) / r`                 |
| Weak / decay         | first-order transition: `Ṅ = −λ N`                    |
| Waves / light        | second-order mode: `Ä = −(ck)² A` per mode            |

The unification this layer formalises is **not** "one new force law"
but "one operator grammar in transformed space." Each row above is
recorded as a named Lean object together with the easiest provable
algebraic statement (norm preservation, exponential / sine derivative,
eigenmode predicate, etc.). Deeper PDE / spectral theorems are stated
as `Prop`-level interfaces.
-/

section GoldenPhysicsOperators

-- =========================================================================
-- Test 1 — Coulomb force / inverse-square Binet (same as Newton, sign-flipped)
-- =========================================================================

/-- **Coulomb / inverse-square radial force.** `F(r) = k / r²`.
For attractive gravity, `k < 0` (e.g. `k = −μ`); for repulsive Coulomb
between like charges, `k > 0`. -/
noncomputable def CoulombForce (k r : ℝ) : ℝ := k / r ^ 2

/-- **Coulomb / Newton inverse-square ↔ linear Binet equivalence.**
`u'' + u = − k / h²` exactly captures the inverse-square law in
compression coordinates. (Gravity = `k = − μ` gives the familiar
`u'' + u = μ/h²`; repulsive Coulomb just flips the sign.) -/
theorem satisfiesBinet_coulomb_iff
    (k h : ℝ) (u : ℝ → ℝ) (hh : h ≠ 0) (hu : ∀ θ, u θ ≠ 0) :
    SatisfiesBinet (CoulombForce k) h u
      ↔ ∀ θ, deriv (deriv u) θ + u θ = -k / h ^ 2 := by
  unfold SatisfiesBinet CoulombForce
  have hh2 : h ^ 2 ≠ 0 := pow_ne_zero 2 hh
  have hrewrite : ∀ θ,
      -(k / (1 / u θ) ^ 2) / (h ^ 2 * u θ ^ 2) = -k / h ^ 2 := by
    intro θ
    have huθ : u θ ≠ 0 := hu θ
    have hu2 : (u θ) ^ 2 ≠ 0 := pow_ne_zero 2 huθ
    field_simp
    ring
  constructor
  · intro hsat θ
    have hθ := hsat θ
    rw [hrewrite θ] at hθ
    exact hθ
  · intro hbin θ
    rw [hrewrite θ]
    exact hbin θ

/-- **Rutherford deflection formula** (closed form).
`δ = 2 · arctan(k / (v² b))` for impact parameter `b` and speed `v`. -/
noncomputable def RutherfordDeflection (k v b : ℝ) : ℝ :=
  2 * Real.arctan (k / (v ^ 2 * b))

-- =========================================================================
-- Test 2 — Magnetism as swirl
-- =========================================================================

/-- **Swirl operator.** Multiplication by `i ω` in `ℂ ≅ ℝ²` is exactly
the infinitesimal rotation `v ↦ ω v⊥`. This is the algebraic shape of
the magnetic / Lorentz transverse force `dv/dt = iωv`. -/
noncomputable def swirl (ω : ℝ) (v : ℂ) : ℂ := (ω : ℂ) * I * v

/-- The swirl operator is `ℝ`-linear in `v`. -/
theorem swirl_add (ω : ℝ) (v w : ℂ) :
    swirl ω (v + w) = swirl ω v + swirl ω w := by
  unfold swirl; ring

theorem swirl_smul_real (ω : ℝ) (c : ℝ) (v : ℂ) :
    swirl ω ((c : ℂ) * v) = (c : ℂ) * swirl ω v := by
  unfold swirl; ring

/-- **Swirl orbit norm-preservation.** The orbit `v(t) := v₀ · e^{iωt}`
generated by pure-swirl dynamics keeps `‖v(t)‖ = ‖v₀‖` for every `t`.
This is the algebraic core of "uniform magnetic motion is uniform
circular motion": the magnitude is a conserved quantity. -/
theorem magnetic_swirl_orbit_norm
    (ω : ℝ) (v0 : ℂ) (t : ℝ) :
    ‖v0 * Complex.exp ((ω * t : ℝ) * I)‖ = ‖v0‖ := by
  rw [norm_mul, norm_exp_ofReal_mul_I, mul_one]

-- =========================================================================
-- Test 3 — Lorentz operator (E + iBv)
-- =========================================================================

/-- **Lorentz operator (2D).** `v ↦ E + i B v`. Combines an electric
"push" with a magnetic swirl. The homogeneous part is the magnetic
operator `swirl B`; the inhomogeneous part is the constant electric drift `E`. -/
noncomputable def LorentzOperator (E : ℂ) (B : ℝ) (v : ℂ) : ℂ :=
  E + (B : ℂ) * I * v

/-- The Lorentz operator with `E = 0` is exactly the swirl operator. -/
theorem LorentzOperator_E_zero (B : ℝ) (v : ℂ) :
    LorentzOperator 0 B v = swirl B v := by
  unfold LorentzOperator swirl
  ring

/-- The Lorentz operator with `B = 0` is the constant push `E`. -/
theorem LorentzOperator_B_zero (E : ℂ) (v : ℂ) :
    LorentzOperator E 0 v = E := by
  unfold LorentzOperator
  simp

-- =========================================================================
-- Test 4 — Heat as spectral decay
-- =========================================================================

/-- **Heat eigenmode amplitude.** `a_k(t) = exp(−(α k²) t)`, the
time-decay of one Fourier mode under the heat equation `u_t = α u_xx`. -/
noncomputable def heatMode (α k t : ℝ) : ℝ := Real.exp (-(α * k ^ 2) * t)

/-- The heat-eigenmode amplitude satisfies the first-order decay ODE
`a' = −(α k²) · a`. -/
theorem hasDerivAt_heatMode (α k t : ℝ) :
    HasDerivAt (fun s => heatMode α k s)
      (-(α * k ^ 2) * heatMode α k t) t := by
  unfold heatMode
  have h1 : HasDerivAt (fun s : ℝ => -(α * k ^ 2) * s) (-(α * k ^ 2)) t := by
    simpa using (hasDerivAt_id t).const_mul (-(α * k ^ 2))
  have h2 : HasDerivAt (fun s : ℝ => Real.exp (-(α * k ^ 2) * s))
              (Real.exp (-(α * k ^ 2) * t) * (-(α * k ^ 2))) t :=
    (Real.hasDerivAt_exp (-(α * k ^ 2) * t)).comp t h1
  convert h2 using 1
  ring

-- =========================================================================
-- Test 5 — Particle-in-a-box energies
-- =========================================================================

/-- **Particle-in-a-box quantum energies.** `Eₙ = n² π² / 2`
(in natural units `ℏ = m = L = 1`). -/
noncomputable def ParticleBoxEnergy (n : ℕ) : ℝ :=
  (n : ℝ) ^ 2 * Real.pi ^ 2 / 2

theorem ParticleBoxEnergy_nonneg (n : ℕ) : 0 ≤ ParticleBoxEnergy n := by
  unfold ParticleBoxEnergy
  positivity

theorem ParticleBoxEnergy_strictMono :
    ∀ ⦃n m : ℕ⦄, n < m → ParticleBoxEnergy n < ParticleBoxEnergy m := by
  intro n m hnm
  unfold ParticleBoxEnergy
  have hpi : 0 < Real.pi ^ 2 := pow_pos Real.pi_pos 2
  have hnm_R : (n : ℝ) < (m : ℝ) := by exact_mod_cast hnm
  have hn_nn : (0 : ℝ) ≤ (n : ℝ) := Nat.cast_nonneg n
  have hnm_sq : (n : ℝ) ^ 2 < (m : ℝ) ^ 2 := by nlinarith
  nlinarith [hnm_sq, hpi]

-- =========================================================================
-- Test 6 — Quantum harmonic oscillator ladder
-- =========================================================================

/-- **QHO energy ladder.** `Eₙ = n + 1/2` (natural units). -/
noncomputable def QHO_Energy (n : ℕ) : ℝ := (n : ℝ) + 1 / 2

theorem QHO_Energy_zero : QHO_Energy 0 = 1 / 2 := by
  unfold QHO_Energy
  simp

theorem QHO_Energy_succ (n : ℕ) :
    QHO_Energy (n + 1) = QHO_Energy n + 1 := by
  unfold QHO_Energy
  push_cast
  ring

/-- The QHO ladder spacing is uniform: `Eₙ₊₁ − Eₙ = 1`. -/
theorem QHO_Energy_diff (n : ℕ) :
    QHO_Energy (n + 1) - QHO_Energy n = 1 := by
  rw [QHO_Energy_succ]; ring

-- =========================================================================
-- Test 7 — Hydrogen-atom spectrum
-- =========================================================================

/-- **Hydrogen `s`-orbital energies.** `Eₙ = − 1 / (2 n²)` for `n ≥ 1`. -/
noncomputable def HydrogenEnergy (n : ℕ) : ℝ := -1 / (2 * (n : ℝ) ^ 2)

theorem HydrogenEnergy_neg {n : ℕ} (hn : 1 ≤ n) : HydrogenEnergy n < 0 := by
  unfold HydrogenEnergy
  have hn_pos : (0 : ℝ) < (n : ℝ) := by exact_mod_cast hn
  have hn2_pos : (0 : ℝ) < (n : ℝ) ^ 2 := pow_pos hn_pos 2
  have h2n2_pos : (0 : ℝ) < 2 * (n : ℝ) ^ 2 := by linarith
  exact div_neg_of_neg_of_pos (by norm_num : (-1 : ℝ) < 0) h2n2_pos

/-- The hydrogen spectrum is monotonically increasing (less negative) in `n`. -/
theorem HydrogenEnergy_strictMono :
    ∀ ⦃n m : ℕ⦄, 1 ≤ n → n < m → HydrogenEnergy n < HydrogenEnergy m := by
  intro n m hn hnm
  unfold HydrogenEnergy
  have hn_pos : (0 : ℝ) < (n : ℝ) := by exact_mod_cast hn
  have hnm_R : (n : ℝ) < (m : ℝ) := by exact_mod_cast hnm
  have hm_pos : (0 : ℝ) < (m : ℝ) := lt_trans hn_pos hnm_R
  have hn2 : (0 : ℝ) < (n : ℝ) ^ 2 := pow_pos hn_pos 2
  have hm2 : (0 : ℝ) < (m : ℝ) ^ 2 := pow_pos hm_pos 2
  have hnm_sq : (n : ℝ) ^ 2 < (m : ℝ) ^ 2 := by nlinarith
  have h2n2 : (0 : ℝ) < 2 * (n : ℝ) ^ 2 := by linarith
  have h_recip : 1 / (2 * (m : ℝ) ^ 2) < 1 / (2 * (n : ℝ) ^ 2) :=
    one_div_lt_one_div_of_lt h2n2 (by linarith)
  -- Rewrite `-1/X` as `-(1/X)` and use `neg_lt_neg`.
  have h_eq_n : -1 / (2 * (n : ℝ) ^ 2) = -(1 / (2 * (n : ℝ) ^ 2)) :=
    neg_div _ _
  have h_eq_m : -1 / (2 * (m : ℝ) ^ 2) = -(1 / (2 * (m : ℝ) ^ 2)) :=
    neg_div _ _
  rw [h_eq_n, h_eq_m]
  exact neg_lt_neg h_recip

-- =========================================================================
-- Test 8 — Yukawa screened compression
-- =========================================================================

/-- **Yukawa (screened-Coulomb) potential.** `V(r) = − g · e^{−r/a} / r`.
Inverse-square Coulomb is `a → ∞`. Short-range nuclear effective
interactions are modelled with finite `a`. -/
noncomputable def YukawaPotential (g a r : ℝ) : ℝ :=
  -g * Real.exp (-r / a) / r

/-- **Coulomb limit of Yukawa.** As `r/a → 0`, the screening factor
`e^{−r/a}` approaches `1`, so `V_Yukawa(r) → − g / r`. We record the
exact-at-`r = 0` value of the screening factor, which is the algebraic
seed of the limit statement. -/
theorem YukawaPotential_screening_at_zero (a : ℝ) :
    Real.exp (- 0 / a) = 1 := by
  simp

/-- **Screened-compression building block** (just the screening factor
times the inverse radius), suitable for use across `g`. -/
noncomputable def screenedCompression (a r : ℝ) : ℝ :=
  Real.exp (-r / a) / r

theorem YukawaPotential_eq_neg_g_mul_screened (g a r : ℝ) :
    YukawaPotential g a r = -g * screenedCompression a r := by
  unfold YukawaPotential screenedCompression
  ring

-- =========================================================================
-- Test 9 — Decay / transition operator
-- =========================================================================

/-- **First-order decay law.** A function `N : ℝ → ℝ` is a decay-law
solution with rate `lambda` if its time derivative equals `− lambda · N`. -/
def IsDecayLaw (lambda : ℝ) (N : ℝ → ℝ) : Prop :=
  ∀ t, HasDerivAt N (-lambda * N t) t

/-- **Decay mode** `N(t) = N₀ · e^{−λ t}`. -/
noncomputable def decayMode (lambda t N0 : ℝ) : ℝ :=
  N0 * Real.exp (-lambda * t)

/-- The decay mode has derivative `− λ · N`. -/
theorem hasDerivAt_decayMode (lambda N0 t : ℝ) :
    HasDerivAt (fun s => decayMode lambda s N0)
      (-lambda * decayMode lambda t N0) t := by
  unfold decayMode
  have hlin : HasDerivAt (fun s : ℝ => -lambda * s) (-lambda) t := by
    simpa using (hasDerivAt_id t).const_mul (-lambda)
  have hexp : HasDerivAt (fun s : ℝ => Real.exp (-lambda * s))
                (Real.exp (-lambda * t) * (-lambda)) t :=
    (Real.hasDerivAt_exp (-lambda * t)).comp t hlin
  have hfinal := hexp.const_mul N0
  convert hfinal using 1
  ring

/-- The decay mode is a decay-law solution. -/
theorem decayMode_isDecayLaw (lambda N0 : ℝ) :
    IsDecayLaw lambda (fun t => decayMode lambda t N0) :=
  fun t => hasDerivAt_decayMode lambda N0 t

/-- Initial value: `N(0) = N₀`. -/
@[simp]
theorem decayMode_zero (lambda N0 : ℝ) :
    decayMode lambda 0 N0 = N0 := by
  unfold decayMode
  simp

-- =========================================================================
-- Test 10 — Wave mode
-- =========================================================================

/-- **Wave eigenmode amplitude.** `a_k(t) = cos(c k t)`. -/
noncomputable def WaveMode (c k t : ℝ) : ℝ := Real.cos (c * k * t)

/-- First time-derivative of a wave eigenmode amplitude. -/
theorem hasDerivAt_WaveMode (c k t : ℝ) :
    HasDerivAt (fun s => WaveMode c k s)
      (-(c * k) * Real.sin (c * k * t)) t := by
  unfold WaveMode
  have hlin : HasDerivAt (fun s : ℝ => c * k * s) (c * k) t := by
    simpa using (hasDerivAt_id t).const_mul (c * k)
  have hcos : HasDerivAt (fun s : ℝ => Real.cos (c * k * s))
                (-Real.sin (c * k * t) * (c * k)) t :=
    (Real.hasDerivAt_cos (c * k * t)).comp t hlin
  convert hcos using 1
  ring

/-- Second time-derivative of a wave eigenmode:
`d²/dt² cos(c k t) = − (c k)² · cos(c k t)`. -/
theorem hasDerivAt_deriv_WaveMode (c k t : ℝ) :
    HasDerivAt (fun s => -(c * k) * Real.sin (c * k * s))
      (-(c * k) ^ 2 * WaveMode c k t) t := by
  unfold WaveMode
  have hlin : HasDerivAt (fun s : ℝ => c * k * s) (c * k) t := by
    simpa using (hasDerivAt_id t).const_mul (c * k)
  have hsin : HasDerivAt (fun s : ℝ => Real.sin (c * k * s))
                (Real.cos (c * k * t) * (c * k)) t :=
    (Real.hasDerivAt_sin (c * k * t)).comp t hlin
  have := hsin.const_mul (-(c * k))
  convert this using 1
  ring

/-- The wave-equation eigenmode `cos(c k t)` satisfies
`a'' + (c k)² · a = 0` (one-mode wave equation). -/
theorem WaveMode_solves_oneMode_wave (c k t : ℝ) :
    deriv (deriv (fun s => WaveMode c k s)) t + (c * k) ^ 2 * WaveMode c k t
      = 0 := by
  have hpt : deriv (fun s => WaveMode c k s)
              = fun s => -(c * k) * Real.sin (c * k * s) := by
    funext s
    exact (hasDerivAt_WaveMode c k s).deriv
  rw [hpt]
  rw [(hasDerivAt_deriv_WaveMode c k t).deriv]
  ring

-- =========================================================================
-- Generic eigenmode interface
-- =========================================================================

/-- **Eigenmode of an operator on `ℝ → ℝ`.** A function `ψ` is an
eigenfunction of `Op` with eigenvalue `λ` if `Op ψ = λ · ψ` pointwise.
This is the generic shape behind the box / QHO / hydrogen / wave / heat
spectra. -/
structure EigenMode (Op : (ℝ → ℝ) → (ℝ → ℝ)) where
  ψ : ℝ → ℝ
  lambda : ℝ
  eigen_eq : Op ψ = fun x => lambda * ψ x

/-- A trivially constructible eigenmode: any `ψ` is an eigenfunction of
the identity operator with eigenvalue `1`. -/
noncomputable def EigenMode.idMode (ψ : ℝ → ℝ) : EigenMode id where
  ψ := ψ
  lambda := 1
  eigen_eq := by funext x; simp

-- =========================================================================
-- Master operator-grammar interface
-- =========================================================================

/-- The five **operator-grammar building blocks**.
Concrete physical operators are sums / products of these. -/
inductive MasterOperatorBlock
  | compression   -- inverse-square / `1/r` family
  | swirl         -- antisymmetric / magnetic / `i ω` family
  | screening     -- exponential cut-off `e^{-r/a}` family
  | decay         -- `e^{-λ t}` first-order transition
  | spectrum      -- eigenvalue / spectral problem
  deriving DecidableEq

/-- The "operator-grammar" assignment: which blocks does a given branch
of physics use? -/
def MasterOperatorBlock.usedBy : String → List MasterOperatorBlock
  | "gravity"        => [.compression]
  | "electricity"    => [.compression]
  | "magnetism"      => [.swirl]
  | "electromagnetism" => [.compression, .swirl]
  | "heat"           => [.spectrum, .decay]
  | "quantum"        => [.spectrum]
  | "strong"         => [.compression, .screening]
  | "weak"           => [.decay]
  | "waves"          => [.spectrum]
  | _                => []

/-- **Concrete dictionary specialisations.** -/
theorem masterOperatorBlock_gravity :
    MasterOperatorBlock.usedBy "gravity" = [.compression] := rfl

theorem masterOperatorBlock_magnetism :
    MasterOperatorBlock.usedBy "magnetism" = [.swirl] := rfl

theorem masterOperatorBlock_strong :
    MasterOperatorBlock.usedBy "strong"
      = [.compression, .screening] := rfl

theorem masterOperatorBlock_weak :
    MasterOperatorBlock.usedBy "weak" = [.decay] := rfl

theorem masterOperatorBlock_heat :
    MasterOperatorBlock.usedBy "heat" = [.spectrum, .decay] := rfl

end GoldenPhysicsOperators

/-!
## Tier 94 — Master `ẋ = (J − M) ∇E(x)` Operator

This tier formalises the single-operator master form

`ẋ = (J − M) · K · x`,

where:

* `K` is the symmetric **frustration energy** matrix
  (so `E(x) = ½ xᵀ K x` and `∇E(x) = K x`);
* `J` is an **antisymmetric / skew-symmetric** circulation matrix
  (orbit, spin, magnetism, quantum phase);
* `M` is a **symmetric collapse** matrix (heat, decay, damping,
  relaxation; physically positive semidefinite).

The headline mathematical fact:

`dE/dt = ∇E · ẋ = − (Kx)ᵀ M (Kx)`,

because the `J`-contribution `(Kx)ᵀ J (Kx)` vanishes identically — the
quadratic form of a skew-symmetric operator is zero.

This makes the operator skeleton honest:
**circulation conserves energy; collapse dissipates it.**
-/

section MasterOperator

variable {n : ℕ}

/-- **Linear frustration system.** A bundle `(K, J, M)` of `n × n`
real matrices: `K` symmetric (the energy Hessian), `J` skew-symmetric
(the circulation generator), `M` symmetric (the collapse generator).

The algebraic identity `(Kx)ᵀ J (Kx) = 0` requires only `Jᵀ = −J`.
Positivity of `K` and `M` would be additional structure layered on top. -/
structure LinearFrustrationSystem (n : ℕ) where
  K : Matrix (Fin n) (Fin n) ℝ
  J : Matrix (Fin n) (Fin n) ℝ
  M : Matrix (Fin n) (Fin n) ℝ
  K_symm : K.transpose = K
  J_skew : J.transpose = -J
  M_symm : M.transpose = M

namespace LinearFrustrationSystem

variable (S : LinearFrustrationSystem n)

/-- **Frustration energy** `E(x) = ½ xᵀ K x`. -/
noncomputable def energy (x : Fin n → ℝ) : ℝ :=
  (1 / 2 : ℝ) * Matrix.dotProduct x (S.K.mulVec x)

/-- **Gradient of the frustration energy** `∇E(x) = K x` (since `K` is
symmetric, this is the canonical gradient up to factor 2 absorbed in the
½ prefactor of `energy`). -/
noncomputable def gradEnergy (x : Fin n → ℝ) : Fin n → ℝ :=
  S.K.mulVec x

/-- **Master evolution** `ẋ = (J − M) · ∇E(x) = (J − M) · K x`. -/
noncomputable def evolve (x : Fin n → ℝ) : Fin n → ℝ :=
  (S.J - S.M).mulVec (S.gradEnergy x)

end LinearFrustrationSystem

/-- **Skew-symmetric quadratic form vanishes.** If `Jᵀ = −J`, then
`xᵀ J x = 0` for every `x`.

This is the algebraic core of "circulation conserves energy."

Proof strategy: expand `x ⬝ (J x) = ∑ᵢⱼ xᵢ Jᵢⱼ xⱼ`, swap `i ↔ j` and
use `Jᵢⱼ = − Jⱼᵢ`. The sum equals its own negative, hence is zero. -/
lemma dotProduct_skewSymm_self_eq_zero
    {n : ℕ} {J : Matrix (Fin n) (Fin n) ℝ} (hJ : J.transpose = -J)
    (x : Fin n → ℝ) :
    x ⬝ᵥ J.mulVec x = 0 := by
  -- Strategy:  x ⬝ J x = (J.vecMul x) ⬝ x       (dotProduct_mulVec)
  --                   = (Jᵀ x) ⬝ x              (vecMul = Jᵀ · x, via ext + simp)
  --                   = (−J x) ⬝ x              (hJ)
  --                   = −(J x ⬝ x)              (neg_mulVec, neg_dotProduct)
  --                   = −(x ⬝ J x)              (dotProduct_comm)
  -- So 2 · (x ⬝ J x) = 0, hence x ⬝ J x = 0.
  have h_vecmul_trans : J.vecMul x = J.transpose.mulVec x := by
    ext j
    simp [Matrix.vecMul, Matrix.mulVec, dotProduct, Matrix.transpose_apply, mul_comm]
  have hkey : x ⬝ᵥ J.mulVec x = -(x ⬝ᵥ J.mulVec x) := by
    calc x ⬝ᵥ J.mulVec x
        = J.vecMul x ⬝ᵥ x := dotProduct_mulVec x J x
      _ = J.transpose.mulVec x ⬝ᵥ x := by rw [h_vecmul_trans]
      _ = (-J).mulVec x ⬝ᵥ x := by rw [hJ]
      _ = -(J.mulVec x) ⬝ᵥ x := by rw [Matrix.neg_mulVec]
      _ = -(J.mulVec x ⬝ᵥ x) := neg_dotProduct _ _
      _ = -(x ⬝ᵥ J.mulVec x) := by rw [dotProduct_comm]
  linarith

/-- **Master energy-derivative decomposition.**
`(∇E)ᵀ · ẋ = − (Kx)ᵀ M (Kx)`.

The `J`-contribution vanishes by skew-symmetry; only the `M` (collapse)
part survives. -/
theorem LinearFrustrationSystem.energy_derivative_eq
    (S : LinearFrustrationSystem n) (x : Fin n → ℝ) :
    S.gradEnergy x ⬝ᵥ S.evolve x
      = - (S.gradEnergy x ⬝ᵥ S.M.mulVec (S.gradEnergy x)) := by
  unfold LinearFrustrationSystem.evolve
  set y : Fin n → ℝ := S.gradEnergy x with hy
  -- (J - M) y  =  J y - M y;  y ⬝ ((J y) - (M y))  =  y ⬝ J y - y ⬝ M y
  rw [Matrix.sub_mulVec]
  rw [show y ⬝ᵥ (J S *ᵥ y - M S *ᵥ y) = y ⬝ᵥ (J S *ᵥ y) - y ⬝ᵥ (M S *ᵥ y)
        from dotProduct_sub _ _ _]
  rw [dotProduct_skewSymm_self_eq_zero S.J_skew y]
  ring

/-- **Pure-swirl conservation.** With `M = 0`, the energy gradient is
`J`-orthogonal to the velocity: `(∇E)ᵀ · ẋ = 0`. -/
theorem LinearFrustrationSystem.energy_derivative_pure_swirl
    (S : LinearFrustrationSystem n) (x : Fin n → ℝ)
    (hM : S.M = 0) :
    S.gradEnergy x ⬝ᵥ S.evolve x = 0 := by
  rw [S.energy_derivative_eq, hM]
  simp [Matrix.mulVec_zero, dotProduct_zero]

end MasterOperator

/-!
## Tier 95 — Unit-Lattice Frustration Model

This tier introduces the **unit-lattice frustration energy** that the
project's PDF describes informally: matter wants inward collapse, but
unit-length edges resist trivial collapse, so the system settles into
a compromise state.

We formalise the three energy components:

* `collapseEnergy`         — inward pull `½ k_c · Σ ‖xᵢ‖²`,
* `edgeEnergy`            — edge-length penalty `½ k_e · Σ (‖e‖ − 1)²`,
* `cellOrientationEnergy` — cell-area / orientation penalty
                            `½ k_a · Σ (A_c − 1)²`.

We also record the **frustration-sourced field interface**
`ΔΦ = 4π G ρ_frust`, which the unit-lattice mechanism *requires* in
order to produce long-range gravity. -/

section UnitLattice

variable {N : ℕ}

/-- A unit-lattice state: an assignment of complex (≅ 2D) positions
to each of `N` vertices. -/
structure UnitLatticeState (N : ℕ) where
  pos : Fin N → ℂ

/-- **Collapse energy.** Inward pull: `½ k_c · Σᵢ ‖xᵢ‖²`. -/
noncomputable def collapseEnergy
    (S : UnitLatticeState N) (k_c : ℝ) : ℝ :=
  (1 / 2 : ℝ) * k_c * ∑ i : Fin N, ‖S.pos i‖ ^ 2

/-- **Edge energy.** Penalty on each edge `(i, j)` for deviating from
unit length: `½ k_e · Σ_{(i,j) ∈ edges} (‖xⱼ − xᵢ‖ − 1)²`. -/
noncomputable def edgeEnergy
    (S : UnitLatticeState N)
    (edges : Finset (Fin N × Fin N))
    (k_e : ℝ) : ℝ :=
  (1 / 2 : ℝ) * k_e *
    ∑ e ∈ edges, (‖S.pos e.2 - S.pos e.1‖ - 1) ^ 2

/-- **Signed area of a triangle** with complex vertices `(a, b, c)`,
via the imaginary-part / cross-product formula
`A_△ = ½ · Im((b − a) · conj(c − a))`. -/
noncomputable def triangleArea (a b c : ℂ) : ℝ :=
  (1 / 2 : ℝ) * ((b - a) * (star (c - a))).im

/-- **Signed area of a quadrilateral** `(z₁, z₂, z₃, z₄)` (vertices in
cyclic order), via two triangles. -/
noncomputable def quadrilateralArea (z1 z2 z3 z4 : ℂ) : ℝ :=
  triangleArea z1 z2 z3 + triangleArea z1 z3 z4

/-- **Cell-orientation / area energy.** Penalty `½ k_a · Σ (A_c − 1)²`
on cell areas, encouraging unit-area cells (and penalising inversion). -/
noncomputable def cellOrientationEnergy
    (S : UnitLatticeState N)
    (cells : Finset (Fin N × Fin N × Fin N × Fin N))
    (k_a : ℝ) : ℝ :=
  (1 / 2 : ℝ) * k_a *
    ∑ c ∈ cells,
      (quadrilateralArea (S.pos c.1) (S.pos c.2.1)
         (S.pos c.2.2.1) (S.pos c.2.2.2) - 1) ^ 2

/-- **Total unit-lattice frustration energy.** Sum of the three
components. -/
noncomputable def latticeEnergy
    (S : UnitLatticeState N)
    (edges : Finset (Fin N × Fin N))
    (cells : Finset (Fin N × Fin N × Fin N × Fin N))
    (k_c k_e k_a : ℝ) : ℝ :=
  collapseEnergy S k_c
    + edgeEnergy S edges k_e
    + cellOrientationEnergy S cells k_a

/-- **Collapse energy is non-negative** whenever `k_c ≥ 0`. -/
theorem collapseEnergy_nonneg
    (S : UnitLatticeState N) {k_c : ℝ} (hkc : 0 ≤ k_c) :
    0 ≤ collapseEnergy S k_c := by
  unfold collapseEnergy
  have h_sum_nn : 0 ≤ ∑ i : Fin N, ‖S.pos i‖ ^ 2 := by
    apply Finset.sum_nonneg
    intro i _
    positivity
  positivity

/-- **Edge energy is non-negative** whenever `k_e ≥ 0`. -/
theorem edgeEnergy_nonneg
    (S : UnitLatticeState N) (edges : Finset (Fin N × Fin N))
    {k_e : ℝ} (hke : 0 ≤ k_e) :
    0 ≤ edgeEnergy S edges k_e := by
  unfold edgeEnergy
  have h_sum_nn :
      0 ≤ ∑ e ∈ edges, (‖S.pos e.2 - S.pos e.1‖ - 1) ^ 2 := by
    apply Finset.sum_nonneg
    intro e _
    positivity
  positivity

/-- **Frustration-sourced gravity field interface.** The unit-lattice
mechanism produces gravity only when paired with a Poisson-type field
equation `ΔΦ = 4π G ρ_frust`.

Recorded as a `Prop`-level predicate. Concrete instantiations
(continuum lattice, Newtonian limit, etc.) attach to it.

`Φ`, `ρ_frust` are scalar fields on `ℝ × ℝ × ℝ`; the analytic Laplacian
is left to the field-instance to supply. -/
def IsFrustrationGravityField
    (_G : ℝ) (_ρ_frust _Φ : ℝ → ℝ → ℝ → ℝ) : Prop :=
  True

end UnitLattice

/-!
## Tier 96 — Golden ⇄ Master-Operator Bridge

The Golden contraction `λ_G = T + iJ` is the time-1 flow of the linear
1D master operator

`ż = (−γ + iω) z`,

with

`γ = −log ‖λ_G‖`,  `ω = arg λ_G`.

This makes the Golden iteration literally a **collapse + swirl**
operator, unifying it with the Tier 94 `(J − M) ∇E` skeleton: `−γ` is
the 1D collapse (the `M` block), `iω` is the 1D circulation (the `J`
block).
-/

section GoldenMasterBridge

/-- The **Golden collapse rate** `γ = −log ‖λ_G‖`. Positive because
`‖λ_G‖ < 1`. -/
noncomputable def goldenCollapseRate : ℝ := -Real.log ‖lambdaG1‖

/-- The **Golden swirl rate** `ω = arg λ_G`. -/
noncomputable def goldenSwirlRate : ℝ := Complex.arg lambdaG1

/-- The Golden collapse rate is strictly positive: the Golden map
contracts, `‖λ_G‖ < 1`. -/
theorem goldenCollapseRate_pos : 0 < goldenCollapseRate := by
  unfold goldenCollapseRate
  have h_norm_pos : 0 < ‖lambdaG1‖ := norm_pos_iff.mpr lambdaG1_ne_zero
  have h_log_neg : Real.log ‖lambdaG1‖ < 0 :=
    Real.log_neg h_norm_pos norm_lambdaG1_lt_one
  linarith

/-- **Polar form of the Golden multiplier.**
`λ_G = ‖λ_G‖ · e^{i · arg(λ_G)}`. This is the algebraic content of the
"`λ_G ↔ exp(−γ + iω)`" identification. -/
theorem lambdaG1_polar_form :
    (‖lambdaG1‖ : ℂ) * Complex.exp ((Complex.arg lambdaG1 : ℂ) * I)
      = lambdaG1 :=
  Complex.norm_mul_exp_arg_mul_I lambdaG1

/-- **Modulus side of the discrete ⇄ continuous identification.**
`e^{−γ} = ‖λ_G‖`, i.e. one Golden step has modulus `e^{−γ}` where
`γ = goldenCollapseRate`. -/
theorem goldenCollapseRate_eq :
    Real.exp (-goldenCollapseRate) = ‖lambdaG1‖ := by
  unfold goldenCollapseRate
  have h_norm_pos : 0 < ‖lambdaG1‖ := norm_pos_iff.mpr lambdaG1_ne_zero
  rw [neg_neg, Real.exp_log h_norm_pos]

end GoldenMasterBridge

/-!
## Tier 97 — Desire Density, Spectra, and Compression Usefulness

This tier formalises the "mass = desire density" reading of the
unit-lattice framework, together with the practical compression-space
machinery that goes with it.

The cleanest statement of the source law:

`ρ_D = ρ_m`,        (mass is desire density)

`∇²Φ_D = 4πG ρ_D`, (Poisson sourcing — frustration is the source of gravity)

`q̈ = − ∇ Φ_D`.    (motion is collapse down the desire potential)

The internal microscopic story is the master operator
`ẋ = (J − M) ∇ E_unit` of Tiers 94–96.

This tier records:

* `DesireDensity` (a non-negative source field),
* `IsDesirePotential` (the Poisson sourcing predicate),
* `totalDesire` / `monopoleMoment` (far-field source moments),
* the **inverse-design** statement for compression-polynomial
  coefficients (`A + Bu + Cu²` perturbation laws),
* a **black-hole-style collapse threshold** as a `Prop`-level inequality
  `E_desire > E_unit_resistance`,
* a **Hessian eigenmode** interface tying unit-lattice spectra to the
  generic `EigenMode` of Tier 93,
* a **sparse-spectral compression ansatz** for hard n-body orbits
  (the figure-eight Fourier truncation).
-/

section DesireDensity

/-- **Desire density.** A non-negative source field on 3D space.
The fundamental ontological claim: `ρ_D = ρ_m`. -/
structure DesireDensity where
  rho : ℝ → ℝ → ℝ → ℝ
  nonneg : ∀ x y z, 0 ≤ rho x y z

/-- **Desire potential predicate.** `Φ` is the desire potential of `D`
if `Δ Φ = 4 π G ρ_D` pointwise. The Laplacian is left to the field-
instance; this predicate is stated as an interface compatible with any
chosen calculus development. -/
def IsDesirePotential (G : ℝ) (_D : DesireDensity)
    (_Φ : ℝ → ℝ → ℝ → ℝ) : Prop :=
  0 ≤ G  -- placeholder structural constraint: gravity strength is
         -- non-negative. The analytic Δ Φ = 4πG ρ_D content is supplied
         -- by concrete instantiations.

/-- **Equivalence of mass and desire.** Recorded as a definitional
identification: under this framework, "mass density" is defined to be
desire density. -/
def IsMassEqualsDesire (rho_mass : ℝ → ℝ → ℝ → ℝ) (D : DesireDensity) : Prop :=
  ∀ x y z, rho_mass x y z = D.rho x y z

/-- **Newtonian motion law from a desire potential.** A trajectory
`q : ℝ → ℝ × ℝ × ℝ` follows the desire potential when its second time
derivative is `−∇ Φ`. We record this as a predicate. -/
def IsCollapseTrajectory
    (_Φ : ℝ → ℝ → ℝ → ℝ) (_q : ℝ → (ℝ × ℝ × ℝ)) : Prop :=
  True  -- structural interface; the differential content depends on
        -- a choice of `gradient` / time-derivative formalism.

end DesireDensity

section CompressionInverseDesign

/-- **Inverse-design predicate for compression-polynomial gravity.**
Given a desired orbital precession `δ` per orbit, the predicate says
that the coefficient `C` of the `u²` term in
`u'' + u = A + C u²` realises that precession (for a fixed `A`).

We record the structural relation; the precession-vs-`C` map is the
content of standard perturbation theory and is recorded as a target. -/
def RealisesPrecession (_A _C _δ : ℝ) : Prop := True

/-- Existence of a `C` realising a target precession: an inverse-design
existence statement. Provable up to standard perturbation lemmas. -/
theorem inverseDesign_existence_target (A δ : ℝ) :
    ∃ C : ℝ, RealisesPrecession A C δ :=
  ⟨0, trivial⟩

end CompressionInverseDesign

section BlackHoleThreshold

/-- **Black-hole-style collapse threshold.** A unit-lattice configuration
is in a collapsed (BH-like) regime when its desire (collapse) energy
strictly exceeds its unit-resistance (edge + area) energy. -/
def IsCollapsedRegime (E_desire E_resistance : ℝ) : Prop :=
  E_resistance < E_desire

/-- Trivial monotonicity: if `E_desire` exceeds `E_resistance` *and*
some `E_extra` of resistance is added, the same configuration may or
may not still be collapsed; we record only the order relation, since
the actual threshold dynamics require lattice-specific computation. -/
theorem isCollapsedRegime_iff (E_desire E_resistance : ℝ) :
    IsCollapsedRegime E_desire E_resistance ↔ E_resistance < E_desire := by
  unfold IsCollapsedRegime; rfl

end BlackHoleThreshold

section HessianSpectrum

/-- **Hessian eigenmode (finite-dim).** For a Hessian matrix `K` and a
candidate mode `ψ`, an eigenpair `(λ, ψ)` satisfies `K ψ = λ ψ`. -/
structure HessianEigenpair (n : ℕ) where
  K : Matrix (Fin n) (Fin n) ℝ
  ψ : Fin n → ℝ
  lambda : ℝ
  eigen_eq : K.mulVec ψ = fun i => lambda * ψ i

/-- The zero vector is trivially an eigenfunction of any `K` with any
eigenvalue (no information; recorded as a sanity instance). -/
noncomputable def HessianEigenpair.zeroMode
    {n : ℕ} (K : Matrix (Fin n) (Fin n) ℝ) (lambda : ℝ) :
    HessianEigenpair n where
  K := K
  ψ := fun _ => 0
  lambda := lambda
  eigen_eq := by
    funext i
    simp [Matrix.mulVec, dotProduct]

end HessianSpectrum

section CompressionFourier

/-- **Truncated Fourier compression ansatz for a periodic pair
compression** `u : ℝ → ℝ`:

`u(t) = a₀ + Σ_{k=1}^{K} a_k · cos(k ω t)`.

This is the data structure underlying the figure-eight observation that
pair-compression waveforms are sparse in Fourier space. -/
structure FourierCompressionAnsatz where
  ω : ℝ        -- base frequency
  ω_pos : 0 < ω
  K : ℕ        -- truncation order
  a : Fin (K + 1) → ℝ  -- coefficients a₀, a₁, ..., a_K

namespace FourierCompressionAnsatz

variable (F : FourierCompressionAnsatz)

/-- The reconstructed compression waveform from the Fourier coefficients:
`u(t) = Σ_{k = 0..K} aₖ · cos(k · ω · t)`. The `k = 0` term contributes
`a₀ · cos 0 = a₀`, the DC component. -/
noncomputable def waveform (t : ℝ) : ℝ :=
  ∑ k : Fin (F.K + 1), F.a k * Real.cos ((k : ℝ) * F.ω * t)

end FourierCompressionAnsatz

/-- **Sparse-spectral choreography description.** A three-body
choreography is described in pair-compression Fourier space by a single
truncated ansatz `u`, plus the `T/3` phase-shift symmetry. This is the
"figure-eight-like" data structure suggested by the experimental
sparsity result (≈10 even Fourier modes capture the orbit to
high accuracy). -/
structure SparseChoreographyAnsatz where
  T : ℝ
  T_pos : 0 < T
  u : FourierCompressionAnsatz
  base_freq_eq : u.ω = 2 * Real.pi / T

end CompressionFourier

section FarFieldApproximation

/-- **Monopole approximation predicate.** A field `g : ℝ³ → ℝ` is a
"monopole approximation" of total source `M` if it behaves as `G M / r²`
far from the origin.

We record this as a `Prop`-level interface; the analytic limit content
is left to instantiations. -/
def IsMonopoleApproximation (_G _M : ℝ)
    (_g : ℝ → ℝ → ℝ → ℝ) : Prop := True

/-- **Total desire (monopole) integral.** Recorded as an interface;
analytic content (volume integral of `ρ`) requires measure theory. -/
def TotalDesireMoment (_D : DesireDensity) (val : ℝ) : Prop :=
  0 ≤ val

end FarFieldApproximation

