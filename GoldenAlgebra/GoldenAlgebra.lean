/-!
## Tier 17 — Golden Hankel HP Approximant Family

The first concrete Hermitian-determinant approximant candidate, built
from the *squared-trace* moments of the Golden matrix.

Raw trace moments `Tr(Gⁿ) = λⁿ + λ̄ⁿ` oscillate in sign, so the
corresponding Hankel matrix is not generally PSD. Squared-trace
moments `(Tr Gⁿ)²` are nonnegative, giving a positive discrete
measure on `ℕ`:

  `μ_q = Σ_{n≥1} (Tr Gⁿ)² qⁿ δ_n`     (for `0 ≤ q ≤ 1`).

The moments of this measure

  `m_k(q) := Σ_{n≥1} n^k (Tr Gⁿ)² qⁿ`

form a Hankel matrix `H_N(q) := (m_{i+j}(q))_{0 ≤ i,j < N}` whose
entries are real. The matrix is automatically Hermitian (real +
symmetric) and so its characteristic determinant has only real zeros
— by the Diamond finite-dimensional Hilbert–Pólya theorem
`charDet_isHermitian_hasOnlyRealZeros` from Tier 16.

Tier 17 then defines a `GoldenHankelXiApproximation` structure: a
sequence of these matrices whose characteristic determinants converge
locally uniformly to a target function `Xi`. The conditional theorem
`goldenHankel_diamond_limit` discharges the real-zero conclusion for
`Xi` from this approximation plus the abstract Hurwitz transfer
principle. This is the **first concrete instance** of the Diamond
`HermitianDeterminantApproximation` machinery.

Components:
* `abs_goldenTrace_le` — `|Tr Gⁿ| ≤ 2 ‖λ‖ⁿ`.
* `goldenTrace_sq_le` — `(Tr Gⁿ)² ≤ 4 ‖λ‖^(2n)`.
* `goldenMomentSq_summand_summable` — summability of the per-term
  series for every polynomial degree `k`.
* `goldenMomentSq` — the moment sequence `m_k(q)`.
* `goldenHankelSqFin` — the Hankel matrix `H_N(q)`.
* `goldenHankelSqFin_isHermitian` — unconditional Hermitian property.
* `goldenHankelSqFin_charDet_hasOnlyRealZeros` — **flagship**:
  `det(zI − H_N(q))` has only real zeros (via Diamond Tier 16).
* `GoldenHankelXiApproximation` — the missing-object structure for
  a limit toward a xi-like function.
* `goldenHankel_diamond_limit` — conditional reduction to real zeros
  of the limit, via the Diamond transfer.
-/

-- --- Tier 17.1 — Auxiliary trace bounds -----------------------------

/-- `|Tr(Gⁿ)| ≤ 2 ‖λ‖ⁿ`. Triangle inequality on the spectral form
`Tr(Gⁿ) = λⁿ + λ̄ⁿ`, then taking real parts. -/
theorem abs_goldenTrace_le (n : ℕ) :
    |goldenTrace n| ≤ 2 * ‖lambdaG1‖ ^ n := by
  rw [goldenTrace_eq_re_goldenTraceC]
  have h1 : |((goldenTraceC n).re)| ≤ ‖goldenTraceC n‖ :=
    Complex.abs_re_le_norm _
  have h2 : ‖goldenTraceC n‖ ≤ 2 * ‖lambdaG1‖ ^ n := by
    rw [show goldenTraceC n = goldenSpectralPair.traceC n from
        goldenTraceC_eq_spectralPair_traceC n]
    exact goldenSpectralPair.traceC_norm_le n
  linarith

/-- `(Tr Gⁿ)² ≤ 4 ‖λ‖^(2n)`. Square of `abs_goldenTrace_le`. -/
theorem goldenTrace_sq_le (n : ℕ) :
    (goldenTrace n) ^ 2 ≤ 4 * ‖lambdaG1‖ ^ (2 * n) := by
  have h := abs_goldenTrace_le n
  have hsq : (goldenTrace n) ^ 2 = |goldenTrace n| ^ 2 := (sq_abs _).symm
  calc (goldenTrace n) ^ 2
      = |goldenTrace n| ^ 2 := hsq
    _ ≤ (2 * ‖lambdaG1‖ ^ n) ^ 2 :=
        pow_le_pow_left₀ (abs_nonneg _) h 2
    _ = 4 * ‖lambdaG1‖ ^ (2 * n) := by
        rw [mul_pow, ← pow_mul]; ring

-- --- Tier 17.2 — Per-term summability of polynomial moments ---------

/-- Per-term summability for the squared-trace polynomial-moment series.

For `0 ≤ q ≤ 1` (and `‖λ‖ < 1` automatic), the series
`Σₙ (n+1)^k · (Tr G^(n+1))² · q^(n+1)` is summable. Dominated by
`Σₙ 4 (n+1)^k (‖λ‖² q)^(n+1)`, geometric with ratio
`‖λ‖² q ≤ ‖λ‖² < 1`. -/
theorem goldenMomentSq_summand_summable
    {q : ℝ} (hq_nn : 0 ≤ q) (hq_le : q ≤ 1) (k : ℕ) :
    Summable
      (fun n : ℕ =>
        ((n + 1 : ℕ) : ℝ) ^ k * (goldenTrace (n + 1)) ^ 2 * q ^ (n + 1)) := by
  set r : ℝ := ‖lambdaG1‖ ^ 2 * q with hr_def
  have hlam_sq_lt : ‖lambdaG1‖ ^ 2 < 1 := by
    have h := norm_lambdaG1_lt_one
    nlinarith [norm_nonneg lambdaG1]
  have hlam_sq_nn : 0 ≤ ‖lambdaG1‖ ^ 2 := pow_nonneg (norm_nonneg _) 2
  have hr_nn : 0 ≤ r := by rw [hr_def]; exact mul_nonneg hlam_sq_nn hq_nn
  have hr_lt : r < 1 := by
    rw [hr_def]
    calc ‖lambdaG1‖ ^ 2 * q ≤ ‖lambdaG1‖ ^ 2 * 1 :=
          mul_le_mul_of_nonneg_left hq_le hlam_sq_nn
      _ = ‖lambdaG1‖ ^ 2 := by ring
      _ < 1 := hlam_sq_lt
  have hr_norm : ‖r‖ < 1 := by
    rw [Real.norm_eq_abs, abs_of_nonneg hr_nn]
    exact hr_lt
  have hpow : Summable (fun n : ℕ => (n : ℝ) ^ k * r ^ n) :=
    summable_pow_mul_geometric_of_norm_lt_one k hr_norm
  have hshift :
      Summable (fun n : ℕ => ((n + 1 : ℕ) : ℝ) ^ k * r ^ (n + 1)) :=
    (summable_nat_add_iff
      (f := fun n : ℕ => (n : ℝ) ^ k * r ^ n) 1).mpr hpow
  have hdom :
      Summable
        (fun n : ℕ => 4 * (((n + 1 : ℕ) : ℝ) ^ k * r ^ (n + 1))) :=
    hshift.mul_left 4
  refine Summable.of_nonneg_of_le ?_ ?_ hdom
  · intro n
    have h1 : 0 ≤ ((n + 1 : ℕ) : ℝ) ^ k := by positivity
    have h2 : 0 ≤ (goldenTrace (n + 1)) ^ 2 := sq_nonneg _
    have h3 : 0 ≤ q ^ (n + 1) := pow_nonneg hq_nn _
    positivity
  · intro n
    have htr := goldenTrace_sq_le (n + 1)
    have h_idx_nn : 0 ≤ ((n + 1 : ℕ) : ℝ) ^ k := by positivity
    have h_q_nn : 0 ≤ q ^ (n + 1) := pow_nonneg hq_nn _
    have h_qmul_nn : 0 ≤ ((n + 1 : ℕ) : ℝ) ^ k * q ^ (n + 1) := by positivity
    calc ((n + 1 : ℕ) : ℝ) ^ k * (goldenTrace (n + 1)) ^ 2 * q ^ (n + 1)
        = ((n + 1 : ℕ) : ℝ) ^ k * q ^ (n + 1)
            * (goldenTrace (n + 1)) ^ 2 := by ring
      _ ≤ ((n + 1 : ℕ) : ℝ) ^ k * q ^ (n + 1)
            * (4 * ‖lambdaG1‖ ^ (2 * (n + 1))) :=
            mul_le_mul_of_nonneg_left htr h_qmul_nn
      _ = 4 * (((n + 1 : ℕ) : ℝ) ^ k * (‖lambdaG1‖ ^ 2 * q) ^ (n + 1)) := by
          rw [show ‖lambdaG1‖ ^ (2 * (n + 1)) = (‖lambdaG1‖ ^ 2) ^ (n + 1) from by
              rw [← pow_mul]]
          rw [mul_pow]
          ring
      _ = 4 * (((n + 1 : ℕ) : ℝ) ^ k * r ^ (n + 1)) := by rw [hr_def]

-- --- Tier 17.3 — Moment sequence and Hankel matrix -------------------

/-- **Golden squared-trace polynomial moment**:
`m_k(q) := Σ_{n ≥ 1} n^k (Tr Gⁿ)² q^n`. -/
noncomputable def goldenMomentSq (q : ℝ) (k : ℕ) : ℝ :=
  ∑' n : ℕ, ((n + 1 : ℕ) : ℝ) ^ k * (goldenTrace (n + 1)) ^ 2 * q ^ (n + 1)

/-- The Golden squared-trace moments are nonnegative. -/
theorem goldenMomentSq_nonneg
    {q : ℝ} (hq_nn : 0 ≤ q) (_hq_le : q ≤ 1) (k : ℕ) :
    0 ≤ goldenMomentSq q k := by
  unfold goldenMomentSq
  refine tsum_nonneg ?_
  intro n
  have h1 : 0 ≤ ((n + 1 : ℕ) : ℝ) ^ k := by positivity
  have h2 : 0 ≤ (goldenTrace (n + 1)) ^ 2 := sq_nonneg _
  have h3 : 0 ≤ q ^ (n + 1) := pow_nonneg hq_nn _
  positivity

/-- **Golden Hankel (squared-trace) matrix**: the `N×N` Hankel
matrix with entries `H_{ij} = m_{i+j}(q)`. Entries are real numbers
cast to `ℂ`. -/
noncomputable def goldenHankelSqFin (q : ℝ) (N : ℕ) :
    Matrix (Fin N) (Fin N) ℂ :=
  fun i j => ((goldenMomentSq q (i.val + j.val) : ℝ) : ℂ)

/-- **The Golden Hankel matrix is Hermitian.**

Entries are real-valued (`star` is identity on real-cast complex
numbers), and the entry `H_{ij}` depends only on `i.val + j.val`,
which is symmetric in `i, j`. -/
theorem goldenHankelSqFin_isHermitian (q : ℝ) (N : ℕ) :
    (goldenHankelSqFin q N).IsHermitian := by
  ext i j
  show star (goldenHankelSqFin q N j i) = goldenHankelSqFin q N i j
  unfold goldenHankelSqFin
  rw [Complex.star_def, Complex.conj_ofReal]
  congr 2
  omega

-- --- Tier 17.4 — Diamond application: real zeros ---------------------

/-- **Flagship of Tier 17 — Golden Hankel HP family has real zeros.**

For any `q : ℝ` and `N : ℕ`, the characteristic determinant of the
Golden squared-trace Hankel matrix `H_N(q)` has only real zeros.

Proof: `H_N(q)` is Hermitian (Tier 17.3), so the Diamond Tier 16
finite-dimensional Hilbert–Pólya theorem
`charDet_isHermitian_hasOnlyRealZeros` applies. -/
theorem goldenHankelSqFin_charDet_hasOnlyRealZeros (q : ℝ) (N : ℕ) :
    HasOnlyRealZeros (charDet (goldenHankelSqFin q N)) :=
  charDet_isHermitian_hasOnlyRealZeros (goldenHankelSqFin_isHermitian q N)

-- --- Tier 17.5 — GoldenHankelXiApproximation and diamond limit -------

/-- **Golden Hankel Xi Approximation.**

A sequence of Golden squared-trace Hankel matrices `H_N(q_N)` whose
characteristic determinants converge locally uniformly to a target
function `Xi`.

This is the first concrete instance of `HermitianDeterminantApproximation`
built from the Golden trace data. The "missing object" of the Diamond
program reduces, for the Golden HP family, to constructing the
sequence `q_N` and verifying the local-uniform convergence. -/
structure GoldenHankelXiApproximation (Xi : ℂ → ℂ) where
  /-- Per-step `q` parameter in `[0, 1)`. -/
  q : ℕ → ℝ
  /-- `q N ≥ 0`. -/
  hq_nonneg : ∀ N : ℕ, 0 ≤ q N
  /-- `q N < 1`. -/
  hq_lt_one : ∀ N : ℕ, q N < 1
  /-- Local-uniform convergence of `charDet (H_N(q_N))` to `Xi`. -/
  locallyUniform :
    TendstoLocallyUniformly
      (fun N : ℕ => fun t : ℂ => charDet (goldenHankelSqFin (q N) N) t)
      Xi Filter.atTop
  /-- `Xi` is not identically zero. -/
  nonzero : Xi ≠ 0
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- Each approximant `charDet (H_N(q_N))` is entire. -/
  approx_entire : ∀ N : ℕ,
    AnalyticOnNhd ℂ (fun t : ℂ => charDet (goldenHankelSqFin (q N) N) t) Set.univ

/-- **Conversion**: a `GoldenHankelXiApproximation` upgrades to a
generic `HermitianDeterminantApproximation`. -/
noncomputable def GoldenHankelXiApproximation.toHermitianApproximation
    {Xi : ℂ → ℂ} (H : GoldenHankelXiApproximation Xi) :
    HermitianDeterminantApproximation Xi where
  dim := id
  matrix := fun N => goldenHankelSqFin (H.q N) N
  isHermitian := fun N => goldenHankelSqFin_isHermitian (H.q N) N
  approx := H.locallyUniform
  nonzero := H.nonzero
  entire := H.entire
  approx_entire := H.approx_entire

/-- **Diamond limit for the Golden Hankel HP family.**

If `Xi` is approximated locally uniformly by the characteristic
determinants of Golden squared-trace Hankel matrices, and the abstract
Hurwitz zero-transfer principle holds, then `Xi` has only real zeros.

This is the **concrete Golden specialization of the Diamond flagship**:
any xi-like limit produced by the Golden Hankel HP machine inherits
real-zero geometry. -/
theorem goldenHankel_diamond_limit
    {Xi : ℂ → ℂ}
    (H : GoldenHankelXiApproximation Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyRealZeros Xi :=
  diamond_HP_limit_principle H.toHermitianApproximation hHurwitz

/-- **Critical-line corollary**: if a Golden Hankel approximation
converges to `criticalPullback xi`, then `xi` has only critical-line
zeros (conditional on Hurwitz). -/
theorem goldenHankel_diamond_critical_line
    {xi : ℂ → ℂ}
    (H : GoldenHankelXiApproximation (criticalPullback xi))
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyCriticalLineZeros xi := by
  have hreal := goldenHankel_diamond_limit H hHurwitz
  exact (criticalLineZeros_iff_realZeros_pullback xi).mpr hreal

