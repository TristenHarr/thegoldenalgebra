/-- **PROVED — within the last-row diagnosis, conservation holds and
`C(n, k) ≤ n^k`.** -/
theorem lastRowFramework_proved
    (_D : LastRowCarryFrameworkDiagnosis)
    (a_k q_kplus1 M : ℕ) (hM : 0 < M)
    (n k : ℕ) :
    (displayedBin a_k q_kplus1 M
      + M * carryAtChamber a_k q_kplus1 M = a_k + q_kplus1)
    ∧ (Nat.choose n k ≤ n^k) :=
