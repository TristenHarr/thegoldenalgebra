-- Half-angle geometry: the recursive nested-radical engine.

/-- **PROVED.** The half-angle cosine identity in absolute-value form
(unconditional): `√((1 + cos θ)/2) = |cos(θ/2)|`. The exact algebra
underneath the old angle-halving construction. -/
theorem half_angle_cos_abs (θ : ℝ) :
    Real.sqrt ((1 + Real.cos θ) / 2) = |Real.cos (θ / 2)| := by
  rw [← Real.sqrt_sq_eq_abs]
  congr 1
  have hc := Real.cos_sq (θ / 2)
  rw [show 2 * (θ / 2) = θ by ring] at hc
  rw [hc]; ring

/-- The angle-halving cosine sequence: `c₀ = cos(π/4)`,
`c_{n+1} = √((1 + cₙ)/2)` — the old "Atomic Measurements" recurrence. -/
noncomputable def halfAngleCosSeq : ℕ → ℝ
  | 0 => Real.cos (Real.pi / 4)
  | (n + 1) => Real.sqrt ((1 + halfAngleCosSeq n) / 2)

/-- **PROVED.** The angle-halving sequence is nonnegative. -/
theorem halfAngleCosSeq_nonneg (n : ℕ) : 0 ≤ halfAngleCosSeq n := by
  cases n with
  | zero =>
    show 0 ≤ Real.cos (Real.pi / 4)
    rw [Real.cos_pi_div_four]; positivity
  | succ k =>
    show 0 ≤ Real.sqrt ((1 + halfAngleCosSeq k) / 2)
    exact Real.sqrt_nonneg _

/-- **PROVED.** Elementary bound `2 ≤ 2^(n+2)`. -/
theorem two_le_two_pow_add_two (n : ℕ) : (2 : ℝ) ≤ 2 ^ (n + 2) := by
  induction n with
  | zero => norm_num
  | succ k ih =>
    have h : (2 : ℝ) ^ (k + 1 + 2) = 2 ^ (k + 2) * 2 := by
      rw [pow_succ]
    rw [h]; nlinarith [ih]

/-- **PROVED.** `cos(π/2^(n+2)) ≥ 0` — the angle stays in the first
quadrant. -/
theorem cos_pi_div_two_pow_nonneg (n : ℕ) :
    0 ≤ Real.cos (Real.pi / 2 ^ (n + 2)) := by
  apply Real.cos_nonneg_of_mem_Icc
  rw [Set.mem_Icc]
  refine ⟨?_, ?_⟩
  · have h1 : (0 : ℝ) ≤ Real.pi / 2 ^ (n + 2) := by positivity
    linarith [Real.pi_pos]
  · have h2 : (2 : ℝ) ≤ 2 ^ (n + 2) := two_le_two_pow_add_two n
    have h3 : (0 : ℝ) < 2 ^ (n + 2) := by positivity
    rw [div_le_div_iff₀ h3 (by norm_num : (0 : ℝ) < 2)]
    nlinarith [Real.pi_pos, h2]

/-- **PROVED — the closed form.** The angle-halving sequence is exactly
`cₙ = cos(π/2^(n+2))`: the old geometric recurrence computes nested
radicals `√2/2, √(2+√2)/2, …` that are exact cosine constants. -/
theorem halfAngleCosSeq_eq (n : ℕ) :
    halfAngleCosSeq n = Real.cos (Real.pi / 2 ^ (n + 2)) := by
  induction n with
  | zero => norm_num [halfAngleCosSeq]
  | succ n ih =>
    rw [halfAngleCosSeq, ih, half_angle_cos_abs,
      show Real.pi / 2 ^ (n + 2) / 2 = Real.pi / 2 ^ (n + 1 + 2) by
        rw [pow_succ]; ring]
    exact abs_of_nonneg (cos_pi_div_two_pow_nonneg (n + 1))

/-- The chord length subtending an angle `θ` on the unit circle:
`ℓ(θ) = 2·sin(θ/2)` — the old chord/length recurrence. -/
noncomputable def chordLength (θ : ℝ) : ℝ := 2 * Real.sin (θ / 2)

/-- **PROVED.** The chord-square identity `ℓ(θ)² = 2 − 2cos θ` — the
exact law-of-cosines form behind the old iterative chord construction. -/
theorem chordLength_sq (θ : ℝ) :
    chordLength θ ^ 2 = 2 - 2 * Real.cos θ := by
  unfold chordLength
  have hc := Real.cos_sq (θ / 2)
  rw [show 2 * (θ / 2) = θ by ring] at hc
  have hpy := Real.sin_sq_add_cos_sq (θ / 2)
  nlinarith [hc, hpy]

-- Complex-power branch oscillation: the honest warning.

/-- **PROVED.** `exp(π·(2k)·i) = 1` for every integer `k` — the
even-integer periodicity of the complex exponential. -/
theorem exp_pi_even_eq_one (k : ℤ) :
    Complex.exp ((Real.pi : ℂ) * (2 * (k : ℂ)) * Complex.I) = 1 := by
  have h : (Real.pi : ℂ) * (2 * (k : ℂ)) * Complex.I
         = (k : ℂ) * (2 * (Real.pi : ℂ) * Complex.I) := by ring
  rw [h]
  exact Complex.exp_int_mul_two_pi_mul_I k

/--
**PROVED — the branch-oscillation warning.** `1 − exp(π·(2k)·i) = 0`
for every integer `k`. The old `f(x) = √5·[(√5/2)^x − (−√5/2)^x]`
factors as `√5·(√5/2)^x·(1 − e^{iπx})`, whose roots are the even
integers. This is BRANCH-CUT oscillation from complex powers of a
negative base — NOT deep zeta structure. Recorded so the framework
does not overinterpret such oscillations.
-/
theorem one_sub_exp_pi_even_eq_zero (k : ℤ) :
    (1 : ℂ) - Complex.exp ((Real.pi : ℂ) * (2 * (k : ℂ)) * Complex.I)
      = 0 := by
  rw [exp_pi_even_eq_one]; ring

/-- A marker for the complex-power branch phenomenon: oscillation
`(e, π, i, sin, cos)` arising from `(−a)^x = a^x·e^{iπx}` is a branch
artifact, not zeta structure. -/
