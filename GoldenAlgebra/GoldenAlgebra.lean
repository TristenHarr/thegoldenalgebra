-- === Phase LXVII: Companion Roots, Half-Angle Cascade, Geometry/Zeta Bridge ===
-- The connective tissue. The "Atomic Measurements" geometric tower
-- (45°, 22.5°, 11.25°, 5.625°, …) is a half-angle cascade — the
-- classical repeated-radical machine. A quadratic root system
-- (α, β) with α² = T·α − N gives two shadows: TRACE sequence
-- Sₙ = αⁿ + βⁿ and COORDINATE sequence Uₙ = (αⁿ − βⁿ)/(α − β),
-- BOTH satisfying Sₙ₊₂ = T·Sₙ₊₁ − N·Sₙ. The golden case (T=1, N=−1)
-- gives Lucas (trace) and Fibonacci (coordinate). The pentagon is
-- the golden root system: ω + ω⁻¹ = 2cos(2π/5) = φ − 1. The trace
-- filter should be built from the companion root system itself.

/-- **PROVED — generic companion recurrence.** If `α² = T·α − N`, then
`α^(n+2) = T·α^(n+1) − N·α^n` for all n. -/
theorem companion_recurrence (α T N : ℝ) (h : α^2 = T * α - N) (n : ℕ) :
    α^(n+2) = T * α^(n+1) - N * α^n := by
  have hexp : α^(n+2) = α^n * α^2 := by ring
  rw [hexp, h]; ring

/-- **PROVED — companion sum (trace) satisfies the recurrence.** If
both α, β satisfy `x² = T·x − N`, then `Sₙ = αⁿ + βⁿ` satisfies
`Sₙ₊₂ = T·Sₙ₊₁ − N·Sₙ`. -/
theorem companion_sum_recurrence (α β T N : ℝ)
    (hα : α^2 = T * α - N) (hβ : β^2 = T * β - N) (n : ℕ) :
    α^(n+2) + β^(n+2) = T * (α^(n+1) + β^(n+1)) - N * (α^n + β^n) := by
  have ha := companion_recurrence α T N hα n
  have hb := companion_recurrence β T N hβ n
  linarith

/-- **PROVED — companion difference (coordinate) satisfies the
recurrence.** `Uₙ = αⁿ − βⁿ` satisfies the same recurrence. -/
theorem companion_diff_recurrence (α β T N : ℝ)
    (hα : α^2 = T * α - N) (hβ : β^2 = T * β - N) (n : ℕ) :
    α^(n+2) - β^(n+2) = T * (α^(n+1) - β^(n+1)) - N * (α^n - β^n) := by
  have ha := companion_recurrence α T N hα n
  have hb := companion_recurrence β T N hβ n
  linarith

/-- **PROVED — φ satisfies the golden companion equation `x² = x + 1`.**
i.e. with `T = 1, N = −1`. -/
theorem phi_companion : phi^2 = 1 * phi - (-1) := by
  have := phi_add_one_eq_phi_sq; linarith

/-- **PROVED — φ' satisfies the same companion equation.** -/
theorem phiConj_companion : phiConj^2 = 1 * phiConj - (-1) := by
  have := phiConj_min_poly; linarith

/-- **PROVED — the Lucas trace recurrence as a companion-root
recurrence.** `(φⁿ⁺² + φ'ⁿ⁺²) = (φⁿ⁺¹ + φ'ⁿ⁺¹) + (φⁿ + φ'ⁿ)`. -/
theorem lucas_companion_recurrence (n : ℕ) :
    phi^(n+2) + phiConj^(n+2)
      = (phi^(n+1) + phiConj^(n+1)) + (phi^n + phiConj^n) := by
  have h := companion_sum_recurrence phi phiConj 1 (-1) phi_companion phiConj_companion n
  linarith

/-- **PROVED — the Fibonacci coordinate recurrence as a companion-root
recurrence.** -/
theorem fib_companion_recurrence (n : ℕ) :
    phi^(n+2) - phiConj^(n+2)
      = (phi^(n+1) - phiConj^(n+1)) + (phi^n - phiConj^n) := by
  have h := companion_diff_recurrence phi phiConj 1 (-1) phi_companion phiConj_companion n
  linarith

/-- The pentagonal trace sequence `2cos(2πk/5)` for `k = 0..4`,
expressed algebraically in ℚ(√5). Period-5. -/
noncomputable def pentagonTraceValues : Fin 5 → ℝ
  | 0 => 2
  | 1 => phi - 1
  | 2 => -phi
  | 3 => -phi
  | 4 => phi - 1

/-- **PROVED — pentagonal trace symmetries.** -/
theorem pentagonTrace_symm_1_4 :
    pentagonTraceValues 1 = pentagonTraceValues 4 := rfl

theorem pentagonTrace_symm_2_3 :
    pentagonTraceValues 2 = pentagonTraceValues 3 := rfl

/-- **PROVED — pentagonal trace sum is zero (k=0..4).** The sum of
`2cos(2πk/5)` over k=0..4 equals zero (a primitive 5th-root identity:
the real part of the geometric sum `∑ω^k = 0`). -/
theorem pentagonTrace_sum_zero :
    pentagonTraceValues 0 + pentagonTraceValues 1 + pentagonTraceValues 2
      + pentagonTraceValues 3 + pentagonTraceValues 4 = 0 := by
  show (2 : ℝ) + (phi - 1) + (-phi) + (-phi) + (phi - 1) = 0
  ring

