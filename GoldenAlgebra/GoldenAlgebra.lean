-- === Tier 74 — Anti-Herglotz Pole Exclusion =========================
-- =====================================================================
/-!
## Tier 74 — Anti-Herglotz Pole Exclusion

Tier 73 built the **positivity engine**: the response `R = Ξ'/Ξ` is
anti-Herglotz (`Im R ≤ 0` on the open upper half-plane) and that
property survives limits. But there the response was only *nice extra
data* — RH still routed through `RealRootedPolynomialApproximation +
Hurwitz`.

Tier 74 turns the response into a **weapon**. The sharp observation:

> An anti-Herglotz logarithmic derivative *cannot have a pole inside
> the open upper half-plane.*

The proof is a blade. Suppose `Ξ` has a zero at `ρ` with `Im ρ > 0`.
Then near `ρ`,

```
  Ξ'(z)/Ξ(z) ~ m / (z − ρ).
```

Approach `ρ` from directly below along `z = ρ − iε` (`0 < ε < Im ρ`),
which stays in the open upper half-plane. There

```
  1/(z − ρ) = 1/(−iε) = i/ε,
```

whose imaginary part is **positive** — contradicting anti-Herglotz.

So a zero of `Ξ` in the open upper half-plane is impossible. By
conjugate (Schwarz) symmetry the lower half-plane is excluded too, and
*every* zero of `Ξ` is forced onto the real mirror axis — **without
the Hurwitz transfer principle.**

Components:
* `AntiHerglotzPoleExclusionWitness` — the abstract local obstruction:
  the pole at `ρ` forces positive imaginary part along the descending
  ray. (Residue analytics are *not* formalized here; the witness
  packages exactly the inequality the blade needs.)
* `no_antiHerglotz_with_upper_pole_witness` — the blade: anti-Herglotz
  + an upper-half-plane pole witness ⇒ `False`.
* `PrimeHerglotzTriangleLaw` — `PrimeHerglotzLaw` upgraded with the
  determinant/log-derivative coherence (`response = Ξ'/Ξ` off zeros)
  and a pole witness for every upper-half-plane zero.
* `PrimeHerglotzTriangleLaw.no_upper_half_plane_zeros` — the zero-trap.
* `PrimeHerglotzTriangleLaw.no_lower_half_plane_zeros` — the conjugate
  twin, via Schwarz symmetry.
* **`PrimeHerglotzTriangleLaw.hasOnlyRealZeros`** — the capstone: a
  direct RH-type conclusion, *not routed through Hurwitz*.

No GoldenAlgebra-specific axiom appears in any Tier 74 proof.
-/

-- --- Tier 74.1 — The pole-exclusion witness and the blade -----------

/-- **Anti-Herglotz pole-exclusion witness.** The abstract local
obstruction attached to a candidate upper-half-plane pole `ρ` of a
response `R`: `ρ` lies in the open upper half-plane, and along the
descending ray `ρ − iε` (which stays in the upper half-plane for
`0 < ε < Im ρ`) the response has *strictly positive* imaginary part.

This is exactly the data the blade needs — residue analytics are
deferred. A genuine simple pole `m/(z−ρ)` supplies this witness, since
`m/(−iε)` has imaginary part `Re m / ε > 0` for the leading order. -/
structure AntiHerglotzPoleExclusionWitness (R : ℂ → ℂ) (ρ : ℂ) where
  /-- `ρ` is in the open upper half-plane. -/
  upper : 0 < ρ.im
  /-- Along the descending ray the response has positive imaginary
  part — the pole signature. -/
  poleProducesPositiveIm :
    ∀ ε : ℝ, 0 < ε → ε < ρ.im →
      0 < (R (ρ - (ε : ℂ) * Complex.I)).im

/-- **The blade — anti-Herglotz pole exclusion.** A response that is
anti-Herglotz on the open upper half-plane *cannot* carry an
upper-half-plane pole witness: the descending-ray point `ρ − i·(Im ρ/2)`
lies in the upper half-plane, where the witness forces positive
imaginary part while the anti-Herglotz law forces non-positive — a
contradiction. -/
theorem no_antiHerglotz_with_upper_pole_witness
    {R : ℂ → ℂ} {ρ : ℂ}
    (hAnti : AntiHerglotzResponseLaw R)
    (W : AntiHerglotzPoleExclusionWitness R ρ) :
    False := by
  have hε0 : (0 : ℝ) < ρ.im / 2 := by linarith [W.upper]
  have hεlt : ρ.im / 2 < ρ.im := by linarith [W.upper]
  have hpos : 0 < (R (ρ - ((ρ.im / 2 : ℝ) : ℂ) * Complex.I)).im :=
    W.poleProducesPositiveIm (ρ.im / 2) hε0 hεlt
  have hzUpper : 0 < (ρ - ((ρ.im / 2 : ℝ) : ℂ) * Complex.I).im := by
    rw [Complex.sub_im, Complex.mul_I_im, Complex.ofReal_re]
    linarith [W.upper]
  have hnonpos : (R (ρ - ((ρ.im / 2 : ℝ) : ℂ) * Complex.I)).im ≤ 0 :=
    hAnti (ρ - ((ρ.im / 2 : ℝ) : ℂ) * Complex.I) hzUpper
  linarith

-- --- Tier 74.2 — The Prime–Herglotz Triangle Law --------------------

/-- **The Prime–Herglotz Triangle Law.** `PrimeHerglotzLaw` upgraded
with the *determinant/log-derivative triangle*:

* `responseMatchesLogDerivative` — off the zeros of `Ξ`, the limiting
  response genuinely *is* the logarithmic derivative `Ξ'/Ξ`; and
* `zeroPoleWitness` — every zero of `Ξ` in the open upper half-plane
  supplies an `AntiHerglotzPoleExclusionWitness` for the response.

The witness field is the honest remaining obligation: it asserts the
pole signature of `Ξ'/Ξ` at a zero, the one analytic fact still taken
as input. Everything downstream is then *proved*. -/
structure PrimeHerglotzTriangleLaw (Xi : ℂ → ℂ)
    extends PrimeHerglotzLaw Xi where
  /-- Off the zeros, the response is the logarithmic derivative. -/
  responseMatchesLogDerivative :
    ∀ z : ℂ, Xi z ≠ 0 → response z = deriv Xi z / Xi z
  /-- Every upper-half-plane zero supplies a pole-exclusion witness. -/
  zeroPoleWitness :
    ∀ ρ : ℂ, Xi ρ = 0 → 0 < ρ.im →
      AntiHerglotzPoleExclusionWitness response ρ

-- --- Tier 74.3 — Upper / lower half-plane zero exclusion ------------

/-- **The zero-trap (upper half-plane).** Under a Prime–Herglotz
Triangle Law, `Ξ` has *no* zeros in the open upper half-plane: a zero
there would produce a pole witness, and the blade
`no_antiHerglotz_with_upper_pole_witness` kills it against the proved
anti-Herglotz positivity of the response. -/
theorem PrimeHerglotzTriangleLaw.no_upper_half_plane_zeros
    {Xi : ℂ → ℂ} (H : PrimeHerglotzTriangleLaw Xi) :
    ∀ ρ : ℂ, 0 < ρ.im → Xi ρ ≠ 0 := by
  intro ρ hupper hzero
  exact no_antiHerglotz_with_upper_pole_witness
    H.toPrimeHerglotzLaw.response_antiHerglotz
    (H.zeroPoleWitness ρ hzero hupper)

/-- **The zero-trap (lower half-plane), via Schwarz symmetry.** If `Ξ`
is conjugate-symmetric (`Ξ(z̄) = conj Ξ(z)`, true for any function real
on the real axis), a lower-half-plane zero `ρ` reflects to the
upper-half-plane zero `ρ̄`, which the upper trap forbids. -/
theorem PrimeHerglotzTriangleLaw.no_lower_half_plane_zeros
    {Xi : ℂ → ℂ} (H : PrimeHerglotzTriangleLaw Xi)
    (hconj : ∀ z : ℂ, Xi ((starRingEnd ℂ) z) = (starRingEnd ℂ) (Xi z)) :
    ∀ ρ : ℂ, ρ.im < 0 → Xi ρ ≠ 0 := by
  intro ρ hlower hzero
  have hup : 0 < ((starRingEnd ℂ) ρ).im := by
    rw [Complex.conj_im]; linarith
  have hzero' : Xi ((starRingEnd ℂ) ρ) = 0 := by
    rw [hconj ρ, hzero, map_zero]
  exact H.no_upper_half_plane_zeros ((starRingEnd ℂ) ρ) hup hzero'

-- --- Tier 74.4 — The capstone: all zeros real -----------------------

/-- **Capstone — every zero of `Ξ` is real, with no Hurwitz.** A
Prime–Herglotz Triangle Law plus Schwarz symmetry forces every zero of
`Ξ` onto the real axis: the upper and lower half-planes are both
trapped, leaving only `Im = 0`.

Unlike the Tier-16/21/73 route, this conclusion does **not** invoke the
`HurwitzZeroTransferPrinciple`. The anti-Herglotz response is itself the
RH engine: the positivity *is* the proof. -/
theorem PrimeHerglotzTriangleLaw.hasOnlyRealZeros
    {Xi : ℂ → ℂ} (H : PrimeHerglotzTriangleLaw Xi)
    (hconj : ∀ z : ℂ, Xi ((starRingEnd ℂ) z) = (starRingEnd ℂ) (Xi z)) :
    HasOnlyRealZeros Xi := by
  intro z hz
  by_contra hne
  rcases lt_trichotomy z.im 0 with hlt | heq | hgt
  · exact H.no_lower_half_plane_zeros hconj z hlt hz
  · exact hne heq
  · exact H.no_upper_half_plane_zeros z hgt hz

/-- **Critical-line form** of the capstone: if the critical pullback of
`ξ` carries a Prime–Herglotz Triangle Law (with Schwarz symmetry), then
`ξ` has only critical-line zeros — RH for `ξ`, response-engine route. -/
theorem primeHerglotzTriangle_critical_line {xi : ℂ → ℂ}
    (H : PrimeHerglotzTriangleLaw (criticalPullback xi))
    (hconj : ∀ z : ℂ,
      criticalPullback xi ((starRingEnd ℂ) z)
        = (starRingEnd ℂ) (criticalPullback xi z)) :
    HasOnlyCriticalLineZeros xi :=
  (criticalLineZeros_iff_realZeros_pullback xi).mpr
    (H.hasOnlyRealZeros hconj)

/-- **No-go (the classification lever).** If `Ξ` has even a single zero
in the open upper half-plane, then no Prime–Herglotz Triangle Law can
exist for `Ξ`. The pole trap, run as a sieve. -/
theorem no_PrimeHerglotzTriangleLaw_of_upper_zero
    {Xi : ℂ → ℂ} {ρ : ℂ} (hupper : 0 < ρ.im) (hzero : Xi ρ = 0) :
    ¬ Nonempty (PrimeHerglotzTriangleLaw Xi) := by
  rintro ⟨H⟩
  exact H.no_upper_half_plane_zeros ρ hupper hzero

/-! ## Tier 74 Status Summary

Tier 74 turns the Tier-73 positivity engine into a **pole trap**.

The blade:
* `AntiHerglotzPoleExclusionWitness` — the abstract local obstruction
  at a candidate upper-half-plane pole.
* **`no_antiHerglotz_with_upper_pole_witness`** — anti-Herglotz +
  upper-half-plane pole witness ⇒ `False`. (Descend `ρ − i·Im ρ/2`:
  the pole forces `Im > 0`, anti-Herglotz forces `Im ≤ 0`.)

The upgraded law:
* `PrimeHerglotzTriangleLaw` — `PrimeHerglotzLaw` + the
  determinant/log-derivative triangle (`response = Ξ'/Ξ` off zeros) +
  a pole witness for every upper-half-plane zero.

The traps and the capstone:
* `PrimeHerglotzTriangleLaw.no_upper_half_plane_zeros` — no zeros with
  `Im > 0`.
* `PrimeHerglotzTriangleLaw.no_lower_half_plane_zeros` — no zeros with
  `Im < 0`, via Schwarz symmetry.
* **`PrimeHerglotzTriangleLaw.hasOnlyRealZeros`** — every zero of `Ξ`
  is real. *No `HurwitzZeroTransferPrinciple` is used.*
* `primeHerglotzTriangle_critical_line` — the critical-line form.
* `no_PrimeHerglotzTriangleLaw_of_upper_zero` — the sieve: an
  upper-half-plane zero forbids the whole law.

The remaining open monster is now surgically explicit: construct a
`PrimeHerglotzTriangleLaw Ξ` for the genuine completed zeta — i.e.
supply, for every hypothetical upper-half-plane zero, the pole-signature
witness `AntiHerglotzPoleExclusionWitness`. Tier 73 built the
positivity engine; Tier 74 built the trap; the gap is exactly the pole
witness. No GoldenAlgebra-specific axiom appears in any Tier 74 proof. -/

-- =====================================================================
-- === Tier 83 — Eventual Pole Signature ==============================
-- =====================================================================
/-!
## Tier 83 — Eventual Pole Signature

Tier 74 packaged the pole obstruction as an *assumption*
(`AntiHerglotzPoleExclusionWitness.poleProducesPositiveIm`). Tier 83
takes the first jab at the monster itself: it **proves** the forbidden
sign directly from the principal part.

The arithmetic is exact. Along the descending ray `z = ρ − iε` into a
pole `ρ` of order `m`, the principal part is

```
  m / (z − ρ) = m / (−iε) = i·m/ε,
```

whose imaginary part is `m/ε > 0`. No residue machinery, no analytic
remainder — just `Complex.div_im` on `m / (−iε)`. This is the algebraic
core the user asked for *before* the full local-factorization tier.

Components:
* `descendingRay_principalPart_im_pos` — the exact sign computation:
  `0 < Im( m/((ρ−iε)−ρ) )` for `m, ε > 0`.
* `EventualPoleExclusionWitness` — the more natural witness, asking the
  pole signature only *eventually* (`∀ᶠ ε in 𝓝[>] 0`) rather than for
  every `ε`.
* `no_antiHerglotz_with_eventual_upper_pole_witness` — the blade,
  upgraded to the eventual witness.
* `AntiHerglotzPoleExclusionWitness.toEventual` — the Tier-74 witness
  refines to an eventual one.
* `principalPart_eventual_poleWitness` — a response that *equals* the
  principal part `m/(z−ρ)` along the descending ray automatically
  carries an eventual pole witness.
* **`no_antiHerglotz_with_principalPart_pole`** — the flagship: an
  anti-Herglotz response simply *cannot* look like `m/(z−ρ)` (`m > 0`)
  descending into an upper-half-plane point.

No GoldenAlgebra-specific axiom appears in any Tier 83 proof.
-/

-- --- Tier 83.1 — The principal-part sign computation ----------------

/-- **Descending-ray principal-part signature.** Along the ray
`z = ρ − iε` (`ε > 0`), the order-`m` principal part `m/(z − ρ)` has
*strictly positive* imaginary part: `(ρ−iε)−ρ = −iε`, and
`Im( m/(−iε) ) = m·ε / ‖−iε‖² > 0`.

This is the exact algebraic blade — `Complex.div_im` and nothing
else. -/
theorem descendingRay_principalPart_im_pos {ρ : ℂ} {m ε : ℝ}
    (hm : 0 < m) (hε : 0 < ε) :
    0 < ((m : ℂ) / ((ρ - (ε : ℂ) * Complex.I) - ρ)).im := by
  have hsub : (ρ - (ε : ℂ) * Complex.I) - ρ = -((ε : ℂ) * Complex.I) := by
    ring
  rw [hsub]
  have hwre : (-((ε : ℂ) * Complex.I)).re = 0 := by simp [Complex.mul_I_re]
  have hwim : (-((ε : ℂ) * Complex.I)).im = -ε := by simp [Complex.mul_I_im]
  have hwne : -((ε : ℂ) * Complex.I) ≠ 0 :=
    neg_ne_zero.mpr
      (mul_ne_zero (Complex.ofReal_ne_zero.mpr (ne_of_gt hε)) Complex.I_ne_zero)
  have hns : 0 < Complex.normSq (-((ε : ℂ) * Complex.I)) :=
    Complex.normSq_pos.mpr hwne
  rw [Complex.div_im, Complex.ofReal_re, Complex.ofReal_im, hwre, hwim]
  have hval :
      (0 : ℝ) * 0 / Complex.normSq (-((ε : ℂ) * Complex.I))
        - m * (-ε) / Complex.normSq (-((ε : ℂ) * Complex.I))
      = m * ε / Complex.normSq (-((ε : ℂ) * Complex.I)) := by ring
  rw [hval]
  exact div_pos (mul_pos hm hε) hns

-- --- Tier 83.2 — The eventual pole-exclusion witness ----------------

/-- **Eventual pole-exclusion witness.** The natural form of the
Tier-74 obstruction: `ρ` is in the open upper half-plane, and
*eventually* along the descending ray (`∀ᶠ ε in 𝓝[>] 0`) the point
`ρ − iε` is still in the upper half-plane (`ε < Im ρ`) and the response
has strictly positive imaginary part. Asking for "eventually" instead
of "for every `ε`" is exactly what an analytic pole supplies. -/
structure EventualPoleExclusionWitness (R : ℂ → ℂ) (ρ : ℂ) where
  /-- `ρ` is in the open upper half-plane. -/
  upper : 0 < ρ.im
  /-- Eventually along the descending ray, the response has positive
  imaginary part (and the point stays in the upper half-plane). -/
  eventuallyPositive :
    ∀ᶠ ε in 𝓝[>] (0 : ℝ),
      ε < ρ.im ∧ 0 < (R (ρ - (ε : ℂ) * Complex.I)).im

/-- **The blade (eventual form).** An anti-Herglotz response cannot
carry an eventual upper-half-plane pole witness: the `𝓝[>] 0` filter is
`NeBot`, so the eventual positivity has a concrete witness `ε` with
`ε < Im ρ`; there `ρ − iε` is in the upper half-plane, where
anti-Herglotz forces `Im ≤ 0` against the witness's `Im > 0`. -/
theorem no_antiHerglotz_with_eventual_upper_pole_witness
    {R : ℂ → ℂ} {ρ : ℂ}
    (hAnti : AntiHerglotzResponseLaw R)
    (W : EventualPoleExclusionWitness R ρ) :
    False := by
  obtain ⟨ε, hεlt, hpos⟩ := W.eventuallyPositive.exists
  have hupim : 0 < (ρ - (ε : ℂ) * Complex.I).im := by
    rw [Complex.sub_im, Complex.mul_I_im, Complex.ofReal_re]
    linarith
  have hnonpos : (R (ρ - (ε : ℂ) * Complex.I)).im ≤ 0 :=
    hAnti (ρ - (ε : ℂ) * Complex.I) hupim
  linarith

-- --- Tier 83.3 — Refinement and the principal-part feeder -----------

/-- The Tier-74 (`∀ ε`) pole witness refines to an eventual one: a
property holding for *every* `ε` in the range in particular holds
*eventually*. -/
def AntiHerglotzPoleExclusionWitness.toEventual
    {R : ℂ → ℂ} {ρ : ℂ} (W : AntiHerglotzPoleExclusionWitness R ρ) :
    EventualPoleExclusionWitness R ρ where
  upper := W.upper
  eventuallyPositive := by
    have h0 : ∀ᶠ ε in 𝓝[>] (0 : ℝ), (0 : ℝ) < ε := self_mem_nhdsWithin
    have hlt : ∀ᶠ ε in 𝓝[>] (0 : ℝ), ε < ρ.im :=
      nhdsWithin_le_nhds (Iio_mem_nhds W.upper)
    filter_upwards [h0, hlt] with ε hε0 hεlt
    exact ⟨hεlt, W.poleProducesPositiveIm ε hε0 hεlt⟩

/-- **Principal part ⇒ eventual pole witness.** If a response `R`
*equals* the order-`m` principal part `m/(z − ρ)` along the descending
ray (for `0 < ε < Im ρ`), then `R` carries an
`EventualPoleExclusionWitness` — the pole signature is proved, not
assumed. -/
theorem principalPart_eventual_poleWitness
    {R : ℂ → ℂ} {ρ : ℂ} {m : ℝ}
    (hupper : 0 < ρ.im) (hm : 0 < m)
    (hagree : ∀ ε : ℝ, 0 < ε → ε < ρ.im →
      R (ρ - (ε : ℂ) * Complex.I)
        = (m : ℂ) / ((ρ - (ε : ℂ) * Complex.I) - ρ)) :
    EventualPoleExclusionWitness R ρ where
  upper := hupper
  eventuallyPositive := by
    have h0 : ∀ᶠ ε in 𝓝[>] (0 : ℝ), (0 : ℝ) < ε := self_mem_nhdsWithin
    have hlt : ∀ᶠ ε in 𝓝[>] (0 : ℝ), ε < ρ.im :=
      nhdsWithin_le_nhds (Iio_mem_nhds hupper)
    filter_upwards [h0, hlt] with ε hε0 hεlt
    refine ⟨hεlt, ?_⟩
    rw [hagree ε hε0 hεlt]
    exact descendingRay_principalPart_im_pos hm hε0

-- --- Tier 83.4 — Flagship: anti-Herglotz forbids principal-part poles

/-- **Flagship — anti-Herglotz forbids a principal-part pole.** An
anti-Herglotz response *cannot* coincide with the order-`m` principal
part `m/(z − ρ)` (`m > 0`) along a descending ray into an
upper-half-plane point `ρ`.

This is the Tier-83 jab at the monster: the witness of Tier 74 is no
longer an input — the bare positivity `m > 0` of the leading
coefficient already produces the forbidden sign. -/
theorem no_antiHerglotz_with_principalPart_pole
    {R : ℂ → ℂ} {ρ : ℂ} {m : ℝ}
    (hAnti : AntiHerglotzResponseLaw R)
    (hupper : 0 < ρ.im) (hm : 0 < m)
    (hagree : ∀ ε : ℝ, 0 < ε → ε < ρ.im →
      R (ρ - (ε : ℂ) * Complex.I)
        = (m : ℂ) / ((ρ - (ε : ℂ) * Complex.I) - ρ)) :
    False :=
  no_antiHerglotz_with_eventual_upper_pole_witness hAnti
    (principalPart_eventual_poleWitness hupper hm hagree)

/-! ## Tier 83 Status Summary

Tier 83 converts the Tier-74 pole obstruction from a packaged
assumption into a **proved** analytic blade.

The exact computation:
* **`descendingRay_principalPart_im_pos`** — `Im( m/((ρ−iε)−ρ) ) > 0`
  for `m, ε > 0`. Pure `Complex.div_im`; `(ρ−iε)−ρ = −iε` and the
  imaginary part is `m·ε / ‖−iε‖²`.

The eventual witness:
* `EventualPoleExclusionWitness` — the natural witness, asking the
  pole signature `∀ᶠ ε in 𝓝[>] 0` rather than for every `ε`.
* **`no_antiHerglotz_with_eventual_upper_pole_witness`** — the blade,
  using the `NeBot` of `𝓝[>] 0` to extract a concrete contradicting
  point.
* `AntiHerglotzPoleExclusionWitness.toEventual` — the Tier-74 witness
  refines to the eventual one.

The feeder and flagship:
* `principalPart_eventual_poleWitness` — a response equal to the
  principal part on the descending ray carries an eventual witness.
* **`no_antiHerglotz_with_principalPart_pole`** — an anti-Herglotz
  response cannot equal `m/(z−ρ)` (`m > 0`) descending into an
  upper-half-plane pole.

The remaining open monster shrinks again: where Tier 74 needed an
`AntiHerglotzPoleExclusionWitness` supplied by hand, a finite-order
zero of `Ξ` now only needs its log-derivative to *equal the principal
part* `m/(z−ρ)` along the descending ray — an ordinary local
factorization fact, the target of the next tier. No GoldenAlgebra-
specific axiom appears in any Tier 83 proof. -/

/-! # Tier 84 — Genuine Prime-Exponent Fock Model

Steps 181-183 introduced the prime-exponent configuration space, the
Fock basis, and the log-scale Hamiltonian *as placeholder structures*
(`PrimeExponentConfiguration`, `PrimeExponentFockStateSpace`, …) whose
fields are bare `Prop`s.  This tier replaces the placeholder
configuration object with a **genuine, unconditional** realization and
proves the arithmetic-Fock-model targets of group E with real
`Mathlib` number theory — no new axiom, no `sorry`.

A `PrimeExpConfig` is a finitely supported exponent map `p ↦ kₚ` on the
primes; it encodes the integer `∏ p^{kₚ}`.  The fundamental theorem of
arithmetic appears as a genuine `Equiv` between `PrimeExpConfig` and the
positive naturals, proved from `Nat.factorization`.  Every declaration
below is **Tier ★ — Unconditionally Proven**: it depends only on the
standard Lean/Mathlib axioms (`propext`, `Classical.choice`,
`Quot.sound`).

This discharges, with real proofs, items 56-70 of the operator
program: configuration arithmetic (57-59, 64), the natural-number
encoding (60-63), creation/annihilation/number operators (65-67), the
vacuum (68), and the prime-Fock/ℕ basis equivalence (69-70). -/

/-- A genuine *prime-exponent configuration*: a finitely supported
exponent map `p ↦ kₚ : ℕ →₀ ℕ` whose support consists of primes.  It
encodes the natural number `∏ p^{kₚ}`; the empty configuration is the
Fock vacuum `n = 1`.  This is the concrete, unconditional realization
of the placeholder `PrimeExponentConfiguration`. -/
@[ext]
structure PrimeExpConfig where
  /-- The exponent map `p ↦ kₚ`, finitely supported. -/
  exponent : ℕ →₀ ℕ
  /-- `supportedOnPrimes`: every mode carrying a nonzero exponent is a
  genuine prime. -/
  support_prime : ∀ p ∈ exponent.support, Nat.Prime p

namespace PrimeExpConfig

/-- The Fock vacuum: the empty configuration, encoding `n = 1`
(item 57, `zero_configuration`). -/
noncomputable def zero : PrimeExpConfig where
  exponent := 0
  support_prime := by intro p hp; simp at hp

/-- Addition of configurations — pointwise sum of exponent maps.  This
is the Fock-space image of integer multiplication. -/
noncomputable def add (a b : PrimeExpConfig) : PrimeExpConfig where
  exponent := a.exponent + b.exponent
  support_prime := by
    intro q hq
    rcases Finset.mem_union.mp (Finsupp.support_add hq) with h | h
    · exact a.support_prime q h
    · exact b.support_prime q h

/-- Configuration addition is commutative (item 58, `add_comm`). -/
theorem add_comm (a b : PrimeExpConfig) : a.add b = b.add a := by
  apply PrimeExpConfig.ext
  exact _root_.add_comm a.exponent b.exponent

/-- Configuration addition is associative (item 59, `add_assoc`). -/
theorem add_assoc (a b c : PrimeExpConfig) :
    (a.add b).add c = a.add (b.add c) := by
  apply PrimeExpConfig.ext
  exact _root_.add_assoc a.exponent b.exponent c.exponent

/-- The vacuum is a left identity for configuration addition. -/
theorem zero_add (a : PrimeExpConfig) : zero.add a = a := by
  apply PrimeExpConfig.ext
  exact _root_.zero_add a.exponent

/-- The vacuum is a right identity for configuration addition. -/
theorem add_zero (a : PrimeExpConfig) : a.add zero = a := by
  apply PrimeExpConfig.ext
  exact _root_.add_zero a.exponent

/-- The natural number encoded by a configuration: `∏ p^{kₚ}`
(item 60, `toNat`). -/
noncomputable def toNat (c : PrimeExpConfig) : ℕ := c.exponent.prod (· ^ ·)

/-- The configuration of a natural number, via its prime factorization
(item 61, `fromNat`). -/
noncomputable def fromNat (n : ℕ) : PrimeExpConfig where
  exponent := Nat.factorization n
  support_prime := by
    intro p hp
    rw [Nat.support_factorization] at hp
    exact Nat.prime_of_mem_primeFactors hp

/-- `toNat ∘ fromNat = id` on positive naturals: the integer is
recovered from its prime factorization (item 63,
`toNat_fromNat_inverse_for_positive_nat`). -/
theorem toNat_fromNat {n : ℕ} (hn : n ≠ 0) : (fromNat n).toNat = n := by
  show (Nat.factorization n).prod (· ^ ·) = n
  exact Nat.factorization_prod_pow_eq_self hn

/-- `fromNat ∘ toNat = id`: the configuration is recovered from the
integer it encodes — unique factorization (item 62,
`fromNat_toNat_inverse`). -/
theorem fromNat_toNat (c : PrimeExpConfig) : fromNat c.toNat = c := by
  apply PrimeExpConfig.ext
  show Nat.factorization (c.exponent.prod (· ^ ·)) = c.exponent
  exact Nat.prod_pow_factorization_eq_self c.support_prime

/-- **Multiplication becomes addition of configurations**
(item 64, `multiplication_becomes_addition_of_configurations`):
`fromNat (m·n) = fromNat m + fromNat n`. -/
theorem fromNat_mul {m n : ℕ} (hm : m ≠ 0) (hn : n ≠ 0) :
    fromNat (m * n) = (fromNat m).add (fromNat n) := by
  apply PrimeExpConfig.ext
  show Nat.factorization (m * n) = Nat.factorization m + Nat.factorization n
  exact Nat.factorization_mul hm hn

/-- The Fock vacuum encodes `n = 1` (item 68, `vacuum_corresponds_to_one`). -/
theorem toNat_zero : zero.toNat = 1 := by
  show (0 : ℕ →₀ ℕ).prod (· ^ ·) = 1
  exact Finsupp.prod_zero_index

/-- `1` corresponds to the Fock vacuum (item 68, `vacuum_corresponds_to_one`). -/
theorem fromNat_one : fromNat 1 = zero := by
  apply PrimeExpConfig.ext
  show Nat.factorization 1 = (0 : ℕ →₀ ℕ)
  exact Nat.factorization_one

/-- `toNat` is a monoid homomorphism: the integer of a sum of
configurations is the product of their integers. -/
theorem toNat_add (a b : PrimeExpConfig) :
    (a.add b).toNat = a.toNat * b.toNat := by
  show (a.exponent + b.exponent).prod (· ^ ·)
      = a.exponent.prod (· ^ ·) * b.exponent.prod (· ^ ·)
  exact Finsupp.prod_add_index' (fun p => pow_zero p) (fun p k l => pow_add p k l)

/-- Every configuration encodes a strictly positive integer. -/
theorem toNat_pos (c : PrimeExpConfig) : 0 < c.toNat := by
  show 0 < ∏ p ∈ c.exponent.support, p ^ c.exponent p
  exact Finset.prod_pos (fun p hp => pow_pos (c.support_prime p hp).pos _)

/-- **Unique factorization** (item 70, `unique_factorization_law`): the
encoding `fromNat` is injective on the positive naturals — distinct
positive integers have distinct prime-exponent configurations. -/
theorem fromNat_inj {m n : ℕ} (hm : m ≠ 0) (hn : n ≠ 0)
    (h : fromNat m = fromNat n) : m = n := by
  have := congrArg toNat h
  rwa [toNat_fromNat hm, toNat_fromNat hn] at this

/-- **Prime-Fock basis ≃ natural-number basis** (item 69,
`prime_fock_basis_equiv_nat_basis`): the genuine `Equiv` between
prime-exponent Fock configurations and the positive naturals,
witnessing the fundamental theorem of arithmetic as a basis
equivalence. -/
noncomputable def equivPNat : PrimeExpConfig ≃ {n : ℕ // 0 < n} where
  toFun c := ⟨c.toNat, c.toNat_pos⟩
  invFun n := fromNat n.1
  left_inv c := fromNat_toNat c
  right_inv n := Subtype.ext (toNat_fromNat n.2.ne')

/-- The prime number operator reads the `p`-adic exponent
(item 67, `prime_number_operator_reads_exponent`). -/
noncomputable def numberOp (c : PrimeExpConfig) (p : ℕ) : ℕ := c.exponent p

/-- Creation at a prime `p` adds one quantum to the `p`-mode. -/
noncomputable def create (p : ℕ) (hp : Nat.Prime p) (c : PrimeExpConfig) :
    PrimeExpConfig where
  exponent := Finsupp.single p 1 + c.exponent
  support_prime := by
    intro q hq
    rcases Finset.mem_union.mp (Finsupp.support_add hq) with h | h
    · have : q = p := Finset.mem_singleton.mp (Finsupp.support_single_subset h)
      exact this ▸ hp
    · exact c.support_prime q h

/-- Creation at `p` increments the `p`-adic exponent by one
(item 65, `prime_creation_increments_exponent`). -/
theorem numberOp_create (p : ℕ) (hp : Nat.Prime p) (c : PrimeExpConfig) :
    (create p hp c).numberOp p = c.numberOp p + 1 := by
  simp only [numberOp, create]
  rw [Finsupp.add_apply, Finsupp.single_eq_same]
  omega

/-- Annihilation at a prime `p` removes one quantum from the `p`-mode
(truncated at zero). -/
noncomputable def annihilate (p : ℕ) (hp : Nat.Prime p) (c : PrimeExpConfig) :
    PrimeExpConfig where
  exponent := c.exponent.update p (c.exponent p - 1)
  support_prime := by
    intro q hq
    rcases Finset.mem_insert.mp
        (Finsupp.support_update_subset c.exponent p hq) with h | h
    · exact h ▸ hp
    · exact c.support_prime q h

/-- Annihilation at `p` decrements the `p`-adic exponent by one
(item 66, `prime_annihilation_decrements_exponent`). -/
theorem numberOp_annihilate (p : ℕ) (hp : Nat.Prime p) (c : PrimeExpConfig) :
    (annihilate p hp c).numberOp p = c.numberOp p - 1 := by
  simp [numberOp, annihilate]

end PrimeExpConfig

