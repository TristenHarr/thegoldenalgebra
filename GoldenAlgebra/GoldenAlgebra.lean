-- === Phase CXIII: Formal Overflow Analysis — Operator Framework + Main Theorem ===
-- The formal core:
--   AdditiveCore:        A i = B i + R + C i,  C → 0  ⟹  A − B → R.
--   MultiplicativeCore:  A i = B i · R · T i,  T → 1  ⟹  A/B → R.
--   PoleCore:            f z = principalPart z + finitePart + regularPart z.
-- THE MAIN THEOREM (`tendsto_peeled_to_residue`) PROVED:
--   value - body → residue whenever correction → 0.
-- BodyKind classification (8 species): polynomial, logarithmic, power,
-- exponential, factorial, entropy, singularity, oscillatory.

/-- **The additive overflow core**: `value i = body i + residue + correction i`. -/
structure AdditiveCore (ι : Type*) (α : Type*) [AddCommGroup α] where
  value : ι → α
  body : ι → α
  residue : α
  correction : ι → α
  exact : ∀ i, value i = body i + residue + correction i

/-- **THE MAIN THEOREM — `tendsto_peeled_to_residue`** (PROVED):
If the correction tends to zero, the peeled object (value − body)
tends to the residue. The mathematical skeleton of overflow analysis. -/
theorem tendsto_peeled_to_residue
    {ι : Type*} {α : Type*} [TopologicalSpace α] [AddCommGroup α]
    [ContinuousAdd α] [ContinuousNeg α]
    (C : AdditiveCore ι α) {l : Filter ι}
    (hC : Filter.Tendsto C.correction l (nhds 0)) :
    Filter.Tendsto (fun i => C.value i - C.body i) l (nhds C.residue) := by
  -- (value i - body i) = (body i + residue + correction i) - body i
  --                   = residue + correction i
  have heq : (fun i => C.value i - C.body i) = fun i => C.residue + C.correction i := by
    funext i
    rw [C.exact i]
    abel
  rw [heq]
  -- residue + correction → residue + 0 = residue
  have h_const : Filter.Tendsto (fun _ : ι => C.residue) l (nhds C.residue) :=
    tendsto_const_nhds
  have h_sum := h_const.add hC
  simpa using h_sum

/-- **The multiplicative overflow core**: `value i = body i · residue · tower i`. -/
structure MultiplicativeCore (ι : Type*) (α : Type*) [Monoid α] where
  value : ι → α
  body : ι → α
  residue : α
  tower : ι → α
  exact : ∀ i, value i = body i * residue * tower i

/-- **The pole core**: `f z = principal_part z + finite_part + regular_part z`. -/
structure PoleCore (α β : Type*) [AddCommGroup β] where
  f : α → β
  principal_part : α → β
  finite_part : β
  regular_part : α → β
  exact : ∀ z, f z = principal_part z + finite_part + regular_part z

/-- **PROVED — pole-core peeling identity**: removing the principal
part leaves the finite part plus the regular part. -/
theorem pole_peeling
    {α β : Type*} [AddCommGroup β] (P : PoleCore α β) (z : α) :
    P.f z - P.principal_part z = P.finite_part + P.regular_part z := by
  rw [P.exact z]; abel

/-- **The asymptotic additive core** — value differs from body + residue
by a correction that tends to zero. -/
structure AsymptoticAdditiveCore (ι : Type*) (α : Type*)
    [TopologicalSpace α] [AddCommGroup α] [ContinuousAdd α] where
  value : ι → α
  body : ι → α
  residue : α
  l : Filter ι
  asymptotic : Filter.Tendsto (fun i => value i - body i) l (nhds residue)

/-- **PROVED — `AsymptoticAdditiveCore` from an `AdditiveCore` with
correction → 0.** Bridges the discrete and asymptotic forms. -/
def AdditiveCore.toAsymptotic
    {ι : Type*} {α : Type*} [TopologicalSpace α] [AddCommGroup α]
    [ContinuousAdd α] [ContinuousNeg α]
    (C : AdditiveCore ι α) (l : Filter ι)
    (hC : Filter.Tendsto C.correction l (nhds 0)) :
    AsymptoticAdditiveCore ι α :=
  { value := C.value
    body := C.body
    residue := C.residue
    l := l
    asymptotic := tendsto_peeled_to_residue C hC }

/-- **The 8 species of overflow body.** -/
inductive BodyKind where
  | polynomial
  | logarithmic
  | power
  | exponential
  | factorial
  | entropy
  | singularity
  | oscillatory
deriving DecidableEq, Repr

/-- **PROVED — `BodyKind` has 8 inhabitants.** Each species is distinct. -/
theorem bodyKind_distinct :
    BodyKind.polynomial ≠ BodyKind.logarithmic
    ∧ BodyKind.power ≠ BodyKind.exponential
    ∧ BodyKind.factorial ≠ BodyKind.entropy
    ∧ BodyKind.singularity ≠ BodyKind.oscillatory := by
  refine ⟨?_, ?_, ?_, ?_⟩ <;> decide

