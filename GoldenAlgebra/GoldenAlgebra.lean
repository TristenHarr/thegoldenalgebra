  identity_holds : Prop  -- ζ(5) = (5/2)S1 - 3·S2 + (3/2)S3 + (3/2)S4 - (9/2)S5
  verified_residual_1e_neg_120 : Prop

/-- **PROVED — the PSLQ relation rationally rearranges.** If
`−5·a + 6·b − 3·c − 3·d + 9·e + 2·z = 0`, then
`z = (5/2)·a − 3·b + (3/2)·c + (3/2)·d − (9/2)·e`. -/
