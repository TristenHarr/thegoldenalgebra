/-- **PROVED — the main theorem applies to the toy core: value - body → residue.** -/
theorem toyAdditive_residue :
    Filter.Tendsto (fun i : ℕ => toyAdditiveCore.value i - toyAdditiveCore.body i)
      Filter.atTop (nhds toyAdditiveCore.residue) :=
  tendsto_peeled_to_residue toyAdditiveCore toyAdditive_correction_tendsto_zero

