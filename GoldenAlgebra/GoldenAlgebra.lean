-- === Tier 13 — Documentation, geometric mean, Poisson connection ====
-- =====================================================================

-- --- Tier 13.1 — Eigen ≡ spectrum (documentation) -------------------

-- NOTE: `BoundedHPBridge.eigen_eq_spectrum_predicate` was removed in the
-- compactified-ordinate migration. It asserted that the projected `Eigen`
-- predicate of `B.toFinalHPBridge` was definitionally `t ↦ (t : ℂ) ∈ spectrum`.
-- Both `toFinalHPBridge` and the raw-ordinate `Eigen` are gone. The
-- free-`Eigen` loophole is now closed *structurally*: `BoundedHPBridge`
-- carries `poleToCompactSpectrum` directly, with no `Eigen` field at all,
-- and the reality of every spectral value is forced by
-- `BoundedHPBridge.spectrum_im_eq_zero` (Tier 12).

-- --- Tier 13.2 — Geometric mean (foundation for entropy) ------------

/-- **The mean of the geometric distribution.**
For `0 ≤ r < 1`:
  `Σ n · (1 − r) · rⁿ  =  r / (1 − r)`.
First moment of the discrete geometric distribution `pₙ = (1−r) · rⁿ`. -/
theorem nat_geometric_mean_hasSum
    {r : ℝ} (h0 : 0 ≤ r) (h1 : r < 1) :
    HasSum (fun n : ℕ => (n : ℝ) * ((1 - r) * r ^ n)) (r / (1 - r)) := by
  have hr : ‖r‖ < 1 := by rwa [Real.norm_eq_abs, abs_of_nonneg h0]
  have h : HasSum (fun n : ℕ => (n : ℝ) * r ^ n) (r / (1 - r) ^ 2) :=
    hasSum_coe_mul_geometric_of_norm_lt_one hr
  have h_ne : (1 : ℝ) - r ≠ 0 := by linarith
  have hval : (1 - r) * (r / (1 - r) ^ 2) = r / (1 - r) := by
    field_simp
    ring
  have hmul := h.mul_left (1 - r)
  rw [hval] at hmul
  refine hmul.congr_fun ?_
  intro n; ring

/-- The `tsum` form: `Σ n · (1 − r) · rⁿ = r / (1 − r)`. -/
theorem nat_geometric_mean_tsum
    {r : ℝ} (h0 : 0 ≤ r) (h1 : r < 1) :
    (∑' n : ℕ, (n : ℝ) * ((1 - r) * r ^ n)) = r / (1 - r) :=
  (nat_geometric_mean_hasSum h0 h1).tsum_eq

-- --- Tier 13.3 — Golden weight mean ---------------------------------

/-- **The mean of the Golden weights**: `Σ n · goldenWeight n = ‖λ‖/(1−‖λ‖)`. -/
theorem goldenWeight_mean :
    (∑' n : ℕ, (n : ℝ) * goldenWeight n) = ‖lambdaG1‖ / (1 - ‖lambdaG1‖) := by
  unfold goldenWeight
  exact nat_geometric_mean_tsum (norm_nonneg _) norm_lambdaG1_lt_one

-- --- Tier 13.4 — Poisson kernel connection --------------------------

/-- **Poisson-kernel form of the spectral denominator.**
For any spectral contraction pair `S`, the real part of
`(1 − S.lam)(1 − star S.lam)` equals the classical Poisson denominator
`1 − 2·Re(S.lam) + ‖S.lam‖²`. For `S.lam = r·e^{iθ}`, this is
`1 − 2r cos θ + r²`. Connects generic dynamical zeta to harmonic
analysis on the disk. -/
theorem SpectralContractionPair.poisson_denominator
    (S : SpectralContractionPair) :
    ((1 - S.lam) * (1 - star S.lam)).re
      = 1 - 2 * S.lam.re + ‖S.lam‖ ^ 2 := by
  have hnormsq : ‖S.lam‖ ^ 2 = (S.lam.re) ^ 2 + (S.lam.im) ^ 2 := by
    rw [show ‖S.lam‖ ^ 2 = Complex.normSq S.lam from
        (Complex.normSq_eq_norm_sq _).symm]
    rw [Complex.normSq_apply]
    ring
  simp only [Complex.sub_re, Complex.mul_re, Complex.one_re, Complex.one_im,
    Complex.sub_im, Complex.star_def, Complex.conj_re, Complex.conj_im,
    neg_neg, mul_neg, sub_neg_eq_add, neg_zero, zero_sub, neg_mul]
  rw [hnormsq]
  ring

-- =====================================================================
-- === Tier 14 — Theorem A: Publication-grade API ======================
-- =====================================================================
/-!
## Tier 14 — Theorem A: The Generic Spectral-Contraction Zeta–Theta–Mellin Theorem

Tier 10/11 established the generic spectral-contraction theory: for any
`SpectralContractionPair S` (a complex `λ` with `‖λ‖ < 1`), the trace
sequence `τₙ = λⁿ + λ̄ⁿ`, dynamical zeta `ζ_S`, theta kernel `Θ_S⁺`, and
Dirichlet series `D_S` all satisfy a tightly linked family of identities.

Tier 14 collects the five publication-grade flagships under the
`theorem_A_*` naming convention so they can be cited as a single theorem
package. The Golden case is then exposed as a distinguished corollary:
the specialization at `λ = T + iJ`.

The five flagships:
* `theorem_A_trace_generating_function` — split form of `Σ τₙ zⁿ`.
* `theorem_A_dynamical_zeta_factorization` — `ζ_S(z) = 1/((1−λz)(1−λ̄z))`.
* `theorem_A_log_zeta_expansion` — `Σ τₙ zⁿ/n = −log(1−λz) − log(1−λ̄z)`.
* `theorem_A_dirichlet_series_summable` — `D_S(s)` summable for every `s ∈ ℂ`.
* `theorem_A_mellin_bridge` — `∫₀^∞ Θ_S⁺(t)·tˢ⁻¹ dt = Γ(s)·D_S(s)`.

Each flagship has a Golden corollary `goldenAlgebra_theorem_A_*`.
-/

/-- **Theorem A.1 — Generic Trace Generating Function.**

For any `SpectralContractionPair S` and `‖λ·z‖ < 1`:
`Σₙ τₙ · zⁿ  =  1/(1−λz) + 1/(1−λ̄z)`,
equivalently the closed form `(2 − (λ+λ̄)·z) / ((1−λz)(1−λ̄z))`.

Citable alias of `SpectralContractionPair.trace_generating_function_split`. -/
theorem SpectralContractionPair.theorem_A_trace_generating_function
    (S : SpectralContractionPair) (z : ℂ) (hz : ‖S.lam * z‖ < 1) :
    HasSum (fun n : ℕ => S.traceC n * z ^ n)
      (1 / (1 - S.lam * z) + 1 / (1 - (star S.lam) * z)) :=
  S.trace_generating_function_split z hz

/-- **Theorem A.2 — Generic Dynamical Zeta Spectral Factorization.**

For any `SpectralContractionPair S`:
`ζ_S(z) = 1 / ((1 − λz)(1 − λ̄z))`.

The dynamical zeta of the contraction system factors over the
two-element spectrum `{λ, λ̄}`. This is the *defining identity*
promoted to a citable theorem. -/
theorem SpectralContractionPair.theorem_A_dynamical_zeta_factorization
    (S : SpectralContractionPair) (z : ℂ) :
    S.dynamicalZeta z = 1 / ((1 - S.lam * z) * (1 - (star S.lam) * z)) :=
  rfl

/-- **Theorem A.3 — Generic Log-Zeta Trace Expansion.**

For any `SpectralContractionPair S` and `‖λ·z‖ < 1`:
`Σₙ τₙ · zⁿ / n  =  −log(1 − λz) − log(1 − λ̄z)`.

This is `log ζ_S(z) = Σₙ τₙ · zⁿ / n` in HasSum form. Citable alias
of `SpectralContractionPair.log_zeta_trace_expansion`. -/
theorem SpectralContractionPair.theorem_A_log_zeta_expansion
    (S : SpectralContractionPair) (z : ℂ) (hz : ‖S.lam * z‖ < 1) :
    HasSum (fun n : ℕ => S.traceC n * z ^ n / (n : ℂ))
      (-Complex.log (1 - S.lam * z)
        - Complex.log (1 - (star S.lam) * z)) :=
  S.log_zeta_trace_expansion z hz

/-- **Theorem A.4 — Generic Dirichlet Trace Series Summability.**

For any `SpectralContractionPair S` and *every* `s ∈ ℂ`:
`Σ_{n≥1} τₙ / nˢ` is summable.

Citable alias of `SpectralContractionPair.traceDirichlet_summable`. The
exponential decay of `‖τₙ‖ ≤ 2 · ‖λ‖ⁿ` beats every algebraic factor
`n^k`, so the series converges for *every* complex `s`. This is the
defining contrast with the classical Riemann zeta. -/
theorem SpectralContractionPair.theorem_A_dirichlet_series_summable
    (S : SpectralContractionPair) (s : ℂ) :
    Summable
      (fun n : ℕ => S.traceC (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s) :=
  S.traceDirichlet_summable s

/-- **Theorem A.5 — Generic Theta–Mellin Bridge.**

For any `SpectralContractionPair S` and `Re(s) > 0`:
`∫₀^∞ Θ_S⁺(t) · tˢ⁻¹ dt  =  Γ(s) · D_S(s)`.

The finite-dimensional analogue of the classical theta-Mellin route
to the Riemann zeta function. Citable alias of
`SpectralContractionPair.thetaPositive_mellin_bridge`. -/
theorem SpectralContractionPair.theorem_A_mellin_bridge
    (S : SpectralContractionPair) (s : ℂ) (hs : 0 < s.re) :
    ∫ t in Set.Ioi (0 : ℝ),
        S.thetaPositive t * (t : ℂ) ^ (s - 1)
      = Complex.Gamma s * S.traceDirichlet s :=
  S.thetaPositive_mellin_bridge s hs

-- --- Tier 14.2 — Golden corollaries ---------------------------------

/-- **Theorem A.1 (Golden) — Golden Trace Generating Function.**

The Golden specialization of `theorem_A_trace_generating_function`
at `λ = lambdaG1`. -/
theorem goldenAlgebra_theorem_A_trace_generating_function
    (z : ℂ) (hz : ‖lambdaG1 * z‖ < 1) :
    HasSum (fun n : ℕ => goldenTraceC n * z ^ n)
      (1 / (1 - lambdaG1 * z) + 1 / (1 - star lambdaG1 * z)) := by
  have h := goldenSpectralPair.theorem_A_trace_generating_function z hz
  refine h.congr_fun ?_
  intro n
  rw [goldenTraceC_eq_spectralPair_traceC]

/-- **Theorem A.2 (Golden) — Golden Dynamical Zeta Spectral Factorization.**

The Golden specialization of `theorem_A_dynamical_zeta_factorization`. -/
theorem goldenAlgebra_theorem_A_dynamical_zeta_factorization (z : ℂ) :
    goldenDynamicalZeta z
      = 1 / ((1 - lambdaG1 * z) * (1 - star lambdaG1 * z)) := by
  rw [goldenDynamicalZeta_eq_spectralPair_dynamicalZeta]
  exact goldenSpectralPair.theorem_A_dynamical_zeta_factorization z

/-- **Theorem A.3 (Golden) — Golden Log-Zeta Trace Expansion.**

The Golden specialization of `theorem_A_log_zeta_expansion`. -/
theorem goldenAlgebra_theorem_A_log_zeta_expansion
    (z : ℂ) (hz : ‖lambdaG1 * z‖ < 1) :
    HasSum (fun n : ℕ => goldenTraceC n * z ^ n / (n : ℂ))
      (-Complex.log (1 - lambdaG1 * z)
        - Complex.log (1 - star lambdaG1 * z)) := by
  have h := goldenSpectralPair.theorem_A_log_zeta_expansion z hz
  refine h.congr_fun ?_
  intro n
  rw [goldenTraceC_eq_spectralPair_traceC]

/-- **Theorem A.4 (Golden) — Golden Dirichlet Trace Series Summability.**

The Golden specialization of `theorem_A_dirichlet_series_summable`:
`D_G(s) = Σ_{n≥1} Tr(Gⁿ) / nˢ` is summable for every `s ∈ ℂ`. -/
theorem goldenAlgebra_theorem_A_dirichlet_series_summable (s : ℂ) :
    Summable
      (fun n : ℕ => goldenTraceC (n + 1) / ((n + 1 : ℕ) : ℂ) ^ s) := by
  have h := goldenSpectralPair.theorem_A_dirichlet_series_summable s
  refine (Summable.congr h ?_)
  intro n
  rw [goldenTraceC_eq_spectralPair_traceC]

/-- **Theorem A.5 (Golden) — Golden Theta–Mellin Bridge.**

The Golden specialization of `theorem_A_mellin_bridge`:
`∫₀^∞ Θ_G⁺(t) · tˢ⁻¹ dt = Γ(s) · D_G(s)` for `Re(s) > 0`. -/
theorem goldenAlgebra_theorem_A_mellin_bridge
    (s : ℂ) (hs : 0 < s.re) :
    ∫ t in Set.Ioi (0 : ℝ),
        ((goldenThetaPositive t : ℝ) : ℂ) * (t : ℂ) ^ (s - 1)
      = Complex.Gamma s * goldenTraceDirichlet s :=
  goldenThetaPositive_mellin_bridge s hs

