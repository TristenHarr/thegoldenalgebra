/-! # Tier 88 — Metallic / Binet Spine, Geometry, Compression & ξ Interface

This tier folds the *old* Golden-Algebra exploratory material into the
current spectral architecture as **audited, reusable infrastructure**,
all inside this single file.

The organising principle is the rank-2 dictionary

    second-order recurrence  ⇔  two conjugate roots  ⇔  Binet closed form

specialised, at `k = 1`, to the golden constants already developed above
(`phi`, `T`, `J`, `lambdaG1`).  Everything here is **unconditionally
proven** (Tier ★) except the final two `structure`s, which package the
classical ξ / prime-zeta analytic identities as honest *interfaces*
pending Mathlib infrastructure — no `sorry`, no new axiom.
-/

-- --- Tier 88.1 — Metallic means: conjugate roots and recurrences ------

/-- The metallic root `Φ_k = (k + √(k²+4)) / 2`: the dominant root of
`r² − k r − 1 = 0`.  `Φ_1 = φ`. -/
noncomputable def metallicRoot (k : ℝ) : ℝ :=
  (k + Real.sqrt (k ^ 2 + 4)) / 2

/-- The conjugate metallic root `Φ̂_k = (k − √(k²+4)) / 2`. -/
noncomputable def metallicConj (k : ℝ) : ℝ :=
  (k - Real.sqrt (k ^ 2 + 4)) / 2

/-- The metallic Fibonacci-type sequence: `U₀ = 0`, `U₁ = 1`,
`U_{n+2} = k U_{n+1} + U_n`. -/
def metallicU (k : ℝ) : ℕ → ℝ
  | 0 => 0
  | 1 => 1
  | n + 2 => k * metallicU k (n + 1) + metallicU k n

/-- The metallic Lucas-type sequence: `V₀ = 2`, `V₁ = k`,
`V_{n+2} = k V_{n+1} + V_n`. -/
def metallicV (k : ℝ) : ℕ → ℝ
  | 0 => 2
  | 1 => k
  | n + 2 => k * metallicV k (n + 1) + metallicV k n

theorem metallicU_succ_succ (k : ℝ) (n : ℕ) :
    metallicU k (n + 2) = k * metallicU k (n + 1) + metallicU k n := by
  simp only [metallicU]

theorem metallicV_succ_succ (k : ℝ) (n : ℕ) :
    metallicV k (n + 2) = k * metallicV k (n + 1) + metallicV k n := by
  simp only [metallicV]

/-- Helper: `√(k²+4)² = k²+4`. -/
theorem metallic_sq_sqrt (k : ℝ) :
    Real.sqrt (k ^ 2 + 4) ^ 2 = k ^ 2 + 4 :=
  Real.sq_sqrt (by positivity)

/-- The roots sum to `k`: `Φ_k + Φ̂_k = k`. -/
theorem metallicRoot_add_conj (k : ℝ) :
    metallicRoot k + metallicConj k = k := by
  unfold metallicRoot metallicConj; ring

/-- The roots multiply to `−1`: `Φ_k · Φ̂_k = −1`. -/
theorem metallicRoot_mul_conj (k : ℝ) :
    metallicRoot k * metallicConj k = -1 := by
  unfold metallicRoot metallicConj
  have h := metallic_sq_sqrt k
  linear_combination (-(1 : ℝ) / 4) * h

/-- `Φ_k` solves the metallic quadratic: `Φ_k² = k Φ_k + 1`. -/
theorem metallicRoot_sq (k : ℝ) :
    metallicRoot k ^ 2 = k * metallicRoot k + 1 := by
  unfold metallicRoot
  have h := metallic_sq_sqrt k
  linear_combination ((1 : ℝ) / 4) * h

/-- `Φ̂_k` also solves the metallic quadratic. -/
theorem metallicConj_sq (k : ℝ) :
    metallicConj k ^ 2 = k * metallicConj k + 1 := by
  unfold metallicConj
  have h := metallic_sq_sqrt k
  linear_combination ((1 : ℝ) / 4) * h

/-- The roots differ by `√(k²+4)`. -/
theorem metallicRoot_sub_conj (k : ℝ) :
    metallicRoot k - metallicConj k = Real.sqrt (k ^ 2 + 4) := by
  unfold metallicRoot metallicConj; ring

theorem metallic_sqrt_pos (k : ℝ) : 0 < Real.sqrt (k ^ 2 + 4) :=
  Real.sqrt_pos.mpr (by positivity)

/-- The two metallic roots are distinct (the discriminant is positive). -/
theorem metallicRoot_ne_conj (k : ℝ) :
    metallicRoot k ≠ metallicConj k := by
  intro hcontra
  have h0 : metallicRoot k - metallicConj k = 0 := by rw [hcontra]; ring
  rw [metallicRoot_sub_conj] at h0
  exact ne_of_gt (metallic_sqrt_pos k) h0

theorem metallicRoot_pow_succ_succ (k : ℝ) (n : ℕ) :
    metallicRoot k ^ (n + 2)
      = k * metallicRoot k ^ (n + 1) + metallicRoot k ^ n := by
  have hexp : metallicRoot k ^ (n + 2)
      = metallicRoot k ^ n * metallicRoot k ^ 2 := by rw [← pow_add]
  rw [hexp, metallicRoot_sq]; ring

theorem metallicConj_pow_succ_succ (k : ℝ) (n : ℕ) :
    metallicConj k ^ (n + 2)
      = k * metallicConj k ^ (n + 1) + metallicConj k ^ n := by
  have hexp : metallicConj k ^ (n + 2)
      = metallicConj k ^ n * metallicConj k ^ 2 := by rw [← pow_add]
  rw [hexp, metallicConj_sq]; ring

-- --- Tier 88.2 — Binet closed forms -----------------------------------

/-- The Binet closed form for the metallic Fibonacci-type sequence. -/
noncomputable def metallicUBinet (k : ℝ) (n : ℕ) : ℝ :=
  (metallicRoot k ^ n - metallicConj k ^ n)
    / (metallicRoot k - metallicConj k)

/-- The Binet closed form for the metallic Lucas-type sequence. -/
noncomputable def metallicVBinet (k : ℝ) (n : ℕ) : ℝ :=
  metallicRoot k ^ n + metallicConj k ^ n

/-- **Binet's formula, Lucas branch**: `V_n^{(k)} = Φ_k^n + Φ̂_k^n`. -/
theorem metallicV_eq_binet (k : ℝ) (n : ℕ) :
    metallicV k n = metallicVBinet k n := by
  suffices h : ∀ m, metallicV k m = metallicVBinet k m
      ∧ metallicV k (m + 1) = metallicVBinet k (m + 1) from (h n).1
  intro m
  induction m with
  | zero =>
    refine ⟨?_, ?_⟩
    · norm_num [metallicV, metallicVBinet]
    · show metallicV k 1 = metallicVBinet k 1
      unfold metallicVBinet
      rw [pow_one, pow_one, show metallicV k 1 = k from rfl]
      exact (metallicRoot_add_conj k).symm
  | succ p ih =>
    obtain ⟨ih0, ih1⟩ := ih
    refine ⟨ih1, ?_⟩
    show metallicV k (p + 2) = metallicVBinet k (p + 2)
    rw [metallicV_succ_succ, ih0, ih1]
    unfold metallicVBinet
    rw [metallicRoot_pow_succ_succ, metallicConj_pow_succ_succ]
    ring

/-- **Binet's formula, Fibonacci branch**:
`U_n^{(k)} = (Φ_k^n − Φ̂_k^n)/(Φ_k − Φ̂_k)`. -/
theorem metallicU_eq_binet (k : ℝ) (n : ℕ) :
    metallicU k n = metallicUBinet k n := by
  have hne : metallicRoot k - metallicConj k ≠ 0 :=
    sub_ne_zero.mpr (metallicRoot_ne_conj k)
  suffices h : ∀ m, metallicU k m = metallicUBinet k m
      ∧ metallicU k (m + 1) = metallicUBinet k (m + 1) from (h n).1
  intro m
  induction m with
  | zero =>
    refine ⟨?_, ?_⟩
    · simp [metallicU, metallicUBinet]
    · show metallicU k 1 = metallicUBinet k 1
      unfold metallicUBinet
      rw [pow_one, pow_one, show metallicU k 1 = (1 : ℝ) from rfl]
      exact (div_self hne).symm
  | succ p ih =>
    obtain ⟨ih0, ih1⟩ := ih
    refine ⟨ih1, ?_⟩
    show metallicU k (p + 2) = metallicUBinet k (p + 2)
    rw [metallicU_succ_succ, ih0, ih1]
    unfold metallicUBinet
    rw [metallicRoot_pow_succ_succ, metallicConj_pow_succ_succ]
    field_simp
    ring

-- --- Tier 88.3 — The companion matrix and the trace identity ----------

/-- The metallic companion matrix `M_k = !![k, 1; 1, 0]`.  Its
eigenvalues are the two metallic roots. -/
def metallicMatrix (k : ℝ) : Matrix (Fin 2) (Fin 2) ℝ :=
  !![k, 1; 1, 0]

/-- Cayley–Hamilton for the companion matrix: `M_k · M_k = k • M_k + 1`. -/
theorem metallicMatrix_sq (k : ℝ) :
    metallicMatrix k * metallicMatrix k = k • metallicMatrix k + 1 := by
  ext i j
  fin_cases i <;> fin_cases j <;>
    simp [metallicMatrix, Matrix.mul_apply, Fin.sum_univ_two,
      Matrix.one_apply, Matrix.add_apply, Matrix.smul_apply,
      smul_eq_mul]

theorem metallicMatrix_pow_succ_succ (k : ℝ) (n : ℕ) :
    metallicMatrix k ^ (n + 2)
      = k • metallicMatrix k ^ (n + 1) + metallicMatrix k ^ n := by
  have h2 : metallicMatrix k ^ 2 = k • metallicMatrix k + 1 := by
    rw [pow_two]; exact metallicMatrix_sq k
  have hsplit : metallicMatrix k ^ (n + 2)
      = metallicMatrix k ^ 2 * metallicMatrix k ^ n := by
    rw [← pow_add, show 2 + n = n + 2 from by omega]
  rw [hsplit, h2, add_mul, smul_mul_assoc, one_mul, ← pow_succ']

theorem metallicMatrix_trace_zero (k : ℝ) :
    Matrix.trace (metallicMatrix k ^ 0) = 2 := by
  rw [pow_zero, Matrix.trace_one]
  norm_num [Fintype.card_fin]

theorem metallicMatrix_trace_one (k : ℝ) :
    Matrix.trace (metallicMatrix k ^ 1) = k := by
  rw [pow_one]
  unfold metallicMatrix
  rw [Matrix.trace_fin_two_of]
  ring

theorem metallicMatrix_trace_pow_succ_succ (k : ℝ) (n : ℕ) :
    Matrix.trace (metallicMatrix k ^ (n + 2))
      = k * Matrix.trace (metallicMatrix k ^ (n + 1))
        + Matrix.trace (metallicMatrix k ^ n) := by
  rw [metallicMatrix_pow_succ_succ, Matrix.trace_add, Matrix.trace_smul,
    smul_eq_mul]

/-- **The rank-2 spectral prototype**: the metallic Lucas number is the
trace of a power of the companion matrix, `V_n^{(k)} = Tr(M_k^n)`.
This is the finite toy model of the trace ⇝ moment ⇝ Hankel-determinant
bridge used by the Golden RH track. -/
theorem metallicV_eq_trace_pow (k : ℝ) (n : ℕ) :
    metallicV k n = Matrix.trace (metallicMatrix k ^ n) := by
  suffices h : ∀ m, metallicV k m = Matrix.trace (metallicMatrix k ^ m)
      ∧ metallicV k (m + 1)
          = Matrix.trace (metallicMatrix k ^ (m + 1)) from (h n).1
  intro m
  induction m with
  | zero =>
    refine ⟨?_, ?_⟩
    · show (2 : ℝ) = Matrix.trace (metallicMatrix k ^ 0)
      rw [metallicMatrix_trace_zero]
    · show k = Matrix.trace (metallicMatrix k ^ 1)
      rw [metallicMatrix_trace_one]
  | succ p ih =>
    obtain ⟨ih0, ih1⟩ := ih
    refine ⟨ih1, ?_⟩
    show metallicV k (p + 2) = Matrix.trace (metallicMatrix k ^ (p + 2))
    rw [metallicV_succ_succ, metallicMatrix_trace_pow_succ_succ,
      ← ih0, ← ih1]

-- --- Tier 88.4 — Golden (k = 1) specialisation ------------------------

/-- At `k = 1` the metallic root is exactly the golden ratio. -/
theorem metallicRoot_one_eq_phi : metallicRoot 1 = phi := by
  have h : ((1 : ℝ) ^ 2 + 4) = 5 := by norm_num
  unfold metallicRoot phi
  rw [h]

/-- At `k = 1` the conjugate metallic root is `1 − φ = ψ`. -/
theorem metallicConj_one_eq_one_sub_phi : metallicConj 1 = 1 - phi := by
  have h : ((1 : ℝ) ^ 2 + 4) = 5 := by norm_num
  unfold metallicConj phi
  rw [h]; ring

/-- The golden constant `T` in `φ`-language: `T = (φ − 1)/2`. -/
theorem T_eq_phi_sub_one_div_two : T = (phi - 1) / 2 := by
  unfold T phi; ring

/-- The golden constant `J` in `φ`-language: `J = (2 − φ)/2`. -/
theorem J_eq_two_sub_phi_div_two : J = (2 - phi) / 2 := by
  unfold J phi; ring

/-- `T − J = (√5 − 2)/2`. -/
theorem T_sub_J_eq_sqrt_five_sub_two_div_two :
    T - J = (Real.sqrt 5 - 2) / 2 := by
  unfold T J; ring

/-- **Fibonacci bridge**: the `k = 1` metallic Fibonacci-type sequence is
exactly the Mathlib Fibonacci sequence, `U_n^{(1)} = F_n`. -/
theorem metallicU_one_eq_fib (n : ℕ) :
    metallicU 1 n = (Nat.fib n : ℝ) := by
  suffices h : ∀ m, metallicU 1 m = (Nat.fib m : ℝ)
      ∧ metallicU 1 (m + 1) = (Nat.fib (m + 1) : ℝ) from (h n).1
  intro m
  induction m with
  | zero =>
    refine ⟨by simp [metallicU], ?_⟩
    show metallicU 1 1 = (Nat.fib 1 : ℝ)
    simp [metallicU]
  | succ p ih =>
    obtain ⟨ih0, ih1⟩ := ih
    refine ⟨ih1, ?_⟩
    show metallicU 1 (p + 2) = (Nat.fib (p + 2) : ℝ)
    rw [metallicU_succ_succ, ih0, ih1, Nat.fib_add_two]
    push_cast; ring

-- --- Tier 88.5 — Repeated half-angle geometry -------------------------

/-- The repeated half-angle cosine ladder: `c₀ = √2/2`,
`c_{n+1} = √((1 + cₙ)/2)`. -/
noncomputable def halfAngleCos : ℕ → ℝ
  | 0 => Real.sqrt 2 / 2
  | n + 1 => Real.sqrt ((1 + halfAngleCos n) / 2)

theorem halfAngleCos_nonneg (n : ℕ) : 0 ≤ halfAngleCos n := by
  cases n with
  | zero => simp only [halfAngleCos]; positivity
  | succ m => simp only [halfAngleCos]; positivity

/-- **The half-angle ladder computes nested cosines**:
`cₙ = cos(π / 2^{n+2})`.  Starting from `cos(π/4)`, each step halves the
angle via the exact half-angle identity. -/
theorem halfAngleCos_eq_cos (n : ℕ) :
    halfAngleCos n = Real.cos (Real.pi / 2 ^ (n + 2)) := by
  induction n with
  | zero =>
    show Real.sqrt 2 / 2 = Real.cos (Real.pi / 2 ^ 2)
    rw [show (2 : ℝ) ^ 2 = 4 by norm_num, Real.cos_pi_div_four]
  | succ n ih =>
    show Real.sqrt ((1 + halfAngleCos n) / 2)
        = Real.cos (Real.pi / 2 ^ (n + 3))
    rw [ih]
    have hge : (2 : ℝ) ≤ 2 ^ (n + 3) := by
      have h1 : (1 : ℝ) ≤ 2 ^ n := by
        have hN : (1 : ℕ) ≤ 2 ^ n := Nat.one_le_pow n 2 (by norm_num)
        exact_mod_cast hN
      have h2 : (2 : ℝ) ^ (n + 3) = 2 ^ n * 8 := by ring
      rw [h2]; nlinarith [h1]
    have hdouble : 2 * (Real.pi / 2 ^ (n + 3)) = Real.pi / 2 ^ (n + 2) := by
      have h2 : (2 : ℝ) ^ (n + 3) = 2 ^ (n + 2) * 2 := by ring
      have hne : (2 : ℝ) ^ (n + 2) ≠ 0 := by positivity
      rw [h2]; field_simp; ring
    have hcos_sq : Real.cos (Real.pi / 2 ^ (n + 3)) ^ 2
        = (1 + Real.cos (Real.pi / 2 ^ (n + 2))) / 2 := by
      have hcs := Real.cos_sq (Real.pi / 2 ^ (n + 3))
      rw [hdouble] at hcs
      rw [hcs]; ring
    have hnonneg : 0 ≤ Real.cos (Real.pi / 2 ^ (n + 3)) := by
      apply Real.cos_nonneg_of_mem_Icc
      rw [Set.mem_Icc]
      refine ⟨?_, ?_⟩
      · have hp : (0 : ℝ) < Real.pi / 2 ^ (n + 3) := by positivity
        linarith [Real.pi_pos]
      · have hle : Real.pi / 2 ^ (n + 3) ≤ Real.pi / 2 := by
          gcongr
        linarith [hle]
    rw [← hcos_sq, Real.sqrt_sq hnonneg]

-- --- Tier 88.6 — Complex power branches -------------------------------

/-- The branch-aware model of the old alternating function
`√5·((√5/2)^x − (−√5/2)^x)`: the principal-branch power of a negative
real introduces the factor `e^{iπx}`, so the antisymmetric branch is
`aˣ·(1 − e^{iπx})`. -/
noncomputable def altBranchModel (a x : ℝ) : ℂ :=
  (Real.rpow a x : ℂ)
    * (1 - Complex.exp (Complex.I * (Real.pi : ℂ) * (x : ℂ)))

/-- At even integers the branch factor vanishes: the model is zero. -/
theorem altBranchModel_even_int_zero (a : ℝ) (n : ℤ) :
    altBranchModel a (2 * (n : ℝ)) = 0 := by
  unfold altBranchModel
  have hexp : Complex.exp (Complex.I * (Real.pi : ℂ)
      * (Complex.ofReal (2 * (n : ℝ)))) = 1 := by
    have harg : Complex.I * (Real.pi : ℂ) * (Complex.ofReal (2 * (n : ℝ)))
        = (n : ℂ) * (2 * (Real.pi : ℂ) * Complex.I) := by
      push_cast; ring
    rw [harg]; exact Complex.exp_int_mul_two_pi_mul_I n
  rw [hexp]; ring

/-- At odd integers the branch factor is `2`: the model is `2·aˣ`,
exhibiting the parity split of the old function. -/
theorem altBranchModel_odd_int (a : ℝ) (n : ℤ) :
    altBranchModel a (2 * (n : ℝ) + 1)
      = 2 * (Real.rpow a (2 * (n : ℝ) + 1) : ℂ) := by
  unfold altBranchModel
  have hexp : Complex.exp (Complex.I * (Real.pi : ℂ)
      * (Complex.ofReal (2 * (n : ℝ) + 1))) = -1 := by
    have harg : Complex.I * (Real.pi : ℂ) * (Complex.ofReal (2 * (n : ℝ) + 1))
        = (n : ℂ) * (2 * (Real.pi : ℂ) * Complex.I)
          + (Real.pi : ℂ) * Complex.I := by
      push_cast; ring
    rw [harg, Complex.exp_add, Complex.exp_int_mul_two_pi_mul_I n,
      Complex.exp_pi_mul_I]
    ring
  rw [hexp]; ring

-- --- Tier 88.7 — The finite compression operator ----------------------

/-- The **finite** compression operator: a disciplined, finite-cutoff
replacement for the old "trap a variable between two alternating infinite
series" notation.
`C_N(A,B) = Σ_{p=1}^{N} ( Σ_{k=N-p}^{N} A_k − Σ_{k=N+1-p}^{N} B_k )`. -/
noncomputable def compressionPartial (A B : ℕ → ℂ) (N : ℕ) : ℂ :=
  ∑ p ∈ Finset.Icc 1 N,
    ((∑ k ∈ Finset.Icc (N - p) N, A k)
      - (∑ k ∈ Finset.Icc (N + 1 - p) N, B k))

@[simp] theorem compressionPartial_zero (A B : ℕ → ℂ) :
    compressionPartial A B 0 = 0 := by
  rw [compressionPartial, Finset.Icc_eq_empty (by norm_num),
    Finset.sum_empty]

/-- With equal kernels the compression operator collapses to a pure
boundary sum — it is a weighted finite-difference operator, not a
mystical object. -/
theorem compressionPartial_same_eq_boundary (A : ℕ → ℂ) (N : ℕ) :
    compressionPartial A A N = ∑ p ∈ Finset.Icc 1 N, A (N - p) := by
  have hset : ∀ m : ℕ, m ≤ N →
      Finset.Icc m N = insert m (Finset.Icc (m + 1) N) := by
    intro m hm
    ext x
    simp only [Finset.mem_Icc, Finset.mem_insert]
    omega
  have key : ∀ m : ℕ, m ≤ N →
      (∑ k ∈ Finset.Icc m N, A k)
        - (∑ k ∈ Finset.Icc (m + 1) N, A k) = A m := by
    intro m hm
    have hnotmem : m ∉ Finset.Icc (m + 1) N := by
      simp only [Finset.mem_Icc]; omega
    rw [hset m hm, Finset.sum_insert hnotmem]; ring
  rw [compressionPartial]
  apply Finset.sum_congr rfl
  intro p hp
  rw [Finset.mem_Icc] at hp
  have hpsub : N + 1 - p = (N - p) + 1 := by omega
  rw [hpsub]
  exact key (N - p) (by omega)

/-- Convergence predicate for the compression operator. -/
def compressionLimit (A B : ℕ → ℂ) (L : ℂ) : Prop :=
  Filter.Tendsto (fun N => compressionPartial A B N) Filter.atTop (nhds L)

/-- A concrete zeta-weighted kernel of the type the old "alternating
compression" note studied: `((b^k − 1)·ζ(k+1)) / (b+1)^k`. -/
noncomputable def zetaCompressionKernel (b k : ℕ) : ℂ :=
  ((b : ℂ) ^ k - 1) * riemannZeta ((k : ℂ) + 1) / ((b : ℂ) + 1) ^ k

-- --- Tier 88.8 — Completed ξ logarithmic-derivative interface ---------

/-- The completed Riemann ξ-function,
`ξ(s) = ½ s(s−1) π^{−s/2} Γ(s/2) ζ(s)`. -/
noncomputable def completedXi (s : ℂ) : ℂ :=
  (1 / 2 : ℂ) * s * (s - 1)
    * Complex.exp (-(s / 2) * (Real.log Real.pi : ℂ))
    * Complex.Gamma (s / 2)
    * riemannZeta s

/-- The digamma function `ψ(z) = (log Γ)'(z)`. -/
noncomputable def digamma (z : ℂ) : ℂ :=
  deriv (fun w => Complex.log (Complex.Gamma w)) z

@[simp] theorem completedXi_zero : completedXi 0 = 0 := by
  simp [completedXi]

@[simp] theorem completedXi_one : completedXi 1 = 0 := by
  simp [completedXi]

/-- **Interface** for the completed-ξ logarithmic-derivative identity

    ξ'/ξ (s) = 1/s + 1/(s−1) − ½ log π + ½ ψ(s/2) + ζ'/ζ (s).

A term of this structure packages the analytic identity at a point.
Constructing one requires digamma-reflection / `ζ'/ζ` infrastructure not
yet in Mathlib; this is an honest interface, not an axiom or a `sorry`. -/
structure XiLogDerivative where
  point : ℂ
  ne_zero : point ≠ 0
  ne_one : point ≠ 1
  zeta_ne : riemannZeta point ≠ 0
  gamma_ne : Complex.Gamma (point / 2) ≠ 0
  logDeriv_eq :
    deriv completedXi point / completedXi point
      = 1 / point + 1 / (point - 1)
        - (1 / 2 : ℂ) * (Real.log Real.pi : ℂ)
        + (1 / 2 : ℂ) * digamma (point / 2)
        + deriv riemannZeta point / riemannZeta point

-- --- Tier 88.9 — Prime-zeta expansion interface -----------------------

/-- **Interface** for the prime-zeta expansion `log ζ(s) = Σ_{j≥1} P(js)/j`,
with `P` the prime zeta function.  Inhabiting it supplies the analytic
convergence theory; again an honest interface, no axiom, no `sorry`. -/
structure PrimeZetaExpansion where
  primeZeta : ℂ → ℂ
  domain : Set ℂ
  log_zeta_eq :
    ∀ s ∈ domain,
      Complex.log (riemannZeta s)
        = ∑' j : ℕ, primeZeta (((j : ℂ) + 1) * s) / ((j : ℂ) + 1)

