-- =====================================================================
-- === Tier 19 — Higher-order Toeplitz PSD ============================
-- =====================================================================
-- Extend Tier 16/17 (two-point, three-point Toeplitz PSD) to N=4 and
-- N=5 via explicit Cholesky factorizations provable by `ring`. The
-- factorization pattern:
--   `Σ cᵢcⱼ r^|i−j|  =  (Σ cᵢ rⁱ)²
--                       + (1−r²) · Σ_{k=1}^{N−1} (Σ_{i≥k} cᵢ r^{i−k})²`
-- generalizes to arbitrary N, but the Finset-level induction proof is
-- substantial work; landing N=4 and N=5 here demonstrates the pattern
-- extends concretely beyond the 3-point case.

/-- **Four-point Toeplitz PSD.**
For `0 ≤ r ≤ 1` and any reals `a, b, c, d`:
  `0 ≤ a² + b² + c² + d²
        + 2r(ab + bc + cd) + 2r²(ac + bd) + 2r³(ad)`.

The 4×4 Toeplitz Gram matrix is PSD. Cholesky decomposition:
  `(a + br + cr² + dr³)²
     + (1−r²)·[(b + cr + dr²)² + (c + dr)² + d²]`. -/
theorem toeplitzKernel_four_point_psd
    {r a b c d : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2
          + 2 * r * (a * b + b * c + c * d)
          + 2 * r ^ 2 * (a * c + b * d)
          + 2 * r ^ 3 * (a * d) := by
  have h_identity :
      a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2
        + 2 * r * (a * b + b * c + c * d)
        + 2 * r ^ 2 * (a * c + b * d)
        + 2 * r ^ 3 * (a * d)
      = (a + b * r + c * r ^ 2 + d * r ^ 3) ^ 2
        + (1 - r ^ 2)
            * ((b + c * r + d * r ^ 2) ^ 2
                + (c + d * r) ^ 2
                + d ^ 2) := by ring
  rw [h_identity]
  have h_one_sub_sq : 0 ≤ 1 - r ^ 2 := by
    nlinarith [sq_nonneg (1 - r), hr0, hr1]
  have h_sq_main : 0 ≤ (a + b * r + c * r ^ 2 + d * r ^ 3) ^ 2 := sq_nonneg _
  have h_sq_tail :
      0 ≤ (b + c * r + d * r ^ 2) ^ 2 + (c + d * r) ^ 2 + d ^ 2 := by
    have h1 : 0 ≤ (b + c * r + d * r ^ 2) ^ 2 := sq_nonneg _
    have h2 : 0 ≤ (c + d * r) ^ 2 := sq_nonneg _
    have h3 : 0 ≤ d ^ 2 := sq_nonneg _
    linarith
  have h_prod : 0 ≤ (1 - r ^ 2)
      * ((b + c * r + d * r ^ 2) ^ 2 + (c + d * r) ^ 2 + d ^ 2) :=
    mul_nonneg h_one_sub_sq h_sq_tail
  linarith

/-- **Five-point Toeplitz PSD.**
For `0 ≤ r ≤ 1` and reals `a, b, c, d, e`:
  the 5×5 Toeplitz Gram matrix is PSD.

Cholesky decomposition:
  `(a + br + cr² + dr³ + er⁴)²
     + (1−r²) · [(b + cr + dr² + er³)²
                + (c + dr + er²)²
                + (d + er)²
                + e²]`. -/
theorem toeplitzKernel_five_point_psd
    {r a b c d e : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 + e ^ 2
          + 2 * r * (a * b + b * c + c * d + d * e)
          + 2 * r ^ 2 * (a * c + b * d + c * e)
          + 2 * r ^ 3 * (a * d + b * e)
          + 2 * r ^ 4 * (a * e) := by
  have h_identity :
      a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 + e ^ 2
        + 2 * r * (a * b + b * c + c * d + d * e)
        + 2 * r ^ 2 * (a * c + b * d + c * e)
        + 2 * r ^ 3 * (a * d + b * e)
        + 2 * r ^ 4 * (a * e)
      = (a + b * r + c * r ^ 2 + d * r ^ 3 + e * r ^ 4) ^ 2
        + (1 - r ^ 2)
            * ((b + c * r + d * r ^ 2 + e * r ^ 3) ^ 2
                + (c + d * r + e * r ^ 2) ^ 2
                + (d + e * r) ^ 2
                + e ^ 2) := by ring
  rw [h_identity]
  have h_one_sub_sq : 0 ≤ 1 - r ^ 2 := by
    nlinarith [sq_nonneg (1 - r), hr0, hr1]
  have h_sq_main :
      0 ≤ (a + b * r + c * r ^ 2 + d * r ^ 3 + e * r ^ 4) ^ 2 := sq_nonneg _
  have h_sq_tail :
      0 ≤ (b + c * r + d * r ^ 2 + e * r ^ 3) ^ 2
            + (c + d * r + e * r ^ 2) ^ 2
            + (d + e * r) ^ 2
            + e ^ 2 := by
    have h1 : 0 ≤ (b + c * r + d * r ^ 2 + e * r ^ 3) ^ 2 := sq_nonneg _
    have h2 : 0 ≤ (c + d * r + e * r ^ 2) ^ 2 := sq_nonneg _
    have h3 : 0 ≤ (d + e * r) ^ 2 := sq_nonneg _
    have h4 : 0 ≤ e ^ 2 := sq_nonneg _
    linarith
  have h_prod : 0 ≤ (1 - r ^ 2)
      * ((b + c * r + d * r ^ 2 + e * r ^ 3) ^ 2
          + (c + d * r + e * r ^ 2) ^ 2
          + (d + e * r) ^ 2
          + e ^ 2) :=
    mul_nonneg h_one_sub_sq h_sq_tail
  linarith

/-- 4-point PSD specialized at a spectral contraction pair. -/
theorem SpectralContractionPair.toeplitzKernel_four_point_psd
    (S : SpectralContractionPair) (a b c d : ℝ) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2
          + 2 * ‖S.lam‖ * (a * b + b * c + c * d)
          + 2 * ‖S.lam‖ ^ 2 * (a * c + b * d)
          + 2 * ‖S.lam‖ ^ 3 * (a * d) :=
  GoldenAlgebra.toeplitzKernel_four_point_psd (norm_nonneg _) (le_of_lt S.hlam)

/-- 5-point PSD specialized at a spectral contraction pair. -/
theorem SpectralContractionPair.toeplitzKernel_five_point_psd
    (S : SpectralContractionPair) (a b c d e : ℝ) :
    0 ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 + e ^ 2
          + 2 * ‖S.lam‖ * (a * b + b * c + c * d + d * e)
          + 2 * ‖S.lam‖ ^ 2 * (a * c + b * d + c * e)
          + 2 * ‖S.lam‖ ^ 3 * (a * d + b * e)
          + 2 * ‖S.lam‖ ^ 4 * (a * e) :=
  GoldenAlgebra.toeplitzKernel_five_point_psd (norm_nonneg _) (le_of_lt S.hlam)

/-! ## Tier 19 Pattern Summary

The Cholesky factorization for the Toeplitz Gram matrix `K(i,j) = r^|i−j|`:
```
Σ_{i,j < N} cᵢ cⱼ r^|i−j|
  = (Σ_{i < N} cᵢ rⁱ)²
    + (1 − r²) · Σ_{k=1}^{N−1} (Σ_{i ≥ k, i < N} cᵢ r^{i−k})²
```
extends to arbitrary `N`. The identity holds entry-wise via
`r^|i−j| = r^i · r^j + (1 − r²) · Σ_{k=1}^{min(i,j)} r^{i−k} · r^{j−k}`
(a telescoping geometric-series identity).

Tier 16/17/19 cover the cases `N = 2, 3, 4, 5` with explicit
`ring`-provable identities. Tier 20 lifts the same factorization to
arbitrary finite length via `List ℝ` structural recursion. -/

-- =====================================================================
-- === Tier 20 — Arbitrary finite Toeplitz PSD via list recursion =====
-- =====================================================================
-- Lift the explicit N=2,3,4,5 cases to **arbitrary finite length** by
-- moving from `Fin N` indexing to `List ℝ` recursion. The recursive
-- structure of `(a :: xs)` exactly matches the Cholesky factorization
-- step, turning the previously index-heavy inductive proof into a
-- single structural induction closed by `ring`.

/-- Recursive polynomial evaluation:
  `powEval r [a, b, c, …] = a + r·b + r²·c + …`. -/
noncomputable def powEval (r : ℝ) : List ℝ → ℝ
  | [] => 0
  | a :: xs => a + r * powEval r xs

/-- Recursive Toeplitz quadratic form:
  `toeplitzQ r [c₀, c₁, …, c_{N−1}] = Σᵢⱼ cᵢ·cⱼ·r^|i−j|`. -/
noncomputable def toeplitzQ (r : ℝ) : List ℝ → ℝ
  | [] => 0
  | a :: xs => a ^ 2 + 2 * a * r * powEval r xs + toeplitzQ r xs

/-- Recursive Cholesky tail energy: the sum of squared `powEval`s of
all suffixes (excluding the full list itself). -/
noncomputable def tailEnergy (r : ℝ) : List ℝ → ℝ
  | [] => 0
  | _ :: xs => (powEval r xs) ^ 2 + tailEnergy r xs

/-- **The arbitrary-N Cholesky factorization for Toeplitz quadratic
forms.** For every list of coefficients `xs`:
  `toeplitzQ r xs = (powEval r xs)² + (1 − r²) · tailEnergy r xs`.

The single algebraic step in the inductive case is
`a² + 2arP + P² + (1−r²)E = (a + rP)² + (1−r²)(P² + E)` (`ring`).

This delivers the arbitrary finite Cholesky decomposition without
any `Fin N` index manipulation. -/
theorem toeplitzQ_cholesky (r : ℝ) :
    ∀ xs : List ℝ,
      toeplitzQ r xs
        = (powEval r xs) ^ 2 + (1 - r ^ 2) * tailEnergy r xs := by
  intro xs
  induction xs with
  | nil => simp [toeplitzQ, powEval, tailEnergy]
  | cons a xs ih =>
    simp only [toeplitzQ, powEval, tailEnergy, ih]
    ring

/-- The Cholesky tail energy is non-negative (sum of squares). -/
theorem tailEnergy_nonneg (r : ℝ) :
    ∀ xs : List ℝ, 0 ≤ tailEnergy r xs := by
  intro xs
  induction xs with
  | nil => simp [tailEnergy]
  | cons _ xs ih =>
    simp only [tailEnergy]
    exact add_nonneg (sq_nonneg _) ih

/-- **Arbitrary finite Toeplitz PSD theorem (the bold theorem).**

For any list of coefficients `xs` and any `0 ≤ r ≤ 1`:
  `0 ≤ toeplitzQ r xs  =  Σᵢⱼ xᵢ·xⱼ·r^|i−j|`.

The Toeplitz Gram matrix `K(i,j) = r^|i−j|` is positive semi-definite
at **arbitrary finite dimension** — the RKHS doorway is now open. -/
theorem toeplitzQ_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) :
    ∀ xs : List ℝ, 0 ≤ toeplitzQ r xs := by
  intro xs
  rw [toeplitzQ_cholesky r xs]
  have h1 : 0 ≤ (powEval r xs) ^ 2 := sq_nonneg _
  have h2 : 0 ≤ 1 - r ^ 2 := by nlinarith [hr0, hr1, sq_nonneg r]
  have h3 : 0 ≤ tailEnergy r xs := tailEnergy_nonneg r xs
  have h4 : 0 ≤ (1 - r ^ 2) * tailEnergy r xs := mul_nonneg h2 h3
  linarith

/-- **Specialization at a spectral contraction pair.**
Arbitrary finite-length PSD for the spectral Toeplitz quadratic form. -/
theorem SpectralContractionPair.toeplitzQ_nonneg
    (S : SpectralContractionPair) (xs : List ℝ) :
    0 ≤ toeplitzQ ‖S.lam‖ xs :=
  GoldenAlgebra.toeplitzQ_nonneg (norm_nonneg _) (le_of_lt S.hlam) xs

/-! ## Tier 20 — RKHS Doorway Genuinely Open

The list-recursion route delivers arbitrary finite Toeplitz PSD in
three short theorems:

* `toeplitzQ_cholesky` — Cholesky factorization, single `ring`-closed
   inductive step.
* `tailEnergy_nonneg` — non-negativity of the Cholesky tail energy.
* `toeplitzQ_nonneg` — the flagship arbitrary-N PSD theorem.

Plus `SpectralContractionPair.toeplitzQ_nonneg` (the spectral
specialization).

The previously open *RKHS doorway* is now substantively open: every
finite-dimensional Toeplitz Gram matrix is provably PSD. The next
stages — Fin-list adapter, matrix-level PSD, RKHS finite-kernel
construction — are plumbing layered on this analytic core. -/

-- =====================================================================
-- === Tier 21 — Council Bridge: Real-Rooted Polys → HP Approximation ==
-- =====================================================================
/-!
## Tier 21 — From Real-Rooted Polynomial Approximation to HP

The Council's central recommendation: **build finite approximants from
coefficient/moment data, not from zeros.** Higher-level analytic work
(Jensen polynomials, Hamburger moment problem, de Branges spaces,
total-positivity kernels) produces sequences of *real-rooted polynomial
approximants* to a target entire function. The Diamond Tier-16
machinery operates on `HermitianDeterminantApproximation`. Tier 21 is
the **bridge** between these two perspectives.

Key observation (Council I — Euclid, V — Riemann):
> Every real-rooted monic polynomial with roots `r₁, ..., rₙ ∈ ℝ` is
> the characteristic determinant of a Hermitian diagonal matrix
> `diag(r₁, ..., rₙ)`.

This is *unconditional* and *immediate*. The Lean bridge says:
real-rooted polynomial approximation upgrades, automatically, to a
Hermitian determinant approximation. The Diamond then concludes:
the limit has only real zeros (modulo Hurwitz).

Components:
* `realDiagonal r : Matrix (Fin N) (Fin N) ℂ` — diagonal matrix with
  real entries `r : Fin N → ℝ`.
* `realDiagonal_isHermitian` — unconditional Hermitian property.
* `charDet_realDiagonal_eq_prod` — `charDet (realDiagonal r) z =
  ∏ i, (z − rᵢ)`.
* `RealRootedPolynomialApproximation Xi` — structure: a sequence of
  real-root tuples whose corresponding linear-factor products converge
  locally uniformly to `Xi`.
* `RealRootedPolynomialApproximation.toHermitianApproximation` — the
  **flagship bridge** to the Diamond `HermitianDeterminantApproximation`.
* `realRooted_diamond_limit` — the immediate corollary: any
  real-rooted polynomial approximation + Hurwitz ⇒ `Xi` has real zeros.

Coefficient-side feeders for this bridge (left as analytic open work):
* **Jensen polynomial approximation** — when an entire function has
  real Taylor coefficients with a Pólya frequency / Laguerre–Pólya
  structure, its Jensen polynomials are real-rooted and converge
  locally uniformly to a transform of the function.
* **Hamburger moment / Jacobi route** — when an entire function has a
  positive-measure integral representation, its truncated orthogonal
  polynomials are real-rooted (eigenvalues of the truncated Jacobi
  matrix).
* **de Branges / Hermite–Biehler route** — when an entire function
  admits a Hermite–Biehler companion, multiplication by the variable
  in the de Branges space provides a self-adjoint operator whose
  finite truncations have real-rooted characteristic determinants.
* **Total-positivity / Pólya frequency route** — when a kernel is
  totally positive, finite truncations of its Fourier/cosine transform
  inherit real-zero behaviour.

Tier 21 makes the bridge from any of these routes to the Diamond
machinery a **single unconditional Lean lemma**.
-/

-- --- Tier 21.1 — Real-diagonal Hermitian matrix --------------------

/-- **Real diagonal matrix** with entries `r : Fin N → ℝ`, cast to `ℂ`. -/
noncomputable def realDiagonal {N : ℕ} (r : Fin N → ℝ) : Matrix (Fin N) (Fin N) ℂ :=
  Matrix.diagonal (fun i => ((r i : ℝ) : ℂ))

/-- The real diagonal matrix is Hermitian: `star ((rᵢ : ℂ)) = (rᵢ : ℂ)`. -/
theorem realDiagonal_isHermitian {N : ℕ} (r : Fin N → ℝ) :
    (realDiagonal r).IsHermitian := by
  unfold realDiagonal
  rw [Matrix.isHermitian_diagonal_iff]
  intro i
  show star ((r i : ℝ) : ℂ) = ((r i : ℝ) : ℂ)
  exact Complex.conj_ofReal (r i)

-- --- Tier 21.2 — charDet of real diagonal factors over the real entries --

/-- For real `r : Fin N → ℝ`, the characteristic determinant of the
real-diagonal matrix factors as a product of linear factors:
`charDet (realDiagonal r) z = ∏ i, (z − rᵢ)`. -/
theorem charDet_realDiagonal_eq_prod {N : ℕ} (r : Fin N → ℝ) (z : ℂ) :
    charDet (realDiagonal r) z = ∏ i : Fin N, (z - ((r i : ℝ) : ℂ)) := by
  unfold charDet realDiagonal
  -- z • 1 - diagonal d = diagonal (fun i => z - d i)
  have hdiag : z • (1 : Matrix (Fin N) (Fin N) ℂ) - Matrix.diagonal (fun i => ((r i : ℝ) : ℂ))
      = Matrix.diagonal (fun i : Fin N => z - ((r i : ℝ) : ℂ)) := by
    ext i j
    by_cases h : i = j
    · subst h
      simp [Matrix.smul_apply, Matrix.one_apply_eq, Matrix.sub_apply,
        Matrix.diagonal_apply_eq]
    · simp [Matrix.smul_apply, Matrix.one_apply_ne h, Matrix.sub_apply,
        Matrix.diagonal_apply_ne _ h]
  rw [hdiag, Matrix.det_diagonal]

-- --- Tier 21.3 — RealRootedPolynomialApproximation structure ---------

/-- **Real-Rooted Polynomial Approximation** of an entire function `Xi`.

A sequence of finite real-root tuples `r_N : Fin (dim N) → ℝ` whose
corresponding linear-factor products
`P_N(z) := ∏ᵢ (z − r_{N,i})` converge locally uniformly to `Xi`.

This is the natural output of any coefficient-side / moment-side /
de-Branges-side / total-positivity-side real-rooting program. Tier 21
upgrades it automatically to a `HermitianDeterminantApproximation`. -/
structure RealRootedPolynomialApproximation (Xi : ℂ → ℂ) where
  /-- Dimension of the `N`-th approximant. -/
  dim : ℕ → ℕ
  /-- Real roots of the `N`-th approximant. -/
  roots : ∀ N : ℕ, Fin (dim N) → ℝ
  /-- The product polynomials converge locally uniformly to `Xi`. -/
  locallyUniform :
    TendstoLocallyUniformly
      (fun N : ℕ => fun z : ℂ =>
        ∏ i : Fin (dim N), (z - ((roots N i : ℝ) : ℂ)))
      Xi Filter.atTop
  /-- `Xi` is not identically zero. -/
  nonzero : Xi ≠ 0
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- Each product polynomial is entire (always true for a finite product
  of entire linear factors; recorded as a field for Diamond compatibility). -/
  approx_entire : ∀ N : ℕ,
    AnalyticOnNhd ℂ
      (fun z : ℂ => ∏ i : Fin (dim N), (z - ((roots N i : ℝ) : ℂ)))
      Set.univ

-- --- Tier 21.4 — The flagship bridge ---------------------------------

/-- **Flagship bridge: real-rooted polynomial approximation upgrades
to Hermitian determinant approximation.**

Given a `RealRootedPolynomialApproximation Xi`, the corresponding
`HermitianDeterminantApproximation Xi` is built by:
* taking `matrix N := realDiagonal (roots N)`,
* which is Hermitian by `realDiagonal_isHermitian`,
* whose characteristic determinant equals the product polynomial by
  `charDet_realDiagonal_eq_prod`,
* and the local-uniform convergence of the products to `Xi` transports
  through this rewrite.

This is the **single bridge lemma** the Council asked for: it makes
any coefficient-side real-rooting program (Jensen, Hamburger, de
Branges, total positivity) immediately compatible with the Diamond
HP transfer. -/
noncomputable def RealRootedPolynomialApproximation.toHermitianApproximation
    {Xi : ℂ → ℂ} (H : RealRootedPolynomialApproximation Xi) :
    HermitianDeterminantApproximation Xi where
  dim := H.dim
  matrix := fun N => realDiagonal (H.roots N)
  isHermitian := fun N => realDiagonal_isHermitian (H.roots N)
  approx := by
    have hcongr : (fun N : ℕ => fun z : ℂ => charDet (realDiagonal (H.roots N)) z)
                = (fun N : ℕ => fun z : ℂ =>
                    ∏ i : Fin (H.dim N), (z - ((H.roots N i : ℝ) : ℂ))) := by
      funext N z
      exact charDet_realDiagonal_eq_prod (H.roots N) z
    rw [hcongr]
    exact H.locallyUniform
  nonzero := H.nonzero
  entire := H.entire
  approx_entire := by
    intro N
    have hcongr : (fun z : ℂ => charDet (realDiagonal (H.roots N)) z)
                = (fun z : ℂ =>
                    ∏ i : Fin (H.dim N), (z - ((H.roots N i : ℝ) : ℂ))) := by
      funext z
      exact charDet_realDiagonal_eq_prod (H.roots N) z
    rw [hcongr]
    exact H.approx_entire N

-- --- Tier 21.5 — Direct diamond corollaries --------------------------

/-- **Diamond limit for real-rooted polynomial approximation.**

If `Xi` is the local-uniform limit of finite real-rooted polynomials
and the Hurwitz zero-transfer principle holds, then `Xi` has only real
zeros.

This is the Council's "polygon-to-circle" theorem in its sharpest
form: real-rootedness of finite approximants passes to the limit. -/
theorem realRooted_diamond_limit
    {Xi : ℂ → ℂ}
    (H : RealRootedPolynomialApproximation Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyRealZeros Xi :=
  diamond_HP_limit_principle H.toHermitianApproximation hHurwitz

/-- **Critical-line form** of the real-rooted-poly Diamond limit. -/
theorem realRooted_diamond_critical_line
    {xi : ℂ → ℂ}
    (H : RealRootedPolynomialApproximation (criticalPullback xi))
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyCriticalLineZeros xi := by
  have hreal := realRooted_diamond_limit H hHurwitz
  exact (criticalLineZeros_iff_realZeros_pullback xi).mpr hreal

/-! ## Tier 21 Status Summary

Tier 21 lands the **Council Bridge** from real-rooted polynomial
approximation to Hermitian determinant approximation.

Unconditional:
* `realDiagonal` — real-diagonal matrix definition.
* `realDiagonal_isHermitian` — Hermitian property via
  `Matrix.isHermitian_diagonal_iff` and `Complex.conj_ofReal`.
* `charDet_realDiagonal_eq_prod` — `charDet (realDiagonal r) z =
  ∏ (z − rᵢ)` via `Matrix.det_diagonal`.
* `RealRootedPolynomialApproximation` — the missing-object structure
  expressed *purely in terms of polynomial data*.
* **`RealRootedPolynomialApproximation.toHermitianApproximation`** —
  the flagship bridge to the Diamond `HermitianDeterminantApproximation`.

Conditional (Hurwitz only):
* **`realRooted_diamond_limit`** — coefficient-side real-rooting
  programs feed the Diamond machinery automatically.
* `realRooted_diamond_critical_line` — critical-line form.

Coefficient-side feeders (analytic open work, *not* in this file):
1. Jensen-polynomial approximation under Laguerre–Pólya structure.
2. Hamburger moment / orthogonal-polynomial / Jacobi-matrix route.
3. de Branges / Hermite–Biehler companion construction.
4. Total-positivity / Pólya-frequency kernel theory.

Any of these analytic routes, once carried out for a specific target
`Xi`, yields a `RealRootedPolynomialApproximation Xi` that
*immediately* gives `HasOnlyRealZeros Xi` modulo Hurwitz.

The Tier 21 chain depends only on standard Lean/Mathlib axioms; none
of the three GoldenAlgebra-specific axioms appear. The bridge converts
the Diamond endpoint from a single conditional theorem into a
publication-grade **dispatcher** that any analytic side-channel can
feed. -/

-- =====================================================================
-- === Tier 22 — Fin/List Adapter for Toeplitz PSD ====================
-- =====================================================================
-- Bridge from arbitrary-N Toeplitz PSD over `List ℝ` (Tier 20) to
-- finite coefficient vectors `c : Fin n → ℝ` via `List.ofFn`.

/-- **Toeplitz PSD for finite coefficient vectors.**
For any `0 ≤ r ≤ 1`, any `n`, and any `c : Fin n → ℝ`:
  `0 ≤ toeplitzQ r (List.ofFn c)`.
Direct specialization of `toeplitzQ_nonneg` (Tier 20). -/
theorem toeplitzQ_ofFn_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1)
    {n : ℕ} (c : Fin n → ℝ) :
    0 ≤ toeplitzQ r (List.ofFn c) :=
  toeplitzQ_nonneg hr0 hr1 (List.ofFn c)

/-- Spectral specialization: every finite coefficient vector inherits
positivity from a contraction. -/
theorem SpectralContractionPair.toeplitzQ_ofFn_nonneg
    (S : SpectralContractionPair) {n : ℕ} (c : Fin n → ℝ) :
    0 ≤ toeplitzQ ‖S.lam‖ (List.ofFn c) :=
  GoldenAlgebra.toeplitzQ_ofFn_nonneg (norm_nonneg _) (le_of_lt S.hlam) c

-- =====================================================================
-- === Tier 23 — Kernel API + KernelPSD predicate =====================
-- =====================================================================
-- Define the abstract positive-semi-definite kernel predicate and
-- relate it to the Toeplitz kernel via the list-based PSD theorem.

/-- **Abstract positive semi-definite kernel predicate.**
A kernel `K : ι → ι → ℝ` on a finite index type is PSD iff every
coefficient vector produces a non-negative quadratic form. -/
def KernelPSD {ι : Type} [Fintype ι] (K : ι → ι → ℝ) : Prop :=
  ∀ c : ι → ℝ, 0 ≤ ∑ i, ∑ j, c i * c j * K i j

/-- **Toeplitz kernel symmetry** (already proved at Tier 16) — copied
here for the `FinitePositiveKernel` structure. -/
theorem toeplitzKernel_symm_nat (r : ℝ) (i j : ℕ) :
    r ^ Int.natAbs ((i : ℤ) - (j : ℤ))
      = r ^ Int.natAbs ((j : ℤ) - (i : ℤ)) := by
  congr 1
  rw [show ((i : ℤ) - (j : ℤ)) = -((j : ℤ) - (i : ℤ)) from by ring]
  exact Int.natAbs_neg _

-- =====================================================================
-- === Tier 24 — Finite Positive Kernel Structure ======================
-- =====================================================================
-- The abstract finite positive-kernel object: a symmetric PSD kernel
-- on a finite index type. The doorway target for RKHS construction.

/-- **Finite positive kernel.**
The abstract data of a positive semi-definite symmetric kernel on a
finite index type. The standard input for finite-dimensional RKHS
construction. -/
structure FinitePositiveKernel where
  /-- The (finite) index type. -/
  ι : Type
  /-- Finite-type instance. -/
  [fintype : Fintype ι]
  /-- The kernel function. -/
  K : ι → ι → ℝ
  /-- Symmetry. -/
  symmetric : ∀ i j, K i j = K j i
  /-- Positive semi-definiteness. -/
  psd : KernelPSD K

attribute [instance] FinitePositiveKernel.fintype

-- --- Bridge: Fin/Σ ↔ List/recursive forms --------------------------

/-- `powEval r (List.ofFn g) = Σ_{k : Fin m} g k · r^k`. -/
lemma powEval_ofFn (r : ℝ) :
    ∀ {m : ℕ} (g : Fin m → ℝ),
      powEval r (List.ofFn g) = ∑ k : Fin m, g k * r ^ (k : ℕ) := by
  intro m
  induction m with
  | zero => intro g; simp [List.ofFn_zero, powEval]
  | succ m ih =>
    intro g
    rw [List.ofFn_succ, powEval, ih (fun i : Fin m => g i.succ)]
    rw [Fin.sum_univ_succ]
    simp only [Fin.val_zero, pow_zero, mul_one, Fin.val_succ, pow_succ]
    rw [Finset.mul_sum]
    congr 1
    apply Finset.sum_congr rfl
    intro k _
    ring

/-- **The matrix–list bridge.**
For any `r` and any `c : Fin n → ℝ`:
  `Σᵢⱼ cᵢ·cⱼ·toeplitzKernel r i j = toeplitzQ r (List.ofFn c)`.

Peeling off `i = 0` and `j = 0` from the double sum, then applying
shift-invariance of the Toeplitz kernel under `i ↦ i.succ`, matches the
recursive `toeplitzQ` head decomposition. -/
theorem toeplitzKernel_sum_eq_toeplitzQ_ofFn (r : ℝ) :
    ∀ {n : ℕ} (c : Fin n → ℝ),
      ∑ i : Fin n, ∑ j : Fin n,
          c i * c j * toeplitzKernel r i j
        = toeplitzQ r (List.ofFn c) := by
  intro n
  induction n with
  | zero =>
    intro c
    simp [List.ofFn_zero, toeplitzQ]
  | succ n ih =>
    intro c
    rw [List.ofFn_succ, toeplitzQ]
    rw [Fin.sum_univ_succ]
    have h_K00 : toeplitzKernel r ((0 : Fin (n + 1)) : ℕ) (0 : Fin (n + 1)) = 1 := by
      unfold toeplitzKernel; simp
    have h_K0j : ∀ j : Fin n,
        toeplitzKernel r ((0 : Fin (n + 1)) : ℕ) j.succ
          = r ^ ((j.succ : ℕ)) := by
      intro j
      unfold toeplitzKernel
      congr 1
    have h_Ki0 : ∀ i : Fin n,
        toeplitzKernel r i.succ ((0 : Fin (n + 1)) : ℕ) = r ^ ((i.succ : ℕ)) := by
      intro i
      unfold toeplitzKernel
      congr 1
    have h_Kij : ∀ i j : Fin n,
        toeplitzKernel r (i.succ : Fin (n + 1)) (j.succ : Fin (n + 1))
          = toeplitzKernel r (i : Fin n) (j : Fin n) := by
      intro i j
      unfold toeplitzKernel
      simp only [Fin.val_succ]
      congr 1
      omega
    have h_outer0 :
        ∑ j : Fin (n + 1),
            c 0 * c j * toeplitzKernel r ((0 : Fin (n + 1)) : ℕ) j
          = (c 0) ^ 2 + c 0 *
              ∑ j : Fin n, c j.succ * r ^ ((j.succ : ℕ)) := by
      rw [Fin.sum_univ_succ]
      rw [h_K00]
      have : (∑ j : Fin n,
            c 0 * c j.succ * toeplitzKernel r ((0 : Fin (n + 1)) : ℕ) j.succ)
          = c 0 * ∑ j : Fin n, c j.succ * r ^ ((j.succ : ℕ)) := by
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro j _
        rw [h_K0j j]
        ring
      rw [this]
      ring
    have h_inner_outer :
        ∑ i : Fin n, ∑ j : Fin (n + 1),
            c i.succ * c j * toeplitzKernel r i.succ j
          = c 0 * (∑ i : Fin n, c i.succ * r ^ ((i.succ : ℕ)))
            + ∑ i : Fin n, ∑ j : Fin n,
                c i.succ * c j.succ * toeplitzKernel r (i : Fin n) (j : Fin n) := by
      rw [show c 0 * (∑ i : Fin n, c i.succ * r ^ ((i.succ : ℕ)))
            + ∑ i : Fin n, ∑ j : Fin n,
                c i.succ * c j.succ * toeplitzKernel r (i : Fin n) (j : Fin n)
          = ∑ i : Fin n, (c 0 * (c i.succ * r ^ ((i.succ : ℕ)))
            + ∑ j : Fin n,
                c i.succ * c j.succ * toeplitzKernel r (i : Fin n) (j : Fin n))
          from by rw [Finset.mul_sum, Finset.sum_add_distrib]]
      apply Finset.sum_congr rfl
      intro i _
      rw [Fin.sum_univ_succ]
      rw [h_Ki0 i]
      have h_inner : ∑ j : Fin n,
              c i.succ * c j.succ * toeplitzKernel r i.succ j.succ
            = ∑ j : Fin n,
              c i.succ * c j.succ * toeplitzKernel r (i : Fin n) (j : Fin n) := by
        apply Finset.sum_congr rfl
        intro j _
        rw [h_Kij i j]
      rw [h_inner]
      ring
    rw [h_outer0, h_inner_outer]
    have h_ih := ih (fun i : Fin n => c i.succ)
    have h_pow : powEval r (List.ofFn (fun i : Fin n => c i.succ))
        = ∑ k : Fin n, c k.succ * r ^ ((k : ℕ)) :=
      powEval_ofFn r (fun i : Fin n => c i.succ)
    have h_shift : (∑ k : Fin n, c k.succ * r ^ ((k.succ : ℕ)))
        = r * (∑ k : Fin n, c k.succ * r ^ ((k : ℕ))) := by
      rw [Finset.mul_sum]
      apply Finset.sum_congr rfl
      intro k _
      rw [Fin.val_succ, pow_succ]
      ring
    rw [h_shift, ← h_pow]
    rw [show (∑ i : Fin n, ∑ j : Fin n,
                c i.succ * c j.succ * toeplitzKernel r (i : Fin n) (j : Fin n))
            = toeplitzQ r (List.ofFn (fun i : Fin n => c i.succ)) from h_ih]
    ring

/-- **The matrix-style Toeplitz kernel is PSD at every finite dimension.**
Direct consequence of the matrix–list bridge + `toeplitzQ_nonneg`. -/
theorem toeplitzKernelPSD
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) (n : ℕ) :
    KernelPSD (fun i j : Fin n => toeplitzKernel r i j) := by
  intro c
  rw [show (∑ i : Fin n, ∑ j : Fin n, c i * c j * toeplitzKernel r i j)
      = toeplitzQ r (List.ofFn c) from
    toeplitzKernel_sum_eq_toeplitzQ_ofFn r c]
  exact toeplitzQ_nonneg hr0 hr1 (List.ofFn c)

/-- **The finite Toeplitz positive kernel.**
Concrete `FinitePositiveKernel` instantiation from the Toeplitz
covariance kernel of any `r ∈ [0, 1]` — the **RKHS doorway
inhabitant**: a genuine positive-kernel object from a contraction
parameter. -/
noncomputable def toeplitzFinitePositiveKernel
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) (n : ℕ) :
    FinitePositiveKernel where
  ι := Fin n
  K := fun i j => toeplitzKernel r i j
  symmetric i j := by
    unfold toeplitzKernel
    congr 1
    rw [show ((i : ℤ) - (j : ℤ)) = -((j : ℤ) - (i : ℤ)) from by ring]
    exact Int.natAbs_neg _
  psd := toeplitzKernelPSD hr0 hr1 n

/-- Spectral specialization: every spectral contraction pair `S`
yields a finite positive kernel at every dimension `n`. -/
noncomputable def SpectralContractionPair.toeplitzFinitePositiveKernel
    (S : SpectralContractionPair) (n : ℕ) : FinitePositiveKernel :=
  GoldenAlgebra.toeplitzFinitePositiveKernel
    (norm_nonneg S.lam) (le_of_lt S.hlam) n

-- =====================================================================
-- === Tier 25 — Jacobi Feeder: Three-Term Recurrence → HP =============
-- =====================================================================
/-!
## Tier 25 — Jacobi Feeder

The **operator-natural feeder** into the Diamond machinery: a finite
real symmetric tridiagonal (Jacobi) matrix is automatically Hermitian
when cast to `ℂ`, so its characteristic determinant has only real
zeros via Tier 16. A `JacobiFeeder Xi` packages a sequence of
diagonal/off-diagonal data whose Jacobi-matrix charDets converge
locally uniformly to `Xi`.

The classical route to Jacobi data:
* a positive measure `μ` on `ℝ` with finite moments,
* orthonormalize `{1, x, x², ...}` in `L²(μ)`,
* the three-term recurrence coefficients `(aₙ, bₙ)` define the Jacobi
  matrix,
* the truncated `N×N` Jacobi matrix has the `N`-th orthogonal
  polynomial as its characteristic polynomial,
* eigenvalues = roots of the orthogonal polynomial = real and simple,
* under determinacy/Stieltjes conditions, an infinite Jacobi operator
  exists and is self-adjoint.

In the Diamond program: any positive-measure / moment-problem
construction lands automatically in `JacobiFeeder Xi`, and through
the Tier-25 bridge in `HermitianDeterminantApproximation Xi`. The
operator falls out of positivity — it is not guessed.

Components:
* `jacobiMatrixReal a b` — `N×N` real symmetric tridiagonal matrix.
* `jacobiMatrixReal_symm` — symmetric.
* `jacobiMatrix a b` — the `ℂ`-cast.
* `jacobiMatrix_isHermitian` — Hermitian.
* `JacobiFeeder Xi` — the missing-object structure.
* `JacobiFeeder.toHermitianApproximation` — flagship bridge to Diamond.
* `jacobi_diamond_limit` — real-zero conclusion (conditional on
  Hurwitz).
-/

/-- **Real tridiagonal Jacobi matrix** with diagonal `a : Fin N → ℝ`
and off-diagonal `b : Fin N → ℝ` (`b i` is the coupling between rows
`i` and `i+1`; `b (N-1)` is unused). -/
noncomputable def jacobiMatrixReal {N : ℕ} (a b : Fin N → ℝ) :
    Matrix (Fin N) (Fin N) ℝ :=
  fun i j =>
    if i = j then a i
    else if i.val + 1 = j.val then b i
    else if j.val + 1 = i.val then b j
    else 0

/-- The real Jacobi matrix is symmetric. -/
theorem jacobiMatrixReal_symm {N : ℕ} (a b : Fin N → ℝ) :
    (jacobiMatrixReal a b)ᵀ = jacobiMatrixReal a b := by
  ext i j
  show jacobiMatrixReal a b j i = jacobiMatrixReal a b i j
  unfold jacobiMatrixReal
  by_cases hij : i = j
  · subst hij; rfl
  · have hji : j ≠ i := Ne.symm hij
    by_cases h_up : i.val + 1 = j.val
    · have h_not_down : ¬(j.val + 1 = i.val) := by omega
      rw [if_neg hji, if_neg h_not_down, if_pos h_up,
          if_neg hij, if_pos h_up]
    · by_cases h_down : j.val + 1 = i.val
      · rw [if_neg hji, if_pos h_down,
            if_neg hij, if_neg h_up, if_pos h_down]
      · rw [if_neg hji, if_neg h_down, if_neg h_up,
            if_neg hij, if_neg h_up, if_neg h_down]

/-- **Complex Jacobi matrix**: the `ℂ`-cast of `jacobiMatrixReal`. -/
noncomputable def jacobiMatrix {N : ℕ} (a b : Fin N → ℝ) :
    Matrix (Fin N) (Fin N) ℂ :=
  (jacobiMatrixReal a b).map (Complex.ofReal : ℝ → ℂ)

/-- **The Jacobi matrix is Hermitian.** Entries are real-cast (so
`star = id`), and the underlying real matrix is symmetric. -/
theorem jacobiMatrix_isHermitian {N : ℕ} (a b : Fin N → ℝ) :
    (jacobiMatrix a b).IsHermitian := by
  ext i j
  show star ((jacobiMatrix a b) j i) = (jacobiMatrix a b) i j
  unfold jacobiMatrix
  simp only [Matrix.map_apply]
  rw [Complex.star_def, Complex.conj_ofReal]
  exact congr_arg _ (congr_fun (congr_fun (jacobiMatrixReal_symm a b) i) j)

/-- **Jacobi Feeder.**

A sequence of finite Jacobi (tridiagonal real symmetric) matrices
whose characteristic determinants converge locally uniformly to a
target `Xi`. The diagonal `diag N` and off-diagonal `offdiag N`
specify the matrix at step `N`.

Intended source: orthogonal polynomials of a positive measure, with
recurrence coefficients `(aₙ, bₙ)` packaged in `diag`/`offdiag`. -/
structure JacobiFeeder (Xi : ℂ → ℂ) where
  /-- Dimension of the `N`-th truncation. -/
  dim : ℕ → ℕ
  /-- Diagonal of the `N`-th Jacobi matrix. -/
  diag : ∀ N : ℕ, Fin (dim N) → ℝ
  /-- Off-diagonal of the `N`-th Jacobi matrix. -/
  offdiag : ∀ N : ℕ, Fin (dim N) → ℝ
  /-- Local-uniform convergence of `charDet (J_N)` to `Xi`. -/
  locallyUniform :
    TendstoLocallyUniformly
      (fun N : ℕ => fun z : ℂ =>
        charDet (jacobiMatrix (diag N) (offdiag N)) z)
      Xi Filter.atTop
  /-- `Xi` is not identically zero. -/
  nonzero : Xi ≠ 0
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- Each Jacobi charDet is entire. -/
  approx_entire : ∀ N : ℕ,
    AnalyticOnNhd ℂ
      (fun z : ℂ => charDet (jacobiMatrix (diag N) (offdiag N)) z) Set.univ

/-- **Bridge**: a `JacobiFeeder` upgrades to a generic
`HermitianDeterminantApproximation`. -/
noncomputable def JacobiFeeder.toHermitianApproximation
    {Xi : ℂ → ℂ} (H : JacobiFeeder Xi) :
    HermitianDeterminantApproximation Xi where
  dim := H.dim
  matrix := fun N => jacobiMatrix (H.diag N) (H.offdiag N)
  isHermitian := fun N => jacobiMatrix_isHermitian (H.diag N) (H.offdiag N)
  approx := H.locallyUniform
  nonzero := H.nonzero
  entire := H.entire
  approx_entire := H.approx_entire

/-- **Jacobi Diamond limit**: a Jacobi feeder + Hurwitz ⇒ real zeros.

The **operator-natural Diamond corollary**: any orthogonal polynomial
/ moment-problem / continued-fraction construction landing in
`JacobiFeeder Xi` immediately yields `HasOnlyRealZeros Xi`. -/
theorem jacobi_diamond_limit
    {Xi : ℂ → ℂ}
    (H : JacobiFeeder Xi)
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyRealZeros Xi :=
  diamond_HP_limit_principle H.toHermitianApproximation hHurwitz

/-- Critical-line corollary of the Jacobi Diamond limit. -/
theorem jacobi_diamond_critical_line
    {xi : ℂ → ℂ}
    (H : JacobiFeeder (criticalPullback xi))
    (hHurwitz : HurwitzZeroTransferPrinciple) :
    HasOnlyCriticalLineZeros xi := by
  have hreal := jacobi_diamond_limit H hHurwitz
  exact (criticalLineZeros_iff_realZeros_pullback xi).mpr hreal

/-! ## Tier 25 Status Summary

Tier 25 lands the **Jacobi feeder**, the operator-natural feeder into
the Diamond machinery.

Unconditional:
* `jacobiMatrixReal` — real tridiagonal Jacobi matrix.
* `jacobiMatrixReal_symm` — symmetric.
* `jacobiMatrix` — `ℂ`-cast.
* `jacobiMatrix_isHermitian` — Hermitian.
* `JacobiFeeder` — the missing-object structure.
* `JacobiFeeder.toHermitianApproximation` — flagship bridge.

Conditional (Hurwitz only):
* `jacobi_diamond_limit` — real-zero conclusion.
* `jacobi_diamond_critical_line` — critical-line form.

This complements Tier 21 (real-rooted polynomial feeder) and Tier 17
(Golden Hankel feeder) with the **third concrete feeder**:
orthogonal polynomials / continued fractions / Hamburger moment
problem.

The Council's "moment → Hankel → Jacobi → operator" route now has its
final-stage Lean bridge: any analytic side-channel that produces
Jacobi recurrence coefficients lands automatically in the Diamond. -/

-- =====================================================================
-- === Tier 26 — Obstruction Registry Seed: Herglotz / Stieltjes ======
-- =====================================================================
/-!
## Tier 26 — Obstruction Registry Seed

The Council's nonexistence program: build a registry of operator-class
**invariants** that any candidate Hilbert–Pólya operator of a given
class must satisfy. If a target `Xi` fails an invariant, the
corresponding operator class is ruled out.

This tier seeds the registry with the most operator-distinguishing
invariant: the **Herglotz / Stieltjes property**. A Jacobi /
Stieltjes-class HP operator implies that the logarithmic derivative
`−Xi'/Xi` is a Herglotz function (maps the upper half-plane into
itself plus the real axis). The contrapositive: if `−Xi'/Xi` is not
Herglotz, no Jacobi/Stieltjes/continued-fraction model exists.

Components:
* `HerglotzFunction` — abstract definition.
* `XiStieltjesAdmissible` — necessary invariant for Jacobi-class HP.
* `XiStieltjesObstruction` — the contrapositive.

Future tiers can add further class obstructions:
* `CompactSelfAdjointHP` — spectral accumulation at zero.
* `TraceClassHP` — entire-function order constraints.
* `ToeplitzPositivityHP` — Pólya frequency / total positivity tests.
-/

/-- **Herglotz function** on `ℂ`: a function mapping the open upper
half-plane into the closed upper half-plane.

The natural class of "spectral resolvent" functions: traces of
`(zI − H)⁻¹` for self-adjoint `H` (or, more generally, Stieltjes
transforms of positive measures) are Herglotz. -/
def HerglotzFunction (F : ℂ → ℂ) : Prop :=
  ∀ z : ℂ, 0 < z.im → 0 ≤ (F z).im

/-- **Stieltjes-class admissibility** of `Xi`: the logarithmic
derivative `−Xi'/Xi` is Herglotz.

A necessary condition for `Xi` to admit a Jacobi / Stieltjes HP
operator model — i.e., a self-adjoint Jacobi operator `H` whose
resolvent trace gives `Xi'/Xi`. -/
noncomputable def XiStieltjesAdmissible (Xi : ℂ → ℂ) : Prop :=
  HerglotzFunction (fun z : ℂ => -deriv Xi z / Xi z)

/-- **Stieltjes-class obstruction**: `Xi` is not Stieltjes-admissible,
hence no Jacobi/Stieltjes-class HP operator can produce `Xi` as its
characteristic-determinant limit (resolvent-side). -/
noncomputable def XiStieltjesObstruction (Xi : ℂ → ℂ) : Prop :=
  ¬ XiStieltjesAdmissible Xi

/-! ## Tier 26 Status Summary

Tier 26 seeds the **obstruction registry**, the Council's nonexistence
program.

Definitions:
* `HerglotzFunction F` — abstract Herglotz property.
* `XiStieltjesAdmissible Xi` — necessary invariant for Jacobi HP.
* `XiStieltjesObstruction Xi` — contrapositive.

The registry is **opt-in**: each future obstruction class adds
predicates and bridge statements. The Tier 26 model is one of the
sharpest:

  `XiStieltjesObstruction Xi`
    ⇒ no Jacobi/Stieltjes/continued-fraction HP model for `Xi`.

This is one of the Council's "falsification levers": even if the
operator turns out not to exist in a given class, that conclusion
itself is a publication-grade theorem. -/

-- =====================================================================
-- === Tier 25 — Gram Matrix / Quadratic-Form Adapter =================
-- =====================================================================

/-- The **Gram matrix** of a finite positive kernel. -/
noncomputable def FinitePositiveKernel.gram
    (P : FinitePositiveKernel) : Matrix P.ι P.ι ℝ :=
  fun i j => P.K i j

/-- The Gram quadratic form is non-negative — `KernelPSD` in matrix
notation. -/
theorem FinitePositiveKernel.gram_quadratic_nonneg
    (P : FinitePositiveKernel) (c : P.ι → ℝ) :
    0 ≤ ∑ i, ∑ j, c i * c j * P.gram i j :=
  P.psd c

-- =====================================================================
-- === Tier 26 — Semi-Inner-Product Space from a Kernel ================
-- =====================================================================
-- A finite positive kernel canonically induces a *semi*-inner-product
-- geometry. Not a Hilbert space yet — the nullspace is kept explicit.

/-- A finite kernel "vector": a coefficient function on the index type. -/
abbrev FiniteKernelVec (P : FinitePositiveKernel) := P.ι → ℝ

/-- The **raw kernel bilinear form**: `⟪a, b⟫ = Σᵢⱼ aᵢ·bⱼ·K(i,j)`. -/
noncomputable def FinitePositiveKernel.innerRaw
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) : ℝ :=
  ∑ i, ∑ j, a i * b j * P.K i j

/-- The raw kernel form is symmetric. -/
theorem FinitePositiveKernel.innerRaw_symm
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) :
    P.innerRaw a b = P.innerRaw b a := by
  unfold FinitePositiveKernel.innerRaw
  rw [Finset.sum_comm]
  refine Finset.sum_congr rfl (fun x _ => Finset.sum_congr rfl (fun y _ => ?_))
  rw [P.symmetric y x]
  ring

/-- The raw kernel form is non-negative on the diagonal. -/
theorem FinitePositiveKernel.innerRaw_self_nonneg
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) :
    0 ≤ P.innerRaw a a :=
  P.psd a

/-- Left-additivity of the raw kernel form. -/
theorem FinitePositiveKernel.innerRaw_add_left
    (P : FinitePositiveKernel) (a b c : FiniteKernelVec P) :
    P.innerRaw (a + b) c = P.innerRaw a c + P.innerRaw b c := by
  unfold FinitePositiveKernel.innerRaw
  rw [← Finset.sum_add_distrib]
  refine Finset.sum_congr rfl (fun i _ => ?_)
  rw [← Finset.sum_add_distrib]
  refine Finset.sum_congr rfl (fun j _ => ?_)
  simp only [Pi.add_apply]
  ring

/-- Left-homogeneity of the raw kernel form. -/
theorem FinitePositiveKernel.innerRaw_smul_left
    (P : FinitePositiveKernel) (t : ℝ) (a b : FiniteKernelVec P) :
    P.innerRaw (fun i => t * a i) b = t * P.innerRaw a b := by
  unfold FinitePositiveKernel.innerRaw
  rw [Finset.mul_sum]
  refine Finset.sum_congr rfl (fun i _ => ?_)
  rw [Finset.mul_sum]
  refine Finset.sum_congr rfl (fun j _ => ?_)
  ring

/-- Right-additivity (from symmetry + left-additivity). -/
theorem FinitePositiveKernel.innerRaw_add_right
    (P : FinitePositiveKernel) (a b c : FiniteKernelVec P) :
    P.innerRaw a (b + c) = P.innerRaw a b + P.innerRaw a c := by
  rw [P.innerRaw_symm a (b + c), P.innerRaw_add_left b c a,
      P.innerRaw_symm b a, P.innerRaw_symm c a]

-- =====================================================================
-- === Tier 27 — Cauchy–Schwarz and the Kernel Nullspace ==============
-- =====================================================================

/-- **Finite Cauchy–Schwarz for the semi-definite kernel form.**
  `⟪a, b⟫² ≤ ⟪a, a⟫ · ⟪b, b⟫`.
Proved via the discriminant trick: `t ↦ ⟪a + t·b, a + t·b⟫` is
non-negative for all real `t`, so its discriminant is `≤ 0`. -/
theorem FinitePositiveKernel.innerRaw_cauchy_schwarz
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) :
    (P.innerRaw a b) ^ 2 ≤ P.innerRaw a a * P.innerRaw b b := by
  have h_expand : ∀ t : ℝ,
      P.innerRaw (fun i => a i + t * b i) (fun i => a i + t * b i)
        = P.innerRaw a a + t * P.innerRaw a b + t * P.innerRaw b a
            + t ^ 2 * P.innerRaw b b := by
    intro t
    unfold FinitePositiveKernel.innerRaw
    rw [show (∑ i, ∑ j, (a i + t * b i) * (a j + t * b j) * P.K i j)
        = ∑ i, ∑ j, (a i * a j * P.K i j + t * (a i * b j * P.K i j)
            + t * (b i * a j * P.K i j) + t ^ 2 * (b i * b j * P.K i j))
        from by
      refine Finset.sum_congr rfl (fun i _ =>
        Finset.sum_congr rfl (fun j _ => ?_))
      ring]
    simp only [Finset.sum_add_distrib, ← Finset.mul_sum]
  have h_quad : ∀ t : ℝ,
      0 ≤ P.innerRaw b b * (t * t) + 2 * P.innerRaw a b * t
            + P.innerRaw a a := by
    intro t
    have hpos := P.innerRaw_self_nonneg (fun i => a i + t * b i)
    rw [h_expand t, P.innerRaw_symm b a] at hpos
    nlinarith [hpos]
  have h_discrim := discrim_le_zero h_quad
  unfold discrim at h_discrim
  nlinarith [h_discrim]

/-- A kernel vector is **null** when its self-form vanishes. -/
def FinitePositiveKernel.IsNull
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) : Prop :=
  P.innerRaw a a = 0

/-- **Null vectors are orthogonal to everything.**
If `a` is null then `⟪a, b⟫ = 0` for every `b` — the fact that makes
the nullspace quotient honest. -/
theorem FinitePositiveKernel.IsNull_innerRaw_left_zero
    (P : FinitePositiveKernel) {a : FiniteKernelVec P}
    (ha : P.IsNull a) (b : FiniteKernelVec P) :
    P.innerRaw a b = 0 := by
  have hcs := P.innerRaw_cauchy_schwarz a b
  have h_aa : P.innerRaw a a = 0 := ha
  rw [h_aa, zero_mul] at hcs
  have hsq : (P.innerRaw a b) ^ 2 = 0 :=
    le_antisymm hcs (sq_nonneg _)
  exact pow_eq_zero_iff (by norm_num : 2 ≠ 0) |>.mp hsq

/-- The zero vector is null. -/
theorem FinitePositiveKernel.IsNull_zero (P : FinitePositiveKernel) :
    P.IsNull (0 : FiniteKernelVec P) := by
  show P.innerRaw 0 0 = 0
  unfold FinitePositiveKernel.innerRaw
  simp

/-- The nullspace is closed under negation. -/
theorem FinitePositiveKernel.IsNull_neg
    (P : FinitePositiveKernel) {a : FiniteKernelVec P}
    (ha : P.IsNull a) :
    P.IsNull (-a) := by
  show P.innerRaw (-a) (-a) = 0
  have h_aa : P.innerRaw a a = 0 := ha
  have heq : P.innerRaw (-a) (-a) = P.innerRaw a a := by
    unfold FinitePositiveKernel.innerRaw
    refine Finset.sum_congr rfl (fun i _ =>
      Finset.sum_congr rfl (fun j _ => ?_))
    simp only [Pi.neg_apply]
    ring
  rw [heq, h_aa]

/-- The nullspace is closed under scalar multiplication. -/
theorem FinitePositiveKernel.IsNull_smul
    (P : FinitePositiveKernel) (t : ℝ) {a : FiniteKernelVec P}
    (ha : P.IsNull a) :
    P.IsNull (fun i => t * a i) := by
  show P.innerRaw (fun i => t * a i) (fun i => t * a i) = 0
  rw [P.innerRaw_smul_left t a (fun i => t * a i),
      P.innerRaw_symm a (fun i => t * a i),
      P.innerRaw_smul_left t a a]
  have h_aa : P.innerRaw a a = 0 := ha
  rw [h_aa]
  ring

/-- **The nullspace is closed under addition.**
All cross terms vanish by `IsNull_innerRaw_left_zero`. This closes the
quotient loophole: null vectors form a genuine submodule. -/
theorem FinitePositiveKernel.IsNull_add
    (P : FinitePositiveKernel) {a b : FiniteKernelVec P}
    (ha : P.IsNull a) (hb : P.IsNull b) :
    P.IsNull (a + b) := by
  have h_aa : P.innerRaw a a = 0 := ha
  have h_bb : P.innerRaw b b = 0 := hb
  have h_ab : P.innerRaw a b = 0 := P.IsNull_innerRaw_left_zero ha b
  have h_ba : P.innerRaw b a = 0 := P.IsNull_innerRaw_left_zero hb a
  show P.innerRaw (a + b) (a + b) = 0
  rw [P.innerRaw_add_left a b (a + b),
      P.innerRaw_add_right a a b, P.innerRaw_add_right b a b,
      h_aa, h_bb, h_ab, h_ba]
  ring

-- =====================================================================
-- === Tier 28 — Chiral Operator Sieve & Chiral Jacobi Feeder ==========
-- =====================================================================
/-!
## Tier 28 — Chiral Operator Sieve (Steps 92–94, strengthened)

The completed-zeta functional equation `ξ(1−s) = ξ(s)` becomes, in the
critical-line mirror coordinate, *evenness* `D(−z) = D(z)`. A genuine
Hilbert–Pólya operator should not merely have real eigenvalues; it
should **explain** the mirror symmetry `t ↔ −t` through operator
structure.

The operator-side reason for an even determinant is a **chiral
(supersymmetric) structure**: an operator `H` anticommuting with a
grading `Γ` (`ΓHΓ = −H`) has a spectrum paired under `t ↦ −t`, hence
an even characteristic determinant.

This tier:
* strengthens the Step-92 `ChiralOperatorSieveLaw` so it binds an
  actual determinant shadow `D : ℝ → ℂ` (the prior version left
  `determinantEvenFromPairing : Prop` unconstrained — a bad candidate
  could set it to `True`);
* adds the Step-93 `ChiralSymmetryLaw` (grading + anticommutation);
* lands the Step-94 **chiral Jacobi feeder**: a zero-diagonal Jacobi
  matrix is conjugate to its own negative under the alternating sign
  matrix, so its characteristic determinant is mirror-even/odd. At
  even dimension the determinant is genuinely mirror-even, and the
  local-uniform limit inherits the mirror functional equation.

Components:
* `RealDeterminantEven` — evenness of a real-line determinant shadow.
* `ChiralOperatorDetSieveLaw` — Step-92 strengthened, bound to `D`.
* `ChiralSymmetryLaw` — Step-93 grading/anticommutation law.
* `chiralSignMatrix` — the alternating-sign diagonal matrix.
* `chiralSign_conj_zeroDiagJacobi` — `S · J · S = −J` for zero-diagonal
  Jacobi `J`.
* `charDet_zeroDiagJacobi_mirror` — `charDet J (−z) = (−1)ᴺ charDet J z`.
* `ChiralJacobiFeeder` — even-dimensional zero-diagonal Jacobi feeder.
* `ChiralJacobiFeeder.mirror_even` — the limit `Xi` is mirror-even.
-/

-- --- Tier 28.1 — Step 92 strengthened: determinant-bound chiral law --

/-- **Evenness of a real-line determinant shadow**: `D(t) = D(−t)`. -/
def RealDeterminantEven (D : ℝ → ℂ) : Prop :=
  ∀ t : ℝ, D t = D (-t)

/-- **Step 92 (strengthened) — Chiral operator sieve law bound to a
determinant shadow.**

Unlike the prior `ChiralOperatorSieveLaw` (whose
`determinantEvenFromPairing` was an unconstrained `Prop`), this law
carries an actual determinant shadow `D : ℝ → ℂ` and *requires* its
evenness. The chiral paired spectrum is the operator-side explanation;
`RealDeterminantEven D` is the determinant-side consequence. -/
structure ChiralOperatorDetSieveLaw (Eigen : ℝ → Prop) (D : ℝ → ℂ) where
  /-- The spectrum is paired under `t ↦ −t`. -/
  pairedSpectrum : ChiralPairedSpectrum Eigen
  /-- The determinant shadow is genuinely even. -/
  determinantEven : RealDeterminantEven D

/-- A determinant-bound chiral law supplies the Step-70 spectrum
symmetry sieve. -/
theorem ChiralOperatorDetSieveLaw.spectrumSymmetric
    {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralOperatorDetSieveLaw Eigen D) :
    SpectrumSymmetric Eigen :=
  chiralPairedSpectrum_symmetric S.pairedSpectrum

/-- A determinant-bound chiral law supplies determinant evenness. -/
theorem ChiralOperatorDetSieveLaw.det_even
    {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralOperatorDetSieveLaw Eigen D) :
    RealDeterminantEven D :=
  S.determinantEven

-- --- Tier 28.2 — Step 93: chiral symmetry law (grading) -------------

/-- **Step 93 — Chiral symmetry law.**

The operator-native source of spectral pairing: a grading operator `Γ`
exists and anticommutes with the Hamiltonian shadow (`ΓHΓ = −H`),
forcing the spectrum to be paired under `t ↦ −t`.

The `gradingExists` and `anticommutesWithOperator` fields are recorded
as `Prop`s (markers for the operator-theoretic content); the
load-bearing field is `pairedSpectrum`, which the marker fields are
intended to justify once concrete matrix infrastructure is attached. -/
structure ChiralSymmetryLaw (Eigen : ℝ → Prop) where
  /-- A `ℤ/2`-grading operator exists. -/
  gradingExists : Prop
  /-- The grading anticommutes with the operator: `ΓHΓ = −H`. -/
  anticommutesWithOperator : Prop
  /-- The resulting spectrum is paired under `t ↦ −t`. -/
  pairedSpectrum : ChiralPairedSpectrum Eigen

/-- A chiral symmetry law yields a chiral paired spectrum. -/
theorem ChiralSymmetryLaw.toChiralPairedSpectrum
    {Eigen : ℝ → Prop} (S : ChiralSymmetryLaw Eigen) :
    ChiralPairedSpectrum Eigen :=
  S.pairedSpectrum

-- --- Tier 28.3 — Step 94: the alternating-sign matrix ---------------

/-- **Alternating-sign diagonal matrix** `S = diag(1, −1, 1, −1, ...)`.
The `ℤ/2`-grading operator: conjugation by `S` flips the sign of every
off-diagonal entry whose row/column indices differ by an odd amount. -/
noncomputable def chiralSignMatrix (N : ℕ) : Matrix (Fin N) (Fin N) ℂ :=
  Matrix.diagonal (fun i : Fin N => (-1 : ℂ) ^ (i.val))

/-- `S` is an involution: `S · S = 1`. -/
theorem chiralSignMatrix_mul_self (N : ℕ) :
    chiralSignMatrix N * chiralSignMatrix N = 1 := by
  unfold chiralSignMatrix
  rw [Matrix.diagonal_mul_diagonal]
  rw [show (fun i : Fin N => (-1 : ℂ) ^ (i.val) * (-1 : ℂ) ^ (i.val))
        = (fun _ : Fin N => (1 : ℂ)) from ?_]
  · exact Matrix.diagonal_one
  · funext i
    rw [← pow_add, ← two_mul, pow_mul]
    norm_num

/-- **Chiral conjugation of a zero-diagonal Jacobi matrix.**

For a Jacobi matrix with zero diagonal, conjugation by the
alternating-sign matrix negates it: `S · J · S = −J`. This is the
operator-native chiral symmetry: `Γ J Γ = −J`. -/
theorem chiralSign_conj_zeroDiagJacobi {N : ℕ} (b : Fin N → ℝ) :
    chiralSignMatrix N * jacobiMatrix (fun _ => (0 : ℝ)) b * chiralSignMatrix N
      = - jacobiMatrix (fun _ => (0 : ℝ)) b := by
  ext i j
  unfold chiralSignMatrix
  rw [Matrix.mul_diagonal, Matrix.diagonal_mul, Matrix.neg_apply]
  set Mij := jacobiMatrix (fun _ => (0 : ℝ)) b i j with hMij_def
  by_cases hij : i = j
  · have hzero : Mij = 0 := by
      rw [hMij_def]
      unfold jacobiMatrix jacobiMatrixReal
      simp [Matrix.map_apply, hij]
    rw [hzero]; ring
  · by_cases hup : i.val + 1 = j.val
    · have hodd : Odd (i.val + j.val) := ⟨i.val, by omega⟩
      have hsign : (-1 : ℂ) ^ (i.val) * (-1 : ℂ) ^ (j.val) = -1 := by
        rw [← pow_add]
        exact Odd.neg_one_pow hodd
      calc (-1 : ℂ) ^ (i.val) * Mij * (-1 : ℂ) ^ (j.val)
          = ((-1 : ℂ) ^ (i.val) * (-1 : ℂ) ^ (j.val)) * Mij := by ring
        _ = (-1) * Mij := by rw [hsign]
        _ = - Mij := by ring
    · by_cases hdown : j.val + 1 = i.val
      · have hodd : Odd (i.val + j.val) := ⟨j.val, by omega⟩
        have hsign : (-1 : ℂ) ^ (i.val) * (-1 : ℂ) ^ (j.val) = -1 := by
          rw [← pow_add]
          exact Odd.neg_one_pow hodd
        calc (-1 : ℂ) ^ (i.val) * Mij * (-1 : ℂ) ^ (j.val)
            = ((-1 : ℂ) ^ (i.val) * (-1 : ℂ) ^ (j.val)) * Mij := by ring
          _ = (-1) * Mij := by rw [hsign]
          _ = - Mij := by ring
      · have hzero : Mij = 0 := by
          rw [hMij_def]
          unfold jacobiMatrix jacobiMatrixReal
          simp [Matrix.map_apply, hij, hup, hdown]
        rw [hzero]; ring

/-- **Mirror parity of the zero-diagonal Jacobi characteristic
determinant.**

`charDet J (−z) = (−1)ᴺ · charDet J z` for a zero-diagonal Jacobi
matrix `J` of dimension `N`. Proof: conjugation by the alternating
sign matrix gives `S(zI − J)S = zI + J`, and `det S · det S = 1`, so
`det(zI + J) = det(zI − J)`; then `(−z)I − J = −(zI + J)` contributes
the `(−1)ᴺ`. -/
theorem charDet_zeroDiagJacobi_mirror {N : ℕ} (b : Fin N → ℝ) (z : ℂ) :
    charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) (-z)
      = (-1) ^ N * charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) z := by
  set M := jacobiMatrix (fun _ => (0 : ℝ)) b with hM_def
  set S := chiralSignMatrix N with hS_def
  unfold charDet
  have hneg : (-z) • (1 : Matrix (Fin N) (Fin N) ℂ) - M
      = -(z • (1 : Matrix (Fin N) (Fin N) ℂ) + M) := by
    rw [neg_smul]; abel
  rw [hneg, Matrix.det_neg, Fintype.card_fin]
  congr 1
  have hSS : S * S = 1 := chiralSignMatrix_mul_self N
  have hconj : S * (z • (1 : Matrix (Fin N) (Fin N) ℂ) - M) * S
      = z • (1 : Matrix (Fin N) (Fin N) ℂ) + M := by
    rw [Matrix.mul_sub, Matrix.sub_mul]
    have hz1 : S * (z • (1 : Matrix (Fin N) (Fin N) ℂ)) * S
        = z • (1 : Matrix (Fin N) (Fin N) ℂ) := by
      rw [Matrix.mul_smul, Matrix.smul_mul, Matrix.mul_one, hSS]
    have hMM : S * M * S = -M := chiralSign_conj_zeroDiagJacobi b
    rw [hz1, hMM]; abel
  rw [← hconj, Matrix.det_mul, Matrix.det_mul]
  have hSdet : S.det * S.det = 1 := by
    rw [← Matrix.det_mul, hSS, Matrix.det_one]
  calc S.det * (z • (1 : Matrix (Fin N) (Fin N) ℂ) - M).det * S.det
      = (S.det * S.det) * (z • (1 : Matrix (Fin N) (Fin N) ℂ) - M).det := by ring
    _ = (z • (1 : Matrix (Fin N) (Fin N) ℂ) - M).det := by rw [hSdet]; ring

-- --- Tier 28.4 — Step 94: the chiral Jacobi feeder ------------------

/-- **Chiral Jacobi Feeder.**

A `JacobiFeeder` specialized to **zero diagonal and even dimensions**.
Zero diagonal makes each Jacobi matrix chirally symmetric (`S J S = −J`);
even dimension makes the characteristic determinant genuinely
mirror-even. The local-uniform limit `Xi` therefore inherits the
mirror functional equation. -/
structure ChiralJacobiFeeder (Xi : ℂ → ℂ) where
  /-- Dimension of the `N`-th truncation. -/
  dim : ℕ → ℕ
  /-- Dimensions are even (so `(−1)^(dim N) = 1`). -/
  dim_even : ∀ N : ℕ, Even (dim N)
  /-- Off-diagonal of the `N`-th Jacobi matrix. -/
  offdiag : ∀ N : ℕ, Fin (dim N) → ℝ
  /-- Local-uniform convergence of `charDet (J_N)` to `Xi`. -/
  locallyUniform :
    TendstoLocallyUniformly
      (fun N : ℕ => fun z : ℂ =>
        charDet (jacobiMatrix (fun _ => (0 : ℝ)) (offdiag N)) z)
      Xi Filter.atTop
  /-- `Xi` is not identically zero. -/
  nonzero : Xi ≠ 0
  /-- `Xi` is entire. -/
  entire : AnalyticOnNhd ℂ Xi Set.univ
  /-- Each Jacobi charDet is entire. -/
  approx_entire : ∀ N : ℕ,
    AnalyticOnNhd ℂ
      (fun z : ℂ =>
        charDet (jacobiMatrix (fun _ => (0 : ℝ)) (offdiag N)) z) Set.univ

/-- A `ChiralJacobiFeeder` is, in particular, a `JacobiFeeder`
(zero diagonal). -/
noncomputable def ChiralJacobiFeeder.toJacobiFeeder
    {Xi : ℂ → ℂ} (H : ChiralJacobiFeeder Xi) : JacobiFeeder Xi where
  dim := H.dim
  diag := fun _ => fun _ => 0
  offdiag := H.offdiag
  locallyUniform := H.locallyUniform
  nonzero := H.nonzero
  entire := H.entire
  approx_entire := H.approx_entire

/-- **Step 94 flagship — the chiral Jacobi limit is mirror-even.**

If `Xi` is the local-uniform limit of even-dimensional zero-diagonal
Jacobi characteristic determinants, then `Xi` satisfies the mirror
functional equation `Xi(−z) = Xi(z)`.

Each approximant `charDet (J_N)` satisfies
`charDet J_N (−z) = (−1)^(dim N) charDet J_N z = charDet J_N z`
(even dimension), so the `(−z)` and `z` evaluation sequences coincide
and have the same local-uniform limit. -/
theorem ChiralJacobiFeeder.mirror_even
    {Xi : ℂ → ℂ} (H : ChiralJacobiFeeder Xi) :
    MirrorEvenFunction Xi := by
  intro z
  have key : ∀ N : ℕ,
      charDet (jacobiMatrix (fun _ => (0 : ℝ)) (H.offdiag N)) (-z)
        = charDet (jacobiMatrix (fun _ => (0 : ℝ)) (H.offdiag N)) z := by
    intro N
    rw [charDet_zeroDiagJacobi_mirror]
    have hone : (-1 : ℂ) ^ (H.dim N) = 1 := by
      obtain ⟨k, hk⟩ := H.dim_even N
      rw [hk, show k + k = 2 * k from by ring, pow_mul]
      norm_num
    rw [hone, one_mul]
  have hz :=
    (H.locallyUniform.tendstoLocallyUniformlyOn (s := Set.univ)).tendsto_at
      (Set.mem_univ z)
  have hnegz :=
    (H.locallyUniform.tendstoLocallyUniformlyOn (s := Set.univ)).tendsto_at
      (Set.mem_univ (-z))
  have hseq :
      (fun N : ℕ => charDet (jacobiMatrix (fun _ => (0 : ℝ)) (H.offdiag N)) (-z))
        = (fun N : ℕ => charDet (jacobiMatrix (fun _ => (0 : ℝ)) (H.offdiag N)) z) := by
    funext N; exact key N
  rw [hseq] at hnegz
  exact tendsto_nhds_unique hnegz hz

/-! ## Tier 28 Status Summary

Tier 28 lands the **chiral operator sieve** and its first concrete
instance, the chiral Jacobi feeder.

Unconditional:
* `RealDeterminantEven` — evenness of a real-line determinant shadow.
* `ChiralOperatorDetSieveLaw` — Step-92 strengthened: the chiral law
  now binds an actual determinant shadow `D` and requires its
  evenness (no longer an unconstrained `Prop`).
* `ChiralOperatorDetSieveLaw.spectrumSymmetric` / `.det_even` — the
  two bridges.
* `ChiralSymmetryLaw` — Step-93: grading + anticommutation law.
* `chiralSignMatrix` / `chiralSignMatrix_mul_self` — the grading
  involution.
* `chiralSign_conj_zeroDiagJacobi` — `S J S = −J` for zero-diagonal
  Jacobi `J` (operator-native chiral symmetry).
* `charDet_zeroDiagJacobi_mirror` — `charDet J (−z) = (−1)ᴺ charDet J z`.
* `ChiralJacobiFeeder` — even-dimensional zero-diagonal Jacobi feeder.
* `ChiralJacobiFeeder.toJacobiFeeder` — embeds into the Tier-25 feeder.
* **`ChiralJacobiFeeder.mirror_even`** — the flagship: the chiral
  Jacobi limit satisfies the mirror functional equation.

This makes the survivor stack sharper: a chiral Jacobi limit is **both**
real-zeroed (via `jacobi_diamond_limit`, conditional on Hurwitz) **and**
mirror-even (`ChiralJacobiFeeder.mirror_even`, unconditional). The
hypothetical HP operator must now carry the functional equation as
genuine operator parity — not merely have real eigenvalues.

No GoldenAlgebra-specific axiom appears in any Tier 28 proof. -/

-- =====================================================================
-- === Tier 29 — RKHS Quotient Pre-Hilbert Object =====================
-- =====================================================================
-- Quotient the semi-inner-product space by the kernel nullspace. The
-- quotient carries a genuine (non-degenerate) inner product — the
-- honest finite-dimensional RKHS construction. No quotient/nullspace
-- corner is skipped.

/-- Subtraction-additivity of the raw kernel form (left). -/
theorem FinitePositiveKernel.innerRaw_sub_left
    (P : FinitePositiveKernel) (a b c : FiniteKernelVec P) :
    P.innerRaw (a - b) c = P.innerRaw a c - P.innerRaw b c := by
  unfold FinitePositiveKernel.innerRaw
  rw [← Finset.sum_sub_distrib]
  refine Finset.sum_congr rfl (fun i _ => ?_)
  rw [← Finset.sum_sub_distrib]
  refine Finset.sum_congr rfl (fun j _ => ?_)
  simp only [Pi.sub_apply]
  ring

/-- Subtraction-additivity of the raw kernel form (right). -/
theorem FinitePositiveKernel.innerRaw_sub_right
    (P : FinitePositiveKernel) (a b c : FiniteKernelVec P) :
    P.innerRaw a (b - c) = P.innerRaw a b - P.innerRaw a c := by
  rw [P.innerRaw_symm a (b - c), P.innerRaw_sub_left b c a,
      P.innerRaw_symm b a, P.innerRaw_symm c a]

/-- **The raw form respects null equivalence.**
If `a − a'` and `b − b'` are both null, then `⟪a, b⟫ = ⟪a', b'⟫`. The
well-definedness lemma for the quotient inner product. -/
theorem FinitePositiveKernel.innerRaw_respects_null
    (P : FinitePositiveKernel) {a a' b b' : FiniteKernelVec P}
    (ha : P.IsNull (a - a')) (hb : P.IsNull (b - b')) :
    P.innerRaw a b = P.innerRaw a' b' := by
  have h1 : P.innerRaw (a - a') b = 0 :=
    P.IsNull_innerRaw_left_zero ha b
  have h2 : P.innerRaw a' (b - b') = 0 := by
    rw [P.innerRaw_symm a' (b - b')]
    exact P.IsNull_innerRaw_left_zero hb a'
  rw [P.innerRaw_sub_left a a' b] at h1
  rw [P.innerRaw_sub_right a' b b'] at h2
  linarith [h1, h2]

/-- The **null-equivalence setoid**: two kernel vectors are equivalent
when their difference is null. -/
def FinitePositiveKernel.nullSetoid (P : FinitePositiveKernel) :
    Setoid (FiniteKernelVec P) where
  r a b := P.IsNull (a - b)
  iseqv :=
    { refl := fun a => by
        show P.IsNull (a - a)
        rw [sub_self]; exact P.IsNull_zero
      symm := fun {a b} hab => by
        show P.IsNull (b - a)
        rw [← neg_sub]; exact P.IsNull_neg hab
      trans := fun {a b c} hab hbc => by
        show P.IsNull (a - c)
        rw [← sub_add_sub_cancel a b c]
        exact P.IsNull_add hab hbc }

/-- **The finite RKHS quotient**: kernel vectors modulo the nullspace.
The carrier of the honest finite-dimensional reproducing-kernel
Hilbert space (its inner product is non-degenerate by construction). -/
def FinitePositiveKernel.RKHSQuotient (P : FinitePositiveKernel) : Type :=
  Quotient P.nullSetoid

/-- **The induced inner product on the RKHS quotient.**
Well-defined because the raw form respects null equivalence
(`innerRaw_respects_null`). -/
noncomputable def FinitePositiveKernel.inner
    (P : FinitePositiveKernel) :
    P.RKHSQuotient → P.RKHSQuotient → ℝ :=
  Quotient.lift₂ (s₁ := P.nullSetoid) (s₂ := P.nullSetoid)
    P.innerRaw
    (fun _ _ _ _ hab hbb => P.innerRaw_respects_null hab hbb)

/-- The quotient inner product computes via any representatives. -/
theorem FinitePositiveKernel.inner_mk
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) :
    P.inner (Quotient.mk P.nullSetoid a) (Quotient.mk P.nullSetoid b)
      = P.innerRaw a b :=
  rfl

/-- The quotient inner product is symmetric. -/
theorem FinitePositiveKernel.inner_symm
    (P : FinitePositiveKernel) (x y : P.RKHSQuotient) :
    P.inner x y = P.inner y x := by
  refine Quotient.inductionOn₂ x y (fun a b => ?_)
  exact P.innerRaw_symm a b

/-- The quotient inner product is non-negative on the diagonal. -/
theorem FinitePositiveKernel.inner_self_nonneg
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) :
    0 ≤ P.inner x x := by
  refine Quotient.inductionOn x (fun a => ?_)
  exact P.innerRaw_self_nonneg a

/-- **Non-degeneracy of the quotient inner product.**
If `⟪x, x⟫ = 0` then `x` is the zero class. This is the property that
the raw semi-inner-product *lacked*; the quotient construction supplies
it, completing the honest pre-Hilbert structure. -/
theorem FinitePositiveKernel.inner_self_eq_zero
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) :
    P.inner x x = 0 ↔ x = Quotient.mk P.nullSetoid 0 := by
  refine Quotient.inductionOn x (fun a => ?_)
  constructor
  · intro h
    apply Quotient.sound
    show P.IsNull (a - 0)
    rw [sub_zero]
    exact h
  · intro h
    have hnull : P.IsNull (a - 0) := Quotient.exact h
    rw [sub_zero] at hnull
    exact hnull

-- =====================================================================
-- === Tier 30 — Reproducing Property =================================
-- =====================================================================

open Classical in
/-- The **kernel section** at index `i`: the indicator coefficient
vector `j ↦ [j = i]`. Represents the kernel "function" `K(·, i)`. -/
noncomputable def FinitePositiveKernel.kernelSection
    (P : FinitePositiveKernel) (i : P.ι) : FiniteKernelVec P :=
  fun j => if j = i then 1 else 0

/-- **Raw evaluation** of a kernel vector at an index:
  `evalRaw a i = Σⱼ aⱼ · K(j, i)`. -/
noncomputable def FinitePositiveKernel.evalRaw
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) (i : P.ι) : ℝ :=
  ∑ j, a j * P.K j i

/-- **The reproducing property (raw form).**
  `⟪a, K(·,i)⟫ = evalRaw a i`.
The defining signature of a reproducing kernel: pairing with the
kernel section evaluates the function. -/
theorem FinitePositiveKernel.reproducing_raw
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) (i : P.ι) :
    P.innerRaw a (P.kernelSection i) = P.evalRaw a i := by
  unfold FinitePositiveKernel.innerRaw FinitePositiveKernel.kernelSection
    FinitePositiveKernel.evalRaw
  refine Finset.sum_congr rfl (fun x _ => ?_)
  rw [Finset.sum_eq_single i]
  · rw [if_pos rfl]; ring
  · intro y _ hy; rw [if_neg hy]; ring
  · intro h; exact absurd (Finset.mem_univ i) h

/-- **The Toeplitz / spectral-contraction finite RKHS.**
Every spectral contraction pair `S` generates, at every finite
dimension `n`, an honest finite-dimensional reproducing-kernel Hilbert
space — the quotient of the Toeplitz semi-inner-product space by its
nullspace. -/
def SpectralContractionPair.finiteRKHS
    (S : SpectralContractionPair) (n : ℕ) : Type :=
  (S.toeplitzFinitePositiveKernel n).RKHSQuotient

/-- The reproducing property for the spectral Toeplitz RKHS. -/
theorem SpectralContractionPair.toeplitz_reproducing
    (S : SpectralContractionPair) (n : ℕ)
    (a : FiniteKernelVec (S.toeplitzFinitePositiveKernel n))
    (i : Fin n) :
    (S.toeplitzFinitePositiveKernel n).innerRaw a
        ((S.toeplitzFinitePositiveKernel n).kernelSection i)
      = (S.toeplitzFinitePositiveKernel n).evalRaw a i :=
  (S.toeplitzFinitePositiveKernel n).reproducing_raw a i

-- =====================================================================
-- === Tier 31 — Euclid Drops: Zero-Pairing, No-Go Schema, Survivors ===
-- =====================================================================
/-!
## Tier 31 — Euclid Drops

Small, clean propositions whose consequences are huge: "if a thing has
this symmetry, then every survivor must pass this gate." Each drop is a
single unavoidable incidence theorem.

The architecture they complete:
* **Feeder classes** prove invariants of their target.
* **Obstruction theorems** kill a feeder class when its invariant fails.
* **Survivor stacks** collect the invariants a serious HP candidate
  must simultaneously carry.
* **Diamond** converts an accepted feeder into a real-zero conclusion.

Drops:
1. `realDeterminantEven_zeroPairing` — even determinant ⇒ paired zeros.
2. `ChiralOperatorDetSieveLaw.zeroPairing` — chiral law ⇒ paired
   determinant zeros.
3. `DeterminantZerosAreEigen` — the zeros-are-eigenvalues predicate.
4. `determinantZeros_paired_of_eigen_paired` — paired spectrum +
   zero=eigen ⇒ paired determinant zeros.
5. `charDet_zeroDiagJacobi_zero_of_odd` — odd chiral dimension forces
   a protected zero mode (finite chiral index shadow).
6. `charDet_zeroDiagJacobi_even_of_even` — even chiral dimension ⇒
   even characteristic determinant.
7. `no_chiralJacobiFeeder_of_not_mirror_even` — no-go: a non-mirror-
   even target admits no chiral Jacobi feeder.
8. `no_model_of_invariant_failure` — the general obstruction schema.
9. `StieltjesJacobiHPModel` / `no_StieltjesJacobiHPModel_of_obstruction`
   — the Herglotz/Stieltjes obstruction as a reusable class.
10. `ChiralSurvivorStack` — the type-level constitution of an HP
    candidate.
11. `mirrorEven_of_even_approximants_tendsto` — the finite-to-limit
    mirror-even transfer lemma.
-/

-- --- Tier 31.1 — Even determinant forces zero pairing ---------------

/-- **Drop 1 — Even determinant ⇒ paired zeros.**

If a determinant shadow `D : ℝ → ℂ` is even (`D t = D (−t)`), its real
zero set is chiral-paired. Determinant parity is no longer merely an
analytic functional-equation fact — it becomes a spectral law. -/
theorem realDeterminantEven_zeroPairing
    {D : ℝ → ℂ} (hD : RealDeterminantEven D) :
    ChiralPairedSpectrum (fun t : ℝ => D t = 0) := by
  intro t
  constructor
  · intro ht
    show D (-t) = 0
    rw [← hD t]; exact ht
  · intro hneg
    show D t = 0
    have h := hD (-t)
    simpa using h.symm.trans hneg

/-- **Drop 2 — Chiral operator determinant law ⇒ paired determinant
zeros.** From the definition, the unavoidable incidence theorem. -/
theorem ChiralOperatorDetSieveLaw.zeroPairing
    {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralOperatorDetSieveLaw Eigen D) :
    ChiralPairedSpectrum (fun t : ℝ => D t = 0) :=
  realDeterminantEven_zeroPairing S.det_even

-- --- Tier 31.2 — Zeros-are-eigenvalues bridge -----------------------

/-- **Drop 3 — The zeros-are-eigenvalues predicate.**

`D t = 0 ↔ Eigen t`: the determinant's real zeros are exactly the
eigenvalues of the spectral predicate. -/
def DeterminantZerosAreEigen (Eigen : ℝ → Prop) (D : ℝ → ℂ) : Prop :=
  ∀ t : ℝ, D t = 0 ↔ Eigen t

/-- **Drop 4 — Paired spectrum + zeros-are-eigen ⇒ paired determinant
zeros.**

Connects two explanations of evenness: "the determinant is even" vs.
"the zeros are eigenvalues, and eigenvalues are ±-paired." A serious
operator must make the two explanations agree. -/
theorem determinantZeros_paired_of_eigen_paired
    {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (hZE : DeterminantZerosAreEigen Eigen D)
    (hPair : ChiralPairedSpectrum Eigen) :
    ChiralPairedSpectrum (fun t : ℝ => D t = 0) := by
  intro t
  constructor
  · intro ht
    exact (hZE (-t)).mpr ((hPair t).mp ((hZE t).mp ht))
  · intro hneg
    exact (hZE t).mpr ((hPair t).mpr ((hZE (-t)).mp hneg))

-- --- Tier 31.3 — Finite chiral index shadow -------------------------

/-- **Drop 5 — Odd chiral dimension forces a protected zero mode.**

An odd-dimensional zero-diagonal Jacobi characteristic determinant
vanishes at zero: `charDet J 0 = 0`. For odd `N`, the mirror parity
`charDet J (−z) = (−1)ᴺ charDet J z` becomes `charDet J 0 = −charDet J 0`,
so `2 · charDet J 0 = 0`, hence `charDet J 0 = 0`.

This is the finite chiral-index shadow: odd chiral systems have a
forced zero mode — the bridge to Dirac operators, supersymmetric
quantum mechanics, and index theory. -/
theorem charDet_zeroDiagJacobi_zero_of_odd
    {N : ℕ} (hodd : Odd N) (b : Fin N → ℝ) :
    charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) 0 = 0 := by
  have h := charDet_zeroDiagJacobi_mirror b 0
  rw [neg_zero, Odd.neg_one_pow hodd] at h
  have h2 : (2 : ℂ) * charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) 0 = 0 := by
    linear_combination h
  rcases mul_eq_zero.mp h2 with hc | hc
  · exact absurd hc (by norm_num)
  · exact hc

/-- **Drop 6 — Even chiral dimension ⇒ even characteristic determinant.**

For even-dimensional zero-diagonal Jacobi matrices, the real-line
characteristic determinant is even. Packages the chiral parity into a
reusable `RealDeterminantEven` fact. -/
theorem charDet_zeroDiagJacobi_even_of_even
    {N : ℕ} (heven : Even N) (b : Fin N → ℝ) :
    RealDeterminantEven
      (fun t : ℝ => charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) (t : ℂ)) := by
  intro t
  show charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) ((t : ℝ) : ℂ)
     = charDet (jacobiMatrix (fun _ => (0 : ℝ)) b) (((-t : ℝ)) : ℂ)
  have hcast : (((-t : ℝ)) : ℂ) = -((t : ℝ) : ℂ) := by push_cast; ring
  rw [hcast, charDet_zeroDiagJacobi_mirror, Even.neg_one_pow heven, one_mul]

-- --- Tier 31.4 — The obstruction schema -----------------------------

/-- **Drop 8 — The general obstruction schema.**

If a model class implies an invariant, failure of the invariant kills
the class. Every no-go theorem becomes a one-liner through this.

`ModelExists` ranges over `Sort*` so the schema covers both
`Prop`-valued models and `Type`-valued (structure) model classes; the
conclusion is `ModelExists → False` (which is `¬ ModelExists` when
`ModelExists` is a `Prop`). -/
theorem no_model_of_invariant_failure
    {Invariant : Prop} {ModelExists : Sort*}
    (h : ModelExists → Invariant) (hnot : ¬ Invariant) :
    ModelExists → False :=
  fun hm => hnot (h hm)

/-- **Drop 7 — No-go: a non-mirror-even target admits no chiral Jacobi
feeder.**

`ChiralJacobiFeeder Xi → MirrorEvenFunction Xi`, so the contrapositive
rules out the whole chiral-Jacobi feeder class. (`ChiralJacobiFeeder`
is a data-carrying structure, hence `Type`-valued; the no-go is stated
as `… → False`.) -/
theorem no_chiralJacobiFeeder_of_not_mirror_even
    {Xi : ℂ → ℂ} (hnot : ¬ MirrorEvenFunction Xi) :
    ChiralJacobiFeeder Xi → False :=
  no_model_of_invariant_failure (fun F => F.mirror_even) hnot

/-- **Drop 9 — Stieltjes/Jacobi HP model class.**

Any Stieltjes/Jacobi-class HP model must satisfy the Herglotz
invariant `XiStieltjesAdmissible`. -/
structure StieltjesJacobiHPModel (Xi : ℂ → ℂ) where
  /-- The Herglotz/Stieltjes admissibility invariant. -/
  admissible : XiStieltjesAdmissible Xi
  /-- Remaining model data (operator construction). -/
  modelData : Prop

/-- **Drop 9 (no-go) — Herglotz/Stieltjes obstruction kills the
Stieltjes/Jacobi class.** Stated as `… → False` since
`StieltjesJacobiHPModel` is a data-carrying `Type`. -/
theorem no_StieltjesJacobiHPModel_of_obstruction
    {Xi : ℂ → ℂ} (hObs : XiStieltjesObstruction Xi) :
    StieltjesJacobiHPModel Xi → False :=
  no_model_of_invariant_failure
    (fun M : StieltjesJacobiHPModel Xi => M.admissible) hObs

-- --- Tier 31.5 — The chiral survivor stack --------------------------

/-- **Drop 10 — The chiral survivor stack.**

The type-level constitution of a serious Hilbert–Pólya candidate: a
target `Xi` together with a spectral predicate `Eigen` and determinant
shadow `D` satisfying the parity, spectral, determinant, and Herglotz
constraints. Not an analytic proof — the bundled set of gates a
candidate must simultaneously pass. -/
structure ChiralSurvivorStack
    (Xi : ℂ → ℂ) (Eigen : ℝ → Prop) (D : ℝ → ℂ) where
  /-- Mirror functional equation. -/
  mirrorEven : MirrorEvenFunction Xi
  /-- Chiral operator determinant law. -/
  chiralDetLaw : ChiralOperatorDetSieveLaw Eigen D
  /-- Determinant zeros are exactly the eigenvalues. -/
  zerosAreEigen : DeterminantZerosAreEigen Eigen D
  /-- Herglotz/Stieltjes admissibility. -/
  stieltjesAdmissible : XiStieltjesAdmissible Xi
  /-- Zeta-lock constraint (placeholder for the arithmetic gate). -/
  zetaLock : Prop
  /-- Prime explicit-formula / trace compatibility (placeholder). -/
  primeTraceLaw : Prop
  /-- Riemann–von Mangoldt counting-law compatibility (placeholder). -/
  countingLaw : Prop

/-- A chiral survivor stack supplies the spectrum-symmetry sieve. -/
theorem ChiralSurvivorStack.spectrumSymmetric
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralSurvivorStack Xi Eigen D) :
    SpectrumSymmetric Eigen :=
  S.chiralDetLaw.spectrumSymmetric

/-- A chiral survivor stack supplies paired determinant zeros — both
parity explanations agree (Drop 4 applied to the stack). -/
theorem ChiralSurvivorStack.detZeroPairing
    {Xi : ℂ → ℂ} {Eigen : ℝ → Prop} {D : ℝ → ℂ}
    (S : ChiralSurvivorStack Xi Eigen D) :
    ChiralPairedSpectrum (fun t : ℝ => D t = 0) :=
  determinantZeros_paired_of_eigen_paired
    S.zerosAreEigen S.chiralDetLaw.pairedSpectrum

-- --- Tier 31.6 — Finite-to-limit mirror transfer --------------------

/-- **Drop 11 — Finite-to-limit mirror transfer.**

If every approximant `F n` is mirror-even and `F → Xi` locally
uniformly, then the limit `Xi` is mirror-even. This abstracts the
heart of `ChiralJacobiFeeder.mirror_even` — reusable for *any*
even-approximant feeder (Jensen, orthogonal-polynomial, determinant). -/
theorem mirrorEven_of_even_approximants_tendsto
    {F : ℕ → ℂ → ℂ} {Xi : ℂ → ℂ}
    (hEven : ∀ n : ℕ, MirrorEvenFunction (F n))
    (hConv : TendstoLocallyUniformly F Xi Filter.atTop) :
    MirrorEvenFunction Xi := by
  intro z
  have hz :=
    (hConv.tendstoLocallyUniformlyOn (s := Set.univ)).tendsto_at (Set.mem_univ z)
  have hnegz :=
    (hConv.tendstoLocallyUniformlyOn (s := Set.univ)).tendsto_at (Set.mem_univ (-z))
  have hseq : (fun n : ℕ => F n (-z)) = (fun n : ℕ => F n z) := by
    funext n; exact hEven n z
  rw [hseq] at hnegz
  exact tendsto_nhds_unique hnegz hz

/-! ## Tier 31 Status Summary

Tier 31 lands the **Euclid drops** — small unavoidable propositions
that turn the project into a classification engine.

Zero-pairing:
* `realDeterminantEven_zeroPairing` — even `D` ⇒ paired zeros.
* `ChiralOperatorDetSieveLaw.zeroPairing` — chiral law ⇒ paired zeros.
* `DeterminantZerosAreEigen` / `determinantZeros_paired_of_eigen_paired`
  — the two parity explanations reconciled.

Finite chiral index:
* `charDet_zeroDiagJacobi_zero_of_odd` — odd dimension ⇒ protected
  zero mode.
* `charDet_zeroDiagJacobi_even_of_even` — even dimension ⇒ even
  determinant.

Obstruction schema:
* `no_model_of_invariant_failure` — the general no-go pattern.
* `no_chiralJacobiFeeder_of_not_mirror_even` — chiral-Jacobi no-go.
* `StieltjesJacobiHPModel` / `no_StieltjesJacobiHPModel_of_obstruction`
  — the Herglotz/Stieltjes class + its obstruction.

Survivor stack & transfer:
* `ChiralSurvivorStack` — the type-level constitution of an HP
  candidate, with projections `.spectrumSymmetric`, `.detZeroPairing`.
* `mirrorEven_of_even_approximants_tendsto` — the reusable
  finite-to-limit mirror transfer lemma.

The game is now explicit: a candidate `Xi` either passes every gate
(mirror parity, Herglotz/Stieltjes, chiral pairing, …) and admits a
feeder — or it fails an invariant and an obstruction theorem kills the
corresponding operator class. No GoldenAlgebra-specific axiom appears
in any Tier 31 proof. -/

-- =====================================================================
-- === Tier 32 — RKHS Euclidean Geometry: Norm, Distance, Sections ====
-- =====================================================================
-- Expose the finite RKHS quotient's *elementary geometry*: norm,
-- distance, kernel-section Gram identity, two-point determinant
-- positivity, Pythagoras, evaluation boundedness.

/-- The **RKHS norm squared** of a quotient class. -/
noncomputable def FinitePositiveKernel.normSq
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) : ℝ :=
  P.inner x x

/-- The norm squared is non-negative. -/
theorem FinitePositiveKernel.normSq_nonneg
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) :
    0 ≤ P.normSq x :=
  P.inner_self_nonneg x

/-- The norm squared vanishes exactly on the zero class. -/
theorem FinitePositiveKernel.normSq_eq_zero_iff
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) :
    P.normSq x = 0 ↔ x = Quotient.mk P.nullSetoid 0 :=
  P.inner_self_eq_zero x

/-- **Raw distance squared** between two kernel vectors. -/
noncomputable def FinitePositiveKernel.distSqRaw
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) : ℝ :=
  P.innerRaw (a - b) (a - b)

/-- The raw distance squared is non-negative. -/
theorem FinitePositiveKernel.distSqRaw_nonneg
    (P : FinitePositiveKernel) (a b : FiniteKernelVec P) :
    0 ≤ P.distSqRaw a b :=
  P.innerRaw_self_nonneg _

/-- The raw distance from a vector to itself is zero. -/
theorem FinitePositiveKernel.distSqRaw_self
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) :
    P.distSqRaw a a = 0 := by
  unfold FinitePositiveKernel.distSqRaw
  rw [sub_self]
  exact P.IsNull_zero

/-- **The raw kernel-section Gram identity.**
  `⟪K(·,i), K(·,j)⟫ = K(i,j)`. -/
theorem FinitePositiveKernel.innerRaw_kernelSection
    (P : FinitePositiveKernel) (i j : P.ι) :
    P.innerRaw (P.kernelSection i) (P.kernelSection j) = P.K i j := by
  unfold FinitePositiveKernel.innerRaw FinitePositiveKernel.kernelSection
  rw [Finset.sum_eq_single i]
  · rw [Finset.sum_eq_single j]
    · rw [if_pos rfl, if_pos rfl]; ring
    · intro y _ hy; rw [if_neg hy]; ring
    · intro h; exact absurd (Finset.mem_univ j) h
  · intro x _ hx
    apply Finset.sum_eq_zero
    intro y _
    rw [if_neg hx]; ring
  · intro h; exact absurd (Finset.mem_univ i) h

/-- The **kernel section class** in the RKHS quotient. -/
noncomputable def FinitePositiveKernel.sectionClass
    (P : FinitePositiveKernel) (i : P.ι) : P.RKHSQuotient :=
  Quotient.mk P.nullSetoid (P.kernelSection i)

/-- **The kernel = Gram geometry.**
  `⟪K_i, K_j⟫ = K(i,j)`.
The geometric collapse: the abstract RKHS inner product of section
classes recovers the concrete kernel value. -/
theorem FinitePositiveKernel.inner_section_section
    (P : FinitePositiveKernel) (i j : P.ι) :
    P.inner (P.sectionClass i) (P.sectionClass j) = P.K i j := by
  unfold FinitePositiveKernel.sectionClass
  rw [P.inner_mk]
  exact P.innerRaw_kernelSection i j

/-- The squared norm of a kernel section is the diagonal kernel value. -/
theorem FinitePositiveKernel.normSq_section
    (P : FinitePositiveKernel) (i : P.ι) :
    P.normSq (P.sectionClass i) = P.K i i := by
  unfold FinitePositiveKernel.normSq
  exact P.inner_section_section i i

/-- **Raw section distance squared:**
  `dist²(K_i, K_j) = K(i,i) + K(j,j) − 2·K(i,j)`. -/
theorem FinitePositiveKernel.distSqRaw_section
    (P : FinitePositiveKernel) (i j : P.ι) :
    P.distSqRaw (P.kernelSection i) (P.kernelSection j)
      = P.K i i + P.K j j - 2 * P.K i j := by
  unfold FinitePositiveKernel.distSqRaw
  rw [P.innerRaw_sub_left, P.innerRaw_sub_right, P.innerRaw_sub_right,
      P.innerRaw_kernelSection, P.innerRaw_kernelSection,
      P.innerRaw_kernelSection, P.innerRaw_kernelSection,
      P.symmetric j i]
  ring

-- --- Tier 33 — Toeplitz section geometry ----------------------------

/-- The Toeplitz kernel diagonal is 1 (ℕ-indexed convenience). -/
theorem toeplitzKernel_diag_one (r : ℝ) (i : ℕ) :
    toeplitzKernel r i i = 1 := by
  unfold toeplitzKernel
  simp

/-- **Spectral Toeplitz section inner product** equals the kernel. -/
theorem SpectralContractionPair.toeplitz_inner_section
    (S : SpectralContractionPair) (n : ℕ) (i j : Fin n) :
    (S.toeplitzFinitePositiveKernel n).inner
        ((S.toeplitzFinitePositiveKernel n).sectionClass i)
        ((S.toeplitzFinitePositiveKernel n).sectionClass j)
      = GoldenAlgebra.toeplitzKernel ‖S.lam‖ i j :=
  (S.toeplitzFinitePositiveKernel n).inner_section_section i j

/-- **Spectral Toeplitz section distance**:
  `dist²(K_i, K_j) = 2 − 2·‖λ‖^|i−j|`.
The contraction parameter as a geometric correlation length. -/
theorem SpectralContractionPair.toeplitz_section_distSq
    (S : SpectralContractionPair) (n : ℕ) (i j : Fin n) :
    (S.toeplitzFinitePositiveKernel n).distSqRaw
        ((S.toeplitzFinitePositiveKernel n).kernelSection i)
        ((S.toeplitzFinitePositiveKernel n).kernelSection j)
      = 2 - 2 * GoldenAlgebra.toeplitzKernel ‖S.lam‖ i j := by
  rw [(S.toeplitzFinitePositiveKernel n).distSqRaw_section i j]
  have hii : (S.toeplitzFinitePositiveKernel n).K i i = 1 :=
    toeplitzKernel_diag_one ‖S.lam‖ i
  have hjj : (S.toeplitzFinitePositiveKernel n).K j j = 1 :=
    toeplitzKernel_diag_one ‖S.lam‖ j
  have hij : (S.toeplitzFinitePositiveKernel n).K i j
      = GoldenAlgebra.toeplitzKernel ‖S.lam‖ i j := rfl
  rw [hii, hjj, hij]
  ring

-- --- Tier 34 — Two-point Gram determinant positivity ----------------

/-- **Two-point Gram determinant positivity** for the Toeplitz kernel:
  `0 ≤ 1 − K(i,j)²`. The Cauchy area inequality. -/
theorem toeplitz_two_point_det_nonneg
    {r : ℝ} (hr0 : 0 ≤ r) (hr1 : r ≤ 1) (i j : ℕ) :
    0 ≤ 1 - (toeplitzKernel r i j) ^ 2 := by
  have h0 : 0 ≤ toeplitzKernel r i j := toeplitzKernel_nonneg hr0 i j
  have h1 : toeplitzKernel r i j ≤ 1 := by
    unfold toeplitzKernel
    exact pow_le_one₀ hr0 hr1
  nlinarith [h0, h1]

/-- Spectral specialization of two-point Gram determinant positivity. -/
theorem SpectralContractionPair.toeplitz_two_point_det_nonneg
    (S : SpectralContractionPair) (i j : ℕ) :
    0 ≤ 1 - (GoldenAlgebra.toeplitzKernel ‖S.lam‖ i j) ^ 2 :=
  GoldenAlgebra.toeplitz_two_point_det_nonneg
    (norm_nonneg _) (le_of_lt S.hlam) i j

-- --- Tier 35 — Orthogonality and Pythagoras -------------------------

/-- Two RKHS classes are **orthogonal** when their inner product
vanishes. -/
def FinitePositiveKernel.Orthogonal
    (P : FinitePositiveKernel) (x y : P.RKHSQuotient) : Prop :=
  P.inner x y = 0

/-- **Pythagoras (raw form).**
If `⟪a, b⟫ = 0` then `‖a + b‖² = ‖a‖² + ‖b‖²`. -/
theorem FinitePositiveKernel.innerRaw_pythagoras
    (P : FinitePositiveKernel) {a b : FiniteKernelVec P}
    (hab : P.innerRaw a b = 0) :
    P.innerRaw (a + b) (a + b) = P.innerRaw a a + P.innerRaw b b := by
  have hba : P.innerRaw b a = 0 := by
    rw [P.innerRaw_symm]; exact hab
  rw [P.innerRaw_add_left, P.innerRaw_add_right, P.innerRaw_add_right,
      hab, hba]
  ring

-- --- Tier 36 — Evaluation Functional Boundedness --------------------

/-- **Evaluation functional on the RKHS quotient.**
Well-defined: `evalRaw a i = ⟪a, K(·,i)⟫` respects null equivalence. -/
noncomputable def FinitePositiveKernel.eval
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) (i : P.ι) : ℝ :=
  Quotient.lift (fun a => P.evalRaw a i)
    (fun a a' h => by
      show P.evalRaw a i = P.evalRaw a' i
      rw [← P.reproducing_raw a i, ← P.reproducing_raw a' i]
      exact P.innerRaw_respects_null h
        (by rw [sub_self]; exact P.IsNull_zero))
    x

/-- Evaluation computes via any representative. -/
theorem FinitePositiveKernel.eval_mk
    (P : FinitePositiveKernel) (a : FiniteKernelVec P) (i : P.ι) :
    P.eval (Quotient.mk P.nullSetoid a) i = P.evalRaw a i :=
  rfl

/-- **Evaluation is bounded** (the analytic RKHS payoff):
  `f(i)² ≤ ‖f‖² · K(i,i)`.
Continuity of the evaluation functional — a defining RKHS property.
Direct consequence of Cauchy–Schwarz + the reproducing property. -/
theorem FinitePositiveKernel.eval_bound_sq
    (P : FinitePositiveKernel) (x : P.RKHSQuotient) (i : P.ι) :
    (P.eval x i) ^ 2 ≤ P.normSq x * P.K i i := by
  refine Quotient.inductionOn x (fun a => ?_)
  show (P.evalRaw a i) ^ 2
      ≤ P.normSq (Quotient.mk P.nullSetoid a) * P.K i i
  rw [← P.reproducing_raw a i]
  have hcs := P.innerRaw_cauchy_schwarz a (P.kernelSection i)
  rw [P.innerRaw_kernelSection i i] at hcs
  have hnormSq : P.normSq (Quotient.mk P.nullSetoid a)
      = P.innerRaw a a := P.inner_mk a a
  rw [hnormSq]
  exact hcs

/-- Evaluation boundedness for the spectral Toeplitz RKHS.
Since `K(i,i) = 1`, evaluation is bounded by the norm: `f(i)² ≤ ‖f‖²`. -/
theorem SpectralContractionPair.toeplitz_eval_bound_sq
    (S : SpectralContractionPair) (n : ℕ)
    (x : (S.toeplitzFinitePositiveKernel n).RKHSQuotient) (i : Fin n) :
    ((S.toeplitzFinitePositiveKernel n).eval x i) ^ 2
      ≤ (S.toeplitzFinitePositiveKernel n).normSq x := by
  have hbound := (S.toeplitzFinitePositiveKernel n).eval_bound_sq x i
  have hii : (S.toeplitzFinitePositiveKernel n).K i i = 1 :=
    toeplitzKernel_diag_one ‖S.lam‖ i
  rw [hii, mul_one] at hbound
  exact hbound

