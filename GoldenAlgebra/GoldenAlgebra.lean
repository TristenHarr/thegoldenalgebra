theorem no_EvenTriangleForcesOddResponse_of_response_not_odd
    {D Response : ℂ → ℂ}
    (hObs : ResponseParityObstruction Response) :
    EvenTriangleForcesOddResponse D Response → False :=
  fun E => hObs E.responseOdd

