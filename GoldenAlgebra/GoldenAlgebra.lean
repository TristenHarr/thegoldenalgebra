-- === Tier 59 — The Operator Construction Ladder =====================
-- =====================================================================
-- Split the monolithic "construct the Hilbert–Pólya operator" debt into
-- a six-rung ladder. Each rung is the precise hypothesis the next
-- depends on; the project can then state exactly which rung is missing.
--
--   Rung 1 — an arithmetic signal exists           (CausalInnovationSignal)
--   Rung 2 — the signal embeds into an RKHS         (FinitePositiveKernel)
--   Rung 3 — the RKHS carries an operator           (SelfAdjointOperatorData.A)
--   Rung 4 — the operator is self-adjoint           (SelfAdjointOperatorData)
--   Rung 5 — zeta poles map into its spectrum       (BoundedHPBridge)
--   Rung 6 — the critical line follows              (criticalShift conclusion)
--
-- Rungs 1–4 are **inhabitable** (Tiers 53–65 construct them). Rung 5 is
-- the genuine RH-strength debt (`BoundedHPBridge.poleToCompactSpectrum`).

/-- **Rung 4 of the construction ladder**: a self-adjoint operator on a
complex Hilbert space. Unlike `BoundedHPBridge`, this rung is
*inhabitable* — Tier 62 constructs inhabitants from any operator. -/
structure SelfAdjointOperatorData where
  /-- The carrier Hilbert space. -/
  H : Type
  /-- Normed group structure. -/
  [instNorm : NormedAddCommGroup H]
  /-- Complex inner product structure. -/
  [instInner : InnerProductSpace ℂ H]
  /-- Completeness. -/
  [instComplete : CompleteSpace H]
  /-- The operator. -/
  A : H →L[ℂ] H
  /-- Self-adjointness. -/
  selfAdjoint : IsSelfAdjoint A

attribute [instance] SelfAdjointOperatorData.instNorm
  SelfAdjointOperatorData.instInner SelfAdjointOperatorData.instComplete

/-- **Rung 4 ⇒ real spectrum.** Every `SelfAdjointOperatorData` has
real spectrum — the Tier 12 spectral-reality theorem, now applied to a
*constructed* (inhabitable) operator rather than a hypothetical one. -/
theorem SelfAdjointOperatorData.spectrum_real
    (D : SelfAdjointOperatorData) :
    ∀ z : ℂ, z ∈ spectrum ℂ D.A → z.im = 0 :=
  fun _ hz => D.selfAdjoint.im_eq_zero_of_mem_spectrum hz

-- =====================================================================
-- === Tier 62 — Self-Adjointization: the Operator-Construction Engine =
-- =====================================================================
-- From *any* bounded operator `N` on a complex Hilbert space, construct
-- a self-adjoint operator `N + N*`. The door from operator data to
-- Hilbert–Pólya geometry.

/-- **Self-adjointization** of an operator: `N + N*`.
The canonical self-adjoint operator built from any bounded operator. -/
noncomputable def selfAdjointization
    {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (N : H →L[ℂ] H) : H →L[ℂ] H :=
  N + star N

/-- The self-adjointization is self-adjoint — manifestly, since
`star (N + star N) = star N + N = N + star N`. -/
theorem selfAdjointization_isSelfAdjoint
    {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (N : H →L[ℂ] H) :
    IsSelfAdjoint (selfAdjointization N) :=
  IsSelfAdjoint.add_star_self N

-- =====================================================================
-- === Tier 64 — Real Spectrum of the Constructed Operator ============
-- =====================================================================

/-- **Real spectrum of the self-adjointization.**
Every constructed operator `N + N*` has spectrum on the real axis.
This is the Tier 12 Hilbert–Pólya engine applied to an operator that
is actually *built*, not merely hypothesized. -/
theorem selfAdjointization_spectrum_real
    {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (N : H →L[ℂ] H) :
    ∀ z : ℂ, z ∈ spectrum ℂ (selfAdjointization N) → z.im = 0 :=
  fun _ hz =>
    (selfAdjointization_isSelfAdjoint N).im_eq_zero_of_mem_spectrum hz

/-- The self-adjointization, packaged as `SelfAdjointOperatorData`
(rung 4 of the ladder). -/
noncomputable def selfAdjointizationData
    {H : Type} [NormedAddCommGroup H] [InnerProductSpace ℂ H]
    [CompleteSpace H] (N : H →L[ℂ] H) : SelfAdjointOperatorData where
  H := H
  A := selfAdjointization N
  selfAdjoint := selfAdjointization_isSelfAdjoint N

-- =====================================================================
-- === Tier 65 — The Toy Hilbert–Pólya Bridge (inhabited) =============
-- =====================================================================

/-- **Toy Hilbert–Pólya bridge**: a self-adjoint operator on a complex
Hilbert space together with its proven real spectrum.

Unlike `BoundedHPBridge`, this structure is **inhabited** — the
operator-construction engine (Tier 62) builds instances. It realizes
rungs 1–4 of the ladder without the RH-strength rung 5
(`poleToCompactSpectrum`). -/
structure ToyHPBridge where
  /-- The carrier Hilbert space. -/
  H : Type
  /-- Normed group structure. -/
  [instNorm : NormedAddCommGroup H]
