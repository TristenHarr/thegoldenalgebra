    ∧
    -- N=12 has the same first 5 terms + extra 1/(1024 n^10)
    (Phi3_poly (2*n) * Phi4_poly (2*n) * Phi6_poly (2*n) * Phi12_poly (2*n)
        / (2*n)^10
      - 1/(1024*n^10)
      = 1 + 1/(4*n^2) + 1/(16*n^4) + 1/(64*n^6) + 1/(256*n^8)) := by
  refine ⟨pentagonal_pair_even_ladder n hn, ?_⟩
  rw [N12_balanced_multiplier_at_2n n hn]
  ring

