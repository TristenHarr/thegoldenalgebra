-- === Phase LXXXIII: New Central-Binomial ζ(5) Identities (PSLQ) ===
-- Two pure ζ(5) identities over `binom(2n, n)` — the standard
-- (alternating) Apéry-like one + a NEW nonalternating identity from
-- a PSLQ scan with residual 10⁻¹²⁰.
-- Alternating:
--   ζ(5) = 2·∑(-1)^{n+1}/(n^5·C(2n,n))
--          − (5/2)·∑(-1)^{n+1}·H^{(2)}_{n−1}/(n^3·C(2n,n))
-- New nonalternating:
--   ζ(5) = (5/2)·S₁ − 3·S₂ + (3/2)·S₃ + (3/2)·S₄ − (9/2)·S₅
-- where the five sums use H_{n−1}, H^{(2)}_{n−1}, H^{(3)}_{n−1},
-- and H_{n−1}·H^{(2)}_{n−1} over `n^k·C(2n,n)`.
-- Both verified to residual ≈ 10⁻¹²⁰. Both lose the raw-partial-sum
-- race (denominator growth catastrophic, log10(error × denom) → ∞).

-- Use existing `genHarmonic : ℕ → ℕ → ℝ` and `centralBinomial : ℕ → ℕ`
-- defined earlier in the file (lines 14845, 16692).

/-- The five PSLQ partial sums for the nonalternating identity
(uses existing `genHarmonic` and `centralBinomial`). All sums in ℝ. -/
noncomputable def aperySum_S1 (M : ℕ) : ℝ :=
  ∑ n ∈ Finset.Ico 1 (M + 1),
    1 / ((n : ℝ)^5 * (centralBinomial n : ℝ))

noncomputable def aperySum_S2 (M : ℕ) : ℝ :=
  ∑ n ∈ Finset.Ico 1 (M + 1),
    genHarmonic 2 n / ((n : ℝ)^3 * (centralBinomial n : ℝ))

noncomputable def aperySum_S3 (M : ℕ) : ℝ :=
  ∑ n ∈ Finset.Ico 1 (M + 1),
    genHarmonic 1 n / ((n : ℝ)^4 * (centralBinomial n : ℝ))

noncomputable def aperySum_S4 (M : ℕ) : ℝ :=
  ∑ n ∈ Finset.Ico 1 (M + 1),
    genHarmonic 3 n / ((n : ℝ)^2 * (centralBinomial n : ℝ))

noncomputable def aperySum_S5 (M : ℕ) : ℝ :=
  ∑ n ∈ Finset.Ico 1 (M + 1),
    (genHarmonic 1 n * genHarmonic 2 n)
      / ((n : ℝ)^2 * (centralBinomial n : ℝ))

/-- **PROVED — `aperySum_S1 0 = 0`.** Empty sum. -/
theorem aperySum_S1_empty : aperySum_S1 0 = 0 := by
  unfold aperySum_S1; simp

/-- **PROVED — `aperySum_S2 0 = 0`.** Empty sum. -/
