    (S : CotangentTraceZetaSource) :
    ∀ ρ : ℂ, NontrivialZetaZero ρ → OnCriticalLine ρ :=
  LocalGlobalZetaSource_implies_zeta_critical_line
    S.toLocalGlobalZetaSource

-- Step 121: higher log-derivative / spectral moment hierarchy.

/--
Higher-derivative trace hierarchy: repeated derivatives of the
log-derivative encode higher spectral sums / moments (pair correlation
and beyond). A fake determinant matching poles can still fail the
higher trace identities.
-/
structure HigherTraceDerivativeLaw
    (Eigen : ℝ → Prop) (detZ : ℂ → ℂ) where
  firstLogDerivativeMatchesTrace : Prop
  secondDerivativeMatchesPairCorrelation : Prop
  higherDerivativeMomentLaws : Prop
  compatibleWithPrimePowerDerivatives : Prop

