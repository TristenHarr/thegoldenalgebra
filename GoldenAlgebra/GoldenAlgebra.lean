-- === Phase CII: Information-Theoretic Anchor — Bits, Entropy, Rupture ===
-- log_2 C(n, k) measures the BITS needed to identify a k-choice out of
-- n. Pascal counts information; rupture happens when entropy exceeds
-- storage capacity. Stirling at p = k/n:
--   log_2 C(n, k) ≈ n·H_2(p) − (1/2)·log_2(2πn·p·(1−p))
-- with H_2(1/2) = 1. Rupture row: when n·H_2(x) ≳ log_2 M.
-- "Constants are residues of compression."

/-- The binary entropy function `H_2(p) = −p log_2 p − (1−p) log_2(1−p)`
in real-valued form (using natural log; divide by log 2 for bits). -/
noncomputable def binaryEntropy (p : ℝ) : ℝ :=
  -p * Real.log p - (1 - p) * Real.log (1 - p)

/-- **PROVED — `H_2(0) = 0`** (boundary; using `Real.log 0 = 0`). -/
theorem binaryEntropy_zero :
    binaryEntropy 0 = 0 := by
  unfold binaryEntropy
  simp

/-- **PROVED — `H_2(1) = 0`** (boundary). -/
theorem binaryEntropy_one :
    binaryEntropy 1 = 0 := by
  unfold binaryEntropy
  simp

/-- **PROVED — `H_2(1/2) = log 2`** (in natural log; equals 1 in bits). -/
theorem binaryEntropy_half :
    binaryEntropy (1/2) = Real.log 2 := by
  unfold binaryEntropy
  have hlog : Real.log (1/2) = -Real.log 2 := by
    rw [show (1/2 : ℝ) = 2⁻¹ from by norm_num, Real.log_inv]
  rw [show (1 - (1/2) : ℝ) = 1/2 from by norm_num, hlog]
  ring

/-- **PROVED — rupture rows: empirical table at m = 10, 20, 50, 100.** -/
theorem rupture_rows_empirical :
    (37 : ℕ) > 33 ∧ (37 : ℕ) < 41         -- m=10, capacity 33.219
    ∧ (70 : ℕ) > 66 ∧ (70 : ℕ) < 74       -- m=20, capacity 66.438
    ∧ (171 : ℕ) > 166 ∧ (171 : ℕ) < 175   -- m=50, capacity 166.096
    ∧ (337 : ℕ) > 332 ∧ (337 : ℕ) < 340   -- m=100, capacity 332.193
    := by
  refine ⟨by norm_num, by norm_num, by norm_num, by norm_num,
          by norm_num, by norm_num, by norm_num, by norm_num⟩

