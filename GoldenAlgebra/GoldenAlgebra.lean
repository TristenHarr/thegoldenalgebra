-- =====================================================================
-- === Tier 82 — Compactified Zeta Spectral Match =====================
-- =====================================================================

/-- **Compactified zeta spectral match**: the bounded-operator-compatible
form of the pole-to-spectrum map. Instead of placing the raw ordinate
`t` in the spectrum (impossible for unbounded `t`, by Tier 80), it
places the *compactified* ordinate `cayleyOrdinate t`.

The architecturally honest version of `ExactZetaSpectralMatch` for a
bounded HP operator. -/
structure CompactZetaSpectralMatch (T : ToyHPBridge) where
  /-- The compactified pole-to-spectrum map. -/
  poleToCompactSpectrum :
    ∀ ρ : ℂ, CriticalStrip ρ → IsPole xiLikeReciprocalResponse ρ →
      ∃ t : ℝ, (cayleyOrdinate t : ℂ) ∈ spectrum ℂ T.A
        ∧ ρ = criticalShift t

/-- A compactified match still pins poles to the critical mirror:
each matched pole is a critical-shift point, hence mirror-fixed. -/
theorem CompactZetaSpectralMatch.pole_on_mirror
    {T : ToyHPBridge} (M : CompactZetaSpectralMatch T) (ρ : ℂ)
    (hstrip : CriticalStrip ρ)
    (hpole : IsPole xiLikeReciprocalResponse ρ) :
    criticalReflection ρ = ρ := by
  obtain ⟨t, _, hρ⟩ := M.poleToCompactSpectrum ρ hstrip hpole
  rw [hρ]
  exact criticalShift_fixed_by_reflection t

/-- **The only-missing-map theorem (compactified).**
A `ToyHPBridge` *plus* a `CompactZetaSpectralMatch` assembles into a
genuine `BoundedHPBridge`.

This is the compactified successor of the removed
`BoundedHPBridge.ofToyAndMatch`: every component of a true Hilbert–Pólya
bridge is already constructed except the single field
`CompactZetaSpectralMatch.poleToCompactSpectrum`. The gap is not a vague
"construct an operator" — it is exactly one map, and that map now
respects the bounded-spectrum obstruction of Tier 80. -/
noncomputable def BoundedHPBridge.ofToyAndCompactMatch
    (T : ToyHPBridge) (M : CompactZetaSpectralMatch T) : BoundedHPBridge where
  H := T.H
  A := T.A
  selfAdjoint := T.selfAdjoint
  poleToCompactSpectrum := M.poleToCompactSpectrum

