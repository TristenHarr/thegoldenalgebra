-- === Phase XCVI: Error-Wave Defect + Five-Layer Hierarchy + Bernoulli Bridge ===
-- Beyond the limit `E_M = (1 + 1/M)^M → e`, the RESIDUE DEFECT
--   log(E_M/e) = M·log(1 + 1/M) − 1
--             = −1/(2M) + 1/(3M²) − 1/(4M³) + 1/(5M⁴) − …
-- has coefficients c_r = (−1)^r/(r+1). This is the FIRST RESIDUE LAW.
-- The full five-layer hierarchy:
--   Layer 0: C(M, k)              (raw Pascal/factorial)
--   Layer 1: C(M, k)/M^k → 1/k!    (factorial front residue)
--   Layer 2: (1+1/M)^M → e         (exponential boundary)
--   Layer 3: log(E_M/e) → harmonic (logarithmic defect)
--   Layer 4: x/(e^x − 1)           (Bernoulli/zeta gateway)
-- The bridge: factorial → e → harmonic defect → Bernoulli → zeta.

/-- The first residue law coefficient `c_r = (−1)^r / (r+1)`. -/
def firstResidueLawCoeff (r : ℕ) : ℚ :=
  (-1)^r / (r + 1 : ℚ)

/-- **PROVED — `c_1 = −1/2`.** -/
theorem firstResidueLawCoeff_1 :
    firstResidueLawCoeff 1 = -1/2 := by
  unfold firstResidueLawCoeff; norm_num

/-- **PROVED — `c_2 = 1/3`.** -/
theorem firstResidueLawCoeff_2 :
    firstResidueLawCoeff 2 = 1/3 := by
  unfold firstResidueLawCoeff; norm_num

/-- **PROVED — `c_3 = −1/4`.** -/
theorem firstResidueLawCoeff_3 :
    firstResidueLawCoeff 3 = -1/4 := by
  unfold firstResidueLawCoeff; norm_num

/-- **PROVED — `c_4 = 1/5`.** -/
theorem firstResidueLawCoeff_4 :
    firstResidueLawCoeff 4 = 1/5 := by
  unfold firstResidueLawCoeff; norm_num

/-- **PROVED — `c_5 = −1/6`, `c_6 = 1/7`, `c_7 = −1/8`.** -/
theorem firstResidueLawCoeff_5_6_7 :
    firstResidueLawCoeff 5 = -1/6
    ∧ firstResidueLawCoeff 6 = 1/7
    ∧ firstResidueLawCoeff 7 = -1/8 := by
  refine ⟨?_, ?_, ?_⟩ <;> (unfold firstResidueLawCoeff; norm_num)

/-- **PROVED — first residue law alternates in sign.** -/
theorem firstResidueLawCoeff_alternates :
    firstResidueLawCoeff 1 < 0
    ∧ firstResidueLawCoeff 2 > 0
    ∧ firstResidueLawCoeff 3 < 0
    ∧ firstResidueLawCoeff 4 > 0 := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · rw [firstResidueLawCoeff_1]; norm_num
  · rw [firstResidueLawCoeff_2]; norm_num
  · rw [firstResidueLawCoeff_3]; norm_num
  · rw [firstResidueLawCoeff_4]; norm_num

/-- The truncated finite carry-wave defect: partial sum to N terms. -/
def defectPartialSum (M : ℕ) (N : ℕ) : ℚ :=
  ∑ r ∈ Finset.range N, firstResidueLawCoeff (r + 1) / ((M : ℚ)^(r + 1))

/-- **PROVED — first defect term at M=10000 is `−1/20000`.** -/
theorem defectPartialSum_M10000_first_term :
    firstResidueLawCoeff 1 / ((10000 : ℚ)^1) = -1/20000 := by
  rw [firstResidueLawCoeff_1]; norm_num

/-- **PROVED — second defect term at M=10000 is `1/(3·10^8)`.** -/
theorem defectPartialSum_M10000_second_term :
    firstResidueLawCoeff 2 / ((10000 : ℚ)^2) = 1/300000000 := by
  rw [firstResidueLawCoeff_2]; norm_num

/-- **PROVED — `M·(−log correction)` empirical table approaches `1/2`.** -/
