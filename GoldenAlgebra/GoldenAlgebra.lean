-- --- Tier 35.1 — Trace-formula transfer of chiral cancellation ------

/-- **Odd test function**: a test function `f : ℝ → ℂ` with
`f(−t) = −f(t)`. -/
structure OddTestFunction where
  /-- The underlying function. -/
  f : ℝ → ℂ
  /-- Oddness. -/
  odd : ∀ t : ℝ, f (-t) = -f t

/-- A trace formula restricted to odd test functions: spectral and
arithmetic sides agree. -/
structure TraceFormulaOnOddTests
    (Spectral Arithmetic : OddTestFunction → ℂ) where
  /-- The two sides agree on every odd test function. -/
  identity : ∀ φ : OddTestFunction, Spectral φ = Arithmetic φ

/-- The spectral side annihilates odd test functions (chiral
cancellation, Tier 34). -/
structure SpectralOddCancellation (Spectral : OddTestFunction → ℂ) where
  /-- Every odd test function is annihilated. -/
  cancels : ∀ φ : OddTestFunction, Spectral φ = 0

/-- **Flagship — trace formula transfers chiral cancellation to the
arithmetic side.**

If the spectral side cancels odd test functions and the trace formula
holds, then the arithmetic (prime) side also cancels them. Chiral
spectral symmetry forces an arithmetic parity fingerprint.

This is a genuine logical transfer, not a placeholder. -/
theorem traceFormula_odd_arithmetic_cancellation
    {Spectral Arithmetic : OddTestFunction → ℂ}
    (TF : TraceFormulaOnOddTests Spectral Arithmetic)
    (SC : SpectralOddCancellation Spectral) :
    ∀ φ : OddTestFunction, Arithmetic φ = 0 := by
  intro φ
  rw [← TF.identity φ]
  exact SC.cancels φ

-- --- Tier 35.2 — Response parity forces prime-trace parity ----------

/-- **Parity-compatible prime trace.** A prime trace law whose response
function has the parity (oddness) forced by the completed determinant. -/
structure ParityCompatiblePrimeTrace (Response : ℂ → ℂ) (Lambda : ℕ → ℝ) where
  /-- The prime trace law. -/
  primeTrace : PrimeTraceLaw Response Lambda
  /-- The response is odd. -/
  responseOdd : OddFunctionC Response

/-- **Prime-trace parity obstruction**: the response is not odd. -/
def PrimeTraceParityObstruction (Response : ℂ → ℂ) : Prop :=
  ¬ OddFunctionC Response

/-- **No-go**: a non-odd response admits no parity-compatible prime
trace — a prime-trace response with the wrong parity dies. -/
theorem no_ParityCompatiblePrimeTrace_of_response_not_odd
    {Response : ℂ → ℂ} {Lambda : ℕ → ℝ}
    (hObs : PrimeTraceParityObstruction Response) :
    ParityCompatiblePrimeTrace Response Lambda → False :=
  fun P => hObs P.responseOdd

