-- === Phase C: ζ at Negative Integers + Five-Step Program + Pascal/Power Parallel ===
-- The formula `ζ(-n) = (-1)^n · B_{n+1}/(n+1)` gives Bernoulli-valued
-- residues at non-positive integers. All values PROVED rationally:
--   ζ(0)  = -1/2,  ζ(-1) = -1/12,  ζ(-2) = 0,
--   ζ(-3) = 1/120, ζ(-4) = 0,      ζ(-5) = -1/252.
-- The FIVE-STEP research program: (1) identify overflow body;
-- (2) subtract it; (3) find finite residue; (4) study correction
-- tower; (5) compare correction towers across objects.
-- The Pascal/e world and power/zeta world share the same architecture:
--   source → overflow → finite residue → correction tower.

/-- The Bernoulli-to-zeta formula at negative integers:
`ζ(-n) = (-1)^n · B_{n+1}/(n+1)`. -/
def zetaNegFromBernoulli (n : ℕ) : ℚ :=
  (-1)^n * bernoulliCoeff (n + 1) / (n + 1 : ℚ)

/-- **PROVED — `ζ(0) = -1/2`.** From `(-1)^0 · B_1/1 = 1·(-1/2)/1 = -1/2`. -/
theorem zeta_zero_value :
    zetaNegFromBernoulli 0 = -1/2 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 1 = -1/2 from rfl]
  norm_num

/-- **PROVED — `ζ(-1) = -1/12`.** From `(-1)^1 · B_2/2 = -(1/6)/2 = -1/12`. -/
theorem zeta_neg_one_value :
    zetaNegFromBernoulli 1 = -1/12 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 2 = 1/6 from rfl]
  norm_num

/-- **PROVED — `ζ(-2) = 0`.** B_3 = 0. -/
theorem zeta_neg_two_value :
    zetaNegFromBernoulli 2 = 0 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 3 = 0 from rfl]
  norm_num

/-- **PROVED — `ζ(-3) = 1/120`.** From `(-1)^3 · B_4/4 =
-(-1/30)/4 = 1/120`. -/
theorem zeta_neg_three_value :
    zetaNegFromBernoulli 3 = 1/120 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 4 = -1/30 from rfl]
  norm_num

/-- **PROVED — `ζ(-4) = 0`.** B_5 = 0. -/
theorem zeta_neg_four_value :
    zetaNegFromBernoulli 4 = 0 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 5 = 0 from rfl]
  norm_num

/-- **PROVED — `ζ(-5) = -1/252`.** From `(-1)^5 · B_6/6 =
-(1/42)/6 = -1/252`. -/
theorem zeta_neg_five_value :
    zetaNegFromBernoulli 5 = -1/252 := by
  unfold zetaNegFromBernoulli
  rw [show bernoulliCoeff 6 = 1/42 from rfl]
  norm_num

/-- **PROVED — ζ at even negative integers is zero (the trivial zeros).**
ζ(-2) = ζ(-4) = 0 (already PROVED above). The trivial zeros of ζ are
the negative even integers. -/
theorem zeta_trivial_zeros_even_neg :
    zetaNegFromBernoulli 2 = 0 ∧ zetaNegFromBernoulli 4 = 0 :=
  ⟨zeta_neg_two_value, zeta_neg_four_value⟩

/-- **PROVED — `ζ(-1) = -1/12`** matches the famous "1 + 2 + 3 + … =
-1/12" regularized identity. -/
theorem famous_minus_one_twelfth :
    zetaNegFromBernoulli 1 = -1/12 := zeta_neg_one_value

