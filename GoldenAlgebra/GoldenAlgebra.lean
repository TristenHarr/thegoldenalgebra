/-- The finite part of Γ at z = -n. -/
noncomputable def gammaFinitePart (n : ℕ) : ℝ :=
  ((-1)^n : ℝ) * (-(0.5772156649 : ℝ) + ↑(harmonicQ n)) / (Nat.factorial n : ℝ)

