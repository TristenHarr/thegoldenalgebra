      IsPole xiLikeReciprocalResponse ρ →
        ∃ t : ℝ, Eigen t ∧ ρ = criticalShift t

/-- The isolated-zeros bridge yields the minimal HP bridge. -/
def XiLikeIsolatedZerosHPBridge.toMinimalHPBridge
